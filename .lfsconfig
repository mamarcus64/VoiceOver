# Git LFS repository defaults (read by git-lfs).
#
# Bulk "git lfs fetch" / "git lfs pull" with no path filter will not download
# objects until you pass an explicit --include (or override this file locally).
#
# This does NOT stop per-file smudge downloads on checkout. For that, run once:
#   bash scripts/git-lfs-lazy.sh
# or: git lfs install --local --skip-smudge --force
[lfs]
	fetchexclude = *
