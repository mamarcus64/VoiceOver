# Python
venv/
__pycache__/
*.pyc
*.egg-info/

# Node
frontend/node_modules/

# Built frontend (rebuilt from source; backend/static/ is the deploy copy)
frontend/dist/
backend/static/

# Videos (downloaded on-demand via yt-dlp, too large for git)
data/videos/*.mp4
data/videos/*.webm
data/videos/*.mkv

# Annotations (user-generated per-machine, not shipped)
data/annotations/
data/smile_annotations/
data/smile_task_manifest.json
data/smile_config.json

# OpenFace cache (generated locally)
data/eyegaze_vad/_openface_cache/

# Binocular gaze CSVs (very large; keep on disk locally, not versioned)
data/eyegaze_vectors/*
!data/eyegaze_vectors/README.md

# YouTube cookies (contains session credentials, never commit)
youtube_cookies.txt

# OS junk
.DS_Store
Thumbs.db
*.swp
*~

