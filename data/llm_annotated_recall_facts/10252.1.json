{
  "transcript_id": "10252.1",
  "source_file": "10252.1.json",
  "model": "openai/gpt-oss-120b",
  "chunk_words_setting": 800,
  "n_chunks": 4,
  "sentences": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Somerstein, S-O-M-E-R-S-T-E-I-N.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Schonfeld, S-C-H-O-N-F-E-L-D.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Marika, M-A-R-I-K-A.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I had a middle name.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I no longer use it.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "It's Agnes, A-G-N-E-S.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Marika is a nickname.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Marianna-- M-A-R-I-A-N-N-A, but no one would know me by that name.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "March 31, 1936.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Nyiregyhaza-- N-Y-I-R-E-G-Y-A-Z-A.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In Hungary.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It was a small town.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I only remember a small part of the town.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was eight years old when I left the town.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So my memory's of immediate trips from my home to my grandmother's house.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "She also had a store in the middle of town.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "She-- she sold paint and groceries, and it was an interesting trip as a child, to come from my house to that store to get candies and-- [PAUSES FOR 3 SECONDS] I went to school.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The school-- we-- we didn't have any automobiles, that I can recall.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "When my father took a train to Budapest, we would see him to the station, and it was in a horse and a buggy.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Not our horse and a buggy, that was the taxi in the town.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We would go into the middle of the town, and the horse and buggy would take us to the train station.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "I was-- I never left Nyiregyhaza up until 1994 when I was taken away.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "'44, Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I never played with too many of the children in town, only the Jewish children.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "That's what we were.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It was-- it was a very close, Jewish knit community.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "That's all I remember.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, I can't-- I can't say that there was a section, but it was a very small area that the Jews lived.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Our neighbors were not Jewish.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't have any contact with the non-Jewish people in the community.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They didn't-- they didn't come into our home, and we didn't go into their home.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father was a businessman.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He traveled to Vienna, Budapest.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He was a very-- I have fond memories of him as a very elegant, intelligent man.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] He was slim.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And we had-- I don't know if you remember the-- the stoves that, in Europe, have the-- with ceramics.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I remember him standing, always, by it, warming his hands.",
      "recall": true,
      "topics": [
        "Parents",
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And the last memory of my father is when-- before they-- before we were going to leave this town.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "He had a little drink with me, a little sweet liqueur, and I felt very, very grown at the time.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And he told me that he will never come back, and that I should take good care of my mother.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "1944.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My mother was very beautiful-- younger, much younger, than my father.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] She-- she was very angry at him when we left.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Again, you're asking me to remember prior to 1944.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I have a problem with that.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I can't.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It seems that whenever-- that's what I remember-- that year.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "It's like my whole life began then.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "My mother didn't want me to go to this Christian family that my father arranged for me to go to in case we were deported.",
      "recall": true,
      "topics": [
        "Parents",
        "Government"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "There were rumors that we were going to be deported.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And nobody believed it because they believed that the Hungarian government would never allow this, although all the signs were there.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "The Polish children were coming across.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "We were hiding them.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Some Czechoslovakian children-- even in my own home we were hiding.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "But everyone said, it can happen in any other country, but never in Hungary.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I had a very famous lawyer uncle who said, it can never happen.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "The Hungarian government won't let it.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "My father didn't believe it.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "My father knew all along that it will happen, and he took precaution.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "He-- he arranged for me to be hidden, and he arranged for my mother and himself to be hidden in a monastery as a nun and as a priest.",
      "recall": true,
      "topics": [
        "Captivity",
        "Parents"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "What was your father's first name?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "Laszlo, L-A-S-Z-L-O.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "Laszlo.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Lilly, L-I-L-L-Y.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "44.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And my mother was 13 years younger.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, I was an only child.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Bohm.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] Jenu.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Jenu Bohm, B-O-H-M.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS]",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Prior to '44?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Two incidents-- learning Hebrew, to write, read in Hebrew and having very great difficulties, and playing with some of the children in the schoolyard.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember a classroom.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I remember almost nothing.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Well, it was-- I guess, it was second or third grade-- second grade-- that I was in elementary school.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "But I do not remember at all.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Before '44?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My-- my grandmother lived there for-- I would say, in the 1800s.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "That's when they moved to Nyiregyhaza-- my grandmother and my grandfather.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother's name, yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Reggie.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Reggie Schlesenger.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "About 45.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather's name was Jenu.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Jenu, and he passed away prior to the war.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I can't.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we used to go to my grandmother's for Passover.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That I remember very well.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Lots of children.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "My grandmother had six children.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And we all went to her Passover.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I remember Sunday mornings, the housekeeper would take me over there to visit.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And all the six children were in one room, and I was the baby and everybody was playing with me.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "See?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I do remember.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 5 SECONDS] I, also, remember my Uncle Micky leaving for America.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "That was in 1939.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "What was Micky's last name?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Micky Bohm.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Things were getting bad and everybody chipped in-- all the children and the husbands like my father.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "They all chipped in and sent him to America.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "He survived in America, yes.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "He's the one that sent us our affidavit and brought everybody to America eventually.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Of course, Micky, Bela.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Bela survived.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Elizabeth, Edith.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Elizabeth survived.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Edith survived.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Lilly.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Well, my-- Elizabeth lives in Hewlett Harbor who was also interviewed.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] Edith Stern lives in Forest Hill.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "She was also interviewed.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Micky is no longer with us.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He passed away a few years ago.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And his last name was?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Sorry, what was her last name?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Bela's last name?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "All Bohms.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And there was another uncle, Immy, who came back after the war, found me where I was hiding when no one else was back.",
      "recall": true,
      "topics": [
        "Captivity",
        "Post-conflict"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And he went up to Budapest looking for my parents and died of typhus.",
      "recall": true,
      "topics": [
        "Health",
        "Captivity"
      ]
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "'45.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The yellow star.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The Germans came in, and I remember all the adults were very nervous and worried.",
      "recall": true,
      "topics": [
        "Captivity",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And we were told that in order to leave our home, we had to wear a yellow star, and it was very scary for me.",
      "recall": true,
      "topics": [
        "Captivity",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I remember my father being taken to a labor camp and my mother trying to have a doctor help him because he had ulcers, very bad ulcers, and we were worried about his health.",
      "recall": true,
      "topics": [
        "Forced labor",
        "Health",
        "Feelings and thoughts",
        "Captivity"
      ]
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I remember he had a very lucrative business that was taken away from him and given to some Gentile people to run.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We were told that it-- it will be given back to him, but that wasn't the case.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "He had a-- it was a-- he had the first factory where they were making canned goods.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was quite unusual those days for Hungary.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And he tried to make it survive by taking in partners that were not Jewish, but one day, they just came in, and they said, take your coat and leave.",
      "recall": true,
      "topics": [
        "Government"
      ]
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "That's how it was taken away.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes, of course.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They were Hungarian.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "This was before the Nazis came.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Well, that probably would be in about '41, '42.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "There was whispers.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "There was no announcements or nobody that we knew.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And even the Jews had-- were afraid to talk among themselves.",
      "recall": true,
      "topics": [
        "Captivity",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So one day, this one-- we-- we heard that might have been taken to labor camp and, next, somebody else.",
      "recall": true,
      "topics": [
        "Forced labor",
        "Captivity"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "But my father was taken away.",
      "recall": true,
      "topics": [
        "Forced labor",
        "Captivity"
      ]
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "He, actually, was taken away from Nyiregyhaza, but my mother got this doctor's letter and went to see him and got him released to come back home.",
      "recall": true,
      "topics": [
        "Health",
        "Captivity"
      ]
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, this was, again, sometimes, we wondered, in retrospect, that he would have been better off-- had he been in a labor camp, he might have survived.",
      "recall": true,
      "topics": [
        "Forced labor",
        "Health",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "We-- he-- he-- we thought we saved him by bringing him back home because he really was a very sick man-- a young man and a very sick man-- stomach, always had stomach problems.",
      "recall": true,
      "topics": [
        "Health",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "That was, finally, at the end-- that's how he died in concentration camp because of the bad stomach.",
      "recall": true,
      "topics": [
        "Health",
        "Captivity"
      ]
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "My mother had connections with a doctor, took a letter.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I guess, some financial arrangements were made, and my father was allowed to come back home.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Exactly.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The yellow star was the beginning.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "It was the least of the problem.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "About two, three weeks later, they showed a certain part of the town which became the, so-called, ghetto.",
      "recall": true,
      "topics": [
        "Captivity",
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Our home became part of the ghetto.",
      "recall": true,
      "topics": [
        "Captivity",
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "We were right in the center of the ghetto.",
      "recall": true,
      "topics": [
        "Captivity",
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "We had a beautiful home-- beautiful large home.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And if I remember correctly, my mother mentioned to me about 17 families were brought to live in this one home.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "One of my relatives was-- had a problem being with people.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "It was a-- there's a-- there's a illness where you can't be social.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Where she was kind of-- she liked-- she wanted to be alone, and she lived in our pantry.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "We were given a bedroom.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "My mother, my father, and I lived in a bedroom.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "My room was given to a family.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "The living room was given to two families.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "The bed-- I mean, even the kitchen, families were living.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] Next door to us, we owned the house, also.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "In-- you know, in Hungary, they have courtyards.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "And in these courtyards, we had our home and another home.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "We owned both.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "We had a tenant.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "And this tenant, originally-- she was Hungarian, but she had some connections to German-- German background.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "So she was-- she and her husband were entertaining German soldiers while we were in this ghetto.",
      "recall": true,
      "topics": [
        "Captivity",
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "That, I remember-- how before this happened, she used to be nice to me-- the lady.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "After that, she never spoke to me again.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Just Just one child who lived in my home.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish community was taking care of these people, and they asked-- they gave us one child to take care of until the parents can be found.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And-- and she was with us until 1944, and then she was deported with us.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Eva.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My age.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, she was telling us that they were beaten.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And one-- one night her mother and father just put her onto the street, and said, go across the-- it was like a little creek to get into Hungary from Czechoslovakia.",
      "recall": true,
      "topics": [
        "Refugee experiences",
        "Parents"
      ]
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And she just walked across the creek and on her own-- a child-- and until she found the first Jewish person that she could.",
      "recall": true,
      "topics": [
        "Refugee experiences"
      ]
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And that's how she survived.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "My father could.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "My father always believed that this can happen.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "No one else did.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "As soon as the Germans walked into Hungary.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They all fell apart.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "My mother refused to leave her mother.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Refused, said I won't leave.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "My father begged.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "They gave me to a Christian family to hide me.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Three days later, my mother carried on and made such a scene that they had to bring me back.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And you can imagine what it was to smuggle me out of the ghetto and then, smuggle me back into the ghetto.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And [PAUSES FOR 4 SECONDS] my father and mother fought through the whole time about this.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "My father, finally, at the very end, [PAUSES FOR 3 SECONDS] refused to listen and on the-- we were on the wagons to-- see, the-- the way they deported us from Nyiregyhaza, they took everyone to a small little town called Nyirbator, where there were the trains to go to Auschwitz.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I was sitting on top of this mountain of-- of luggage.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And the men and the women were walking.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Only the children and the old people were allowed to be on the-- on the wagon.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And I was wondering why all these people were looking at us.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "I knew them all.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And they were looking, and I was wondering why they're not helping my mother to-- and then, my father sent word to this same gentleman who he knew, who he worked under in the-- in that-- in that very same labor camp that I was telling you about-- and found out that this man needed money very badly and wanted money very badly.",
      "recall": true,
      "topics": [
        "Forced labor",
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And [PAUSES FOR 3 SECONDS] my father sent my aunt, the one that is in Hewlett Harbor now, with a huge bag of money.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "My aunt took me off the wagon, took me to the temple of town.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how the two of us ever got through the stamp or how we were able to move around, but we did, and we got there.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And I waited there for an hour.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And then, I was told to go outside to meet this man.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "I already knew him because this is the same man I lived with for three days prior.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "And I went out, and I had to walk into town, take off my star, and just walk through town and meet him.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "The trouble is, I forgot to take off my star.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Late May.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes, while the people that took me did it for monetary reasons, the monastery, the nuns and the priest outside of-- of Nyiregyhaza, were going to-- they just wanted to help my father.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They knew him prior.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "They liked him.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And they were willing to hide him.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Humanitarian.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Huge.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "They would have been killed, obviously.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "My mother and father were supposed to go to the monastery.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I was going to this Christian family where I was put in a bed and hidden for two years-- in a room in a bed.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Excuse me, two years.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "From 1944 to 1945.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "They never went.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And I did.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "There was a grandmother.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "There was a mother.",
      "recall": true,
      "topics": [
        "Parents"
      ]
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "There were two children.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "The grandmother was very nice to me.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "The rest of the family was not.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "It was for the money.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I am grateful to them.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "They saved my life, but they did not treat me well.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
