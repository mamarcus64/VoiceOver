      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And they-- my records went into some high school.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I decided I wanted to go to Brooklyn Technical High School.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And the assistant principal who spoke Yiddish, he used to talk me.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He said, said no, that's not for you.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "You know.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "He didn't want to insult me, saying, it's difficult or whatever.",
