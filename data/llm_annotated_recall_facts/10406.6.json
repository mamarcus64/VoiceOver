      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "You know.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And then I decided to quit and open up a business making equipment for dental laboratories.",
