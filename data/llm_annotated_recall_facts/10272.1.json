    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] His father's name was [?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Lieb ?] Jacobovitz, and his mother was [?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Chendel ?].",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They lived in a very, very small village, [?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Chandrov ?], not far from Bushtina, where we lived after my father married my mother.",
