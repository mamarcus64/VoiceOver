      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And I was raised in an orthodox religious family.",
      "recall": false,
      "topics": []
    },
