  "sentences": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Sam, Samuel, Koslowski.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "K-O-S-L-O-W-S-K-I.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Wisznice, 18 May, 1920.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "75, Close to 76.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Chaim Koslowksi.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My mother was-- her name was Craindle Koslowski.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did have.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I had four brothers and five sisters.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Blacksmith.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I remember my father's parents.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The mother was Esther, and the father was Nachum.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do have about 40, 50 of them, cousins.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was going to yeshiva all the time.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And after yeshiva lesson, I was going to the Polish school through the seventh grade.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do remember.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we had Pesach, we had Shavuot.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We had Rosh Hashana.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We have Yom Kippur.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We had Sukkot.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did celebrate with my family.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I used to go to school, to the Polish school.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They were big anti-Semites in the school.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "You know, the teacher tried to keep them down, not to discriminate so much.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Like the kids in the school discriminate against Jewish people.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And we went to school until seventh grade.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "The anti-Semitism was so big.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "For example, the Polish children, they used to call me all the time, Jew, Jew.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't pay attention.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Well, one time they started to fight with me, there was a-- and I ran to the teacher, and I told the teacher, they-- they don't let me pass by the street.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And the teacher quieted them down-- stopped them, and not to discriminate so much.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The house was not far from the school.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was a brick house.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We had four rooms, and [PAUSES FOR 4 SECONDS] we had [PAUSES FOR 4 SECONDS] oil [NON-ENGLISH] in-- in this-- in this house.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We used to have a barn which we used to flour the-- the-- the-- flour the-- the-- how do you call?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "The jars?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Make it flour.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Later, they used to bring it into the house, and my mother used to give them such a big dish, and they [PAUSES FOR 3 SECONDS] made it softer, the flour, and they-- they made it oil.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And my father used to be a blacksmith, and he used to have extra-- a bungalow for the blacksmith.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "All my brothers were blacksmiths, because my father helped them to do this.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't like it.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I, myself-- my brother-in-law had a flour mill, and I used to run away to the flour mill to help my brother-in-law by the mortars-- which he likes it.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And he-- I did a lot of work for him, which he used to give me some food [LAUGHS] for the job.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And I was very happy, till my father saw I am not there.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "He used to beat me up.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I should come back.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I had a lot of friends.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We used to go to school and we used to go to yeshiva, we used to go.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And we used to play together, and we had a lot of fun.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I liked it.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "It was very nice.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "There was no discrimination between friends.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "It was nice.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean 'to share'?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do remember my father.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I'm sorry-- I have to mention like I used to run away to the flour mill, and he used to catch me and he used to beat me up.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And that I should go back to be a blacksmith.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I never like it.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember a special friends.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I just remember we used to go to school together.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "We had a lot of fun.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "It was nice.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Could you explain to me what you mean?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "My-- [CRYING] my mother was so nice.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She used to tell me, ignore them.",
      "recall": true,
      "topics": [
        "Parents",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Run by them and just go tell the teacher they bother you, which I did.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And one time, it was a Saturday morning, I and my friend watched the boys, which they used to do a lot of harm to me, we used to watch them.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And when they run out for school, we used to beat them up.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Not special beat them up, but we tried to, for example, to make believe we're going to beat them up.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And the galach came across.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "He was running on-- on the wagon--",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The galach.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "A galach.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You know what it means?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "A galach?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "From the church where they used to sit-- he used to pass by, on a wagon, he was sitting, and he stopped it and I told him the boys, they were beating me up and they discriminated me.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And he took them away and stopped them.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "That he was from the church, that one.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The priest.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "1939, The war broke out.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Like I said, there was danger because they used to beat me up, all the boys from the school, which they belonged to a group, a church group, and they used to beat me up.",
      "recall": true,
      "topics": [
        "Daily life (childhood)",
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was about, for example, there was about 2,000, 3,000 Jews were living.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And about 2,000, 3,000 Catholics were living.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish community didn't-- together.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They never worshipped together.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They-- in our synagogue, we used to go to synagogue Saturday in the morning and at night, every day.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't bother with the Catholics.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "It was.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They were close to each other.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They were nice.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "In 1939, I was a very wild boy, full of life.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I was full of life.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "For example, they said-- the German came to our town in [PAUSES FOR 3 SECONDS] vehicles-- what do you call this?",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I forgot the name, the big tanks-- tanks.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "They came over and I was on the spot in the-- in the-- in the market.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "There was a market there.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And he called me, and maybe recognizing me, I'm Jewish, or maybe not.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And he asked me, do you have-- does a lot of Jews live here?",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I said, not too much, because a lot of them went to Russian-- to the Russian zone, when the Russians came close by and the Germans came out of sight.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And he said to me, I feel sorry for you-- he didn't say for me-- I feel sorry for the Jews, because we're going to kill them.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I think it's funny.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And he run away-- run away.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Then, for example, 1939-- they came in September, October.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "The Germans came.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We didn't bother with them too much.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "The Polish people, they used to attack Jews in the city.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "We used to call the Germans, they should come, because to avoid the Polish people should attack the Jews.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "They came, they didn't bother too much.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "The Germans didn't bother too much.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "In 19-- in May, 1940, the Germans started to catch Jewish boys and girls and to take them to the concentration camps.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I was the one which they called me.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "They took me not far from the city, about 20 miles away, in a small city they called Rozwadowka.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "They took me there.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] In this-- they made empty the school, which the kids who used to go to-- they didn't go to school-- and they put us in-- in the school, and [PAUSES FOR 3 SECONDS] a few days later, they took us to work.",
      "recall": true,
      "topics": [
        "Captivity",
        "Forced labor"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "They took us to work in a-- in a lawn, in a lawn in which grass had been grown.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And they gave us shovels, and they started to tell us to dig in the middle rivers-- and-- to make a river.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "The water should go inside in the middle of the lawn, not all over the lawn.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "I worked over there.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] There was May, June, July, August, September.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "I became sick.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] There came a doctor-- a Polish Jew-- a doctor.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "He told me I have pneumonia.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "[CRYING] He took me to [NON-ENGLISH].",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "He took me to a hospital, with several more boys.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 5 SECONDS] And I was there about two, three weeks, and I became better.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "I remember we didn't have what to eat.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "There was a family, our family, that lived-- [CRYING] and she brought me some food.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "I ate the food she brought me every day, the food, till the doctor came and said, you have to go home.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "All right.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "It became better, the pneumonia-- the pneumonia.",
      "recall": true,
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "And I went home.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "I went home. 2 December, a Polish man came to me, a very nice man, he said to me, come to me to work in the flour mill.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "There was-- for example, they gave us shovels.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They gave us-- we used to go every morning to the place where we used to dig the ground to make the rivers.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Oh, by the way, the-- the-- the engineer from the-- which he took us, his name was [NON-ENGLISH].",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I remember very well his name, because he became friends with me.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "He used to make comments to me and joked around with me.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "There were about 500 people there.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Mostly they were from Miedzyrzec, from a big city.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They were about 30,000, 40,000 Jews living there.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They brought them over from Miedzyrzec to the-- to the Rozwadowka.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And we used to go to work all of the time.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We slept in the-- on the floor with the school.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "On the floor.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The flies and the lice used to eat us up.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "You know, we had straw on the floor, and just a blanket.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "My sister brought it to me and gave it to me.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I was there, and my brother was there.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "An older brother, like me.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Moshe.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My sister-- we had a family, they used to live in the city.",
      "recall": true,
      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "My sister, Chana Sarah, she used to cook for us.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "She had her husband there, and we had Moshe, my brother, and I was there.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "She used to cook for us.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "She couldn't go inside in the ghetto.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "No, she brought the food outside the wires, and I used to-- and we used to take the food to eat.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Nothing then.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We never knew they was going to come a time in which they were going to kill us-- want to kill us.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We never talked about, because the rest of the people from Miedzyrzec, when it got cold in January, they sent them home, too.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "They went home.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We didn't-- you know, you-- you can't go to the other-- to the other cities to hear news, because the Germans would kill you on the road.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We didn't hear nothing from the other cities besides our city.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In December, I used to-- I started to go to work.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Three Germans came and caught me, and I said to him, what do you want from me?",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I'm not a Jew.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Let me go.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "They said to me, oh, no.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I don't believe you.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Let's go to the lady-- her name was Gerchinska-- Ger-chin-ska.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "He took me in to the lady-- they had a store.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "They had German things for sale for the Polish people.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "They took me in, and they asked Gerchinska-- first of all, I talk before she talked.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "I said, I don't know what they want.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "I'm not a Jew.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And they said-- it was three Germans-- they said to her, tell me if he's a Jew or not.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "She said-- she knows me very well-- she says, I don't know him.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "And they let me go.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "They let me go to work.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "I told the [NON-ENGLISH], my boss, the Germans want to catch me, they want to take me away, and later they would kill me there.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "He went over to the German [NON-ENGLISH]-- [NON-ENGLISH], they called him.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "He was a-- a big [NON-ENGLISH], a big man.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "And he brought me a paper, which nobody should touch me.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "And I used to go to work.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "I had a good time.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "I liked it because, you know, he's the one-- he was such a nice man-- he's the one who wanted to help Jews.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "He used to give me flour, he used to give me [PAUSES FOR 4 SECONDS] cereals I should take them home, and we should-- and I should give it to the Jewish people, because they-- we didn't live in the ghetto, our family didn't live in the ghetto.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "Well, we used to live three or four sisters in one house.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "And they brought over, in the ghetto, in Mlawa, people, they should live in the ghetto.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 26,
      "text": "I used to go in once in a while in the ghetto.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The people didn't have straw to sleep in, straw.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They used to sleep on a board, [NON-ENGLISH].",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "You don't understand?",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "On a board.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Like that.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And I used to saw little kids used to die from hunger.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] They couldn't walk, they couldn't move.",
      "recall": true,
      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And the mothers used to go to us-- we weren't in the ghetto-- to steal bread, to steal potatoes.",
      "recall": true,
      "topics": [
        "Daily life (imprisonment)"
      ]
    }
  ]
}