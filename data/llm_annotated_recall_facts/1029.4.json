    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "It's-- you're-- we're lazy when it has to do with emotional things.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "When it has to do with relationships, we're lazy.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "We're lazy to talk.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "We're lazy to bring it up.",
