      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "We're lazy.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "We're afraid.",
