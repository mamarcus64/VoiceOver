        "Parents"
      ]
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "This is a sketch I did in 1990, the way I remember the torture I experienced in 1944 in-- from the [NON-ENGLISH], the Hungarian Nazis internment took place.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "This is a sketch.",
