      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And he could be about six years old.",
      "recall": true,
      "topics": [
        "Other"
      ]
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This is a sketch of mine about my mother, which I did here in 1989, and the way I remember her.",
