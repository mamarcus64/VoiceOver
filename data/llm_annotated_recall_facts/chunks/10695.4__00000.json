    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Don't go to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And I changed my mind to America.",
