  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "That my-- my idea.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He pushed my leg.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He wants to say, you know, that I am-- I am-- I am different.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But I am playing with him, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] He left.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "He came to me somewhere in end of September, mid of September, or the beginning of September.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Klebanow, I'm going with 400 women away.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I need a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Would you like to go with me?",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And now, at that time, I had my wife.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I had my sister-in-law from Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I had my cousin's daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I had some family.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And I will take all your family.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I say, I am afraid-- turned around and left.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "After liberation, I am meeting-- I went to a Dr-- Dr.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], who was also in concentration camp-- in main camp, Kaiserwald.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "There I meet another widow of a doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And when she heard the word, Klebanow-- [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She said who said always my friend Klebanow-- Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Klebanow?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "I say, if somebody, it must be Blatterspiel.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "She say, yes, Blatterspiel very frequent to [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "She were-- went with these 400 woman.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He will always repeat, my friend, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Klebanow.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "The-- two days before the Russians, he send away all the guards.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "One day before the Russians, he told-- gathered them-- first-- the 400 people-- please, don't show up in the windows.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Nobody has to see that-- that you are here.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "It was a camp, camp with-- with barracks, and et cetera.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Don't show up.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Tomorrow are the Russians here-- turned around, and left.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Basically, he saved their lives, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Or in other places, other places there are-- it was the most brutal cases was a place [NON-ENGLISH], where my friend Dr.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] perished, where the SS put the-- commanded them to put the wood, and to lay down, and then to kill them.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And so, what-- whoever was in-- in the-- in the camp, you know, they killed on the-- on the wood.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They burned them.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, no contraceptive devices.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The women basically lived in the-- in women compound and the men in men compound.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in the-- I have a small revere.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It means a small hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And the-- she-- my wife was with the dentist of this-- we-- I had a dentist.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have any sex.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Why not?",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She worked--",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "She worked with me.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "That's my choice.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "It is-- we are in September.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I-- he left-- Blatterspiel-- with the 400 women.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We left.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "The 2,000 Hungarian women were taken away-- disappeared.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And we don't know whether we will-- what will be with us.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And on one day, we're ordered to go to the main camp, Kaiserwald.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "By-- by trucks.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "You must-- it was around, I will say probably around 4,000.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "From the--",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "--from Spilve, everything-- we was taken there.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "It is already-- it was fluctuating.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- a big group of us sent to another camp-- another camp to-- to work from this over there.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "At the end, we had in Spilve around 400 or 500 people.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And with this, we came to the main camp.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Main camp-- that was already typical concentration camp with gas camera-- gas--",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "--gas chamber.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "With all this, you know, we got, you know, new numbers.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "96-- 96043.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "In Kaiserwald.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I had it on my-- on my-- on my this--",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Only Spilve-- only who were in Auschwitz, where-- where they had on the arms-- only Spilve-- only Auschwitz.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "All other camps didn't have any-- any of this.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "96043.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "That is 96,043.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "That was my now number.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "From this 96,000, only maybe 10,000 were in the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "The 83, they were not liberated-- maybe few.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Single persons were liberated.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "They perished in this camp.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Stutthof.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In Stutthof, we came beginning of-- of October.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We came to Kaiserwald only, you know, the-- from there I took-- took us on a-- on a boat.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And they brought us to Stutthof.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Also-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "She went to Stutthof, too.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Here in my camp-- career as a doctor ended.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Here I am a simple, simple guy.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Simple.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Next, terrible conditions in the camp-- appells-- they-- appells, you know-- the--",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "--yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And that is hours and hours in the morning, hours and hours in the evening, rain or shine-- rain or whatever you want-- you know, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "We were in the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "You know, it was three-- three tiers.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In Stutthof, when we came into Stutthof, basically, we didn't do anything.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Food-- got that-- means a piece of bread and in the evening, a water and soup.",
      "word_count": 16
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We came to Stutthof in-- I was remained for approximately four weeks",
      "word_count": 12
    }
  ],
