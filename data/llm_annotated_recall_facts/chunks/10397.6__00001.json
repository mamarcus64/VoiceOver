  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "So it's-- actually, it's Brandwein.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And I remember him as a good father, never laid a hand on me.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And it was-- this picture was taken approximately before he married my mother or right after they married.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was born 1912, so it must have been 1911 or 1910.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Radzivilov. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Radzivilov, yeah. ?]",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Everybody comes from [?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Radzivilov ?]",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "This is a picture of my mother, bless her memory.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Her first name was Rachel, [RUSSIAN] in Russian.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Rachel [?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Baratz ?].",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "That was her maiden name.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And when she married my father, her name was [RUSSIAN], or Rachel, Brand-- Brandwein, B-R-A-N-D-W-E-I-N.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And she was studying medicine to a point when she gave up medicine to marry my father-- that the story goes.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was taken before-- it was before 1912-- before 1911.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Radzivilov. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Russian-- this was Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "This is a, a, a, a picture of my registration book in the Czech university in Prague, first semester.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And that was done in 1930, 1930, first semester before I transferred to the German University.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "This is the registration book of my studies in the German university of Prague in 1931.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And I transferred from German.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but I mean, I registered in 1931.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "That's every semester you have to have a new, you know, stamp and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So that's starting in 1931 until graduation in 1937.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And this book is for registering all the sub-- subjects and all the lectures which are required to complete medical studies.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And this is a picture of my times at the-- being a student in the University of Prague, the German University of Prague, walking on main, on the main streets in rare moments when studying was secondary-- facetious.",
      "word_count": 38
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] '32, '33-- '33 probably, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And that's--",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And [? you-- ?] and an acquaintance of mine.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My name is Michael Brand, is Michael Brand.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I don't remember the lady's name.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, [?",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Mojsiej ?] Brandwein, [?",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Mojsiej ?] Brandwein-- that's how my cert-- birth certificate said, [?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Mojsiej. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture and a certificate taken during the German occupation in about 1942, '40-- 1941-1942.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We had a-- there was an offer to take-- to work as a-- as a doctor in a village near Brody because of epidemic of typhus fever.",
      "word_count": 31
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And it was required, a certificate of-- and a permit from the Ger-- from the German authorities to be able to do that.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And I had to ref-- [? refer ?] the application for a permit to reside in this village every month.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And that's my picture.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And the years are 1931-- no, 1940-- 1940--",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "'42, '43, yeah, '42, '43-- my name is [?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Mojsiej ?] Brandwein.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I got mad at, at that and then scratched it out.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of me and my dear wife.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And it was taken in, in-- [PAUSES FOR 3 SECONDS] here.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In California, in Ventura, about a year ago in the house-- in the, in the yard by the pool-- my son's house.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "It was taken in 19--",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "'94, Yeah, that's right.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "The name is Anna S.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Brand, my wife.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "My name is Michael Brand.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of my immediate family taken a year ago-- from left to right, Abraham, close to 17-year-old, his father, Steve Geller, undernea-- and, and below, the daughter-- CREWl Excuse me.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I lost the battery here.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "This is a picture of my immediate family taken a year ago.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "So that means 19--",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "'94.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "From left to right, Abraham Geller, my grandson-- he is 17 years old.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Then his father, my son-in-law, Steve Geller, below, kneeling, sitting, my granddaughter Shira Geller.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Next is my daughter, Jean Geller.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Next to it is my grandson, Benjamin Geller.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Next to it is my wife, blessed memory, [PAUSES FOR 3 SECONDS] Anna Brand, and me, Michael Brand, Then Mozel, my granddaughter, my son's family, Mozel, who is about 12 years old, my son, Richard Brand, my daughter-in-law, Ellen Brand, my grandson, Mitchel Brand, and my granddaughter, Rachel Brand.",
      "word_count": 49
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It was taken in [PAUSES FOR 4 SECONDS] Cambria, in Cambria a year ago.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "In, in my, in my son's home.",
      "word_count": 7
    }
