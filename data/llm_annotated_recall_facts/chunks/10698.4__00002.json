    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They were grownups.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "One is my brother, Leo Fromer.",
