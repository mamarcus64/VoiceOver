    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I'm so anxious to talk",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know if you can get the 25 in the flower bouquet.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "That was the silver anniversary of my parents, Devor-- Devora Leah Fromer, Mattis Shlomo Fromer.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "It was a huge party for their 25th wedding anniversary.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not-- not children.",
