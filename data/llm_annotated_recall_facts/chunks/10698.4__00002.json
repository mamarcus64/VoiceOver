    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And that's myself.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "This is Devora Leah Fromer, Mattis Shlomo Fromer, and [?",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Nahama ?] Fromer.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Approximately either-- [INAUDIBLE]",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "'28 Or '29.",
