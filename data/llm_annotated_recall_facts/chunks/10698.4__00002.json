    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh my God, certainly.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I was a young school kid when that was taken.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And that was all Warsaw, Poland.",
