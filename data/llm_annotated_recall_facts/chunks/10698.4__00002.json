    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And those guys are nice.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "This picture is of my mother and father.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "This is an enlargement from an original picture that was sent 1938 to the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And I made an enlargement.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Devora Leah, and my father's name, Mattis Shlomo.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Last name Fromer.",
