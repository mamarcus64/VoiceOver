    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "When we went-- yeah-- when the war-- then was in 1939.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I says to my first husband, you go.",
