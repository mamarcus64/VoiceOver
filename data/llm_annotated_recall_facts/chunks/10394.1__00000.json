    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "The-- the-- the bombs-- everything.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And they came, right away.",
