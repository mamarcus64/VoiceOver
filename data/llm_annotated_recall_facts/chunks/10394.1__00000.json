    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't find anything.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, no-- like this, just like this.",
