    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "You know, because it wasn't so good.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I have to make a living.",
