    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Over there I went into school.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Once a week I worked in store.",
