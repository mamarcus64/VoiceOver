  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Sure, I was finished with my medical studies and had worked as a doctor, but I didn't have my diploma, because that was when the Germans came in and cut me off.",
      "word_count": 32
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "So, am I a doctor, or am I not a doctor?",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And there came on a motorcycle a high SS man running-- I mean riding in so the dust-- looked all at us.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We looked terrible after the transport.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We looked really like some beggars afterwards.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And he saw me standing a little bit up [PAUSES FOR 3 SECONDS] away from the rest.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "What's the matter with you?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I-- I am a doctor, but I have not gotten my diploma.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Everybody laughed.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he said you go to the hospital and work there, so you won't forget your medicine.",
      "word_count": 17
    }
  ],
