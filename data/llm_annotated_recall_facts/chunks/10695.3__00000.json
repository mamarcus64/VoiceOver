  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] When we used-- when I used to live in the ground, I made a-- I made a big bunker, a big bunker.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Because we were about 10, 12 people.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And my father gave me to cover at night-- [PAUSES FOR 3 SECONDS] what do they call this?",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "What do they call this?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "A blanket, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "There was goose feathers.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I used to cover myself.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And some boys covered-- help cover them.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] We used to live very tired.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Everything was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Everything was cold, till the springtime come.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I used to go with a gun-- with a gun.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Give me a bread.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they were afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "The Polish people were afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They used to give me bread.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "I want something to-- meat.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] We want to find the place where the cows are.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "We used to take out a cow, a little cow, and take him in the woods, and kill them.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "We used to cook.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "In the daytime, I used to go out and make fire, and cook the meat.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they did.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They did find me.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Several times, several people find me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Or I told them-- I used to go around with a gun and told them, if you want to call the German, I'm going to come and kill everyone in your family.",
      "word_count": 32
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Which is true.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I-- we used to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Oh, they didn't tell nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "They didn't [? do. ?] The Polish, they were very rotten.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "They used to talk about the-- the Jews live in-- it was [INAUDIBLE] they lived there.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "Oh, they didn't run over to the Germans to tell the Germans how there-- over there live Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "No, they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] When I used to go for food, we had plenty food.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "They give us plenty food.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And when the time, when the German came and killed all the family, they came to me too.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Because that's, you know, there was a way go.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "We run away.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "We run about 20 miles away.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "They didn't caught us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] And we stayed there till it became dark.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "And we run to a-- in a Polish place where they-- people used to keep the corn and the wheat.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "We sleeped over there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "Well, the Polack knows we came-- we live there.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "He came fast to run.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Germans surrendered.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "He didn't came when they were close.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "I don't know he find out, but they were a couple miles away.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "And we run away.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "We run away, and they shoot at us.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "We run about four miles away.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "They shoot on us bullets, so fast.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "They shoot on us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "They didn't caught us, didn't caught us.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "Nobody was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "We run away to the same place where we used to stay.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "We find a little girl who was frozen.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "She frozen up.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "She run away from the-- from the bunker, with her father, and the mother lived there.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "She run to us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 39,
      "text": "But we didn't was there.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 40,
      "text": "And she frozen up.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 41,
      "text": "We took her, and we buried her with the father.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 42,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We lived.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I lived to the time a Russian man came over.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He said to me, who knows the road how to go to-- to Russian army?",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] I said, I know.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "You know why I know?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Before the war started, my father rented a place in a different city, with-- with-- with a water, by the brook-- by the brook.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And he made his shop over there, and I used to be there.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] He-- he was just such a good blacksmith.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "He used to-- [PAUSES FOR 5 SECONDS]",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He used to take-- He went to a Polish man, and pay him $50.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They should make for him a wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You know what's mean a wagon?",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Woods to make a wagon.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And he made it iron work.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "That-- my father made iron work.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the Polish man gave him the wood.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And I know the guy.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I used to go to.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I said to the-- to the Russian guy.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He says to me, the Russian guy says to me, there's a hundred feet water.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We have to-- how we going to go the other side with the Russian?",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Because we have to go past the water.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I says, I know somebody.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They have a boat.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And he's gonna give us the boat.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And we gonna swim to the other side where the Russians are.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I went with him, with the Russian guy, to this-- this Polish man.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He recognized me.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "He didn't-- was afraid to give it to me, because he knows already who I am.",
      "word_count": 16
    }
  ],
