  "model": "openai/gpt-oss-120b",
  "elapsed_s": 130.8,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "The people who came over from Europe and the-- from the underground.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "They stood there overnight, over a few days, and they were taken away.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "They were sent to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "So they-- the government what-- were the officials.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "The-- this was still not in the ghetto yet, before we went to the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "We were in the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They picked up-- there was always the underground.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "People from Poland escaped.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "We-- [? and there ?] are young kids who came up at the sewers.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "That was in Kosice ghetto-- in Kosice, where I was in Kosice working in the children's home.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I was still living there.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I was still living-- still living in the home, which it went on for quite a bit.",
      "word_count": 17
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "They came, and they went to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We-- they did not want to talk too much, because they were afraid.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "What they kept, it was everything hush, hush.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So they did not want call name-- tell names or their names.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, they-- one of the groups stood over.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And I heard the most beautiful song, which it stuck with me.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "We had a concert.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And there was a-- he must have been 12 or 13, and he was studying music.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And there was a young kid, and he sung-- he sang this song.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "He gave us-- of course, we all cried.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "At that time, I didn't understand as much.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "Now the words are something.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I would like-",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "--to record it.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "It went like this.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH SINGING] [SOBBING]",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
