  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Whatever you do, we love you.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And try to do the best you can.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "We love you all.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS] This message I'm trying to give you is my memories.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Try to give it to your children, to your grandchildren, and for our future generation.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Never forget the 6 million Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "I know you will try.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "Because once we are gone, it will be a tough time to let people know there was a very bad war, [? very ?] [? crucial. ?] And we went through from the ashes to life.",
      "word_count": 36
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And never forget who you are.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "Oh--",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I would like to.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Well, I met my husband in Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We got married in Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And we are married 49 years.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "We have three lovely children, and lovely daughters-in-law and grandchildren.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "This is part of my life.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Shall I say the other half?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "This is part my half.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "We went through high and low, hot and cold.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "But I'm thankful to God that we met, and to him.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "He's very good to me and to the children.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "I hope and pray that God lets us stay here for a long, long time yet.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "His name is Josef, Josef Schwartz.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Yosek ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Note ?] Schwartz.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Well.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And we are coming a long way.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Half way around the world.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And we met.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "We are happy, and the future looks good.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "All right?",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm the lucky guy.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I got the best woman there is.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We are married for 49 years.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "We went through hell together, ups and downs.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "And I'm continue to support the whole family.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And the kids are good to us.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And we hope we're going to see our weddings, bar mitzvahs of [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "We went through plenty.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "We're not dead.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "So we are looking future for [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We're having a bar mitzvah coming up for our grandson.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And I'm hoping that God would be good to us, and I can walk down the aisle with my granddaughter, Beth.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "The other ones are still young.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "So we hope we will be around for a long, long time.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "This is a school picture made in Krive of my little sister's school, public school in 1938.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "From the right, the second on the right, her name was Gitel Halpert.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "On the second row in the middle, the third one, is Sura Miller, my cousin, little cousin, which is same school.",
      "word_count": 21
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "All the way on the top right there is Mendel Berkovich, my cousin.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "The other ones are all our friends' children, which I don't remember the names.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of my cousin [?",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Moishe. ?] He is standing.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I cannot identify the girl.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I think it was taken in Krive, 1939.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "This is a picture taken in Cremona in a DP camp.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "The bottom left is our friends, Nathan and Rosalyn Sherofski.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "The third one, it's myself, Rose Schwartz and Josef Schwartz.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "The rest of them are all friends, which we met.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "They are all survivors.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "We met in Cremona, and we-- we had at the gathering.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 10,
      "text": "This is a picture in Trana.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 11,
      "text": "We had some cousins visiting.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 12,
      "text": "It's 1948, leaving the DP camp, going to-- I don't know the destination.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 13,
      "text": "This is a picture taken [INAUDIBLE], Italy, just before our friend left.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 14,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 15,
      "text": "Surlek ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 16,
      "text": "Shmerkovich. ?] Next to him is Rose Schwartz and Josef Schwartz.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 17,
      "text": "This is a picture taken Margate, New Jersey, of my oldest son and his family.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 18,
      "text": "From the right, it's Mark Schwartz, Beth, Joyce, and Michael Schwartz.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 19,
      "text": "The picture was taken in 1992.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 20,
      "text": "This is a picture from my second-- of my second son.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 21,
      "text": "The top is Dorothy, my daughter-in-law.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 22,
      "text": "From the left is Rebecca and [?",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 23,
      "text": "Alora, ?] and Edward Schwartz.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 24,
      "text": "It was taken in 1993.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 25,
      "text": "This is a picture of my youngest son.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 26,
      "text": "From the left is Dana.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 27,
      "text": "In the middle is our granddaughter, Beth, And this is Robert, our youngest.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 28,
      "text": "They're all very precious, those.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 29,
      "text": "The date it was taken in 1992.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 30,
      "text": "This is a picture taken of all the girls in the Cremona Club in 1995 in New York.",
      "word_count": 18
    }
