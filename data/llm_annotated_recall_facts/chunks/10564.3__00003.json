    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "I was running.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Oh, maybe about two hours later, the German, one German, a terrible guy.",
