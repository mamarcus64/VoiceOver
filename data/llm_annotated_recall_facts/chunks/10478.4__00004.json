  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "This is a release form I got from the Germans when I was released from concentration camp.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In 1945.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "It must be the second one, I suppose, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, that was the second one when I was arrested for the second time.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Concentration camp Amersfoort.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "There's a copy of it illegal magazine, Free Netherlands, that I was the provincial representative for this organization.",
      "word_count": 18
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I spread the magazine around.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "On the screen at the moment is the diploma of honor that my sister Margeretha received when Yad Vashem, because she so helped me in hiding Jewish and looking after them.",
      "word_count": 31
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And she received this.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And that's correct, yes, in Jerusalem.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "That was, I believe, it was 1962.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Before that she already had tree planted.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And it was one of the first trees [? she ?] [? get ?] Yad Vashem is for her.",
      "word_count": 19
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "That is what my sister received in Yad Vashem when she planted the tree.",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I believe it was done in 1963.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "She was one of the first, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Her tree is one of the biggest ones.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "It's standing in front of the Lane of the Righteous Gentiles.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The medal I received in Yad Vashem-- that meant I was honored there.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I plant them a tree, and I got also this medal.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "That is.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Well, there's a well-known [INAUDIBLE] who developed.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I know the saying.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Well, one person helped the whole world-- something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "This certificate I got at the Israeli embassy in Ottawa in November, 1969, also given out by Yad Vashem.",
      "word_count": 19
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "This certificate I received from the Jewish community in Ottawa in 1991 in January when they honored me in one of the synagogues in Ottawa.",
      "word_count": 25
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I received this certificate in 1945 in November, when I was honored by the Jewish community in Maastricht.",
      "word_count": 18
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "And that meant the names of the people I was able to help during the wartime and who came alive out of the wartime.",
      "word_count": 24
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "These are there-- not all, a few of them are missing, but the majority of the people I helped during the wartime.",
      "word_count": 22
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this portrait was made by a well-known-- Dutch painter, Charles [DUTCH] And that was handed to me when I was celebrated and honored by the Jewish community in Maastricht in November of 1945.",
      "word_count": 34
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "There's my daughter, Margaret, my youngest daughter, with her husband, Rich, and their three children.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "It was taken last year in Canada.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And [? now ?] my grandchildren are living in Canada, yeah.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "That's my only son, Gerrit with his wife, Hetje and the two children, who are living now in Dallas, Texas, in the United States.",
      "word_count": 24
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No, the picture was taken just before they left.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Last year, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "In '96, in 1995.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "This is my oldest daughter, Ria,s and her husband, Ralph, and their four children.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "They are all living in Canada.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "In last year, 1995, in Canada.",
      "word_count": 6
    }
  ],
