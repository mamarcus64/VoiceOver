    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "This is my youngest granddaughter.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "She is named-- her middle-- her middle name is after my late son, Michael Zygmuntowicz.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Her name [INAUDIBLE] in Hebrew is [?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Michaela. ?] And her first-- she has two names-- [?",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "Elizabeth ?] Michaela, and we call her [?",
