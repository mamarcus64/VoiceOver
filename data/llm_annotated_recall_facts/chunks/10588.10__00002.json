    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "On the side are the two brothers, which live in Israel and have now families themselves.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I just know one, the one that-- Kalfus, that I met, that you saw previously the picture.",
