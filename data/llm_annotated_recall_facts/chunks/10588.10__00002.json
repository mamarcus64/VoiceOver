    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And the one sitting down is [?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Ito ?] Pazdziorek, who emigrated in 1934 to Israel when I was four years old.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And the picture was taken in 1930 in Ciechanow, Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "This photograph is of my beloved parents of blessed memory.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "My father, Eljo Frajman, my mother, Simo Frajman, and I, Itka Frajman Zygmuntowicz.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "I was seven years old.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I got this picture actually twice.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "It's a composite picture.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "I got a separate picture of my mother and a separate picture of my father and I.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "The first time I got this picture was from my uncle, [?",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "Moshe ?] [INAUDIBLE] Zebrah, from England, when he find out I'm alive.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "The second time, I got from my kindergarten teacher, that my father gave in 1939, beginning of 1939, before she left.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Her name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Malka ?] [INAUDIBLE], and she lives in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "This picture was taken in Ciechanow, Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I was seven years old.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I was born in 19-- in 1926.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "This photograph I got first was cut out.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "The one on the bottom row to the left, the cutout picture, I got in Israel when I went in 1978.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "The second time I came, they gave me the rest of the picture.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "This was taken in [?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Pultusk, ?] Poland, when my mother was playing theater.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And later on, I got the other part.",
