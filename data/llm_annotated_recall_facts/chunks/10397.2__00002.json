{
  "stem": "10397.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "There was complete office arranged with all the instruments.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "There was a waiting room.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "There was  a couch.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "There was all things-- everything-- examining tables, syringes, everything that a doctor needs.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "OK, I'll give you-- give me-- I'll give you-- she didn't ask for anything-- no-- no contract or anything.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She gave me a key to the office.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "It had a separate entrance.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I took the key, locked the office, and I started-- I'm going to start office hours tomorrow.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And I told my mother and father I'm a doctor.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "I have an office.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Mazel tov, mazel tov, mazel tov!",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "All right,  next day, I come in there.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "There is another lock on the office.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I said, what happened?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So I say, two officers came, broke off the lock, put their own lock.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they said it's-- we are requisitioning the office to sleep-- to live there because there was a couch, and chairs, and blankets.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "One slept on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "One slept on the-- on the-- on the examining couch.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "What kind of officers were they?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Russian officers.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So my career is end-- end of my career to practice medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So I go out to the Communist-- to the party office, which is the secretary of the party in Russia is the-- the supreme being over-- above the city manager, above everybody.",
      "word_count": 32
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I come in to him, to the secretary-- to the Communist party office.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And I say, I want to talk to the secretary.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "The secretary is like God in the-- in the-- in the district.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And he's a-- he's a nice guy.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "I told my name is Dr.-- my name is Brand.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I am a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I just-- I'm a refugee.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I told him the whole story.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And I rented an office.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And I was going to open the office for patients to see.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And the two officers invaded my office.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And I have no office.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "That's terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So he said, yeah, this is terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I agreed-- he agreed with me.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "See what I can do.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] every doctor is a specialist.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "That's-- they call them specialists.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "You're a specialist, and they took away your office?",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Come tomorrow and see what-- what I can do you-- very friendly.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I come in tomorrow.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "He says, I can do nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "It's the war.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "It's the army.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "They are a priority.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "That's the end of it.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Then I got another break.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You see, the Polish Army was retreating east, running away from the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "When we were walking 24 days, the army was running away.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The civilians were all going east.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "The Russians came in from the east going west.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "So any-- so any person in a military uniform, Polish uniform, they took him as a prisoner, although there was no war between Russia and Poland.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And they had thousands and thousands.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "The officers they segregated.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "The officers were enemies of the people in Russian opinion-- in the opinion of the Communists.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "They put them in concentration camps.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "There's the famous camp of Katyn.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "They killed 3,000 Polish officers.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "They said the Germans did it.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "But the Russians did it.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Beria was the KGB, the head of, you know, the KGB and signed an order them to be killed.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Beria.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Beria.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He was not Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He was-- from Turkistan or from Georgia, from Georgia or something like that.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "B-E-R-I-A.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Beria.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Beria.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "He was the head of the [INAUDIBLE] or KGB, you know, secret service.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, they had several thousand-- 20,000, 30,000 Russian-- Polish prisoners of war-- polish soldiers-- prisoners of war.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "The reason they took them-- they were building a strategic highway from Kiev to the Curzon line to the German border.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They were building a strategic highway.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And a strategic highway requires a lot of stones to be broken and built.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "There was about 800 miles.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "So  they needed these people to work on this highway.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "So they took them like prisoners of war.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "It was not-- not fair.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "But that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And they organized camps-- work camps.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And it happened so they needed doctors in these camps.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "This-- like, there was a camp of 5,000 people.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "And this camp was in-- in four points.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And each camp-- each district had 5,000.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "Let's say the 5th District was 5,000 Polish prisoners of war, they called them.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "But they had-- had five camps in this district.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "I got acquainted with a-- with a Russian officer, a Jewish Russian officer.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "They were coming to our house for coffee, tea.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "The-- the chief engineer of this construction was a Jewish engineer, Berdachevsky.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "He is from Berdichev-- Berdachevsky-- a wonderful man.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "He was a, yeah, member of the party because he had a responsible job.",
      "word_count": 14
    }
  ],
