{
  "stem": "10.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "She came about in February, '46 from Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I still worked with the American war crimes, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And then we got an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "The Germans had to give me right away an apartment because I couldn't live in the hotel with the officers and with my friend, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We got an apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And we lived separate.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And I went every day to work.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And here, we have to go to Germany-- to America.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Sieg.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We will go without money.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "What will we do?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I got a salary from the Americans.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And my money, I sent every month to Cleveland to my cousin through the APO through the military [INAUDIBLE] mail-- post.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And I kept here a few thousand dollars.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So I said, we have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I will do something.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I would go into the black market.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And all of my friends, they became millionaires.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They did black market in Germany, smuggling cigarettes, liquor, and all those things, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They became millionaires.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "So I never wanted to do it-- never.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I said, I don't need it.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Because I thought I come to the United States, I will go in my profession, and I will work as a pharmacist.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I don't do this kind of work.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She said, we have to do it, she said.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So I went every morning to work.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And I [? sold ?] to all the officers-- do you need some money?",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They gave me dollars.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I took it-- the lunchtime route, went to the DP camp, displaced person camp, near Frankfurt.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "The name was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And in the afternoon, she brought money.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "She changed the money.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "She got, for $1, 200 marks.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "But I gave the officers only 100.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And we-- quite a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "In this few months, we saved some money.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And I sent it all to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "This picture is from 1972.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "There was a visit of my aunt and uncle for first time from the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "This is my youngest brother.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "This is my aunt from the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "This is the uncle from the United States-- no, this is my grandmother.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "This is the uncle of the United-- from the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "This is my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "This is my aunt and this is my aunt.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Amelia.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name was Paul.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The children-- there is-- the last-- the first one here is my sister, Katie.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "This is a cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "This is a cousin and this is a cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "This is me in the Polish army.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I served in 1931-- no, 1930 and '31 in the Polish army in the officer school.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "This is my older brother, Isador, and this is myself.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "At age 2 and 1/2, 3 and 1/2.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "This is my older brother, Isador.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "This is my younger brother, Paul, the first day in school.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "This is my younger brother, Paul.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "This is my sister, Katie.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "This is my older brother, Isador-- no, I'm sorry.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "This is myself, and this is my older brother, Isador.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "This is after the war in 1945.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "This is myself, my wife, Ruth, and an American soldier friend of ours.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "We met, naturally, after the war.",
      "word_count": 6
    }
  ],
