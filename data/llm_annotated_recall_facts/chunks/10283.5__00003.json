  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "But in her 80s, in 80--",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "This is my mother, Erna Stern-- and she was already in her 80s-- and me, Gerda Wilchfort, at my 65th birthday, so--",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "This is a favorite picture of four generations-- my mother, Erna [?",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Stern. ?] And she is already in the nursing home.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "That's one of the last pictures of her.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And me, Gerda, and my daughter-in-law, Cyd Marcus, and the little girl, Erica Marcus.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I hope so.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "This is my younger son, Peter, and his little daughter, Erica.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "My daughter-in-law, Cyd, had to stay home.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "They have a brand new baby, which is a week old today.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "The baby's name is Jennifer, Jennifer Eve, and this is Erica.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "My older son, Gary, and his wife, [?",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Skeeter, ?] Miriam, and their two sons, Matthew and Benyamin.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I would just like to tell her how proud I am of her for taking the time and making the tapes.",
      "word_count": 21
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I know that it's not easy for you.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "But it's very important.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And I'm very proud of you for doing it.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And I love you very much.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And it's something that we will treasure--",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Where's the tape?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The tape's right there, honey.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER] It's something we will treasure as a family, and hopefully many people will benefit from forever.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And I love you.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to give you a kiss.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I love you, too.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I love little Erica.",
      "word_count": 4
    }
