  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I'm very proud of my parents and all of the things they have accomplished.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was a pretty big accomplishment, at least in my eyes.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And I'm very grateful to have this opportunity to have their memories recorded for future generations to understand and learn from.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "If somebody would tell me in 1940 that I would be married to my lovely wife, have beautiful children, grandchildren, live in United States, have a house, have a trade, never hungry, and free, I would not believe it.",
      "word_count": 39
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But when you're alive, you can accomplish everything.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I accomplished, with my lovely wife, with the children.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So that's why I'm here.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "You know, it's possible.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Everything is possible when a person is alive.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And I thank everybody that I'm here, especially my wife, because she's a very, very supportive woman.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And she's a very good wife--",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Thank you, for the compliment.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "--mother, understandable.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And she's creating job, you know, helping Holocaust to come and to speak to the children.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And she's very good in it.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I know it.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Somebody told me already.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "But we would not help each other, where we [INAUDIBLE] against religious, against where you come from, who you come, he's black, he's white, he's green, then we have a disaster in this country.",
      "word_count": 34
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I hope that people understand it's very, very good to help each other.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "That's what we're doing.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I hope that we would live to see it.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "This photo, it's me in the picture.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "The photo was taken in 1946, or '47. '46, probably.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And that was in Laufen, when I was liberated.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It took me a long time before I put my hair in shape, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Because my hair was half inch tall.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I done a good job on it, I think so.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And that's me, 1947, before I got married.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Nothman, what is this certificate?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "This is anybody who belonged to the Jewish Athletic Club, you know, soccer game.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We got like a registration that I belonged to that organization, and I played soccer for this special club, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And this is my picture.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And that was in 1947, January, 1947.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "That we got, in the camp, anybody who play for the soccer must have a registration and must belong to a camp.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So now, they register him as a camp.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And then, I got my pictures and that things that I play soccer for them.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "This photograph-- before we play-- before we played, some of us to make picture.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And this is the whole 11 or 12 with the coach, before we play soccer.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So we made a lot of pictures.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And they're all my friends.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I am there, from my left, one, two-- the fourth one there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "This picture-- we lived by photographer in Laufen when I lived in a small city.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "This is my sister, to my left, Regina [?",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Moskowitz ?], and my wife, and myself.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And this was 1946, end of '46, in Laufen.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Quiet.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "This is the wedding day, January, 1947, January the 26th.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "This is the picture with my wife sitting.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "To my right, is my sister-in-law, Helen, Regina [?",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Moskowitz ?], my friend, my brother-in-law, my sister-- sister, [?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Bella Soloway, ?] and my brother-in-law, and my-- and my niece.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "She was maybe about three months old.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "This is picture in my house.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "My mother came from Sweden to visit me.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And they're all my friends.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "They're my brother-in-laws.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "They're my sister-in-laws, my wife, my mother, myself, my friend, and my sister and my brother-in-law.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "That was 1948 in Laufen where I lived in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "This is a New Year, what we send it in Germany.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "We lived by photographer.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "And we told them that you should make a picture with my wife, put in a circle so we can sent it to our friends.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "And they would see the picture who sent them.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "And there was a greeting for New Year, for every year we were in Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "This is the picture for my daughter, Carol, 1985.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "To my right is my son-in-law, my granddaughter, my daughter, Scott, my grandson, and [?",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "Marty ?], my granddaughter.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "There's myself.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "There's my son-in-law.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "This is Carol.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 28,
      "text": "This is my wife, Sonia.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 29,
      "text": "This is my daughter-in-law, Nancy, and my son, Sam.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "A very, very happy occasion.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I do.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "So from nothing-- yeah.",
      "word_count": 4
    }
