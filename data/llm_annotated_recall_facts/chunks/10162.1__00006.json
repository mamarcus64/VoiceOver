  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Because my father, besides that he spoke several languages and he was so handy and mechanical he could always-- even when Jews weren't allowed to have a radio, he would make something.",
      "word_count": 32
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And it was inside the piano and he would listen to BBC, and the Voice of America, and all that.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And he was an extreme optimist.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "It was just a pleasure to listen to him.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I can't believe it.",
      "word_count": 4
    }
  ],
