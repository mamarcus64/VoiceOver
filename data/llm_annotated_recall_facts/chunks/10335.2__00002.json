    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 4,
      "text": "Israel told me, no, you no can go.",
      "word_count": 8
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 5,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 6,
      "text": "Because my wife got the boy, the son.",
      "word_count": 8
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "I tell them, what I can do?",
      "word_count": 7
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I don't want to be over here.",
      "word_count": 7
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "Well, make application to the American's Council down at the Israeli council.",
      "word_count": 12
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 3,
      "text": "Israeli Council told me, you want in?",
      "word_count": 7
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 4,
      "text": "You ready.",
      "word_count": 2
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 5,
      "text": "I came in and 10 minutes you got the passport.",
      "word_count": 10
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "My wife told me no, not yet.",
      "word_count": 7
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "I go to the American Council.",
      "word_count": 6
    }
