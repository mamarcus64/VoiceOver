{
  "stem": "10394.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "I was two days in-- in the closet.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "And then I says, go and tell my brother that I am here.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "He was sure nobody's alive, because he-- he knows everybody.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "And they hear the-- the bum!",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "Bombs!",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "And here.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "I am here.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 16,
      "text": "He says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 17,
      "text": "Keep her the night, but I gonna try and tell one from the other man.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 18,
      "text": "This was the Jewish--",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "The oldest, Sigmund.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the oldest.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "So he says, I take her.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I can't take her now.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "It has to be legal, you now?",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And before, when the ghetto is in the door, was a other German.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "He was so good.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "He was killed in-- before the war-- about two days before.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "But he got a-- a Jewish woman, and he keep her in someplace with the-- with her kids-- a 3-- 3-years-old boy.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "He was-- he didn't see nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "When you go to work outside, they-- the people, they bring bread, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But he didn't see.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "He covered the Jewish woman.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And her husband was with me together in Brunnlitz-- the woman's husband.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Before the war, somebody saw him, tell the German here and here is a Jewish woman.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "He put her here.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "They killed-- killed him.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "They killed her, and the baby.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "For two days.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Then--",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "She given me, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Because-- and then the kids, they went to the school.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "They were not at home.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "So she give me, yeah-- about two nights.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I was so quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't say nothing, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And she was happy when the kids, they go out.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "When I came to around other man.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "This is the Jewish police, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "He take me in-- and let me in-- the German.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "He let me in-- not even to my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "My sister-in-law, what I got, I says, better than when I was in my town.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "And I was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 13,
      "text": "Must help.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "She doesn't want to see me here.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "Then you can go like this.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "You have to work.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "You have to work.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "If I have to go to work, I have to have a machine to-- a sewing machine.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't got-- on where?",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Tell me, your sister-in-law said you had to go to work?",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "You can't-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "You-- when you was in ghetto, you have to go to work.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Everybody has to work!",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "If not, they killed you!",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So my brother got somebody in Madritsch where I-- they take me over there.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Over there it was the Jewish people are sewing.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "This was the uniform what I told--",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yeah!",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "You know the-- the-- the people that he knows.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So he takes me over there, and I was over there.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know I can do some things or not.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "So they try.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "They give me first, I remember like now, the collars for men's shirts.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "The collars was for Madritsch-- on-- the chef from the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And I make the collars.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "One looks at the one that says, oh, beautiful, so nice.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't believe that they-- I sit in the first [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And I got a machine.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I got everything.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "And the supervisors-- this was Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "And then they give me, you know, pyjamas to do for Madritsch.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "I was the first over there-- the first.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "They need something, they came to me, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "And for a while, we was-- we lived in-- in ghetto, and we go to outside.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "This was not too far from ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 14,
      "text": "From ghetto to Madritsch was in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 15,
      "text": "And we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 16,
      "text": "But now a few months--",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "This was the year-- 1939 or '40-- '40.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And we went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And then from Madritsch, then he got six shirts to make for [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "If these-- if some stitch is not right, he can kill you.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "He looks like this on-- you know?",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH]-- the [NON-ENGLISH] was the ship-- the chef from the whole concentration camp Krakow-Plaszow.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And we went-- before we went to work in Krakow-Plaszow.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We didn't go when they liquidated this ghetto, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "So we went to Krakow-Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "19-- 1940-- '41?",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Exactly, I don't remember the date.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "When we came--",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There was--",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "--no!",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And then everybody has to go in concentration camp-- no more ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "In ghetto when we was-- when it was-- there's a liquidate the ghetto, got to over there.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "It was unbelievable what they doing with the Jewish people.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "They kill.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "What I saw-- I was scared to look.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I saw this.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "They take a baby, a small baby from third floor.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "This is not the third floor of like here.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "This is the second, third.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "This is like here the fourth floor.",
      "word_count": 7
    }
  ],
