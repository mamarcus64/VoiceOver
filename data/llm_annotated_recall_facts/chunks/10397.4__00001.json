  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "She started not crying but she started to beg me, stay.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And never heard.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "She gets around.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "No, I don't hear anything.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I say, I'm going out because your life is in danger.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "6 o'clock in the evening it gets dark.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was March.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And there was a pump, a water pump by the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans walk around.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Here, there, you know, a solider.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I went down.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "After dinner, the sergeant went away and the corporal went away.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I sneaked through, you know, behind their house.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And I lied down behind the pump.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And there was a German walking.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And as soon as he walked out there from the barn, from the pump I ran to the barn.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And in the middle of the night, I left the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And there was a field, you know, land, and it's March.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Mud, just mud.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And across the distance to the woods are on a slope.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "That's there out there, the forest.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And I walk in the forest.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And I was tired because I had heavy shoes, boots.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "I was dressed very warm.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "I had all my documents with me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "I always slept with my documents.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "And I walk around and walk around and walk around.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "There is snow.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And there's a ditch, and there's snow on the bottom of the ditch.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "That's wonderful.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "I take the snow and eat the snow.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "So I wasn't thirty because thirst is worse than hunger.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "And the ditch-- since how the ditch was a trench, a military trench from the First World War.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "And there is a ditch.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "And this is diagonal, and this part is diagonal.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And the snow is on the bottom, and I lay down to rest up a little.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "And there is snow.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "And I look around, and I close my eyes.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "And look around, and I rest a little bit more.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "And suddenly on the snow, I see yellow spots like somebody urinated.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "And I don't pay attention to it.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "Then I open the eyes.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "I look around more and more.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "Here and there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "And there is smoke comes out from a little hole from the ditch on the other side.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "A smoke, a little smoke.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "And I look at the yellow spot.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "They're gone.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "They're gone.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "So I figured it out.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "A Jewish family or a Jewish man is hiding.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "There was a store in his village.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "Parness was the name of the Jewish family who had the store for years and years.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 48,
      "text": "They're village Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 49,
      "text": "And I knew I have to get away because I can't ask for help.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 50,
      "text": "And I don't want to expose them.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 51,
      "text": "And they would not help me, or they would kill me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 52,
      "text": "And I just climbed out from this ditch, and I just walked away a little further.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 53,
      "text": "Because the ditch was, you know, meandering.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 54,
      "text": "You know, this way and this way.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 55,
      "text": "I find myself a different place to lie down.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 56,
      "text": "Maybe I slept.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 57,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 58,
      "text": "But I was rested.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Comes in the morning-- the whole night.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, I walk on a little through village-- through the forest.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Not a road, you know, a path.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And I walk and walk.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It's 11 o'clock in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Suddenly I see a soldier or a Gestapo man with a gun.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And a Ukrainian farmer walking right against in the opposite direction.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And the soldier doesn't say a word.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "Takes out a machine gun from his shoulder.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And I turn around, and I know he wants to kill me.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And the only thing I think is, does it hurt when he gets me right in the neck or in the head?",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "Does it hurt?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And I ran in the forest on this little path.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And I ran and ran and ran.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "He didn't run after me.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "He didn't shoot.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Then I can say this forest is dangerous.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "I go back to the village.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "Cross the road to the field and I come to the school.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "The best building in the village is the school.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "Nicely built primary school for the village children.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And there is an outhouse in the yard.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "I go in the outhouse and lock myself.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "How long can you sit in an outhouse?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "An hour, that's all.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "I didn't have to use it.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "I was sweating but that's all.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "I was wet.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "Wet.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "I had a warm 3/4 coat, and I had felt boots with galoshes.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "Felt boots.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "That's what the solider wear.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "That's was the Russians wear 20 below zero, 30 below zero.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "I sit in the outhouse.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "Finally I got sick of this outhouse.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I walk into the school.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "No children, naturally, it's war.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But that there are two teachers, two sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They live there in the school.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They had an apartment.",
      "word_count": 4
    }
  ],
