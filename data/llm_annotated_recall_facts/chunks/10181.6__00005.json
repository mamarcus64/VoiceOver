  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "This is a picture taken in Hamborn, where I stand in front of the flowers.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And that's my mother behind there with two aunts and-- and a friend of my mother's.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "One-- one is Aunt Anna, who lives in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "The other one is my Aunt-- Aunt Marthe, who was married to my uncle Adolf.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "This is the wedding picture of my aunt [?",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Greta, ?] or Margareta, which was her name, really when she-- she married a-- a Dutch gentleman called Hertog Weijel, and they lived in Enschede, Holland.",
      "word_count": 26
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "Unfortunately, they were killed during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "The whole family was.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "This is the house where we lived in Holland, in Dinxperlo.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "This is the house of Uncle Max.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "It's in [?",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "Polstraat ?] in Dinxperlo.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "This is in 1946, in England.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "My mother and my sister and myself after the war in 1946.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "This is a picture of my mother with my aunt, who now lives in Argentina, when the-- when the aunt went to visit her in-- in-- in Chile.",
      "word_count": 28
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "It was taken a few years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Aunt Marthe.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Marthe.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "My mother had three sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "There are four together.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "This is Marthe.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "There was Anna, who lives in Israel, and Margareta, [?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Greta, ?] who got killed in the war.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The only one I would have liked was-- you had the original of this, don't you want to use that?",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "OK, this is a picture taken some time in-- in the summer of '42.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "This is my maternal grandfather, Julius Berghausen, myself, my sister, and Sophie Beckhousen-- who actually is not my grandmother.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "It-- it's my grandfather's second wife.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "My grandmother died in 1919.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I think that's enough on that.",
      "word_count": 6
    }
  ],
