    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I thought I saw a Russian guy, a Russian.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He had a taxi.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I told him, please, could you take me to my home?",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "I wanted see something there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "If he is going there, he was going the same city where I was living then.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And my father buried a lot of gold in a-- in a box.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And I-- he showed me-- my father showed me.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "Somebody survive, they should go take a-- open-- take a-- dig it out and take the gold, which I-- I did that.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And I picked-- picked the gold out.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "There was chains, and a clock, and all kinds, rings, all kind rings.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And my wife has it now.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "She has it.",
      "word_count": 3
    },
    {
