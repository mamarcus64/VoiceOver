    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Tell me what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Did you go back to your hometown immediately after?",
