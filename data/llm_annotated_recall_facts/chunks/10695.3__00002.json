    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "All right, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I was with her about [? 50 ?] years.",
