    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I'm gonna go.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "They saw I managed, and they made me a [NON-ENGLISH].",
