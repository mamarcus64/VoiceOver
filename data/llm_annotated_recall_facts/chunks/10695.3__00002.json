    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "You know, a cook, [LAUGHS] by the officers' kitchen.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They made me a cook.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I used to put-- make shoes, and make for the horses shoes, and fix the wagons, and do-- they loved me.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "You know, they loved me.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And I was with them about a year and a half, till the war ended.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The war ended.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I said I wanted to go back to home.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I wanna go home.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I'm not a Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Which I supposed to stay a Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I want to go back home.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Maybe somebody would survive and I'm gonna live with them.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "They let me go home.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "They let me.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And I went home with a train.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And I find my girlfriend, which she survived.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And we was getting married.",
