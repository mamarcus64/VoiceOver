    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I went to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] That's a sad story, I tell.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] We pass by the city, which I used to live.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And the Polish people told me that the Polacks killed one by one.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "When I went to the army, to the Russian army in to fight the German, I was wounded, wounded.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I tell.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] The bullets went through my foot.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It didn't went through the foot, it went to this one.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] And I saw I'm in trouble.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I take a-- a razor, cut it the foot.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "It let me blood.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The Russians should take me away from the front.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And they took me to the-- to bandage.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "To-- what do they call this?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "To-- and I went to the-- what you call-- the first aid.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And they wrapped around me.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I was in the front, not far from the brook, which they supposed to be liberated.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The-- the boys, who they were with me, they said that we not going no place.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We gonna be liberated from the Russian army.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And they bandaged me in the foot.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There was not too much.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I said, you mental sick.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "You go-- I live.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I survived such a Hitler bomb time.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "You want to send me back to the army?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I'm not going to go.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Kill me.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I'm not gonna go.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And who did you tell that to?",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I told it to the-- to the Russian people, to the Russian-- to the officers who they send it back to the army.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Oh, no.",
