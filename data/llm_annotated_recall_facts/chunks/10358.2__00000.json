{
  "stem": "10358.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I go from the beginning?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Some friends went to Ostrog a few years ago.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And they spoke to some-- to people that were witnessing the executions.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And they said that a day or two later, they saw the earth was moving as evidence that some of them were still alive in the graves.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "That's the grave that my father was.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "They were not, they were not completely dead when they were buried.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, I never wanted to go back.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "But I did have recently a memorial.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Some friends in Israel organized a memorial.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And they all went back for the memorial, which I'm going to get tapes pretty soon.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "That's it",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Third execution, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Now it's a break?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had an outhouse.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have toilet facilities.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And then there was no hot water, and no heat, and very bad-- terrible, terrible sanitary conditions.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But somehow, we survived.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And then started a third execution.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And then my, my husband-- at that time, he was my boyfriend-- he came in.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And he says, let's go.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And said, I cannot leave my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And I asked my mother to go with us to escape from the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And my mother refused to go.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And she said, I'm getting too old.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "I don't have the strength.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "I'll never survive.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "You are young.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "You will go with Mark, and try to survive, and try to escape, and try to be alive to tell the family in, in America and tell the world how the Nazis tortured us and what a-- how they persecuted us.",
      "word_count": 41
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "And then I kissed her goodbye.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And I left.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And I ran away with my husband.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And the ghetto was surrounded by Ukrainian policemen.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And he bribed them, one or two, with gold coins.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "And he let us escape.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And we escaped to the house of this Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "Stepaniuk, this policeman's mother.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "He wasn't there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We just-- we were told.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We knew it was coming, because they were chasing people out of their homes.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I, I-- while all this, we left.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was a terrible chaos.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was running and screaming.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And then we got to the gate with the barbed wire.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And my husband gave him the gold coins.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And he let us get out of the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And then we ran into-- through fields.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "We ran to the house where this Stepaniuk lived.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "She let us in.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And she put us in a basement.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And she gave us food.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And we spent the whole day until the evening in the basement.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And I heard the shots in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And lights-- there were lights.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And we saw lights.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And we, and we heard shots.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And at that point, I knew that my mother was being executed.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And we stayed there till the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "She gave us food.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And she said, I can't keep you.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "Because somebody saw you come in here.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "And they're going to come and get you.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "You have to get away.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Because a neighbor told her.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "A neighbor told her that they saw us.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Because we were jumping from, from-- what do you call that-- from gates, to gates, from the people's gardens, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They saw us escaping there.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And she told us we have to leave.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And then we left.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And then we went to another Ukrainian friend of my husband who put us in the cellar.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He had other Jewish people he was hiding.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And, and that's where we spent time in the basement, in the cellar, on-- sleeping on potatoes, and beets, hard surface.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And his wife fed us once a day.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "In the evening, she came in with a big bucket with milk and some dough.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "They were called kluski-- dumplings, dumplings and milk.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I was looking forward every day to the dumplings and milk.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "And I said, when I come out alive, I'll never want any other food, just lots of dumplings and milk.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I still like dumplings-- no milk with it, but dumplings, Polish dumplings.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I had this bag that my father gave me.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And I was about 13 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And it was my talisman.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I carried with me all through the entire war.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I, I-- in my hand.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I never parted with it.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "That's the only belonging.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And I have a coat, and one pair of shoes, and one shirt.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And that's how we lived for a long time.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I mean, in the, in the the basement.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "In the cellar, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "My husband will tell you this.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember the exact dates.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And while we were in the cellar, we heard the shots every day.",
      "word_count": 13
    }
  ],
