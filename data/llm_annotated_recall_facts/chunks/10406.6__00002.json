  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And the bottom is an enlargement of the picture from the kindergarten.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And it shows my sister, second from right-- from left.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "This is a wedding picture of my oldest daughter, Paulette.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And she's married to Alan Wolf.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They're both doctors.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "They met in medical school.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And this is my son, Kenneth Ginsburg.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And he's married to Vicki [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She originally is from St.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Petersburg, Russia.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And he now works in the finance industry.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "This is my youngest daughter, Suzanne Ginsburg.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "She just spent three years in Japan doing research and teaching English.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And now she's back in the United States, in San Francisco.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And these are my grandchildren.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "On the bottom-- on the bottom is Zachary.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And next to him is Olivia.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And on top of Zachary is Ari.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And those are my daughter's three children.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And on the top left is Paulina and Sasha, and those are my son's children.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "In 1993, I went back to my hometown.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And some of the surviving people collected some money, and we put up three monuments on three mass graves.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "The top one has 400 men that were killed by the Einsatzgruppen in the beginning, when they first arrived in our town.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "The middle one is the mass grave when they killed everybody in town.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And that one contains 4,500 people, including, including my mother, my sister, my grandparents, and many relatives.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "And the bottom is a grave that contains some of the people that managed to run away from our town during the killing.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "They were tracked down later by Ukrainians and Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And they were buried in the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "And that grave was left open for one month while they were capturing those people.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "Even in our area, and in our town where the population was very unfriendly and collaborating with the Germans, there was still a few people that, in a way, risked their life to help Jews.",
      "word_count": 35
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "And this woman is one of them that saved a couple that now live in, in Florida.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "His name is Yakov Biber.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 30,
      "text": "And she was honored by Yad Vashem.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 31,
      "text": "And her name is inscribed in the Washington Holocaust Museum and, and the-- on a special wall of righteous people.",
      "word_count": 20
    }
  ],
