  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I go to the gym.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And she says, I can't-- and she went to the gym.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "No, to the park for a walk, Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember if it was Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "But it was, anyway-- it was 29th of March.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And she says, I can't get out of bed.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "I says, well, I thought you were ready already.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "We want to go early.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "Because we walked an hour.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I go to her, Chupka, Chupka, [SOBBING] you're still in bed?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "She didn't answer.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I look around.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "She's dead.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "She was dead.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I can't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "She was dead.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "When did--",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I just called Ellen.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She called the rabbi right away.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] I go to the cemetery twice a week.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I'm doing this stone now.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "My next project is the stone, headstone.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "It has to wait a year.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "29Th of March.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SOBBING] That's all the story.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] She loved this apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You know, we worked together.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We traveled the world together, in Japan, Korea, Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We were three times-- two times in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I was in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I just came back around a month ago.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And England, France-- she graduated in France.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "She spoke French.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And we-- Italy, her sister is in Italy.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "But her husband also dropped dead about three months-- six months ago.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I play the violin.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I can't play, because I don't see good.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    }
  ],
