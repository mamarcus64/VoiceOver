{
  "stem": "1020.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Each time we sat down to the table, before we eat, and during we ate, and after we ate, that story, the Holocaust, was right on top of the table.",
      "word_count": 30
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "This was a, a cocktail and a dessert.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We never missed a day.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Each piece of bread I put in my mouth, I told them that sometimes, this was not bread.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "They knew.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They knew.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Everyone knew.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "My son is very active.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "He's very active in the second generation.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "My children, they give their time to it.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I was very active in the community, in the Federation, Jewish Family Service.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I was active in the Speaker's Bureau.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I was in the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was president of a shul and twice president of the Association of Jewish Holocaust survivors.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Till now, whatever I can do for the cause, I will continue as long as I live.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, go ahead.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "You want me to show you a paper?",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "If you want to look at it-- from Deggendorf?",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "If not-- it's 40, 50 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this is, on my right side, my wife, Anni, which I have her for 49 years to 120.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She gave me a good life.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "She gave me all my pride I needed and all my support for the years, and hope to the years to come.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture taken in public school in fourth grade.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The teacher name is Goldstein.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And many of our friends are alive from this picture.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I am in the bottom line, sitting, the second from left, the cutest little boy in this picture.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Issy Hollander, picture was taken 1931 in Bedzin, in a public school in fourth grade.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "This picture was taken 1930 in Bedzin, in public school.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And the teacher was a woman, [INAUDIBLE] [?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Luvna. ?] She is in the back, right next to the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And some of my friends from this picture are still alive.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Sometimes we see each other.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "It's been so many years since then.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 14 SECONDS] This is my sister, my older sister, four years older than I am.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "She perished in the Holocaust with four children.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And this is a picture that we found after the war from the archives to Canada.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I would've never had this picture if I wouldn't have be able to search for that.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "She was born 1916, not far from Bedzin in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] The place was-- her name was Fay, and it was [?",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Tzipporah, ?] Holender, H-O-L-E-N-D-E-R, Bedzin, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And the date of the photo, I cannot recall because it was taken during the German occupation, which I wasn't home.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "This picture-- my name is Isadore Hollander in this picture-- was taken during the war in an unknown place.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I was in German in the first line.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And I cannot recall the date.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "It was during the line-- during the time in the war.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "It's the Polish army.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 4 SECONDS] Again, in here, I'm Isadore Hollander, sitting with a group of soldiers, Polish army, next to the left, sitting behind me, is my sergeant, which was a-- one of, I mentioned before, the biggest antisemite, which I was always afraid of him.",
      "word_count": 46
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "And this was taken the picture a day after the, the, the war ended.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 13 SECONDS] The war ended May the 8th, 1945.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 7 SECONDS] Again, this is me, Isadore Hollander being a policemen, a security guard in a DP camp in Deggendorf, in Germany after the war.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "We didn't have any live ammunition or guns.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "We just, for security purposes, to guard the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "[PAUSES FOR 6 SECONDS] Why, again, I am Isadore Hollander explaining the first newspaper after liberation in a DP camp in Deggendorf, and the dating over there for the first Hanukkah celebration in freedom since the war.",
      "word_count": 37
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "And here, this paper has been 50 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 21 SECONDS] Isadore Hollander again, and I am speaking in Philadelphia in front of an audience on the cemetery.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "We are celebrating a year outside, which we have over there a shrine, a monument, for our fallen relatives.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "All their names are inscribed over there, and I'm speaking on that particular day.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "Every year, we are celebrating our anniversary for our loss of our families.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "Again, my name is Isadore Hollander, as I mentioned before, we had in Philadelphia yearly symposiums with all kind of schools, Catholic, parochial, and Jewish schools.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "And here, I was a speaker in the Speaker's Bureau.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "And I'm sitting and speaking to the class about the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "And the teacher is sitting beside me.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "[PAUSES FOR 5 SECONDS] My name, again, is Isadore Hollander.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "Standing next to me is the ex-governor of Pennsylvania, Dick Thornburgh.",
      "word_count": 11
    }
  ],
