{
  "stem": "10588.10",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "You never have a chance to-- to go in that much, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I was once-- but I was many times on television and the newspaper.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I wrote, you know, poems and a story.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "In fact-- I don't know if it's time, but there is-- there is one poem that when I was on television, I read, and they got a lot of responses.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Many people wanted this poem.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "It's been made now to a song, too.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "But right now, I don't think I'm going to sing it.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Or maybe I should, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "It's called 'Show Your Face,' and it was written in 1978.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] [SINGING] Show your face-- no, I think I'm going to-- I'm going to-- I'm too exhausted now to sing it.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Show your face at least in a dream.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "I wake up in terror and hear your screams.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "Your images I see in ashes and flames, yet still, I can hear you calling my name.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "Show your face.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "I'm so alone.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "My father and mother and brothers are gone.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "They left me behind to carry the pain and to see that their death shall not be in vain.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "Show your face so my children can see the roots of my [? chopped-up ?] family tree.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "Heal the branches with your faith and love, until we are united in heaven up above.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "This picture-- on this picture is my great-grandmother [?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Zita ?] and her son.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My great-grandmother [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Zita ?] was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "She was-- she was born in Poland, and this is her son.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I believe it's [INAUDIBLE], because she-- she had three sons and four daughters.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But I'm not quite sure which one this is.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "But I know that she was very Orthodox, and all of the children were Orthodox, too.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The picture was taken in Ciechanow, Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Sometime in 1800.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And there is a story how I got all the pictures.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "In-- Until 1984, I had no relatives here from-- all my relatives from Poland, that were in Poland didn't survive, except on my father's side, that were in Russia.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "In 1984, I received a letter from Ida [?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Jarvis, ?] Fall's Church, Washington.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I had no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "The name didn't mean anything.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I never heard it before.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And when I opened it, it had a note.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "It said, 'I'm your cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "We are named after the same great-grandmother, [?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "Zita ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Shinekopf. ?] My family immigrated when I was four years old to America, and I found a photograph of your great-grandmother-- grandmother'-- not this photograph, but of my grandmother.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "This is my great-grandmother, and I'm sure you would like to have it.' And I appreciated it very much.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "I thanked her.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And she invited me to come to see her.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "When I came there, she told me that two of the cousins which came here before the Holocaust organized that every year they should have a Thanksgiving reunion, because people were living in different places.",
      "word_count": 35
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And she-- This picture I received from Ida [?",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Jarvis ?] when she sent me the letter in 1984.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "On this picture, you see my grandmother-- my maternal, widowed grandmother, Chaye Sure Zebrah, who lived with us in Ciechanow, Poland.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And her son, [?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Moshe ?] [INAUDIBLE] Zebrah, who emigrated from Poland to London, England about when he was 18 years old.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And my grandmother went to visit him, and this is when this picture was done.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "It was taken in the beginning of 1900 sometime.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "In London, England.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "This I have no idea.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I know she lived to have-- a long time, but I don't know exactly how old she was.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "She had five married children and-- This is a picture of my late maternal grandfather.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "His name was Isaac Zebrah.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I was not privileged to know him, because he was no longer alive when I was born.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I received this, too, from [?",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Ida ?] and her relatives.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea, but must also been sometime in the late 1800s.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In Poland, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because he was born, lived, and died in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "On this picture, you see, on the right side-- right side, my mother, Simo Frajman, and her first cousin.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They were both born in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know the cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I don't think I was alive yet when this was taken.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I have no idea what date, but I know it's in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "It's my mother's first cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But she was pretty young at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "This-- On this picture are three of my first cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "On the right side, standing, is my cousin Hannah Pazdziorek.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "The other one next to her on the left is [?",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Ito ?] Pazdziorek.",
      "word_count": 3
    }
  ],
