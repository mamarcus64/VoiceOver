  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And he tried to use his influence to encourage our staying.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "1936.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And let me say that in-- in-- after-- after Buchenwald, he asked me again to come and see him.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I sat in his book-lined study, and he said to me this time, Fritz, I was all wrong.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Get out, and get out as fast as you can while you still can.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And after I was all through, he looked at me and said, the reason that I was interested in this, I have the feeling that some day I will go to a concentration camp.",
      "word_count": 34
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And indeed he did.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So-- in--",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They-- they would say to you, look, the old cliche, we don't mean you, but there are certainly some Jews who have done things that were wrong and you have to suffer.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Being innocent, you have to suffer with the ones who are-- who have been guilty.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And their guilt consisted, and their-- from their point of view, that during the Depression that-- and I'm quoting them now-- the Jews had taken advantage of their economic situation and had bought during the ridiculous inflation-- you know there was an inflation where-- where people didn't figure in millions but in billions.",
      "word_count": 53
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They were paid in billions.",
      "word_count": 5
    }
  ],
