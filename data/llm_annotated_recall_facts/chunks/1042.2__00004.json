  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, because we were only in Gross-Rosen.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They kept us for five days.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "It was seven days.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They used to hit us there.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They didn't give us food.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And one day, we're supposed to go to Brnenec already.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "So they called us, you know, to cut the hair, and they showed us to take a shower before we go.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "We knew that this is not a shower.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "That they send us to burn down.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "But it was not true.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "The first few people, what they called, nobody wants to go.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "So they, by force, they push a few.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "So then we go, all of us.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "It was really a shower.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And from there, it was one day more.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "We were ready, and we went by train to Brnenec.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "So that was the transportation, what we had from Plaszow to Brnenec.",
      "word_count": 12
    }
  ],
