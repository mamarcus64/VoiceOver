  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "The cook-- the one who was the cook was spooning it with, with a big thing, but there was nothing there.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "We didn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "We still, still fasted the first Yom Kippur.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "And then in the evening, we were able to eat something.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "But this was only the first Yom Kippur we fasted.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "The other one-- we fasted all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "But you had to have something, black coffee or something.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 40,
      "text": "But this, I remember that Yom Kippur.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 41,
      "text": "I never forget it.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 42,
      "text": "People still, still believed.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 43,
      "text": "And the people who even weren't religious believed that there's a God and he's going to help us one, one day.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were working in Rabka.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "One day, they, they-- in the middle of the work, they, they took us.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They told us we're going-- they taking away from Rabka.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Now you can't go back to your room.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Whatever you have there, it stays there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And this-- you're going just like this.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I still had my tefillin with me, which I was putting on every day.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "But this was already gone, too.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "They took us on, on, on their wagons, on the truck loads.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And they took us-- they took us to, to Plaszow.",
      "word_count": 10
    }
  ],
