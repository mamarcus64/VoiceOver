{
  "stem": "10588.8",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And as I was leaving the door, she yells at me, don't go!",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "Just like this.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "All of a-- all of a sudden, the Auschwitz, the kapos with the-- with the commandments, with the-- all the things flash before my husband-- my-- my eyes.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "A few minutes later, the good manager, as I called her-- I don't even know her name-- either this one or this.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "But I-- she was the manager from the general hospital, for-- it was for tuberculosis children, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Comes in.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And she says to me, Itka, I heard what's happened.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I know you're right.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "But do it for me.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Go back.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I was torn.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "My head told me, go, because after all, you're working here, and she's nice to you and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "My heart says no.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "The beginning is the most important.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "If I give in now, then I am again a slave.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "Even though I'm free.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I cannot do it to myself.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And I started to go with her.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "First I went with her.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "Halfway.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "The kitchen was on top.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "We had the-- the lower level, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "So I going.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "I felt, no, I can't do this.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And I started to run.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "Tears were pressing to my eyes.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And then I know-- I say, I cannot do it.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "At least here, I have a roof over my head.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I know I'm going to get a meal.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "If I leave this here, then I'm going to be completely alone.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Beside, Bina and Regina is here.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But let it be washing toilets.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But I want to be asked to do something, not to order it.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Especially when it's my time off.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I would have gladly stayed if she would have asked me.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I had nothing to do anyhow.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "There was no place to go.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Nothing to do.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And she said, I can't.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "She been working for me for 36 years.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "So I figured, uh oh.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "So it's more-- not what's justice, but what is comfortable for you.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Then I didn't think anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Then nothing mattered anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Because there two things I cannot negate.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "I cannot give up.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "It's my life, my self respect, my freedom, and my menschlichkeit.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "That, I'm not going to give up for anybody in this world.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "Because without it, I no long-- I will exist, but I'm not going to be a mensch anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "What I didn't know-- that she's-- she said that I should come back.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "That she's going to call up there and check out my story.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And she did, because at home, as I told you, I had no phone.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Didn't have any of the modern gadgets we have today.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And we were going.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We were working together.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But Bina and I shared everything except underwear.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We didn't care mine, so use, or money.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Regina was-- didn't quite-- she was a nice girl.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I have nothing bad to say about her.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But it was not the same relationship.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And from the sinks, from the regular sinks-- there was not a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I think I made a kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "That's how we lived.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But after Auschwitz, that was heaven.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I didn't complain.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And we went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "In-- in Sweden, the big meal is during the day.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "So every day, we would go, you know, for lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "So we took shifts.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "One day, Bina went home and warmed up the lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "One day, I.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And I was always fast.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And I'm rushing to go home to warm up the lunch.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "The homemade noodles that I made, with the chicken-- you know, like, still like home cooking, because I didn't even know that exist ready-made food at that time.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And as I walk, bingo, I'm all on the ground.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And somebody picks me up by the elbow from-- and I look up, and it's a man.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And I thank him.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And we start talking.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And he tells me that he's also a survivor of the Holocaust.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "And his name is Abram Shmolevicz.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And he lives on the same street.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "And he helps me home.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "And he was going to bandage my knees.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "I was still a modest girl, even after Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "So I says, oh, no.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And I cleaned up my knees.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "And I warmed up the food.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And he says to me, oh, smells so good.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "I would give-- gladly pay to get a meal like this.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And he was-- start to-- I don't know if I should call it date-- but he liked me.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And he came up.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I like him till this day.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Thank God, he's alive.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But as a friend.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "As a brother.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "No otherwise.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And we came in.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And as soon as I came in, a man was sitting there.",
      "word_count": 12
    }
  ],
