    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Little David must have been six.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And Micky in the front, who was just now 11.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "When that is.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Avital's Bat Mitzvah, all the grandchildren are together.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And that was a great joy to have them all together and photographed together with them.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Can you see I'm smiling?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It's my happiest moment there.",
      "word_count": 5
    },
    {
