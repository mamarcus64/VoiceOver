  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And we lived on the money that I had smuggled out of Germany at that time, a few-- a few years before.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well, you make-- you have your different experiences with family.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We had a cousin of mine and her husband, who had emigrated before, and in time to take out a substantial part of their money.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "You know, in earlier years it was possible.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And they had started a factory in Wales, a part of England which was subsidized by the government.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They-- they helped people erect factories and gave them tax abatement for a number of years, in order to develop an industry in that region.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We had even taken railroad tickets from London to that part of Wales, where they lived in Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "That you could do.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Buy-- my mother-- Hella had bought the tickets.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "We never used them, because they-- they didn't know us at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "They were afraid that we might ask them for money.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "So they broke off the relations.",
      "word_count": 6
    }
  ],
