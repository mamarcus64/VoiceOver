  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And then when the war started to get a little bit closer, the people who were there in the ghetto, they start taking them away.",
      "word_count": 25
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "Then they start separating, which they blamed us for coming there.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "They started-- they separated them to send them to Auschwitz, the older people.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "When we got in that camp, it was a camp, so-- but there were people who were there before.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "They still had their own clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "So one morning, they called up all those people for an appell.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "And they separated them.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "And they send them away.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 17,
      "text": "Very few of them remained.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 18,
      "text": "Only the young people remained.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Try to do my best.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "It's not easy.",
      "word_count": 3
    }
  ],
