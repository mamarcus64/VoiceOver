  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "In other words, you've got to start concentrating on-- on the living.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And I made it my business to-- to do something with my life.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Medford, Massachusetts.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Well, I had a teacher in high school that-- that was sort of sponsoring me.",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And it was a good university.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "So-- I was a good student, you know,so it was just a matter of-- he was sponsoring me.",
      "word_count": 18
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And he said, why don't you go to Tufts, because I went to Tufts.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And I said, well, I'll take-- I mean, I knew very little about colleges at that time.",
      "word_count": 17
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "So I knew about Harvard and-- and Yale and all that.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "But I was very pleased.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "I was very happy there.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "I was commuting.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I was commuting.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "In other words, from my house.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "In other words, I was not living on-- on the campus.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Now, when I went to Columbia University the next year-- I mean, after-- at '52 to '53--",
      "word_count": 17
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No, No.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "--graduated.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I graduated with a-- a B.A. in-- in History.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to Columbia University, who accepted me.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And then I got my Masters in Columbia University.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "European History and American History.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I'm not sure what exactly-- what made-- what my-- what exactly made me do this.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "But the point is this, that history was my favorite subject, OK?",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "Maybe it-- all my travels and everything else had something to do with it.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "But history became my-- my favorite subject, and that-- I stuck with it.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "American history, European history.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "And later on, you know, when I start teaching history, I even included Middle East and Medieval.",
      "word_count": 17
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, a Masters.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Political Science.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "The Masters was in Political Science.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "I was interested in government.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "One year.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Just one year.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Yes, New York.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "Columbia in one year.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "I made it in one year, the Masters.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "And then I went to the service for the Korean War.",
      "word_count": 11
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "That was between 1953 and '55.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "And then I met my wife during that period.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "--we got married.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Well, I was mostly in-- in the-- in the shipping area.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "In other words, I was shipping soldiers in-- out and in, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "Receiving them.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "Soldiers that were-- came from all parts of-- all parts of the world.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I also took care of the finances.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "The finances with the-- you know, how much these soldiers were getting, and everything else.",
      "word_count": 15
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "I would-- I would process those things.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 8,
      "text": "I think the-- the reason that I never went overseas, basically, is because I met my wife during that time.",
      "word_count": 20
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 9,
      "text": "And when we got married--",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "1954.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "We-- when we came-- when I came back, I had less than a year to go.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I didn't pay the-- Uncle Sam to-- to-- pay me-- pay them to go over to Korea.",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "Besides, 1953, a truce was signed anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "But no one knew exactly how long that truce was going to last.",
      "word_count": 13
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Lillian.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Lillian.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "And I met her during a-- during a dance in-- in-- in the Fort, in-- in Fort Dix.",
      "word_count": 18
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And it was love at first sight.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "I mean, we just had a proper chemistry.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Asbury Park, New Jersey.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "In other words, when I-- when I got out, my first job was in Asbury Park, New Jersey.",
      "word_count": 18
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "I was the teacher.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "I was a teacher, and-- and that's where we lived together.",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "In other words--",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "High school.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "High school.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And they-- they also needed a-- a German teacher, so it worked out nicely.",
      "word_count": 14
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "History and German.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "See, I-- I had a-- a minor in-- in German.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "That's, of course, basically, from-- from my experience.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "But it-- it worked out very nicely.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Well, she was a secretary of-- in a South Philadelphia school.",
      "word_count": 11
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Secretary.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "But when she-- when she moved to Asbury Park, she wasn't doing anything except taking care that-- of my daughter, who was-- you know, was just one-- let me see.",
      "word_count": 30
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Was just about a year old, my daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "What's that?",
      "word_count": 2
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "The first born, right.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Linda.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "Linda Susan.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "October, 1955.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "What's that?",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Linda?",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "I have Steven.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Who is 35.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "And-- now, 35.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "And Scott, who's 26, who's getting married in February.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Grandchildren?",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "I have three of them.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "One is Erin, and-- and Laura, and Diana.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "Laura and Diana are-- belong to my son, Steven.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "And-- and Erin is my-- my daughter's daughter.",
      "word_count": 8
    }
