{
  "stem": "1020.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "He didn't want to leave Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Drexler.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Marion.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "In Polish, they called him Marion.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But in the Yiddish name was Malach.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Malach is like, I say, a kink in translation in Hebrew-- Malach.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I found the two sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And they related to me.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "My wife is a cousin of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And I told them, I didn't know that we're going to be together.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "But I told them I'd like to take them out of Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "In which time, I'm six years older than Annie.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "So she depended upon that I will.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "So I took the two sisters out of Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And I saved my cousin, one in the army.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I went in to the-- bought a civilian suit with a hat, with a coat.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I took him out from the army camp.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "I had already tickets.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "And Annie and her sister were already in Kattowitz, away from Bendin, awaiting me.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "We had already planned out.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "I was a big planner and a risk in my life-- how to do it.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "And we escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "And here we come on the Czechoslovakian Polish border.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "We came into Kattowitz.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "And from Kattowitz, we got together to go.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "We're coming on the border.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "Here the Russians again-- passports.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "You know, the Russians were controlling Europe all the years.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "Everything was under Russian control.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I speak Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We left all what we took.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Our belongings were left on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We figure, we'll come back.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I took the two girls.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I bought a Russian jacket with a Russian hat.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And I said to the Russians, where can I get in here some tea?",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I speak Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "He says, go over there to the station.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I said to the girls, in Russian, let's go.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So we run around.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "As soon the control passed my wagon, we went back into the train the other way.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And all our belongings were gone.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "They stole everything from us on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have-- if we would walk with all the belongings, they would stopped us.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "So I speak Russian. they didn't know.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "So we went, and we came into Bratislava in Czechoslovakia to the town.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And we didn't have anything to wear, nothing to change.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "Everything what we wore was, We have two ladies, too.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Molly was-- Annie was 19-- not even 19.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And Molly was not even 17.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And I got to take care.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "But Jewish people are very helpful.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "There was already a committee in Bratislava which they helped all the refugees coming in.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "They served soup.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "And they located us where to stay.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And I think I made a little mention-- I mentioned to you before that communication after the war was on the wall.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "Everything was written on the wall-- names.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "I'm going there.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "And I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "And this and this name is in here.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "And we start to follow.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 25,
      "text": "So we found out that we're going to leave Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 26,
      "text": "We're going to Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 27,
      "text": "Well them we did tricky.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 28,
      "text": "I had my cousin, the one I took him out from the army, and the two sisters.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 29,
      "text": "Now we had to cross another border-- illegal, Germans, the Americans on one side, Russian and Czechs on one side.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 30,
      "text": "So we were coming to the border.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 31,
      "text": "I said to my cousin, you go first that the girls shouldn't be left alone.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 32,
      "text": "Always should be somebody to overlook.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 33,
      "text": "Men is different.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 34,
      "text": "I sent him first.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 35,
      "text": "I send Molly next across.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 36,
      "text": "Then Annie went.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 37,
      "text": "And I was the last one.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 38,
      "text": "And we crossed.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 39,
      "text": "So we start to walk away from the border.",
      "word_count": 9
    }
  ],
