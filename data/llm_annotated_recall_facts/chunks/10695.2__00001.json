  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My family wasn't-- wait, I forgot something-- OK-- [PAUSES FOR 8 SECONDS] My mother, the sisters, and the kids, they took them away five days before.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] They separated the young boys, the young girls.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They put them in synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was a big synagogue, beautiful synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They put us in the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And they captured us five days without food.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Without water and without food.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 8 SECONDS] We should lose our strength and fifth day, they took us out.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "The Jewish police came, and they brought over bread.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Loaf of bread.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "I captured a bread.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And a German was standing by.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "He ran over the German and killed one Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "The bullets went into young boy in the hand, and the bullets went to me.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "It right-- hit me.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "It hit me very-- very bad, very sharp.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "But it not hit me, just hit me.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And they took us to the train.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "They took us to the train.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "I didn't want to go to the train, run away.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "I was full of life because I had a bread.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "I ate bread.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "And became dark. 5 o'clock, it was September, end of September, about at 6 o'clock got dark.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 4 SECONDS] And like the German came over and said kill them.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "They should kill us.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "The people would.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "I am so sick.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 6 SECONDS] They should kill us on the spot.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "I understand what they said.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "[PAUSES FOR 4 SECONDS] My-- I pushed me in the train.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 4 SECONDS] I was by the door.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 32,
      "text": "The door was locked-- closed.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 33,
      "text": "I said, please, people, let me go to the window.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 34,
      "text": "Maybe I will help some people escape, too.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 35,
      "text": "I went to the window and I-- it was a rail in the middle of the window.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 36,
      "text": "I broke the rail, one side, just one side.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "And I jumped onto the train.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "I jumped onto the train.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "I was watching the train.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "The train was going about 200 speed limit.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "The train was going.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 42,
      "text": "I was watching.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 43,
      "text": "They should be a-- a hole, and I jumped out into hole.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 44,
      "text": "I lost my mind.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 45,
      "text": "My mind-- something hurt-- hurt me and got help came a rain.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 46,
      "text": "When the rain started to pouring, it was leaking.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 47,
      "text": "And we became wet.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 48,
      "text": "And I came to myself.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 49,
      "text": "I remember a Jewish boy jumped close where I-- where I jumped.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "It was a soldier, a Polish soldier with a Polish [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I saw to him.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Are you a Jew?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I told him.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "I said, yes, I'm Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I jumped from the train, too.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And this, he said, [PAUSES FOR 4 SECONDS] we can't stay here, by the rail, because the German, when it gets daytime, the German comes and the rest-- there a lot of people jumped-- they cut the hands, they cut the feet, and the Germans killed them.",
      "word_count": 47
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Shoot-- shoot them.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I didn't, was scared nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I went to a garden with cabbage.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I laid down with the cabbage, I digged a little hole, and I saw the Germans coming and they killed the people where they jump.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] And I was laying all day with the cabbage.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Well, the boy didn't go with me.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "He went separately run away, run away.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "It was about 10 miles from the city.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "Because since I jump, the train was running around about 200 speed limit, I moved away the train about 10 miles.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And [PAUSES FOR 3 SECONDS] I started to go home to my father.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I know my father was still alive because I want to tell them what happened to the mother and I want-- go in two weeks, I was going home to the city where I was born, lived.",
      "word_count": 37
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I-- two weeks, took me.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "There's one small town.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] There was Germans there.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "They came with a big light reflector.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "You know what's mean, reflector?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Because the Polish people, the bastards, they let the German know Jewish boy is going in the city, in the small town there.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And they want me-- this reflector, they're looking for me.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Or I running downstairs because was-- I run downstairs.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They shouldn't-- they didn't see me, or their reflector was lighting but then 15 minutes, they didn't saw me.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I was going home.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Still going home.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I came home and saw my father.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And there was about 200 people more, Jewish people, living in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] And I told they, they took the woman to kill, and the kids.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "They didn't believe me.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They didn't believe me.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I can't help it.",
      "word_count": 4
    }
  ],
