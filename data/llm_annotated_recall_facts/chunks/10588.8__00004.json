    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "That was the first time I got a good cry after-- after liberation.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Was the kindest woman I met.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "She must have heard me cry, or she maybe assumed that I cried.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She knocked at the door.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "She said, Itka, come out.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You cried enough alone.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Come share-- we'll be with you.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And she embraced me.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And I start to-- I said to myself, the only way to combat evil is to do good to it.",
      "word_count": 20
