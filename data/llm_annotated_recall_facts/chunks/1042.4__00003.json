  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Children had to know me-- who I am.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "You know, and a strange man is coming-- not always for the children are welcome.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So we were awaiting the time they were bar mitzvah.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And then my wife told them, listen, boys, I want to know what is your opinion about I would like to marry Joe Sterngast.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So the answer was, you know, Mommy, this is the only person what we agree you should marry him.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Right from the beginning, we love him so much.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he will replace our father.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And they were very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And in 1960 we married.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And things got-- we are very happy.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Our son is in Toronto, with two great children what we love-- you know? it's hard to describe.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Those are our children.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And we go very often there.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We are with them.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And the holidays-- like now, Passover-- I have to be with them and to make the Seder for Passover.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And the Rosh Hashana, also, we spend together.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And, altogether, we are very happy.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And really [PAUSES FOR 3 SECONDS] I am very happy for my decision.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And the children, they love me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And that's our life now.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "We live, and we are coming every year here.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "We are for a few months in Florida.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "You're very welcome.",
      "word_count": 3
    },
