{
  "stem": "10359.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "And on the left is me being a teenager at the age of 16.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "On the bottom is the picture of my sister, from the top left, and her husband.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "My brother-in-law, who was killed by the Soviets because of being an active leader of the Zionist movement.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "And two of her friends, who were emigrated before the war to Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "The picture here, is on the left side is a picture of a friend of mine, Csesek Wierzbicki, who is presently in Florida.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "He's the one who helped me to get a job with the German toy organization while Dorothy was in hospital.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "He's the one who helped me to arrange certain things while I was in Ostrog, and we still maintain active communication.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "He helped me tremendously during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 4 SECONDS] The picture on the upper left and lower left is me with my friend, Zygmunt Sinawski.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "That's the gentleman who helped me during the war in 1941, in Rowno.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "When I went to get my sister to bring back to Ostrog, he kept me for two or three days in the basement of a theater.",
      "word_count": 26
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "And this picture is when we visit him in Poland, several years ago in Warsaw.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "One more.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I don't think-- well, the left picture is self-explanatory.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "That's me in diapers.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "The right one is my brother Henry, the one who studied in Austria and France, and came to the United States, luckily, right before the war.",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He practiced medicine here.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "The lower middle is part of my indirect family.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Some uncles and aunts from Ostrog.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They all perished in the second action in 1941, in Ostrog.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 14 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "You told a story.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I told them before, in detail, so I would not repeat myself.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And my wife, I think, wants to say a few words about the dolls that she wanted, which we bought in Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I love my family dearly.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "My daughter and granddaughter.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "It's all we have left, now.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I have nieces in California and New Jersey.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "The doll that I'm holding, I bought in Poland when we went to visit our dear friend Zygmunt.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "The reason I bought the two dolls is because the costumes remind me of the dance I did.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "It was the night of Polish dance that I did on the stage.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And that's the exact costume that I wore.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he played a piano, and I danced with a group of friends.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm the proud mother of Simone.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And daughter of Dorothy and Mark.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And it's really an honor to be part of this video and whole experience.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I really can't relate to anything that they experienced in the war, because I was born in this country.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And privileged to be born free, and without the prejudices and the plights that they had to undergo.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "is Simone, and I call my grandparents Boba and Papa.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Sort of a nickname for grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And I love them very much.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "That's very nice.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Beautiful.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
