{
  "stem": "10587.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "My sister's sitting, Regina Honigstein, that-- and top-- above Regina is Jacob Rosenbaum, who was with me during the entire time in the various concentration camps, and myself.",
      "word_count": 28
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "This was taken in approximately 1945, after the war, in Munich, Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And my sister is now married to Leo Honigstein, who we spent together since [NON-ENGLISH], throughout the rest of the concentration camps.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "This picture I am standing.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "My brother-in-law, David Chapelle is sitting.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "This was taken after the war, 1949 in Munich, Germany, English Tiergarten.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "This American soldier looks like me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "This was taken during the Korean War when I was in the army, approximately 1953.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Mark Bader.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Rank?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Was corporal.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And this picture is my lovely wife and myself.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "This picture was taken just after we were engaged in 1956 in Detroit, Michigan.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "My name is Mark Bader.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And my lovely wife is Rhona Elaine Bader.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Maiden name was Rhona Elaine Fiedler.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "This is my grandfather's house in Auschwitz, or Oswiecim, Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And this was a postcard, which was blown up after my sister brought it back from one of the trips to my hometown.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And it's on the main square in Oswiecim.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It's still there.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "At the present time, it's the-- the city hall for Oswiecim.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "This is a picture, from right to left, is Tim Freund, and Tamara Freund-- my daughter Tamara Freund.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Tamara was named after Tamara Bader, my grandmother.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Next to her is Debbie-- Deborah Hope.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Deborah was named after one of my wife's aunts and one of my aunts.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And then I am standing next to Debbie, my wife is to the left of me.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And then we have Rochelle Susan, my oldest daughter.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And my youngest child, David Joseph Bader.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Rochelle was named after my youngest aunt, Rochelle Susan Enoch.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And David was named after-- my mother-- my wife's--",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "My wife's--",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Rochelle was named for your mother.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Rochelle is your mother's name.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Susan was your aunt's.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Rochelle.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And my daughter, Deborah, is named for my grandmother.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Can I make a correction?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I got confused.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And I don't have my glasses on.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Next to my wife is standing Rochelle Susan, who was named after my mother and my aunt, my mother's younger sister.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Next to her is David Joe, actually David Joseph Bader.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "He's named after my wife's grandfather and my uncle, the oldest uncle, Enoch-- Joseph Enoch.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It was taken in July of 1995.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Los Angeles.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Actually Beverly Hills.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Those are my grandchildren, from right to left, is Daniel Jordan.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "He was named after my wife's grandfather and my Grandfather Bader.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Next to him is Joshua Henry.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "He was named after my youngest brother, Joshua.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And Henry after my wife's father.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Next to Joshua is Hannah Linton Freund.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Hannah was named after my aunt Helen, who I stayed with when I came to this country in Detroit, Michigan.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And she sent me the papers to come to this country.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And Linton is a name from the Freund's family.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Next to her is Andrea Carol Goodman.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Andrea was named after her father's family names.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And sitting on Andrea's lap is [PAUSES FOR 5 SECONDS] Adam.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "Adam Bader Freund.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "He is our youngest grandchild.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "He is-- he was named after my brother, [NON-ENGLISH], who did not survive the camp-- the camps.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "And after, they left the Bader family.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "This photograph was taken at Passover of 1995.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The Regency Club in Westwood, California.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Thank you very, very much.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And also I'd like to thank Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Spielberg for his-- his generosity that he was able to create this.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I am very impressed with what he has done, and what he is still trying to accomplish.",
      "word_count": 17
    }
  ],
