  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "We were all slaves.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "Worse than slaves, because a slave has some rights-- gets fed, gets things.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "We were worse than them.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "They brought us to destroy us.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "Even the ones who send there-- were sent, who would take a little longer.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And I realized all those conditions, and then the work, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "And that's when I realized, and I said to myself-- I started to examine the values of my parents.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "I realized the importance of their love.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And-- and then, when we went to work, and when we came back-- constant selection, constant with people dying.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And mountains, mountains, of body.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Around us was the electric, electrical barbed wires.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Above us, smoke.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Beneath us, muddy, muddy ground, and constantly people dying in [INAUDIBLE] columns.",
      "word_count": 12
    }
  ],
