  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "She's-- she's a sister, not a sister-in-law.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So I went into a place where it was-- a cold flat, with a toilet outside, and the bath tub in the kitchen.",
      "word_count": 23
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And my husband started to work, and he was making-- and we always say it.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's an expression in Russian-- [SPEAKING RUSSIAN], meaning half of nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That-- and I had an infant.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And being that I was brought up with a live-in maid.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And I said to my Aunt Rhea, please, find me a place where I can go and scrub somebody's toilets.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I went to the butcher, bought a small piece of meat, used extra potatoes that it would fill up the stomach.",
      "word_count": 22
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "But I always tried to feed the stomach with the right kind of food.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was pregnant three more times.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Twice I had miscarriages.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And one time, being that I worked very hard work on a farm, [PAUSES FOR 4 SECONDS] I was hemorrhaging for six weeks until, she was taken by-- by C-section.",
      "word_count": 30
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And she died after two days.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "This is the end.",
      "word_count": 4
    }
  ],
