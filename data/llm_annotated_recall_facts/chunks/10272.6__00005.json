{
  "stem": "10272.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And with  broken English, I told him the story that I am now a refugee from Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I don't have nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "I want to go to America because I have an-- I have an aunt in America.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "I didn't know where she lives.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "But I know that she's an American.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So he put me in this Cinecitta thing there.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And there I was-- I was there sleeping, sleeping there and getting lunches and getting packages.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And during the day, I was walking and seeing Rome-- Vatican I got to visit.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "All Rome-- all over Rome, I went to see all the places.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "One day, I-- they asked me in the office about America-- to fill out forms.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't remember the name of my aunt.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So they said, if you don't know the name, you cannot find-- you have to know the name.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Where is she located?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "What is her name?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "So I-- they asked me, do you want to go to-- you're from Czechoslovakia?",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "There's a transport train leaving from here, from this camp, back to Czechoslovakia.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I said, OK, I'll go.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Because I  want to see if somebody from my family survived.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "Maybe a brother survived, maybe my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "So I joined this train.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "And it took me to Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "So you went back to Czechoslovakia?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Czechoslovakia.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "That is it.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "That's It.",
      "word_count": 2
    }
  ],
