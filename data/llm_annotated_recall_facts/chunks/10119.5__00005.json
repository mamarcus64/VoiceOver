  "model": "openai/gpt-oss-120b",
  "elapsed_s": 121.6,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "We lived there for about-- I don't know-- five years or so.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "From there, we moved to the island on Glen Oaks.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "We already had two children at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "My second son was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Mark.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Mark.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Second one is Edward.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In Hebrew, it's [INAUDIBLE] is my younger one.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And the second one is [INAUDIBLE]-- got to think a bit-- [INAUDIBLE]",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Eleazar, ?] I can't think of it right now.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Just too much, what was going on today.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "My head is just jumping.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, I'm trying.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It's not easy.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Then we moved to Glen Oaks, the Garden Apartments.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "By that time, my husband already was a butcher.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "He got a job in Great Neck.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "My children went to Great Neck to school.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And when we decided to try for a little girl, which we were very happy to have another little boy.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Robert, and Eleazar is his second name.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And we lived there in Glen Oaks.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I'm trying to rush it.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how much time we have--",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "--to get into the tapes.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, I like to tell my children, be good.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Make sure that you are OK with charities.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "The main thing, don't forget who you are.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Whatever you do, we love you.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And try to do the best you can.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "We love you all.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS] This message I'm trying to give you is my memories.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Try to give it to your children, to your grandchildren, and for our future generation.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Never forget the 6 million Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "I know you will try.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "Because once we are gone, it will be a tough time to let people know there was a very bad war, [? very ?] [? crucial. ?] And we went through from the ashes to life.",
      "word_count": 36
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And never forget who you are.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "Oh--",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I would like to.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Well, I met my husband in Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We got married in Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And we are married 49 years.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "We have three lovely children, and lovely daughters-in-law and grandchildren.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "This is part of my life.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Shall I say the other half?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "This is part my half.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "We went through high and low, hot and cold.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "But I'm thankful to God that we met, and to him.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "He's very good to me and to the children.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "I hope and pray that God lets us stay here for a long, long time yet.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "His name is Josef, Josef Schwartz.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Yosek ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Note ?] Schwartz.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Well.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And we are coming a long way.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Half way around the world.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And we met.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "We are happy, and the future looks good.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "All right?",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm the lucky guy.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I got the best woman there is.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We are married for 49 years.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "We went through hell together, ups and downs.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "And I'm continue to support the whole family.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And the kids are good to us.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And we hope we're going to see our weddings, bar mitzvahs of [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "We went through plenty.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "We're not dead.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "So we are looking future for [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We're having a bar mitzvah coming up for our grandson.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And I'm hoping that God would be good to us, and I can walk down the aisle with my granddaughter, Beth.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "The other ones are still young.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "So we hope we will be around for a long, long time.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "This is a school picture made in Krive of my little sister's school, public school in 1938.",
      "word_count": 17
    }
  ],
