  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She bringed the-- the-- [NON-ENGLISH], you know-- the [NON-ENGLISH] to the room.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She said she has Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And then the--",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "She was a Ukrainian.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "A woman.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "She was a superintendent.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "This is like she take care of the house, you know, everything.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "So she bringed everybody over there, the Ukrainian.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They got the one day they can do with the Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "What they did-- my oldest brother was over there, too, but not in the same place.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Then he talks from them to-- he take his head on the wall.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He couldn't hear.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "What they did, they cut pieces from them.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother--",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "--was in Israel, but he passed away.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "That's how I know.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And they got killed by them.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah but then we left to the small town to my sister over there.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We-- we was thinking maybe they not coming over there.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But they was over there-- all over.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was very hard-- not so easy.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how many-- two months.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And what I got everything-- and my brother, I give everything to one guy.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "He was the chief from the police.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And he tell us, this night, you have to go from the town.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Because they are going here.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And we left, and the small kids, my sister's three small kids, my mother, my father, and I.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "We didn't-- where are you gonna go?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "No place.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Who will let you in?",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "But one guy let us in where they caught the-- the horses, the cow-- one night.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And then in the night we hear what was going on-- the small town.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "This family was killed-- everybody.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "This was in our village-- in our village.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Next day, he says, you have to go.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Where we go?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "No place to go.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "We go again to one.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I told you, my father got the money.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "He borrowed then the money.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And he let him in-- but not for long-- just the same place where the cow-- the cow, and the-- and the-- and the horses, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Then my mother says to me, you know what?",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Don't stay with us.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I say, where I go?",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I don't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "It was one guy over there, Polish guy.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "He says, I take her to Krakow in ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I got my brother-- the oldest brother was in ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "This time, the ghetto was closed.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You can't go-- not go-- not in, not out.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "All the Jewish people in one place-- it was a big place, you know, the-- not so big, but all the Jewish people was in the one place.",
      "word_count": 28
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I says-- and the guy says, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "If you give me 3,000 zloty-- not dollars-- 3,000 zloty, I take her to Krakow.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "When you got to Krakow with me, I don't know you-- nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "You-- you go first, or I go first, and you go behind.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "It was 40 kilometers to Krakow from this village.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "So my father says, I have $20 I can give you-- no more.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "I don't have any more.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "So he says, no.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "I wanted 3,000 zlotys.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "The $20 he doesn't want.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So my father gives him the 3,000 zloty, and he went with me.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But I was afraid, you know, that the German they go in and back-- they recognize me or not.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "So I take something, a piece of bread, another [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how-- on the back-- and-- and milk.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I put a-- a scarf like this.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Nobody recognized me.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "But I couldn't walk so many kilometers.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "You know, I says, I got like this.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "I says, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "Maybe we take the-- it was a tram by in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "He said-- I says, I can't walk anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "He says, what?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "You crazy?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "If somebody recognize you-- and this was true.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "And I said, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "[NON-ENGLISH] was at the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "The [NON-ENGLISH] was like here, sometimes here.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "Sometime you need a [NON-ENGLISH] another wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "A [NON-ENGLISH] is a horse.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a horse.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And a carriage.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And a-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "But-- but this was covered.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And he did.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "So where can I go?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "You can't go in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And then I says, you know what?",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "In this same strip, where the ghetto was, my brother used to work-- live on this street.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I says, take me over there to the superintendent.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And he took me.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "See, he got two kids.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "She's saw me.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "You know how the Pollacks-- I'm afraid, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "But the kids are not here.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "I take you and put you in the closet.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And-- but if the kids enter here, they cannot recognize you.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "They can go and tell them.",
      "word_count": 6
    }
  ],
