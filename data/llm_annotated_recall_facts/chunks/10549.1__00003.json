  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And somehow I persuaded [PAUSES FOR 3 SECONDS] one of the majors over there to give an order that before they liquidated the ghetto, they should bring my father to the prison.",
      "word_count": 32
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Actually, the prison saved our life.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Because we were locked up in the prison, we were, we were safe to-- in the prison.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "That saved our lives.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "At that time they liquidated the ghetto, literally.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "They took a lot of the people from the ghetto to concentration camps.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "The one who was older, they used to, they used to shoot, shot, shoot a lot of people, kill them.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] They went to hospitals, and they liquidated the hospitals.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "They used to shoot the people in bed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "My father was telling me, when he came in-- they found him, [PAUSES FOR 3 SECONDS] because he was in the house where the-- actually was designated for us, so they-- the, the major gave a order to look for my father.",
      "word_count": 42
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And they found him.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And they put him on a truck.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 5 SECONDS] They put him on a truck.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And the same truck stopped in a nursery, [PAUSES FOR 4 SECONDS] and they took about 20 kids from the nursery, on the same truck.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] And they stopped.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "They, they drove over to Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "Plaszow was a concentration camp not far from, from the Cracow ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And was in the That's where it was.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "They took the kids.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "They stopped at, at the field by the concentration, concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "They took the kids out, and my father was left in the truck.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "And he heard when they shot all those 20 kids.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "When my father came in to prison, when I met him, he was in shock.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "He couldn't stand it.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "He says he, he was, he was beside himself.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "And he told me that.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "And [PAUSES FOR 3 SECONDS] he was-- it was terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "And that's how they liquidated the ghetto.",
      "word_count": 7
    }
  ],
