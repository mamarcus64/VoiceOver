  "elapsed_s": 68.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was a shipping clerk.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Maybe two years.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In December--",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "--1949.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "First, I was just a worker.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Then, I was assistant.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Then, I became manager.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Of the furniture store.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to school.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "My boss thought I spend too much in school.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "So he told me I speak better English and read better than he can.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And he really, I wish he wouldn't give it to me, because anything you learn a plus.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And he made me quit, you know, which I didn't like it.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Because he was needing me different times of day to be with him.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And I wish he wouldn't do that to me.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Because I really enjoyed it.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "It's a-- it's a-- I had a private teacher.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Hester.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "She taught me English.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "She used to teach in Columbia University.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And-- and she thought I did good-- been doing good, she thought.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I used to do lots better than I'm doing today.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "I used to write good and everything, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I got involved in business.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "I had so many secretaries.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "I had sometime I used to complain to my teacher such a difficulties, and watch your tongue, don't be [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I had problems.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "She say, get a dictionary.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And I thought it's really something which is not proper way to do it.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "Almost everybody carry a dictionary.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And I used to carry a little dictionary in my book.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "When I wouldn't pronounce it right or spell wrong, I look in the dictionary.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "I don't want to look like a schlemiel spelling something, and maybe not proper or right way about it.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "It's-- it's proper.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "Everybody do that.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "It's proper way.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "If you don't know something, you answer, how you spell it?",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "How you spell it?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I used [INAUDIBLE] conscious to say that.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You know, I thought it's not common.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But it's very common to say how you spell something.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "It's-- it's something.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "When you left the furniture store, where did you to work?",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I had a friend of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He was in scrap, buying scrap iron, running around.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And he was telling me, he was a nice fellow.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He use to come to the house taking me a ride.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I didn't have no car.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And he really did a mitzvah-- took me out on a little boy.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And then I had another little boy.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And he'd been telling me he ran around buying scrap and making a living.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And he got a fellow-- a black fellow with him.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And he help in driving the truck, and he'd making a nice living.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "He really liked it.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And he told me he makes some day $30, $35, $40.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "Hey, I worked a whole week for that money.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And something in my kopf, in the head been laying about him, what he was telling me.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And soon enough, the poor fellow was sick and died.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "They didn't have no children.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And I knew that lady, very-- Kaplan was her name-- very well.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And Leon-- the truck went back to the, [? you know, ?] national people.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And-- and I was working with that fellow in the furniture store.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "He always threatened me, and was not appreciable of what I was doing.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "I was working for two, three people.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "One day, I just quit.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And most people say what are you going to do?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You've got a family.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'll take care of them.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I'm in a free country.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Nobody going to have to feed me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I know how to take care of my family.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Then, I started running around, burying scrap iron.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I could hardly drive a truck.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Barely drove a car.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Before you know it, I find out where is that black fellow who used to work for him, Leon.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And I had somebody else running around all over the road.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And people liked me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And I started doing real good.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And I liked that work what I was doing.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "People thought I'm Leon's son, you know, because he never talked about children.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "He was an older fellow.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And I went places where he was going, and I start making a living.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And people liked me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And before you know it, I got into the oil fields, and buying pipe.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "I had a friend of mine that never met Jewish people even in-- in the country.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And all of them, they like me.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "I told him who I am.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And they start selling me pipe, and told me to start selling more pipe-- better than scrap iron, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And I started selling pipe and more and more.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And then I got into business with a-- a lot older man here.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "He was born here in Monroe.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "Marx-- David Marx.",
      "word_count": 3
    }
  ],
