      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And that's what I try to-- that's what I try to teach them.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "It's hard for them to understand at this age.",
