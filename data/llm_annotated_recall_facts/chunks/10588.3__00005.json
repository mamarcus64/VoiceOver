    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "So they kept on chasing me away.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And finally, one of them got a bright idea, said, [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "You see, that's why it was useful that I spoke Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "I could understand what they said more, because it's similar.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "And mostly during the Holocaust, I could follow all this.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "And that saved me from a lot of beating.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They took us both.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They brought us to the Gestapo station.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they separated us.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "My mother--",
      "word_count": 2
    }
