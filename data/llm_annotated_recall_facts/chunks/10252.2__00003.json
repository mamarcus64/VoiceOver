  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] Those are my two cousins that are now living in Israel and I in the Czechoslovakian Tatra.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "It's right after the war.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "I'm waiting for my mother to come back from Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] This is I in Munchen, probably in 1950, thinking I'm very beautiful, I think.",
      "word_count": 18
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I must have given it to a boyfriend.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] This is the that brought my stepfather, my mother, and I to America.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't a luxury cruiser.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "We came into New York.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We left Bremerhaven and came into New York.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "It was a horrendous trip.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "It was in November.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Unbelievable.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "That is an incredible-- you can't imagine that feeling.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "That-- that's-- that's unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] This is Kenneth and Cherie at Ken's bar mitzvah.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And that's my Lhasa Apso, Tutu.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Tutu is no longer with us.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "My daughter was born in '58, and Kenneth was born in '56.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Don't ask me how old they are, because I never remember their ages.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I choose not to.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Those are my grandchildren, Jade and Bo.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "It's a recent picture, about a year old.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "They live in Florida, and they're wonderful children.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I love them very much.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Bo--",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Bo is 11, and Jade is 4.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] That is Stuart my husband, and I think that's me.",
      "word_count": 14
    }
  ],
