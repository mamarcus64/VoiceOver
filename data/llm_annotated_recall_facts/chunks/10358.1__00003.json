{
  "stem": "10358.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And then they chased everybody out again of the houses.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And then my mother was taken first.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I was able-- I was separated from my mother and I ran.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And I opened the door from the basement.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Do you want to say something?",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They chased-- they chased them-- I didn't know where they chased-- where-- where to, because I remained in the house.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They got my mother first.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And I was able to run into the cellar.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And I closed the door on the inside of the cellar, so they were able-- they knew that somebody's there, because I should've left the door open, which I didn't.",
      "word_count": 30
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "I left it-- I locked from the inside in the cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And I was sitting in the cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And-- and then I heard footsteps in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Again, [GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "And then somebody tried to open the door from the cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And he was banging with the rifle.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "At this point, I felt it's no use.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "My mother was gone and everybody else is gone.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "I might as well go to.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "I I felt there's no point to-- to remain alive.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "As I came out from the cellar, in front of me was this Ukrainian policeman with a big rifle.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 15,
      "text": "And he said, out.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 16,
      "text": "And I went on my knees and I cried.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 17,
      "text": "And I said please, let me live.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 18,
      "text": "I want to live.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 19,
      "text": "I'm only 16 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And he said, go back into the cellar but leave the door open.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He remained in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Then several Nazis-- I heard the footsteps-- several Nazis came in into the house.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And they asked him in German, is everybody [GERMAN]?",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And he said yes, everybody's [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I was all day in the cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And then towards the evening, I said, I'm going to get myself out and I don't want to live.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "As I ran out through the back of the cellar, I saw my mother running up the hill.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And she was black.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Her face was black.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I never saw her look like this.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And she said, they took all your friends, all the young people they took on trucks.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And she was screaming and crying.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And we embraced.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And we came back to the house.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "This was the second execution, where they took all the young people, all my friends, all my young relatives they took on trucks and we didn't know where they took them.",
      "word_count": 31
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "Some say that they were gassed in the trucks and some say they were shot.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "This, I don't have no recollection of that.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "That was the second [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "And after that, [PAUSES FOR 3 SECONDS] we lived in fear.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Excuse me?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We went out of the house, yes, because after that, an order came out they're going to place us in a ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We had to pack our belongings and move to a ghetto, which was a-- a neighborhood where very poor Jews lived years ago.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And there was this big, very famous synagogue, [NON-ENGLISH], it was called, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "Maharsha.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It was just called Ostrog ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Living in the ghetto?",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "We were-- we-- they gave us one room and a kitchen to share with-- with other people.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "It was a small room and my mother and I slept in one room.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And we were practically starving.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "There was no food.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Whoever tried to escape from the ghetto to get food, they were shot in front of that synagogue.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "All the executions were in front of the synagogue, because we were told that this one was shot and all our other friends were shot in front of the synagogue, this big [NON-ENGLISH].",
      "word_count": 33
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "And there was no food.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "And it was despair.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And it was hunger, was-- was horrendous.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "It was-- it's impossible to describe.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "And we lived-- it was a day to day, an hour from hour, a day to day existence, [PAUSES FOR 3 SECONDS] and-- until started the third execution, the Final Solution.",
      "word_count": 31
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody worked.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Nobody worked.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It was a different ghetto than other ghettos.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "We had-- we had rations.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We were on line for just little, little food.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "But we were able to get-- my mother had friends, Ukrainian friends.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And somehow they were able to smuggle some food to my mother, but very little.",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "They did it near a gate, because we were-- the ghetto had barbed wires.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "There was a gate.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "They came-- they came to the gate and they were able to [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I-- my husband will give you the information.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "I just don't recall right now.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes, however long.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And then my husband-- at that time, he was my friend from school.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "We were friends.",
      "word_count": 3
    }
  ],
