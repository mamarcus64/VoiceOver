    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "In order to go there, they gave us a soldier of the Yugoslavian Army who was supposed to take us from the border to the station.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And we could see the station maybe half a mile away.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "We could see the station.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And he took us instead to the station.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He took us a few hundred feet maybe to the German border.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He handed us out to the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He was a Croat, a German spy.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And this was the end of my liberty.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We were arrested, spent a couple days on the border.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And then they took us to Graz-- to the largest city in Southern Austria.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And in about 10 days, we were-- 10 days--",
