    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So I guess that's my message.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My advice to my children is that they should cherish freedom, because it's precious.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And they should not take anything for granted, because the Holocaust can repeat itself.",
