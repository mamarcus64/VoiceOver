      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And we worked on the Gestapo headquarters as a laborer.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "I was carrying coal.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "I was carrying furniture because the Gestapo were in charge of liquidating and confiscating all the wealth or whatever they were taking away from everybody, and mostly Jewish population.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] So I become one of the workers.",
      "recall": true,
      "topics": [
        "Forced labor"
      ]
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "And because I became a useful person-- when the ghetto started in Cracow, they designated one building for their workers.",
