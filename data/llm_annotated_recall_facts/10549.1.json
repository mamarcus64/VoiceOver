      "topics": [
        "Captivity",
        "Parents"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "They confiscate the jewelry.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And they, they locked him in, in a, in a prison.",
