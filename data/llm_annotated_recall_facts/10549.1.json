    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I found out later on that my sister went to Russia, because right after the war broke out with, between Germany and Russia, she went to Russia, where she lived through in Russia.",
      "recall": true,
      "topics": [
        "Refugee experiences"
      ]
    },
    {
