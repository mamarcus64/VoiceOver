      "topics": [
        "Feelings and thoughts"
      ]
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "When the war broke out-- at that time, my whole life changed.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
