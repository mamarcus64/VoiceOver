      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "And I couldn't holler in order for him to, to, to see me, but I whistled his favorite tune.",
      "recall": true,
      "topics": [
        "Captivity",
        "Parents"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "And was very quiet.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "And he came over to the window.",
      "recall": true,
      "topics": [
        "Captivity"
      ]
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "And I had a chance to, to, to say a few words to him.",
