      "topics": [
        "Daily life (childhood)"
      ]
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "That was on the Polish side of the border.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "There was a border town, actually between Germany and Poland.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And there was a border town.",
      "recall": false,
      "topics": []
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "The name of the, the town was Katowice.",
