  "elapsed_s": 147.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And he-- and Vati said, [PAUSES FOR 3 SECONDS] that he did something that-- he-- he-- he made it clear that we knew nothing about it.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My father tried to get some cash money and some silver cutlery, sterling silver cutlery, that he was hoping, if we ever get out, that he was able to sell.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And they caught this man who did-- who tried to smuggle it out of Germany at the border.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "My father was arrested.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "He was put into prison.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And three months later, I heard that if a girl's 18 year old and over, could apply to England to become a maid in a English household.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Without telling my parents, I applied for that, and I lied about my age.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And not very long after, I got a special delivery letter that I was accepted.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No, anybody could.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But no-- no-- no Gentile girls would apply, mostly Jewish-- only Jewish girls applied.",
      "word_count": 14
    }
  ],
