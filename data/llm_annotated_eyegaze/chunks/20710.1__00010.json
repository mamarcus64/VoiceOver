  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So the-- the-- the men used to go there and the-- and the woman from all around, from all these villages used to come in the morning and-- and-- and work there all day and then go home.",
      "word_count": 38
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So this was going on all summer.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And of course, [INAUDIBLE] and also the same thing the Ukrainians used to come and used to-- they-- they tortured us.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Not that much, though, the Germans didn't come too much in there, because there wasn't enough, you know, Jews to-- to-- to take care.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And they gave it over to them.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And they were much worse in some ways.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They were very-- they were very ignorant people.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They were very, you know, vicious people.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
