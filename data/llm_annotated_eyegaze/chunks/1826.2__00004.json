  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And we still didn't know what to do with me.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "She didn't know what to do with me.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "She couldn't tell me, go.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "Because if I go, they-- the Germans will kill me right way.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "So we-- we knew.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "Again, comes in here [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "My brother had this grocery store.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "So one another customer of there, a Russian family-- a Russian family-- and Maria [?",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "Nikichna ?] knew them, too.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "We knew them.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So she went to them.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And this was a strange family.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "It were two sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "There's no father, no mother, two sisters, rather spinsters-like, you know, and one man.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And one man, the man, who was also from the Russian aristocracy-- and he was a radio engineer.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "At that time, the-- nobody could have a radio, you know, only the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So they-- he used to repair.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "The Germans went to him.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "He used to repair it the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "So [?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Maria ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "Nikichna ?] went there.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And she convinced them to take me in, to take me in.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "They-- they were fantastic people.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "Very-- the ladies were very religious, very religious.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And they believed that if something will happen to them, it will happen with me there or without me.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "They just believed, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And one evening, I went there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And the first time for-- it was at a table, a tomato or a piece of bread, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And I was-- I was there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And there comes in an interesting story also, if I have the time?",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "I have the time?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "Yeah, all right.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "During-- I mean, the time I went to-- one Jewish woman from the-- from the ghetto told that her mother gave away a fur coat, a fur coat, to a wife of a Polish doctor, Polish doctor.",
      "word_count": 37
    }
  ],
