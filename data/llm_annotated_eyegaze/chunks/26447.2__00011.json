  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And it's night.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "I never was in a time like this in forest.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "No, and I begin again to think how to go to the-- to my village, I will go.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "I know the-- the way how to go.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I cannot go by the highways.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "I begin to watch the highway at nighttime and decide to go.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "I went maybe-- I got to go to-- to the my-- my-- my village.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "It's maybe 12, 13 kilometers.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 3 SECONDS] I-- at nighttime hiking to one place.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "I see people sit around a fire.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "And they begin to talk what is happening today in ghetto, in Kolki [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "Maybe it was four or five people.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "What they was doing this time in the forest, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "You know, I-- when I heard what they talking, I feel that I cannot come to them.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "And I cannot talk to them.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "And I cannot ask them for help.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "I go with a side in, and I begin to run.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "Because I need to run that's at nighttime.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 33,
      "text": "If I will not measure-- not make the time to come, at daytime I am afraid that somebody will kill me.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 34,
      "text": "I came to the-- to a village, Kulikowicze.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 35,
      "text": "I came to the village, Kulikowicze, from village Kulikowicze.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
