  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "You took some clothes, some food, some money, and that's about it.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't-- if you had, maybe take a backpack or a piece of luggage, something like that.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "The-- the closest thing you can grab.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Well, in Prokocim, I-- they were-- I was working on the camp, and they were doing rail work.",
      "word_count": 18
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "They were laying tracks, like railroad tracks.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And naturally, I was young and I wasn't able to lift up the big sledge hammers to do something like that.",
      "word_count": 21
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "So I was doing maybe helping with the gravel or cleanup and things like that.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And we were there for-- and that still a labor camp so you still were allowed to have some money.",
      "word_count": 20
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "You didn't have the barbed wires and things like that.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And I was there for about-- I don't know-- four weeks or something.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "And after that, we-- oh, while we were-- while were there, four weeks you know, something like that.",
      "word_count": 18
    }
  ],
