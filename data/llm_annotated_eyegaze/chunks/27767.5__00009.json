{
  "stem": "27767.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And it was very, very-- because they would have-- dangerous, you would have found, they would have shot me right away.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And after that, they took me in as a-- I was washing the floors there all day.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And that was a big kitchen, mopping the floor the whole day.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And-- and then I was working, also, in the-- we had a warehouse there.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "There was a warehouse.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And they sent us in to Munich to bakeries to pick up bread, and supplies for the SS.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And some bread also for the-- our people.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "They sent myself, and four or five other people from-- from the camp there.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "In a truck, and with three SS guards with the-- with the-- with the machine guns.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And they took us into Munich.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And there, I saw the destructions with the bombardments.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "It was-- we went to a bakery, it was destroyed.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "We went to another bakery, destroyed.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So we had to go to a third bakery.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And it was always something like this.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So we picked up their supplies.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And we brought it back to the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Then I had a little better life there, because-- number one, because I worked in the kitchen, they put me in a separate barrack.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "They gave me clean clothing every day, because we cooked for the SS too.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So I have that.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I was not a cook.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But I have that.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I was able to have a separate barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I was able in the evenings, when I-- before I went home to sleep.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And we didn't have to go out for cell appell.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "They came to us in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They counted us there.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We were in line.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We were about 20 people there, and count.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They counted us there.",
      "word_count": 4
    }
  ],
