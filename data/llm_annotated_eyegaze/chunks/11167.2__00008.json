{
  "stem": "11167.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Then I came-- when the postcard came, it was such a beautiful postcard, and the paper as they didn't-- they never saw in Russia something like it.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And everyone touched this card.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I saw thought that is a joke.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And they started asking me.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "I say, yes, my sister's in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "She-- she went away before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "She went away before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "She was given a certificate from the English government.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "She worked five years for the Zionist movement.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "Then she had the certificate to go there,  I hear-- went away three months, four months.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "I had an invoice that's I've got a parcel in the post office.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And then it was very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "You know, they used to sell the half a kilo of bread.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "But you have to go, yet, every day.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "They used to take it and sell it on the black market.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "And we didn't know-- 10 days, eight days is being without a piece of bread.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "And you could not complain, because you can't say nothing-- no bread.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "They say it's no bread today.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "There's no bread today.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "You just say you're going back.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "You already dying for-- for something, but nothing will help.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "So I received this from my sister that I've got a parcel.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "But I have to pay money to get the parcel.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "And you know, the-- all these people from Latvia, Lithuania-- it was-- together-- the Jewish people did keep together.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "Then I did tell one man that I knew from Riga.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "And I said to him, [?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "Luva ?] you know I have an invoice from-- for a parcel.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "But I haven't got a penny.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "He says, get it.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "Get the parcel.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 32,
      "text": "I will give you the money.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 33,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 34,
      "text": "And I got the parcel.",
      "word_count": 5
    }
  ],
