  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And while this is not the time or the place because it would take a long time to discuss this, there was a neo-fascist movement in Hungary led by a very talented Hungarian writer, Istvan Csurka, who had a very high position in the leading Hungarian political party several years ago, and I took him on.",
      "word_count": 56
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "I had a special session arranged in Congress with a group of my colleagues where we denounced the upsurge of fascism and anti-Semitism.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And the Hungarian television carried this with simultaneous translation.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And not according to me, but according to many observers in Hungary, I am very happy that I've played a modest role in-- in at least temporarily dealing a setback to neo-fascist anti-Semitic trends in Hungary.",
      "word_count": 36
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "I remain very much interested in Hungary.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "I want Hungary to be a full-fledged member of NATO, a member of the European Union.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "I want Hungary to be a free and open and democratic society where people of all religions have equal opportunity to achieve anything, so I am very heavily involved with Hungary.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "I'm very heavily involved with the countries around Hungary.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "I-- I am, perhaps, the person in Congress who is most interested in this region and who spends the most time on this region, so I've been to all of these areas many, many times and have done a lot of things.",
      "word_count": 42
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "But I'm very conscious of the fact that I'm only one of 435 members.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "And obviously, my-- my power is very limited.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, immigrants, I think, fall into two categories.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "People who never find themselves at home, who always feel that the old country or some idealized version of the old country that never existed is somehow better.",
      "word_count": 28
    }
  ],
