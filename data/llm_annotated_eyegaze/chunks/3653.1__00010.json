  "sentences_input": [
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 6,
      "text": "You have to look right at the person.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "You mean dead people?",
      "word_count": 4
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "Who knows.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "They count if you [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "When I was one day passing the camp to work, I saw one guy.",
      "word_count": 14
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "There was a telephone post.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "He was tied up to the telephone post with ropes and a big carrot in his mouth.",
      "word_count": 17
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "And the sun was hot.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "And it was like this.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "Probably, he died there.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 8,
      "text": "I thought he was Jewish, or not Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 9,
      "text": "This I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 10,
      "text": "But I saw him there.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 11,
      "text": "That's what they did, you know.",
      "word_count": 6
    }
  ],
