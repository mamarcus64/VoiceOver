{
  "stem": "3097.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And they make some [? bad ?] cards for people, for, you know, DPs.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "They used to call us displayed-- displayed persons.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And they started to give some lectures.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "There were some professors from Lithuania, Russia-- you know-- you know, college studies.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "So I registered.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And they used to give us to eat, too.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And I started to get some medical education.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And after that, when the German university, Ludwig Maximilian University, opened, I matriculated myself and started to study at the university, at the medical faculty of the university, of Maximilian University.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And I studied.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I assigned me to a-- I didn't have to pay tuition.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the joint distribution committee helped us-- us with some supplies.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I used to go at 4 o'clock in the morning to a special DP camp, where I was assigned for-- to, and collect food for a few people, for us, for these students, and bring it and distribute.",
      "word_count": 38
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And then I was assigned to a German lady, to her apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They gave me a room there.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "The husband was working before in a IRS department, from-- let's say in some-- And he was not-- he was a Nazi, but they used to call [NON-ENGLISH].",
      "word_count": 28
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He was nothing--",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He would go along.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Go along, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "He wasn't an instigator.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They had no children.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They had a dog and a canary, and his sister used to live there.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They-- those people took care of me like I would be their son.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Not because they were afraid of me, but really, they-- they really, they-- she did anything-- wash my clothes, wash my hair.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "She did anything like I would be a really found son someplace.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Really incredible.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Gemeiner, G-E-M-E-I-N-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They're dead already.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He died, and she died.",
      "word_count": 5
    }
  ],
