{
  "stem": "1141.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And they test you emotionally.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And with the help of the United Jewish Appeal, with the help of my uncle who lived in the Bronx.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "I came to this country 1949.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I arrived Monday.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And I-- Thursday, I applied for school.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "I went to school in Monroe night school in the Bronx, where I went for three years.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And in 1950, I met Michael.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "I married Michael Eckstein.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And we settled in the Bronx.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "Worked in a sweat shop in the daytime.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And at night, we went to school.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And 1953, Marilyn was born, In 1956, Irene was born.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And we lived in the Bronx for 25 years.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Life in the Bronx-- we lived in two rooms in Minford Place there, East Bronx.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We were quite happy.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We had a home.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We had food.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And we went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And we were very devoted to each other.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "The children went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We realized that both of the girls are quite smart.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And so we decided that perhaps she-- they should go-- become in the medical profession.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "But those days, it was impossible for girls to be in medical school, right?",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So Marilyn became a schoolteacher.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "She attended Yeshiva Hebrew Academy, Acad-- Akiba Hebrew.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Academy, and Yeshiva university.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "At the age of 22, she received her master's and bachelor's in education.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Then a year later, she decided she wants to go into medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And she applied to medical school.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And she made it.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "She now is an infectious disease specialist in Dallas, Texas in [?",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Parkland ?] Hospital.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Irene is a registered nurse.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "She got her education at Beth-Israel Hospital in Manhattan.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "She's a trauma nurse and works at The Village at St.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Vincent's Hospital.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "They're both married.",
      "word_count": 3
    }
  ],
