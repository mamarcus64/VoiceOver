  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But we only lived in Sweden for about a year, so it may have taken, oh, half a year before they granted us the visas.",
      "word_count": 25
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Oh, it was soon-- I remember, it was soon after the presidential elections that year, and the presidential elections are always in November.",
      "word_count": 23
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "So it must have been soon after November.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "So maybe it took six months.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was the difficult thing.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "We-- we decided to go to the United States, and we hadn't-- well, we thought we'd go to the United States the way everybody used to go to the United States.",
      "word_count": 31
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "You just cross the Atlantic.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "In those days, remember, people did not fly the way they do today.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "We thought you just fly across the Atlantic and go to New York.",
      "word_count": 13
    }
  ],
