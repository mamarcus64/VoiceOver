  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "In a sense, they were very boring weeks, because nothing-- nothing bad happened.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And there was no way for anything good to happen, because most places of interest, I wouldn't be able to go to.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they definitely were not planning at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I tried to convince them, but they said, no, we're-- we are still making sort of a living, and this nonsense is bound to-- to stop sometime, we hope soon.",
      "word_count": 30
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Remember, this was before Kristallnacht, and the-- I would say a very large percentage of German Jews did not realize the danger until then.",
      "word_count": 24
    }
  ],
