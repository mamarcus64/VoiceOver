  "elapsed_s": 253.2,
  "sentences_input": [
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And a different division comes down.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "Then in the meantime, this division which transferred, the other division, must go in before.",
      "word_count": 15
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "And the other one leave later.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "I mean, they changing.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "Each part-- each, each battalion-- each battalion have several, several groups.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 9,
      "text": "And each group is a special design what to do, how to do it, how to-- which part of the, of the front to take over.",
      "word_count": 26
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 10,
      "text": "Each battalion has a certain part.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 11,
      "text": "Everything is, is marked down.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 12,
      "text": "You couldn't jump in and take it.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 13,
      "text": "Everything is marked down exactly before we move.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "It's a small photo album.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "This is, this is pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "He didn't say he took it.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "But I think he took it, because if not I would kill him twice.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "I only killed him one time.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "And-- [LAUGHS] and this is pictures from Auschwitz, from Treblinka, from people which-- nobody can take pictures down there.",
      "word_count": 19
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "They don't take in a person like he, this gentleman which is taking now the pictures, to take pictures down there from dead people.",
      "word_count": 24
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "This is a person which was working inside.",
      "word_count": 8
    }
  ],
