  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "It was a little bit of a-- it was alive.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And a lot of the men from Siberia, the Jewish army, came-- had to come through our town.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And we went to the station.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "We met them there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "They had to get off.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "They couldn't go further.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I met quite a few people who used to-- who still remember that they came to us after the war.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
