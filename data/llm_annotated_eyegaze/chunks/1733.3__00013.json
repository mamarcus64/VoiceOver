  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "My grandmother, who was 80 years old-- a picture in my head from my mother and my aunt that was living with us and her three little girls.",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And my mother was of an age that she could have survived.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "She wouldn't have been picked to be killed immediately.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "But-- [PAUSES FOR 3 SECONDS] --she wanted to stay with her mother.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "She wanted to stay and help her sister with the three little children.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "So she told my sisters to go on the other side, and she'll see them later.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I heard it from my sisters.",
      "word_count": 6
    }
  ],
