  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "His older brother must have been two or three years older than himself.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And their primary education was probably more interspersed with-- with Jewish studies than a straight out primary school education as such.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Obviously.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "But at the age-- at age of 14, he had to go out to work because Grandmother managed to make a living, or whatever you may call it.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "She has opened a little corner stall of groceries.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And that was the source of sustenance for her and for her two sons.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And the story used to be told that when she had to go into the kitchen to prepare a meal and the older son used to come into the-- into the shop to wait for a customer, which may or may not have arrived during that generation, he used to spend the time exercising on the-- on the white wrapping paper in-- with abstract mathematical exercises.",
      "word_count": 66
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And so time she had to come to-- to roll something up, and it was covered in-- in-- in figures and so on and so forth.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "But Father worked as a-- in a textile shop where-- as a-- as a-- a-- a young helper, whatever it is, at age of 14, obviously.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And then slowly, he learned the trade and-- and Bialystok, as we'll most probably talk about it later on, was an industrial city.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And textile manufacturing was its hallmark.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So everybody's wish and desire and ambition was to be a textile manufacturer.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "So having had such limited [PAUSES FOR 5 SECONDS] chance in his early youth and life, that was his dream.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And he ultimately-- ultimately became a textile manufacturer, both a set of spinning-- spinning machines which are huge, you know, the spinning-- [PAUSES FOR 3 SECONDS]",
      "word_count": 26
    }
  ],
