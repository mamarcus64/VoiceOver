{
  "stem": "321.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "My father was the last born Jew in Sternberg.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "S-T-E-R-N-B-E-R-G, Sternberg, in Mecklenburg.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And they made use of the synagogue three days a week-- three times a year, rather.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And there was a cemetery.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "But the cemetery was right on top of the hill.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I remember going there with my father to say goodbye to the uncles, to the relatives on top of the hill.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And there were quite a number of Jewish graves.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "When my grandfather died in 1926, I believe-- '27, before I was born-- my father and uncle, having moved to Hamburg, moved their mother to Hamburg, as well.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "My uncle and his family lived right next door to us all the time I remember.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "So I was the only girl, a tomboy brought up with a brother-- an older brother and two older cousins.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I was rather-- well, I call it cheeky.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Fresh, I guess you would call it.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And was rather abrupt.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And I knew that the older guys would protect me if I ever got into too much trouble.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "So it was a very warm, loving kind of a household that I lived in.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And the boys were in our house more than they were in their own house, because my Aunt Betty, their mother, my cousins' mother, was a school teacher and a professor.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "She was the president of the lodge.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And my mother was more at home.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "Although she was a teacher, and before she got married, she liked being at home with the children.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "The B'nai B'rith lodge.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "There were Masonic lodges, as well, which the Jewish people in Hamburg belonged to.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And my aunt was a president.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And she was a more intellectual kind of a person-- and the boys-- and wasn't home as much as my mother.",
      "word_count": 21
    }
  ],
