{
  "stem": "9701.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "You know, we go through rituals when people die.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "You usually know when and why the person died.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "You may see the body.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "There's a funeral.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "There's a tombstone.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "I don't have any of those things.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "And I think that, combined with the fact that I needed to deny it to be able to continue my life, I-- that's probably why it took me that long to accept the fact that they're no longer alive.",
      "word_count": 39
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Life was difficult.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I stayed with the cantors in the cantor's home only a short time, only about 10 weeks, because there were some problems there.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I was then put in a or placed in a girls' home in Belsize Park.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "That's B-E-L-S-I-Z-E Park, P-A-R-K, which is part of London.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "The girls' home was run by a woman by the name of Mrs.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Glicksman, G-L-I-C-K-S-M-A-N, who was herself a refugee from Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Miss Glicksman was not a very good person.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "She was-- really exploited all of us.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "No matter how much we earned, that's how much we owed her for our board and lodging.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And there were three buildings.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I was first placed in one of the buildings that had no heat in the winter.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And once the pipes froze, there was no water.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "I mean, I literally had a crust of dirt on my body.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "My clothes were grey because I couldn't wash them.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "Later on I moved into one of the other buildings, the same building where she lived.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "And there was heat and hot water there, or warm water there.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] And I initially worked in the home.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "She had what was called a doll factory.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "We were making dolls and doll clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "Later on she branched on into making children's clothes.",
      "word_count": 9
    }
  ],
