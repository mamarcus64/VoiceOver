  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "But somehow-- I don't know how-- he didn't see me and didn't hear me.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I did go to the next house.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I talked to my girlfriend.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I told her we will be free, and we will be together, just don't give up hope.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Came back, and when I was in the middle of that hall, an SS man came-- I mean a light came into my face-- a flashlight-- and that was an SS man.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And the blokova who was with him asked me where did I go.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I told him the truth.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "He didn't say a word, but the blokova told me I will get it next day.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "I did tell you that.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
