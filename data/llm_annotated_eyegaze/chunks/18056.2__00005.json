  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And it was like potato soup or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "Then I was working as a-- as a-- they send me to do things.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "I was a-- [PAUSES FOR 4 SECONDS] well, some of the jobs, they don't even have here that they would create over there because of the circumstances.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "I would run from one office to the other, take papers here, bring them over there, bring it-- this was one of the jobs it was a better job, because I was able to walk out and speak to people and see new people and so forth.",
      "word_count": 47
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "Then I was working for a-- and that was one of the better jobs I had was a office that was like a controlling office would-- which would control some of the thieveries going on, things like this, things that-- if something was going on in a grocery, somebody would steal, these people would go there and make sure that it's clean, that it's cleaned up, or they would do the right thing.",
      "word_count": 73
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "It was called [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "It was-- that was a good job, because Rumkowski, the president of the ghetto, would come there once a week.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And he would-- we would have-- he would have a conference there.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And I was able to put his coat on and-- and say hello to him.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And he would always, you know, push my hair.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "And it was the-- a better job for me, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The soup was for people that came there to eat soup every 12:00-- between 12:00 and 1:00 or 12:00 and 3:00, people from these various [PAUSES FOR 3 SECONDS] shops that had to do work came to eat their-- their lunch.",
      "word_count": 41
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So it was just soup, potato soup.",
      "word_count": 7
    }
  ],
