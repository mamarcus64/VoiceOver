{
  "stem": "24958.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, the lady let us know.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They let us know that we had to-- we had to leave, that the-- the lager is going to be liquidated.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And we had to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "First left the men, and then they left the women.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We had to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "But we-- we thought we are going to Brunnlitz!",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Oskar Schindler wanted to have 300 women.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I was one of the 300.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And-- and we-- we thought we going to Brunnlitz!",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And in the meantime, our train-- in this cattle train, which we were in-- went to Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "So we thought we are going-- this is gonna be the end.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "We thought we are gonna be gassed there-- killed there, yes?",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Was your husband already in Auschwitz, at that time?",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My-- my Auschwitz-- my husband didn't go to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My husband went to Brunnlitz there.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And then, from Brunnlitz, he-- he-- he took him to Gross-Rosen.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He couldn't stay there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He had to leave there because-- because of the child.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I left to Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We are-- we had to go to the-- in-- to the-- to the gas chamber-- to-- not the gas chamber-- to the shower.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "A matter of fact, when I saw the movie, and I saw the-- the film-- the scene in the-- in the-- in the shower, where the women-- you remember?",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Did you see the film?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was looking for myself.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Because we went through exactly the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We were standing there in the shower when we was looking-- is there going to come water, or is there going to come gas?",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know-- exactly the same.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "When I-- I was looking.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I was saying, what is-- that-- that must be me!",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "So we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And then we-- we went to a block.",
      "word_count": 8
    }
  ],
