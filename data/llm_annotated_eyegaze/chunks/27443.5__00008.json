{
  "stem": "27443.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "You will remain in life alone, and if you have a boyfriend you have to get married.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So my uncle and my grandfather in Brazil stayed in touch with the consulate in Rome, the Brazilian consul.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Because they send me papers to go to Brazil.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they insisted that I should come to Brazil that I have a big family.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And they wanted to have this [NON-ENGLISH] to take me to the chuppah.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "On the other hand, my uncle in Paris insisted that I should come to Paris that my mother wanted him to have the mitzvah to take me to the chuppah.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Between the times my husband found out that he has family here in the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And as it came, my husband became obsessed that he wanted to go to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "By the time were made up our mind to go to Brazil, Jews were not allowed to go to Brazil.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And we couldn't go to Brazil.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, we made up our mind that instead to go to Brazil to wait till Jews were allowed, but I wrote to my uncle that for money you could make false papers as an Aryan to go to Brazil.",
      "word_count": 39
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And my grandfather became frantic.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He wrote to me in a letter that nobody in my family is [NON-ENGLISH], converted.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "That I shouldn't dare do that.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "That he wouldn't want to have on his conscious to do that.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Well, I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Instead we went to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "My uncle from Paris sent me a tourist visa to Paris.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And Sol and I, we went to Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And we had a complete wedding in Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "By that time my uncle who was liberated in Russia came to Paris too.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Because he was looking for me in Poland.",
      "word_count": 8
    }
  ],
