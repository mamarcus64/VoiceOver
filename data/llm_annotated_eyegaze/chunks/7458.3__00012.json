  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 140,
      "text": "It was a very dangerous thing to do.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 141,
      "text": "If the other Poles or the Germans found out that a Polish farmer was helping a Jewish family, they were bound to come and burn the house and kill them.",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 142,
      "text": "And they've done it many, many times.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were there on and off.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We would go back to the forest when we could.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And we would come back to Dekar's.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And these went back and forth until such time, really, as we were liberated by the Russian army, early spring of 1945.",
      "word_count": 22
    }
  ],
