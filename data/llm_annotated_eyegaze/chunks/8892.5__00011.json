{
  "stem": "8892.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "Hart's ?] and bought fabric and all this, and learned on my own.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "My first?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I was 20 years-old, in '49, January, and I was very-- I was scared being pregnant that fast.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "My husband was delirious because the rumors were very, very horrid that anybody who survived cannot have children.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And all these kind of rumors were already in this country, and they heard.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And of course, we didn't want to believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So when I got pregnant, I was married, young, 20, inexperienced.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to be just for myself, live, really, truly.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I came home from the doctor, crying, what am I going to do with a baby?",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And he was thrilled.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And then, of course, after each other, my kids just came, and we were very happy.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have much, but we were happy.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Tell me about your-- the names of your children.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my oldest one is Jeffrey, and he's married, thank God.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He has a family of three children.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "He's a dentist.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "My second one is Stephen, and he is, unfortunately, unmarried, but he has a gorgeous son, a 14-year-old boy, Daniel.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And Carol, and she was like from heaven, because I was dying for a little girl.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I had to say that, and when I had her, I think I was delirious for three days, and I thought I was the most genius person on earth that I finally have a daughter I want.",
      "word_count": 38
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So they were loved.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Grandchildren, we got six, thank God.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We got Danny.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And we got Erica, Emily, Erin.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We got Lori and Mark.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So my son has three, and my other son has one, and Carol, my daughter, has two.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And they were all precious.",
      "word_count": 5
    }
  ],
