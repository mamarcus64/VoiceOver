{
  "stem": "7016.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "They said they don't have enough gas for the children, and they burn-- they put them in the hills, and they burned them.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And we hear all the crying from the little children.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Every day.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Every day was this.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And the-- we-- food, we didn't got.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "We got a little bread in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And we got the-- a coffee.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And we-- and then we got a little margarine.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And sometimes we got a little, uh, marmalade.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "They-- they took away.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Then we came to-- then they came from-- Szopienice to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They took away-- I got a ring from my mother, which I wear there.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And I got a gold tooth.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They took it out, too.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They took it away.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We got a red bowl.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "A-- a bowl.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "A red bowl.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I lost that red bowl, and this you have to always save.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "If you wouldn't got this, you couldn't live.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "You can-- you cannot get your food.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "You have to sleep on that like a pillow.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You hi-- in daytime you hang it up on your neck.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "You-- you went to work like that.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And they all looked-- they shaved us.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Every-- every two, three weeks, they shaved our hea-- we was happy that we didn't got no hair.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "Because we got a lot of lice.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We-- we-- we was not-- you catch those lice from one person to the other person.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "My whole body was holes just from the lice.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So I worked there for-- then they closed up that-- they said [INAUDIBLE] and they give me another work.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "They put me-- we went to work in water.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Uh, they didn't need this work.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They need just to torture us.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And when I went-- we stayed in the water.",
      "word_count": 9
    }
  ],
