{
  "stem": "7777.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Was very hard for the Jews to make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "For the-- there was a lot of people, where they was-- they-- they have trades, like tailors or shoemakers.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "If they don't work those four days, it was very hard to make a living.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Celebration-- the temples, they was packed.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Every holiday was packed at celebrations.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And people was living-- in every town was some rich people-- only a small percentage, a very small percentage.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "The most people was working people.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "They don't took in too many people with government jobs-- just like tailors, or-- or carpenters, or shoemakers.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "They was working, and they make a living.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And the storekeepers, they was making a living.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "Only it was very, very poor country for the-- very poor country.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in our town, was about 500 Jewish families.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The town had about 8,000 Polish people.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "There was about 500 Jewish families.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It was a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We have nice temples.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We have a rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And like before-- it comes like-- they have-- the Polish people have celebration the 3rd of May.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "It is the Jewish have come together to the temple.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And the rabbi have a speech for the government try-- the government is good.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "They send all over-- the government people to the temples.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "In his speeches, the rabbi said, in Hebrew-- [SPEAKING HEBREW].",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "This means you have to pray for the good guy and the-- the government.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And he was talking about a government-- how the government is good for the Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "In our town, was the rabbi, he said, o, this man, what he is staying here-- he is [SPEAKING HEBREW].",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He love Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "He have to say it.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "He-- you know, he don't love Jews, only he had to say it.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "This what-- this was the Polish government.",
      "word_count": 7
    }
  ],
