{
  "stem": "20580.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 42,
      "text": "And the son was with us.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 43,
      "text": "[INAUDIBLE] 5 o'clock, we have to go home.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 44,
      "text": "And I says, let me hide yourself.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 45,
      "text": "We're going up in the chimney.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 46,
      "text": "We had a big chimney which has got the brick.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 47,
      "text": "And the chimney didn't work.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 48,
      "text": "We made a space to live there.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 49,
      "text": "We put on [INAUDIBLE] everything else.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 50,
      "text": "Could be 10, 15 people.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 51,
      "text": "It's a very big chimney.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 52,
      "text": "But we figured in case they find out we're there, they make fire, and we're finished.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Then we run away from the chimney.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Other places we hide in wood.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And one guy says, with their son, says I don't believe they're going to kill us-- impossible.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "How could you kill us?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "The leather-- so much leathers for this.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "He says, give me your name.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I gave him my name.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I give my this.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I give him other things with the son.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And then will the other guys, we're planning to go back to the forest.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We didn't go back to the forest, because it was very late.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We did hide ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "In the factory, there are big woods-- like the woods is like over here, so much wood we have.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We put into the woods and made a hole, and put in water, put in bread, put pickles.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "We had a lot of pickles because the garden-- I made pickles for myself.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We had tomatoes.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "We says, we could stay a week, even a month.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And suddenly, he had the police-- 12 o'clock, they come to the guy.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He says, where are the other people?",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "He says, they went into the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We went in the roof.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We went to this.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "He's showing the places.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "He doesn't know where he is.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "He's right near the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "He shoot them.",
      "word_count": 3
    }
  ],
