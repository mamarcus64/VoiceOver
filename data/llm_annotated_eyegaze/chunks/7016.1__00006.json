{
  "stem": "7016.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Later on, I heard my brother, Jack, for this year, he went to camp too, another camp.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was thinking, yeah, I will never see them again.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And in Szopienice, it was-- actually, the-- we [? was ?] there, maybe 20 girls.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And we worked, and we peeled potatoes-- we prepared food for the kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "It was a big barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And we sit there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We peel potatoes.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "We-- we cut cabbage.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And in-- in that-- the most there was there from Holland.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "They brought a lot of people from Holland, mens.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And they went every day to work, and every day they came less from the work.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And came a Sunday, let's say-- Sunday, there was like the block fuhrer.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "He took out some mens, and he put hoses in his mouth with water.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "He put-- they have so long to [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "We have to all stay there and see-- and see this.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "We was not-- the girls, we didn't got too bad.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We got potatoes because we worked with the potatoes and cabbage.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So we didn't got-- at that time, we could have our hair.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They didn't cut the hair.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "That camp for the girls, for us, was very good.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Just the mens that got so terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "They-- every day there was more dead.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They closed up.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "It was just not left many.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And they took us on buses, and we went to Auschwitz from that camp.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We know when I was in Sosnowiec.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They said, if somebody goes to Auschwitz, nobody will come back.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They-- they killing them right away.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They're putting-- we-- we-- we heard all this, that they're put in gas chambers.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "So we didn't know from-- when we were in Szopienice, we go to Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "They say, we go to another camp.",
      "word_count": 7
    }
  ],
