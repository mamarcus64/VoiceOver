  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 39,
      "text": "Then after all, took us to the gas chamber to show us the gas chamber.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 40,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] never know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] has never know nothing, was going like a snake.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Goes like this.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "That was the camp, was the gas chamber.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Around them, was wire link.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And over the top from the wire link was glass, cutting glass.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "You can never run away no place.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "That's the gas chamber.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "That, as I said, that's a new place.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] for you to take it.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "Long day is over with us.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "One day.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I told you, in the basement.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "In the temple basement.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I don't know when.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "We were right before this.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "There we were.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "It was right before they liberate us now.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "I think one night.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember, I mean, what I went through.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I know I never went out from the place, the same place.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "All over was the same, crying, crying, and crying.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "That's when they play the music.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "Maybe two nights.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember this for sure.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "I tell you the truth.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "I remember I was over there.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "And they liberate us.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "What do you think I was feeling?",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "What'd you feel?",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Well, still everything is nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "You're alone.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Alone.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Go here or go there.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "To [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "This was after camp.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH] That's it.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH] Europe.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "For me they decided every Polish citizen got to go back to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'm not going to the anti-Semitic Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "I got nobody left there.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I don't need it, Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "I said, I'm not going back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "Then decided on a transfer to make it to not to Germany, to Austria, To Salzburg.",
      "word_count": 16
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "They transferred us in.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "They make me go to Salzburg, to Austria.",
      "word_count": 8
    }
  ],
