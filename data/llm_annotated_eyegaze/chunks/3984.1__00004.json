{
  "stem": "3984.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We was living neighbor-- Jew and-- and the gentiles.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And is the gentiles in this time, they have a lot of children, like-- like-- like Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Or they don't have, you know-- they-- they have children-- if they have 10 children-- like-- like us.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And if we was neighbors, they was very nice to us, the neighbors.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "But if we went to the other street, they was mean to us.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You-- you are?",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So we was playing with the-- you know-- we was-- everybody has a little house.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And everybody has a big-- we had-- but I remember, we have a very, very big yard outside-- a very big yard.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And we was playing in the-- in the summertime.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "We was playing only outside and not in the-- in the room, and not in the house.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The house was clean and nice.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And we was only outside.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And we was playing a lot outside in the yard.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And we was going to the gentile children, and they coming to us.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So we was very friendly-- only the neighbors.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "But after the neighbors, they was very mean.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I remember in-- in-- I remember a little in '43 when-- when my-- my-- my mother-- in '43-- I don't know if this is-- I think in-- in-- in '43-- when my mother get-- when he hurt-- that-- the-- the big brother, in Yugoslavia-- takes him and all the family.",
      "word_count": 50
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "One day they take all them outside.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And they killed them-- five minute.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "The mother was very young.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "He was-- he was pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "I shows you-- I show you the picture.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And it was six children with her.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And they take-- I think the German, they killed them.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "This is half-brothers, yeah-- yes.",
      "word_count": 5
    }
  ],
