  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 34,
      "text": "But he made it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I-- I-- I was so unhappy, because remember, mother is gone, father is gone.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And now my two brothers and myself, we are there three months.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And now we are separated after three months.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I suddenly was alone.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "But Madam Rothschild was such a sweet, and loving, and beautiful human being.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I really grew to love her as my own.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And I honor her.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Each--",
      "word_count": 1
    }
  ],
