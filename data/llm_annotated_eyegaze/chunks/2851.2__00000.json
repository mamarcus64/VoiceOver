  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We met.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "She was hide in a barn not far where we are hiding.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "When I-- when I used to see her, her boyfriend, Tmosz, came up to the-- to the place where we were, and he took me to her.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Just she likes to have company.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "She was like about 35 years old, two children, very, very pretty, pretty woman.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Also the same-- the same time.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "She was there before we came.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "But she was hiding also two years with her two children.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Her husband used to deal with Tmosz.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He hide her because he knew very good her husband, and he-- he work for him.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He worked for him.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "So-- and he-- he is a very good person.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Like we didn't know him at all, and he hide us.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So he did it for him.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "He took away the-- his wife and the two children from Kowel, and he gave her a place in his barn.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Also, she was-- she had the good straw.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He made a place for them.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Oh a lot better.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "You cannot compare.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Because they lived like man and wife.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "She was her-- he likes her, and she had everything.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "She was the-- she was the [NON-ENGLISH] for the house.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But she said he did.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He was married.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "His wife was home.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "She didn't-- she didn't say anything.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "She was also very good.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She knew.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, she has everything.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Her condition?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, our condition was we didn't have nothing to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We-- I-- we couldn't-- we didn't have where to wash.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We didn't wash ourselves-- never.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "We been hiding downstairs where the-- the cows and the horses.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He had two horses.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And upstairs we had a place.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And she was in the barn.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The barn was big, nice.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
