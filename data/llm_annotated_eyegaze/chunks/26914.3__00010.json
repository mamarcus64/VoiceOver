{
  "stem": "26914.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 19,
      "text": "And we went-- I wrote to her, I thank you very much for it, but we decided to go back to Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "In Birsk, I had the job.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In the store, in the magazine.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Until the end.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "He wasn't doing-- yeah, he had-- they told him to be a fireman.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "If a fire will be, to run to the office, this was his job.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "But he had ulcer, so he didn't work.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Leon was born in 1942.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "It was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "It was very hard-- no food.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And-- but somehow, we survived.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "He was a year old.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "He fell, and he bite his tongue.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And he was bleeding.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "I put him to bed.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "It was daytime.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "In the morning, the whole bed was in blood.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "So I went to the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And the doctor said, you know what?",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "He has a cut.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "I will sew it.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "I said, Doctor, if you sew it, you'll make holes.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "It will bleed more.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "He said, it's a good idea.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "I'll make a test, it's not hemophilia.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "He made the test, and he told me it's a hemophilia.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "Then I found out.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "But it was a blessing from all this-- all sides.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "That you were able to-- to find out without any--",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Not that-- no, I'm--",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Uh.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "It's a irony.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I said, it's the blessing from all sides-- the war, and mine husband sick with the ulcers.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    }
  ],
