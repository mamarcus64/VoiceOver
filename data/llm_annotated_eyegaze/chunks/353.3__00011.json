  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "You didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "You didn't know even the men who were-- was the-- the chief of the partisans.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have no idea.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have no idea then.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "No idea at all.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "After the war, when the war, when Schindler was getting away-- now, I want to tell you something.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Schindler knew something about this partisan group.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "The partisan group [? back ?] got ammunition from outside, from the Czech-- Czech partisans.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "The connection was done, so they sent in into the camp ammunition, guns, and rifles.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And we were running, the 25 people.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I know about 25 now.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "But then when I'm talking about, I knew only five people.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "The all five people had guns on them-- every one from the five people.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "One was Joel Lipschitz.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "The other one was--",
      "word_count": 4
    }
  ],
