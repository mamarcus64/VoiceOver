  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "For example, if your family had six kids, they made a law about this-and-this date later on, if anybody is missing from this, this house at night when they come to check, they killed the whole family to instill a fear in you that nobody should run away from the house, go into the woods, become a partisan, or start fighting against the Germans.",
      "word_count": 64
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "They couldn't do it to the Gentile population-- that they do it to us.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "They made everybody responsible for each other.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "So any good son-- like, for example, myself.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "My father sneaked me out before the ghetto was formed.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "Later on, he sneaked me away to a village.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "He couldn't have done it later after this law would have enacted because then I would be afraid to leave in order not to harm my father and mother, my brothers and sisters.",
      "word_count": 33
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Because then it would be-- it would be out of the question.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "They made so much-- so many laws against every-- water to be gotten.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "You have to get it in, in, in-- and you have to stay in line to get water.",
      "word_count": 18
    }
  ],
