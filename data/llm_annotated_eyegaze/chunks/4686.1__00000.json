{
  "stem": "4686.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Ivan Devai, D-E-V-A-I.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Ervin.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "E-R-V-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My name was originally Deutsch, D-E-U-T-S-C-H.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I changed it in 1949 in Hungary.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Partly because I had to sort of say get lost.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And partly because it was customary by that time to change German sounding names to something more Hungarians.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They couldn't spell the name.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "It gave problem so I decided to change it then.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in 1932, 2nd of April, in Budapest, Hungary.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "That makes me 66 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Look, before the war, I was a reasonably young and Budapest for me was that trams and the wide avenues and the snow in winter and-- and the flowers and gardens and that sort of things in-- in summertime.",
      "word_count": 39
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "School, family, going out into the mountains over to Buda with my father, with mother, with their friends and their children.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We lived a very normal, civilized middle-class life.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My father was working hard.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Mother was running the household.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And [PAUSES FOR 3 SECONDS] big family get togethers at my grandma's place, at our place.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And that was mostly what happening.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I was the first grandchild, so I was a lot with my grandparents, who adored me.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "By that time, they were retired so they had [BACKGROUND NOISE] really time to spend with me, to teach me how to ride the bike, and all that sort of things.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We were very close knit family.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And very close.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather name was Appel, Appel Fulop, [BACKGROUND NOISE] with the P in the middle what was standing for [?",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Pincus. ?] He came from a little village up [BACKGROUND NOISE] parts of Hungary.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And there the Jewish boys had only the Hebrew name.",
      "word_count": 10
    }
  ],
