{
  "stem": "21978.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 44,
      "text": "And he said, no, this is my sister-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 45,
      "text": "And he said, open your mouth.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 46,
      "text": "And she opened her mouth.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 47,
      "text": "And he said, this is your wife.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 48,
      "text": "Because I have made this filling.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 49,
      "text": "It was coincidence she had the same filling as I did.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 50,
      "text": "He didn't want to believe.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 51,
      "text": "[LAUGHS] We had fun.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 52,
      "text": "So my sister visited us twice.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 53,
      "text": "I have-- haven't been well at some time.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 54,
      "text": "And so they didn't know what's wrong with me.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 55,
      "text": "So she came to visit me.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 56,
      "text": "But everything was all right.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 57,
      "text": "And Robert was always treating my sister as his second wife-- you know, being good to her.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 58,
      "text": "And when they came to join us in Australia, we were the first ones to come here.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 59,
      "text": "So we were a big family.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We came here from Kenya in '62, in April.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And we had the two children with us.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We flew part of the way.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Naomi and John, John.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "John lives in Brisbane.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And he has family there.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He lived until two years ago, three years ago, here.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But he decided the green-- grass is greener there.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "His wife, his present wife, is from, from Brisbane.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "So we visit them there once or twice.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "They come here always to visit us.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We came here in April at the-- on a ship, [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And while we were traveling on the ship, John and Naomi were little.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And we boarded the ship at night from [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And we were not given our-- there was no-- some, some mistake with the cabin.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And we were not given the cabin.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And eventually, we were shown a cabin which was given to somebody else.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But we were told we can't have it.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And John said-- he was brought under Mau Mau in Kenya.",
      "word_count": 11
    }
  ],
