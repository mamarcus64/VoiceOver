{
  "stem": "25835.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 58,
      "text": "And we came to the-- to Flossenburg.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 59,
      "text": "It was terrible experience to see only this block, these barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 60,
      "text": "And some people going in striped dress very, very frightened, hidden.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Some people, they look at us very interested, what-- what's happened?",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because this, [PAUSES FOR 3 SECONDS] this camp was only for men.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And then they said us, dress out, strip off, and go to shower.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Shower, of course, everybody not with men.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Men is separately.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We were separately.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We came to this cold shower, undress with our valuables-- valuable things we left.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Probably, they said it will be for to kill some animals.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And, you see, when we left, we, we received new dresses.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Each was striped on the back with other color, and nothing much, of course.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And we look like from circus, but not so important.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Men were separate, women separated.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "After two weeks of struggling there, they sent us again to other.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And then I left my brother and father in Flossenburg.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My father; mother; aunt; her friend, old lady; our two maids, our, our chief from factory, who, who cut this material, or was old lady.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "But she was always working in my father's store because she came to my parents.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She lost son in uprising.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And so many people was there.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And sister, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Only time I was with my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My aunt, my mother sister, Sonia Szachowska.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I spelled to you before, yes?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My-- [PAUSES FOR 3 SECONDS] I forgot this.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Paulina is friend of my aunt.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I forgot name.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "But she lost life in Ravensbruck, and she was burned.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And two maids.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "One was [?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Anyela ?].",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "I don't remember last name.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And other, [?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Janka ?] [INAUDIBLE] She, she was all the time in concentration camp with us.",
      "word_count": 14
    }
  ],
