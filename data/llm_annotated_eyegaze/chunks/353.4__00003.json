{
  "stem": "353.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Matter of fact, we had a woman, we had around 300 women there but around the 300 women was one woman in middle age.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "She had two daughters, her name was [NON-ENGLISH], and she kissed this-- this Russian man when he arrived-- the first Russian guy.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Then came army, and they occupied our-- out-- our facilities.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They had the captain of the Russian army, he was the chief of our concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And this was the end of the war, what-- what was.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "But the-- the-- the four months what I-- it was five months, five months when I was with Schindler-- it was like in a hotel compared with the other one.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "After liberation people started to go all places looking for family.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And a man came to our-- out-- our Brinnlitz concentration camp and he said to me, what are you doing here?",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Your-- your brother is in-- [PAUSES FOR 3 SECONDS] forgot the name, Czechoslovakia where my wife was.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In Theresienstadt.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So I said, which brother?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He said, your brother Leon is in Czechoslovakia-- I was-- he was with him together.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So I said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "The next day, in the morning, I went to-- to Theresienstadt and I found my brother, and I found my wife there.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "My wife was there, also.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "When I walked in, there was a-- no, no-- Theresienstadt concentration camp was closed.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You couldn't go in because they had the quarantine.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "They had--",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Typhus.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So what we did, I cut the wire and went under the wire in the evening, before evening.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I went under the wire and I went in with a friend of mine and walking toward the concentration camp there in Theresienstadt, I found another boy who knew me.",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He said, Victor, what are you doing here?",
      "word_count": 8
    }
  ],
