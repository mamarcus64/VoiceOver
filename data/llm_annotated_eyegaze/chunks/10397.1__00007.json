  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I went to Brody.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I had a foreign diploma.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't practice medicine in-- in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "To-- to practice medicine, you have to be admitted for nostrification.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "That means you have to take a test.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "All the material in Polish-- in Polish-- Polish.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And then they give you it.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "But I couldn't have dreamed even to be admitted to nostrification.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because I was a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And my father didn't have any, and it wasn't worth $5,000 or $10,000.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't afford it.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "There was one, like I told you before, this one student, was in-- graduated Prague.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "He was a nostrification, Schwartz, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Because his father was a secretary of the court, and he had connections.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, he was the only one.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And there was another Jewish student who-- who became Christian, converted to Christianity, and then get they admitted him to medical school in Krakow.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "He converted.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "His-- his father was the director of the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "It was the health department-- health department.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Like here, you know, HMO or something like that.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So I-- I had a friend who went to high school with  me.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And he was a very capable newspaper man.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He graduate from high school.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "His father was a-- not a shoemaker, a-- a-- a watchmaker.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "He didn't have any money.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So he went to Warsaw on a lark.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was about 400 miles.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "He left for the town, because Brody didn't have any prospects.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "When I went to medical school, he went to Warsaw, 1930.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And [? he leave ?] [? '31. ?]",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And there was a Jewish newspaper in Polish, [?",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Naz ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Shaglun. ?] He understand a little bit Polish.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And he became their-- start to work from the bottom.",
      "word_count": 10
    }
  ],
