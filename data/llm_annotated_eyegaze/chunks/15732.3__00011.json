  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "I think that was for the first time that I had-- that I really came to see the-- the reality that what the Germans really did.",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "Because all the rumors that we heard before-- that the Germans are killing, and the Germans are gassing-- we-- we thought these were only rumors.",
      "word_count": 25
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "It is-- it is-- couldn't be that way.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "We refused to believe it.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And that was the first time that I really saw those and I associated with what we heard.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And I thought that might be some truth in it.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "We passed a--",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
