{
  "stem": "6110.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "When they were giving soup, they gave you another dish of soup.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But so it was never enough.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Toilets for women?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That was-- they made a barrack with holes.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "There were a lot of holes, but a lot of women were waiting.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't even sit down and be comfortable to do what you had to do.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't because they will stink and you had to go in.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "It was terrible, terrible, terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I worked, I think, from 7 o'clock in the morning until 5:00 in the evening.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we had at noontime soup, a piece of meat in the soup, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And then, in the evening, you got a dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "You got a soup and also a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was [NON-ENGLISH] work, you know, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We used to work on the pots and pans, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So I had the job to carry a big piece of wooden thing, you know, so wide and so long, here on my arm.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I used to walk over to that thing where a man was working, was putting the white [NON-ENGLISH] on it.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "'Enamel,' yeah, 'enamel.' We used to call [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I used to carry that thing with six parts to the oven, where they used to bake it, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I used to leave it there, and then go back and bring again.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Go back and bring again.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "That wasn't so easy.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Sure, they were heavy.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It was hard work.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "There was one supervisor who was a devil.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He was the worst what can be, the worst.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We used to complain, but it didn't help us.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We used to complain to the Jewish men, but it didn't help, you know.",
      "word_count": 14
    }
  ],
