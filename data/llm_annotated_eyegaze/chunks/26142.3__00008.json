  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 52,
      "text": "The oldest one was about that time, about-- in-- in-- in 1940, '41, he was around 12 or 11, the oldest one.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 53,
      "text": "The other one was around seven, eight.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 54,
      "text": "And she went with-- with her-- the children to her mother in Debrecen.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The other brother, the-- the one that I'm talking about, Tsvi, his wife was in Kalerne or-- and they already had a baby.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "The baby was only about a year old at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So she also went away from Torun to-- to her parents.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The only one that-- that didn't go away was my brother Moshe, because his wife was from Torun so-- so where were-- where were they gonna go?",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We're coming to the end of the tape now.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Oh, all right.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "So I'll continue.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I'll continue on the next tape.",
      "word_count": 6
    }
  ],
