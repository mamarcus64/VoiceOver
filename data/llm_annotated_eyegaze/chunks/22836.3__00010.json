{
  "stem": "22836.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Brooklyn, we come.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And we stayed there with the-- with the uncle.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Tante [INAUDIBLE], he pass away.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And Tante pass away, too, but the kids is still alive, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "He's my wife's-- my wife's uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "My wife's.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And finally, we've been by him.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And when-- and I find me a job.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "I looking for a job.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't talk English.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "It was not easy.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "But the people was very good to me.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "Anybody-- I have a list, like I want to go on that-- that place.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "I catch a man.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "I show him.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "And he took me there.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 10,
      "text": "I can't talk English.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 11,
      "text": "I can't talk-- he took me there.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I was look any work, anything I see.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I was caps, [POINTS] to do caps.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "So I figure I'll go do caps.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "I was young, strong.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "So I do caps.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And then I come to the caps.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "He says, I want him to-- the boss says, if you know how to ride a machine, I'll take you.",
      "word_count": 20
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "But I don't know how to start a machine.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Then I say to the man there, a Jewish man, I say, can you show me how to start the machine?",
      "word_count": 21
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "He says, come over Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I say, why Saturday?",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "Because Saturday, I say, I wouldn't be here.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] That's a funny--",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "First he is telling me to go buy a cap.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I was going without a cap.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "We buy a cap, because we'll be making caps, have to show.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "I said, then I looked for another job.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "I find a job later-- I find a job later for $0.72 sell pickles.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "I was selling pickles at a Jewish place.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "I make $20 that week.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "It was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "I have a full fridge there.",
      "word_count": 6
    }
  ],
