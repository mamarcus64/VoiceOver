{
  "stem": "17526.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 75.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "I was told by the leader of the community that the services should be over by a certain time because the police guarding the synagogue could not afford more manpower to watch it.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Because of it being Shemini Atzeret, the holiday, we could not enter the cemetery, which is right in the back of the synagogue, where the Remuh supposedly is buried.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "As a courtesy to us and appreciation for conducting the services, they took us to the rear of the building and through an open window from the women's section, they showed us the grave-- the tombstone of Remuh and his whole family buried right alongside.",
      "word_count": 45
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "This place now is like a mecca for every visitor-- Jewish visitor-- and tourist that visits Jewish historical sites in Krakow.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "From there, they took us to the old synagogue, the one on which we couldn't enter before.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "Through a rear entrance, we were led inside through a magnificent huge building that while deteriorating is still so beautiful.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "I was standing in awe looking up at the ceiling, at the balconies, the architecture, the art, the beautiful artwork, and the hanging lights.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "All this now laying in ruins, with peeling paint on the walls, rotten windows, broken pews, all these broken chips of a crown that adorned Krakow's Jewry.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I could feel the [INAUDIBLE], the holy spirit, still resting and hovering in the air.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "This edifice was so beautiful that even the Nazis tried to preserve it for the future.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "One of the officials who took us there-- who was, by the way, active in restoring old Jewish historical sites in Poland-- told me that Mr.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Lauder, the famous philanthropist, walked away from there without any positive action because the renovation costs would involve hundreds of thousands of dollars at least.",
      "word_count": 25
    }
  ],
