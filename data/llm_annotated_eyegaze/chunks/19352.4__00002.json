  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I said, at Christmas, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And he said, they have music?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I don't need music.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "But I want to play on your wedding for free.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "Where is the rest of you?",
