{
  "stem": "1419.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And that's where-- and that's where they, they are buried there in a-- in a grave, I guess.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "I don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "A unpicked mass grave, I guess.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "But I can just [PAUSES FOR 3 SECONDS] think about it, how they could-- how they-- how they felt coming down and taking them down and walking them [? down ?] to the cemetery-- [PAUSES FOR 3 SECONDS] the fright of the little kids, the fright of my mother.",
      "word_count": 49
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 4 SECONDS] Yes.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My sister was 10 years younger than me, and my brother was, was five year-- no, she was five years younger than me, and my brother was 10 years younger than me.",
      "word_count": 32
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She was still in teenage years, going to school.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "That's what happened September.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "That was 1942.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] We have-- the city of Nowy Targ, we have all the people-- we have a [NON-ENGLISH], they call it, we remember 'em every year.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And when was it?",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "About, I think, three years ago, we went back to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "People from Nowy Targ gather in Poland, people from the United States, still survivors, people from Israel, and some people from London came back to Nowy Targ.",
      "word_count": 27
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And we-- and we-- and we go to the monument on the cemetery in the city of Nowy Targ at the big mass grave, which is there.",
      "word_count": 27
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "In the cemetery, right?",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Well, me and my wife went back here from, from, from, from Los Angeles, [INAUDIBLE] because from Nowy Targ, there's not that many people left.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I have here one more-- one more friend living in-- in Los Angeles, which he is from Nowy Targ.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "That's about it.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Friedman.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Is Saul Friedman.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Sam ?] Friedman.",
      "word_count": 3
    }
  ],
