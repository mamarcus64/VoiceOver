{
  "stem": "2620.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Everybody wanted to have a brother in America.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Well, I asked-- I wrote them back, and I asked questions-- never heard from them again.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Then I received a letter from--",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, I asked parents' name and where did they live-- never received an answer.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Then I received a letter from my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I knew right away it was him.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I just had a feeling.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And you know, of course, I wrote him back and I asked questions.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And I got all the answers I needed.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I-- I worked in a wholesale men's haberdashery store in Pittsburgh.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And there were three partners.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "But I worked on the inside.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I was the inside man with-- with one of the partners.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And they liked me so much that they were willing to send an affidavit to my brother, to bring him over-- send him as a-- as a relative, as a cousin.",
      "word_count": 31
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Why not as a brother?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "My-- my boss claimed to be a relative",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "--of him.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "So-- but my brother, at that time, was just released from the army.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "He was in Israel, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And he was in the reserves.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "That was approximately 1950.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "So-- and Israel needed the young people, especially-- especially somebody who already served in the army in the-- in the reserves.",
      "word_count": 21
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So they made 'em very, very difficult to get out.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "In the meantime, he got married.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And he married a girl from Iraq.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And she had a lot of family over there.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So what are you gonna do?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "If he gonna to bring 'em both over, then she is going to be separated from her family.",
      "word_count": 18
    }
  ],
