    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 6 SECONDS] [DRINKS]",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And when she saw me, of course the first thing was, where's Dad?",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I told her.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I said, he went home already.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I said, he's waiting for you.",
      "word_count": 6
