  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH], this is [NON-ENGLISH] after, you know, they-- they go to another-- the children they got to another, bigger, Gemara, and [INAUDIBLE], you know, [INAUDIBLE], you know.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He was when four year five years till [NON-ENGLISH], till they turn 11 years. 11, children from five to 11.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And after they went to the bigger.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "He was a-- a Hebrew teacher.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "In Yiddish it's the melamed, small children.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Very religious, very religious.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I mean all children were-- we was five children, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And all was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It's coming Saturday, you know, or Friday, even if we was poor, you know, all children they was-- there was on the table, and we ate, even dinner was nothing to eat.",
      "word_count": 32
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] Oh, it must be, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But might have to make a kiddish, and make matzah, and all [NON-ENGLISH] was respect was nice.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Even we was poor, very poor, I-- I remember my father, you know, he was a melamed.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Then a lot of people didn't have money to pay.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "You know what I'm saying?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He let maybe 30 children with 35 children.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Where was the shul?",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He went in the shul.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "There was a special, you know, in the shul.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "He took the children in, and he teach them there.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Our house was small for so many children, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And he teached them till and he got paid, you know, maybe 10, 10 got paid, and 20 and 22 they not got-- he worked for nothing.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And how he works, you know, he-- so hard, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We works [NON-ENGLISH], you know when the children was coming at 7 o'clock, my father, he got a private work.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We rented the shul, and daven, and after, you know, in the kinder-- the children when they were coming and-- and [INAUDIBLE].",
      "word_count": 22
    }
  ],
