{
  "stem": "449.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You have your visa, but you cannot go out.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We had to wait one year until we had a chance to-- to go to-- over Spain to Portugal to take a boat in-- in-- from Lisbon.",
      "word_count": 27
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And we had to stay in Barcelona and wait, all-- all with the help of the-- of the [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "All your money, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "All the money you-- you-- you gave them.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And we got a ticket to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "My mother, fortunately, she died in '33.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Natural causes.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "My father-- my father, he-- he was in-- in pension.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Pension.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And he-- he lived in Berlin.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And as I said, Berlin was a very nationalist city.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Nazis.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "It was the headquarter of the Nazis.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Oh, my brother, my brother was a physician in-- in Berlin.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "He had to close too.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "He-- he went to America.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "You know, that was--",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My father-- I want to talk about my brother, then.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Maybe first-- first my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "My brother, he had to close his-- his office.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He was a physician.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And-- but-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "That was still at the time when I was in Ankara.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And he asked me to help him financially.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I could.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "I took a-- a good-- a good part of my savings and sent it to him so he can go out.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "It happened a few-- a few-- maybe a half year, it happened to me.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Ah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And he came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And had to-- to-- to study.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "He had to study medicine, American medicine, for one year, and became the staff physician in Kankakee in--",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "You know Kankakee.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And-- yeah, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "At that time, they didn't know what cigarettes are doing.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He was a heavy smoker.",
      "word_count": 5
    }
  ],
