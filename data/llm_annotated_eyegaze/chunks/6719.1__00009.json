{
  "stem": "6719.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I knew that my parents came and were gassed on the 22nd of April of 1943.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So it is-- it's very-- it's very faint, but you can still read it.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "It says the 22nd of the fourth, 1943.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "That's my grandfather.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Well, the story ended in a very, very peculiar way.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Uh-- usually, they, they brought the truck up around, uh, midnight and, uh, loaded everybody up there.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And away they went to either one, two, three, or five.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And, uh, then they were either-- usually, with, with small amounts of people like that, they weren't gassed.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They were shot in the back.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "There was an assessment down there that-- that they caught after the war that did that.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And I forgot his name.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "He came from Mannheim, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Uh-- and then all of a sudden, somebody called my number.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And I run up to the person that did, which was a-- a-- a guy that is called a Stubendienst, which is the-- usually the flunky of the block elder that runs it.",
      "word_count": 33
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "He had people working under him that took care.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And he says-- I know the exact words in German-- [SPEAKING GERMAN].",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "In other words, excuse the expression-- you asshole, go back to your barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And I went back to my barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "And I didn't know what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "There's a story behind all these things.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "Uh-- but here I'm going to-- you wanted chronologically, and it isn't chronological, but it has to be said because it fits with it.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "When I worked in Kanada in the Aufraumungskommando, which we will later on discuss in details, one day, a man showed up that worked in the same Kommando as a prisoner.",
      "word_count": 31
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And he was an Unterkapo.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "There was a Kapo, an Oberkapo, and an Unterkapo.",
      "word_count": 9
    }
  ],
