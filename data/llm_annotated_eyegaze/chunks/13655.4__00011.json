  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "What can I have-- in ghetto-- outside of the ghetto was [INAUDIBLE], my sister-in-law-- no, my niece, my nephew-- three nieces and one nephew.",
      "word_count": 24
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "What shall I do?",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Go back to them?",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I have no strength.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "I have no guts.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "Go further?",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "I cannot leave them.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "But I make my decision.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "I went in the direction to Konstantynow.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "I-- Which is which direction?",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "Towards them?",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "And I left them on the [INAUDIBLE], and I went walking there.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And this is 36 kilometers.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "She said-- she told them, Louis jumped.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "She said, let him succeed.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I am not going.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to Treblinka, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "This was the answer.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Go ahead.",
      "word_count": 2
    }
