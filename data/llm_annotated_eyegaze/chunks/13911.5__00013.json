  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I ate a slice.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't have tomatoes, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "So this was as far as food.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Honestly, when I-- sometimes I say, hey, what did we do?",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "What did we eat?",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't like breakfast, lunch, and dinner.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "This, I can assure you.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, hoping that they'll never stop me, and I was a living entity in that place.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "This continued one year, one month, and one day, exactly, after the second pogrom.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I just always remember.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Now, the exact date, I-- all I know is September 1.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "The first one, two months later.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "The second one, which again, two months.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "I don't know if it was, again, on the 1st or-- I don't.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "I won't try to rack my brains, even.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "It won't help, anyway.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And then I remember, this I remember, that memory was acquired while I was right there.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "One year, one month, and one day.",
      "word_count": 7
    }
  ],
