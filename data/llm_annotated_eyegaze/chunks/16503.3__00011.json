  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 33,
      "text": "Speaking fluent German, she observed what was happening, and what was happening was that the women-- some women-- went with the children to one side.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 34,
      "text": "Some children were taken out of the arms of the mothers screaming and the mother went somewhere else and the child went somewhere else.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 35,
      "text": "And so it went.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 36,
      "text": "It took hours.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 37,
      "text": "Finally, we came to the end of the line, and they s-- there stood an SS man.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 38,
      "text": "Meanwhile--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    }
  ],
