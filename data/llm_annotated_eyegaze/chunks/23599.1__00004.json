  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "My father took me most of the time to-- to shows and to [PAUSES FOR 8 SECONDS] the theatre, and things like that.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "My father took me.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean by that?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was a German, was a theatre.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Lots of things.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "He was very, very educated.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "He was very well educated and he was very respected in town.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And lots of people came to him for advice.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] And [PAUSES FOR 4 SECONDS] like he was-- [PAUSES FOR 3 SECONDS] he, too, he was a teacher.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "He was a teacher, too, in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "He was preparing, he-- in small towns, he would stay with families and-- and prepare the boys there for bar mitzvah.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And he learned it from his father, because that was his father's job.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "But we had relatives-- we had relatives-- my grandmother had relatives who had-- who had a factory making all kinds of paper-- of paper things like for school.",
      "word_count": 28
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And my grandmother wanted the boys to go there, because they were relatives, they should learn that job, and they should get a job there, and-- But my grandfather wouldn't let them.",
      "word_count": 32
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Wouldn't let them because it wasn't good enough, just to be worker.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I-- [PAUSES FOR 4 SECONDS] I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It's hard to say what I wanted.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I was very sports-minded, and I wanted to go skiing, and I wanted to do this-- and-- and this, I said, go in the mountains, and things like that.",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Grade 12.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] It was-- it just, kind of, grade 12.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "There-- by that time, there was no school in German anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So, but I wanted a degree, so I had to go to-- I got private lesson, and to go to Prague.",
      "word_count": 21
    }
  ],
