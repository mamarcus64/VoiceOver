  "elapsed_s": 0.9,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "I'm very, very grateful to you, both of you, to the filmmaker and to interviewer.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "I cherish very much your knowledge.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "Because really, I found a person, Miss Baker, in you, that you are so familiar, not only in my area, but I can understand you're familiar-- the whole Holocaust.",
      "word_count": 29
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "And you are listening with patience, and I wish I would have more [LAUGHS] time, maybe I can tell you more.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "And thank you once again from my deep of my heart.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "And any time you have some questions, or you want to know more about something, whatever I can, very gladly and with great pleasure.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 30,
      "text": "Once again, thank you very much.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "There are some pictures.",
      "word_count": 4
    }
  ],
