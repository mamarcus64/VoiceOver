  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "When you get in a-- [PAUSES FOR 4 SECONDS] six Jews together, this is my personal opinion I can give you, if you'll get in six Jews together, they will have seven parties.",
      "word_count": 33
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Me, personally, [PAUSES FOR 4 SECONDS] I lived OK, because-- with some of the families.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I lived a lot with the Frydberg family, [BACKGROUND NOISE] [PAUSES FOR 3 SECONDS] used to eat a lot there, or other families.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I had no problem to-- I was sort of privileged somewhat.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So I had pretty good compared to others.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Look, I grew up very quickly.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I don't think I had a normal childhood.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Maybe a year into the war, and I was probably a man like anybody else.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I had, I had no normal childhood.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I guess my best examples were my brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Some of them are good, some of them were bad.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] But I think most of them, I guess, at the end, they were good examples.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "But they were good for the country over there, for that part of the world, not for America.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] I wouldn't want to go into that.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It's too personal.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I wouldn't want to go into that.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "First of all, in a way, I was a very sad kid.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I was a very sad kid from the, from the time [PAUSES FOR 6 SECONDS] that I have seen they beat my father up.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Since then, my sadness remained up until this minute, in a way.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 6 SECONDS] If I'll go into a restaurant, [PAUSES FOR 3 SECONDS] I wouldn't show this.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It's not their fault.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And if I won't act myself civilized, I'd be thrown out.",
      "word_count": 11
    }
  ],
