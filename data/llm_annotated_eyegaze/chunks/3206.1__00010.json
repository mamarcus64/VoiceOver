{
  "stem": "3206.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And when I came home from school, I remember times, which-- when I had a piece of bread and a piece of onions-- raw onions with bread-- it was good.",
      "word_count": 30
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And I took a piece with a piece of-- my mother gave me a piece of onion.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Take a piece of onion with the piece of bread, stale bread.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "She was hiding from me because I was young growing up.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Szmulek Jaskulka [INAUDIBLE]-- so this was his name.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "So he was my best boy friend.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You know, I was living this side of the street, and he was living across the street.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They were already in a better position than we were.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "In their house, you-- when you came in, you seen, they had a good dinner, you know-- meat at the dinner and and-- bread, butter, all kind of milks, and you know, good things when they came in summer.",
      "word_count": 39
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "There was no fridges then.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Fridge was a-- not a thing in the vocabulary yet in Poland at this time.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "But they had all those good things, you know, to eat, so I was always envy-- to see them, their living.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "You know, we used to go out together-- very good friends.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "So this was the-- the things which you lived through in life as a young child-- nothing good, nothing good, but memories.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
