{
  "stem": "4513.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "When I was in-- in Barcelona at the Olympics, I wanted to get some additional tickets to fill out my itinerary in track and field.",
      "word_count": 25
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And I got them-- I got-- the vice president of Coca-Cola's a friend of mine-- gave me the tickets.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "But he gave me the tickets in the German section.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And I was sitting with these-- sitting in this seat, which we were pushed together and could hardly move.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And I sat down beside this fellow who was a German fellow who swung around from me as far as he could and said he didn't want the likes of me touching him.",
      "word_count": 33
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I sat there looking at him.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And my wife said, what did you say to that man?",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Or what did he say to you?",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I told her and she said, what did you say to him?",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I just said, I didn't say anything.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Said, well, he turned white as a sheet.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "What did you do?",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I said, I just looked at him.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "She said, I know that look that you have.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "I've seen it a couple of times.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "I said-- she said, it's like staring in the eyes of death.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "I  said, I don't know about this.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] I said, all I know is that  this man being very close to me, pitching him out there on the track, OK?",
      "word_count": 23
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "And then I said to myself, no, that's not a civilized move.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And I remember Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "King telling me to learn how to-- to live with your anger.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And I just looked at him and ignored him.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I said-- he-- Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "King said, every time you lose it to someone like that, what you do is [? dimunize ?] yourself.",
      "word_count": 19
    }
  ],
