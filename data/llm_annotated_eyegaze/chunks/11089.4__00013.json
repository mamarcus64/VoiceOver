{
  "stem": "11089.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 371.8,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 25,
      "text": "And I got better, and better, and better.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "In that barrack-- it's ugly-- they took in one corner healthy people, heavy people.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "They gave them food, and they raised lice underneath their elbows and their chest.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 28,
      "text": "And every few days, they came, they picked up those lice into-- into cans for some medical experiments.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 29,
      "text": "And when they had enough lice, they stopped giving the food.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 30,
      "text": "The same people died.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 31,
      "text": "I saw this in the same barrack, the second-- the second corner.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So when I already recovered, now, he was afraid they're going to come take me out to go to work.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And he doesn't want to lose me, because Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Weiss, may he be in [INAUDIBLE], he survived.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, I became a [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "[GERMAN] means the janitor.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Me and another boy, our job-- our job was, you know, can imagine.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Take out the bodies.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Take out the golden teeth.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Put the number on their chest.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "That was my job.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "But I was not taken away from this barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And so it was OK.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "All of a sudden, the Germans gave us to eat something, and we all got typhus.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "Typhus fever.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "Didn't catch everybody, but it got me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And while I was janitor, what was my reward?",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I found, you know, under the dead people's head a piece of bread, a-- a-- a shirt with lice.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I cleaned it in the snow.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I put it on.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "That's how I lived.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "When I got typhus, doctor comes home, he says, you are lost.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I can do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Because I have to be taken to a typhus camp.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Across was a ditch.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And there's a different world over there.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "He can do nothing with me.",
      "word_count": 6
    }
  ],
