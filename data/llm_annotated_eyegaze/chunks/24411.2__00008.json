  "sentences_input": [
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "Whatever you got on your shoulders, this is what you were wearing.",
      "word_count": 12
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "That point, I saw the last time.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I had no feeling.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "There was no feeling at all.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was for themselves to survive.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "There was no feelings.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "It was warm.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I don't-- July, August.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "It was warm.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "We're going to send you back.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "In cattle trains, for the, you know, for the cattles.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I mean, the doors were open.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "There was no windows.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "It was just, you know, like a little-- put eye in, just to look out a little bit.",
      "word_count": 18
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "And the-- the Russians were staying, and they were looking after us.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't-- we couldn't go down.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't escape.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Hundreds and hundreds of people.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Not in my car.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "There was plenty of cars.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I don't know. 20, 30.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Well, there was no treated.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "You know, a whole day you were inside.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "At night, they opened the doors.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And they brought us bread and water to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't wash up.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "Everybody was running into the trains, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "There was no toilets.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "There was a hole in the-- in the car, and we were ashamed.",
      "word_count": 13
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "So a lot of people had blankets or something.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "And they made it, if everybody wants to go, you know, they just covered it.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] And everybody slept together.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "There was no arrangement.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "It was made like from wood, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yes, inside.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And everybody would find a place to lay down to sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "They were crying, and what can you do?",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Nothing else.",
      "word_count": 2
    },
