{
  "stem": "1733.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 43,
      "text": "The only thing that we did not have, we did not have a set date when the flight was going to take us from Paris to New York.",
      "word_count": 28
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 44,
      "text": "And until-- until the flight-- until we had a designation of flight, we couldn't get any visas.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So when we got to Prague, I went to the Joint Distribution Committee, and I told 'em about our plight.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I told 'em that we are going to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And I told them that the Russians are looking for them, and we have to leave Czechoslovakia.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They put us on a train to Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And in Paris, we stayed a few days until we came to America.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Quick clarification for the people who see this.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "At the beginning of the war, Velike Loucky was part of Czechoslovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Hungary, and it was called Nagylucska.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "It was back to Velike Loucky.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "It become-- it became Russia, which is presently the Ukraine.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I really don't remember how we got in touch and how he found out that we are alive.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "But somehow he found out that we are alive.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And actually, from-- when we  were liberated in Prague, I knew his address, and I wrote him a letter.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I told him that I'm going back to Loucky.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And he had-- this is how we got in touch.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I told him who survived, that my sister survived.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And I also told him that-- to be in touch with Henry Davis, that his nephews-- nieces and nephew survived.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And we came to the United States within two days of each other.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I know that the rest of the family were killed.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather, who was 84 years old, was taken away from home.",
      "word_count": 12
    }
  ],
