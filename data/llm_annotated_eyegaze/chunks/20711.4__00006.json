{
  "stem": "20711.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "So when we heard about that news, we knew we have only a couple more days, perhaps, to stay in peace.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And that same time, there was a, a whole busload of organizers coming into town who were setting up this Szalasi party, which called Arrowhead Party.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "They were organizing it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And my aunt, who happened to work in the town hall, heard about this group coming out.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "She didn't even knew if it's going to be an armed group or just civilians or what.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "But she called my mom, and she said, I think you better get out of town as long, as soon as you can, because these people is coming, and we don't know what they are up to.",
      "word_count": 37
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But there was no way to get out.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't trust anybody and ask where's a horse and wagon to take us to the railroad station?",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It's taking two, three hours with a horse and wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Anybody could pick us up on the way.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It was no way to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "So my mother, again, pulled her trick out of the hat.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "She told me to get dressed very well.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And we put on our best, most elegant outfit we could.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And she said, only take our pocketbook, and come with me.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We walked to the town hall.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "The bus was still in front of the building.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "She approached the bus driver, who was in army uniform of the Arrowhead people, which was a black uniform.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And he said to the chauffeur, would you mind to take two passengers into the city of Miskoic?",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And he said, oh, I think we have enough room, and we are heading to Miskoic.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Oh, I'm sure my boss will approve.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "Let me talk to him.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "He got the approval.",
      "word_count": 4
    }
  ],
