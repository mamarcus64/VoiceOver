{
  "stem": "13524.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And you had to pick a piece of clothes-- article of clothes-- in a running pace.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I have managed to picked up a green dress, evening dress, with open front, open back-- no sleeves-- a pair of knickers, and pair of clogs.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] I was glad to have something.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And as we walked on, we went through a place where there were autoclaves.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And I spotted a fellow, also a prisoner, working with the autoclaves, pushing, pulling clothes from one autoclave to another autoclave.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And I spotted a coat-- a big coat-- men's clothing.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And today, to this day, I realize that it was not Polish coat.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "It was beautiful coat-- pure wool.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "It had fur collar.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "I grabbed the coat.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And I said, please give me that coat.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "I knew that with my figure, I won't exist very long in Auschwitz in an evening dress-- full length, and here-- nothing!",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And he said, I can't give you the coat.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "You get shot.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "It's got a fur collar.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "I said, I'll get shot anyhow.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "Give me that coat.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "And he fought with me.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "And I fought with him.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "But he was little.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "And my life depended on it.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "I grabbed the coat.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "And the rest was following me and telling me, go on, go on, quick!",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "Because you know, that was the attitude.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "Don't stop the queue.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "They'll shoot you!",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "They'll shoot us!",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "I grabbed the coat.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "I had the coat in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "I was the only one walking in a men's winter coat-- with a fur coat.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "I was wearing it up to make sure they didn't see.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "But nobody cared anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "We were all destined for ovens sooner or later.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "It just probably that particular period we were still to work.",
      "word_count": 11
    }
  ],
