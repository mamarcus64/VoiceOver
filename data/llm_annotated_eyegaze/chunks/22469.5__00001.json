  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So we start to work.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "What was to work?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Nothing-- nothing to work.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But suddenly, the SS, they wanted to paint the rooms for them.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And so I start to be busy.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And I took another three or four people, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I said, it was old man [?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Ferber. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I show you-- very old.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Maybe 70. ?] How he came to us, I don't know.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I says, [?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Ferber, ?] sit here.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "You got brush.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "You got-- when somebody's coming, paint.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And this was the joke.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But I was free.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I was always [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "The commander wanted to make friend.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE] [? a proper ?] commander, [DRINKS] [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "This other guy, what, he killed thousands and thousands of Jews in Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And he was our commander.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We've been in the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And in the camp, he got two rooms with kitchen, everything.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And he took one girl to cook, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] It was a murder.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And he suddenly-- where's the painter?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I need a painter because it's dirty.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "So I went to him.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "He said, painter, you're going to do the-- all right, sure.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I said, boss, but I need flour.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "You know this flour?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "Flour in the war?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Are you crazy?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I said, excuse me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I need a glue.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But glue is not here.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I-- I need flour.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And he said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "If you need flour, you are clever and go to the kitchen to the Jewish-- and tell them that you need flour.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Bastard.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I went [? to ?] the [? boss ?] kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was German Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I said, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I need five kilo flour.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I didn't need nothing because I want flour to make, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "To bake something.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I said, [INAUDIBLE].",
      "word_count": 3
    }
