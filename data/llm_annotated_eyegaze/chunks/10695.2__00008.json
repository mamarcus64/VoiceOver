  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "If not, they wouldn't fit into-- in the gun.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I want a Polish man.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They gave me a file.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "A good file.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I filed around the pistol.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Every bullet is a pistol-- they call it pistol, I think.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "See.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I filed around the pistol.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And took out-- easy, easy the pistol, and put it in the Polish bullets.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I have bullets ready.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I put it the [POLISH]-- you know what I call the [POLISH]?",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "The powder.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I put it in the Polish bullets.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I made about a dozen bullets.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Do you know, it was something unbelievable.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "The people that used to be with me, they used to watch me.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "They used to watch me.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "Nobody said kill me, too, because they couldn't find another such a bright boy.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "Can we take a moment and talk a little bit about the living conditions in the hole?",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "In the wintertime, we-- I use to live in the-- in the-- in the hole.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "For example, I-- when I used to-- I used to have food to eat.",
      "word_count": 14
    }
  ],
