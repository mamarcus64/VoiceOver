{
  "stem": "471.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "The Ukrainian came out and he said, look, at-- a-- a-- a couple trucks has to go by first.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And Goth going to be-- Goth going to be here any minute.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I said, already, uh-huh.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Is that the end of us?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "What for I went to see-- what for I want to see my brother?",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "What for?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I'm thought, God, Goth going to see that, going to ask what we do here.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "So he's going to kill us.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But now, they push us on the side, said, don't worry.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You're going to get in.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "You're going to get the-- you know, the men-- the-- the-- the food for the whole camp.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And Goth, is walking, come over.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And he's walking back and forth already, back and forth already.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Didn't look at us.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "What happened maybe 15 minutes later?",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Two full trucks of Polacks, gentile people.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "All bound up against the tailgate from the trucks-- [PAUSES FOR 3 SECONDS] --pull over.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know what's going to happen with this.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "So I remember, and I see him, his face today, I would recognize him.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And he start to-- they to sing, you know, the national hymn, the Polish National Hymn.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Because they knew they-- they-- they-- where they'd carried them.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "But we didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING POLISH] And I'm going to say it in Polish.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And then translate it.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "[SPEAKING POLISH]",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They say it.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Polack.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "You're not helping the Jews now.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "But can't you see what's happened?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They start with the Jews but they end with us.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The prisoner, the Polish--",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "--prisoner on the truck.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Said that.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And there was two carloads of them.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how many.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And five-- yeah, they went-- no, no, no.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They went to Hujowa Gorka.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The ramp open up.",
      "word_count": 4
    }
  ],
