{
  "stem": "14002.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "From Kobenz, we were there just about three months.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "From Kobenz, they took us to Admont.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "In 1946, they took us to Admont.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I was in Admont till-- to-- till 1949.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Yeah, in the spring of 1949, I was-- I was in Admont.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And Admont, basically, also was a camp.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "There's a lot of people left for the-- for Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I was working in Admont not for the British.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I-- I say the truth.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I have I did a lot for the people what wanted to go to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "I made a lot of arrangements for them, with a-- with a Jewish agency, they should be able to go to Israel.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "I changed-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "My brother changed my mind.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "I wanted to go to Israel, too.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "My brother, he was in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "He changed my mind.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "That was in 1948, when the war started there.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "He says to me, he wrote me, that, he says, don't come now to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "He says, It's a war.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "He says, go to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "You'll be alive there.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "Now, there-- there is something that I wanted to say how I-- I had an uncle here-- how I found my uncle.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 4 SECONDS] That was in 1946.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "I was reading the Jewish-- the Jewish paper, They used to send the-- the paper to the camp.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "And, of course, there was the classified ad.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "There was people, you know, they were looking for their relatives.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Who-- who is alive?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I've seen, over there, a name from next to our town, that he's looking for some relatives.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I figure maybe he knows my uncle.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I did-- I did write to him that this and this is my uncle's name, Harry Fox.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He was in-- he was in Europe.",
      "word_count": 7
    }
  ],
