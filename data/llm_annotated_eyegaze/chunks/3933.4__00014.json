{
  "stem": "3933.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And I left him there with, I don't remember, with people from the railroad, and telling them I will be back.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I went to Lucia and to Kola, and I find them that she left.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I told her-- she said, where's Zbyshek?",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I told her he's on the station.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "She went with me.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We took a little wagon, and we took him back, first of all.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Then I stayed with them.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "There was very terrible apartments, tiny apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "It goes on during [NON-ENGLISH], along with this [INAUDIBLE] with him, and he still continued to go to the bar.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He still continue to come back and he bashed, very much, his sister, too.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And I must say, I was raped from him again, because I sleep together with him-- there was no choice.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And on one-- in a nice day I came back, but then Tsila, my son's cousin, the girl who survived who's in Israel, not Fela, the one who brought him from the street.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "My husband's sister's girl, she survived by the non-- non-Jewish brother-in-law hid them.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "David was-- oh, I didn't mention the story with David.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Oh, my God.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "David was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "He was hidden by a Polish family.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "They [NON-ENGLISH] him, and they gave him away.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "They were paid to hide him, and they gave him out.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "David was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "Then Tsila, the younger sister, survived.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "She was in a village in a Czech-- The non-Jewish brother-in-law have not any children, and they liked her.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "He liked the sisters-- his wife's sister's little girl.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "Then Tsila's a wife.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "She's  in a Kibbutz in Israel, my son's first cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Kristal.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, you name after your husband.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "She's a mother, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Kristal.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "It was Pomeranz, when she was young-- Pomeranz.",
      "word_count": 8
    }
  ],
