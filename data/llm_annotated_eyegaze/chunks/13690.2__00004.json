  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "The rest of the 4,000 run away like our family, to Pilica and all the other surrounding towns.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The 700 people were loaded into a horse and buggies, brought to the railroad station, put them in a couple of cars, and there were just send them to Treblinka to the gas chambers.",
      "word_count": 34
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No, my father was with us in the town, and we came back.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Then the-- from the 30 people, they were-- were buying out, by the Germans, stating that they do need more than 30 people to clean up the city.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So in that way they got permission to extend from 30 to 100.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "In that 100 group of people, our family was included.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "For money.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I was actually not between the 100 counted ones.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The one that was between was my father and my mother, of blessed memory.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I was in the apartment that they lived in, one room, and when they went to work, so to say, I was put between the covers.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Same thing, but they-- one day they-- they were checking those houses for other Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "They found my-- being the big man, they caught the big fish.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was 14 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "They took me to the local jail. 1 was so big, and I was so skinny, and so barely showing life, signs of life-- so that they put me between the ladies, I do remember, the lady-- the lady sections of the jail.",
      "word_count": 43
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Some how, some way, I had to be rescued during the day, because of the next morning at the daybreak, all the inhabitants of jails were killed.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "One of the leaders of the 30 original people came during the day and he bailed me out, seemingly that my father probably paid and he got me out.",
      "word_count": 29
    }
  ],
