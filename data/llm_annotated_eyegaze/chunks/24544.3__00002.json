  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So it was very low.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "That was a very big things in our life later on, because we went on our stomach to drink.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Five meter from us people was washing something.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And some other people was washing their face and was drinking.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "We didn't see any--",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "--water, ever.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So we were taken in the barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they said, lie down.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Which means like sardines.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Empty--",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Only wood and--",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, no, we were the new people over there.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "When one and two was full, the third one was used.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And that was ours.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we went in the barrack and lied down on the bare wooden.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Nothing on.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I was watching in the window myself, how do I look like?",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I was looking backward, because I thought my [?",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Tibika, ?] my brother is standing behind me.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I ran to my mother, Mother, I am [INAUDIBLE], your daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We were thirsty.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We were tired.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have our own [? soul. ?] I'm telling you.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We were already like animal.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I am-- I am sure.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And what they think?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Who is going to give us to eat?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And where is the place we are going to sleep?",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "So we were happy just to lay down.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And we have very close two friends and one cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "So we were there five.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Five means in our life until we were in [? deportant ?] people, five in a line.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And we keep together.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We came home together.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "We went to work together.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "We did everything together.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So we lied down.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "But next day, we were smarter.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "We went out, and we finally saw a little grass.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So we were getting grass to get in the barrack and put it under our head.",
