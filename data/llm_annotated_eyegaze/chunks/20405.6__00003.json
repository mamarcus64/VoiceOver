{
  "stem": "20405.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And he didn't know he was going to get burned.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And he started hitting the floor with his feet, so hard, hitting, hitting, hitting, hitting the floor-- broke up the floor on top-- the ceiling, or the floor, whatever-- and he came down.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "When he came down, he run right on the electrical wires they had over there.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And he was telling me all the way that time-- all the time he was telling me how somebody can get away from-- from those wires.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "It was those pointed wires they got, like this.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "He was telling me, just lay down like this and just make a turn.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "That way, holding a little bit the wires, you can get out.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "This is the way he did.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "Because they brought him to us after.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And I learned it from him, the way they killed the other guys and they-- they push them in the hole.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "What he did-- he got away from this wire, from the crematorium around the wires.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "What did-- where did he go?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Did he go to Kanada kommando.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He was near to it.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "So [INAUDIBLE] when they saw him.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "They got him, and they hide him.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "They hide him one, two days.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And then the guard, the German guard, went inside.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And they told him, we got a guy, this and [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "This German, he didn't killed them.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "He brought him to us in crematorium two.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And he was working with us.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Now with the crematorium building over there, the [INAUDIBLE] crematorium one, crematorium two, and crematorium four.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Crematorium four, they killed them right away.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "From the crematorium one was in the south side, I guess, or north side-- south side or north side.",
      "word_count": 19
    }
  ],
