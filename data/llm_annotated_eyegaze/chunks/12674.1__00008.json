{
  "stem": "12674.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And Tata lived with some of my grandmother's sisters and another aunt.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "They had a huge apartment with inside rooms and outside the rooms.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "So they took me up there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And they were all worried-- I was only two years old-- that I was going to cry and be hysterical.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And they said that I would have to stay there because it was very cold, and in our place it was too cold, and I would be more comfortable there.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And when the flowers bloom and it gets warm outside I could come back.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So when my mother went home, she cried.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You know, she wanted-- she had to leave her baby.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They told me that, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember it.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So they said, all right, we're going now.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "So I lifted up my hand and I waved at her.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I said, goodbye, Mommy-- in German, of course-- I see you when the flowers blooms.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And she never forgave me.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] When I was 15 years old, she still told me that I just dismissed her.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I see you when the flowers bloom.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And then I take off.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And she says, I cried, but you didn't it.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I loved my aunt.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She had a business of making [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "She made embroidered bedding and blanket covers and night gowns and house coats and things like that.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "They called it white sewing.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "It wasn't clothing.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "It was household articles and underwear, fancy slips and house coats and things like that.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And she had a business like that.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And that was long before sewing machine.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And I would sit for hours while she was sewing on her lap while she was doing that.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "It was a very nice childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "We were all very close.",
      "word_count": 5
    }
  ],
