{
  "stem": "24346.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We have, in the house, is these very nice-- Oh, no.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "This is our problem-- [INTERPOSING VOICES]",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Henry Goteiner.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "G-O-T-E-I-N-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "At birth, Chaim Gotajner.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "G-O-T-A-J-N-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in the city of Lodz, Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "City, L-O-D-Z.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In November 16, 1923.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Now, 73.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Just the Yiddish name, Chaim, that's how I was called.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Lodz was a big textile city.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was the second largest city in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "In fact, it had 3/4 of a million inhabitants, so it was a pretty large city, considering Europe.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We lived in an area of Lodz that's called, it was called Baluty in Polish.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "In fact, that became later the area where the Germans created the Lodz ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My immediate family, I had two brothers and myself, so we were three, my mother, and my father.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I know whatever I'll tell you, whatever I'll know, whatever I still remember.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "My father was born, also, in Poland, in a city that was called, in Polish, [?",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Zychlin. ?] It was Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "He was one of, also, seven brothers and sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "My mother was born in a city named Krasnik near Lublin.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Lublin was the big city.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "The Krasnik was a smaller town.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And she was also one-- maybe, six brothers and sisters together.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father was in the wholesale business of delicatessen, meaning he sold wholesale salamis, baloney, all the stuff that the people asked, he delivered.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He went to people who needed to sell retail.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And he sold them-- he went to small restaurants, to-- what do you call this?-- beer saloons.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They used to buy these knackwurst and all this stuff, and that's where he sold it.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, for me personally, we had a decent living made, because my mother also ran a retail store, delicatessen.",
      "word_count": 19
    }
  ],
