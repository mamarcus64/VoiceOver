{
  "stem": "21786.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Where I was sitting in the middle and two guarded-- two armed SS Men next to me were taking me to Prague 12.",
      "word_count": 27
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I picked up, explained to my parents, they shouldn't worry, that we'll manage somehow.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And my father gave me a Hebrew blessing, let me kneel down, gave the [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And I left.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "They took me to the gathering place.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And we left that evening.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Left, meaning, we walked towards a train.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "We boarded the train.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "It was still, I mean, a personal train.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And we went to Terezin where we walked about 2 miles.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "Later on, they had a special track going directly to Terezin about a year later.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "And they walked us in guarded to a special gathering place which was part of old-- one of the old military barracks.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And we were simply closed off.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "We were not permitted to move out.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "We simply were waiting just for further transportation.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And-- during the night, there came one Czech gendarme with two Jewish persons from the Council of the Elders in Theresienstadt.",
      "word_count": 25
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "And he had the permission to take out four persons.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "One of them was somebody whose name I forgot.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "One of them was Eva's mother.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "One of them was Eva.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "And one of them was I.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "And we left.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "And the transport left within 12 hours, went to Sobibor, S-O-B-I-B-O-R.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "The people lived probably another 36 hours.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Now, that was how I got-- how we got to Theresienstadt.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Any question?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Or, am I off?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Roden, do you remember the name of the Zionist representative on the Council of Elders in Prague who originally helped you get into transport?",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] His name was simple.",
      "word_count": 8
    }
  ],
