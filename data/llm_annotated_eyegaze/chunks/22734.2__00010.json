  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "So he-- he denounced my father, my mother, and my uncle at something that is called-- [PAUSES FOR 3 SECONDS] not the Gestapo.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "It was called the Wiesenschutz commander.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "They were-- [PAUSES FOR 3 SECONDS] I-- the reason is for an exchange.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "And it was a-- an office to protect the foreign exchange, meaning the hard currency and gold.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "And-- and this guy denounced-- I know also his name-- denounced my parents and my uncle that they were-- they had gold at home.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "And the Gestapo came while I was at school, and they really ransacked the apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
