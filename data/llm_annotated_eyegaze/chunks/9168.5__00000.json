{
  "stem": "9168.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The seventh experiment was seawater, conducted to develop a method of making seawater potable-- or drinkable.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The victims were German, Czech, and Polish gypsies-- this was a gypsy experiment-- who were deprived of food and given only brackish yellow seawater for weeks, which resulted in excruciating pain, foaming at the mouth, and eventually, in most cases, madness.",
      "word_count": 41
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "One of the most dramatic courtroom scenes occurred during my turn in the courtroom.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Karl Hoellenrainer, H-O-E-L-L-E-N-R-A-I-N-E-R, was a dark haired man of small stature who was nervous and very excitable as he assumed the witness stand in the courtroom.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The main courtroom of the Palace of Justice looked very large that day in front of this little man.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "It was June 27, 1947.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Question-- now witness, for what reasons were you arrested by the Gestapo on 29 May, 1944?",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The question was asked in English, and interpreted through the English Channel of my earphones into German.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The answer given in German was, because I am a gypsy of mixed blood.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The Reich Citizenship Law, dated April 25, 1943, read, quote, 'Jews and gypsies cannot become citizens,' unquote.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "The Law for the Protection of German Blood and German Honor, dated November 14, 1935, which prohibited marriage between gypsies and Germans read, quote, 'a marriage shall furthermore not be contracted if the progeny to be expected from it would endanger the purity of German blood,' unquote.",
      "word_count": 47
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Karl Hoellenrainer was first sent to Auschwitz, then Buchenwald, and then Dachau, where he underwent these seawater experiments, which tortured his body and mind for weeks.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Question-- do you think you would be able to recognize that doctor if you saw him today?",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Answer-- yes, immediately.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I would recognize him at once.",
      "word_count": 6
    }
  ],
