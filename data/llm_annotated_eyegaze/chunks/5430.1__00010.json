  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And when the houses started burning, my father and my brothers and I, we went down in the basement and dug up a big hole in the basement.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And we took most of our belongings or anything that was of value, including bedding and all the-- and buried everything in that basement.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And, and sure enough, a few days later, the whole building was on fire and it literally collapsed right above that.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And we came a few days after the-- the house was still smoldering.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And we decided to un-- un-- dig the-- dig up the basement to get our belongings out.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And it's a good thing we did because things started smoldering already on top of it.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And that's how we were able to salvage some of the pictures that we had from pre-war.",
      "word_count": 17
    }
  ],
