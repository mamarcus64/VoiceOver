{
  "stem": "17299.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 293.3,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We had to march to Salaspils, which was 17 kilometers, which is roughly 11 miles, through ice and snow, under supervision of Latvian SS and police.",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "For each 10 Jews you had one rifleman.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "The march took roughly four or five hours because it was very difficult to march.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "When we arrived in Salaspils, we saw two barracks, one barrack partially built, and a tent.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And we had to stay outside, and a lot of yelling was going on.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Then one fellow Jew came out and introduced himself as [GERMAN] Wertheim, that he is the leader of barrack number two, where we Jews would go in.",
      "word_count": 27
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "He was the barrack leader of-- then there was Jewish police.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "One fellow introduced himself as [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "He was the elder of the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And then we were sorted out in groups and got told we are going to sleep on bunks.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Each bunk will hold three persons.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "So we brothers said we stay together.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Then we were-- when we were marched in the barrack, we got the surprise of our lives.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "There were not-- were not bunks.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "There were shelves.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "There were three shelves on each side of the barrack and five shelves in the middle.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And the shelf was, oh, I would say six feet wide and seven feet long, and on each shelf three persons had to sleep.",
      "word_count": 24
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "But the only surprise we got that on the shelves were mattresses.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "When we looked at the labels on the mattresses, they had the name of Jews, and the addresses were from Berlin.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "But there were no Jews from Berlin in the ghetto at that time.",
      "word_count": 13
    }
  ],
