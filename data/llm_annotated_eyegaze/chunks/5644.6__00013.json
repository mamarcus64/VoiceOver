  "sentences_input": [
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 1,
      "text": "I landed in Sydney and then came to Melbourne.",
      "word_count": 9
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "John ?] [? de Witt ?].",
      "word_count": 6
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "No, because I did have the people here in Melbourne.",
      "word_count": 10
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "But we landed in Sydney.",
      "word_count": 5
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "I think February 1947 if I am not mistaken.",
      "word_count": 9
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "I went straight to Melbourne.",
      "word_count": 5
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "On a train.",
      "word_count": 3
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "Already been in Melbourne.",
      "word_count": 4
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 0,
      "text": "They came earlier.",
      "word_count": 3
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 0,
      "text": "I haven't been on a job.",
      "word_count": 6
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 1,
      "text": "I start a little bit in leather.",
      "word_count": 7
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 0,
      "text": "Producing leather, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 0,
      "text": "Tanning.",
      "word_count": 1
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 1,
      "text": "Not tanning, exactly, but finishing.",
      "word_count": 5
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 2,
      "text": "The finishing of the leather.",
      "word_count": 5
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 1,
      "text": "I been with my brother-in-law.",
      "word_count": 5
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 0,
      "text": "No, he was in fur.",
      "word_count": 5
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 1,
      "text": "He wasn't in leather.",
      "word_count": 4
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 2,
      "text": "He was in fur business.",
      "word_count": 5
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 3,
      "text": "And then we start off little fur business.",
      "word_count": 8
    },
    {
      "segment_idx": 189,
      "sentence_idx_in_seg": 4,
      "text": "Small, but--",
      "word_count": 2
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 0,
      "text": "Little-- not furrier.",
      "word_count": 3
    },
    {
      "segment_idx": 190,
      "sentence_idx_in_seg": 1,
      "text": "We did specialized things--",
      "word_count": 4
    },
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 0,
      "text": "--from little pieces, we made beautiful coats.",
      "word_count": 7
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 0,
      "text": "And then my brother-in-law opened a clothing factory.",
      "word_count": 8
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 1,
      "text": "I was a partner to it, quiet partner.",
      "word_count": 8
    },
    {
      "segment_idx": 193,
      "sentence_idx_in_seg": 0,
      "text": "The furrier-- not shop.",
      "word_count": 4
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 0,
      "text": "That was only a business.",
      "word_count": 5
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 1,
      "text": "Goodrich and Landau.",
      "word_count": 3
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 0,
      "text": "And another one, their clothing was Leading Fashions--",
      "word_count": 8
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 0,
      "text": "--which the Italians called [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] in Italy, bim, boom, bim, boom, bim, boom.",
      "word_count": 9
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 1,
      "text": "Our Australian machine, rrrr, too quick.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 2,
      "text": "Me finish.",
      "word_count": 2
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 3,
      "text": "So I thought that she wants to finish completely.",
      "word_count": 9
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 4,
      "text": "She didn't want to finish.",
      "word_count": 5
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 5,
      "text": "She want to finish by hand.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 6,
      "text": "Oh, my daughter is a very good cutter.",
      "word_count": 8
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 0,
      "text": "Which factory did she work?",
      "word_count": 5
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 1,
      "text": "No factory.",
      "word_count": 2
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 2,
      "text": "She cut sandwich every morning for the husband.",
      "word_count": 8
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 0,
      "text": "I am not.",
      "word_count": 3
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 1,
      "text": "I am not.",
      "word_count": 3
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 2,
      "text": "That's how it was at the clothing factory.",
      "word_count": 8
    },
    {
      "segment_idx": 200,
      "sentence_idx_in_seg": 0,
      "text": "My life went to building.",
      "word_count": 5
    },
    {
      "segment_idx": 201,
      "sentence_idx_in_seg": 0,
      "text": "To my old trade.",
      "word_count": 4
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 0,
      "text": "A little bit in a tannery, and then to building.",
      "word_count": 10
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 1,
      "text": "We'd been partners to a tannery which been losing 10,000 pounds a week.",
      "word_count": 13
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 1,
      "text": "Two [INAUDIBLE] the company, and they explained us that the losing of the money will take about 10 years.",
      "word_count": 19
    }
