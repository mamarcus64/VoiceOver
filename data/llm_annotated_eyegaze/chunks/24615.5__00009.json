{
  "stem": "24615.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Still with the Brigade Gordonia, a kibbutz.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "At this point, maybe we were about 20 or 30.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And it was different.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "It was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You know what a [NON-ENGLISH] is?",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I had from the kibbutz.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And from there, we stayed there a month.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We were in hunger and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And they took us on a farm to teach us how to work on a farm, to teach us how to plow, to teach us how to-- you know, to teach how to milk a cow.",
      "word_count": 36
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Do you see on the horse?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "This was the kibbutz where I was.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And how were you feeling at this point?",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I felt but still I was sick, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I was in my stomach and everything, you know like flies fly around.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Now from there, we had to go to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So I was so sick and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Nobody know what is wrong with me.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And I went to take baths and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And then they told me I need appendix.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "So I went to hospital, and there the nurses told me it was a Gestapo he operated on me.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "I didn't need the appendix.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "I didn't need nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "I was just sick, you know, like nerves, or nervous breakdown, or whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And while I was sick, you know, and it was a teacher.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "He taught us Hebrew.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "So he came in to teach me while I was in bed.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And a guy was there.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "He starts talking.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "So a guy told him he has relatives in United States.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "So I said I have relatives in the United States too.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "And he asked me the name and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "And I told him.",
      "word_count": 4
    }
  ],
