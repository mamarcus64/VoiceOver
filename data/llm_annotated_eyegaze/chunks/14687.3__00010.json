{
  "stem": "14687.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "He said that time they put-- also in there-- they-- they had also crematorium there, ready to-- to kill all these Jewish that were there.",
      "word_count": 25
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "But the-- the Russians arrive.",
      "word_count": 5
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 2,
      "text": "And they were fighting there.",
      "word_count": 5
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "When we were there, they-- they took us to Theresienstadt.",
      "word_count": 10
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "Still they were fighting.",
      "word_count": 4
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "On the 8th of May, it's finished, the war.",
      "word_count": 9
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 4,
      "text": "How did you know that it was finished, the war?",
      "word_count": 10
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Because they says, finished.",
      "word_count": 4
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "You know, they were talking, the other people.",
      "word_count": 8
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 2,
      "text": "This is finished-- is finished.",
      "word_count": 5
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 3,
      "text": "And they were shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 4,
      "text": "And-- and the German-- the Jewish people, they start taking the Germans like prisoners-- you know, the Jewish people, the ones that were in Theresienstadt.",
      "word_count": 25
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 5,
      "text": "We were sick, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 6,
      "text": "We were thin.",
      "word_count": 3
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 7,
      "text": "We had no strength.",
      "word_count": 4
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 8,
      "text": "So they give us nice food, nice soup, for two weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "And then when you wanted to go anywhere, you used to show the arm with the number.",
      "word_count": 17
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "You didn't pay no water, no cafe, nothing, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 2,
      "text": "They used to give you for nothing, these people.",
      "word_count": 9
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "And after two weeks, we were in Theresienstadt there, two, three weeks, I was walking, and I saw my cousin, Clara.",
      "word_count": 21
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "She was in the typhus verboten.",
      "word_count": 6
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 2,
      "text": "You can't go near.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 3,
      "text": "She had the typhus.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 4,
      "text": "After a few weeks, she was better.",
      "word_count": 7
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 5,
      "text": "She came with us, with that-- where we were, the Jewish people, like Matilda, Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 6,
      "text": "All these people, they were together.",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "In Theresienstadt, it was a very big camp.",
      "word_count": 8
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "But they gave us nice food.",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 2,
      "text": "The Red Cross, they give us parcels.",
      "word_count": 7
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "As soon as we start eating, our period came.",
      "word_count": 9
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "And we used to make food, fete, you know, dancing and singing, you know, from the joys, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "We had the-- the thing.",
      "word_count": 5
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 3,
      "text": "[SPEAKING SPANISH].",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 4,
      "text": "Shame.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 5,
      "text": "She was young.",
      "word_count": 3
    }
  ],
