{
  "stem": "18575.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what village or what town it was, but I remember she passed away.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I was sleeping with her and she just passed away at night.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall it.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I don't recall it.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "But, of course, she lived with us, the grandmother, mother's side.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "The closest we were, of course, was to the mother's side of the family, because she visited there more often than the father's side of the family.",
      "word_count": 27
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Although, my grandparents from the father's side lived, lived in the same apartment building, two floors beneath us, or below us, [INAUDIBLE] was below us on the first floor.",
      "word_count": 29
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "We were in a third floor.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "So we very often, I went back and forth.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "But the closest relations we had with the family, cousins, and uncle, and aunt, who are from my mother's side.",
      "word_count": 20
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall her first name, but the last name was Benderman.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Gold, as my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He was a sister of my mother, Benderman.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "In fact, their son, I don't know if I should get you, the son is now in Israel.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "He left Poland in 1938.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "He couldn't get to Polish university.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "They would not accept Jews into technical school.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "He was, he wanted to study aerodynamics or whatever.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "He went, he had some cousin Australia.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "He went to Australia and he survived.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "He fought with Australian army.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "Then he joined Israeli army or prior to Israel, Palestine.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "And he lives now retired in a kibbutz.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "His name was Benderman, Mark Benderman.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Now he changed his name to Mark Bendor.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Bendor is B as in Boy, E-N, D as David, O-R, Bendor.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "He was a major in Israeli army.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "He fought through all the wars.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
