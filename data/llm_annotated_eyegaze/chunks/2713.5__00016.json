  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "And they told me if you are not going back for such and such time, I-- you have to join in the army.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "So I knew I'm-- I'm not going anywhere.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "So the passport, in the meantime--",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "--expired.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what to do with myself.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So I went-- I went skiing.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "When I went skiing, I could see I was near the border, near the Czech border.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And I can see that it's not so hard to go through the border.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So I came back to my sister, and I told her that I think that I'm going to go to Austria.",
      "word_count": 21
    }
  ],
