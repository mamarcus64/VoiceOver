{
  "stem": "752.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "My father gave me diamonds, so I sold that.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "When -when you saw your brother, did he tell you if he tried to get the rest of the family to leave Warsaw?",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't, because-- because my father had an occasion.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He had a big [INAUDIBLE] machine, a truck.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we got set up for him all comfortable that he could go to the Russian zone.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And then my mother went and said goodbye.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "[SOB] Start crying and he left.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He went back.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He says, you cry, I don't go.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "But otherwise, he could save.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Because whatever my father did, the whole family did.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 5 SECONDS] [CRYING] I-- I went back one time on a special occasion.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I received a letter from my father that the-- the Germans allow to open up the stores.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "But it has to be the original owner to sign the license certificate.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "So I came all the way from Lviv to Warsaw with a guy which-- a guide-- a guide, which took me across.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And I went, and I signed the license.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And my father didn't want me to leave anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "So he got angry.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "He didn't say goodbye.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "He left and I left.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "In 1940.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No, no I met my husband, myself.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "But my brother was with us already.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And then the Russian-- I was working in Lviv in a theater.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I was serving a buffet.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And my brother came to have dinner.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I said to him, Mosze, don't go outside, because the Russians are grabbing the refugees.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they sending them to Siberia.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And he didn't want to listen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I went to work.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And he went out, and they grabbed him.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "They send him away.",
      "word_count": 4
    }
  ],
