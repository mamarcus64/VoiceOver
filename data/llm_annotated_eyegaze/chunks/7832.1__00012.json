  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "But I said to my father, why are they throwing the children-- what do you mean they're tearing them in half, and they're throwing them in Dniester?",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And he said, you never heard that.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "That never happened.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And you have to forget about that.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I said, but that man said, that was here last night.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He said, there was no man here.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And you are not to tell anybody there was  a man or what he said.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "So I realized that something terrible is going on that they don't-- they don't want the children to know.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So I just kept quiet about it and never, never mentioned it again to anybody.",
      "word_count": 15
    }
  ],
