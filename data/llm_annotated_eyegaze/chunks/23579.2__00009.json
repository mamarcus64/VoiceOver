{
  "stem": "23579.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And I was working in the hospital from the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "They put me in there.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I should not go out to the Germans, and they should hit me over the head because they were-- the people, when they went out to the city, they were killing them.",
      "word_count": 32
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "They were hitting them-- they should work faster, faster, faster.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So my father, he knew to whom to give whatever he gave.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And they put me in the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And I have the people that they were working with me-- I have here Sonia Orzman.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "You saw them on the Novogrudok.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "These are my friends from school.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We finished together.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "We made the exams to Rostov for dentistry.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "Only me and her got accepted to Rostov.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "We made the exams.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "But the war came in two days.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "Everything was finished.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "So that's not what you can say something.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "And this is not true of this, is it?",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "Were your parents with you?",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Always with me.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Always with me.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "My father did many things for the Jewish people in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "He was very friendly with the head of the police, the Polish police.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "He was, all life, he had a family from four children.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And he didn't have-- never enough, so my father was always giving him food for the family.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "He gave to him shoes for the family, gave it to him four coats for the family.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "But when I needed him, he did everything for me, for my father.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "My father took it out, [PAUSES FOR 4 SECONDS] a wife and two children an hour before they took him to the [INAUDIBLE] to kill them.",
      "word_count": 26
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "Because she said that she is something-- a family with us.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "So my father went.",
      "word_count": 4
    }
  ],
