{
  "stem": "2946.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was prayer songs-- Hebrew prayer songs, and some Hungarian songs, and some Yiddish songs.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Oh, she had no voice.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, she had no singing voice.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She was a good cook, she was, and baker.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And-- and my mother was very strict with me, while the Aunt Kathy was very giving.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So anytime my mother chased me out of the house and no food, so I-- I hid in the alleyway behind the house.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And Aunt Kathy brought some food so my mother couldn't see it and see if she fed me so I shouldn't go hungry.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "That was Aunt Kathy.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Describe your house.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Describe the house?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Well, we didn't have indoor-- what's the word?",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Indoor plumbing.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So we had to walk through a-- a-- a way between the house to take us to the out-- out-- outdoor house.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And that's what we did.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And then there was the store.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And there was a big room that they used-- the young men came to have a drink in the evening before they went to see their girlfriends.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "So it was like an inn.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And the store was open doing the day.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "In the evening, it was closed.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "But the inn was operating.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And then there was two bedrooms and a big kitchen.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And that's about it.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In Bratislava-- I'm not realizing Bratislava.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I went to synagogues.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I was in a choir, a religious choir.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember too much until I graduated somehow.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Bratislava was a big town, big city.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It was a capital.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "People-- there were about 200,000 maybe.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "It sure was very large, the Jewish community.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was German speaking, Slovakian speaking, Hungarian speaking, one third of each.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And the Jews were part of each section.",
      "word_count": 8
    }
  ],
