  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "If they wouldn't have mixed in, I could have saved-- we could have saved some time without being under the German occupation.",
      "word_count": 22
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "They-- right away the--",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They were helpers.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "The Lithuanians were very big helpers.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "We lost 90% of the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "The most people that lost-- that lost during the war were the Lithuanian Jews, because the Lithuanians were very big helpers.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "To help the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "To help the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "They rounded up the people.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "They helped.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "There was a Lithuanian-- like a-- Lithuanian soldiers, Lithuanian Army.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "They-- the intellectuals were rounded up.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "I remember again phoning my mother that my father was taken away.",
      "word_count": 12
    }
  ],
