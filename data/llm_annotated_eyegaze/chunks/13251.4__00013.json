{
  "stem": "13251.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "English was no-- I had no problem with the language.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "No, they were-- at work treated me great.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "It was a great environment.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "No problem at all.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And I only stayed in New York, which I didn't like.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "Even though I, I lived in London with all that congestion and everything, it was a totally different environment than New York.",
      "word_count": 22
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "New York to me is like a jungle.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "[LAUGHS] I mean, I always compared the subways, because, you know, I used to travel the subways in London a lot.",
      "word_count": 21
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "And you stand in the subways like sardines.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "You can't even move.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "Yet the English, they just read their paper calmly, quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "In New York, you can get killed.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "Everybody's pushing and shoving trying to get into the door when the, when the train opens up.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "You can get, you can get thrown in front of a train.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "And it's totally different there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And so I just stayed in New York long enough to pay my-- like I said, to give my aunt back the money she, she put out, which I appreciated.",
      "word_count": 30
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I always thanked her for it.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Well, I visited Cleveland a couple of times, and I liked it better than New York.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "So I decided even before that once I settled with my aunt, I'm going to move to Cleveland, which I did.",
      "word_count": 21
    }
  ],
