{
  "stem": "6989.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "For a short time, by the way--",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Because--",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Why it was a short time is this.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "After the liberation of our town, a landsman of ours-- in other words, somebody, a person from our town, wrote to this-- I think it was to the neighbor, I'm not even sure to whom.",
      "word_count": 35
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Not the Czech neighbor.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "There was-- you know, from the very beginning--",
      "word_count": 8
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "I think I mentioned to you, we had a neighbor next door, [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, she wrote to one of the people that survived.",
      "word_count": 10
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Is there anybody left from the family?",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "The Leviatin family, or who's left from Dubno?",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "And somebody wrote her back to Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "She was in Russia at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "That they think one of the-- the Leviatin children may be spared, alive with Lena.",
      "word_count": 15
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "So she came back to the town.",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "And she started looking for me.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "And how she found out that I was not in Dubno, but rather than that Chervon Armeisk.",
      "word_count": 17
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "I'll never know.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "But she came to our house.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 5,
      "text": "She kept asking and asking, and asking.",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 6,
      "text": "And when she came she said to me-- because my given name was Shifra.",
      "word_count": 14
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 7,
      "text": "She said Shifra.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 8,
      "text": "And I said, I'm not Shifra.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 9,
      "text": "I'm Marusia.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 10,
      "text": "And I ran away from her.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 11,
      "text": "And I went to school that day.",
      "word_count": 7
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 12,
      "text": "And when I came back, she was there.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 13,
      "text": "And she decided to take me back with her.",
      "word_count": 9
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "She was in-- it's called Pervouralsk.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "It's like the-- I think Siberia.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Russia.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "It's Russia.",
      "word_count": 2
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Deep Russia.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "So what happened--",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "She may have been like a distant, distant relative.",
      "word_count": 9
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "So what happened was, she wanted to take me back to her, to where she lived.",
      "word_count": 16
    }
  ],
