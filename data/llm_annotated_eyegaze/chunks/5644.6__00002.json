{
  "stem": "5644.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we built up this when the resistance fall when I did have to walk out of Warsaw, the 800,000 people.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Or, nearly 800,000 people, because they finished the resistance.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "The Germans told them to surrender.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And they did surrender.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I think Bor-Komorowski was the general that surrendered.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And I start to walk out of Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "We'd been staying next to the walking out people with the red and white band.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And we used to--",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Red and white, it's the Polish flag.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Like-- like a fighter.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Like one of the--",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "--resistance fighter, but Christian.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I used to say to the boys, drop the gun.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Because I did have to leave the gun further down for the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Guns, grenades-- I said, if I seen a good gun, a machine gun, I said, drop the gun here.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Leave it here.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "They left it with us, because what I thought is one important thing.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "If someone is staying there, maybe they're going to rise up again.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Because they haven't been informed what they got to do.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "The information was only one.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Leave it with the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But if a Pole is taking it, give it better to a Pole.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "That I haven't been advised even about it.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "But from themselves thinking that someone is standing there, give him the gun.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And we used to take the gun and brought down to the bunkers.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "We been very well-- we been very well--",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And when the--",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Ammunition-- everything.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "A lot.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We been very well armed.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Luba was with me.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And this, again, is a very important point.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We're going to the bunker.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "The resistance finished.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "The Poles going out of Warsaw. 305 people stayed in Warsaw, Jews, hidden.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "305 People hidden in the bunkers.",
      "word_count": 6
    }
  ],
