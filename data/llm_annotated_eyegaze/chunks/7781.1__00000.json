{
  "stem": "7781.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Are you taking-- can I turn the chair a little bit?",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "This way?",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "OK, any time.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that doesn't matter.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name is Daniel Geslewitz.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "D-A-N-I-E-L G-E-S-L-E-W-I-T-Z.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "That was Gedalia Geclewicz.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "G-E-D-A-L-I-A G-E-C-L-E-W-I-C-Z.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lodz, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "L-O-D-Z.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born on August the 14, 1924.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Now I'm 71, going to be 72.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Thanks.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I can tell you about family.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I was the youngest of seven children.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My father had his own business.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "He was in the cabinet-makers-- cabinet-making business.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "All my brothers worked for my father.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Was-- I was going to school, attending public school.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I had seven years of public school.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "That's all what was compulsory.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And after the seven years, you were out, and you-- that was the end of it.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "But I used to attend technical school, evening, because as a-- if you learned a trade, that the law required that you work so many hours, and then you-- after noon you have to attend technical school.",
      "word_count": 37
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And this was till the war broke out.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "There was no more-- no more education for Jewish kids, any more.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was 15 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, at that time, I was.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The war broke out, it was vacation time.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But, once this-- after vacation, they-- I went to school, and there was an assembly.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And the principal, with a friend of mine, made me get up and leave the-- leave the assembly, because he said there no more education for Jewish kids.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "As far as a Jewish home, we were strictly traditional religious.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We had a Jewish kashrut, was strictly kashrut.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We observed all the Jewish holidays, all the Jewish holidays.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yom Kippur.",
      "word_count": 2
    }
  ],
