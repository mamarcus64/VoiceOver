{
  "stem": "19895.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And when my bar mitzvah was, we had about six of us at the same day bar mitzvah.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I was one of them.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And as the usual routine goes that the portion of the Haftorah is to be chanted or, or read by the bar mitzvah boy, the bar mitzvah man.",
      "word_count": 28
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "At age 13, that's when your manhood starts.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "We had to share the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "We were six of us, so probably the one who was quite good in the reading of the Haftorah was given that portion.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And the rest of us read a portion from the Torah.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "But nevertheless, it was a nice event with six of us being there and our families and friends.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And after that, we had a-- not the, the big parties which are now done in the United States.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And we did the same for my daughters as being bat mitzvahed.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "But it was a much more modest celebration.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "Nevertheless, some family members came.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "And, and we received gifts like a young boy does it here, too.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "And we received the fountain pen.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And we received the candies.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "It was a very happy day.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "Later on, we can even see the invitation which my parents send out for the bar mitzvah of mine.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "Because somehow, it survived World War II.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "And if I, if I am correct, I think how it got back to my hand is that a relative of ours, of ours here in the United States handed it over to me after I came to the United States at our meeting here.",
      "word_count": 45
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I remember Gabor Alpar.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I remember Jan, Janos Neumann.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And that's about, I think-- the other four, or one, I was one of them.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "The other three, I can't recall right now.",
      "word_count": 8
    }
  ],
