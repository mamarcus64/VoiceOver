{
  "stem": "11672.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "But the SS, the Gestapo, you know-- and what they told the soldier, the soldier would do, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And other people, it's better [INAUDIBLE] they can get nothing-- kind of bread, and not milk, not-- it's the terrible.",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "People died in the street.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Right away.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "For very hard.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "You see, you have a lot-- in this neighborhood, where I live, is a lot of Jewish stores-- little stores, with bread, with herring.",
      "word_count": 24
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I remember a special store, with the grocery.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "The people have a little and sold to you, you know, what I have to-- in the reserve.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "No-- very hard to get.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "A lot of people go to the farms.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "From Lublin to the farms are not so far.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "People walked to the farms-- 10 kilometer, 15 kilometer-- bring something for the family.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "My family don't talk from this because she-- not-- not possible.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Impossible.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Impossible for him.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "My mother-- they can't go.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "She's a sick lady.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "She stay more on the bed like she walk.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No, the sister was living with my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "My one sister with the-- the sons in Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I have a lot of [INAUDIBLE] cousins.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "I have uncles.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "I have a-- aunts.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "No, you know, I'm [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Lublin, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Because when I take me in camp, and I escaped from there-- I escaped from there.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "It's impossible to escape.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Two German officers-- it's get cold in winter time.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "This is in November, in beginning of November, in 1940.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Comes in two officers, ask, who understand German?",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "In school, I take German three years.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And I speak German.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "Who know if you can to buy wool stocking?",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "I know, I know.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And take me out.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "And this camp is in the center of city from Lublin.",
      "word_count": 11
    }
  ],
