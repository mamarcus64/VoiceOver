{
  "stem": "2004.6",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I did work for-- I'm talking about in the early days-- for a very famous singer, Fran Warren.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I don't know if you've ever heard of her.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "She made-- this is before your days, but she made a record, of which is still being played now on the radio.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "She's still around.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "She plays nightclubs and so on.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "And I did work for political figures, you know, people in show business, people in, in the theater.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "I did work for the Imogene Coca in her day, you know, in her hey-day.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "But most of the time, I worked for people in the world of business, you know, people who, who can afford custom things.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And then I branched out to other things.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "I branched out into real estate.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "I bought some buildings, which I own now.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "And I got involved in the stock market, which I'm still pursuing.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So I have my-- I have my hobbies, which I use-- these are really not hobbies.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "These are really things which I do to supplement things.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "How about your family?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My family?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Well, you see, we were my oldest daughter Debbie-- our oldest daughter Debbie was born June 29, 1952.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "She's the first one.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Then our second--",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "About each kid--",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Well, Debbie, Debbie was cute as a button when she was born.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She was just unbelievably cute.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And of course, it's the first one that obviously is the cutest one.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They're all cute, but the first one is always the cutest one.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "At that time, we lived in Brooklyn.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We had an apartment in Brooklyn on Washington Avenue, which at that time was considered a good neighborhood.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Today, it's not so hot anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "But at that time, it was considered a nice neighborhood.",
      "word_count": 10
    }
  ],
