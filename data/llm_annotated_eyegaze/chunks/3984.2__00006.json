  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Even he make me trouble, I love him very much and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "But you know-- and oh, something else-- when they going-- when my children went to, you know, to the-- went to the school, and you know, they take-- they go to the trip, I went with them all the time.",
      "word_count": 40
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "No, the little one, the little one, there is a [INAUDIBLE] going to the camp, you know, and take them one a week to the beach, and sometimes they take to the movie, or something.",
      "word_count": 35
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I am so anxious.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I am-- I am not, I am not quiet.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I have, I have very bad feelings that-- [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Something, you know, can happen.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So every time-- the last time he went some-- a trip, I went with my husband until the bus is moving.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And in 5 o'clock, I was over there to see that he's coming to back.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I have from childhood a very bad feeling that I feel that I am, I am lonely.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "If we could go back to that period, now, when you were reunited with your mother and the rest of the children, where did the family go from that point?",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So when--",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "When we went to the, to the ghetto together?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We went to Hajdunanas in this day.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They make a few street.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I don't know, exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We was over there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It was very sticky, a lot of children.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "It was a lot of problem, crying.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "But you know, I was even-- it was very bad.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I was happy-- more like over there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Because I was over-- I feel that I am with, with, with my family, and with my mother.",
      "word_count": 18
    }
  ],
