{
  "stem": "11611.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 28.5,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "There was an economist in the US Treasury who had been active in pursuing the record of these banks during the war, fellow named [?",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "Forster ?] Adams who became convinced he didn't like these banks and was kind of zealous about it.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And he had whipped up a fair amount of material.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "I was the bottom man in a trial team that was projected to three people.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "The other two were Rawlings [?",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "Ragland, ?] who was a damn good lawyer from Washington and whose going to Nuremberg cost him literally millions of dollars.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "He was one of the original founders of Geico Insurance Company and he sold out all of his stock at the beginning of Geico when he went to Nuremberg.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "And the other fellow was a graduate of Columbia Law School who had a couple years of practice named Herb Goldenberg.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And I roomed with Goldenberg in an office.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "We worked together.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "Goldenberg, of course, was a much more knowledgeable and better lawyer than I was, but a very quiet fellow.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "And we were on very good terms.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And I liked Rawlings Ragland too, he was a very able lawyer, experienced too.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He had worked with-- primarily with-- what the hell's his name?",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember it, a fellow who did legal work in Puerto Rico, quite a well-known American lawyer.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Tugwell.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Rawlings had been lawyer assistant to Rex Tugwell, who was known in the New Deal days of the '30s.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, that was the team and we-- we started to investigate heavily.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We collected literally thousands of pages of Dresdner Bank records, Deutsche Bank records.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We stumbled upon a report prepared in the Dresdner Bank on so-called aryanization.",
      "word_count": 13
    }
  ],
