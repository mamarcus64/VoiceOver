{
  "stem": "26358.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And we're coming in the train, the guy say, pay for your mother 5,000.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "You paid for your sister, you need to pay for your mother.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I said to him, Dave, what happen now?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "He say, I can't tell you the whole story.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Well we came to Munich with the train.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "First we went through in Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We was there for four days.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And after Prague, we went off a train and came and going through the-- [PAUSES FOR 4 SECONDS] the custom.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And I have a few things from home and they took away.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I have a candelabra.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I have the cup from the wine.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I have a material I got, what I bought to make myself a couple dresses.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Well, I don't know how to sew, but I figure I'd come someplace-- somebody would do it for me.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And I came there, and they took away that.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You can't buy it.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We came in the train, and we went to Munich, of the American zone.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "When we passed that-- that station, and they say, you are in the American zone, not in Germany, I picked up, and I screamed.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Was a full wagon with people.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I said, thank God we left everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I'm free.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And we came to Munich.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "I am broke.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "I have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "Spent all money.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "Worked for a whole year, and spent stupid.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "Stupid, that was stupid, some things, but you can't help it.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "Come in, and the main office was-- and when I saw what happened to that state-- I never saw it-- was a disaster.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "Come up, and I see a friend-- Jacob, the guy what we was in hiding with, with his son.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I say, Jacob.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I'm glad you're here.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He say, why?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He hugged me-- kissed me.",
      "word_count": 5
    }
  ],
