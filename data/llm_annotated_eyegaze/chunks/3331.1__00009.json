{
  "stem": "3331.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And then I wanted to go to a gymnasium, which is high school, but it was impossible for me because--",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because the gymnasium, we had to go Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And, naturally, I wouldn't dare.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Or my father wouldn't let me or my sisters to go in a school where we had to attend Saturday and we had to write Saturday.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So we didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And I was the only one, when I finished seventh school, I came home and I cried the whole day.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "All my school friends, they were so happy and they compose songs and there were special songs.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They are so happy that their schools are finished.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I came home and I cried because I saw that this is the end of my secular education.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And I wanted to go higher, but I knew I couldn't do it.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "So I joined-- I enrolled in a vocational school.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "They had in our town, a vocational school, which I had to go in the evening.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So in the evening, the vocational school was for two years.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I picked out-- there was different subjects.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I picked out subjects-- bookkeeping and business courses.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And after two years, I finished the vocational school.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "So I asked the principal if he would allow me to go an other two years in the same classes, just to go to school.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So I went again to the same classes there the next year, I think, was there.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And then-- and then when I was 15 years, my father, he always dreamt that I would be a scholar like him.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "He always wanted the sons should be very religious, which he was not successful.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he sent me to his rabbi, to Tarnow.",
      "word_count": 9
    }
  ],
