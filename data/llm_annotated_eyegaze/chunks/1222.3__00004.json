{
  "stem": "1222.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "The international used to give us parcels, some of it.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So I used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "It was American soldiers.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I used to pick up for them cigarettes, buy it, and go between the restaurants, and sell the package of cigarette that was unlegal.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "So I used to go from one city to the other one selling the cigarettes.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "After that, I used to rent a bike.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "I learned how to ride a bike, and I used to go out and sell clothing house to house.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "After that, I saved a little bit money.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I moved into an Italian home that they treated me, looked like a child.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They had eight children.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't talk Italian.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "That's the place I learned how to talk Italian.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And that was a good life, you know, everything there.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And then, incidentally, I went in.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They made already a sanitoria for invalid people.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I got a note of Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And it was run from the United Nations again.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "One man wrote a letter to Winnipeg.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "I never knew where Winnipeg is.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "I never knew what Canada is.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "I knew one thing-- that my parents are poor, and they're getting parcels each Yom Tov, Pesach, or Yom Kippur, and I knew this America.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And I knew my mother used to say that she has three sisters in America.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "When they were-- when I said before they were orphans, the sisters went some to America and some, like I told before, the way my mother was a maid.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And then I wrote down the name.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "But I didn't know the second name, but I knew my mother's maiden name was Zilberstein.",
      "word_count": 16
    }
  ],
