  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They stayed there for awhile.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "His grandfather's name was Leibish Lipschitz, or Aryeh Leib Lipschitz.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "He was rabbi in a few towns, in [NON-ENGLISH] and Busk and [NON-ENGLISH] because he was a individual that could not bend to anything.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "He had his principles and if it's not so he didn't care what, where, when.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "If it's good for the family, oh-- his principles-- naturally principals in this case means the strict religious life.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "His wife's name?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "His wife's name was Hadassah.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And, and in the middle '20s around, he left to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "He wanted to settle in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And my grandmother was supposed to come, you know, send the tickets, supposed to come to Israel.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "He never could get the money together, and she was left there with her daughter that was never married because she was sick.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    }
  ],
