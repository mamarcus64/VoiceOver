  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "They were sent away to the-- they killed people what's find on air, pile of papers.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And they did kill them upstairs in the-- the-- the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Not in the ghetto, in-- they killed them in this upstairs in [NON-ENGLISH]",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They send [NON-ENGLISH], and they-- not [NON-ENGLISH] what-- higher.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They sent away a lot of people.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I never know Schindler.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] I know.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I met.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this was horror.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The mothers had to leave the children and go to work.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They killed the children.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They-- [SOBS] terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I was lucky I didn't have no children.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I was alone.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "We went with my sister [PAUSES FOR 6 SECONDS] into the barracks.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "You were happy this is over.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "They killing the ghettos.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "They close the-- in the ghettos.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "The mothers left [INAUDIBLE] woman.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Know was next to going.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "She was crying bitterly.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "She said she bathed the child and it was so beautiful.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "She left.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Your cousins kill my-- When I got-- went to Emalia, I took the girl with me.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I had a coat, and the girls went around me.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And Goeth was standing under the-- this-- under door and with two dogs.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The dogs were terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I went through.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "With the little girl, to the-- to the Emalia.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I came there and we were there a couple days in [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if you know the head of the--",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "OD, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "This is-- this is Emalia.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We come to the Emalia.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And the head, he-- he went.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "He came to us.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And he said, I have also a brother, a little boy.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And she's going to be safe kinderheim.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And they took her from there.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "She would be alive now.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "[SIGHS] So Chilowicz took her away.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And what happened to her?",
      "word_count": 5
    }
