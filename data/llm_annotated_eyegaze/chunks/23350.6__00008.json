{
  "stem": "23350.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But in the meantime, whilst I went upstairs, I quickly went and put on the kettle to make myself cup of tea.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I went upstairs, and I changed my shoes, put my slippers on, made myself comfortable.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And she was sitting and talking to him.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "After a while-- and I was wearing no lipstick.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And in those days, after the war-- and I didn't need it anyway.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I was a young girl.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Anyway.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Suddenly, she calls me down.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She says, Minia, come down a minute.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "What is it?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Minia, he didn't come to talk to anybody.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He only wanted to speak to me.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] This is what it was.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "So I sat down, look, I want to tell you something.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "So I said-- she said, did you put the kettle on?",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "You sit down.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I make the tea.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "She will make the tea now.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "So, all right.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "We were sitting down.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And I said, but I have to go out because I was made out arrangements with the other girls from which I came over with that day to meet up.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "We had a club in Primrose, you know, Primrose Club, which was in Hampstead.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And in the evening, we're all meeting up together.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "So what do I need-- so I, I, I said to him, we have got a meeting this evening, and we are going to Hampstead.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "So he says, but I live in Hampstead.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "He was living in Haverstock Hill, right near Primrose, walking distance.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "Oh, may I come as well to this house?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "I want to see what it-- what-- how they-- because he heard now that we are all from-- he wanted to come and look at this hostel.",
      "word_count": 27
    }
  ],
