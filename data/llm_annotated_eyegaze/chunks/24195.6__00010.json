{
  "stem": "24195.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "So I came over in August 5th, 19-- I landed in New York Harbor on August 5th, 1951.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I'm sorry, yeah, 1951.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And somebody from the joint distribution committee picked me up at the, at the pier.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I actually volunteered.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I was one of the last ones.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Because I volunteered, because I spoke English well enough that-- to translate for many of the-- German was a good language.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "But many of these people were speaking Polish, Lithuanian.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "But many of them could understand and communicate in German.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "So they used me for the medical officer for the Public Health Service officer, checking the medical records.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was right there.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, it was right on the pier.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but no-- yeah, no, no, I worked for the Joint Distribution Committee in, in Munich.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Munich, right.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And then my, then my immigration, you know, was-- came through, my, my visa and-- well, you don't-- you didn't need a visa.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You just needed your DP certificates and, and travel orders.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And then I came-- was sent to Williamsport, Pennsylvania.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "That was assigned, pre-assigned to me.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "By the Joint?",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, by the Joint.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They had to go.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I didn't even know where Williamsport-- when I got the information, the notice that I was sent there, I had to go on a map.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And you know, I didn't, I didn't really know that much.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I knew where New York, New Orleans and San Francisco were, but not Williamsport.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I found it was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "It's was a small-- it's a small city in Pennsylvania.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "It's actually the birthplace of the little league.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "It's that city's claim to fame.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And I had a, I had a great time there.",
      "word_count": 10
    }
  ],
