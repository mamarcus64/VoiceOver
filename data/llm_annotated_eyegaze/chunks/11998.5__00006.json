{
  "stem": "11998.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And when we got to Funfteichen, I became an electrician, and I worked in the-- wiring up the barracks that-- they were expanding the camp, so I was working inside the camp.",
      "word_count": 32
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And I worked there for about three or four months, till the job was finished.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And then I got a job in-- in part of the-- in the camp itself.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "But sooner or later, they-- they threw me out of the camp, and I had to go to work in the-- in the factory.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I went to work in the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I went to work as an electrician, which was a very good job, because I-- you know, it wasn't difficult work.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You're pulling wires, and working with your hands, and machining, you know, bending pipe, cutting pipe, threading it, stuff.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So this was-- was work, but it wasn't-- wasn't-- you know, nobody stood over with you with a, with a-- with a-- A gun?",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "A whip?",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "With a gun, or with a stick over your head, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We had our kapo.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And our boss was a civilian, who we worked for, and a civilian Nazi.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "German.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And it was a very good job.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "The only-- the only thing was that it was-- you know, it was dangerous work.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "We worked on live electricity.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And one day, I was sitting in the trench-- the wiring was in trenches-- and I was trying to file out a burr out of a box that was alive.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And the file touched the live terminal, and it just went-- welded right through.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And a big flash hit my eye, and it blinded me.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And I thought I lost the-- the sight of the eye, but it was temporary.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "It gradually came.",
      "word_count": 3
    }
  ],
