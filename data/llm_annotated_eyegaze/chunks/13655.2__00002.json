{
  "stem": "13655.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They [? watched ?] the law to keep for the Germans, everything.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "It was organized from [? before. ?] The local-- [PAUSES FOR 4 SECONDS] --municipal, and this was existing, but they worked for the Germans.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "At first ?] by a lot of them, but they were [? sitting ?] about 20 Gestapos, I would say so.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "About 20, maybe.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Till the last minute, when they disappeared.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Was changing for ups and downs, came in new ones.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They changed the people there, the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Miserable.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was no life.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We just existed.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was no life.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "'Till the end. 'Till the end in 1942, where we went out.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto--",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "They pushed us in all together in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1941.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It was ups and downs with the ghettos.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They closed off the ghetto, and they opened up the ghetto, and they kept us together.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And the worst part of it started when they went [? on the ?] Russians, in June 22, 1941.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In our town, in [?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Konstantynow. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "With a section.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "In this, we got to stay there.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You cannot go in another section.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "It was a fence around.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, [INAUDIBLE] from the wire.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Already was about 1,500 less, because a lot of them died already.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "A lot of them had been out to Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Maybe about 1,200 people.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The living condition was terrible-- four, five people in one room, six people.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Three families in a one bedroom, and a living room and a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Three families.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Approximately what?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1940 to '42.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My parents and my whole family.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Of course, I didn't go there.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have any-- it was no store anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Of [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It's hard to explain, with what we was living.",
      "word_count": 9
    }
  ],
