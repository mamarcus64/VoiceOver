{
  "stem": "2350.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "I didn't feel that I'm liberated.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "We were scared for our lives because of the Russians.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "The Russians raped the girls.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "We were the luckiest five, that we were not touched.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "I was hiding in the cars on the bottom, covered with rags.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "They shouldn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "Everybody-- my girlfriend says, you put your head down if the Russians are coming.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So we were lucky that we went through till we got to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And in this house, I left my girlfriends-- the one that lives in Seattle and the one in Israel-- and I took off with another one to go to my hometown.",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And we came to Zawviercie the next day to look who was here.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I didn't find my brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I found friends-- a few friends, a few good friends, somebody from the family.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I stayed in Zawviercie a few months with friends.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "You know, they had already taken over the house-- a Jewish house that it was once.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And we stayed there, and we started to live, to see who was alive.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And being in the house, a man knocks on the door.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And I opened the door, and he looks, and he says, I know you.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I says, what is he, crazy or something?",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I saw your picture.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was with your brothers in camp, and they are in Bergen-Belsen.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they are alive.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He said that I'm not coming back without you, because I told them if I find anybody, I'll bring you back.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I thought in  the beginning that he is nuts.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "But he told me, you know, what picture, because I did send my brothers a picture.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And we stayed in Poland maybe two months, for May, June, July.",
      "word_count": 12
    }
  ],
