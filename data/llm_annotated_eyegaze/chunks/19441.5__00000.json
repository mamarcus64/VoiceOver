  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The experiment.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "First of all, they did sterilization.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And then they made different operation on woman, like taking out the woman business that just from sadistic way.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I found-- I remember the Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Dering.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "He was a Polish doctor, but a very sadistic man.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Imagine making those unnecessary operations for young women without anesthetic, without any medication.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "The girls cried and screamed, and he just did it.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "There was a doctor, Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "Samuel, which was a very famous doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "He said that the sterilization, what Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Clauberg is doing, they are not so dangerous, because Dr.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Clauberg stealed his ideas, because he did work on this idea, and he didn't finish it.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "So even he, he sterilize the women, but they still will be able to have children.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Because as he didn't finish that, so that is not so dangerous.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "More dangerous was the other operations what, what they did.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Samuel--",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Was a Jewish doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "They came to the clinic.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Dering too, from the men's camp.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Samuel, he did reconstructing or healing if something was wrong.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "He didn't want to do unnecessary like Dering did.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "But he said that if I one day don't come back, that means they found out that I didn't do the operation what they wanted.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "One day he didn't came back.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "So we knew that either-- that Dering put him in or the SS man put him in.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "They did such terrible operation that there was a French woman--",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "French woman.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Adelaide Hautval was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "From what?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "There was hundreds of women.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The, the women the experiment done was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "All of them.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They was Belgish.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "A lot of them they been Greek and Belgish.",
      "word_count": 9
    }
