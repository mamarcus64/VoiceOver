{
  "stem": "9486.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "Friday he used to come to us.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "The most he used to come to us, my mother was with us.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Each day was not long enough to be with them, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My mother told me how she survived.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I told her how I survived.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "My brother told how he survived.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And we always use to talked every Friday, you know, and always crying.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And it was not tissues like that.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Instead, have the big-- that was not enough.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Every-- every time I used to cry.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And we couldn't believe how we could survive something like that.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Lots of people didn't want to believe.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "How can of person, a young child survive something like that?",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Lots of people, they say they can't believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Just nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "It make me cold, like, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Most, the survivors, they believed.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Only people, the Israeli people didn't want-- could not believe how can a child survive.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And a grownup person survivor is OK.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "A grownup can run.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "How could you run?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Where you know where to run?",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They ask you, question things like that.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "Well, you start, and you think yourself, how can I really run?",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "How could I survive?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "Sometimes you thought it was a dream.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "I just dreamed everything up.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] I was jealous.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "And people when they were in camps, even they didn't get too much food.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "They got once a day sliced bread, or they got soup from potatoes.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "What do-- you needed to find a potato, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "But that-- they would water for them.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They gave once a day.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have that.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Well, my-- my husband, I fall in love with him.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "He didn't have nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "He didn't have-- he was a single guy.",
      "word_count": 8
    }
  ],
