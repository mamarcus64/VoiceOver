{
  "stem": "12150.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I wound up in a-- in a ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And the survival rate of the people that worked in the forced labor camps was 50%.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "The survival rate of the Holocaust is about 8% or 10%, at most.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "OK, Harry, can I stop you for a minute?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Let's go back a little bit.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "How was it that you decided to go to this-- to this family?",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "How-- your father found out for you?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well the-- this family had a-- my next door neighbor, they had a store next door to us, this family, in my town.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So they contacted their-- their relatives.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And-- and I think this woman's husband was also in the forced labor camps.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So an extra few dollars helped.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "So I paid for my keep.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And in [?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Ungvar-- ?] OK, go ahead.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Any more questions?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "In [?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Ungvar-- ?] the name of the town is Ungvar, the same size as Munkats-- not so Hasidic.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I believe the proportion of Jews and non-Jews was about the same.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And I-- I did the work, in a factory, part time, just to ward off the suspicion, I figured.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "In 19-- no, I was-- no, more.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I was born in '22.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I was 20.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was exactly 20.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I stayed there two years, until-- and-- I-- I managed.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I managed.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I had enough food.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "In that family?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Very nice.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They treated me nice.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And they needed the money.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And we had enough food.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And once in a great while, I went home-- for a day, only.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "By bus.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I had papers.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I had really papers.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I was only afraid in Munkats somebody would notice me.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Because there were people reporting on each other, for money.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "They got a few dollars from the government.",
      "word_count": 8
    }
  ],
