  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "And we stay overnight in New York, then we came to Chicago by train to our brother-- to my husband's brother and sister-in-law.",
      "word_count": 23
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "And we stayed there, then we couldn't find a room even that time.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "It was hard to find an apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "1946.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "So we visit our-- we have relatives in-- in-- [PAUSES FOR 4 SECONDS] in Chicago?",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Milwaukee.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "So we visit Milwaukee, the relatives, and there we start looking for apartment in Milwaukee.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Jack was the time when we traveled, six months old.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "In Milwaukee, he started-- he-- he worked for a-- he was a cutter for glove, by hand.",
      "word_count": 17
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Very hard work.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Then he quit this job, was too hard.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "He used to come with blisters on his hand.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "And then-- then he worked for a shoe company.",
      "word_count": 9
    }
  ],
