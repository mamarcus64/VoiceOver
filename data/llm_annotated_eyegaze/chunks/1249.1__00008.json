{
  "stem": "1249.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And they said, what happened to you?",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I was so white.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And I was scared, and shaky.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And, and my mother said, what happened?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And what my mother went through, I cannot tell you, because she was a wonderful mother.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And she was always worried about her children-- not about her life, but her children.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I have a big sister.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember exactly what happened to them.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "But I know what happened to me.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "But I know what happened with the others.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "So I know exactly what happened to them.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't talk too much about it.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And, and from there, they took us to, to the brick factory.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I thought it's in Miskolc.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But my brother-in-law said was not in Miskolc, close to Miskolc.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I cannot remember.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And since I was in the concentration camp, I never went back to Hungary.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I don't want to see them.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I don't want to see the country, because it's not there.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "My mother is not there.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "[SOBS]",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "They put us in-- on the floor.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And we were ready to-- they said just we are going to be there a couple days.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And they are going to transfer us somewhere else.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And men, and women, and boys, and girls, they were all together in the floor, like very close to-- you know.",
      "word_count": 21
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And, again, my mother was so worried about us.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "It's shameful or embarrassed, you know, my girls, men over there.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And, and--",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "But the most worry about her, what's going to happen with her daughters?",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "This was the most worry.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And we are always hear this machine gun, and, and things like that.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And the day we left, we were there, a man was walking around, looking around.",
      "word_count": 15
    }
  ],
