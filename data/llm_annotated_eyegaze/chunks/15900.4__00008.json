{
  "stem": "15900.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And she was in love like crazy, and she showed me her book.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She lived in Philadelphia.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "She had a home.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "She wants to bring my brother from Israel, and give him an apartment and this.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And she was older than me.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And I-- I would not-- no way I would marry her.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "I want to have children, without children, I don't want it.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "She showed me the book, and the house and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I quit.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And I was afraid I [? sleep ?] there, but then I have clothes there.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I was afraid some Americans are going to give me problems.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "I took the policeman with me.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "He put on civilian clothes, and we went there.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And she didn't say nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "I took my clothes out.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "She wind up in hospital anyway.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "But anyway, I met my wife.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "I came there.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Miriam.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I come there to visit, happy New Year's.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And she gives me the telephone.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Some girl wants to talk to you.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I started to talk to her.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And she said, I just came back from Florida.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I was in Florida.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "She said, I go to Florida all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Where we were staying?",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And this.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And I made a date with her the following week to go.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "And I used to work seven days.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "I said, I'm gonna see you.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "My brother was already in-- in-- in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "I went to see him, and I went to see.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "He lived in New York with his wife and children, in the Bronx.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And I said to him, I'm coming.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "I take a bus after work on a Friday night.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "I took the bus.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "It was on Thanksgiving.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "It was a snowstorm you'll never believe.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "I got stuck.",
      "word_count": 3
    }
  ],
