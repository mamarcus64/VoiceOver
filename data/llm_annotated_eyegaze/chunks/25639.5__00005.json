  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 30,
      "text": "Late at night, a truck came to take us all away.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 3 SECONDS] One SS led us to the truck, and another, this Hungarian guard, came to close the canvas in the back.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 32,
      "text": "And just as he was about to finish closing it, he sort of looked in, and there I was.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was among the last ones to enter the truck, so I was pretty much in-- in front now.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He said to me in Hungarian, [? 'Te ?] is?' Meaning, 'You, too?' And I just nodded.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "This was the Hungarian guard who used to guard us at our Canada work detail, and into whose pocket my sister put a few things.",
      "word_count": 25
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] This was the very guard who was there, closing the canvas in the back.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "After he saw me there, he told all of us, 'You all know that we are going to the gas chamber.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Those of you who would want to could jump off.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But if you are found, you must not give me away, for I may be able to save other lives yet.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "But if you do give me away, both you and I will be caught, killed.' And with that, he closed the canvas drapes, and he went up front, and he slowly drove off.",
      "word_count": 33
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Now, the gas chambers were a good distance away.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It took us about a solid hour to march there each morning and back to our barracks at night.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I had ample time to-- to know what the immediate area looks like.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I knew that I am going to jump off that truck.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "I thought to myself, if I stayed on this truck, I will die.",
      "word_count": 13
    }
  ],
