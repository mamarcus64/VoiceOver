{
  "stem": "19242.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And my father's rooms-- he says, let's take everything in there.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "He wasn't ready for the second time.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And the Shabbos, you know, when Shabbos was, the store was closed.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "From Friday-- Friday till that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And the whole town closed down.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "All the Jewish people.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "You could-- you're not supposed to sell on Sunday, but some customer, they come to the house.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And I remember I used to stay outside, and when the policeman was not there, we'd let him in.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And then later, we'd let him out.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Otherwise, there was a fine for opening.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "No business could be open on Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I had a radio.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I told you that-- what was that?",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Telefunken?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Telefunken.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And I remember the news.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Everybody-- some of the neighbors were staying in the window and listening to that.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Because not everybody had a radio.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Next door was some business.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "What was it?",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "It was a bank.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, was a bank there.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And they had a telephone.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "Nobody had telephones.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My favorite holiday-- Pesach.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they used to make all kinds of [NON-ENGLISH] and all kind of-- [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And I think it used to take like six, no, 46 [INAUDIBLE] and Purim and Pesach to get everything that they would take and paint everything.",
      "word_count": 26
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "This was a big-- a big holiday.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I helped to take down the dishes.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "All the dishes were in the attic.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And you had to put a-- a ladder and crawl up.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And like three, four people pass on all the dishes.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And then after it's over, you got to put them back up.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Every-- every year.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I know they tell me to be careful.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "These dishes are 100 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Don't drop it.",
      "word_count": 3
    }
  ],
