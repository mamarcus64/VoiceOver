{
  "stem": "18061.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 470.1,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And police and Gestapo and all kind from them surrounded the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And they called the lowest streets, one, two, out from the houses.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And I was between that too.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "They took us out at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "Me, at that time was already my wife, and I had a small baby from four weeks.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "My baby's name was after mine father, Will.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And they took out 6-- over 6000 Jewish people, man, woman, young, old.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And we went to the railroad station.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "It happened that coming to the railroad station, all the train cars, they're full.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't push in anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "And they order us to go back to our home.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "The 6,000 they left, you went home.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "There was a hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No, I just mentioned before even in a-- in an emergency, nobody could go out from the house.",
      "word_count": 18
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "My wife, she was at that-- she was pregnant.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "She-- she's supposed to give birth, but she couldn't go out to the hospital until 7 o'clock in the morning.",
      "word_count": 20
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And she was suffering the whole night until after 7:00.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "I was allowed to go out and to take her to the hospital.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And that--",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The hospital was inside the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Inside, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "It was a small-- it wasn't the big Jewish hospital what we had in-- in our-- in our town.",
      "word_count": 19
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And over there, she had the baby.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "She had a big boy, very big baby for that, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "For people they had nothing to eat, it was at that time big baby, about seven pound.",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Hm, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, were circumcision to the-- to the eight days, the way he was supposed to, yes.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We did it.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "It was done, also, without the knowledge of the German authority.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were sent back from the railroad station.",
      "word_count": 9
    }
  ],
