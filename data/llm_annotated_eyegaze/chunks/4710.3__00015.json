  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Then-- then they said, since people started struggling behind.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And then they said, people who cannot walk any further should stand-- should step out of the line, should stand aside.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And then I realized that this is end now.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "This is end is coming.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "There is-- but I couldn't walk any further.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "My-- my-- my body has really given up.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "I-- I just-- I just haven't had the energy.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "My feet were swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "I've discarded the blanket that they had given us in the-- in the beginning of the march.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "I just walked as a robot.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "But just-- I found myself that I cannot walk any longer.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I stepped aside, and I was prepared for the-- for the worst.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "That I realized that-- that I'm not going to-- to leave here.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But, fortunately, this is not what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We were taken into another camp.",
      "word_count": 6
    }
  ],
