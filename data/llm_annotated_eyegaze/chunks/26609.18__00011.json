  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "One not aware of the other one, that she's Mehr and I'm Mehr, but her name was different, we both bore, bore two children, two little girls.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 36,
      "text": "She had a girl and I had a girl, and both Mehr.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 37,
      "text": "Then the war came, and we'd never knew each other, strangers.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 38,
      "text": "It's a lot in Jewish, you know, that among Jewish people, that we have the same name.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 39,
      "text": "They are not relative, not related at all.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 40,
      "text": "After the war came, he was sent to Russia and so was my husband, but my husband, they took him not far, and straightaway, the Germans got them over and took him away.",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 41,
      "text": "And he was deep into Russia and came back from Russia after the war.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 42,
      "text": "Many came back from Russia-- men.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 43,
      "text": "His wife and child were killed, both, by the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 44,
      "text": "While he was away, they were killed.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 45,
      "text": "I survived in Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 46,
      "text": "My story, I told how I survived, but his wife what got killed, both, and the child.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 47,
      "text": "My child survived-- I told you the story where she survived in Poland because of that Polish woman, and later, Jews helped her.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 48,
      "text": "When I-- he was back, searching for his wife and never found her.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 49,
      "text": "He was a very simple man, and he couldn't believe it, that they killed his wife and his daughter.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 50,
      "text": "When it was known there through the Jewish committee-- and it was quickly set up, a Jewish committee in Poland after the war-- when that woman, whom I have seen, she said, your daughter's alive and so, and so, through the committee, he came back, went to the committee, and said I had a wife and a child here, born so-and-so, but not the first name.",
      "word_count": 66
    }
  ],
