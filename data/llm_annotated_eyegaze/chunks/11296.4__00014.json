  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And this was, you know, we brought up the children there.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "They went to school there.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "They went to-- to Hebrew schools.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Even there was a-- a very little village.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "You still, you know, we send them, you know, to the city.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "They got their education.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "They got their education in Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "They got their education in the college.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "They went to college.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "One went to Brandeis and one went to [?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "Kautz ?] University.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "And they-- well, they, you know, after the schools they went to New York, and they found themselves jobs.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "Now they're residing in-- one is in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "One is in Long Island, in Staten Island.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "And one is in-- in New Jersey, Millerstown, New Jersey.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "They're married.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "They're happy.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "They-- they have-- they have-- they-- they have sons, one son.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "And the-- the grandchildren's name, one is Zachary and the other is Daniel.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "And they're very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "The children are happy, and the mother is happy.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "And that's my story.",
      "word_count": 4
    }
  ],
