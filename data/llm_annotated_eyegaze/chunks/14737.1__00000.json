  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "At home, they called me [?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Zoli ?] Schwimmer.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Here on in America, from [?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Zoli ?] became Sydney.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Dolha, a small little town in the Carpathian Mountains.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It was, they call it-- it's a crossroad town.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Because from that little small town, you can go different directions.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "You can go one direction to Beregsaz, which a larger town.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "You can go to Khust.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "You can go to Munkacs, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Or you can go to Svalyava.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "That's why from other smaller, rural areas used to come to Dolha.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And from there, they go.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I'm sure you'll find it on a map.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I'm going to talk a lot about Dolha, because there where I was born, and there I grew up.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And it was my home.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Now, when I was born, it was Austria-Hungary.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I was born in 1915, December the 14.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "So you can figure out now my age already.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I already, I already--",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So next--",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My name is Sydney Schwimmer.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Spell it?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "S-C-H-W-I-M-M-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Actually, they called me at home [?",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Zoli ?] Schwimmer.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "When I was born, it was Austria Hungry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And in those days, they give Hungarian names.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "My Hebrew name is Zalman Schwimmer.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But now in America, we use it Sydney Schwimmer.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was born December 14, 1915.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Now we can figure out my age.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I was in December 80 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Dolha.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "This was a small town in the Carpathian Mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It belonged, once upon a time when I was born, to Austria-Hungary.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Later, from 1918 till 1939, it was Czechoslovakia, next as, as [?",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Carpatho-Russia, ?] Russia.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "From 1939 till 1945, it was Hungary, next to Hungary.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Later on, it the Soviet-occupied, Soviet territories.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And now it's in Ukraine, Dolha now.",
      "word_count": 7
    }
  ],
