{
  "stem": "6878.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We then took stock of the businesses, and one big storeroom, I have not declared.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I took a chance not to declare one storeroom of goods, and my [INAUDIBLE] boss used to come to the certain times we used to arrange, from me, and I used to give him goods from there, to help him out to make a living.",
      "word_count": 45
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he used to sell to the goods to us under a false name, and we used to pay him back.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Because goods, goods started to be very scarce for when Russia moved in, very, very scarce.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Everything was sold out to the shops in no time.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And from Russia, we didn't get any goods at all.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I was then living with a friend of mine, which we were friends from the army.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We're living together.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "His name was Alter Eisen.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And he was working for a manufacturing business.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And we were quite good friends, and we lived together in a, in a quite in a nice room, until the war broke out in 1941, the 22nd of June.",
      "word_count": 30
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "That morning, me and my friend, we went fishing.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I had a motorbike.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So we went fishing together, and we saw a lot of planes flying around.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "The fishing was about 25 kilometers away from Kovna.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And we didn't recognize the planes.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "That's not Russian planes, I said to my mate.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Look at all these Russians.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "They're mad today.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Look at the planes what that's running around.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And they were German planes.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Because, 3 o'clock in the morning, Germany attacked Lithuania, Estonia, Latvia, these three little countries.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And the fishing was bad.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "They didn't bite, the fish, so I said to my mate, let's go home.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "The planes are flying around, I suppose they frightened the fish away.",
      "word_count": 12
    }
  ],
