{
  "stem": "58.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Some of them were involved in Jewish life-- committees for-- [PAUSES FOR 3 SECONDS] they had a committee for burial, they had a committee to help poor people.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And this was-- people were, was, were occupied in the businesses.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "A lot of people had the stores, liquor stores.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "There was one big one because you had to have permission from the government.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And there were grocery stores, restaurants.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Then there was also a market day, was Thursday, that people-- the farmers used to bring the products to sell.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And people used to put up stands to sell suits, shoes, all necessities for people's everyday life.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And this was the city of Grojec.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We were-- kept a kosher house, my mother did.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We were not Hasidic.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] My father attended shul every Saturday-- Friday night, Saturday, holidays-- but not every day.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We had no chance, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "If you prayed, you prayed at home.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Because we were preoccupied making a living.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Most of the religious people had businesses that they kept on Saturdays closed, so they were able to observe holidays more than-- although if we had to go to Warsaw with the horses and wagon to deliver fruit, we didn't drive on Saturday.",
      "word_count": 43
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "We didn't ride on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "We send somebody non-Jewish to take it, the load, to Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And this, this was the life, this-- as I, as I remember it.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Actually, we had no quarrels like, as I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We were-- we were a tight family.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We had to be tight, we only lived in a two bed-- two small bedrooms and a kitchen.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "There were no living rooms or dens or-- this, only a millionaire could afford a house like-- an apartment like this.",
      "word_count": 21
    }
  ],
