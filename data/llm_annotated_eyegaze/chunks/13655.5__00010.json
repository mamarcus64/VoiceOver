{
  "stem": "13655.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.0,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And he escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And these Polish people killed him.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We was divided.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We were separate-- five in one place, five in the other place, because we didn't want to put in the [? cheese ?] in one cake.",
      "word_count": 26
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, was another guy.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "He was trying to help out.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "What busy?",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "We was laying like dead people, and that's it.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Inside it was looking-- a very small place for six people.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And the mattress was from branches from the birch leaves.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And if you have to go, for example, to make a pee pee, you had to wake up the other one.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "We was-- [CLAPS].",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "It was a-- [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Then we was-- we came to our city, Konstantynow.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "After the war.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "The Russian liberates us, the Russians, in July the 30th.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I was [INAUDIBLE] for a couple days by a Polish family.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "But the other ones in--",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "We know the Germans are going to break their necks.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "They're going to lose.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "But we-- but we are going to survive.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "This what was our talking.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We had connections with the news, from the radio, from the Polish peoples, because I picked up [? one ?] of [? five ?] from that, when I went there.",
      "word_count": 30
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was in that time in a Polish family, also in a bunker.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "But when I heard, I looked out a little hole.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "I saw the Russian people.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And the housewife, the Polish, she told us already.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "They're coming in.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "They're already not far away.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "When the Russians come?",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "We left the woods, the people.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "We went into the city.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "It was very, very hard to step into that town-- very hard.",
      "word_count": 12
    }
  ],
