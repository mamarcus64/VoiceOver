  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "The third time, he says, Rose, there's a max of 60 girls they sending to Markstadt.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I was glad to see that.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "So when I-- for the first time, I was a first child ever came to a father, to camp, concentration camp.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "When I came, when Daddy came from work, from [?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Bausteller ?], so he said, [PAUSES FOR 3 SECONDS] my child, you fell here.",
