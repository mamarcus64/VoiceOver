{
  "stem": "11611.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "German was their first language, but they had lived in the States or England long enough so that they were perfectly fluent in English.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, there was-- there was very little quibbling about the interpretations.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The German defense counsel had-- had their own interpreters listening in.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "There was more dispute in the original trial.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He was convicted basically on these so-called spoliation or plunder charges, and as an accessory before or after murder.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "That was what he was convicted for.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "The financing concentration camp charges failed.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "The courts didn't take them seriously.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "What was his sentence?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He got an eight-year sentence with time off for time spent in jail during the course of the proceedings, which was roughly three and a half, four years.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "John J.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "McCloy, that distinguished, High Commissioner for Germany, appointed, I guess, by the Truman administration, commuted all the sentences, effectively.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Including Rasch?",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Why not?",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I mean, let's not be nasty to Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No, I never had that privilege.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Two things-- American policy, which was to conciliate the Germans and oppose the Russians, and second, the prospect on behalf of his New York law firm getting some German business.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I won't name it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "What",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "All commuted.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, all my cases were convictions.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You were never in doubt of that, were you?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "There was never any-- look, in the Nuremberg Trials, if you were responsible for a half million murders or more, let's say the overall commandant for all the concentration camps-- Oswald Pohl, you would get a death sentence.",
      "word_count": 38
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "If you were responsible for 100,000 up to a half million, it was maybe a 20-year sentence.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "You got below 100,000, that was negligible.",
      "word_count": 7
    }
  ],
