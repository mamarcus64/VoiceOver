  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And do you know my mother and my brother, how they are?",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I said, oh, they are OK.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I saw them before I left.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I heard that the Russian very peacefully to took over.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So you can be sure that they are OK.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And later-- never this man wanted to-- to talk to me.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And I was, so-- inside, was so grateful to him.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I thought, this-- this man saw on me that I am not really Gyigor, Irene.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And he must be a-- a better human being.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "He let me go.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "But it was not the case.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Later, I will tell about.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So-- and that day, when they took away my papers, I was very desperate.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see any-- any way how I can get out of that.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "So I decided, since I don't want to discuss about that, I don't want to talk to-- well, he was a very nice woman, the nurse, we got-- as a name-- teacher, you know, I was in the same level, because we got friends-- friends, as far as-- [LAUGHS] you know?",
      "word_count": 51
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "So I decided that I go down to town.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I go to the movie.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So I had to go through-- there was a part though the forest down to the-- to Budakeszi, to the movie.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "I said-- I went.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I-- so I go in the part-- nobody goes there in the dark.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And then I feel safe.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So I went down.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And in the movie, they were full with German soldiers.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They had there a, you know, they were fighting.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And they had there somewhere the-- the poor or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So I went to the movie.",
      "word_count": 6
    }
  ],
