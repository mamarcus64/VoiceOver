  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "But there were other girls, too, so there must have been a few other enlightened parents in the world.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And I also went to a Hebrew school where I learned modern Hebrew.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And when I was 12 years old, you know, when Hitler came, I spoke beautiful Hebrew.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And when I went to Israel for the first time in 1970, I could always read, of course.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "I knew all the nouns, but I had forgotten all the connecting words-- by, to, from, with, at.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So I was sitting in the taxi going from the airport to Tel Aviv.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And I couldn't sit still, because it had been so long, I don't go-- I don't pray, and I don't go to synagogue.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I had no had no connection with religion.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We're just going to have to pause for a second to change the tape.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
