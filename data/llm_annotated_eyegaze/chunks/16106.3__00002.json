  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And we were lots of girls, young girls, together.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "There was [?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Asa ?] and there was the principal, her father.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And there were lots of-- in between work, we used to sit there and gab and--",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Gossip.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Funny things.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Just, just funny stuff.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "The, the stories what it-- it had a very, there was something evil was going on.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I mean, there was this one guy-- his name was Max Gore-- among the old people.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "He was a drunkard.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "He smelled.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He was ugly.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "He, he was like a portrait by Picasso.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "One eye came out here, the other came out-- no, seriously!",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "They stank for wide heaven.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And he took advantage of the situation and bedded one of the most beautiful girls of us.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Oke ?] was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And she was a widow by then.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "By then she was a widow already.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "Her mother-in-law was there with her.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "And she-- I, I, I, I not quite get it.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "I mean, that was her passport to, to life, that [?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "Oke. ?] And she did not discourage it at all.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "And he used to torment her.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "He used to have her wear-- schlep the most heaviest bags of, of, of, of shoes and hit her on the behind.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "She was a glorious, gorgeous looking, tall, beautiful girl, [?",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "Oke. ?] That had a bad [? thing. ?] That, that-- it was very unpleasant.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "And I mean, Ribbsdor, Dietmar, and Hanke couldn't have been nicer.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 25,
      "text": "They treated us with respect and consideration.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "They ran the, the depot.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Paul von Ribbsdor was the chef.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And after work, we had to march home and sing on the road.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We had to sing something, which was a march.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I mean, we sang.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We sing [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "There were wonderful girls among them.",
      "word_count": 6
    }
  ],
