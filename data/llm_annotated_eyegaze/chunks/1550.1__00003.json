{
  "stem": "1550.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "My parents didn't like the Jews who came from, from Galicia because these are the people who were-- who were some of them, when they arrived, they had those beards.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And even the Jewish people who were already completely assimilated, they thought that there are these new people coming in and they will bring the anti-Semitism because they look different.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "They speak Yiddish.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And they're going around with those beards and so forth.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "It's not good.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "You see what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "There was a lot of-- even my parents-- my parents never did like the people from [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They never did like those people from Eastern Europe, Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, drastic.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It was like day and night.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There is one day in which I will never forget.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "The Nazis arrived on March the 11, 1938 when, when the Austrian government kind of caved in and the German army moved in and occupied Austria.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "But there was so much resentment against Jewish people in Vienna that there were kind of pogroms on the street, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "People had to scrub the sidewalk and terrible things.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Jews were beaten up and their furniture thrown out the window.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Terrible things were going on.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I can't-- nothing happened to us, I must tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Nothing ever happened to me personally except that one time I was cornered on the street by a few people and they tried to beat me up.",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But really nothing happened to me.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was accosted a few-- a few times on the street.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And told pig Jew, get out of here and stuff like that.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "But let me tell you what happened to my father's business.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "My father had at that time a business selling fodder for animals like chickens and horses and stuff.",
      "word_count": 18
    }
  ],
