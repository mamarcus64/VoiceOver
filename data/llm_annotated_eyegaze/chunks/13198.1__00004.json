{
  "stem": "13198.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was just an extension of our house, with music in our house.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "There was always music.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And musicians came.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "My mother-- Sundays, there was a big lunch, and lots of musical friends came.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "The conversation was always about music, and composers, and composing, and things of all-- we were most unmusical children, which was a great disappointment to my parents.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "All of us, no good at all.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "I used to hate practicing and hate playing, learning the piano.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "It was really rather sad for them.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, much later, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was quite old, really.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I was about-- I think I'd already left school-- about 17. 16, 17.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Yes, I was 17.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, then my mother thought I was too young to sort of have a job.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "So she-- to finish my education, they sent me to a Dutch finishing school, where it was a-- you learned to run a household and learned how to cook and to do all those things that when you were married, that were useful to you.",
      "word_count": 45
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It was a sort of pre-marriage course, but without the husband, so to speak.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They were all girls of my age there.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I rather enjoyed it.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "She bought a house in [DUTCH] and-- of course, she never forgave my father.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he used come over several times a year to see us all.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But it was always a terrible strain.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "We always had to be on great, best behavior.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And all the young men were banished from the house.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Nobody was allowed to visit, because we had a very bohemian-- the front door was never locked.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "It was always wide open, and the boys used to come in and out, chat with my mom and with us.",
      "word_count": 21
    }
  ],
