  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "And one of the pictures I have here, with the three children, is made in this place.",
      "word_count": 17
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "Then we had vacations together with parents.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "We went somewhere, to a village or farm, to enjoy the fresh air.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "But we didn't have any long trip somewhere.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "Or I went to Lodz, to my grandparents, to spend with them, some-- a week or so.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Well, you have to divide the population, the religious and the not so religious.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "You mean Jewish population?",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Well, the Orthodox, there was many synagogues in [INAUDIBLE], you know what I mean.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Holidays, everybody was in the shul, my father, my mother, sister, and everybody.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And we stayed as-- as-- as long as-- as long as the service was going on.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Then we went home.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And we had the usual meals, if this is Hanukkah and Purim, or Seder Pesach, of course.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "This is not so religious.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "But still, we observed all the-- [PAUSES FOR 4 SECONDS] --the religious-- [PAUSES FOR 3 SECONDS]",
      "word_count": 16
    }
  ],
