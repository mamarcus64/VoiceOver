  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "But you are you.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE], I says, this is [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "She must fall down and fainted.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "Two minutes later, her husband picks her up the phone.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "Who are you?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "Who are you?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And then [INAUDIBLE] come to the phone.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "I don't want to tell you how we feeled.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "She says, right away, the Lebanon the border, I showed you where, where the Jordan River is, I says, [INAUDIBLE], I'm coming out tomorrow.",
      "word_count": 24
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "She says, [?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "George, ?] you'll never find that.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "So next day morning, she says, George-- I says, when you coming?",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "She says, we get up a little later.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "But I'll be there, 11 o'clock.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I told my girlfriend, here's some money.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Go out shopping.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "When-- when she comed in there, in the Hilton, you know, I don't want to tell you what a relief was that.",
      "word_count": 22
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Only one left over.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I got there on the cape-- whenever I did-- 10 years, 11 years ago now. 12 years ago.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "She was twice in-- I-- I bring them up to Boston.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They were twice here.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And now she-- she goes to Budapest to fix up her teeth as one for [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So I-- I-- I take a place for them to the-- in the-- in the [INAUDIBLE], and the market island.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "That's the life story.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Nobody left out--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, 12-- 12 years exactly now.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I want to go back to Budapest following the war.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "After the war, I-- well, should I be honest?",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I'm honest.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "First, honest, I got first a job.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "The farmers used to bring in gooses, chicken eggs.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And I used to help them take it off from the truck.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I got a pretty nice pay.",
      "word_count": 6
    }
  ],
