{
  "stem": "24466.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And after, that-- before the war, the years before the war, I was more engaged in my work as a tanner, master tanner.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "A lot.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "A lot.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "A lot.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "My father implanted in us, in the children, the love for Zion.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And he was one of the first one.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I start to, in 1919, when just Zionism was born, and he was working as one of the first in Radom, especially.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And he was working for that ideology.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He was-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "But unfortunately, [PAUSES FOR 4 SECONDS] he didn't-- we went through a lot of wrong things during the time-- till the war.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Because I lost my mother-- the wife of my father-- really young.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And I lost, a year later, I lost my brother, Rubin.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And that was a hold up a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "But he was-- he was a very serious thinking about to go to Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "My mother, she was a sick person.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And she passed away in 1930.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In '31, a year later.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was-- he was-- one of his friends [PAUSES FOR 4 SECONDS] was sick with, I believe, typhus.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "He visit him.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And he-- just-- [PAUSES FOR 5 SECONDS] he caught, of him, that sickness.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And he was alive, that friend.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And my brother, after, two or three weeks sickness, passed away.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "From that sickness, typhus.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, and during the holidays, mostly.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "That was-- the synagogue, that was next to the Zionist organization.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That was in Zeromske 23, number 23.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Z-E-R-O-M-S-K-E.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "This was in the center of the town.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, it wasn't a large synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Most of the members of the Zionist organizations were praying there during the holidays.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "There were holidays.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "This wasn't a rabbi there.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't a rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "There was only a cantor.",
      "word_count": 5
    }
  ],
