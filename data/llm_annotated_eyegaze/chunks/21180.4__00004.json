{
  "stem": "21180.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "This they [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "This call Hohenstein-Ernsttal.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Machiner. ?] And we built the-- they-- they built, but we helped building, a group of our people, building new barracks.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "It took very not long, and we build new barracks and was in this barracks.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And we worked a block, two blocks away in this factory, also made parts to the army, tanks, trucks, whatever it is.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "In the 14 or 15th of April, 14 or 15 of April was it.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "We-- we are getting the soup in the camp at [INAUDIBLE], and he asked us who has something inside the barrack should take with them.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And we didn't have-- we had-- he was-- you could go talk to him.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "But not everybody would stop this SS man, only his uniform.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "But we had leaders in this camp, like I showed the-- the picture.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "He was very close, I should say, friend with him.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "I will show you.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "So he was the shoemaker.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "And he made them a pair of shoes.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Moishe Favel [PAUSES FOR 5 SECONDS] Kris.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "My wife told you [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "His grandson is [INAUDIBLE] in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "My wife told you about [INAUDIBLE] in New York, no?",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Can I say?",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The Oberscharfuhrer?",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, they spoke every day politics with him.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "He was-- this Kris was a good friend of our.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "He died in December.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He's supposed to make in March a hundred years.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "He died in September in Brazil.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And I spoke with him every day, don't forget my birthday.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I'm sorry I-- OK, so continue this.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "We-- oh, we stand-- stand up and we went on the death march.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "We didn't know what--",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Of course, not enough, but we could live on it.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "But he, this leader, was stealing for us.",
      "word_count": 8
    }
  ],
