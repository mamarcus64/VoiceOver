  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "We have Russians over here.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And there was a Jewish captain, a Jewish mayor in the city.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "I remember his name.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "You'd never think he Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And they gave me a place to live to-- straw.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "And the grandmother, which is my father-in-law's mother, gave me cream and bread, and I eat the bread and talk.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "I can't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "He can't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "He can't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "And my wife, she's already [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "I didn't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "She comes, I remember she put her hand in over here.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "She was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know her.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] She puts her hand.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "She says, he has no temperature.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "She says, I don't see any temperature.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "He called a doctor [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "He was in the city, [NON-ENGLISH], I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Doctor [NON-ENGLISH] says, he will need a strong guy.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "He's terrible injured four-- four ribs.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And it was six weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "I start to walk with a cane.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And now, from my town, a city-- from my town passed through down there.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And he comes in.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "A Jew is down there.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "He comes to me.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "He see me.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Oy, he says to me my name.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And I can't talk to him.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "He says, you know who is this.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "This guy which went in this, in this, and this.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "I went with him here.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "We know each other for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "He tell the story.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "Then they put together a bed for me from boards, two boards, straw.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And I was laying in bed.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And I was about two months probably.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "It was Passover.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "I try-- I work hard.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "I work hard.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "I start to talk Russian.",
