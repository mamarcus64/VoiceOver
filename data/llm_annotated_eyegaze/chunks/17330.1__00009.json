{
  "stem": "17330.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 173.8,
  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't believe it, because in those days, they said that to people to tease them and then they didn't let them go.",
      "word_count": 24
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "So I was scared for that.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And I said, are you having me on?",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "No, you're free to go.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "But tonight you have to sleep with somebody from the Jewish Council.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "And they get you papers to travel.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "So I slept with those people.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "Do you remember their names?",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "No idea.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Never saw him in my life.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, then I came in Amsterdam.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "By train.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "I had special papers.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And somebody warned my father that I was free.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "That was-- I left in July.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "'42.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And so I was 12 days there.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And then when I came back, I didn't want to go in my own flat, because I didn't feel safe.",
      "word_count": 20
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "But I had to go to a doctor to get a certificate that I was not able to look after myself and that I was pregnant and that I have to have permission to stay with my parents.",
      "word_count": 38
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "So I got a letter from a doctor and I stayed with my parents.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
