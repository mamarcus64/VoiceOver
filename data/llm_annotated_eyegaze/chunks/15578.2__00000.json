  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "There is no question in my mind it was, because Jewish people that play with Lechia.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Even older spectators, the public, what did it come to watch, and they wanted Lechia to win.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Fortunately, Maccabi won.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They were a better club.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I'm just there.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I watched the game, because I didn't belong to that team.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The end of the game, when Maccabi won, they started to go into dressing room, and they start the-- kick mostly the public-- the public what they wanted Lechia to win.",
      "word_count": 31
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And they start to fight with the people.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "There were a lot of people from lodge that come to participate the game.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And They did fight.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "As a matter of fact, I remember one took out a revolver and shot in the air.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Everybody, they tried to get out as fast as possible, [PAUSES FOR 3 SECONDS] because no matter what it is, somebody that got hurt, and they tried to hurt as many as they could.",
      "word_count": 34
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I did belong to Ha-No'ar ha-Ziyyoni.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Zionists.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "That was a Zionist organization.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We did come there.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We had some [PAUSES FOR 3 SECONDS] all kind of activities like from-- I remember we went in 1937, we went to a camp for four weeks with that organization.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And then in 1938, we went again, [PAUSES FOR 3 SECONDS] and we spend there-- there come some people in that time from Israel.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I remember one man, [?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Katz, ?] he was from Katowice.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He gave some speeches.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] That was very interesting.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] Everybody from the young people, they knew Palestine.",
      "word_count": 12
    }
  ],
