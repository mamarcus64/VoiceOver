    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 140,
      "text": "There was a shed in the side.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 141,
      "text": "I go in, in the shed.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 142,
      "text": "And I hear the pig.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 143,
      "text": "If I hear the pig, because I know somebody will come to feed the pig.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 144,
      "text": "[INAUDIBLE] in the morning comes in this guy [?",
