    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 137,
      "text": "I come over there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 138,
      "text": "Impossible to-- it was so [INAUDIBLE], and nobody can come in.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 139,
      "text": "Because it was the war time, they was get [INAUDIBLE].",
