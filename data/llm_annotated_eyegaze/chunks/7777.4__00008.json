    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 135,
      "text": "It was not too far from the nuns to this [?",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 136,
      "text": "Gochinski ?], what he lived.",
