    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 128,
      "text": "When I work in the mill, I took out some flowers.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 129,
      "text": "And I sold.",
