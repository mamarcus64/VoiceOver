{
  "stem": "6076.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Herlig to the side, the other woman to the side, you whores, you bitches, you whores.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "You are pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And their faces, they bent down their heads like you're taking somebody to be hanged, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And they stood straight, limping with their arms down.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Their arms looked longer to me than ever.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "But their shoulders dropped down.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I could not look at Herlig's face and the other girl's, too, the other woman's, too.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "She was young.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She must have been in her early 20s, the other woman.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And they waited in the barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They didn't let them work anymore near my machine.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And a few days later, a truck came, and they took them.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And more people from the ward they took it out.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So we were not just Jewish girls over there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We were surrounded with Russians, you know, what prisoners, gypsies, you know, together.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But of course, the Russians didn't do our work.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They worked in the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They had better work.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They were the kapos.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They did that.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They gave them better work.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Only we were the only one who worked on the machines, hustling from morning to night with a slice of bread, with a little soup, day in, day night.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "This is the routine from our work.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "As long as we didn't get hit, as long as we didn't get sick, that was a blessing, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "If somebody got sick, there was very little opportunity, very sick I'm talking, little opportunity to survive.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "The sickness finished them up very fast.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So the truck came, and by luck, because Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Herlig is a big woman, a husky woman, they let her stand the last.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "All the skinny ones go in first to the truck.",
      "word_count": 10
    }
  ],
