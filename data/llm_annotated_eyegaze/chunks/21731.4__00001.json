{
  "stem": "21731.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "In the meantime, I had no place to stay.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "One of the ladies in the-- in the work home gave me-- for a few days, a bed.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Somebody else gave me a bed, but I remember that sometimes when it was warm, I was sleeping in the park, or somewhere outside.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And that was-- that was the problem then.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "My things, whatever I had, were in the wash in the work home, whatever I had extra dress or some shoes or something.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Then one of the ladies who worked in the shoe-- shoe-- [PAUSES FOR 4 SECONDS] it was also a shop.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "It was not only a work home, but she worked in the work room-- knew that I am homeless.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And she suggested me going to a nunnery and asking one of the nuns whether they would perhaps know somebody who could give me a room, or perhaps I could work for somebody.",
      "word_count": 33
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Somebody would have needed somebody to look after a child or an old woman.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, well, naturally I was a Polish woman.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Nobody knew that--",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "--I'm Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes I was Eva Sarnetzka.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And Jan was Jan Sarnetzky.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We kept the initials so it will be E-S and G-S, in case something would be found on us with a monogram on it.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We had to think of everything.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Well anyway, I went as I was there as Eva Sarnetzka.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I had the identity card.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I had my baptism paper.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And I went to this nunnery in [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "That was the place were I lived in for a few years.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I saw Sister Laurentia was her name.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She was an elderly nun.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Well, for me she was elderly, because I was young.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And she was very nice to me.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I told her the same story.",
      "word_count": 6
    }
  ],
