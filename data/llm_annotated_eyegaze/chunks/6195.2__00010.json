  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I am a nobody towards a big army like that.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I said, well, I am not giving up.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "So I had to be-- but we had a tenant who was-- who had a horse and a buggy.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Well, this was called a [POLISH], a [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And he said-- I went to him, and they were owing us heaps of money for rent.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So I said, will you take-- all I want you to take is my father's library.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We'll break here for end of the tape.",
      "word_count": 8
    }
  ],
