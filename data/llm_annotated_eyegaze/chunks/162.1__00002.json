{
  "stem": "162.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And he traveled with an orchestra that was like the Stan Kenton or Glenn Miller of the times.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And they would perform everywhere, all over Europe.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And one time, several times my father was given a warning that if he continued to play American music, or if he continued to play music, that he would have to pay the consequences.",
      "word_count": 34
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And I remember my dad telling me that because he was a professional, and because he, you know, had the status that he had, that they would let him leave the country.",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And my father then decided, being an artist and not a very smart man, not a businessman, not intelligent in that way, he decided that we would go back to Poland, where his home was, because he had film commitments in Warsaw.",
      "word_count": 42
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And unfortunately, my father left first.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And I remember my mother and I followed soon thereafter.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And we all ended up in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And I remember, it was one of the most beautiful times.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "We lived in this magnificent apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "We lived in this apartment building that had a huge courtyard with beautiful trees.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And I would look out the window across to the other building.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And every day-- I inherited my father's talents.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And every day, I would spend hours in front of the mirror, playing different characters and different personalities.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "I wanted to be an actress.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So my parents lived there.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we lived there for awhile.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And one day, my father came home and he said, you're coming with me tomorrow.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I have an audition for you for a film.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So we've gotten this far, but--",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I know we lived in--",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "There was none.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "There was very-- there was none.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Before the war, there was very little.",
      "word_count": 7
    }
  ],
