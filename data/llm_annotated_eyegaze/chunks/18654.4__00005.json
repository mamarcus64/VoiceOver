{
  "stem": "18654.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So we didn't go out to grand places.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "We went to the cinema once a week probably.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And we'd go to each other's house, and have a spaghetti, things like that, to each other-- when I say house, I mean to each other's [LAUGHS] rooms.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Very few of us had flats or houses then.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "That came later.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "That was basically our social life.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And we all worked, and I used to bring-- I used to work at home and I used to go out to work and work at home as well in the evenings.",
      "word_count": 32
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, my first work was I worked in haute couture, which is upper-class dressmaking.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And you can starve to death on the wages you earn.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I then changed, because somebody offered me a little bit more money, to make hats.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And I became-- it takes a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "But I became a fully qualified milliner.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Because I earned a little-- only because I earned a little more money doing it.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "My-- my ultimate work experience was when I married my-- well, I stopped-- I'm sorry.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I-- I then stopped work.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "Because I had a child.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "But I then started to work at home, because we needed the extra money.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And I worked together with a friend of mine as outdoor workers for a-- a very good class dressmaking firm.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And eventually when I married again, I worked in my husband's business, which was different again.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "But in between marriages, I also used to, apart from working at home, I used to do-- I'm not religious by the way, anymore at all-- I took a Saturday job.",
      "word_count": 31
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "Because my ex-husband took care of the child on Saturdays, and I was able to work.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "So I took a Saturday job in an antique shop, which I loved.",
      "word_count": 13
    }
  ],
