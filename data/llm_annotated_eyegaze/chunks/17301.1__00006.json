{
  "stem": "17301.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 219.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It-- I think it was like 50/50.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But I couldn't give you a number.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I-- I can't tell you a number because I-- I didn't know, and I don't know.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Not right away, not right away.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They did occupy our-- they told us that we have to get out.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We had a pretty good-sized home, and then we had to get out of-- most of our, our rooms we-- we had to turn over most.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We kept the kitchen and we kept one living room.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I mean, part of the living room and a bedroom for us, for our purposes only.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And they took over the rest of it.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "They were living-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Practically with us, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They didn't treat us in any way at all.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I mean, they just let us stay there because they knew something was coming.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Sooner or later, they'll have the whole house to themselves.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was very fearful.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I was very, very fearful.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know how to handle them.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know how to go about talking to them.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid to talk to them.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And yet, I spoke German at that time because we learned in school.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We learned German, so I was able to communicate with them.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "It was at that-- in the beginning, it was not threatening to the point where they would shoot us or they would do any harm to us, not-- not for a while.",
      "word_count": 32
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "No, It wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I know my my mother was very scared.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And my-- my father-- both were scared.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They just didn't want to show it to us, because they were afraid that if they're going to show us that they are scared, that we're going to panic and we might say something to the German.",
      "word_count": 37
    }
  ],
