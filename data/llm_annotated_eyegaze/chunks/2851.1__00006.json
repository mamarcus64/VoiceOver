{
  "stem": "2851.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "It's the same way we supposed to go, to the Koszary.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "They took them to Koszary to work.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "So we sneak in with the people.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "They took to work, me and my brother-in-law.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "We went-- we went-- this was in ghetto, when they took the people from ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "They came to the ghetto to take the people, two policemen.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "So we sneak in with the people.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "They have to-- they have to count every day the people who-- how much they take.",
      "word_count": 16
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "After the-- they count the people, we sneak in, both of us.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And we went together.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "They went on the train on another side, and we supposed to go in the other side-- in the other side on the train.",
      "word_count": 24
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "It was about 20 minutes by train.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "When the train-- the train-- before she stopped.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "When she stopped, we couldn't go-- we couldn't go.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "When the train didn't go so fast, we jumped, me and my brother-in-law.",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] But we were very-- I-- I couldn't stand up because it was very-- I was very-- I was shocked and hurt from the train.",
      "word_count": 28
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "We didn't go-- we rolled on the-- on the-- from the train.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And then we-- [INTERPOSING VOICES]",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Oh, maybe half an hour.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "We were-- we didn't know what's going on.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "We were in shock.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "We went a few kilometers, the place where the-- the-- the man, the Russian man, wait for us to take us with.",
      "word_count": 22
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember the name.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "We went to a place where the-- my brother-in-law has the place we were supposed to be.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "It was-- he was the-- the [INAUDIBLE] from the-- from the little town.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "He was the-- he-- he was the-- the-- he did everything for the-- for the town, this man.",
      "word_count": 18
    }
  ],
