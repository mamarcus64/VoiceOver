{
  "stem": "13219.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a lot of shooting-- and I would say 2/3 of the city burned down.",
      "word_count": 15
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "Our house was burned down, too, at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Overnight.",
      "word_count": 1
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "I mean, the fight was going around maybe for six hours.",
      "word_count": 11
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "I think was August.",
      "word_count": 4
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "'41.",
      "word_count": 1
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "'41.",
      "word_count": 1
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "And at that time, the morning the Russian were gone.",
      "word_count": 10
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "And the German army startin' come in to our city.",
      "word_count": 10
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Yes, artillery and rifle shots and machine guns.",
      "word_count": 8
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "And the citizens, the everyday citizens, just sort of froze.",
      "word_count": 10
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "They had nowhere to go.",
      "word_count": 5
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Nowhere to go.",
      "word_count": 3
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "You are in between.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 2,
      "text": "You on a battlefield.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 3,
      "text": "You are there on the line, worse that them.",
      "word_count": 9
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 4,
      "text": "They had rifles.",
      "word_count": 3
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 5,
      "text": "We lay there.",
      "word_count": 3
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "After, after the Germans started to come in and--",
      "word_count": 9
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "The fields-- well, we're laying.",
      "word_count": 5
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "We saw, we saw the, the, the, the, the bullets flying back and forth.",
      "word_count": 14
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 2,
      "text": "We hear them.",
      "word_count": 3
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 3,
      "text": "But we're scared.",
      "word_count": 3
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 4,
      "text": "And my, my mother was holding cover my daughter and me-- my, my sister and me.",
      "word_count": 16
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 5,
      "text": "And my father was the, with the other brother.",
      "word_count": 9
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 6,
      "text": "Because third brother was in the army.",
      "word_count": 7
    }
  ],
