{
  "stem": "27770.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And we played together.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And he put out sandwiches.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "In one of the sandwiches, I saw it was ham.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And he told me, take a sandwich.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I said, I wouldn't eat this sandwich.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And he says, why?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I say, because this is ham, and I am Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And I am eating only kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And he said, you are Jewish?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "He looked at me like he didn't believe it, that I'm Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "I said, no, I wouldn't eat it.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And he said, you know, you do-- you don't look like the rest of the people, of the rest up the Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I said, what do you see on me more or different than between the rest of the Jews?",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "Of course, probably, he has this in mind, they have horns, and I haven't.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And the non-Jews, they haven't got horns.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "That's the only thing for probably he was thinking in his mind.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "But since this, then later on, I never played with them.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I felt that I'm not invited anymore there.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And that's how it was, the situation between the Jews and non-Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "If a Jewish kid, on the street, was walking with their payos, many, many times, before he arrived back to his home, he was beaten from the goyishe kinder.",
      "word_count": 29
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And it was not pleasant to be between the goyim.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In fact, not only Hebrew gymnasium.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We started, in Munkatsh, it was in Russia, we called it Carpathian.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And in the whole area, this was the most educated school what could exist.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I started, already, from kindergarten.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We has, already, Hebrew kindergarten, lower classes, and gymnasium.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "In fact, we had also the girls attended to polgari.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Boys went to gymnasium and the girls, they went to polgari, till the fourth gymnasium.",
      "word_count": 15
    }
  ],
