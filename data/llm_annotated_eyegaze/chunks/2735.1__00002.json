{
  "stem": "2735.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "The only other store that was of the same was my father's sister and brother-in-law.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I went there to elementary school.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "After the elementary school, they opened an [INAUDIBLE], a secondary school like a high school.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I went there for about a year and a half.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And after it, my parents sold everything and moved to big city.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "To Rowne.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because my brother was the oldest and he was going already to school in the next town.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And then, they had to send me, and it was a lot of money to-- to live out and we had two more younger children.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And my mother was never happy to live in a small town.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And eventually, they-- first they rented the property for a bank.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And then they sold it, and we lived in a different town, in Rowne.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And we lived, 1939 when the war broke out, that's where we were.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I'm trying to think, if I moved in '37-- I think '37-- so I was 14 years old.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents spoke a lot of Russian between themselves.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] They spoke Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "But they spoke a lot of Russian between themselves.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "My mother really was-- she-- she used to teach, like, not in a public school, but she used to teach Russian.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "So-- and they both spoke Russian a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In school, poetry.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "It was always.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "When I left the-- [PAUSES FOR 5 SECONDS] well, when I left the town, I just was thinking in terms of finishing high school, gymnasium.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I really couldn't see myself in a-- I wasn't-- I don't remember.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "If I did think of any professional of anything, I don't remember it.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I was thinking of school, of friends, of activities that would go on with all this.",
      "word_count": 16
    }
  ],
