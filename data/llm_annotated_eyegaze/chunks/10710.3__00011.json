{
  "stem": "10710.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "If you-- we used to get a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You didn't leave it for the next day, because if you leave for the next day, it was not-- somebody will take it from you.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You sleep, and you take it from you.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I remember we used to get, in Deutsche Emailwarenfabrik, which was a really good camp, we used to get one bread for six people.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So the bread was like a-- it wasn't round.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "It was long.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So you had to cut it into six pieces.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Everybody wanted the end, not the middle, because the end was more.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So how we did it, we cut it in six pieces.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And one had to turn around, you know, he didn't see it.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And he says, this is for Moshe.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "This is for-- for whom is this?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "This is for Yankel.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "This is for-- this way was no-- you know, whoever luck it was.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And as soon as you got the bread, you ate it up because you couldn't leave it for the next day.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Somebody would knew that you had a piece bread.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "It was like-- like animals.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It-- they took it away from me.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was for himself when it came to food.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I saw hanging in Rabka, and I saw hanging in Plaszow, too.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In Rabka, [PAUSES FOR 3 SECONDS] there was a guy working for that Rosenbaum.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] came in an SS man from another town, and told him he needs [pauses] the horse and wagon to bring him-- to-- to take him somewhere.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He didn't go to Rosenbaum and ask him, but he did it on his own.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He got so mad that he-- he says, you're going to be hanged.",
      "word_count": 13
    }
  ],
