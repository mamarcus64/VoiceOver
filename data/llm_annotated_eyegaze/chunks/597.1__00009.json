{
  "stem": "597.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "They had a-- a printer shop.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "They print a hundred books in the-- in-- in the-- over there on this-- about the Kabbalah in Hasidism.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So that was the-- the town-- very, very famous town, famous in the history-- written.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I was raised Hasidic, yeah-- orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But I'm not-- now I'm not orthodox.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Now, I am conservative.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They are new times.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You cannot be too orthodox.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "My son is orthodox.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My daily life?",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "In the morning, I used to say prayers early in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I don't say today; and dress myself up, eat, and go to school.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I played with children, like young-- you know, little kids-- run around on the street.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "It was very, very free there.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They did not-- you aren't afraid over there.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "We didn't-- we wasn't afraid to play there, you know, during Poland's time.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "It was free.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "It was not so easy, but we-- in school-- eat, lunch time and supper time, together with the family we eat.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "My father used to come from work.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "We used to sit down.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Winter was very cold for us-- about 40 degree below 0-- very cold.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And my father used to come in just to warm himself up near the oven.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "There was a oven; and sit down to eat the meals, what my mother used to prepare.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "My mother used to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And in the morning, I used to get up early in the morning-- the snow was up to the knees-- went to school.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "Everybody, they didn't miss one day to go to school.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "And I used to help out mother in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "I used to go and-- it's not like here, you turn off your faucet and you have water running.",
      "word_count": 19
    }
  ],
