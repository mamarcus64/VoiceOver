{
  "stem": "1917.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 388.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And when I was pregnant with my daughter, I realized that my husband had serious, serious problem, was that all my love and my caring-- I mean, I pampered the guy.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I cut his toenails.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I shampooed his hair.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I was going to make him feel so good that he was going to be the happiest guy in the world.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "Didn't work.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "He developed severe problems.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "He had-- he couldn't take care of the boy.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "He was worried that he would-- there were a lot of sad things, like he worried that he was going to kill him or-- I don't know.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "Psychological problems.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "What really happened, the way I understand it, is that he all his life worried that he could not be a good father and a good husband, rather than thinking how a good husband he could be.",
      "word_count": 37
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And all that worry kicked in.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "And now he was worried that he's going to lose it all.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "And so he developed, in addition to that, he said he had cancer, that he was throwing up every morning.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "And I had an extremely difficult pregnancy.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "I had to be-- I had a tubal pregnancy between the two children.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "I lost one.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And this one, I started the bleeding in the second month, so the doctor said, you have to be off your feet until the minimum of the seventh month.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And we handled that, but I had here a husband who was sick.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "And the baby was born, again Cesarean, and little girl, 1963.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And it was unbelievably difficult to me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "I felt that I was overwhelmed with everything.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "And my husband said that he had cancer, and that he doesn't want to go to the hospital.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "So I forced him to go to the hospital.",
      "word_count": 9
    }
  ],
