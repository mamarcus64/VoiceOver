{
  "stem": "11175.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And-- and I started to walk.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And I walked about 5, 10 feet away from that [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "I came on that-- to that grave where the people were laying-- laying shot.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "So you heard them-- [GURGLING SOUND] just-- they did-- there was not-- some of them, they were still alive.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "Some of them, they was you know, working hard until he's died.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "So he like-- like-- a-- a pot of potatoes would cook.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "[GURGLING SOUND] [STAMMERS] But so many hundreds of people that were laying there, shot there.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "So I looked at this, and I started to walk.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "And I walked away from that grave.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "I'm going to lay down there?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "But I walked away then, the grave.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "And I walked in one direction.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "I knew approximately-- you see, if I'm going to go there-- I knew the area there.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "If I'm going to go there, then [STAMMERS].",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "So I walked, until that's the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "This was in-- not September, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "The day was still a big-- long-- until the morning, when it started to get a little light.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "It started to get a little light.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I saw some women coming out from the-- from the-- a house there.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They said, oh, [NON-ENGLISH SPEECH]-- for sure, from Treblinka.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Help me.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I say, please.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I started to-- started to cry, say, help me.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Said, I'm afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I cannot do this.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "If they're going to see me, I'm-- they're going to kill me.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I said I would not go away.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "They would have to help me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "So she took me in, inside, and took a pot with water, and she bent me down, and she washed me [STAMMERS].",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And said, give me a-- a clean rag.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "And I tied it up.",
      "word_count": 5
    }
  ],
