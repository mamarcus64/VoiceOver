{
  "stem": "22734.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "So-- and I-- I had to write an entrance exam at the end of grade four, which I passed.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "You write it in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "It's a four, five-hour exam.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "How old were you then, Eva?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I was about-- I was exactly nine.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And you write an exam in Czech, and sort of a dictee.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And you write a short story on the topic they give you, and-- and math.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It was a four-hour exam, and they told you that same afternoon whether you passed or not.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And if you would speak Czech, I would still tell you what I did-- the sentence I had in my Czech spelling, which was very, sort of-- you know, in Czech language, the-- the difficulty is with i and igrec-- i and y.",
      "word_count": 43
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And there are too many exceptions.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So they gave you three or four sentences which were really difficult for small children.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I went to an all girls school, and the last year, I had a year of Latin, which was taught very well, because I still-- I-- I never forgot what I learned.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And we had an-- we never went to school in the afternoon.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "We went to school from 8:00 to-- in grade school, we went from 8:00 to 12:00, and twice a week from 2:00 to 4:00, for gym or singing, music, or-- and drawing.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And in the gymnasiums, we never-- we went from 8:00 to 1:00-- 1:30 sometimes.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Six days a week, never in the afternoon.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "In the afternoon was religious instructions for Jewish kids who wanted it.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "So that's-- that's about it.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And we had-- we had-- we had math, and we had German, and we had geography and history and Czech, mostly.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "You know, Czech grammar, Czech structure, Czech written.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "What else?",
      "word_count": 2
    }
  ],
