{
  "stem": "18281.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 184.7,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And she lived in the little room all by herself.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Nobody ever bothered her.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And she lived in [INAUDIBLE], which is part of Brussels.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She went back to Vienna.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And the Viennese wouldn't, wouldn't pay her pension.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Because she now was a Belgian subject.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They wouldn't let her stay in Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So she went back to Belgium.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "She kind of lost all her papers.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And with her birth certificate, she says, now I'm here.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "I'm an Austrian.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I was born here.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And she got a pension.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "She lost all her children in the war.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "She had three girls and two boys.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And they all died before her.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And all by herself, she went back to Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "And eventually, she fell and broke her hip and died at the age of 90.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, I rang the bell.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And nobody opened the door till the, one neighbor that I had never seen before opened his door and says, please get away from here.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "The Germans just picked up your, your parents half, half an hour previously.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So I walked to my uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I had no money in my pocket.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And that night, my uncle and I, we broke into the house.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We broke the seal of the Gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I picked up some clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I picked up a little suit-- leather suitcase that was hidden in the garden.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "I still have it to this day.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And in that suitcase were my parents' passports, a little bit of money, and some documents.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And my dad, again, had been dabbling in leather goods.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So we had a bunch of hides in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't want the Germans to take those hides.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Don't ask me why.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Those hides would have helped the war effort.",
      "word_count": 8
    }
  ],
