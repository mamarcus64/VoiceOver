  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I got half a bread, [INAUDIBLE] got half a bread, a herring-- a salted herring, a big herring, and a bit of sugar, and a number for the carriage.",
      "word_count": 29
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "We have to go to the train.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I see about 25 carriages, different sized carriages.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And each character [INAUDIBLE] according the carriage can take-- 20 people, 10 people, 15 people.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we started-- after two days, all the carriages was full, we start to move.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We moves like a fly [INAUDIBLE], so slowly, slowly, slowly till we come to the old Russian-Polish border.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "What you think about my story?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We'll finish the tape two here and we'll continue on tape three.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
