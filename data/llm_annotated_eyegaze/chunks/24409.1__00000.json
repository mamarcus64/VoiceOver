{
  "stem": "24409.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is William, W-I-LL-I-A-M, middle name, R, middle initial, R.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Last name is Perl, P-E-R-L.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No, at birth my name was Willy, W-I-L-L-Y, Perl, P-E-R-L.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The 21st of September, 1906.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I'm 90 years, plus.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Prague, Czechoslovakia.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Then, it was part of the Austro-Hungarian Empire, capital of the Bohemian province of Austria.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I feel all right.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "However, I have-- I'm suffering from Parkinson's disease, for many years.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And for the interview, the viewers have to be aware that I am performing with the need to present a healthy picture of a healthy person, which I am not.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I make very, very many involuntary movements.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They're all part of my Parkinson's disease symptoms.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And I apologize for them, and ask you to concentrate on the content, and not on the weird movements which you will see.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We lived in Prague until to my fourth year of age.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Then my family moved to Vienna, Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They moved because they saw a better future for themselves.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Vienna was the capital of the country and a very admired city, all over the world, at that time.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father was, first, a traveling salesman for a large textile firm.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And then he established himself as a dealer on wholesale in textiles.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Rudolf, R-U-D-O-L-F.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, her name was Camilla, C-A-M-I-L-L-A.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And her last, maiden name, her maiden name was Fischer, F-I-S-C-H-E-R.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was a very good-looking woman, a very warm woman, ready to give her last shirts for the poor, and very un-political.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I had one brother, Walter, W-A-L-T-E-R, with the middle name Vladimir.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Prague was a bilingual city.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Many people gave their names-- a German and a Slav name, too.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He was four years younger.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They were religious but not in any way orthodox.",
      "word_count": 9
    }
  ],
