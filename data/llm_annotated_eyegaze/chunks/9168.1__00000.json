{
  "stem": "9168.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I think I did the same thing backwards.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It's no problem.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Gary.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is July 21, 1924.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in Anaconda, Montana, when my parents were traveling from Seattle to Joliet, Illinois, for a new position for him.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I was born on the way, on this trip.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So we had to make a stop off in Anaconda, Montana.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "That's how I happened to be born there.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Anna Catherine, with a C, von Eresch, E-R-E-S-C-H.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My father was Guy Vivien, V-I-V-I-E-N, Putty, P-U-T-T-Y.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My mother was born in Beloit, Kansas, in 1894.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And my father was born in Hopkinsville, Kentucky, the same year.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I have one brother living, John Kenneth Putty, in Dallas, who is-- who is now 65.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And my sister died in 1978 at age 52.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Edna Mae, M-A-E, Putty.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember growing up in Joliet-- I mean, for most of that young-- very young period of time-- in Joliet, Illinois.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My father was a professional chef.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he worked at the Silver Cross Hospital, in Joliet.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And that's where I went to-- my early years in school.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It was a very difficult period, during the Depression, for my family.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I just don't remember much other than going to grade schools, elementary schools, in Joliet, Illinois--",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "--as a very young child.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was-- my father was an alcoholic.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And he had difficulty being on a job for a very long period of time.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He was a top chef at country clubs and hospitals.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And so this made life very difficult.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "My mother and father both had a-- a rabbit tree, which is what it was called at that time.",
      "word_count": 19
    }
  ],
