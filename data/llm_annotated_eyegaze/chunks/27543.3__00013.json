{
  "stem": "27543.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I have no complaints.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "But now, listen here, all of-- see, what I told you, 40 years later, 42, for 42 years ago I had a heart attack. 40 years, I didn't even go to a doctor.",
      "word_count": 33
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I got angina.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I got a pacemaker.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I got a dislocated disc.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And I take 14 pills in a day.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "And I still date.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "I still go out.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "I'm not going to feel sorry for myself.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "I-- if I would feel sorry for myself, I don't think I could live that long.",
      "word_count": 16
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "And I better have 100 friends to 1 enemy.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "I used to live in Norwood, in the [?",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 10,
      "text": "Windsor ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 11,
      "text": "Garden. ?] Nobody-- nobody know my name, except the Cookie Man.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 12,
      "text": "Where every day I brought the kids a big box of chocolate chip cookies or cupcakes, or half and half.",
      "word_count": 20
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 13,
      "text": "I used to take them to the children's zoo.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 14,
      "text": "In the winter I-- I rented out the snowmobiles.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 15,
      "text": "I used to take the kids around.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 16,
      "text": "I had a pretty-- I tell you why, because I told you.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 17,
      "text": "I've never smoked.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 18,
      "text": "I never drinked.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 19,
      "text": "The only thing, I gambled when I got married.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 20,
      "text": "No, I used to gamble.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 21,
      "text": "I used to go up to Foxborough, with my date, give her $20 to play.",
      "word_count": 15
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 22,
      "text": "But I'm not a gambler.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 23,
      "text": "I love the theater.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 24,
      "text": "And I love traveling.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 25,
      "text": "And I like nice restaurants.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "And nice ladies.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Number one, be good to yourself.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "How long you don't hurt nobody, it's nobody's goddamn business what you do.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And the most important thing in your life, try to meet the right people.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "Try always to look a little higher, where you are.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "I can show you my last week lady friends was all doctors and this.",
      "word_count": 14
    }
  ],
