{
  "stem": "25591.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I tell you, as best I can remember, what they were, and then I tell you what I did with my money, because it's sort of interesting.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I worked in a grocery store at night filling up the shelves.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I worked in a furniture store helping to carry furniture.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Then later on, I also did some bookkeeping for the furniture store.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I tutored Latin, math, English, French, and Italian.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I had a job in a borrowed tuxedo ushering at the Seattle Symphony.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And when Toscanini was at the symphony, I was one of the-- maybe the only person who spoke Italian, and I had the pleasure of having dinner with him because I spoke Italian.",
      "word_count": 33
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I'll never forget it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "It was-- I-- he was in his 80s, I believe.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I was the sandwich man on Sorority Row.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I had a big tray on my neck with Washington state Delicious apples, pies, milk, and various sandwiches.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And it was a wonderful job.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "I would go into the sororities filled with beautiful young women, and I screamed at the top of my voice, sandwich man, sandwich man.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And they would all come down, and I got more dates than I could handle.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And I made a fortune selling all this stuff.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "When I got my first little money-- I have no idea what it was-- $20, $30.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I had a wonderful friend who is still my closest friend, [PAUSES FOR 4 SECONDS] a Jew from Alaska by the name of Barney Gutstein.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "And he's my dearest and closest friend and has been since August of '47, almost 50 years now.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And he really taught me to be an American in every way.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Politically, how to drive a car, you name it.",
      "word_count": 9
    }
  ],
