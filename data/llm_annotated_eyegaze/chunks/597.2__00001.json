{
  "stem": "597.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "He became a-- he was a bookkeeper, was working in an office in bookkeepers.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "My aunt was a devoted woman, too.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "Very devoted.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "Used to invite me every-- Come in, come in.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "Used to make gefilte fish, used to treat me with fish, with sweet rolls.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "She liked me very much.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "This was my father's sister.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Jewish, very Orthodox woman, too.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "Very charitable woman.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "She used to go around and Saturday used to go around between the Jewish houses and collect pieces of challah, whole basket with challah, and used to bring it in to the Jewish old home, to feed the old people.",
      "word_count": 40
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "But it's challah, and sometimes chicken soup, somebody'd put some extra on.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "Poor people, for poor old people, bring it in to the Jewish old home.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "The Jewish old home.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "They called us [SPEAKING IN HEBREW], it's a Hebrew-- a Hebrew name.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "Used to go there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "She was with another woman.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "Two woman.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "Very nice.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "That's the way I was raised, in this kind of my environment.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "To give charity.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "To help poor people.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "To help sick people.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "To help everybody what is in need.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Before the war?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was in-- In school, I didn't feel anti-Semitism.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Because the school was all Jewish. 73% were Jews there.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So all the children are all Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "But outside, there was a few Polish stores.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "They used to sell merchandise to-- to the Polish people, the-- you know, the-- so they used to write on signs, 'Don't buy from a Jew.' Don't-- [SPEAKING IN POLISH] This was in Polish.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They used to made up some pictures from Jews with long noses.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "That was my first experience.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I never had these things.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "The look, the face with a long nose, with a beard, that big kapote, you know, the dress.",
      "word_count": 18
    }
  ],
