{
  "stem": "13556.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "For minimum wage, you can't go too far.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "I sent money to my wife, a little bit to pay off my debts, what I borrowed money for a ticket.",
      "word_count": 21
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "And then I prepared a little bit money to make a down payment.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "And I was living in Polson, which $50 I paid a month.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "My wife came over in-- after a year I was here, in 1963.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And she came over here.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "We--",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "--was-- in the beginning, we was-- one Jewish man, [?",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Hoffman, ?] an older man, have a bungalow.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And the wife left him.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "He was living alone.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And he told us he will not charge us too much and to live with him.",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "I was living in Polson, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "With the--",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I was living in Polson.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I was renting for $60 a month-- $50 a month, one bedroom.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And it was not convenient.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "See, one washroom, and the landlady, older lady, and I feel not comfortable to use one washroom with a person what she's not looking so nice left to herself.",
      "word_count": 29
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "She's older age, a nice lady.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And I decided to-- I already make a little bit of money.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And I saved in this time maybe $120 or $130.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "And I told my wife-- OK, we paid out a black-and-white TV, in monthly payments.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "And I told my wife, time to move out.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "And came opportunity, which the wife left him.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 11,
      "text": "And he lived in Seven Oaks, the guy.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 12,
      "text": "He had a house in Seven Oaks.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 13,
      "text": "And he said, [NON-ENGLISH], I don't need the money.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 14,
      "text": "Just come in, whatever you pay me, what you're paying.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 15,
      "text": "I charge you only $80 a month.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 16,
      "text": "I told my wife, $30 the difference, we're going to live comfortable.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 17,
      "text": "And we left.",
      "word_count": 3
    }
  ],
