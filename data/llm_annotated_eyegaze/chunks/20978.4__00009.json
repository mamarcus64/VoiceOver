{
  "stem": "20978.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "She goes to the high school.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "She's graduating, going to go to college next year.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "And she works part time at the Freehold Mall.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "She works part time--",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Lauren, Lauren Col-- no, Lauren Weisler, is from the second marriage.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My wife name-- I met her 48 years ago.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We-- I met her amongst the [?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Greens, ?] that we used to hang out together through friends.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Her name is Betty Greenbaum, maiden name.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She's done an excellent job raising my children, our children, I should say.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She's active for the past 30 years in my synagogue, Always to raise funds, to raise money.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I'm active also, the past 18 years, 20 years, since my father passed away.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "I was a three-times-a-year shul goer.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "But since he passed away, I go every Shabbos.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And I had a beautiful Sefar Torah in the shul, under his name and my wife's parents' name, in their honor, which I see every Shabbos, and I kiss it and they learn from it every Shabbos.",
      "word_count": 37
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "To me, that's a great honor that I did for them.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "What effect did it have?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Life is cheap.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I been so close to death so many times that nothing scares me.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I just hope and pray for the well being of my kids and my grandchildren.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That affected it very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Not now, anymore.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But when-- when we came here, well, after my-- I buried my mother, I-- like I said, I said Kaddish for a year.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, OK.",
      "word_count": 2
    }
  ],
