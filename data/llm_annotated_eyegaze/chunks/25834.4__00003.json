{
  "stem": "25834.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 7 SECONDS] A very, very difficult situation.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Nobody touch eat.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "[DRINKS] [SIGHS] [SIGHS] The whole ghetto was burning.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "On the outside, it was like in Berlin wall.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And on the other side, you see, on the top balcony, people was hanging.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "That was not only Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "That was prisoner what was in ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Because there was some prisoner, political prisoner, Polish side and all over.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And maybe 10, maybe 15 people, you know, was tied and like this and hanging in the wind, you know, blowing.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "If you see this, that's terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And, you know, this day, I remember very well.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "Dinner was served in on our house.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "And this time, we live closer to ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Because other, old house was destroyed.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "And we moved to the Miodowa-Strasse, Miodowa Street.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "And [PAUSES FOR 3 SECONDS] was the smell of the burning [PAUSES FOR 3 SECONDS] buildings was terrible smell.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And you know, you see the shooting, bombard-- artillery bombardment.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "You know, and we know many people, our-- not friends, only people who was a relation to us, one or other way, was killed there.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "That was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "People hide in the basement.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And that's something what I mention, maybe you cross already this.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "Melamed mother, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "Birnbaum, what I said-- Melamed go to our side, to-- my father took the family to other side.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And we located in a Swedish embassy.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "And grandmother, I mean Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "Birnbaum, and the daughter of Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "Melamed-- because there was one grandchild.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "Greenbaum, who is hold this girl.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "And I not-- we go to special bunker-- called bunker.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And we be there all time after German go out.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The German go house by house.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Was a couple of days, all right?",
      "word_count": 7
    }
  ],
