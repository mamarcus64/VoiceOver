{
  "stem": "2118.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "He took it out to a machine shop that specialized in those things.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And they would rout it, or you know, like make fancy legs, or the fancy edgings around.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And the rest he'd do in the shop.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "It was all done by hand with hot glue and no nails.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "It was all dovetailed and very expensive.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "He was very good at it.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And he was doing very good.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And then he was-- they wanted to take him to the army.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So being the oldest brother, he applied for a referral.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Whatever it-- not a referral, a deferral.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "How would you call it?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "An-- A deferment.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So they gave him another year.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But it didn't-- he had to go to the army.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "He was two years in the army, and-- and he was my oldest brother.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My next brother, Hershel, the younger than him, couldn't be younger more than 2 years or a year and a 1/2.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He worked for my father, with my father, in my father's shop.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And he had-- he-- he-- how would you say that?",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He was going around with mine-- with a cousin of his, of mine cousin from my mother's side, Sarah.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I will come back to that a little later.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So-- and then my youngest, the next one, was my sister, Alta, or in Polish she called herself Adela.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And she was at home.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She was a young girl.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I mean before the war, she couldn't have been more than 19.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Then was my brother, Manny.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And he also worked with my father-- with my father.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And he's around.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "My other brother, Mendel, finished school maybe a year or two before me-- maybe not even a year or two.",
      "word_count": 20
    }
  ],
