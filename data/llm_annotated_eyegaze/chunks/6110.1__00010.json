  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Because Sam, that was my boyfriend that time, he used to travel.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "He used to sneak in some leather, you know, to sell.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "So that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "So he came.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And he told me that they killed my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "That's how I got the news about my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "Do you remember when this was?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember what time of year.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "It was not winter.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "That, that, that, that shock got to me.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I, I forgot all about it.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I have--",
      "word_count": 6
    }
