  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And he's afraid that I might get it-- infection in the heart.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And they took me to the hospital in the ghetto in Zhmerinka.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And I was in that hospital three months.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "The only medication that I had that the doctors made was aspirin.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And the aspirin was not in pills-- in liquid.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "It was a black-- I had to drink it.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "I still remember the bitterness that I drinked.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And this saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And so--",
      "word_count": 2
    }
  ],
