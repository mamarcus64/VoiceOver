  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "At the age of six, when we still lived in Cracow, we received a postcard from my paternal grandparents that my great-grandfather was very ill and was about to die.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And he wanted to see me.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The reason that he wanted to see me is because I was the first born son of a first born, the grandson of a first born, and the great-grandson of-- my great-grandfather was also first born.",
      "word_count": 36
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And therefore I was carrying the lineage of the family.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So he sent out the postcard and wanted us to come over.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "But in those days, you know, you didn't leave right way.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The four-hour trip was as much as flying today to the West Coast.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So it took us seven weeks of preparation until we finally took the train and went up the hundred miles to the town of [POLISH].",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "When we got there, my great-grandfather was in a small chamber in bed.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He could hardly speak, but they brought me to his bed.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And they made me put his-- put my head on the bed, and he laid his hands upon my head.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And the best he could he pronounced the blessings that probably every Jewish parent pronounces upon his sons, the blessing of Menashe and Ephraim.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And when he finished, he put his hand under the pillow and took an apple.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Apparently he put that apple for me some four weeks ago.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And by the time I got that apple, it was brown already.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "But I was very awed by the whole situation.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And I took the apple.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And I kissed my great-grandfather's hand.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And after we walked out of the chamber, my grandfather said to me-- said to my father-- he says, God will bless him for that.",
      "word_count": 25
    }
  ],
