  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't start it with drugs.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, 1914.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "It was in my 11th year.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I started just going to high school.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "You're very welcome.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "But you have to excuse my voice.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It is not in its natural stage today.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I'll try to-- my best to control it, but I can't guarantee.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My full name is Herbert Zipper.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "That's all-- that's all of it.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I was born April 27, 1904 in the heart of Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You want to have the address?",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Number 31 am Graben, that is that large place in the center of the city adjoining to the place in which the casino is, which is the-- the tower that's characterized as Vienna.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father was an inventor, an engineer [PAUSES FOR 4 SECONDS] who represented the spirit of the time of the fin de siecle and of the beginning of this century, which, in a few words, [PAUSES FOR 3 SECONDS] meant [PAUSES FOR 5 SECONDS] that every problem of humanity can be solved by science and technology, and that-- that at that time, in the early 1900s, that [PAUSES FOR 3 SECONDS] the good life could be forever if we just let science and technology work its way, that wars are obsolete, [PAUSES FOR 3 SECONDS] that security of-- of all could be practically guaranteed.",
      "word_count": 105
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] That means that we young people, we kids, grew up in an atmosphere of utter security, of a security in which everything could be solved.",
      "word_count": 29
    }
  ],
