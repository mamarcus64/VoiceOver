  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 47,
      "text": "[PAUSES FOR 3 SECONDS] And I used to paint them.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 48,
      "text": "First of all, they used to make a complete color.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 49,
      "text": "From white, all different colors; blue, pink, red, yellow.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 50,
      "text": "They used to dye them in the yard.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 51,
      "text": "He's a mechanical engineer-- a chemical engineer.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 52,
      "text": "He survived the war.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 53,
      "text": "And they used to sell it on the airfield.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 54,
      "text": "There used to be a song in the ghetto [PAUSES FOR 3 SECONDS] about the [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 55,
      "text": "And they used to sing it.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 56,
      "text": "[NON-ENGLISH SPEECH].",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 57,
      "text": "This was a song in the ghetto similar.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 58,
      "text": "Maybe a few words, I made a mistake.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I'll--",
      "word_count": 1
    }
