  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It so happened that there was a, a, a family of Bialystok people who was a, a renowned manufacturer, who, when he arrived in Shanghai-- in, in, in Shanghai, ultimately-- first in Japan, then in Shanghai-- was in the extraordinary situation that they have sent out goods just before the war to Harbin.",
      "word_count": 53
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And he was in a position to collect the money for the goods that they have sent out there.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And he was an exception.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise, we have parted with whatever we had.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I certainly parted whatever we had to pay for the ticket in American dollars.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "By the time I, I arrived in Japan, I had $10 on me.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "That was the sum total of my wealth and worldly possessions.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was-- in terms of, of the, as I said before, it was not a, a, a, a, a problem for the Jews.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "It was a problem for the strata of the population.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Wilno was a poor city.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "It was a big city.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It was a city of culture, of Yiddish writers, of YIVO.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "The YIVO Institute, its origin was in, in, in, in Wilno.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "But it was a poor city.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "You saw-- you saw beggars in the streets.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "It was a city which was cut out like the York peninsula on the Australian map.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "They, they occupied Wilno.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't occupy the surroundings of Wilno.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "So it had to leave from the surroundings of the south because the, the north and east and the west were Lithuanian territory, which, which was not under Polish suzerainty.",
      "word_count": 30
    }
  ],
