{
  "stem": "13213.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "You are spies for the Ukrainian.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "Whether they were anti-Semites or what, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "Maybe they really thought we're Ukrainians.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "And we started to speak Yiddish to them.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They didn't believe us.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And they were just-- left us there in the field.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And they said, we're going to kill you.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And one guy was standing with a gun.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And we were crying and begging.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And we were all the three of us-- four of us were standing there and begging.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And said, he's going to kill us any time.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And we were talking between us, maybe we'll start to run, and maybe one of us will escape.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "And as we were thinking about to escape and run, a cavalryman-- a guy came on a horse and said something to the guard, and they let us go.",
      "word_count": 29
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "It was like a [NON-ENGLISH] that came and they let us go.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And we went to look to some families to find some work.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "In the Huta Stepanska.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "My brothers did find work on a farm.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "We were all from a village, like I said, so we easy to find work.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And I went into a Polish family there.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And the woman took me in right away.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "She started questioning me.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "I told her I was Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And she was very nice to me.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "She was a widow with a daughter and a son-in-law and a kid.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "And her husband was killed by the Ukrainian bandits.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "And we were staying there and working for them.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "We were meeting from time to time.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "And this was really a heaven, because we didn't have to hide, just work.",
      "word_count": 14
    }
  ],
