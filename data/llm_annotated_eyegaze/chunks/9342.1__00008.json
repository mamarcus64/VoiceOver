  "sentences_input": [
    {
      "segment_idx": 264,
      "sentence_idx_in_seg": 1,
      "text": "And I had to watch the yarn, when the yarn tore off.",
      "word_count": 12
    },
    {
      "segment_idx": 264,
      "sentence_idx_in_seg": 2,
      "text": "When the yarn tore off, I had to watch it and put it on again.",
      "word_count": 15
    },
    {
      "segment_idx": 264,
      "sentence_idx_in_seg": 3,
      "text": "And after 10 hours, I think we worked, we went to the barracks, we washed, we went to eat.",
      "word_count": 19
    },
    {
      "segment_idx": 265,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 266,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 267,
      "sentence_idx_in_seg": 0,
      "text": "I think we did have shower rooms, too.",
      "word_count": 8
    },
    {
      "segment_idx": 267,
      "sentence_idx_in_seg": 1,
      "text": "Together with the other girls.",
      "word_count": 5
    },
    {
      "segment_idx": 268,
      "sentence_idx_in_seg": 0,
      "text": "Depends which one.",
      "word_count": 3
    },
    {
      "segment_idx": 268,
      "sentence_idx_in_seg": 1,
      "text": "Some were OK, some of them were not OK.",
      "word_count": 9
    },
    {
      "segment_idx": 268,
      "sentence_idx_in_seg": 2,
      "text": "So we--",
      "word_count": 2
    },
    {
      "segment_idx": 269,
      "sentence_idx_in_seg": 0,
      "text": "The ones who were not OK, they were sometimes--",
      "word_count": 9
    },
    {
