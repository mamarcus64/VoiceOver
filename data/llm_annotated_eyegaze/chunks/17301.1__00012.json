{
  "stem": "17301.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 256.2,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "Whatever you have on, you don't want anything on.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And then they took us one by one and they shaved us from top to bottom.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And they then lined us up to go into the shower.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "And they told us, leave your shoes here, you'll find them later, don't have to worry about it.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "And they lined us up.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "And sure enough, we went into a shower and we showered.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "And when we came out, just as wet as we were, there were no towels available to wipe ourselves.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "They gave you a gray drabby like a dress.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "It looked like a sack.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "And that was our dress from then on.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "And we found shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "The shoes were whatever you were able to find.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "It was not you own shoes that you came with.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "Whatever you were able to find, that's what you took.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So that was our indoctrination.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "That was the beginning of our Auschwitz stay.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "OK, why don't we pause here.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "This is the end of tape 1.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
