  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Very, very little.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I, we belong to the-- you know, I get the Jewish newspaper.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And I-- Jewish Appeal and so forth.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "What is it?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "JAH.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah, the Appeal.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The federation or whatever, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "No, I haven't joined.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I go to services, you know, but that-- you know, only on high holy days.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And of course, you know I am-- it's, it's, it's somewhat difficult because everybody in my family is Catholic, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "But all of them, they're not going to church.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "But my wife works for the Catholic church, so she is, you know, she is, she is very much involved in it.",
      "word_count": 22
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, yeah, they know.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "But yeah-- but she doesn't-- you know, we don't talk much about it.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But-- so I have, you know, I have a lot of good experiences.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, with, with Jewish, yeah, with Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I'd like to make-- can I--",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
