{
  "stem": "11723.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Lillie Rubin is a fancy, uh, fashion store.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And she was first, uh, sewing as a-- in the back room.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And then she later became a supervisor and fitter and, I don't know, whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And they had a very hard time, very, very hard time.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And I, uh-- I was, uh-- all my life I wanted to get an education.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And I felt in this country I am going to be able to get it.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "But I didn't know anything about Ivy League or anything like that.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And nobody took the time to explain anything to me.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "In fact, we arrived in February.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "I took them until the end of April or May to get me to a school.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And, uh, I didn't speak English.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "And I had six weeks left of the school year.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "And I decided by the time the school year ends, I better speak English.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I went home with a headache every single day, but I learned English.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And they gave me an IQ test when I  arrived.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "This was a beauty.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And since I didn't know English, I turned out to be an imbecile on the test.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And the, uh, principal took me under her wings and said, these people are crazy.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Why did they give you an IQ test?",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And, uh, she took me around to all the department heads.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And they tested me, uh, like they asked me-- they wrote down, for instance, what's the logarithm of 1,000.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I said 3, and they were flabbergasted that off the top of my head.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It's not a big deal, but they thought it was so great.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And so anyway, I learned English.",
      "word_count": 6
    }
  ],
