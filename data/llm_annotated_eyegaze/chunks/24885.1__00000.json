{
  "stem": "24885.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Just from the boat, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "No, it's-- people come down for a few days, they stand out here.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Most of them go home.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Very seldom do they catch anything.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "That's the main reason.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And just waste a whole day, just stand there.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "You won't to see some action.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "You go out for four hours.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "There are some people with boats here too, but you know, the old story.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And most of them are not captains, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My uncle used to say, by me you're a captain.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "By your mother, you're a captain.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "But between captains, you're no captain.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "That it was his story.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHTER] And that's the same here.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It was fate to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Same here.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "At my age, go to-- belong to the JCC.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We exercise, meet friends, go out for lunch.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Unfortunately, I think as I told you, I'm-- whatever you want to call it punishment or whatever, I don't know for what-- I have a son who needs more supervision.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I feel like somebody asked me, why don't you volunteer more for the hospital over there right now?",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Which I would, but I have my own son to take care of.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah he was born problem with the-- not educable.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He holds a job, but under supervision.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He lives by himself, independent.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Not autistic.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Just not educable.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Very set in this ways.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Independent, very independent.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "You know, there's certain terms for him.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Whatever it is, he's not-- can't fit into to society.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My name is Harry, H-A-double R-Y, Konar, K-O-N-A-R.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Maciejowice, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Maciejowice is close to Warsaw, near the Vistula.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I was born in June of 1921.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I was one of four children.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I had an older sister and two younger brothers.",
      "word_count": 9
    }
  ],
