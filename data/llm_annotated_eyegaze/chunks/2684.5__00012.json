  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Without-- I was so young, and maybe my system is such, mentally and physically, that [PAUSES FOR 3 SECONDS] I'm an individual.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I've always been, and if God give me strength, I always will be.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And when everybody wears jeans, I'll wear tuxedo.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And when everybody wear tuxedo, I wear jeans.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I never felt myself as one of the mob.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So I hate-- my hate is specified.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I don't hate globally, and I don't hate generally.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I hate x and y.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I show my hate, and I give it to them.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And when I played for Hakoah, somebody called me, on the field, a bloody Jew.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And the guy don't speak since then because I broke-- I-- [PAUSES FOR 3 SECONDS] I punched his face.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I broke his face to pieces.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I was arrested, and Hakoah Soccer Club is the witness.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I got that arrested on the field, and I was walking on air between four policemen in Marks Field in Sydney because he called me a bloody Jew.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I don't hold against the Dutch, because the Dutch never been anti-Semite.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "But that guy was.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "So my hate is different from other people's hate.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I was young, my thoughts were different from a person whose whole family was destroyed, whose father, mother, sister, and all, died.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I don't blame him for his hate.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "My hate is different.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I am-- I am a rare bird in the-- in the-- in the German tour.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "If somebody calls me, I'll give.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I don't ask somebody else to do it for me.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And if somebody called me something today, I give it immediately.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "I'm 66, and even when I'll be 100, and somebody calls me a bloody Jew, I still will whack him on the nose.",
      "word_count": 23
    }
  ],
