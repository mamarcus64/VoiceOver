  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "They came 3:00, 4:00-- half past 3:00.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And they start to dancing and drinking, and the-- and the-- and the dust, the red dust going up-- they were very happy, because dancing and kissing, and [INAUDIBLE].",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "But-- but the dust went in their nose, in their [INAUDIBLE] the shirt of white, shirt was red.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I was sleeping.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It was Sunday in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And they took few of our people to dishes, to wash, you know, because there was luxury, food.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And these two people came, and Victor said, if you going to live today, you survive.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Don't ask me.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Everybody's red.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] Well, you know the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And Schindler came with [?",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "Goth. ?] Come on, meister!",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Heh, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Everybody's like idiot.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "This is our fun.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "They won't mind this.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was laughing.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No, he [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Before he introduced, he knew.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He knows me, because he tells me, that's my best painter.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I don't know this is sympathy or not.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "He was so clever, a [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You know what is a [INAUDIBLE]?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] [LAUGHS] He was so clever, you cannot cheat him.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was not possible.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He knew everything better.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I was straight honor.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "If you lied to him, you were finished.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS] What I remember of her, I cannot believe what-- I don't know, I guess-- I cannot believe what I have [INAUDIBLE] from him.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I wanted too much for him-- from him.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] So go on, maybe.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I tell you how we start.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They took me from-- because we've been together with my wife.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And suddenly, they took me, and the wife stay there.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I didn't know where I am going.",
      "word_count": 11
    }
  ],
