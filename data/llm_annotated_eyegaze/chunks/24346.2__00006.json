{
  "stem": "24346.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I told them, you know-- people who survived, and they said, we remember a house there rented by-- bad, bad stories.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Bad stories, very bad stories.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I could start telling now from-- this is what I heard, because--",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Because we were separated, and no way we could get together.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I spoke to people after the war, and they remember, they asked the Borensteins.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They got my whole family left, I said, from Lodz to there, and they rented a house.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I told them, on the [INAUDIBLE], because I was there, too.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I travelled back and forth a few trips, but then I was stuck.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "But I was there, so I learned already who was where.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And they said, yes, there was the Germans once came and took everybody, all the Jews on the market, an open market.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And one cousin of mine, female-- that uncle's daughter, who married a fellow by the name of Yehiel Feingold-- They said, women on one side and men on the other side.",
      "word_count": 31
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And this was the prettiest girl that you could see.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And the German officer said to her, du, kommen hier.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And he started dragging her.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "She ripped out her arm, went over to the men's side, and grabbed her husband around the neck.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "The Germans shot her from the back, dead, right then and there.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "I know, my brother-- what I told you, Jacob, they took him to a camp to work.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "That was all things that I heard after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "It happened early in 1940, it happened-- took him to a camp to work.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I have never seen him since.",
      "word_count": 6
    }
  ],
