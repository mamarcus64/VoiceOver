{
  "stem": "13655.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "I broke my arm, and I [INAUDIBLE] family.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "My wife is not alive.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "My children-- Who said that?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "A lot of people.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You cannot blame it, because there was a run.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was a very solid police, and the Gestapo was watching us very close.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, because [NON-ENGLISH], the uprise was in Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And they was [? watching-- ?] they was thinking maybe this is going to be also.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "What can I tell you?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "About 2 o'clock, they took us to the train, five people in the row, armed.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they walked with us.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They pushed us in, in the train.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "That time, in the train, we came in.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "My niece was separate.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "My nephew was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "A cousin was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "The son was with me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And we came in.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And the window was closed with metal-- not with wire.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "No more wire-- a small window and a metal plate, with heavy bolts.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And we got this-- we got-- we were thinking, how can we do this?",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "How many people in the train?",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In that train was, they expect--",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "It was about 60, 70 people in the wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was the cattle cars.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It was prepared for more people, but a lot of them was hiding.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They didn't come out, all of them, to the-- to the transport.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I was in the train-- me, and my nephew, my cousin, my friend, and another 60, 70 people.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "When we came in, we got disappointed.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It's no wire by the windows.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It's metal.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "One guy was so strong, like a Superman.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "He broke up the metal bolts.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And one guy, his brother said, I'm going to jump out.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I'm going to try to open the door.",
      "word_count": 8
    }
  ],
