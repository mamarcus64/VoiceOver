  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And we children tried to find some-- some-- something which was still growing, grass.",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "But even there was no grass.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "It was a severe winter.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "Sometimes we found the [NON-ENGLISH], the-- how you call it?",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "Off the grass, which is inside.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The part that is inside the earth.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "The part that is inside the earth.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes we were lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "We found something we could eat.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "The hunger was undescribable.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "I remember people who came from Hungary and had some golden rings, which the Germany and his great cowardice, didn't succeed yet to take away, took their golden rings and gave it just for two spoons of soup.",
      "word_count": 38
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "I remember--",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
