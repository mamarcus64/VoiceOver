{
  "stem": "3453.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE], they have names for it.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "I don't know in the English version how is it.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "When I came to this village, I came to my immediate commanding officer and with tears in my eyes, I said, I left my sister, and she will not know.",
      "word_count": 30
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She'll think that I am-- I am killed.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "How can I let-- how can I let her know that I am fighting, and I am with the Partisans?",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He said I have-- I have a solution.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We are going to stay in here for two, three days.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I'll give you my adjutant.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I'll give you my horse.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Go back to her.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Tell her what's happening.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And that's the story.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I went-- I went back.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "It took us a long time.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "It was 50, 60 kilometers on a horse.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "It was a long way.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "We came to the village.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "I came to the woman.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I-- I-- we go into the house, and I said I'm going to fight.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I didn't have my gun yet, but she saw the other guy with the gun, with the horse.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "She knew that I was going to fight.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "If something will happen to my sister, I'll pay you.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "I'll burn your house, and I'll kill you.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "She knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "I meant business.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "And the-- the-- I made my point straight and was clear.",
      "word_count": 11
    }
  ],
