{
  "stem": "16792.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And my mother was born in Tarnow-- also Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And the reason they meet is through a shadchan-- we're calling it a shadchan.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "It means a person which put together two people.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And, uh, they didn't meet before the wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "This is the way the very religious people do.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And it was make, they got the wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And I was born in 1921.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "The wedding was in 1919.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 4 SECONDS] And, uh, we have always got maid in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Because in-- in this particular part, you need to have a maid.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "If you don't have a maid, you must bring your own water every two days in the house.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "We have got in the corner, special bowl, special maid.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And the maid bring, or we have got a special woman which bring in twice a week, three times a week, water from-- from the-- from the main station, from the water station.",
      "word_count": 33
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And the water station was around half a mile, a little bit more than half a mile, from our house.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And this is the way I was born.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And in our congregation, and the-- and the religious Jewish people, you start school when we was three years old.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And, uh, I started before, because my father teach-- excuse me.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "[DRINKS] In three years old, I was in the Jewish school.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "And my father paid a special person which come to the house, pick me up, bring me to school, pick me up from school, bring me home everyday.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 3 SECONDS] And school was when I was young, three years old, until five.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "We was going to school.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "They pick us up 8:00 in the morning.",
      "word_count": 8
    }
  ],
