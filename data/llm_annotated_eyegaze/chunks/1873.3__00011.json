{
  "stem": "1873.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "Can still-- and that time, Belzec didn't function anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "But cremation did go on from the graves.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "They opened the graves.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "But it was Belzec functioned till the end of 1942.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I finally arrive to Izbica.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I go down-- go to our home.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He forgot to tell me, Kraus, that we are moved to another place.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I knock on the door.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I hear a voice.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Who is it?",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And I didn't recognize him.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Immediately, I said, it's me, Toivi.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And he said, [NON-ENGLISH], you dirty Jew, run away.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Get out of here.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You don't live her anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Please, tell me where-- where we live.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Oh, in Schneidmesser's house.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Schneidmesser, the same place, where I used to live.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "There were shutters.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And I put my fingers behind the shutters and knock on the window.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And the light was still on.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I hear a voice.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Who is it?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And I say, me, open.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I hear, immediately, my brother is yelling, oh, Toivi, Toivi.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And they open the door.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I go in.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And my father was pretending he doesn't cry.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I-- He turned his face.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And my mother-- and I was most happy to see my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And we talked, a whole night, practically.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I had here-- because, in the Jewish part-- portion of the jail, I was sleeping on the floor.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So I had here, you know, like you have a wound.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You have, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "It was very bad, on both sides.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Because I was sleeping on the-- a hard floor.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So she looked at this, my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And later, she takes an envelope and handed-- and my picture, with a black piece of a-- fabric.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And it-- and she told me to read the piece of paper.",
      "word_count": 12
    }
  ],
