{
  "stem": "979.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And she says to me, now I'm all alone, I say, you-- I say, I'm your sister now.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "I say, we're sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And she says, that's why we're so close up til now.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Even if she's in Israel, we went through hell together.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And-- and they went.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "We didn't know until-- because we found out from them.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And the-- the worst part was that when we went back to Greece-- see, I'll go backward because it relates with the story.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "When we went back to Greece, and one of the girls who made it told us, you know your cousin Frida?",
      "word_count": 21
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "She says, she didn't have to go to the gas chambers.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "It's your cousin Nita who had to go.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But they-- she decided to go and die with her sister.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And she gave me the place.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I was the one to go to the gas chamber.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "See, she wanted to die with her sister.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "She let that girl come out and stay alive.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "She says, that's why I'm here.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "So you see, we learned some one to the other what happened.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "So-- so-- and then-- then as time was passing already and we were giving concerts.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And and one day-- oh, then they needed a double bass very-- very much.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "They said the double bass is important into an orchestra.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "We had a fantastic cellist.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "She was from Berlin and she-- now she's alive.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "She just came here to give a concert, and I went to-- to see her, you know, with the English chamber orchestra.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "She says, funny how the world is small.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "When I saw they're playing, I had-- because my son plays with the opera, played here at [INAUDIBLE], he's a violist.",
      "word_count": 21
    }
  ],
