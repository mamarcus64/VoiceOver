{
  "stem": "23579.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how they lived.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "They didn't die from hunger.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I think they were working on shuls.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "They were working on dresses.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And many, many didn't work at all.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yes, was movies.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Three movies we had in Novogrudok.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Three movies.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "We had the theater who once in a month, they were coming.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Not Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "This come from Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It was coming Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "It was some life.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "But I didn't belong there.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Because this was in Jewish language.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Probably, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "But I was not into the library.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I went to the Polish library.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Because in our school, where there were the 3% Jewish people, they were asking us not to talk Yiddish, because of the language.",
      "word_count": 23
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We were talking the language.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "This was like a [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "It's not a clean Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And they were making that you have to improve your language if you want to go to school.",
      "word_count": 18
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "So there were reading enough Polish books.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "We had libraries in the gymnasium.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "And we had for this week, we had to finish two books.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "What would you say the relationship, generally, of the Jewish population was with the non-Jewish population?",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Not so good.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Not so good.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I will tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I know the non-Jewish, they hate us.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The Polish people, they hate us, the Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "They were saying, heh, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "You came for [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "You came to beg, to beg something.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "What do you want to beg?",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "You want money?",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "Go to Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 10,
      "text": "You don't have to beg us for something.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "There was [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You know what is a [NON-ENGLISH]?",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] is now you have Blue Cross and Blue Shield.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "In Poland you were not paying for that.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "You had.",
      "word_count": 2
    }
  ],
