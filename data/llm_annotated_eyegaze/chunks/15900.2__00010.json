{
  "stem": "15900.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "They came in, the Russian, and they arrest me.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "And they put me in Bialystok in prison.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "I was sitting in prison.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "I was tortured, tortured you'd never believe.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "They want to know why I register to go to Germany, you must be a spy.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 14,
      "text": "I said, a Jew is a spy?",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 15,
      "text": "Day and night, they took me at 12 o'clock.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 16,
      "text": "We was in a cell, 40 people in a cell like this.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 17,
      "text": "And four beds-- everybody-- unbelievable situation.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And they told me you are a spy and this.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Later on--",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "In Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I asked for a Polish translator.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "I don't want it in Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "I don't speak Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "But anyway, later on they got me a Jew, a Russian Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "He was worse.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "He was a Communist.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "The worst-- worst.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I don't want you.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Go to hell.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "If you want to kill me, kill me.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, they tortured me.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "I was blue-- 12:00, 2 o'clock they took me out.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh I was there-- maybe for weeks they were questioning me.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Later on, somebody came in to the-- our cell.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you know your brother is next door in the cell?",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "The brother who was at the wedding, his wife and-- they went through the border with the children, but he was arrested.",
      "word_count": 22
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And I said, my brother was arrested.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And-- and-- and-- and I went out to the window.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "And I see they're walking around like a--",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "To give them exercise.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And I started to scream, Avraham!",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Avraham!",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And he recognized my voice, as my brother Abe, he was named.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And he was stalling.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "He was going back and back to talk to me.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "And the guard, son of a gun, get out of there.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "We're gonna put you in solitary.",
      "word_count": 6
    }
  ],
