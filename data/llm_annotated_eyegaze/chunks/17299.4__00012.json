{
  "stem": "17299.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 67.8,
  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "But there were not enough washrooms to wash properly to wash up and to the toilets.",
      "word_count": 16
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "So half could go to the toilets and half to the washroom.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "Because there was not enough at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "Then you went and had to go for roll call.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "You would stand for roll call for a while-- a lot of beatings, too, in the roll call.",
      "word_count": 18
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "The small ones had to be in the front and the bigger ones in the back.",
      "word_count": 16
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "And since I was wearing glasses, they told me, never stay in the front because they'll punch your glasses right in your eyes.",
      "word_count": 23
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "5:30.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "We would get some coffee.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And then we was-- went out to work.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I had-- they were expanding the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I had to work on the-- I don't know what's lorries in English.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "But it's we had to load trucks-- trucks and trolleys and push them on the-- in a camp to make the roll call count bigger and put up a fence to make the woman camp bigger.",
      "word_count": 36
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "When I worked maybe three or four day in the camp, I got the first surprise.",
      "word_count": 16
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "A few hundred women were chased out the barracks and had to strip in front of us.",
      "word_count": 17
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And they were standing and delousing.",
      "word_count": 6
    }
  ],
