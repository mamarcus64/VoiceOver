{
  "stem": "471.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "She tried to educate us.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I was, you know, the youngest.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I was the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So I cannot say.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Because if I say anything, and my mother said, right way, hey, give it to him.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "That was her discipline, huh?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, oh yeah, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I was getting from my mother too.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Because I wasn't an angel.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Don't get me wrong.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "You see, I could put on brand new shoes, and this is valuable, and go out and play soccer with the shoes and beat up the whole shoes.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So when-- when-- when it comes sometimes twice a year, we were going to the synagogue.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I had to have nice shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I had to be nice dress.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "But she was proud.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "She was proud.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Because when it comes-- we were not religious.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My father, they-- they were-- the home was kosher.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Out-- outside the home, nobody except my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "But she was-- she comes from a religious family, my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "But not my father at all.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Did you have Shabbat dinners?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Mm, well, we knew it's Shabbat.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But nothing-- nothing-- nothing special, what my father had--",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Say that-- what?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Yes, she lit candles every Friday.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "As long she had the candle, even in the ghetto, she wouldn't buy bread.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "But she bought candles to lit the Shabbas.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "But that doesn't mean that we had food, Shabbas food.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "OK, Friday night, they had usually big dinner, big thing.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "No, we didn't want that.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "We had some fish, cakes, and coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And that was plenty for us.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Nobody wants to eat the whole thing.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes my mother used to say to my oldest brother, who was much educated, in-- in Hebrew--",
      "word_count": 17
    }
  ],
