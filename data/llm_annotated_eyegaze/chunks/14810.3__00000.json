{
  "stem": "14810.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "May we start?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Can I use the telephone?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "That would interrupt.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So, and I was laying in that crater, and I remember I was in a shock-- in shock, and the buddy, next buddy, he saved my life.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I didn't even know it.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He looked at me and my-- my shirt was soaked in blood from my-- I was bleeding.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I would have bled to death.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So he-- I remember he turned me on my belly.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "He tore up the shirt and put a-- what do you call it?",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "A-- tourniquet.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Tourniquet on my neck to stop the bleeding.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And that probably saved my life.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And I was laying there for several hours.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And I was already considered a not heavy, not severely wounded, but many of them lost their legs, their limbs, and everything.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Trucks came and picked them up.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And my buddies from my kommando, they made a makeshift stretcher, and it brought me back in there because we had to walk almost [? 45 ?] miles, and I wasn't able.",
      "word_count": 32
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And they brought me, took me into the-- back to the camp at Buna.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Buna had a dispensary.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "They called it a dispensary, and they took me in there.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And I remember it was already filled up with-- with wounded and half-dead.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And I was laid-- that was on a Sunday.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "I was laying on the floor, because they didn't have no room, till Thursday.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I-- in the meantime, I got infection.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "I remember I-- I couldn't even speak.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "I couldn't drink.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't take anything.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "It got infected.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Finally on Thursday, the doctor-- it had one doctor, Jewish surgeon.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "His name was Grossman, I remember right now.",
      "word_count": 8
    }
  ],
