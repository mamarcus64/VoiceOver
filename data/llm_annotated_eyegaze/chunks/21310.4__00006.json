{
  "stem": "21310.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "But she was trying to find the, these smugglers and the, the hole.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And all of sudden, the Germans-- she heard the German motorcycle.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "So she, she ran.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And she ran into some building that was bombed out.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And she fell into some kind of a hole.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And there was, was a puddle.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "It was in November.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "So anyway, she, she fell into that hole.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And the two Germans came with the flashlight.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And they were going, you know, back and forth with the [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And one was saying to the other, I, I saw her.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I saw somebody run.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I saw.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And my mother was just kind of squeezed at the, at the wall, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And they were just about above her.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't look straight down.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And she said she was praying.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "She said, if there, if there is a God, please help me.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Please help me.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Because, you know, nobody will ever know where I died but tell my child and my husband.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, so apparently God helped her.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't, didn't find, didn't discover her.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And then she made her way to, again, some Gentile friends.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "No actually it wasn't Gentile.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "They were-- the, the woman was Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "But she was married to a non-Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And she never went into the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And her husband had-- was an officer in the Polish army.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And he was in a POW camp.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "But she had some kind of a lover, another Polish man.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And he was helping out with the ID cards, with the very false ID cards.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Anyway, so I was out.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "My mother was out.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "She was able to get-- rented peasant's hut, half a hut.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And there were just rooms, a kitchen and living and, and another room.",
      "word_count": 13
    }
  ],
