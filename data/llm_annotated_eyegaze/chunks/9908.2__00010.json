    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] We were not hungry as we'd been in the further times.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "We all went out to work.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And in the evening, they took us back.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And in the next morning, the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "One thing-- we didn't work on Sunday-- Shabbos we did.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "That's what the Germans for.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "[DRINKS]",
      "word_count": 1
    }
