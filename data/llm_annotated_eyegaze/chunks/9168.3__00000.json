{
  "stem": "9168.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I arrived in Nuremberg on November 6th, 1946.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, on the way there, the plane landed in Frankfurt, and some military officers came on board to try to get me off the plane to work on other, evidentiary hearings involving the trials in Frankfurt.",
      "word_count": 40
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I had a little verbal tussle with them about getting on to Nuremberg, which was where I was going.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I actually had to get to a point and say, I have a signed contract to go to Nuremberg.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Nuremberg, or send me back to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how I had the nerve to do that, you know, but I did, and I got to Nuremberg.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "It was a bombed-out city.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Totally cold, ice cold, snow.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And I was assigned my first home in Nuremberg, which was on [?",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Beulah ?] Strasse.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "It was a three-bedroom, ordinary, two-story house, which I-- which I was-- I shared for several months with one young British woman, and one young Frenchwoman on the Allied payroll.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "But they were not court reporters, different categories.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And we were picked up every morning at our front door by-- which was the order.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "We were-- we were really restricted and limited.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "We had no freedom, because of the Nazi fanatics who were still around in catacombs in Nuremberg, and the threat of being killed, bombings and shootings, which had already occurred in Stuttgart.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So we were picked up every morning at our front door by a displaced person who was on the Allied payroll.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He usually came in a German car, and drove us directly to the iron gates of the Palace of Justice, which were guarded by United States Army personnel carriers, US troops.",
      "word_count": 31
    }
  ],
