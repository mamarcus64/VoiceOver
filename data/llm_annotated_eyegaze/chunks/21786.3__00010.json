  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "His name was Stein, the same as my mother's-- in my-- my-- my-- good slip-- my wife's family, S-T-E-I-N.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And the person who was responsible in Theresienstadt, his name was Edelstein, E-D-E-L-S-T-E-I-N.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "He was a great man who simply shielded and saved anything and anybody who can, and who mostly shielded the young people.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And due him-- he did not survive-- but due to him and who followed then him as the Chief of the-- Chief of the Council of the Elders, some people, some young people survived even in Theresienstadt til the end of the war.",
      "word_count": 47
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My parents came about not even a month later after us.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And Eva's mother was in the same transport and as Eva and a vignette.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "The reason how I justify that I want to join my bride for the SS--",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
