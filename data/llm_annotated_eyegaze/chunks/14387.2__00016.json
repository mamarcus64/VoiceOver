  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "They were going to take a boat up to the north part of Norway and they could leave the children with a maid or somebody.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But they made a suggestion that they would send the children up to a little farm, a little resort farm that was not too far outside of [INAUDIBLE].",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And they said would you like to go with the children and stay with them?",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They said, we can't send them alone.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Would you like to go and stay with the children there for a couple of weeks?",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And you'll have a vacation.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We'll pay for everything.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And it's close enough that Michael could come over the weekend and stay with us.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And oh, gee, that would be-- why not?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Why shouldn't I do that?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "So--",
      "word_count": 1
    }
  ],
