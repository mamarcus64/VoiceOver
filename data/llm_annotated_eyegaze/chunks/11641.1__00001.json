{
  "stem": "11641.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was-- it was a custom in my family that always we had somebody from the small towns, and one from my mother's side, a relative, and one was from my father's side, relative.",
      "word_count": 35
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "As soon as my father saw to it that they learned their trade, the next couple came in.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So that's the way it was brought up by us.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "That's the way it was.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Clothing.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He had a store.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "In Chorzow, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember in summertime was something unusual.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We-- my mother packed some sandwiches for us, and in the summertime, one time I remember we went sort of like an outing, but before work.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We went-- was-- in Poland, it was named [NON-ENGLISH], means the sort of a-- sort of small mountain of-- [GERMAN].",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It was a German name.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We went to eat in the morning, and then we all proceeded.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "My father went to business.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "My mother went home.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "It's-- this sticked in my mind long time.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And that's-- I mean, this was unusual, but it, it happened.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "Normally, we went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "We all walked to school, and my father went to business.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And my mother was at home, and took care of all of us.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I went to-- in the public school I went to-- actually, it was a Jewish public school, but it was a public school attended only by Jewish children.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "[SIGH] I really wouldn't tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "But all, all the children-- all the children-- Jewish children attended the school.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And if you were more affluent, after a while, you could attend private schools where you were actually mixed with non-Jewish children.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Around 30, must have been.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Must have been.",
      "word_count": 3
    }
  ],
