{
  "stem": "7777.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "Of course, they just allowed the people what they have the [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "Only in this little ghetto, we was hiding.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "We was sleeping in a shed.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "Rain, got wet-- only we stayed over there a little while.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "Over there, in this Judenrat, they have one educated man in Hebrew, a high scholar man.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "He called-- the one Sunday, he called all the people from this.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "And he told us, if you running out from the ghetto, we endanger us.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "He told two stories.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "If man is riding in a boat on the ocean, and he have a nail, and make it with the nail a little hole, this little hole the water is coming in.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "And everybody is cry [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "It's the same thing.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "If you run out one, you can spoil-- they can kill the all 600, 700 people over there.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "Later he said another story.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "I will not forget the stories.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "When [NON-ENGLISH] make the [NON-ENGLISH], his God told him to bring in all the animals, two in the [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "And the question-- the wild animals-- how come they don't eat up the animals for they was going in a [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 46,
      "text": "The answer is, he said, if they have [INAUDIBLE] them, they don't have in the mind the other one.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 47,
      "text": "They will save his life, he don't remember the other thing.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 48,
      "text": "Same thing with the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 49,
      "text": "The Germans-- they not getting very bad [INAUDIBLE], going back from Stalingrad.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 50,
      "text": "This was already in the winter time-- September, October.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 51,
      "text": "It was winter over there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 52,
      "text": "This was in this time.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 53,
      "text": "Is they have to do it themselves, and they will forget on us.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 54,
      "text": "In another [INAUDIBLE] the [?",
      "word_count": 5
    }
  ],
