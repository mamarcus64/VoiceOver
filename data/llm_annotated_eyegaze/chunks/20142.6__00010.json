  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "And people started to leave the bunker, because it was impossible to-- there was no breathing air whatsoever.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And when they-- when we got out of the bunker-- and then these people somehow had two little children, five and seven, with them.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "And I don't know how did they ever survive all this time.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "But the Germans send in-- after we all got out, the Germans sent in two dogs.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "And the dogs didn't get out of the bunker.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "The gas affected them, the dogs, and they-- they died.",
      "word_count": 10
    }
  ],
