{
  "stem": "16792.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Eveyday in the morning, it was 6:00 in the morning, I wake up.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I took him to the mikvah.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And from the mikvah, I took him to schul, everyday to schul to pray, and then I bring him home.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And, uh-- he-- I was the only person which did that all the time.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And when I left, and I was older, and I left, my brother took my place.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Everyday, in the morning.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I was very religious.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I got, uh, sight [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And I was very religious.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And, uh, until I-- I became a little bit less religious when I was older.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "But in the time when I was in school until five years, and then they transfer me to a different rabbi when I was older.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "When five years old, my father made a party.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He calling it the [HEBREW] seder.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "[HEBREW] seder is-- [HEBREW] means, this is the fifth book from Moses is [HEBREW].",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "[HEBREW] seder.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He made a party, and they asked me, the rabbi asked me questions.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And I answered, but [INAUDIBLE] all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "After that, they transferred me to a higher rabbi when I was five, to a different rabbi.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And I learned more, a little bit more.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Like you go here to the school, the regular school, and you learn when you are 8, and 7, 9 years old.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "We learned this when we was five in Jewish religion.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And when I-- when I was seven, they transfer me to a higher rabbi.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And I was very, very, very religious.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "I was religious when I got seven years old, I was going to two schools.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "When I was seven years old, I was going to the city school-- we calling it the Polish school.",
      "word_count": 19
    }
  ],
