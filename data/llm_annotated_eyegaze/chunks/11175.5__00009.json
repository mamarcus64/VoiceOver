{
  "stem": "11175.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And she gave me a piece of bread.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And she said, you know, shh.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Don't-- run away from here.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "I don't want to see you.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "I don't want to hear from you.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I went away from her.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "How long can you walk, you see, after being shot, and wandered, and with that blood from the mouth?",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I walked a few hundred feet away from her, and I came over to the other side from that forest.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I laid down, until I said, well, I'm going to lay down.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And if I'm going to wake up, and I'm going to go back to this, I wouldn't know where I  am.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So I know-- I-- [STAMMERS].",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "As a soldier, I knew a little bit, the strategy, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I took a-- a piece of wood and put it in front.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I-- I laid down with that hat here.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "It make up something in the top.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "If I'm going to wake up, I have to go in that direction where the wood-- the piece of wood is, because it shows me to go there.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I lay down, and I fell asleep.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I was sleeping there a few hours, this looks like.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I got up, and I started to walk.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I was about more-- almost about 14, 16 days there, not having food, not having water, not having where to sleep, and nothing, and swollen.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I was swollen.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "This picture you have here-- this is already after-- after this.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And at night, I went into some of the-- in the-- in the-- you know, into houses.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And I asked for help, a piece of bread.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Some of them, they gave it to me.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And some of them, they said, run away.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I don't want to look at you.",
      "word_count": 7
    }
  ],
