{
  "stem": "2074.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I want to find you.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "So I got that letter.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Can you imagine how I felt?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "A first cousin of mine-- she was a librarian.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Her husband was a Jewish writer who wrote that article for me in the paper.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And then she found out the family in Duluth.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "I had other relatives on my father's side.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "The-- the-- the brother did not live anymore, but five children is married.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "They all took interest, pitched in, sent us the papers to Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And we left Germany in 1947.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We got in to Duluth, Minnesota, December, Christmas Eve, 1947.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "With my husband and my son, 18 months old.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The biggest devil in the world.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "On the boat, I was sick.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I had to land with him in a hospital, because I couldn't control him.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He was on the run all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "He ran all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So yeah, and then without knowing the language, we traveled all the way from New York, changing trains.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "There's no planes at that time.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "There was times that they filled up the train, that we had to stay all night, hold the baby on the train overnight, coming out from the displaced person camp.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in the displaced person camp from-- we got-- we got there December in '45.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And we left December, '47.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I was supposed to go on the Exodus boat.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My husband was active in that deal.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "The Exodus boat-- they don't accept me because I had a baby.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "My husband wanted to go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "He didn't want to go to-- to the States.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "But my family insists.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "That cousin of mine wrote a letter to him and say, look, if you're from America-- Israel, the situation is very bad.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Israel in a state of war.",
      "word_count": 6
    }
  ],
