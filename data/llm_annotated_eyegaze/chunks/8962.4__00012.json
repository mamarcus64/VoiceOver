{
  "stem": "8962.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And in those days, you know, some girls married not only out of faith, but out of color.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So this guy, he was Jewish, he was white, and he lived in Baltimore.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "What more could we ask for?",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "We had just a wonderful time.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It was the year we were married 25 years.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We had a party.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We had an engagement party.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And we had the greatest wedding ever, with two rabbis and a cantor.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "But it didn't last.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "She had two sons.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Wonderful boys who we adore.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And after 22 years of marriage, she divorced her first husband.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "But she's married again, out of faith, to a man 14 years her junior-- he's 14 years younger-- whom we adore, who is wonderful.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And you all came to Phoenix together?",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She came first, with her first husband.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And a year later, we decided, what are we doing in Baltimore when they are here?",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We want to be a family.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "So we came to Phoenix.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I don't think the young ones are here.",
      "word_count": 8
    }
  ],
