{
  "stem": "14463.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And I'll tell you about those interests whenever you want.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Certainly, certainly.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Shall I start with my father, or grandfather?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Now my grandfather was a Hungarian Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He was born in a city on the border in Poland, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We were there anyway.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "After the war, we visited.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And he came from an extremely religious family.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And the name is Schreiber, right?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Schreiber means writer, poet, writer.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "We can trace the Schreiber family right up to Hasam Sova Schreiber, which was the foremost rabbi at that time in Middle Europe.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "This man had a Yeshiva in Frankfurt-am-Main with 600 pupils.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And he wrote a lot of books on Jewish law and so forth.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And he's very well known in the-- in the Hasidic Jewish world, as the most important man of his time.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And this went through from generation, to generation, to generation, until it came to my grandfather, which I knew so very well.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "My grandfather was a very religious man.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "He was a Jew with a long beard.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And he was wearing a kittel in the Yom Tovim.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "He was wearing a [NON-ENGLISH], with a shtreimel And he brought up the children the same way.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And he was an extremely religious man.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And he was also, if I may say something-- speak about him now before I speak about my father-- that he was the representative of the Jewish community, in his little city where we lived.",
      "word_count": 35
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And on top of it, he was also a very able, and a very successful businessman.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He was called the King of Wheat in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "He and his three sons and his son-in-law, were in business together, buying and selling wheat through all of Europe.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And also they were selling food for carps, you know?",
      "word_count": 10
    }
  ],
