    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "So I didn't go back to school.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I was there for one semester.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] But in order to learn how to read and write, I would take a newspaper.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Most of the time didn't know what I was saying or doing, and somebody told me to pronounce the words with my mouth right.",
      "word_count": 28
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "So I would sit in the bathroom, look in the mirror so I can see what I'm saying, and for hours I would sit there and read and read.",
      "word_count": 29
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't know what I was saying, but it was fun.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Then I [PAUSES FOR 3 SECONDS] got a job at Thrifty's [?",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Rockstall ?], [PAUSES FOR 5 SECONDS] and-- Were you still on your own?",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was still on my own.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Still on my own.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I lived in-- [PAUSES FOR 3 SECONDS] I lived in somebody's home, in a room.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "They took me in like I was their kid.",
      "word_count": 9
