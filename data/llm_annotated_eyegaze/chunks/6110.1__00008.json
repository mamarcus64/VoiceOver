{
  "stem": "6110.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was in '39 or '40.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I'm born in '16, so how was I? 23, something like that.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "You had to have a reason.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "My mother was sick, that said that sick.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And as sick, she needs help.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "So they had allowed me to be her nurse, taking care of her.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "That's how I got the paper.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And that paper, I gave it to my niece.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And she was there taking care of my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "That was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "A few times, they caught up with me on the road, the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They took me to a police station.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But somehow, I was always lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Somebody was standing up for me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Oh, let her go.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Let her go, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "So I was sneaking a lot of times.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "Once, I was going back, And it was already evening.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Was not dark, but was evening.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And I was going from the ghetto to Skala, you know, very tired, knocked out, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And my husband passed me by on a bicycle.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know him.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "No, I didn't know nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I saw young boys going on their bicycle.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he, he stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And he asked me.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "He said, where are you going?",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I said I am going from the city.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I'm going back.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Didn't know he's Jewish, not Jewish, on a bicycle.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "I said, I'm going from Cracow to Skala.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "He said jump in on the back seat, and I take you.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "So he took me to Skala on the bicycle.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And that's how it starts, the romance, Romeo and Juliet.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "[LAUGHS] And then he tried to help me a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "He tried to help me.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "Tried to help me.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "To sneak in the ghetto wasn't easy.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "It was not easy.",
      "word_count": 4
    }
  ],
