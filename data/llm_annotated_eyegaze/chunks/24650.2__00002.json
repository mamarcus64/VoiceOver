{
  "stem": "24650.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "They need [NON-ENGLISH], all kind of stuff.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He make them.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We had a-- first of all, we had a library, Strashun's Library.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We had a theater.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We had a cafe.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We had, by us, was Advocat Muszkat.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "He maked a special school for children, who the-- were alive and their parents were killed.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "He took them in, with sleeping, with everything.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "He teach them like in school.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And they-- and he makes so that he get the food.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Advocat Muszkat.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Then, what did we have more?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We had partisan, too.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And our ghetto Jewish commandant, inside, helped them to go out.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "In-- What was his name?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Jacob Gens.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He helped them every night.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He would let out, through a second door, 200 people.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "No, we had the police, too.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "He wasn't chief of police.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He was, in Jewish, they called him the Ghettovorsteher.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "He was the person who talked for every Jew in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "But he couldn't do nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The Judenrat-- the Judenrat were separate.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Where my father worked, there was the Judenrat.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And in the other side, it was the police.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The first station police.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We had four stations police.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he was like a-- well, we say here, is in-- in-- in-- in this town, it's a small town, they have a-- a-- how do you call them?",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "A mayor?",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "A mayor of the town.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He was the mayor of the-- of the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But he had to talk to the SS and tell them what he thinks, how it goes.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "No, he didn't tell them the truth, that's for sure.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "He was very intelligent.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He was a maior.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "A maior is a major in the army.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And everybody loved him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So they believed him.",
      "word_count": 4
    }
  ],
