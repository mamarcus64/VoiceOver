    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "But the crew, there was just a few-- a few crew members, not many, maybe 10 or 15.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And they kept to themselves.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And we had a leadership.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They-- they negotiated with the captain everything that had to be negotiated with.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Well, let me now start about the journey.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Well, first of all, there were three ships anchored in the estuary of the Danube at a place called Tulcea.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "You can find--",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Well, that's good place to stop.",
