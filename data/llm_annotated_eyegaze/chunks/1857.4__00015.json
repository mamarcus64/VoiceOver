  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "By that time, he was already taking conducting lessons, also, from Laszlo Halasz, who was the head of the City Center Opera in New York.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 3 SECONDS] And he was a great pianist already by that time.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "And within a couple of years, Lester was accepted to Amherst College.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "And a terrific student.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "And he decided at one point that he wants to become a rabbi.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "And he applied for divinity scholarship from Amherst.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "And this was the first case at Amherst College, first case, that they had a Jewish student going to rabbinical school.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "You know, of Amherst College, which is very WASP-ish.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "And in the meantime, Arthur was also accepted-- while he was at Wesleyan, he was accepted to Curtis Institute of Music.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "And he graduated from Curtis.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 40,
      "text": "And Christoph von Dohnanyi, who is today the music director of Cleveland Orchestra-- Cleveland Symphony Orchestra-- was a German, a German conductor-- he--",
      "word_count": 23
    }
  ],
