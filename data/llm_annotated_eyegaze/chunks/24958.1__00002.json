{
  "stem": "24958.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "He said, he declared that I am full of age.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I got the license as a dressmaker as a master.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And I had a little sign on the door with my name on it.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I was very successful.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Of course, I didn't have no overhead.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I paid no rent.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "I paid no electricity.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I paid for nothing, so I was successful.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "It was very easy.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Mostly friends of my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Dresses, blouses, skirts, no slacks.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "This time, it wasn't-- it wasn't in style for ladies to wear slacks.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Until I got married.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My-- my wedding gown was-- was sewn in my shop.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My girls that worked for me, they sew this gown for me.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Matter of fact, they sewed with some hairs they pulled out, and they sewed.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They said, when you-- when you sew in your hairs, then you get married.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We wanted to get married, so that's what we did.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "It was a superstition, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Now how did you meet your husband?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And what was-- what was your husband's name-- your fiancee at the time?",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "My husband's name was Henry, Henry Rosner.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "He was playing in a very elegant restaurant not far from our coffee house.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Well, my father, once in a while, took us there, my sister and myself, for dinner.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And was starting to flirt, once he found out who I am, and that-- that's how we got acquainted.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "That's how it started.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I was 14 years old when I met my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And then he left me, and he studied in Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "He was in the [? conservatorium. ?] And then he left Vienna, and we are-- he was writing to me.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "I was writing to him, and then he came visit Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And-- and we fell in love.",
      "word_count": 6
    }
  ],
