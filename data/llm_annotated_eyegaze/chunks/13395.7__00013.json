{
  "stem": "13395.7",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And when the British returned them to Germany and they were behind barbed wire in a camp called Emden in North Germany after the British brought all the exodus people back, they were the first ones when Israel became a state to be taken out and taken to Israel.",
      "word_count": 49
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "When my sister was in Israel and mother and I had nowhere to go, no country wanted us, we decided to go to Israel.",
      "word_count": 24
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And we left in-- before Passover, 1949, via Marseilles.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I met my husband there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He was working, trying to get people on the boats.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And we-- he decided when he met me to go on the same boat to Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "His name is Lior, or Lazer was his name, Frieberg.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "His father and his two brothers that survived were already in Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "He lost one brother.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "But two brothers survived.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "So they were already in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "So he decided to go to Israel, too.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And so we had arrived in my sister's area of [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And we lived in Jaffa.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That's where she got her apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Because as a refugee, she got an apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Her husband was in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And she was working as a hairdresser.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And we lived with her.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "She had two rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "So we took one.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And then I got engaged.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "We looked for a place in Tel Aviv, and we found a room.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And I would never, never leave my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "Everywhere I went, my mother always was with me.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "I still was taking care of her every step of the way.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "I provided for her during and after the war.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "If I had a piece of bread, she was getting her part of it.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "Never ate--",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I-- I'm a designer, self-taught, clothes, couturiere, what we call in French.",
      "word_count": 12
    }
  ],
