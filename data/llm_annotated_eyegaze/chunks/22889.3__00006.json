{
  "stem": "22889.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We used to bring, with the horses, the timber to the lumber yard, unload them, cut them.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We used to build pre-fab homes.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I worked for [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "It's German company-- lumber yard.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I haven't received a penny.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I was only compensated for the time I was in concentration camps, which I got very little.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And I got a couple hundred dollars.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I worked for [NON-ENGLISH] Company in Auschwitz when I was in Auschwitz.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And their company paid me a little bit--",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "--nothing to speak of, really.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "This was a forced labor camp, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I worked-- before I went to Hobug, in between the-- the [NON-ENGLISH] company and Hobug, I worked on the railroad first.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I used to unload the coal.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And we used to lay-- fix the tracks.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "Wintertime, we used to travel on the steam-- steam locomotive and clean out the snow from the-- so the train-- the train could pass for miles and miles.",
      "word_count": 28
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "We used to clean out the snow from the railroad tracks.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Then later I was assigned to Hobug.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "I worked for Hobug like this till August 30, 1942.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "We used to travel back and forth every day.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "1942.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The living condition was very hard, because we had-- we were rationed, our Jewish people.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We used to get the-- they used to call [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And the-- and we were rationed.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "They used to get so much bread, so much beans, so much sugar, so much butter.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "It was very hard, because of course, my family, we weren't so bad.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Because we had a lot of friends-- farmers-- which we used to deal with them.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "They used to come to our house.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "Our house was open Thursday with always market in that town.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "The farmers used to come.",
      "word_count": 5
    }
  ],
