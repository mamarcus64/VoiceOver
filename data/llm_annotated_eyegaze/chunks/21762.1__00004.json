{
  "stem": "21762.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "Was a [NON-ENGLISH] guy was in a new truck.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And he didn't had no gasoline.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "So he says to me, give me the gasoline, and I take your family.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "On my truck was 17 people, strangers, just neighbors.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "I couldn't look.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "I says, I got 17 people.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "Can you take them?",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "He says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "Four people can I take.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I says, I'm not going to leave anyone.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Everybody's going with me.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Where I am going to be, they going to be.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I sold him the gasoline for cash.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I sold him the gasoline for cash.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And I went and bought a horse and wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "So I had a horse and a wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "But the wagon was too heavy.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "So at the next village, I traded in a light wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "I paid off a guy.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "He give me a light one.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "And I loaded everything onto the wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "And we go.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "In the daytime, we couldn't go because they bombed.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 14,
      "text": "They shot from the guns.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "They let the place go low and they shot.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "On the road was a lot of people killed.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 17,
      "text": "So we stay in the forests in the daytime.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 18,
      "text": "In the nighttime, we moved.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 19,
      "text": "In the daytime, I went and there was a time when potatoes was already in the land.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 20,
      "text": "I went and brought potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 21,
      "text": "I bought a big pot, a big one with two handles.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 22,
      "text": "And we cooked them in the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 23,
      "text": "And we feed the people.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Stranger people, but they was with me.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I will not leave nobody, my neighbors from where I lived, and other I knew it.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I knew the people.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And that way, I went until Brest-Litovsk.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And Brest-Litovsk was already Russian coming in.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Well, we went through.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "It was no border this time.",
      "word_count": 6
    }
  ],
