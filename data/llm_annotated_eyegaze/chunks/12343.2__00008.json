  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They kill them already on the-- on fields-- how you call it?",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They call it like, like the soldiers stays and count them.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "How you call [INAUDIBLE]?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Ah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] something.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] they counted and take them [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "[INAUDIBLE] come, they take the [? tents ?] out to kill.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "They did daily all the time, every time.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Nothing ?] [INAUDIBLE] killed.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Put them on the wagon right away to burn them.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, always.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "What I think?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I'm next.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "What I think?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "What I think?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "You think I'm going-- it's not just [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't fathom what I think.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "There was more concentration [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Then from this, they-- they started to take out-- take out to work.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "My cousin was still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] They took us out, [INAUDIBLE] to the Germans, Gestapo, looking who was good, take off everything, the clothes.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Then they go around to see how you look.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "My cousin was a little-- actually and before the war-- one foot was a little shorter.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE] limped onto one foot, this side.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "He started to kiss me.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "I'm not to see him.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "On this side, this side.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "Then they figure I'm a good slave for work.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "That's not happened here before.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "They took-- took a-- put everybody in a line and see.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "[INAUDIBLE] before this happened, they count.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "The [? tent ?] [INAUDIBLE], and I look from the side.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "Something is wrong.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "I'm afraid I'm in the [? tent, ?] and they're going to get me out for killing for nothing.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "Then I started myself.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "I tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "Everybody heard the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "I started to take my shoes, my shoes-- tie my shoes, [? whether ?] they are together.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "Then I go on the other side.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "I rescue myself.",
      "word_count": 3
    }
  ],
