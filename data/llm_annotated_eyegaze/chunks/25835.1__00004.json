{
  "stem": "25835.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It was many, many places for skating.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But we used in this time different kind of skate-- everything removable, not like now.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, only or special place-- my parents wouldn't let us to go for unsafe place.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I mentioned you before that Catholic group for performance, something like Christmas carols or performance.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Also this sport [PAUSES FOR 4 SECONDS] and vacation in the, in, in the field with my father who told us about each place, each wood, what is it.",
      "word_count": 29
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "What's the name about mushrooms, what we can take, what not.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "It's-- it's not too much memories, because I was on-- 11 when start to be war.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Usually when vacation was in school.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "School finished, like here, about 22nd or 23rd of June for two months, through first of September.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "To, to the country-- I don't remember, [INAUDIBLE] or somewhere.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember-- in the wood, beautiful places.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Usually, Father took us four.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes Mother came for a short time or our aunt, who was single.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And she was like second mother.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Sonia, and last name Szachowski like maiden name of my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "She was younger.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And we loved her so much.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "She survive.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But she passed away very young, in my opinion, of course.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "She was 52 when she died.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "She was in concentration camp.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "She survive-- [INAUDIBLE] bad memory.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In school, I tell you true-- in, before the war or after?",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Before the war-- everything was very nice for me and easy.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I had older brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They helped if was necessary.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't like to draw.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "When I give money, my brother did everything for me.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] Usually, I had the best gra-- the best grade in school.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "When I finished my seven years in elementary school, it was everything on top.",
      "word_count": 14
    }
  ],
