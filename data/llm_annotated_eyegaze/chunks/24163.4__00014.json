  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Hearing about the undernourishment, having seen some of the escaped and released prisoners, I had put food in the Jeep.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And the moment an American officer saw me walk up to the fence and started to talk to these guys, and he said, whatever you do, don't you dare give them any food because they get deadly sick from normal food.",
      "word_count": 41
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They were just-- their, their stomachs wouldn't accept it.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And they had typhoid.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And they were diseased.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They were so sick.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "They looked so terrible, some of them were just-- they were more dead than alive.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And then some of them died, you know?",
      "word_count": 8
    }
  ],
