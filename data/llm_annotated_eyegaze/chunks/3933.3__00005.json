  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And he was worse and worse and worse.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Until this man find out-- Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Jelinski ?] find out that it was hidden.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "This is a Jewish woman there with a child, and he asked him to move out.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "He said, OK, I will find a place.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "Then the Germans were-- how do you say that, when-- oh my god, they start confiscating apartments.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "They needed it for the-- for the-- for the army.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "They put-- took out-- they didn't even ask.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "They didn't have to ask.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "We are taking this room.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "I want to be available this room, this apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And they were going to-- going to take it.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "Once, he walked in-- OK, they're going to take this apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "One time, he opened the door with the keys.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "He walked in, with somebody-- a little girl-- a girl, bundled up in clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And I look at her, and she's [?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "Fela. ?] We knew each other.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "We were in the ghetto together.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "She was a teenager, and I knew her parents.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We [? around-- ?] happened to be in the same backyard together.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "When we lived in the ghetto, their apartment was there in a compound, kind of.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And I say, [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Fela, ?] what are-- oh my god, [?",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Fela. ?] She-- her parents were also killed in the [INAUDIBLE]-- no, in the ghetto, when they finished out the Jews from the [INAUDIBLE].",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And her mother said, [?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Fela, ?] go hide-- go away.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Go away from.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "They were standing to be placed in the trucks.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Go away-- go away-- go away.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And she went to-- into a big garbage can, she stuffed herself.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "She survived.",
      "word_count": 2
    }
  ],
