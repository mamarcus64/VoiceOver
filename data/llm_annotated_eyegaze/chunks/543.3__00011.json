{
  "stem": "543.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "She does-- she helped me all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "One time I get in a different blood group-- in my arm-- so that I got as if I have A something.",
      "word_count": 22
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They gave me a different blood group.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And I was already gone.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And it was very-- everything was spinning around me.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "And they wanted to see how long it took and how long it would take.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "And then, she let the needle fall out of my arm.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "And the SS was furious about her.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "And she did other things.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "When I had the needles, you know, that was like a-- looked like a burning, you know, like, I don't know what they put in it.",
      "word_count": 26
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "And it was burning and bleeding.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "And you know, and then she came in the night and gave us water, and tried to wash us.",
      "word_count": 19
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "And that was Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "Slavkov.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "And she helped me many times.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "If she was getting a liking to us, I don't know, but she did.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "So later, when I was-- so now, we have to go back when I was in-- when we went out of Auschwitz.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Everybody had to go out of Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I called it always the death march.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "When we went we came out.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Death March.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "The Death March.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "When we-- you couldn't sit down.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't go to the washroom.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing there.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And everybody who sit on the road, they get shot.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "So you were practically walking between dead people.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And they were marching me out of Auschwitz, through the snow.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "We were two-- two days marching, then we could sit down somewhere.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "It was snow.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "It was middle of the snow in the year.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "It-- I was-- I was in-- in-- I was between men, and later it was women and men.",
      "word_count": 18
    }
  ],
