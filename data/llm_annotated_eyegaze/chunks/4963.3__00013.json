  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I was 14, and I remember that I-- since I didn't know anything about sex or about the reproductive system-- here and there, you know, from what we were-- what we heard from other children-- I remember that I got my period there.",
      "word_count": 43
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And I remember sitting on the couch and all of a sudden getting up and there was a big blood spot.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I got up, and I-- I felt so badly, and I took a towel, you know, tried to wash it off.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Well, this-- this mother had a brother, and he was there.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "He wasn't working, I don't know why, but he was in the house all the time.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And I remember that he was fondling me, but I couldn't say anything, you know, in fear that she would-- she didn't know.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "The woman didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "No one knew.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And he told me don't say it to anybody.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, since she was many times in the kitchen, the lady was in the kitchen, the man, her husband went off to work, the children were in school, so there was-- and he was home most of the time, and so, you know, we were sitting on the couch or he would go in the room or whatever and he would say, well let me feel you.",
      "word_count": 67
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He touched my breasts, touched my vagina, and, you know, I couldn't say anything.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Here I was, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I felt-- [PAUSES FOR 4 SECONDS] well, I felt abused, but also I felt rather, [PAUSES FOR 4 SECONDS] excited, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I-- I really-- you know, I didn't know at the time that, you know, it was-- it was bad or whatever.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, I wasn't afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I somehow didn't resist.",
      "word_count": 6
    }
  ],
