{
  "stem": "20800.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Because it was in the territory of Ukraine.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I knew Ukraine always were antisemites.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Nobody they knew that I a Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "But I don't trust them with nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And I was frightened to get friendly with anybody.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I can say something not about my personal, but something what I think, and somebody will go and-- you see from then, from the arresting me and putting me in gestapo hands, I was very, very careful.",
      "word_count": 37
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I practically didn't trust nobody, nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I was frightened.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Because I trust this girl.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "I will never, ever if somebody said that she can give you away, I would have spit.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I wouldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "But that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And since then there is that I learned a very good lesson.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Don't trust nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And that's how I lived for a long, long time.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I didn't trust nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed there for six months.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was in December or January.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Now that was snow.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It was already winter, not even autumn, but winter.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That's about October, maybe November.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was sent to first, that's not only me, 61 women and men were separated.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And we were sent to Buchenwald.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "By train, like a cattle train.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "In one of those-- it was straw.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We would stay in the straw.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "There was very bad conditions.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We have to clean after ourselves, and to throw away the-- the-- if somebody vomited or somebody this, we have to clean after them and after yourself.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "We had a bucket where we did our business.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And that was thrown out when we could, and when it was permitted.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "It was all command.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "What they commanded, we did it, and that was that.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "We were going through Russia and to Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Buchenwald was in Weimar.",
      "word_count": 4
    }
  ],
