{
  "stem": "13258.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "There were cousins, second cousins, and so on, and [PAUSES FOR 4 SECONDS] from her mother's side from the family, not too many survived.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "There are a few distant relatives.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "From my father's side more, because they, some of them, managed to get out, Australia, New Zealand, wherever, Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Can you tell me where you went to school at?",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I started school in that city of Beuthen, which I mentioned once before, where the system was what is called in the United States, separate but equal, which meant since Upper Silesia is predominantly Roman Catholic, all the Catholic kids went to the elementary schools closest to their homes.",
      "word_count": 49
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "For two other confessions were separate municipal elementary schools.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "There was a Protestant municipal elementary school, and there was a Jewish municipal elementary school.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The teachers were being paid by the city.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The teachers were not all Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "In my time, there was one Gentile teacher there.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "The rest of them were Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "There was no-- were no classes on Saturday, in contrast to the other schools where, in Germany at that time, it was a six-day school week.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "From the second grade on, there were Hebrew classes in the afternoon, twice a week.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And from the second grade on, some kids were selected to sing in the choir.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "There were two synagogues, the big one and a small one.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And the big one was a kind of strange set up, with on the one side, women and men sitting separately, and the women on a second elevation.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "But there were-- the choir consisted of boys and men, boys being the sopranos and altos.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "No girls were allowed in my time.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "Later on, I found out after I left, there were some girls.",
      "word_count": 12
    }
  ],
