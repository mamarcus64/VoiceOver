{
  "stem": "5799.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I came to the States, and she's named after my mother and my sister.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And I put her in a dresser drawer.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I lived in the Bronx, in a furnished room.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I went to the hospital-- first I went to the hospital, to the clinic.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And every time there was a different-- a different doctor examined you, and I was extremely afraid of it every time.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I called nurses sister, and she used to tell me, I'm not your sister.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And but after a few months I had a very limited vocabulary, but I understood everything and I spoke.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "So evidently I had some kind of a ability to languages.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And then I said, I'm not going any more in the clinic.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "I don't care if I have the baby in the street.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And I was sitting in the Bronx in Crotona Park, and I had two papers with me.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "One was the PM, and the other one was a Jewish paper.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It took me long to read it.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And I was sitting there and said, what am I going to do?",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And a man passed me by and he says to me in Yiddish, are you a refugee?",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And he says, I am a former GI.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I was a liberator of Dachau.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I said, right.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "We started talking.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "I said, and what do you do?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "He says, I am a doctor, and said, what are you?",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "I said, and I am pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And he says to me, my name is Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "Fand, and I have an office right here not far from Prospect Avenue.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "I said, yeah?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "He said, are you registered in a hospital?",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "He said, then where will you have the baby?",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "I said, I don't know.",
      "word_count": 5
    }
  ],
