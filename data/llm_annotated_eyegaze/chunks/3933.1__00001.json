{
  "stem": "3933.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My father was a carpenter, and circumstances-- when I say circumstances, Vilna belonged to-- started to belong to Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And my father was in the other side in Vilna, and I was in Kovno with my parents-- with my mother.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Later, we immigrated to Vilna.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "My father was involved with another woman, and this was effect of this whole life, the poorness and the broken home.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I have no dates.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I was a very-- very young child.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I have no dates, no years, no specific dates.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Then we immigrate.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Well, my-- my father suggested we try another city.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We immigrated to Rovno.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Oh, I already said I was born in Rovno.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Can we make-- can we say that?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Can we redo?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "When-- then-- we-- I was-- then-- we'll make it as I was born in Rovno, because I was-- we emigrated to Rovno.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I was a young girl, but all the things happening-- my marriage, my son was born, and everything-- then I, consider-- in my passport, I consider-- because I wasn't sure where, then I have to make that one city.",
      "word_count": 39
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Then I consider Rovno.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Someplace in Russia.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Someplace-- someplace in, let's say, Lithuania.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My father never hesitate, or I don't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Someplace in Lithuania, I would say, in Kovno.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "You will fix it, John?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I have to say that we-- we moved to Rovno, and I was born there.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Is it OK?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I said [?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Litvia. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I have to stick with Rovno.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I spent my teenage years there.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I married my husband there.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "My son was born there.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "The-- the Holocaust happened there, and my passport-- there's got to be a specific place, and I made up, and I stick with it.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When we came to Rovno?",
      "word_count": 5
    }
  ],
