{
  "stem": "11167.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "You know, you had high temperatures there.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "She had to go, because somebody reported that she has typhus.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "She has to go.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I made arrangements there.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "In the night, I will come.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "She must get at-- we will get her.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And we did get her.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "We got her back.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "We jumped out to get her back.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Of the window, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Then I-- from our town, my town was one older person who knew me from home.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "But he was friends with a doctor from-- you know, in-- in Russia, every district has a doctor.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So I did ask him to get me a certificate because I can't work any more in the factory, because I couldn't take it anymore.",
      "word_count": 25
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "My hand was in blood already.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "You know, so-- so that's the end of  me.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And I had arranged with somebody that would take me for work, privately.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And the--",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Sewing.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "She used to sew and sell it on the black market.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I used to help her with the sewing.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "She was from Bialystok, also a Jewish woman.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "How she did arrange herself, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "She didn't work one day.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "She worked privately.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "She was a sick-- sickly woman.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "And I did get this certificate from this doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And they gave me for six months not to-- not to work in the factory.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And my card for the bread still was-- I still could receive my bread.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Then you don't get.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "But because I was-- had from the doctor this certificate, they asked me to-- for six months.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "After six months, it was already going into the war.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Already, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "We did hear already they took this place and that place.",
      "word_count": 11
    }
  ],
