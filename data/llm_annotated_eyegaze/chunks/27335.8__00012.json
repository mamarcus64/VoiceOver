  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "And because of Churchill and Stalin, especially two-- two person, because Roosevelt was an illiterate and ignorant about European-- European politics.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "But it was Stalin and Churchill who knew what they are doing.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "And they organized everything it was possible-- had to put into-- into motion to stop Hitler.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "People don't know it.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "Those who were there and so-- and even Jews who escaped and they are survivors of the Holocaust, many of them have forgotten about the [INAUDIBLE].",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I know, I know.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And I ask many of them, show me one.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Show me one who was saved by Wallenberg.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "When he talks about that Wallenberg-- Wallenberg opened up the safe house and put the Jews there-- the Nazis were putting them in a yellow star-- the yellow star [INAUDIBLE], and they pin it on Wallenberg.",
      "word_count": 36
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He was there for-- for the purpose.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And I have it in-- it's collected.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Show it to you.",
      "word_count": 4
    }
  ],
