{
  "stem": "24195.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "But coming back to the-- that-- the medical examination where the doctor assigned me to the-- I was in that factory, working with 40 women.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It was very difficult because they all wondered why I wasn't on the-- on the Russian front.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "That was, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "So again, I had to use-- I was not acceptable for physical reasons.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I can only do light work.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "So that went over.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I did not tell them anything about me.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, she, she was-- she didn't have to go, no.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They might, might have put her-- excuse me.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "They might have put her, but she didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My brother was still too young.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "For some reason they--",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, he wasn't doing anything.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He was just sitting around.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He was not doing anything.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He couldn't go to school either.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He couldn't enroll in school in that new community either.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I mean, there was no-- no.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "He was banned from that.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "But he just stayed home, just stayed with my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But I was the one that got all-- had to take all the brunt of this whole situation.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So I was with all these women, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And these-- it was actually difficult with those women.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "You have a-- what, 17, 16-- '44-- I'm 17 years old, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And all these women without their boyfriends and, and husbands-- they're all on the front.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I have to keep my-- that would have been the last thing I would be interested in.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "What do you mean?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They were making overtures to you?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they were interested.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, more or less, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't-- I mean, I was a-- I was a teenager, really, you know?",
      "word_count": 15
    }
  ],
