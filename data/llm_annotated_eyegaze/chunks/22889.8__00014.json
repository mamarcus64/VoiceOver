  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "The reason I do, because I feel maybe I leave some kind of legacy behind me.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "People should know what happened, not only to me but to thousands like that, like myself.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "And time is running out for us.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "Not too long ago, I was just a youngster.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "Today, I'm reaching old age, already, almost.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "I don't feel my age yet.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "But I act like a 30-years-old kid, believe me.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "And I feel, too-- and I perform like that, too.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "But you can't stop progress.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "Time doesn't stay still, unfortunate for all of us.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The only thing I'd like to share--",
      "word_count": 7
    }
  ],
