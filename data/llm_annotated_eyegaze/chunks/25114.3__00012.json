{
  "stem": "25114.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "They said, we need a list of all the single women.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The Gestapo came to the Judenrat.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They said, there's too many survived.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We need a lot of single women who were not supposed to have survived.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Give me a list of all single women.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So what-- what do we do?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "The Judenrat didn't want to give them the list of single women, because they knew what's going to happen to them.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "So they went quietly into the-- into the huts, into the houses.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And they said, people who are single, if there's any single men, please come to the Judenrat and register yourself as husband and wife.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Well, I had to look for a man whom I can trust, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Because he could-- this wasn't to-- to be for real.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "It was fictitious.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "So I was looking around.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "There was one young man.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "He said, you know, I might write my name, what he also get married fictitiously.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And then came this man, this-- my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And much older, 18 years older.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "The other one looked like a kid, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And he said, if you want-- he knew me, because from work, I had a very sort of good relationship with my workmates.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And he had a friend who worked there too, and he sort of saw me.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't one of the-- from the town, because I was a newcomer.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So now everybody sort of looked at me as I'm a bit different from them, which I was, actually.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But I was easy to adjust and to fit in.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That's what they liked of me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Started talking, you know, the way-- Yiddish, the ways I spoke.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    }
  ],
