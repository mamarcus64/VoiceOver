    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And for me, it didn't end.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "If you want to know, really [INAUDIBLE], I still think about it.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] For me, it didn't end.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 15 SECONDS]",
