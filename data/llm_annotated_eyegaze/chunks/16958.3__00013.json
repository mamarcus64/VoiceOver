{
  "stem": "16958.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "We didn't have nothing to-- to-- to brace it.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "We went through this about 20 feet, and then it start already good earth.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And we start going up.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And I see I am very high.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "All the same, we were experienced cave-- cave guys.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And I was so high there with-- very high.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "And I see that my light, my little light, is keeping-- there was no more oxygen there.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "They-- they keep-- out-- I put down again.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "And I find already a piece of wood, that I know that we are soon going to be out.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "But while I'm up there, I hear noise.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "And then they say, hey.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "You are closed up already.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "This ground in the gravel start coming down and close up.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "I didn't even know that I was on the top that everything is closed.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 27,
      "text": "And they-- there were five, six guys there.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 28,
      "text": "They clean it out.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 29,
      "text": "And says, come down.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 30,
      "text": "I came down.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 31,
      "text": "And we went back.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 32,
      "text": "We went back to sleep, like to eat and to sleep.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 33,
      "text": "[PAUSES FOR 4 SECONDS] But we were-- I went back.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 34,
      "text": "We-- we were eating there twice a day.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 35,
      "text": "My sister, Yetta, she was the go-to cook.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 36,
      "text": "Two soups a day.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 37,
      "text": "One about 7 o'clock in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 38,
      "text": "One at 7-- but two times a day, that's all what we had.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 39,
      "text": "A little bit of soup.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 40,
      "text": "Plate of soup.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 41,
      "text": "I used to say to my mother, if that soup could last at least half an hour, it will be good.",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 42,
      "text": "We came back.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 43,
      "text": "We had the soup.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 44,
      "text": "We went to sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 45,
      "text": "Now-- next day, we have to go to work, back in there.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 46,
      "text": "We came there.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 47,
      "text": "And there's so much of this blue stuff, this gravel.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 48,
      "text": "Mountains came down.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 49,
      "text": "We start cleaning, and we cleaning.",
      "word_count": 6
    }
  ],
