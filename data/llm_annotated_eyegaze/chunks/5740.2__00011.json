{
  "stem": "5740.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 9,
      "text": "Where my mother was was called the Drittes Reich.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 10,
      "text": "And she thought, hearing what atrocities were going on in this part of occupied Poland, by the German, that I have more chance if I be with her.",
      "word_count": 28
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 11,
      "text": "So she sent this man.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 12,
      "text": "And I trust him.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 13,
      "text": "I left my aunt.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 14,
      "text": "And I went with him.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 15,
      "text": "Don't ask me how long it took, how dangerous it was, and how many times we were nearly caught.",
      "word_count": 19
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 16,
      "text": "But I reached my mother in December, 1941.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "I returned back to Bedzin, to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And I met my mother in the street.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "It was-- it was a fantastic reunion.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "She somehow grew up too.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "She wasn't the same as she was.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "She wanted my love.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "She didn't want me to be scared of her anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "She only wanted my love.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "And my mother lived, at that time already, not in the center of the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "But she was thrown out from our beautiful home.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "And she was living in somebody's kitchen, in the back of the kitchen, divided by a wardrobe.",
      "word_count": 17
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "And there I stayed with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto-- not quite the ghetto, but outskirts of-- of the city.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "In Bedzin.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "That was some friends, my father's friends.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "They always lived in this part of the city.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "And they let her stay there in this part of the kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "And there were my-- part of my furniture of my room in that part of the kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Jewish, Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Ernst was their name, I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "I came-- I came back to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "I moved back to my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "But I was illegal there.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "I had no identification papers.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "I had no coupons for bread.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "I had no coupons for-- for clothes.",
      "word_count": 7
    }
  ],
