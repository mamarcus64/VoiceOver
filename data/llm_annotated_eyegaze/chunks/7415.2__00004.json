{
  "stem": "7415.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "Maria, my grandmother-- new grandmother told me, and saying I am not Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And I have nothing to do with Jews-- Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "And some salt fell on this-- on the floor.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "And he-- the guy said in Polish-- I don't know they were Gestapo, but they spoke Polish.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "I don't know German.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "He said, you see, that's the proof you are Jewish, because that's Jewish saliva.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "And I never forget it, because I went-- went there and said, don't you see that it's salt, not saliva.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "I thought that must be really awful to be Jewish, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 38,
      "text": "Obnoxious.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 39,
      "text": "And [PAUSES FOR 3 SECONDS] at the end, when they said if you will not tell us-- they were leaving me alone and then they were coming back.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 40,
      "text": "And they were leaving me alone and they were coming back.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 41,
      "text": "And I could hear them shooting.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 42,
      "text": "I was hearing some other shooting.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 43,
      "text": "And they say, your mother is still alive, but if you will not tell us all the truth, in five minutes, she will be killed.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 44,
      "text": "And I told them that I am Alexandra Mayzel.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 45,
      "text": "That my father is a Polish officer.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 46,
      "text": "And I am not Teresa Piechoczynska and I don't want my mother to be killed.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 47,
      "text": "That was in Czestochowa.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 48,
      "text": "And where we didn't know anybody, and Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 49,
      "text": "Maria went to Warsaw at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 50,
      "text": "So they took me to my mother, and I remember my mother was lying on the floor.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 51,
      "text": "She was very-- they really beat her up terribly.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 52,
      "text": "And they said to her and to me to get up.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 53,
      "text": "And some guy was taking us through empty streets which were leading to ghetto, but one-- and he said, [GERMAN], which means stand up.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 54,
      "text": "Don't move.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 55,
      "text": "So we say now he will shoot us.",
      "word_count": 8
    }
  ],
