{
  "stem": "1537.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Of course, only thing I was interested-- to go back to Czechoslovakia to see when I get to Somotor, to see if somebody survived.",
      "word_count": 24
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So they took us to Pilsen, in military-- the Czechs, we arrived Sunday there.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The Czech people, they brought all their Sunday meal.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They gave their Sunday meal for us, for the refugees.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They didn't have themselves, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And then in Prague, went-- the Joint had already some kind of office-- you know, the Joint.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they gave us a few crown, something, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "At least I had already a few dollars, but it meant maybe three dollars on the black market.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Because if it's five from the crown, a dollar, officially, right away after the war, officially 50 crown a dollar, and 500 crown.",
      "word_count": 23
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "But they gave me about 1,500 crown. 1,500 crown, I can buy a piece of bread on the road, I can do something.",
      "word_count": 23
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So to go to Somotor, yeah?",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "To Slovakia.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "They telling me you cannot go there because the bridges are destroyed.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "You have to go to down river, the [NON-ENGLISH] yeah, to Bratislava.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And then you cannot get through, the train cannot get through.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "So from Prague, I managed to go on freight trains, on the top of the trains.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "I didn't care.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "I just jumped forever.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I ask which direction this train goes.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "If it was going closer to Somotor-- I jumped there and I was going.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Ticket, no ticket, freight train, no freight train, passenger train, I didn't ask.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have to buy, anyway, because I was a refugee.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "You know, I had already a little piece of paper that I was liberated in the concentration camp.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So we come to Bratislava, the atmosphere already different.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The Slovaks, they speak Slovak and Hungarian.",
      "word_count": 7
    }
  ],
