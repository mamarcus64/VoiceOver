{
  "stem": "21004.7",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "You have to go in the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So I said all right, you're right.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I don't want to put you in trouble.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I don't want to put us in trouble.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And I went to a little forest, very small forest, not far from our Polish friend.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "I used to go with him to school, with him and his sister.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "They were our family.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "Their name was Stefan.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Jasek Martko was their name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And their son's name was also Jasek Martko.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "That's the way they give names.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And I went in and I sit in the back of his big farm.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "He had a big farm.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And I sit in his wheat, corn and wheat.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "He was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "He was Polish, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Christian.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And I was going-- yeah, Christian.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to the school, to the Polish school, four years or four and a half years, to this school.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he was my close friend, very close friend in school.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Of that forest?",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It's just a little forest, just like-- I don't even remember the name.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It was a very little forest.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Near Lubiana, another city.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Lubiana, by the village.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Not far from the village, also by the city of Jawarow [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "So and I went in that little forest.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I went and started building a bunker, and once I build the bunker, at one night I was all ready to finish up the bunker inside, my wife calls me up.",
      "word_count": 31
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Leon, they caught us already.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Two boys, tall boys came in, they just heard something, you know, I was digging in the inside.",
      "word_count": 18
    }
  ],
