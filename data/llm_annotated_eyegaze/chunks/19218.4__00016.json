  "elapsed_s": 271.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "So he came here.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "Unfortunately, it just didn't work.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "My brother got acclimatized to Costa Rica.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "Work wasn't hard.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "And if you wanted to work hard, he could have been a extremely wealthy guy.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "When he came here, life is not so easy in the States.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "He had to work hard.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "He suddenly realized, hey, you have to work very, very hard to make a living in the United States.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "Over there, he had maids in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "They even had a butler in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "And he was a plain, ordinary peddler.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "Just peddling, from door to door, going and selling some goods from door to door.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "And-- but he has made a beautiful living.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 38,
      "text": "I-- I think when he came here, he already had about $20,000.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 39,
      "text": "In 1953, $20,000 meant you were a rich man.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 40,
      "text": "Anyway, I took him out one--",
      "word_count": 6
    }
  ],
