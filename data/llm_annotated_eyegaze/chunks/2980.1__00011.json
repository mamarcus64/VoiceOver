  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 30,
      "text": "So they made their little pogrom.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 31,
      "text": "And then as they came, they went out.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I did not see, I just-- a friend-- the father of a friend was killed.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "They found him in the street.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "People would just be in the street, they would just shoot you down.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And then they--",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "But the book has them all listed, all the people.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "There was young people and older people.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "They would just shoot them down.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And they would lie in the streets, and houses, and doorways.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And-- and-- and then they ran and went back to the railroad station and ran out-- out of town.",
      "word_count": 19
    }
  ],
