{
  "stem": "9908.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "When going to all places with other-- was just something to dance or to play, we always [? been ?] there.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And my mother was a very good cook, a baker.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And above all, the best mother and clean.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Our house was so clean we could eat from the floor.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "Everybody knew.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "My mother was taller than my father.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "So they called her, in Ozokiwicz, the tall Beila.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My father was a councilman, honorary, in the city hall.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Then he-- he was-- he formed-- he loved music so he formed a band from all Jewish boys.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And every Sunday, they worked in the alley and-- and the avenues, [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And they played the Jewish-- you know, music, orchestra.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "My father was president of this organization.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And he found that when they played every Sunday, my father right in front with white shoes, white pants, and a navy alpaca jacket.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "He was very sharp dresser.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "The orchestra had only hat.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "They didn't have any uniform, just hats.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "So was my father.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "They loved to dance.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "They loved to go places.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And when I got older, they took me along.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "My father belonged to all [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "He was running the labor-- the labor union from the tailors.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And there were meetings in our house.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "We lived in a very beautiful flat.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And my father has a shop there.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "I would go-- when in Poland you will start going to school seven-- seven years.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My mother's parents, my mother did hardly knew.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But my-- my father, I remember very distinctly my grandparents, because every Pesach, my mother baked cakes.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They lived nearby, a city called Leczyca.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Today it was again a university city.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "All the higher school and elementary students were attending in Leczyca.",
      "word_count": 11
    }
  ],
