{
  "stem": "6320.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "This was a golden watch for my sister that she had-- that she had gotten as an engagement present before the war.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Then my sister said to me, don't-- my sister says to me, run away.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Because he is going to-- he is going to kill you.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He's looking for you.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And my father took me by my hand and just rolled me down that hill.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And he says, they're all dead.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And my sister died in my arms.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And he said, you have to survive, so you can tell the story.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "These were his words.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And when I fell down, and it was a terrible thing to leave all this.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I didn't want to go.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I just want to get finished to.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "But my father insisted.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "[INAUDIBLE] [? sister, ?] he rolled me down.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "I was already on the bottom of the hill.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And we started walking.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And we stopped in a-- and there were lots of forests over there.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And we came to a forest we saw.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "We saw a-- we saw a little house.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And we went in.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "And there was a Polish lady.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "And we told her what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "And she sit down on her knees.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "And she prayed.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "She says, praise to God that God should take away some years from her two sons and give me that I should can survive this war.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "And my father told her that she should take me to a priest to make me Catholic.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "So he should give me some-- he should give a paper to survive.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "But he said, well, if you believe in Jesus and you got to heaven, then you go to heaven.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "I said, if-- if you die, then you go to heaven.",
      "word_count": 11
    }
  ],
