{
  "stem": "6773.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So we didn't have to, to move out.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "In 1942, they liquidated the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Another thing, they liquidated in three shifts, like three days within six days.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We went the first day.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So we, everybody went.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "My, my brother and my sisters, they went with the first shift.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "They all went to Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "At the time where they were going, we didn't know.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We on--",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We only found out about three days later.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We found out that they were came to Treblinka, and they were liquidated there on the second day.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I found it out through friends of mine.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I remember one name, Monek Medlah.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They, before they came to in, into the camp on the railroad train, they told them to undress.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And they left all their clothes and their luggage and everything on the train.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Now between the train, some people, like two or three friends, I think, they hid underneath the clothes.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And when the train went back, on the way, they jumped the train.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And they came back home.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "When they came back, they told the whole story.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "So three days later, we knew everything what goes on.",
      "word_count": 10
    }
  ],
