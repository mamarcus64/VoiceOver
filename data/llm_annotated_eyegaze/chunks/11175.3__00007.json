{
  "stem": "11175.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Coming back to [INAUDIBLE], we had to meet over there this is already the fourth-- fifth day in the operation.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Don't forget this was the fourth, fifth day.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "They started bringing some people more.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Then came another order, we should come-- go again there opposite the-- the [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And they start to make again a selection.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "They picked up some people, and the rest we went back to the-- to the-- again to the [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "So we were there about eight, nine days in the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Then they came the order to go up to the umschlagplatz.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "From the [INAUDIBLE], the umschlagplatz was not too far, so they organized everybody and we went out to the umschlagplatz.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "We came out to the umschlagplatz.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "Was hundreds and hundreds and hundreds of people already on the umschlagplatz.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "They took them out from-- from the other side and they come from [?",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Schultz ?] and [INAUDIBLE] and from all the factories what they have to organize.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And they took them out on the-- on the umschlagplatz.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "Umschlagplatz, they were standing and selecting the people-- one here, one here, one here.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And-- I was standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "You know, we kept together with [?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Yanous ?] [INAUDIBLE], you heard-- you heard the Jewish actor.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "We were together.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "We were work-- they were standing together and-- and they started-- they took out from the-- they started take out some people, the SS, 10, 20 to-- to here on this side and this side.",
      "word_count": 35
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "And I remained in the back.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "I remained in the back.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "I was standing in the back.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "Then they came for me also.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "Go on this side.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "I went to with [?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "Tuka. ?] We went over the other side and were standing and waiting.",
      "word_count": 13
    }
  ],
