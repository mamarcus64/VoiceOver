{
  "stem": "2350.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And they asked me, what are you doing?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But there was the Jewish commander from the police.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And he says, go home.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He knew me, because they knew if they-- why should they kill me now?",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I'm going tomorrow, anyhow, to, to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And we, we were surrounded the whole night.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And the next morning, everybody walked out from the house taking whatever you can take.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Thousands and thousands of people, because I don't know how many we  were there.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And we assembled on one place.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And then everybody was starting going out to the gates.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "They says, take everything off what you have, your watches, your rings, whatever you, you carry, your money.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And put it in the bag when you went through, through a gate to go into the wagons, to the open, to the closed cars.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So everybody threw in everything.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And we walked.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So my mother went, my sister, and the baby-- a nine-month-old baby, my older sister.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I had a friend, a boyfriend and his sister and younger brother.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And we all, like, stuck together.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And we all walked out.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And when it came to go into this wagon, my mother couldn't get up.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was so high.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans with the dogs were behind you and beating you and screaming, get in, get in.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So my friend went up.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And he took the baby.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And then he-- I pushed my mother up, not to be hit, not to be killed before.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And we all got into the car, maybe 100 people in one car.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You couldn't breathe.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "The doors closed, and we start rolling.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "We didn't know where we going.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "Nobody believed that we going to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "You know, if you're young, you don't think.",
      "word_count": 8
    }
  ],
