{
  "stem": "2684.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Jules Forgacs, J-U-L-E-S, F-O-R-G-A-C-S.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Julius, J-U-L-I-U-S, Fischer, F-I-S-C-H-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "3rd of May, 1929.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "66 last week.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Budapest, Hungary.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Same. 9-- 3rd of May, 1929, in Budapest, Hungary.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In one of the suburbs of Budapest, right in the middle of it.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Garay ter.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "That's had a market where my mother had a shop for 60 odd years.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "From the beginning?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Mm.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "J-U-- oh.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Can we start?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] We lived in-- in Garay ter, number 15.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And we lived together-- my father, my mother, my sister, and my grandmother, who was the mother of my father.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We lived in a-- a two-room apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] my father and my mother lived in the bedroom, and my grandmother, my sister, and myself, we lived in the living room, where it was removable beds.",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And-- and that's how I remember beginning my life.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "We had a-- a-- a family-- quite a large one.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "My grandmother had four sisters-- four daughters and one-- and two son.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "One son died just exactly 10 years before my birth, in very young age.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "He was-- he met an accident where a telegram post hit his head, and he died instantly.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And I born exactly on the same day, 10 years after.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "My sister is two years-- two years older than I am.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And we had-- because my parents had a business, a-- a little poultry shop down in the market, we seen very little of the parents.",
      "word_count": 25
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "My mother went away 4 o'clock in the morning and came home at 6:00, 7:00 in the evening.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And my father did the same.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "My grandmother stayed home.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And we had a-- a-- you could call a servant, who looked after.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And they more or less raised us.",
      "word_count": 7
    }
  ],
