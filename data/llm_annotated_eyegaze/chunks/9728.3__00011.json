{
  "stem": "9728.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And every two, three weeks, you had to go around from-- it was a full-time employment-- Monday, this house, Tuesday, this house, and pick out the-- empty the toilets into the barrel and put the barrel out to the fields, out to the field and the outskirts, and dump it.",
      "word_count": 50
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "They just dumped it on the field.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And you can imagine that, of course, there were going to be sicknesses and things.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And the people who worked on this-- they smelled two blocks away.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Because this is-- it's just normal.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "It got splashed on their clothing and things.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "However, the good part about it is that they got that extra ration of bread.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They got an extra slice of bread and an extra watery soup.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Now, as I mentioned before, I got the choice either to do this or to do, to go to the cemetery and work in the cemetery.",
      "word_count": 26
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Well, I don't know if I was smart or not.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "But I picked the cemetery.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I picked the cemetery.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Now, this was-- I came back.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "This was 1941.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "I came back in September 1941.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I had to work in the cemetery.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And it's true.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "I got an additional slice of bread and an additional soup, which, believe it or not, it helped.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "Because at home, I could already slice a piece of bread for my brother and my sister-in-law.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Your brother and sister-and-law were still there.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Still there.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And they still-- my brother still worked in the tailor shop.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And my sister-in-law did not, if not mistaken.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She did not work.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I worked in the cemetery.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "At that time, let me point out that to Lodz ghetto came in people from all-- from half of Europe.",
      "word_count": 20
    }
  ],
