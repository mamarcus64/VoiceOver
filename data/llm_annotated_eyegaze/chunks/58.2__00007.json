{
  "stem": "58.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "They used to pick up manure from the gendarmes, at the-- in the forest.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "It had stables.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So they paid two zlotys-- like a half-- half a dollar.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And they picked up as much as they could load in a wagon.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So they-- I went with them, and we loaded our wagon of manure.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We came back.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He gave us lunch.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And he told us after we finished lunch, we shall go again.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I say, tell me, could you give me permission to load this wagon really-- I'll bring you a double wagon for the same money, because this is not enough, I say.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He says, how are you going to do it?",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I say, if you give me permission, I'll come back with our wagon-- you'll see.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I went, and I told the other guys-- I say, first we'll load inside the wagon.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Then we'll make a pyramid over the wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Come to a pyramid-- I came back with the wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "The horses couldn't pull it.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He says, he talked to God, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He has a double wagon here for the same price.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Well, I worked in this place quite for a long time.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I actually plowed, and I learned how, and I-- all work in the farm-- whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And one day, a farmer's-- a poor farmer-- the house burned down right across from where I worked.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And they helped each other, so he said I should go with the wagon and help bring home some logs to build another house.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I went, and they stayed-- the other farmer stayed.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They don't know how to load it.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I turned the wagon sideways and put chains.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And the horses pulled the-- the-- the logs that the wagon came back straight by itself.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It fell into the wagon actually.",
      "word_count": 6
    }
  ],
