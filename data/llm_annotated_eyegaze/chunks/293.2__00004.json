{
  "stem": "293.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "They took about a thousand most prominent Jewish and non-Jewish and Gentile family out, confiscating everything in.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Doctors, attorney, professors, and teachers.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "Mother of my-- my mother-in-law, mother of Mila, was a very prominent doctor.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "She was skin and venereology doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And she was first on the list.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Mila didn't have to go with her.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But she was only in this time 18 years, 19 years old, So you understand? she didn't want to stay alone.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And she went with brother, and they sent her to city of Cracow, because in this time, we are also working to have a document that we are working.",
      "word_count": 29
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We were also involved in the work in the Jewish Judenrat.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I was assistant to the president.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "What was my job?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "I was keeping the appointment.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "[BACKROUND NOISE] I stay by the door.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "Everybody wants to see the president.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And I was the man who was responsible, who can go and talk to the president.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My-- my friend, what I stayed with him, was in charge [BACKROUND NOISE] in the welfare department there.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So he got an order to go and pick up some family and assign some apartments for them.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Look, he saw a young woman who was introduced as Dr.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Maria Lewinson, and a beautiful young lady around 19, 20 years old, you understand.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "He said, we will-- we have-- he has three apartments to his disposal.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "He decides to take this Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Lewinson and her daughter, Ludmila Lewinson, to our apartment, because we have a tremendous apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And it was Friday evening.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "It was 6 o'clock in the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "[LAUGHS] I tell you something.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "They came up in a droshka.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "You know what is a droshka?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Horse and, and carriage.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And was pouring.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I was waiting.",
      "word_count": 4
    }
  ],
