{
  "stem": "12674.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I was terrified of what was going to happen to me, but I was afraid of my father, because I knew that if he ever caught me after that, I was going to pay for it dearly, because he'd never forgive me for being so stupid and not, not doing what he told me to do.",
      "word_count": 56
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "That was unacceptable.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "He says, with life and death, you listen.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, so I, I don't know what I did.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I was going back.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I said, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Well, whatever.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I wasn't meant to die.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I moved my head.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I was wiggling, and the window behind me gave.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And I wiggled myself back and wiggled myself back and into the window.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And I turned myself around.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "At least I didn't fall backwards.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And I got there, and the window gave.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "I pushed it in.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And it was pitch black.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And I, I, I said, well, if I go there, I'll be dead.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And  if they don't kill me, Papa will.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "So I might as well go in there.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And I thought I was going to break my neck or something.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "I don't know what was going to happen.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And I fel-- and I launch-- launched myself in there, and I fell about this much.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "There was a pile of coal there.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And I fell onto the coal, and I pushed the window closed.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "And I laid there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And I heard them loading the stretchers.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And I heard the train pull out, and it got night.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "And I heard the rats and the mice.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "And I was terrified, and I was crying.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "And I was afraid to make a noise.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "I was afraid somebody was patrolling outside, might hear me cry.",
      "word_count": 11
    }
  ],
