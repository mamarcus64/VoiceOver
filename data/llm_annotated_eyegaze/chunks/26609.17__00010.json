{
  "stem": "26609.17",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "So illegally, you can take them out, if you can cross the Polish border.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "You as one with the Red Cross here, Red Cross there, you can go.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Nothing will happen to you.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "No one will touch you-- International Red Cross.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But those people, if you take them, you go out with them as the one who is leading them, maybe you'll get through from Poland out to where Czechoslovakia is, you know?",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I didn't think anything will happen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I went, took the group of Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "No one knew that I'm Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "No one knew.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "They took me all for Red Cross.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "They were afraid to talk to me, from Red Cross, Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We went.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "On the border Poland and Czechoslovakia in Kudowa, the police say, where are you going?",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I said, it's through the Red Cross.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I have all documents here.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "You have to-- two-- two police on the border-- we have to go over.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And these people are mostly sick people, survivors.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You have to let us through.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They think over, they talk together, they let us.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "But we had to stay until to Kudowa.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And stay in Kudowa, it was a camp after the-- terrible, awful.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We slept on straw.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "We could see lice.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "It was after the army was there, the German army was there.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And we couldn't lay down of that, just straw, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Without any coverings.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "On this, we had to sleep there three weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I saved them, not knowing even.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "It was in winter, cold, ice, icy-- it was [INAUDIBLE], there, the ground.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And I walked outside once.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And it was so slippery, the snow was frozen ice.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And I slipped on the ground outside.",
      "word_count": 7
    }
  ],
