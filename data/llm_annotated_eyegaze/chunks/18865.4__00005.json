{
  "stem": "18865.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 316.6,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I mean, they-- I think an evening class.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I took evening classes too.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "But when I started with the beauty culture, I had a lot to study.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "It was a lot-- and I didn't speak English so perfectly, and all the names of the muscles and the-- the blood circulation, and was all-- and everything up to the chest, including the chest.",
      "word_count": 35
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I had to study very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And when I tried to get to-- and I was working on top of it-- to night school to learn public speaking I took up, I fell asleep.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "I couldn't-- I did it for one or two semesters, but I couldn't keep it up.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And she did.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And she--",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I worked at the [INAUDIBLE] beauty salon.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And then the owner of the store was inducted into the Army.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I took over the management of the store.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Until I got married, until I-- until-- no.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Even longer, until my child was born, until Diane was born.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We met in the Jewish community center at a dance that was set up by the-- by the center in Chicago for soldiers and sailors.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And the ladies cooked dinner for them for Saturday night.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And then we-- we were very, very-- we were interviewed-- and hours of interview before they accepted us.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And then we got our little sign here that said who we were and where-- I think where we came from and a picture.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And that's when we were accepted.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And we were then classified as-- I don't remember what they-- how they did it, but we could come any Saturday night.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I went there a couple of times and-- and then next Saturday night I came.",
      "word_count": 16
    }
  ],
