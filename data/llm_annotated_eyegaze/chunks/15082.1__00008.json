      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "The rest of the words I-- be probably difficult.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "[SINGING IN YIDDISH]",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The grandpa-- it relates to that his dad has passed away.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And he's holding the-- the grandpa is holding the son, and is now teaching him the Kaddish.",
      "word_count": 17
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it's a sad song.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "The war-- the early memories that I have is in-- in 1937, when people started coming towards us from Czechoslovakia.",
      "word_count": 20
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Czechoslovakia was taken.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And I used to go to shul regularly, you know, every Shabbos, and even on the weekdays, earl morning services, with my dad and my grandfather.",
      "word_count": 26
    }
