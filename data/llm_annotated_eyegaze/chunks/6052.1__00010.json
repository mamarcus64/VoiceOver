  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "It was felt that he was--",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He was eventually arrested and sent to the concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "All the-- all the men were in the most immediate danger, but also all of the women, as later shown.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Women and men and children, they were gradually taken and deported to various places from Riga, where my mother and three sisters were deported, to-- to Majdanek, to Theresienstadt and so on.",
      "word_count": 32
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And there is a clear summary where everybody was deported and at what time, and I have such documentation.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I am not cognizant of-- of all the preparations which were made because my fate was something different up to a certain point.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I succeeded-- or rather, with the help of the [INAUDIBLE] I was sent to a [INAUDIBLE] place.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But this came after I had to do [INAUDIBLE] or [INAUDIBLE] or forced labor in Leipzig.",
      "word_count": 16
    }
  ],
