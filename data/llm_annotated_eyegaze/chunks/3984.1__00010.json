  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And then he take of-- care of us, whatever she can do in this time.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "You know, in this time, usually the-- the woman was at home-- take care of the children.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Almost every year they was pregnant-- every time was babies.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And it was a lot of work at home.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The girls, no.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "The girls, no-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "We know-- we know the little prays, you know, like the berakhot, and the-- when-- where you get up in the morning, you have a special pray, like modeh ani.",
      "word_count": 30
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And we going to-- when you going to sleep, you have a little pray-- [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And you have all the berakhot before you going to eat.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, but this is not-- yes, they was helping a little bit.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They cannot-- they helping every time a little bit-- not with-- not with money, only with food.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And when-- when you are hungry, you want to eat more.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "When you are-- where-- when you know that you can't take the food, you are not hungry.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Because you know that after five minute, you can eat.",
      "word_count": 10
    }
  ],
