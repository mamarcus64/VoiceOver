{
  "stem": "19921.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 121.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Under no condition they said that was-- people were dying there.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We knew that people were working in there, but not that people were dying in there.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "People were dying.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Whoever was dying or whoever felt like-- whoever they felt is going to die, put them in the crematorium, because they had crematoriums.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They had crematoriums.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And they replaced them with people which still were able to work, simple as that.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And they wouldn't admit.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "They wouldn't admit that they, they didn't-- they didn't know what was going on.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Don't tell me.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "The Germans are not stupid.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "They knew what was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Whereas the Poles who lived around the camps, they would say--",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They said it openly.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They said it openly.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And the Russians would say about the killings.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Exactly.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "But the Germans didn't know.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "But the Germans would not say nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And if, if somebody you had already caught, interrogated, like a soldier or something, he had orders to do it.",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "That was the excuse.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "You can do it.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Same thing.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Same thing.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "In Oranienburg, not longer than two hours.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Left, left in, in, in front positions-- in other words, in advancing positions.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "So that-- the Oranienburg was about, about the 20th-- about the 20th, or maybe the 21st.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember, really.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Of April-- OK?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "About the 20th or the 21st of April-- and the direction was there were small towns-- to burn down everything.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You have to occupy that.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "You had to cross another river to go through Berlin, the River Spree.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And finally, we crossed the River Spree and encircled the whole Berlin.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Once we crossed the river, we encircled the whole Berlin.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And from then on was hand-to-hand fighting, really.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I was 12 days in Berlin, including the Reichstag.",
      "word_count": 9
    }
  ],
