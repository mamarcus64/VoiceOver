{
  "stem": "18626.13",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 353.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--saw in the Jewish newspapers, they need a woodturner in Seaford.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "It's a long way from where I used to live, you know, in the Bronx.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "You got to take trains to go there, Seaford, Long Island.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But I said, let me try it out, see what's going on.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So I took the train.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I went to Seaford, a small little town in Long Island.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I walked into the shop.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Morris came out, WM Morris.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And he had like five, six workers working, all gentile people.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And he says, you're a woodturner?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And he looked at me again.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Because people don't believe when you're young, 20-some years, a boy, you know, a woodturner.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "You got to have experience many years in woodturning.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "He says, here, go to the lathe.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And he had that time a order from a furniture company to make bed posts in cherry wood with the fancy ball on the top for beds, you know.",
      "word_count": 29
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The legs, the headboard, and the footboard, all in four-by-four beautiful turnings in cherry wood.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I turned it out.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And he looked it.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He says, I was looking for a man like you for a long time.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "You got the job.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "How much a week?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "He asked me.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "He asked me, how much shall I pay you?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I says, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "You're the boss.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "He says, I'll start with $90.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And he gave me all the privileges in the shop.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The boss himself I didn't like, but to say, [INAUDIBLE] like that.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "When I used to go home, he used to run with a brush and clean up the wood shavings from my thing.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And the other workers used to be a little angry.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They didn't like that.",
      "word_count": 4
    }
  ],
