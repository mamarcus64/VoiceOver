{
  "stem": "18654.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 377.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was going to a technical school.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "It was decided that I was-- as I was good with my hands, I should do dressmaking, which was a big mistake.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Because you-- I couldn't earn my living.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "You were paid so badly that you couldn't live off what you earned.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And all-- all the money that I did earn, practically all of it, we had to give for our keep.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Once you started to work, you had to pay for your keep.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "You were allowed to keep a small sum, enough for your fare money, and a tiny bit of pocket money.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "The hostel closed in late '47, and we all had to move out by this time.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I was very-- I was still childish in many ways, but very adult in some ways.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And we moved out of the hostel.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "I and another girl found a room in a house, and-- which we rented, a furnished room.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "That was in Willesden Green in London.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And it took whatever I earned, it took it all up for just basic, very basic living.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Yes, but my sister, as I think I mentioned, she was very academic.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And in those days you couldn't go to university.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "There was no-- no means of going.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So she had passed her high school certificate, which I suppose is the equivalent of A levels these days.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And I think she passed with very high grades.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "She then went to work in a science lab-- in a metallurgy laboratory.",
      "word_count": 13
    }
  ],
