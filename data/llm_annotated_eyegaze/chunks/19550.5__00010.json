  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "At another time, we snuck one of the boys away, and one time I sneaked away and went into the back door of an apothecary and just broke it open and schlepped out whatever I could.",
      "word_count": 36
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "It was-- it was all very makeshift and very much dependent on the opportunity of the moment.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] Everything was like that.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And again, you had-- it's-- I don't know how I can sufficiently impress you with this problem of time, which was a completely different dimension and category than-- than what is normal to-- to people and to human existence.",
      "word_count": 39
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "We were-- we were in the jaws of death every moment.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
