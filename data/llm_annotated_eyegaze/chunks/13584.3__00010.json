  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "We searched different places.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "Maybe it was so, maybe it was not.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "[PAUSES FOR 4 SECONDS] So that's-- that's about what I can say, what I can recall right now about the Holocaust of my family.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "In [?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Legnica, ?] my father-- my father was a waiter, waiter.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then he was-- he-- he decide to change his profession.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "The reasons-- I don't remember the reasons.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "But he changed the profession.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "He start to work in a winery, you know, in a winery he was working.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "He became-- he was-- he was also involved in-- in unions, in union.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And he was a leader of the union.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "He was-- he was taking care of workers.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "If they had some complaints or something, they used to come to him.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And through him, they used to-- they used to solve problems they had, et cetera, et cetera.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He was-- he was elected four times.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "The people of [?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "Legnica ?] elected him four times and re-elected as a councilman to the city hall.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "A year after he passed away-- he passed away in '60-- in '65, 1965.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "A year after he passed away, people did not know about it.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "He used to come-- they used to come to my house, to my mother's house, ask for him.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Because he was-- for advice.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "He was-- it-- it-- I don't know I should be humble or not.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "But he was very wise.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "People used to come for him for advice, even though he was not an educated person.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "He educated himself.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "He had very few grades passed.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "Same thing, my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "My mother, when she was a girl, she could only finish second grade.",
      "word_count": 13
    }
  ],
