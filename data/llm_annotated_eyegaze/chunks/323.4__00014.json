{
  "stem": "323.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] But the worst thing that happened-- and I'm bringing this up because it really is-- I was in a ski accident, in an automobile accident.",
      "word_count": 29
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "We came back from skiing, this friend of mine and I.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "This was well, we skied in Vermont.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And we went to Massachusetts, because I have a house in the Berkshires.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "It's in Lanesborough, it's near Tanglewood, in the Berkshires.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "So we decided to stay at my house overnight, before we came back to New York because-- to shorten the drive.",
      "word_count": 21
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And we left that morning.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "That was on January 29th.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "What year?",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Four years ago.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "It will be five years this January.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And it was snowing.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And there was ice on the road.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And I was driving on route 22.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And I started skidding.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And this truck skid, and the truck hit me.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "The car turned around completely.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "Then he hit again, the passenger's side, full force, and Erica was killed instantly.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And this is my very, very best-- the best friend I ever had.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "Not Dita, Dita is my-- was like a sister, more.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "And a rip punctured her heart, and she was killed instantly.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 12,
      "text": "And I was in the hospital for a long time.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 13,
      "text": "I was also completely messed up.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 14,
      "text": "But having to live with that, I think, is the-- is the worst thing that ever happened to me.",
      "word_count": 19
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Worse than anything.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Because I was an adult.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "It was different.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Also, it was-- it happened while I was there.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "My parents and all this, that was gradual.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "This was bang.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "It just happened.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "This was a woman who had everything to live for.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "She was a great skier, a great hiker, a good human being.",
      "word_count": 12
    }
  ],
