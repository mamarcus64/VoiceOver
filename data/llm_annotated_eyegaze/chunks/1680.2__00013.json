{
  "stem": "1680.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "In the outside, they had bowls with detergent.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They told us everybody should put yourself on with this detergent.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "That was burning like-- like terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And then we into the shower, there was no water.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So and then they chased us out from the other side.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And we have to stay and wait during the night-- the middle the night-- until everybody comes out.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Then they took us into the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And took us into the barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Everything was rush, rush, rush, rush, running, running.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "When we came to the barracks, they gave us a pair of shoes, a pair of pants, a jacket, and a nightgown, and a little cap.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "The-- the-- the suit that I pulled out a thread, because I wanted to see what kind-- what this is.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "So I opened it up and it was newspaper.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "They made from newspaper made threads and the threads they made-- it was a-- a-- paper-- paper suit.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "My nightgown was too long, so I ripped off a piece and I use it for a-- for a towel.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "That was my-- my towel for this.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "We were there about several days.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "They took us into a room which could hold the most-- the most, 300 people.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "They took in 700-800 people.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And we were sitting one between the legs, the other one-- that's the way we slept day and night, day and night.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "During the day, they take us out, outside.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "They had 50 bowls for all these people for soup.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "They give us the soup, and they was standing there with the-- with the whips.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And if you didn't-- you have to-- supposed to drink the soup and handed over the bowl to the next one.",
      "word_count": 21
    }
  ],
