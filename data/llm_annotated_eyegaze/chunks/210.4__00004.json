{
  "stem": "210.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "There was one guy, a friend of my husband's, that came back.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He survived the war.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where, but he survived.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And he was a dentist.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And he had his, you know, his equipment and everything in this other small town.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And he stayed one night, overnight, with us.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And the next day, he went there to, you know-- he said he's gonna-- just wants to take his thing and his equipment if-- if it's still there, and go and establish himself in Lodz as a dentist.",
      "word_count": 38
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "This man never got back.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "We found him a few days later in a ditch-- dead.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And after this, I said, I'm, you know-- I-- I'm-- I'm not-- I don't want-- I'm not gonna live here.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I'm gonna stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And the next day, we went back to Lodz.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Well, we went back to Lodz, and I stayed with my friends.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And my husband kept coming every few-- he wasn't my husband at that time-- kept coming for every weekend and everything.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And he says, well, we just made up that he wants to marry me.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And all-- you know, at that time, my cousin said, you know-- my cousin and everybody said, look.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Why don't you want to marry this man?",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "You don't have nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "You are nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Your house is burned down.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Your-- everybody is dead.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "What are you?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "You know, you cannot live all the time with, you know, with these people.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I really didn't want to get married yet, but my cousin, and my friends, and-- I figured to myself, why did I survive?",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Maybe that was the purpose, that I survived-- to maybe make this man happy.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "He lost his wife.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "He lost his children.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "So maybe I was left to make this man happy.",
      "word_count": 10
    }
  ],
