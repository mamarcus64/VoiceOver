{
  "stem": "1917.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 367.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "Many Jewish people who returned from the camp, who were grownups, were put on trial and jailed.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Life in-- in Hungary and Romania-- or in Cluj-- it was very difficult.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Poverty was everywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Food very scarce.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Number one, we were so malnutritioned, we had so many health problems, it was unbelievable.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "We would get little spots-- dots-- like little bubbles on our skin.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And it would grow into the size of a quarter, and at times, even an apple.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And my aunt didn't know what to do with us.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "It was very painful all over my hand, leg, stomach, everywhere.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "My aunt took us to the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And the doctor said, these children suffer from so much malnutrition.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "That these are blisters of malnutrition.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Get them anything that you can to eat. 1946, [PAUSES FOR 3 SECONDS] we went to the synagogue one evening.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And the rabbi said it was Friday night.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "Sunday we are going to have a memorial-- first memorial service for the people who were killed in the death camps.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "They didn't call it Holocaust then.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "And if anybody has any soap from the camp, to please bring it with you to the service, because we are going to bury it since it was made out of human fat.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "[PAUSES FOR 3 SECONDS] And I still had two bars of soap.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "I knew from the time before we went to the camp that soap was very difficult to find.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "And it was a luxurious commodity.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "And my mother said, you have to save all the soap.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "So when I was in the camp, we got a bar of soap once a week.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "I kept with me the soap.",
      "word_count": 6
    }
  ],
