  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And the Americans sang it with me.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And-- and they looked at the Russians.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And the Russians looked at them.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And they said, let him come over to us.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "He opened the gate.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I was over by the American side.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So when I got to the American side, that Jeep-- they had that Jeep there.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And I got into that Jeep.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And they were driving us till it was-- we were-- we were-- I was not-- I was never what's it called-- I trusted nobody.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Driving-- where did they go?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "Suddenly into big gate.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And they opened that big gate.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "They got in there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "All the German officers, the army, was in there.",
      "word_count": 9
    }
  ],
