  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And he said, by 11 o'clock in the morning, you will be in Frankfurt, because it was a fast train, only four stops.",
      "word_count": 23
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And I managed.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Nobody asked me-- asked me for the ticket.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "I managed to get through.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Even a lady asked me, would I like something to drink?",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "So I said danke schoen.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Then I pretend I was sleeping, and I went through to Frankfurt.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "Did you manage to sit next to the window?",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I managed.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And the curtain was covering my head.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I just went through.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And then when I got-- that's it.",
      "word_count": 7
    }
  ],
