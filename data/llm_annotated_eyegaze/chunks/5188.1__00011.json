  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I don't think I really understood exactly what was going on, but I knew something was going on that was out to destroy us.",
      "word_count": 24
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Something was there that was terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And the-- the worst thing was that my parents were frightened.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "They acted frightened.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My mother was kind of a-- the-- the kind of person who would get an upset stomach if something terrible would happen.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And she walked around with an upset stomach a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And my father tried to be calm and reassure her.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But even his reassurance, I mean, it-- it was disturbing.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I mean, there were things going on that I didn't like.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "There was a lot of talk about my sister going to the next school.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Normally, she-- she would, as she did, have started out in the volksschule, which was a local school.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "But then in the fourth grade, she would have gone to a gymnasium.",
      "word_count": 13
    }
  ],
