{
  "stem": "6526.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "All I have to do is deliver papers and bring papers back.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And slowly, I went to school, to night school.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I finished night school very easy, and-- being that on the job, I learned the language pretty fast.",
      "word_count": 18
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And, uh, came a-- a time that I can be proud of that business got slow.",
      "word_count": 16
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And they-- and they let go a lot of-- a lot of messengers.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "But they didn't let me go-- let me go.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Because whatever they couldn't do-- the American boys, they couldn't do the job, uh, to arrange whatever they were suppose to.",
      "word_count": 21
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "They sent me.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Because when I came there not knowing the language, they had to call up the main office, say, what do you want?",
      "word_count": 22
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "There is a man that doesn't know what he wants.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "(LAUGHING) So I was the one.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "But I learned so fast that I got a job inside making-- on a cal-- on a copyrighting machine-- not like we have today.",
      "word_count": 24
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "But there was a machine.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Uh, it's called a duplicating machine.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "There-- and I worked there for, uh-- let's see. 1947 till-- about a year and a half.",
      "word_count": 17
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And I got a raise.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I got-- [BACKGROUND NOISE] I started with $35.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Then I got $40 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And I was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "The relatives of mine in Costa Rica, in-- but separately, we-- my brother and I started to do business, to work, to peddle.",
      "word_count": 23
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "We used to peddle stockings, pantyhose-- not-- not pantyhose.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "There were no pantyhose-- stockings, blouses, skirts.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "Used to go on farmers' markets.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 9,
      "text": "And the relatives in Costa Rica saw that we're not sleepy.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 10,
      "text": "We can do something.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 11,
      "text": "I became their agent-- their buyer, their agent here.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 12,
      "text": "They needed material, certain textiles.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 13,
      "text": "They sent me in a sample, a swatch.",
      "word_count": 8
    }
  ],
