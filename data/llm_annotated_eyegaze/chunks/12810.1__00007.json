  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And we embroidered and listened to the radio.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And then one day-- Sunday afternoons-- and one day we were sitting and then the Hungarian soldiers come in, because the Jewish people can't have radio.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So he comes in, take off the radio.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we was-- we was-- just looking.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "No voice coming out of our mouths and no, that-- three of my girlfriends who were not Jewish then but they were in my place.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "We was crying, and we can't say a word.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "They take our radio away.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "It was only one thing that was to us an afternoon, and then they take it away.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they said that's unbelievable.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "But what can they do?",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "What they can do?",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "A 17, 16-year-old girl?",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "What she can do?",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They went home and tell their parents what has happened.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "His second wife was born non-Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Then he she married and she became-- became to be a Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And she has two children.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And when she married my father, like a Jewish woman.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And then, when Hitler started to come, and they have their little boy, and they're going back to her religious.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So my father leave the Jewish religious, and go with her, in the Catholic.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "So she originally wasn't Jewish, she married a Jew,",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And then she--",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes, again.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And they had Catholic papers at this stage.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I tell you honestly, I-- I-- I can't say a word because it was his life.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "But I was hurt, because then I feel it, again-- he leave us down.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We was not her family anymore-- he has his new family, the new religious-- and that's how-- that's how I feel.",
      "word_count": 21
    }
  ],
