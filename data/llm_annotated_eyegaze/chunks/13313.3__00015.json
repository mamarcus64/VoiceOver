{
  "stem": "13313.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "OK, any Jew arrested in Belgium caught during the war was sent to a camp in the city of Mechelen, Malines, which is about halfway between Brussels and Antwerp.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And there was a German military headquarters for the area that was called Kazerne Dossin officially.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Like you have Drancy or whatever in Paris and you have whatever the name is in Holland.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Kazerne Dossin was the assembly camp in Belgium where all the Jews that were arrested or caught were assembled.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "An then every 15th of the month, a train full of people used to be sent to Auschwitz from that-- from that camp.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So my mother was caught in that camp around October of 1942. 28,000 people went to the camp, Belgian Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "A few hundred were alive at the-- when the camp was liberated.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My mother was one of those few hundred.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Absolutely unbelievable.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She endured quite a bit of hardship, but she wasn't in Auschwitz.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "She was in that camp.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "She came out at 75% invalid for doing all kinds of things, was beaten and all that.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "But how did she survive?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a manicurist in the beauty salon.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And the first commandant needed a manicurist, wanted a volunteer.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "My mother saw-- by the way, my mother's sister was caught with two children, [PAUSES FOR 3 SECONDS] Paula and Maurice, little children, beautiful little girl, Paula.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And-- and because of that, they went right away on transport.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So my mother-- my mother was right in separating, which was a tough thing to do for mothers.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But she was-- she-- but also, she could afford it and my aunt couldn't.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So she saw-- she saw my aunt with the children go on this transport.",
      "word_count": 14
    }
  ],
