{
  "stem": "26790.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I tell him my name is Mojsze.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "My girlfriend's name is Leja.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Like that.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Did you ever learned Torah?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "Jewish religion?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Till 16 years of age, I learned.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "He said, I want to ask you some Torah questions.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "You will answer me?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "That's what you did, did, did.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "That's what, what the question.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I said, it depends what questions you will ask me.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He asked me four or five questions, Torah questions.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I answered the questions.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "As he saw that I am not-- that I know nothing, I know something, he pushed his hand to me, he said, mazel tov.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He told me, Mojsze, when you go home to your hostel, in the corner, you will see a, a, a few cottages.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "One cottage, the front door is painted-- he tell me a color, red or green, I can't remember what color that he told me.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "You going into this cottage.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "You tell-- Zalman, my name is Zalman.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "You tell Zalman asked you to go there, and she, the lady will fix Leja's chuppah.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "When I went home, I didn't go in because I'm [INAUDIBLE] with Leja.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I want to speak with Leja first, like it's to-- to discuss.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And the question was, when I have off weekend, she didn't have, because we didn't work in the same place.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "If I have off Monday, she has Tuesday.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "If she has Tuesday, I got Wednesday, something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "But between two-- a few weeks, comes together, we have one day off.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "When we have, bought of us, one-- the same day off, and we walk pass this place, I said to Leja, let's go in and tell him, and tell him about the chuppah.",
      "word_count": 33
    }
  ],
