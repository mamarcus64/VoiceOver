  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Hela ?], her name is in Polish, [?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Hela ?], that [?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Chaya ?] in Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "She lived in a small city here, not too far from here, two hours, maybe hour and a half, with the bus to go.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "She's married a partisan.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And she have two children.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And I find him.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I lock the door.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE], a leather coat.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I asked him, Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Meinster, ?] the name, the second name, [?",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Meinster. ?] He said, [INAUDIBLE] come in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And Hela, [? see? ?] She said, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "No, she's with the children.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "She sleep with the children.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "They're little children.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "She's a beautiful girl.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "She has something [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "[LAUGHS] She comes out, [LAUGHS] and she start crying.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "She recognized me.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] She looked and balding.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I even met-- ?] And when [INAUDIBLE] that, what I tell you, I lost, in three days, the hair.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And put more [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "She sit with me five hours.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Because in 1942, the German make the ghetto of Lublin.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Take every Jew in that special ghetto, in that special neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "This neighborhood called Majdan.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And this neighborhood make the second bigger concentration camp, Majdanek.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I can spell you if you want.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "M-A-J-D-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] In there, every Jew in this neighborhood.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And she lived in the same house with my parents, with my sister, and with the children, and my brother-in-law.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She worked in a restaurant, which cooked only for the German officers.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It's a lot of doctors, a lot of [? engineers, ?] Jewish, [INAUDIBLE] saved her life, went there to work in this restaurant.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But the peoples work in this restaurant, the Germans don't kill.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "She tell me there's a one officer, a German officer, was to come every day to this restaurant.",
      "word_count": 18
    }
  ],
