  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And this is the beginnings-- this is March '43, which I mentioned before, and I-- it was a mistake.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "In March '43, the Crakow ghetto was liquidated, and we-- oh, the Crakow Jews, let's say, went to Plaszow, which was in the first stage so-called working camp.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father, my mother was with me.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And in the beginning, my sister was in a place-- she was working in a place where they were also overnight there.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "She came to Plaszow a few months later.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "She was working at the airfield-- Crakow airfield.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Not far from Crakow was an airfield, which was there for the German Air Force airfield.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the people who worked there didn't come back.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So they were sleeping there, and they have even not bad conditions there.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "But they-- it was liquidated a few months after we were in Plaszow.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "So she-- she joined us later, if you can call it joining.",
      "word_count": 12
    }
  ],
