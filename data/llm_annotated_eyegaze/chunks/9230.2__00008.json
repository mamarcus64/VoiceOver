{
  "stem": "9230.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No, no it was open like the you-- horses, like animals, everything was open.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And the bombs was flying.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "We wasn't scared [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "You know, we live in the ghetto, and we was imagining we hear they are fighting.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "We hear something.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "No, I think it was imagining.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "It was near Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "That's why we could hear something.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And we have radios.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And we know when they catch you with a radio, whew, that was the worst-- the worst-- the worst what you can do.",
      "word_count": 23
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "They kill you right away.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "No, the radios was under-- underground.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We know a little bit of what is going on through the radios.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "That was-- oh boy, you took a chance.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Oh, if they catch, right away.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "They left a few hundred.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how-- how many.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They left to clean up the ghetto because it's-- the people they left a lot of jewelry.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And after the people-- they make the graves and they have to be shot and to fall to the graves.",
      "word_count": 20
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "And the Russian came.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And after we-- we saw them because I saw a few in Montreal.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "Mostly the people that was working, you know, the hard people working-- flour or potatoes, they was carrying on the-- the strong people-- they left them in the ghetto with their families.",
      "word_count": 32
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They didn't get killed because the Russian come.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "The graves, and yeah, and not-- not one got killed.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "They called them the white workers.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a surprise.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "They didn't-- they didn't-- it was too late.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We came to Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I look out through the window and I saw them.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "They put my mother separate and the men.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "They were all separate.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "They didn't put them together to kill.",
      "word_count": 7
    }
  ],
