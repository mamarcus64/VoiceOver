  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And I can only say God bless Australia, because there is no any other country in the world like Australia.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "In every way.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "First of all, the country, it's sunshine.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "It's big.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "It's beautiful.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The people are beautiful in it.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "If you want to work, you can do anything what you want so long as you're not cheating and you don't do any fraud.",
      "word_count": 24
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And if anybody wants to work, any youngsters or any old ones, you can always do what you want.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "It's the most beautiful country in the world.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "I wish I would be born here.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "That would be the nicest way to do.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "But my daughter is already like she would have been born here.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "My grandchildren have been born here.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "So I hope we never have to go away anywhere else so long as we live.",
      "word_count": 16
    }
  ],
