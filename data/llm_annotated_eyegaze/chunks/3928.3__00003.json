{
  "stem": "3928.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I had a pass, which I showed you, you know, the railroad pass.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I used this railroad pass and went to the border, the Austrian border, because I had a movie right in a border city, in Sopron [NON-ENGLISH] was the name.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "It's a small movie theater.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And I talked to the cleaner.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And I told the cleaner-- I had to come up with a lie, because you don't trust nobody at the time.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "So I had-- I was afraid to carry a suitcase or anything with me.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "I had a little briefcase with me, with some of the papers I showed you.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And I had a change of-- of underwear and extra socks, and that's it.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And I told this man that I want to go to Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And I want to smuggle some medicine, because, at the time, there was no medicine.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And if you help me, I will give you all-- half of the stuff if you wait for me and bring me back.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And as far as I know, he's still waiting for me to go back, [LAUGHS] you know?",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But the point is that that's the only that I could go through the border.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I went from-- the first city I went was Wiener Neustadt.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And that's-- I took the overnight train, from Wiener Neustadt, and I went over to Vienna.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I ended up in the American sector in Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't want to stay there, because that's, I felt, too close.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "You know, because this was a Russian sector.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "They had a French sector, English, and American sector.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I wanted to go to Germany, to the German sector-- I mean, in Germany, because the southern Germany was occupied strictly by the United States Army.",
      "word_count": 27
    }
  ],
