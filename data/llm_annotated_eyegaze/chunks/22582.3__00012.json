{
  "stem": "22582.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And there were about four in one, and one small, very small, bed-- bed like a [INAUDIBLE], they call them.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And I went there for two weeks, and I couldn't find the diamond, because the latrine was right next to the-- next to the electric-- electric wire-- electric, how do you call, electric gate, an [INAUDIBLE] gates.",
      "word_count": 37
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Anyway.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And at the other side were the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "Whether-- whenever you are started to looking, when you went to the bathroom, it said, [SPEAKING GERMAN] and with a gun.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And I never found it.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "It was this story with the ring.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't work in Gross-Rosen.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Gross-Rosen was strictly quarantine.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And we had to get up in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And that was in the mountains.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And at that time, it was very cold.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "That's in Silesia.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And it was cold.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And they-- they got us up at-- at 4 o'clock, 4:30 in the morning.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "We had to stay till 6 o'clock at night, 7:00-- till it was dark.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "We stayed.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And everybody-- everybody was next to each other, like-- like you see cows out in winter time.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And one was next to each other.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "That's how we [? survived, ?] all day.",
      "word_count": 8
    }
  ],
