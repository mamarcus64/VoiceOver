{
  "stem": "2165.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The people who used to be in the camp used to throw through the chimney-- there was a chimney going down to the basement-- used to throw us in food.",
      "word_count": 30
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And then we prepared before grains, you know, mostly things that-- it was rationed, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "I mean, we used to get the--",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I would say close to 40 people.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "It was very crowded, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes not enough air.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I remember I used to put my face on the ground to get air.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Sometimes there was not even enough air.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And people got sick.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "I got the typhus in the bunker.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I was very sick-- high fever, but I came out of it.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Some people died.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "We buried them right under, you know, in the ground.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "And my sister apparently, with a friend, survived.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "We had a castle in town where a princess used to live.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "And the Germans used to bring the furniture, the furniture to that stuff and store it.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "From the Jewish homes.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And her boyfriend used to work there.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So apparently, she survived with him over there.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "The Commander-- the Polish Commander of the Jewish camp, which was a [INAUDIBLE] That means his ancestors from somewhere-- they were-- they were German.",
      "word_count": 24
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "They were special treated as Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "He was the Commandant of the camp, and he must have killed a lot of Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "But probably to justify him or to save himself, and for money, too, he made one room in that castle with the princess who-- the rumor was that he was in love with her and for money.",
      "word_count": 37
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And they build one room.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "They closed it up with bricks outside and they boarded up, and he kept 20-some Jews.",
      "word_count": 16
    }
  ],
