  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They dressed me up in that uniform.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And they got the tags on [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And then we had to be in fives.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So it taught me how to count French and to my number, when-- when I had to count the-- And then I walked with them all over Poland.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "They were going to the French zone.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "That was Stuttgart or [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "It was a French zone.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Well, out from the Russian zone, they were going to the French zone.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I walked with them.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I had to share a bed with [?",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Rene. ?] He was very decent.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "He watched over me like a daddy.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And then we got on the-- on the train.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "We had to sit-- it was only-- only a place on the roof.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "So I, of course, I held onto [?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "Rene, ?] and then he held the arm around me.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And we were just sitting there.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And then when-- at one point, the train went on a bend.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "And it was slippery.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "It was raining, and it went slow.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "And I fell asleep, and-- and [?",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "Rene ?] was asleep.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "And I fell off the train [INAUDIBLE] and turned my ankle.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "Ah.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "And I kept on yelling.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "And all the guys were saying, Alors, Jean, alors!",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "I'm telling you, I ran after the train.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "I mean, Tom Cruise in didn't-- would have given me an A.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 30,
      "text": "I ran after the train with my [? limp ?] after the train, as all of the arms were down.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 31,
      "text": "And they dragged me up, and I [? called ?] [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 32,
      "text": "And was an [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 33,
      "text": "And they left me in Berlin.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 34,
      "text": "And they went to Stuttgart, and they left me in Berlin.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 35,
      "text": "The war was over at that point.",
      "word_count": 7
    }
  ],
