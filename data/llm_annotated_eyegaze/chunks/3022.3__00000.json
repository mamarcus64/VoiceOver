{
  "stem": "3022.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah. - Please continue the  story.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I, I was looking for-- getting the Aryan papers for my father, and I contacted some people, and I was told it would take several days.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "So I contacted a Polish girl that I knew that worked for the Polish police.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And she offered to hide my father in her apartment, which is above the Polish police station.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "She felt they would look for him over there, which was true.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So I was able to keep my father about four days, you know, in her apartment above the police station, till I had the papers for him.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Then we-- I took him and my mother in a horse and wagon to the town of Sandomierz.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "We, we-- and from there, my father took a train to Debica, where he was supposed to meet us the next day.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We felt it was not wise to travel all together.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "The next day, my mother and I came to the Debica, and we met my father.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And we went to the village of Wielpole again, where at that time my grandparents, and my uncles and aunts were living with my grandparents and my little brother.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "In that village, we stayed about three or four-- three weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "On one night, the village was surrounded by the SS.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Flood lights and loud speakers were set up.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "An announcement was made that if the able-bodied men and young men will volunteer to go to this particular labor camp, the women and children and the elderly person will not be resettled, will be allowed to remain in town.",
      "word_count": 40
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "We, at this time, we were subject to resettlement.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "All towns were being liquidated.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "We knew the atrocities that were happening, and the, and the loss of life.",
      "word_count": 14
    }
  ],
