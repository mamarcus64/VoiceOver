  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "The money had to be transferred first, and then they had enough to allow us to come here.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "Because these were poor people.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "They-- they didn't have much money.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "My aunt worked as a maid.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "My-- my mother's aunt and uncle, the old people, had a little newsstand in one of the-- one of the buildings here in Manhattan.",
      "word_count": 24
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "They lived in Astoria, in Queens.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "But it worked.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "We got the visa.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "We were early enough to be on the quota, and we came here.",
      "word_count": 13
    }
  ],
