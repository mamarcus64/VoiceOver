{
  "stem": "24231.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I was 23, and she was 18.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "First, we had a small apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And we both saved up some money.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "We bought a six-family house, because I was saying on engineering salary.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "I don't know if I can afford a one-family house.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "So we bought a six-family house.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And later on, we-- we kept the six-family house.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "We bought a house in Plainview.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And I sold the six-family house.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And then we lived in Plainview, I think, for 13 years.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "That's where most our kids went to-- our three kids went to schools, went through the schools.",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "And after they went through the schools, we moved for a while to Massachusetts.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "I was a program manager on a radaring job at Raytheon in Massachusetts.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "And we didn't like it too much in Massachusetts, so we moved back to Long Island and moved to Huntington.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "And that's where we are right now.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "And I went to work for General Instrument.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "That's where I wound up staying all my life.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 20,
      "text": "And my kids, my oldest daughter, she went to-- to Plainview High School.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 21,
      "text": "And she went through Stony Brook University, and then she went to Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 22,
      "text": "She became a language teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 23,
      "text": "She got a master's degree at Stony Brook.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 24,
      "text": "My son went to Columbia.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 25,
      "text": "And then he got a scholarship to Stanford University.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 26,
      "text": "He got his PhD at Stanford.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 27,
      "text": "And now he has a lab at University of Michigan and teaches also in Michigan.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 28,
      "text": "My youngest daughter, she went for-- she was in gymnastics, became a Phys Ed teacher.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 29,
      "text": "And also, her second degree is in software.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 30,
      "text": "But she wound up making software, and she married.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 31,
      "text": "And now she is a housewife.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 32,
      "text": "She just stays at home.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
