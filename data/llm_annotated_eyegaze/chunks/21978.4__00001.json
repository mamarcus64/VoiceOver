{
  "stem": "21978.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "In the sick bay, we might have got extra ration of something what was given to the patients and that they didn't eat because they were sick or they might have died.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "So if somebody died, his portion was always divided between the others.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We had always just the same.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "When we came, we had been stripped of our clothing.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "You have to realize that we have been having our suitcases-- they were not-- never given to us.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "They were just taken away.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They were kept there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And there was special treatment of all the things that prisoners brought to Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Good stuff was separated, and it was sent to Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And other stuff was given to the prisoners as clothing, some of it, not good-- not good stuff.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "We have been given a dress.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "It didn't matter if it fitted or not.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Sometimes a big girl got small dress, then there was exchange.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "We got some-- we had our shoes.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "We had good shoes because I have been given-- I must tell you.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I have been given once shoes, ski shoes, when I have been carrying a-- a dead body-- corpse-- to the crematoria.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "That was not crematoria.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "It was the laboratory of Mengele.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And that was-- I'm not sure where.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "I have been given by one of the kapos, one of the prisoners who was in charge of clothing, secretly he gave me a pair of shoes.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And I carried it back into the camp, in our camp, under the blanket where the corpse was before.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "So I had shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "But we have been given only clothing there what we were using all the time.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "If we were able to wash it in cold water and dry it, that was fine.",
      "word_count": 16
    }
  ],
