  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She felt it is so-- it's is altogether different than what you really expect it to be.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "But since she was a very good student, so she, anyway, she will take the bar the first time around, when everything is, you know, fresh in her mind.",
      "word_count": 29
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And she took the bar, and she quickly passed it and worked for a law-- for some friends who wanted to hook her up with some big firms here.",
      "word_count": 29
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But she said, I don't think that I would be interested in big corporation.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "She was not interested.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "All she still-- I mean, our kids are idealistic.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We never pushed them, and we never made any money either.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, so she worked for one year on criminal-- criminal-- on criminal law and-- and hated it.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "She's-- she's married now.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "She married only recently, she-- she went five years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "She lives in San Francisco.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And what-- then what she did, so she did not want to do the law anymore.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "So we talked about it.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And anyway, she was very much interested in performing arts, especially in ballet.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So we had a friend here who, actually, he was originator of that-- maybe you know that it is Performing Arts Administration, it's part of the MBA.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I said, well, if Karen would like to, you know, do UCLA, she could get that degree if she wants to-- even, you know, to put together, to connect law and these things.",
      "word_count": 34
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So she came down back to California.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And she she got her degree in performing arts administration.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She worked for four years at the Met in New York, always with this administrative thing, and then at Joffrey for five years.",
      "word_count": 23
    }
  ],
