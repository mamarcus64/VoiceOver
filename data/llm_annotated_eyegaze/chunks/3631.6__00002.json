{
  "stem": "3631.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "He had a-- a distributor of-- a wholesale distributor of photographic supplies.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And I worked there for many years.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "It was a family business.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And my sister became an operator, got work very soon.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And it was a slow beginning, but we were very happy.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And we were-- it was interesting.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "We lived in a new country, and we were free.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And it-- it was hard.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "Any-- any new start is hard.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "But I worked in that company, until 1959, I think, for many years.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And I got married in 1957.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And Martha had a-- has a very nice family.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And she had three sisters at that time-- one-- two.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "One isn't here anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And her mother.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And a very good family, a very close family too.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And I was used to a close family.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And my sister died young, in 1954.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "She was married a few years.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And she left a little boy behind.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "My mother died in 1956.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And we got married in 1957.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And my father got remarried again, later.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And he got-- he died in 1971.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In Newark, New Jersey.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, when we got married--",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, we lived in Newark, New Jersey.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but not-- not in the detail, for instance, that I just talked here.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We talked about it.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I never made a secret out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "If people asked, I would tell them.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But I always had a feeling that people either were embarrassed to ask, or they didn't want to ask, because they thought it would hurt me when I talk about it.",
      "word_count": 31
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I guess there was a need for me to talk about it.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And when the picture came out, that-- in 1980-- no, when the book came out in 1982, that started changing my life a little bit.",
      "word_count": 25
    }
  ],
