{
  "stem": "13313.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "So shouldn't be able to tune in to foreign radios, like BBC from London was beaming broadcast, following news from the free world, so the Germans, with their propaganda machine, didn't want anybody to be influenced by-- by the BBC.",
      "word_count": 40
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "So-- so there were edicts out, they were posted everywhere, that anybody who was hiding a Jew, or having such a radio, would be subject to very stiff penalties.",
      "word_count": 29
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "If you were-- if you could turn in anyone who was hiding a Jew, or that you knew someone to have such a radio set, there would be a reward of 2,000 francs. 2,000 francs for a radio, and 2,000 francs for a Jewish person.",
      "word_count": 45
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "So that was the value of a Jew in German currency to the local population.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And this young chap that was supposed to be a friendly co-walker was bragging every time he turned in Jewish children, to me.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And I naturally-- I'd been warned by my parents and by the Roggemans to be as reticent as possible, never to talk to strangers, never to volunteer any information, and just to play the part of being good little Catholic boys, named Roggeman.",
      "word_count": 43
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And I realized the danger of reacting so it was very, very frustrating to have to hear this, and to realize how-- how bad this was, and have to act as if I-- as if I thought it was a great thing that he was doing.",
      "word_count": 46
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "A little bit later, I would say about six months later, Mrs.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Roggeman thought we'd be better off if we were baptized, so she took us to local priest of Hove.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I remember we went to his house, and I remember us walking in, the three of us, Mrs.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Roggeman, my brother, and I.",
      "word_count": 5
    }
  ],
