  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And instead of helping the kid, get over his pain, doing something, when Mrs.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Roggeman [PAUSES FOR 3 SECONDS] saw that he had violated the rules, and try to drink-- although he couldn't drink because it wasn't even beer, she-- she went into a fury, and she picked up a-- a poke, a metal poke that was lying there, because of the firewood that was there, and she smacked him right over the head, and really-- and just kind of split his skull.",
      "word_count": 69
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "The blood just poured out, and the kid-- she almost killed in front of my eyes.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I-- [CRYING] most horrible thing because I couldn't help him.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't help him.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "That was so terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So that's an example.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] My brother, I must say, has never fully recovered from that.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the scar is there, but the mental scars are even worse because my brother has never been able to-- to lead a normal life.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "That's all I can say.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Had a very, very tragic life after that.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Another episode--",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
