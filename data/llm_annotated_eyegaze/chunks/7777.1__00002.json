{
  "stem": "7777.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "They was-- even the government, was always against the Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Even-- the Jewish people won't emigrate from Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Only it was not a possibility.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They want to go to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And Israel was the Englishmen, that they don't give too many certificates.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They were-- they went to Belgium-- not legal.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Some people, they went to French-- not legal.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Some people, they went to United States.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Only, not too many people left Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Maybe, like if Poland was 3.5 million Jews, maybe about 200,000 in all the years, they left the country.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It was not a possibility to-- to go out of this country.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "The-- Even--the last year, it was the senate was over there, a senator, a lady, Mrs.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "[NON-ENGLISH]-- she-- she make a statement-- the Jewish [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "There's too much pain for the animals, like the Jews are killing the animals.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "They have to-- to discontinue this do.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And that was already signed by the senate for the 1st of September, 1939.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "They have to be stopped, the Jewish [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And this life was very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Like, Friday, September 1, 1939, 6 o'clock in the morning, the radio announced the German start the war on Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My family was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They was very orthodox.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No-- even they attend a synagogue, and my mother was very orthodox.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I even went over there every day to shul, two times a day.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My family was a very orthodox family.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the holiday-- the celebration-- the celebration for the holidays was very nice.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Only, like, we have a grocery store.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It was not allowed Sunday to be in the store, to open.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Even it's-- even it was coming out that said, [NON-ENGLISH], like Sunday, Monday, Tuesday, even like a Saturday, Sunday, [NON-ENGLISH], Monday, Tuesday, [NON-ENGLISH].",
      "word_count": 23
    }
  ],
