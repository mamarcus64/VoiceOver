{
  "stem": "131.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[CRYING] Hannah and me went to the right side.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And Serene was also-- she supposed to be on the right side, and she went back, because she didn't want to leave my mother.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And he took her in his hand and pulled her back, and she said no.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "She went back twice to my mother to be with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 5 SECONDS] And the rest was history for everybody.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "They took away those little suitcases what we had from us.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] And they put us in-- in a room, [PAUSES FOR 4 SECONDS] naked.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And they cut our hair.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And [PAUSES FOR 3 SECONDS] just woman.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "And they gave us clothes that we should look like not human at all.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "A thin person got big clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "A fat person got [PAUSES FOR 3 SECONDS] little clothes, just to make fun out of us even there.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I saw that happen.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I wanted to go with them and they pushed me back.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] They pushed me back.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "No goodbyes.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "After that they gave me the clothes, [PAUSES FOR 3 SECONDS] I don't know.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They took us in a room.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I saw my cousin by whom we been in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She lives.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "She's in England.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I saw her.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "She was a beautiful girl, her hair shaved.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I says, Hilda, how you look?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I didn't see myself.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I know what they did with me.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I felt it.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "But you-- you didn't know what they've done to you.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But anyway, then we been together.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Then they pushed us in the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But it was almost the same thing.",
      "word_count": 7
    }
  ],
