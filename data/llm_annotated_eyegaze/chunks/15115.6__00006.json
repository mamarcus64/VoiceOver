{
  "stem": "15115.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "I says to him, I says, are you looking for phone numbers, or are you looking for somebody to work?",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "The guy didn't give an answer.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "I says, where's your broom?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "He showed me the broom.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "So I took the broom.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "I start sweeping the floors, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "I says, no, I don't want no pay.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "I says, I'll work for nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "Just want to-- so I hired myself.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "I worked there Wednesday afternoon, Thursday, Friday, and Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "All of a sudden on Saturday a big slob comes in.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "A big, fat guy comes in, takes a look at me.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "But I didn't know the names.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Like sleeping bags-- I didn't know what a sleeping bag is, or a camp cot.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "They were selling camping stuff.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "But pants, shirts, boots, shoes, socks, gloves, I knew.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "But this stuff, I didn't even know.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "But they had another guy, a salesman over there.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "If a guy would ask me for something I don't know, I used to transfer it to him.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And then I was-- because I was quick.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "So the old man comes in, says, who are you?",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I says, my name-- my name Al.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I work here.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Oh, I'm the boss.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "How do you do, sir?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So the guy [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "He says, go to my car.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I got some boxes.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "Bring it in.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "So anyways, Saturday afternoon comes up, in the evening, 6:00.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "He says, how much you want to get paid?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "Well, I says, I don't want to get paid much.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "I says, just to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "He says, how much you want?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I says, $50 a week.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "Those days, were working for $35.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "A big salesman was making $40.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "I asked for $50.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "So the guy says to me, what kind of food you eat?",
      "word_count": 12
    }
  ],
