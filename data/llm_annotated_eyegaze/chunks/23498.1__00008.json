  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "They were hiding.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And then how we started to talk, and sort of-- but we were full of fear, of course.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I felt so terrible that I-- I couldn't sort of restrain myself.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I started to giggle.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I should-- I couldn't stop.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "That was sort of nervousness.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "Yes,",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I remember.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "It was in and out.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "It was an alarm.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And then it was sort of, you know, another alarm said, you can go home.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "Sort of.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And it was a time when my father said, all the men should go--",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "--to-- --should run away to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Because it's very dangerous.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "After the invasion, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "The Germans were in-- in Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Alright.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "OK, yeah.",
      "word_count": 2
    }
  ],
