{
  "stem": "18626.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And that-- that German-- the American almost shot him because he start to move his hand.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "And he was going like that.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "And they took him right downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "And while they took him downstairs, [PAUSES FOR 8 SECONDS] he said to me, that American soldier-- I wish I knew who it was.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "I should have taken his name.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "I would kiss-- I would hug him.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "I wouldn't know what to do with that man.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "He said to me, [SPEAKING GERMAN], what's your name?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I said, Moishe.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "He said, in America we call you maybe Morris or maybe Marty or maybe Moe.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "[YIDDISH], he said in Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "He says, Morris, [PAUSES FOR 4 SECONDS] if you want to knock his face off, do it right now.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Beat him, that SS man.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I was a skeleton.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I weighed 60-- about 68 pounds.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Almost like 33 kilos.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "That was my weight.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Kilogram almost. 68 pounds or 64 pound.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I got to look it up from [INAUDIBLE] when they weighed me, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "My-- my weight.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "That's what I weighted.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "About 33 kilos.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I was about, you know, to give him that real punch in his face and-- and tell him apart.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "But I gave him a little punch and little thing, I thought I almost broke my wrist here.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "The man said, I know you couldn't beat him.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "We are going to do it for you.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And he gave him a couple of kicks, you know, and pushes.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And he pushed him right, you know, in front of the trucks.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "And he told him to sit down.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And he was searched again, you know, underneath the coat and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "And they took his rifle from upstairs.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "Brought it down, all his things.",
      "word_count": 6
    }
  ],
