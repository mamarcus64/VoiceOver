{
  "stem": "198.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 73.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I was with my sister and with my cousin, Masza, which she survived.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "She lives in Chicago now.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And then we said, what do we do now?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "It was a ghost town.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "The ghetto was empty.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Everybody was taken away.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "So we volunteered, and we went to the station.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "We thought that we are going to a better place.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "So they took us to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "I need to ask you.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "Who-- who-- you volunteered to whom?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We just left.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We volunteered to go someplace to find [PAUSES FOR 4 SECONDS] some food.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It was different.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "There were loud speakers at the end of the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans said, whoever is alive, and whoever is in hiding, should get out and go to the station, that we are go to a working camp.",
      "word_count": 28
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We we going to be together with families, and we're going to have enough to eat.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So we did.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "By the Germans.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So it was nothing to lose.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "There was a ghost town.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So I took my sister and my cousin, and we went to the station, which was maybe two miles.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And we went on the train going to-- we didn't know where we was going-- but they took us to Auschwitz.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Can you describe that-- that experience a little bit more?",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was so numb that I don't even know.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I was all numb.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I lost everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I was left with my younger sister, which was so weak she could hardly walk.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "There were a lot of people going to the station.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They loaded us on trains, on cattle trains with no windows.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "We didn't even had space to sit.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "We were standing.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "People were dying like flies.",
      "word_count": 5
    }
  ],
