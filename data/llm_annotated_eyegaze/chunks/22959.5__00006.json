{
  "stem": "22959.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So I remember when he started going to school, the teacher would always send a note and say, how do you-- how do you pronounce it?",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "How do you spell it? 'Irwin' or 'Erwin'?",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Because I wouldn't pronounce it properly.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I would say, 'Erwin,' and it's 'Irwin.' So we had lots of fun.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "But-- and he was a beautiful baby, with blond curly hair.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And everybody would stop him on the street and say is that a boy or a girl?",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And finally I cut his hair, for he was a boy.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So you couldn't go to school you thought?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I could-- I could not go to school.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And it was hurting a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And so did my husband, he couldn't either.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So we started-- we-- he was working for-- OK, he was working for-- for his uncle in the furniture store.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I-- [SIGHS] I was involved in Venetian glass.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I was selling Venetian glass to-- wholesale to stores, to furniture stores, to flower shops.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Who-- whoever carried it, I would sell it.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The one who supplied me with the Venetian glass was Max Schiff-- Max [?",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Sucher. ?] He lives in Los Angeles now.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "So he would supply me with the items, and I would to sell it.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I was like a middleman.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I developed a nice little business.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I would drive to different places and sell these items.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Finally, my husband, he wanted badly to get into his own business.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And we decided that we'll do it.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And that's when I gave up my business, and he got out of this furniture store.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And we opened up our own restaurant.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And it was a big success.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We did real well.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Can I tell you a little bit about my children?",
      "word_count": 10
    }
  ],
