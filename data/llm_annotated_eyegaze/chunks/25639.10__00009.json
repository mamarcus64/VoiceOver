{
  "stem": "25639.10",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And during that time, I went to Americanization classes, where they taught us English-- language, culture, and history.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I immediately begin to learn English.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I was very restless.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "My aunt didn't want me to work.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I wanted to keep busy.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I really wanted to work, to keep my thoughts away from me.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I-- I was just-- [PAUSES FOR 5 SECONDS] I had troubles, psychological problems, which I felt due to all this-- the changes, the turmoil, a new language, and the frustration in learning it and making yourself clear.",
      "word_count": 37
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And school helped a great deal.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "I loved it, and I did well.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And eventually, I went to high school in Kansas City and-- Americanization classes and then high school.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And then I finally had five years of high school, in three different countries, in three different languages.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And I decided the hell with it, I'm going to take a college entrance examination.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And I passed it, and I started college.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "So I never could finish it, because I could not go full time.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "So I have many units.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And each time-- I mean, I took two, three courses at a time, for at least 13 years.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And so I really just wanted to improve myself and catch up.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And I wanted to improve my job, which constantly grew as I grew.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And I worked my way up to research analyst for financial institution.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "I worked in that field for 20 years.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "St Louis or-- Kansas City was the last one.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, while I was in Kansas City, my Aunt Bella decided to go on vacation, to visit Los Angeles.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "She hasn't been there since-- since some World's Fair.",
      "word_count": 9
    }
  ],
