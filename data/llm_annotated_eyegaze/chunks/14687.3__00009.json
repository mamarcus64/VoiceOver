{
  "stem": "14687.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 6,
      "text": "From the-- when-- when you were in the camp in Wilischthal, where did you go from there?",
      "word_count": 17
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "From there the Germans came.",
      "word_count": 5
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "They said, we must go to-- all the people from the factory-- to the train, you know, trains, like, again, the wagons, you know?",
      "word_count": 24
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "We went inside there.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "No, closing trains, closing-- only time closing, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "We went up there, and there they were going round and round.",
      "word_count": 12
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "And there they were throwing bombs.",
      "word_count": 6
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "What can we do?",
      "word_count": 4
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "We had only water-- for nine days, water and sugar.",
      "word_count": 10
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "We survived.",
      "word_count": 2
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 6,
      "text": "You had no food?",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "No food.",
      "word_count": 2
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "In the train.",
      "word_count": 3
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "No, only for water, you see?",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "And all of a sudden, we saw all the signs are written, Prague-- Prague.",
      "word_count": 14
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "We were passing all these villages, you know, and round, and round, and round.",
      "word_count": 14
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 3,
      "text": "All of a sudden, the train stopped, and they left us there.",
      "word_count": 12
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 4,
      "text": "And all the Germans, they used to be with the clothes, soldiers' clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 5,
      "text": "They change themselves civilian, and they run away.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 6,
      "text": "And they left us there.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 7,
      "text": "Many people who were sick.",
      "word_count": 5
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 8,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 9,
      "text": "All of a sudden, we see people coming.",
      "word_count": 8
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 10,
      "text": "They were-- said, don't be afraid.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 11,
      "text": "We are Red Cross.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 12,
      "text": "We are Red Cross.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 13,
      "text": "We-- they took us to Theresienstadt.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 14,
      "text": "From there, they took us--",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "In Czechoslovakia.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "They took us there.",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "And then they-- to give a nice bath, you know, put [? fluid ?] here, all over.",
      "word_count": 17
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "Because if you sick, you are sick.",
      "word_count": 7
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 4,
      "text": "In any case, they took care of us.",
      "word_count": 8
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 5,
      "text": "They give us a nice clothes, nightie, a coat, and [NON-ENGLISH], all this.",
      "word_count": 13
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 6,
      "text": "And then I said to my sister, I'm going to go around again.",
      "word_count": 13
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "The-- the-- in Theresienstadt, the-- the Red Cross.",
      "word_count": 8
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "They said they're Jewish.",
      "word_count": 4
    }
  ],
