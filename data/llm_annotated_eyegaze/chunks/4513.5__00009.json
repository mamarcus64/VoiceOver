{
  "stem": "4513.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember coming back to Indianapolis, and I got into a cab and told the guy I wanted him to take me to 1051 [?",
      "word_count": 26
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Roche ?] Street.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he turned and looked at me and said, I don't take nobody to nigger town.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And I was always armed.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Even though I came out of the Army, I still had this German souvenir of mine, [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "But it was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And I pulled it out and put it up against his head and said, look, World War III can start right now, and you're gonna be the first victim.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I said, I've got 15 clips on me.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Each one has nine rounds in it, and I'll take somebody out with every round before they get to me, OK?",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Now, you have a choice.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We can start this right now or you can take me to 1051 [?",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Roche ?] Street.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He turned white and he said, I'll take you anywhere you want to go.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Took me there and said, you don't owe me.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I said, oh, no, no, no.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I'm gonna pay you for the cab ride.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "Because you're not gonna say to anybody that I held a gun on you, took you here just so I could get a free cab ride.",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "That's not what this is about.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "This is about letting you know that where I've come from and what I've seen and what I'm about, and you are very lucky to still be alive.",
      "word_count": 28
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I took my stuff out of his car, and I left him.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And I went-- about three days later, I went to Purdue.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And I went to Purdue, and I went-- and I went into the dean's office.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And the lady said, you-- I don't think you have an appointment.",
      "word_count": 12
    }
  ],
