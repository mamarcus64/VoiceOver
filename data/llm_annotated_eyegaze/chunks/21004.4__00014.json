  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Now from the beginning, who stays in the [INAUDIBLE]?",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Five, ten people couldn't go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Take them out on the truck in the woods, shot them.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And that's it, finished.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "Did you ever see that?",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I didn't see it.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Because they took them out.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "We know what's, what's happened that they took them out.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "This was their, their system.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Now months later, the commandant's name was Grzymeck, what his name-- very, very terrible person.",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And his helper was Heinz.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "He was also-- he was a German, real German.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "But he was a Volksdeutsche, Heinz.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "And he was also terrible, terrible person.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "So he say-- the commandant came.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "He say, he say, from now on, next week there's no shooting the Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 11,
      "text": "[SPEAKING GERMAN].",
      "word_count": 2
    }
  ],
