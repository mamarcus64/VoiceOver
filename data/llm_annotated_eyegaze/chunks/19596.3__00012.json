  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "If I got-- if I got five-- say, if I got five sausages, I got about two for myself.",
      "word_count": 19
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "There it was a fortune.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "A fortune.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "Absolute fortune.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I had to give to them first, otherwise I would have been dead.",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I went in there, and they gave me two sausages out of five.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Were the butchers are living, in the barracks, who gave-- who gave it to me during the daytime outside.",
      "word_count": 19
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "You can't.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "You can't.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Impossible.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "They would have asked you where you got it from.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "They would have talked.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "You can transfer this saus-- a piece of sausage you can transfer into bread and help some-- a friend of mine with bread, but you can't give him the sausages.",
      "word_count": 30
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "They were special.",
      "word_count": 3
    }
  ],
