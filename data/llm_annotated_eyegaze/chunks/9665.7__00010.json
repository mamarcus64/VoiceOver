{
  "stem": "9665.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I never played cards.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I'm not a gambler.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "I'm a gambler in my own business.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My interest is I like music.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And-- and that's as far as it goes.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And-- and can I mention something else.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And this goes for my children, I can't do that, you know, what I like.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "I can't do that.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "What about your activities in the Jewish community, presently?",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Jewish community-- I'm very much involved.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I was involved with building the-- involved-- how does it go?",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "One, I called a synagogue, Central Synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I joined them when I arrived here, in Grafton Street.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And it was Felix Friedman who got me involved in the [INAUDIBLE] court.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I was-- I organized-- organized for them the-- organized for them the-- the overdraft.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I was talking to the architect, and so on.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I didn't have a fallout, until years later, which was with a man called Gulowski.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "I might as well put it there.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "Gulowski came home [?",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Adelaide, ?] who didn't know me.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "The board came to see me at my home, I should come back.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "Joseph [?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "Bradenaugh ?] organized a cocktail party to come back, but my-- the President of the Temple Emanuel, [?",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Motel ?] [NON-ENGLISH], wanted me to join the temple, and gave me seven seats.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "My seven were only five, because this is the old-fashioned way of going about the Jewish thinking.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Jewish thinking is you are five, and you get the odd one to come and join you.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Now, I'll go a step further.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You want to know what I did for the Jewish-- OK.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I-- Rabbi Feldman was my friend.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I think I paid either for one or two rooms.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "You want me to go further?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "OK.",
      "word_count": 1
    }
  ],
