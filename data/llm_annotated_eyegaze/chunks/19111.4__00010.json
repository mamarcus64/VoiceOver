{
  "stem": "19111.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And as soon as the women got off the train, the Lithuanians and the-- and-- and the Germans ran by all the cars and they shut the doors.",
      "word_count": 28
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And the train took off.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And the train took off-- that was in Stutthof, town of Stutthof, where my--",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Stutthof is in Prussia, I believe.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And that's where my mother, my sister, my aunt, and my-- my cousin Debbie, they were taken off there.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And my father and I, and most of the Lithuanian people from Kaunas-- men-- were were taken into Germany.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They were all mostly people from Kaunas.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "S-T-U-T-F-- I believe F-F-H-O-F, something like that.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "T-T--",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "H-O-F, right.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "That's where I was separated from my mother and my sister, right.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We were brought into camp number one, which was a satellite of the Dachau concentration camps.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "D-A-C-H-A-U.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That's right, exactly.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "In August 1944.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was-- when we arrived in Dachau, the first day that we arrived, they put us into a roll call.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Everybody had to stand at attention.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And they counted us.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And they gave us numbers.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "My number was 80984.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "8-0-9-8-4.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] That's right.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "That was my number.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "My father's number was 81478.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And these numbers were not put on the-- tattooed on the arms.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "They were given us on the-- on the little white piece of cloth.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And the number was written.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "It was-- and they gave us the striped garbs to wear, prisoner garbs.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And I recall this terrible indignity.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "They told us to give up all our jewels, and all our monies, and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "We had to give up all our clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "Everything has to be given up.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And some of the people have thrown their-- their possessions into the latrine, into the bathroom over there.",
      "word_count": 18
    }
  ],
