{
  "stem": "8072.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And this in-- about-- in February they started to-- reducing the camp because they might have finished the work and that they were trying to reduce the camp, and they're trying to combine it with another camp which was nearby, which was called Plaszow.",
      "word_count": 44
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And when they were a reducing the camp, I don't know how, but I was one of the ones that was in the reduction.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I was sent to Krakow ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "By myself.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They were still-- my two brothers and my sisters remained in Prokocim and I was sent to the Krakow ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "At that point was-- it was bearable.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "You-- you did-- you worked a long hard day, but you were able to still have something to eat because you still had x amount of money from-- from-- from home, you know, from Poland.",
      "word_count": 35
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And the living quarters, I mean, it-- it was survivable.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You know, I mean, you didn't-- you had to-- you didn't have to ask that much.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "You had-- I guess there was SS, but it wasn't that-- it was bearable.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "It was livable, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "It was survivable, you know, something like that.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, well-- well, my sisters, you know, they-- you know, they had their cooking.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So if you work in a kitchen you always have something to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Schmattas.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "You were freezing.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You didn't have the warm coats and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "You get up early in the morning, feel like it was cold.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "It was raining.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And yeah, it was-- it was miserable.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Then-- then I wound up in ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In Krakow ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And in ghetto, I didn't-- I was by myself.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have anybody.",
      "word_count": 4
    }
  ],
