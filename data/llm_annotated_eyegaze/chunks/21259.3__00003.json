  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "That was waiting to [INAUDIBLE] Italian, though they told me they need-- they need-- you are supposed to wait.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I got a quota, a quota.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "To wait-- make for a quota to go to America.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Takes a few years.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "The-- I tell you why I wait so long, though it's coming special [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "A special [INAUDIBLE] they take to Canada.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Either I think that they take me to Canada.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And from Canada to America, it's not far.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "So there was a Jewish ORT, ORT class-- ORT children.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "In Italia.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So I learn.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They need four years, special [INAUDIBLE] four years, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I'm a tinsmith, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "In there, [LAUGHS] you know?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I tell you, if this, I go to learn this.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "That was the Jewish Committee, you know, the ORT?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And they took me, and I learned there.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "In two months, I got-- I got a permit, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I'm a furrier.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Operator.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "In, in not long, you know, took some few weeks, and I was coming to Canada.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Where did you-- where did you meet your first wife?",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In, in Italia.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "In Italia, I got married there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "She's, she's from Romania.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "She's a Romanian Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Survivor, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They went to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She was in Israel with the-- with the mother and her brother.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Then when I got married in [INAUDIBLE], you understand, she told me, you know, she has a brother with her mother, with this, And you saw they were coming to Canada, you know?",
      "word_count": 33
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Now, we make up, you know, papers with all us, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And they come from Israel to Canada.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And we got the house, you know, apartment, nice apartment in Canada.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And, and they're living with us here in this.",
      "word_count": 9
    }
  ],
