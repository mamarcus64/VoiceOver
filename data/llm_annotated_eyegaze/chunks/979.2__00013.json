{
  "stem": "979.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't strong.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Like I-- at home, because I had too much homework when I used to go to French school and English school, that I was-- I wasn't strong.",
      "word_count": 27
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "You know, like I was working hard to study.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I said to myself, to my sister, I'm going to die.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "So-- and you can't say no.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They picked me.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And I wasn't supposed to go.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "I was supposed to go two weeks later.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "I don't know where they were going to put us.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "But something wonderful happened.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And suddenly, a [NON-ENGLISH] came from the main office.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And they say-- who speaks-- oh-- who has this number?",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We don't have names.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Numbers-- that was our name.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I say-- so we look at the number.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "That was new.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I didn't even know what name and number it was.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And she says, I have this number.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And my sister say, two girls.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I say, who has this other number?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "My sister, I have it.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I say, what do they want from us?",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I thought, what they're going to do to us?",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "So she says come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "They never say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "They let you just wonder.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "So we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "And we went to the next camp.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "There they had the lager A and lager B.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "And there was a division in between them.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "You couldn't get from one lager to the other.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "There was the barbed wires.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "You know, if you go near there and you touch it, you get killed.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I saw somebody getting killed by mistake.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They put their hand.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "You know, so in between-- so we--",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I was in lager B.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And they took us to lager A-- to lager A, all the way around-- the other way around.",
      "word_count": 18
    }
  ],
