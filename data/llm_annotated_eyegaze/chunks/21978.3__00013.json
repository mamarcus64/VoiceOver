  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "To come out in the yard to be counted, we had to stand for hours and hours to counted in rows.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "If you were sick, and you couldn't stand there, and you were just falling down, somebody helped you to stand up.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "There were long hours of counting when the SS men came-- and the kapos, and the blockalteste, everybody was in charge, very important, counting.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "And we had to stand if it was raining or not.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "And if somebody was missing, that she was sick and she was still lying on the bunk and couldn't get down, or somebody went to the latrine and didn't come out in time, we had to stand there and wait.",
      "word_count": 40
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
