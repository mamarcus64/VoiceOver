  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And-- So what kind of-- what kind of Jewish education did your daughter have growing up?",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "She got-- I, I [INAUDIBLE] she learned in the Hebrew school, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I sent her.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "In the Bronx.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I used to live there.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "In the Bronx, in Jerome Avenue, there was a Jewish-- oh, she used to, till turned to me and she got-- she has a [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "She got bat mitzvah with everything, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I gave her.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Even the school she was in Boston, she went to Sunnybrook.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And after Sunnybrook-- and after she went to Boston, she took candles-- she Hanukkah lights.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "You know Hanukkah?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "She lit the candles in Friday.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Now, the husband, he never was [? relig ?] You know, the mother, you know, I tell you, the whole family was goyim, the most.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Now, my daughter, you know, are Jewish home, kosher, kosher, [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Even I'm not [INAUDIBLE] very kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And, and they want the children [INAUDIBLE] this is.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And, and I'm, I'm not against.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Do what you want.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "It's your home.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Now, That have a house.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They live in Oceanside.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They bought two years ago.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And every day, you should see my grandson, four years old.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Zeyde, how you-- how you feeling?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] Just let me ask you one other question.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "What, what effect had your experiences had on the way you brought up your daughter?",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "You brought her up a certain way because--",
      "word_count": 8
    },
    {
      "segment_idx": 52,
