  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So as I was already past the police guards and I was already in the station, and we both go to the one that the girl who gave me in Kiev that led to her friend in Moscow.",
      "word_count": 38
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And this is on the [NON-ENGLISH SPEECH], that means that in the station which is completed.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So yes, we came down.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It was a beautiful railroad, beautiful station.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "The subway, I thought it a museum.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we were asking two Russian policewomen, where is the right Russian station, and she showed us straight to the train, and we came there.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "As we came to the address we-- I had, and we walked up a couple floors, there was no elevator.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It's a 10 floor building without elevator.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So we walk up, and-- and I knock the door, it was late in the afternoon.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "It was about 3 o'clock and nobody answered.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So I was a little bit concerned, I hope I-- I don't have nowhere to stay or to be.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And then we sit down on the steps and waiting until 8 o'clock in the evening and knock again.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And here comes out this young girl, and she-- and I give her the letter.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And she was very excited.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And I told her who I am.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "She said, please come in.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And she took us in the whole apartment, the whole-- it was only like a little room, like just a bed, a table, and a-- and a candle light on the table, and that's it.",
      "word_count": 35
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And she apologized that she is studying to be a doctor, she studies for the last weeks and weeks.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "She has nothing to eat much and she did not hear a knocking.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "So I said, don't worry.",
      "word_count": 5
    }
  ],
