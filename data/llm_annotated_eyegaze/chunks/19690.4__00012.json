  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "I decided to change to restaurant management as a goal.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "In 1950, I was working in the Catskills as a waiter when the war broke out with Korea.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And knowing my luck, I would be sent in the infantry to Korea.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "I didn't want that-- enough mud and dirt-- so I enlisted in the Air Force on the 27th of December, 1950 and became a radio man.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "I spent some time in California, I spent some time in Washington state, and then was shipped to Korea in October, 1951-- 52, after going through radio school at Keesler Air Force Base.",
      "word_count": 33
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "And spent a year in Korea, first in Taegu and then in Seoul in the communications centers there.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "After I came back, I was stationed in-- near Detroit, Willow Run Airport, for just under a year and I was discharged early in order to start attending college.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "I got an admitted to Paul Smith's College in upstate New York, near Saranac Lake, to study in hotel and restaurant management.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "It's a junior college, where I spent the first two years.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "After that, I transferred to Denver University and finished the last two years and had a bachelor's in science in hotel and restaurant management.",
      "word_count": 24
    }
  ],
