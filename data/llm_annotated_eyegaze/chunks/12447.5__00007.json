{
  "stem": "12447.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Greenberg. ?] And we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we had a-- [PAUSES FOR 3 SECONDS] she gave birth to a boy, Jeffrey, in 1959.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And we lived a nice, happy life for awhile.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And over the years, being in New York, I did not like to live in New York, and work-- especially my trade, I was a construction worker.",
      "word_count": 27
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And it was cold.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I couldn't stand this kind of a life, this kind of world.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I wanted to be more independent.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I decided that I am going to move to Florida.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "We went to Florida a few times on vacation.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I decided that this would be the right place to go.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "Maybe in Florida, I would be able to maybe do some building on my own, and become independent, and so on.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "This didn't work out.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "But we lived in Florida for about four years.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I was able to save some money, bought a house over there.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "Anyway, she decided not to live in Florida.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "She did not like Florida.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "So from Florida, she thought I would get back to New York.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "But I didn't want to go back to New York.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "We moved to California.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "We moved to California.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "And in California, after a short time, I got a contractor-- general contractor's license.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "And I became a independent contractor.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "So I've worked here for-- since 1977, I worked as a general contractor.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "The name of the company that I formed was [INAUDIBLE] Construction.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "I was not a very large contractor.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "I was a small contractor.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "I had people working for me.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "I was happy for awhile, but my wife was never happy to be in California.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 30,
      "text": "She always resented it.",
      "word_count": 4
    }
  ],
