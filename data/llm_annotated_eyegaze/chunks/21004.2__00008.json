{
  "stem": "21004.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "Whatever he was working on it, my mother used to come every year and just whatever was taken off, half was taken.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "My mother would sell his half, and that's the way it was working.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "It's still there, the land.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Only one sister, the middle sister.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Pearl. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Pearl. ?] was married.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "The name was Jakobowicz.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I got the pictures I got from my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And they all got-- nobody is alive.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I'm the only one.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I'm the only one alive.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So 1937-- first, when I was in Krakow, 1936 they had very bad in Krakow.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Also signs, [NON-ENGLISH], 'beat the Jew,' and this and that, and all kind of things.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So my cousin came.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He was going to the university of Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "This is my cousin from the restaurant.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "His name was Geitzholz.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Targets So his oldest son was going to the university.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "He come back.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "He used to-- they started beating up Jewish students in the university.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He come back all bloody, beat up, the face and the arm here with-- they beat him up, so he came.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Then it started getting really bad.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They said something.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "There was a-- a church.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They called it [NON-ENGLISH], very tall, high church.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They called it [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Somebody from the anti-Semite broke out the window, couple windows in the church.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "So they said that the Jews did it.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And that's what they say, making like a pogrom.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So once on a Friday night, I remember like today, I was by my cousin.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And then we hear people running in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You heard the-- all the students from all over, they're coming on-- we lived on the [NON-ENGLISH], a Jewish neighborhood, [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "There was a kosher restaurant, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So he say, everybody has to be in the house.",
      "word_count": 10
    }
  ],
