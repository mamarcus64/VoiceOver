{
  "stem": "6076.8",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So she says, look, Rachela, go to America because when you come to Israel, Herb is young.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He's 20-- you know, he was 26 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And he's-- they will take him to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You wouldn't be able to, to resist another life like this, going through.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Go where you can live a better life.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Israel is beautiful, but it's hard life.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So President Truman opened the gates for the survivors because before, you needed-- you needed a visa to go to America.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And, [PAUSES FOR 3 SECONDS] and we registered.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And we came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Tell me when you came.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We came the end of December, you know, December 18--",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "December 28--",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "1949.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We were on-- you know, 10 days on the ship, and it wasn't the easy life.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "The story, what--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Of course not with my youngest son.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "With my son, Solomon.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He was he was three years old already.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "His-- we came on January-- his birthday was on January 5-- with the hope.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In America, was born in 1951 in Brooklyn.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "His name is Joseph-- very bright.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I'm very ha-- you know, I'm very proud of him.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He is a professor at the University of Buffalo.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "My oldest son, Solomon, he finished the Pratt Institute in Chicago.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He got his masters.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He went for architecture.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "They're both bright.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "They also finished yeshiva.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "They're educated in Hebrew and in English-- I don't have to tell you.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And I'm very proud of them.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "They're very devoted sons, and I'm the proudest mother to have my sons and to be together.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I should only live to have nachas from them.",
      "word_count": 9
    }
  ],
