  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "For example, in some level of-- in my school, I must know all rivers in Europe, all town in-- I mean, DC, like Washington, DC, all words.",
      "word_count": 27
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I remember, I receive one very interesting [PAUSES FOR 6 SECONDS] reward about prepare the maps.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My hands was very good to prepare the maps.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And that was my-- I was very patient, good graphic.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I put nice letter, for example.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And how many times-- how many years, I remember, in my life, that was true reward for me.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "All drawings, technical drawings, all the time, I was the first in the class.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And also, the maps, for example, that was my-- and also, during the school, if I can say so, I was-- up to now, I have the same feeling.",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "People trust me.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I was all the time in school secretary of the money, financing secretary.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "How many time-- years, I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "All the time, people vote for me.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Pawel be the guy.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] Now, I am here in a Polish museum also eight years trustee and financing guy.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I don't know, for public, people [LAUGHS] don't know me.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "That was the high school.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And what I can tell about the high school?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "During the high school time was also for me nice.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Because I was very good gymnastic, sportsman.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "That was-- sometime my father was very upset, because, in this country, if you are good sportsman, you have career.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "There, you-- if you are good sportsman, you can die without the bread.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] This time, and that was 50, 60 years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I was good in gymnastic, the same, my brother, very good.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And also, during the-- up to 1938, I was in team.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "We played the basketball.",
      "word_count": 4
    }
  ],
