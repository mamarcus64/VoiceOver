{
  "stem": "15028.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "I couldn't make it practically.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "And that wasn't far.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 17,
      "text": "And I decided that time that I'm going to go instead to try to schlep my bag go home, and go to Sweden.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 18,
      "text": "In Sweden, they were talking [INAUDIBLE] they want in the war.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 19,
      "text": "And they try to make good for the people, what they went through the war.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 20,
      "text": "[INAUDIBLE] And I went on the to the train.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 21,
      "text": "And as soon as I came to the train to the English.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 22,
      "text": "They took a look at me.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 23,
      "text": "And I started walking out.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 24,
      "text": "They didn't let me walk out.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 25,
      "text": "I thought I hear they're holding me.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 26,
      "text": "They don't let me go.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Instead, they brought a stretcher.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And they put me on the stretcher.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't walk anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And they put me on the stretcher on the train.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They took me down from this-- from the train on the stretcher.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "This was the English.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And they put me in the boat.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "In a-- like a thing, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Also like a stretcher there.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "It took only a day or a night into Goteborg.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "Where's that?",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In Sweden.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And [INAUDIBLE] here--",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, I got to know some people there also.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I got to know some people who were in Goteborg in the hospital.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "They took us to a hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] On that hospital I was four or six weeks.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "In Sweden in Goteborg.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they took care of me.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "First of all, they saved me from top to bottom.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "On-- you know, and scrubbed me.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "Nurses.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And put me in a clean bed like this.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Did I have lice?",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] I got the lices.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "That-- I have-- you know, you say, shaving.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I forgot.",
      "word_count": 2
    }
  ],
