{
  "stem": "10768.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Rita Finver, R-I-T-A F-I-V-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "V, like Victor, E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Rita Wielopolska.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It's a typical Jewish name.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "W-I-E-L-O-P-O-L-S-K-A.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, not to my knowledge.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "January 8, 1920.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I just had my birthday yesterday-- birthday.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I'm 76 years old.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lesko, Poland, which is the old Galicia in the Carpathian Mountains, the southern part of Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father and mother-- this was the second marriage for the two of them.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But they never spoke about it, because there were no children prior to-- with the first marriage.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was born when my mother, apparently, was, was over 30.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "She divorced her first husband because they didn't have children.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And according to the Jewish law, if you don't have children, you're entitled to divorce each other.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "We were five children at home.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I was the oldest on both sides, from my maternal grandfather and paternal grandfather.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "The paternal grandfather and my father were born in Brzozow, Brzozow, also Poland, which was maybe 30 kilometers from our town.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We were five children at, at home.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "After-- I was the oldest.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "Then was a brother, Abraham.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "There was a brother, David.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "There was a sister, [NON-ENGLISH], and there was the youngest one, which was called [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Our grandfather-- the maternal grandfather-- lived, we lived in the same building.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "He was ultra-Orthodox, and so was grandmother.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "They were strictly-- very strict in, in their religious behavior.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And even though my parents were also Orthodox and kosher-- but grandfather was so strict that he didn't even want to eat in our house.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Naftali Wielopolski.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "When he came to our town when I was a young child, he was buying skins from wild animals or from rabbits.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And these skins were dried.",
      "word_count": 5
    }
  ],
