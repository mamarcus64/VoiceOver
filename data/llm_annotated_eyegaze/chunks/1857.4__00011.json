{
  "stem": "1857.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 473.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, I came to New York on a Saturday, and Monday I was already at work, working for my-- my uncle, actually, but my cousin was the big boss.",
      "word_count": 29
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They put me into their warehouse.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They had plumbing and heating supplies.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And they had six stores and a huge warehouse.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And they put me into warehouse.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I work loading and unloading railroad cars when the-- when the bathtubs were coming, and the-- and the pipes, and the-- and the hot water heaters, loading and unloading.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I wasn't very happy with this-- with this job.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And then they transferred me-- deliveries to people's home.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Delivering bathtubs to the fourth or fifth floor, schlepping it on a-- on a staircase.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And I quit.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I got into an argument with my cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Oh, they prepared the-- my uncle prepared an apartment for us above one of his stores.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "He owned all the buildings where his stores were.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Which was a sort of a shopping street, busy, but look, apartment with two or three bedrooms was terrific.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "We were very thankful.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "My father, in the meantime, decided that he will try to get back into goldsmithing.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "So he set up a little bench, and he started working in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And he worked for five, six months.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And he said, I'm ready to do some work.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "So after work, I used to go, in the evening to jewelry stores, and get repairs, and bring them in.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "This eventually developed-- like, before Christmas we were getting so much work that I learned how to file the rings.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "My father was soldering and my mother was polishing.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And we worked 20 hours a day, day in and day out.",
      "word_count": 12
    }
  ],
