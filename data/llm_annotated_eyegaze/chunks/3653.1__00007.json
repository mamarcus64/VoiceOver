{
  "stem": "3653.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "Because every-- every day was 20, 30 dead people from there, from hunger, from death.",
      "word_count": 15
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "So they took the Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "We have to take them there to the graves.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "So from our camp there was about 5 miles, a little wooden area.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "They dig a big, a big hole with bulldozers.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And we used to-- and they made a box with the 2 by 4 on one side, and a 2 by 4 on the other side.",
      "word_count": 26
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And four people was carrying the box with the dead person.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Till we reach there, a lot of people, you know, died.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Of course, sometimes it was a rainy day.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "With mud, you couldn't do it.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "So the guy took a gun and-- and killed him.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "So till they reached there, was already two three people in one box.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "This was the worst job in your life, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "When you first got to this camp and you got off the truck, can you describe exactly what happened to you?",
      "word_count": 21
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "They took us off.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "They put the Ukrainian people separate, the Jewish people separate, the Polish people separate.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Oh, right away they separated everybody, separated everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "They put me in a barrack there with the Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "It was just-- just to sleep on the floor, was nothing there.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Even the roof was not finished there.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Was [PAUSES FOR 3 SECONDS] in November, I think was it.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No, it was cold, rain, everything.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] the blouse from the army just.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I was wearing two months, the same blouse.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Shoes.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "If you have a good pair of shoes, they took away from you.",
      "word_count": 13
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "They give you their shoes, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Wooden shoes just to survive.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "They were from Poland, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "They was from Russia, too, you know.",
      "word_count": 7
    }
  ],
