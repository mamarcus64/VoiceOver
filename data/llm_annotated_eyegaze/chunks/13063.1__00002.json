{
  "stem": "13063.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a very devoted-- devoted [HEBREW].",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "She was a devoted homemaker.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "In spite of having the chores of helping out in the factory, she was a wonderful homemaker.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "She was a wonderful cook.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She was [HEBREW]-- with heart and soul-- tied and devoted to the children, and of course to my father.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I remember Shabbat was a beautiful occasion of togetherness, of spiritual fulfillment, and, of course, of good food.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I remember the gefilte fish my mother-- my mother used to make.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I remember the beautiful meats-- the variety of meats-- that she prepared for Shabbat.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Not only for Shabbat, for everyday.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "She cooked every day.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And in spite of us having a live-in maid, she was always there in the afternoon to cook, for us, dinner and to be-- to be of help, not only in the factory, but to be of help in the-- for the family.",
      "word_count": 43
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Every Shabbat.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "There was no Shabbat without Cholent.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was-- it was-- it was a integral part of a Shabbat celebration.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Cholent?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, of course, the regular-- beans, meat, sometimes a hard-boiled egg.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It was delicious.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But there were special recipes that my mother had that nobody can match.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Perhaps my wife some-- can match it, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And not only the Cholent, but beautiful cakes that she'd bake.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And not only cakes, the challahs.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She baked challahs for every Shabbat.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And you didn't have such facilities like we have today.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "It was an oven, you know, a-- an oven which was-- which was [PAUSES FOR 3 SECONDS] on coals.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "It was heated by coals, an oven with coals.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "You know, the old-fashioned ovens, the-- the-- you know.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And-- and it took quite a-- an effort to bake challahs, to bake cakes, and to cook.",
      "word_count": 17
    }
  ],
