{
  "stem": "12003.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.6,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And I, as a very young child, I remember my father somehow-- I don't know how this happened, but he told me one day that, I will be working for a paper factory.",
      "word_count": 33
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish people used to own the factory, but the German took over.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And these people used to teach me how to make lines on a tremendous, tremendous printing machine.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I remember I had to be pushed up to stand up on this machine, to feed the tremendous paper so the machine would make lines.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Later on, the papers were cut and sent in to schools, I guess, or to businesses to be sold.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "No, I was the youngest.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I was the only child that worked there--",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "--among adults.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, there were ways.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They were-- first of all, they made me look older than what I was.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I had long braids, and they used to put the braids around my head a couple times.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And they used to dress me with a long dresses.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "So I appeared, at that time, like 15, not like--",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "About 11.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And this is how I left ghetto, with this company.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Because they were liquidating ghetto, and they're going to forced labor camp, Plaszow.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I went with this company.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But before the company was set up there, I was busy washing windows in the barracks.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Because I already was shipped out to Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "But you could still go out with a group.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "We used to go, and come once in awhile to the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And I still could see my parents, because my parents were still in ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "They were shipped out with the last transport to Biezanow when the ghetto was liquidated.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "But I already was in Plaszow, which is a different camp.",
      "word_count": 11
    }
  ],
