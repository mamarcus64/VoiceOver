    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And my parents lived then in this terrible apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And they had-- they packed their belongings because they were expecting to go to Switzerland and eventually also to England.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Because they had this visa for England.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And they sent the whole, what we call the lift, which was a moving crate with the furniture, to England to furnish the room that was supposed to be their room in [NON-ENGLISH] house.",
      "word_count": 34
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And so with that, that was the resolving of living where we lived.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And my father did sell the house, which later after the war came back to me.",
      "word_count": 16
    }
