  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So eventually, she insisted that we take her car.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Now, I've never driven on the wrong side of the road, as you do now.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I-- because of my arthritis, I drive an automatic little car on the left side of the road.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I'm now in a car that is not mine, which makes me nervous, which is manual, which I can't use my arms properly.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And which is driving the wrong side of the road.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I have to get to Hof.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I did it with great trepidation.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I did it.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And then we had to go from there, because as I said, I don't speak German at all.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I can understand a little.",
      "word_count": 5
    }
  ],
