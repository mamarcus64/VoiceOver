  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And-- and he was [PAUSES FOR 4 SECONDS] praying to himself.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "My father, and-- just the opposite, like my grandfather Enoch would open the window Shabbas morning, and-- and-- and read out loud from-- from the-- from the portion of the five books of Moses that was for this particular Saturday.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And so the whole community could see how well he knows it.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "So it was very-- they were both wonderful people, but there was-- I could see the difference.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "I was very close to my grandfather in Oswiecim, to Enoch, Wilhelm Enoch, because when he retired, he-- he raised pigeons.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And-- and when I came home from school, I used to help him with-- with the pigeons.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And he-- he knew, you know, the pigeons with the-- would sit down in-- in the middle of the little-- of the square in our building with food, and the pigeons would-- would come on over and sit down on his head and on the shoulders, and-- and he would feed them.",
      "word_count": 52
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "And he knew every pigeon, and he knew exactly how many he had.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "It was a-- [PAUSES FOR 4 SECONDS] it's very unusual type of a hobby that he had.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And they both lived to be old people.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "However, Not old enough because their life was cut down when the Germans sent them all to Auschwitz.",
      "word_count": 18
    }
  ],
