{
  "stem": "27443.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Nobody knew what the future will hold for us at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "As I said, the next morning we were loaded into trains.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where our destination is.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "We were loaded into trains, and then after a few days, we wound up in Izbica.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We never knew the town.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I never heard of it as a young girl.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "This is in-- near Lublin.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "We wound up in Izbica.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "When we wound up-- when they took us out from the trains, the Judenrate from Izbica met us there.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And we were--",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "In the train?",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well those are not sitting compartments.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was trains that they loaded animals.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They transported animals-- with straw on the floor, with no way to go to a bathroom.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We had no food or drinks.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "But somehow, we survived.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I guess my mother took with her certain-- certain things for-- for the children to be able to get through it.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And when we wound up in Izbica, we met-- we were met by the Judenrate, and they resettled us.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "From Izbica, we went to Krasnystaw.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "In Izbica, we were a few hours.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We were given water and certain food and bread.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we were loaded up into horse wagons, family-wise.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We were loaded up two or three families into a wagon, and we were taken to Izbica-- to Krasnystaw.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "That was another town a few kilometers from Izbica.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "In Krasnystaw also the Judenrate decided that they had previous transports of Jews, and they don't have place for us.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And that was already winter time, and we were loaded up on-- again, on wagons, and we were take to Gorz-- Gorzkow.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I remember the snow was so high, and it was so freezing.",
      "word_count": 12
    }
  ],
