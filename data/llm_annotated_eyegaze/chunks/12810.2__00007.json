{
  "stem": "12810.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "And they take us to the wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "That was in June, early June.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, it's started the hot weather-- spring-- summertime coming.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And they take us to the wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Walk-- walk to the-- the wagon, come into the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Because that was a big factory.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "They have their own-- own train line, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "So it was the-- the train come out, and they put us in.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "To the wagon.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Like they take the sheeps, and the-- the things, you know, the animals-- exactly the same wagon.",
      "word_count": 18
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Ugh.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] You can't count it.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "We was-- we was like a herrings.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "But then a [? siren ?] started.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Siren.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And they said, everybody out!",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "Everybody out!",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "German soldiers and Hungarian soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "And they said, everybody out and go to the bunker, the-- the Jewish bunker.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And I said to myself, no, not me.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "I run to the non-Jewish bunker, I take off my blouse where I have the star.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And I have a scarf.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "And I put it on my head.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "And I go to the toilet.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "And I don't move-- when everybody settled down.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "And then I leave my parcel there, and I walk out.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 9,
      "text": "And I started to run to the gate.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 10,
      "text": "And then that boy who was taking me to the doctor's--",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "In the fire engine.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "He was standing there and look at me.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "What-- what-- what-- what did I do over there?",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And I shake my head.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "I said, oh, don't.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "And he turned around.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "And between the two soldier with the gun, I run out in the gate, and I take a big breath.",
      "word_count": 20
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "And I run to my father place.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "Nobody was in the street, because it-- it was a bomb--",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "This is it, yeah-- [NON-ENGLISH], you know?",
      "word_count": 7
    }
  ],
