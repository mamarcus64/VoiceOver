{
  "stem": "20684.3",
  "chunk_idx": 19,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "And we've got a holiday house on the peninsula, which we go on weekends.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "And I-- I-- I am a volunteer at the holocaust center.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "I spend a great deal of time there, two or three days a week.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "I'm a president of the Victorian Bridge Association that I've been for eight years and I do a lot of volunteer work there, as well.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "I work at the National Council of Jewish Women, where my wife has been recently elected as president of the National Council of Jewish Women.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "And that's-- we are very happy with that.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "She she's very busy that way.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "And life is a game and I'm talking to you today.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "That's-- that's also nice.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "It's nice to be here.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "But I'd like to dedicate my talk, and I always do, to the one and a half million children that perished because none of them could talk.",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "I also indicated-- dedicate my talk to the children that survive but are not able to talk or they're too traumatized to talk or they don't have the opportunity.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "I have all those opportunities.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "I qualified in the [INAUDIBLE] criteria.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "I can talk, you gave me the opportunity.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 39,
      "text": "Thank you very much and it's been a pleasure.",
      "word_count": 9
    }
  ],
