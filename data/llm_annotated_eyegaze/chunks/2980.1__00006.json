{
  "stem": "2980.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And whenever they write about synagogues in Europe, they point out the synagogue in Luboml, which existed all these years and survived of the pogroms, and all the wars, and all the-- and all the invasions, and till-- till this war.",
      "word_count": 41
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "When after this war, they destroyed the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "The synagogue had walls which was a meter and a half thick.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "It was very huge, but it was all destroyed.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "At home we spoke Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Everyday, among ourselves, we would speak Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "When we came to-- to the school, we had to speak-- we were forced to speak Polish.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "If we didn't speak Polish, we would have to pay fine of 2 [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "2 [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And for us children, it was a-- it was a lot of money.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It meant not having an ice cream.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "It was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Really very, very, very little.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But you can buy a candy.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Kids measure in terms of an ice cream or a candy.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The [HEBREW] rabbi was, they called him the [HEBREW] rabbi.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I have to look up for the name in the book.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "His name was Baruch Twerski.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And he had a son-in-law, which was-- I think I gave you the name.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was kind-- I was very skinny.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I would eat very little.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I was more the studious type, scholarly type.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I would not go into-- most kids would go into playing ball and other things.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I would do it every once in a while.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "But I would make my own little notebook.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And I would make little notes in it.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Till today, I do this thing.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I make a little note, I put it in my pocket.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And I would always try to do something different or invent something.",
      "word_count": 12
    }
  ],
