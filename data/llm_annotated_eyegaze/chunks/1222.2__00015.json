  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "In Mezhyrich. 20 police, they killed.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The first day when they came in, the second day, they hanged them.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Because they figured that-- the-- the partisans figured themselves that there will be themselves in trouble, because maybe they still have the guns, or maybe they will come around at night time and fight with them.",
      "word_count": 36
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So they picked up the ones where the-- anybody squawked, and they tried to kill-- and they killed them.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They didn't-- there was not such a thing like a trial.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They have to save their own life too, because after all, they know how to fight, and they were-- they know they are guilty.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "They were the killers for the Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And sooner or later, they going to be taken.",
      "word_count": 9
    }
  ],
