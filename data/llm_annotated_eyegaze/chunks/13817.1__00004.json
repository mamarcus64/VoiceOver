{
  "stem": "13817.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "She always would eat with us together.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And this-- this was just part of the family.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And we-- I remember two maids, we had and each one of them until '35 and Hitler came out with the Nuremberg Laws.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't have any maids that age anymore, the young girls.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Both of the maids were with us for over 10 years until they got married.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "So they were treated like a daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "My mother really treated any-- any girl like anybody else.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "The business was 60 years old and never had a lawsuit until the Nazi time when some guy pulled some trick on doubling receipts on a radio he bought.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And even the judge-- he was represented for 40 years by a-- by a high Nazi-- high Nazi official who was the-- the-- his lawyer, and even the judge come-- came to the conclusion that there was nothing illegal done.",
      "word_count": 40
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I had Jewish-- I had non-- a non-Jewish friend but I would say 98% of the friends were non-Jewish.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I was at their home, and they were at our home.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We were living together, playing together.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Whole time there was no-- like I said, there was no different.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We were very well-liked.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Like I said, my parents grew up.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "My mother's friends were all more or less all non-Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And her parents lived in that town and grew up there.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Her great-- great-- my great-grandparents lived there.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Their parents lived in that town.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "So on my mother's side, the whole-- as far back-- like I said, before I can go lived in that town and were always very respected.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Until 1933, life was a normal life like any place else.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And in the summertime, we went swimming in the river.",
      "word_count": 10
    }
  ],
