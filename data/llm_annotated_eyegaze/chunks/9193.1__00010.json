{
  "stem": "9193.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "And he was working for the Sultan of Johor.",
      "word_count": 9
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "You've heard of Johor?",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "You have?",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the Sultan of Johor was his client at the time.",
      "word_count": 11
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "And had-- he built-- they're still standing-- little houses for all his wives and what have you, staff and-- in Johor.",
      "word_count": 21
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "And my late husband--",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "I think so, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "He was very, very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "First of all, he was not half dark, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "He was-- and not so terribly religious, very religious business.",
      "word_count": 10
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "And I was really non-- I didn't-- I didn't have any Jewish--",
      "word_count": 12
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Not much affiliation with the Jewish religion at all.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Pennhaus didn't like me--",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "No, he was not very keen.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, no.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "He let me go out, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "He had to come to the house, and he had to bring me back to the house, of course.",
      "word_count": 19
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Can't remember.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "Not very long.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Well, when he proposed to me, I first of all didn't understand him.",
      "word_count": 13
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "My English wasn't good enough.",
      "word_count": 5
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] And-- but he went to Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "Penhaus, to him.",
      "word_count": 3
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "Very reluctantly, he said to him-- he told me later on.",
      "word_count": 11
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't present, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "He told me later on that he was very, very heartbroken, because he had a sister.",
      "word_count": 16
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 3,
      "text": "Penhaus had a sister.",
      "word_count": 4
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 4,
      "text": "She was the ugliest duckling under the sun.",
      "word_count": 8
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 5,
      "text": "You have never seen-- and she was not married.",
      "word_count": 9
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "That was Flora.",
      "word_count": 3
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "And Flora didn't like me.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And Flora-- but they were frantically looking for a husband for Flora and couldn't succeed.",
      "word_count": 15
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    }
  ],
