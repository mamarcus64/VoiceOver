  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] And we didn't know what's going to happen, but the rumors were that we-- that they're going to liquidate the ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "My father was still in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And because I knew a lot of [PAUSES FOR 4 SECONDS] Gestapo officers over there, I plead with one captain [PAUSES FOR 3 SECONDS] that my father is a watchmaker, and he's a jeweler, and maybe he will be able to be useful for the, for the headquarters to fix people's watches or-- because they needed people to work.",
      "word_count": 59
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And somehow I persuaded [PAUSES FOR 3 SECONDS] one of the majors over there to give an order that before they liquidated the ghetto, they should bring my father to the prison.",
      "word_count": 32
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Actually, the prison saved our life.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Because we were locked up in the prison, we were, we were safe to-- in the prison.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "That saved our lives.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "At that time they liquidated the ghetto, literally.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "They took a lot of the people from the ghetto to concentration camps.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "The one who was older, they used to, they used to shoot, shot, shoot a lot of people, kill them.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] They went to hospitals, and they liquidated the hospitals.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "They used to shoot the people in bed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "My father was telling me, when he came in-- they found him, [PAUSES FOR 3 SECONDS] because he was in the house where the-- actually was designated for us, so they-- the, the major gave a order to look for my father.",
      "word_count": 42
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And they found him.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And they put him on a truck.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 5 SECONDS] They put him on a truck.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And the same truck stopped in a nursery, [PAUSES FOR 4 SECONDS] and they took about 20 kids from the nursery, on the same truck.",
      "word_count": 25
    }
  ],
