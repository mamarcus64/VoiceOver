{
  "stem": "14715.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 24.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We saw a month before.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "When the Russia war broke out, we were told among us-- nobody told us, but a rumor went around that they're going to bring the Russian prisoners of war into this camp, and we're going to be sent home.",
      "word_count": 39
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We actually picked a date that that date, we're going to go home.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "It was a Sunday morning, and the SS came in, chased us all out into the yard.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And at that date, they picked seven boys from our camp and they hanged them-- first three, then more three, then one on the end.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And there was a big public-- a lot of people came in to see that spectacle.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They were sitting on the gallery in the stadium.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And from that day on, we didn't even know what's going to happen to us.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They propped up some jargon, language, in English-- in German.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We didn't even know what they were saying.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They said one stole this and one stole that.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And from that day on, we came home from work-- every time we came home, they marched us out because our camp was the main camp.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And there wasn't a day that a hanging wasn't going on from the satellite camps.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I assume they tried to scare us or that we shouldn't run off.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We were always threatened.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And there was no reason.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "We didn't understand why they are doing it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "About 10 days before we left the camp, we had some satellite camps liquidated.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We were afraid where they were going to send us.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "That they're going to kill us.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We didn't believe that the others were sent back home.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "In fact, some of them weren't sent home.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And the night before, they came in and said, you're going home tomorrow.",
      "word_count": 13
    }
  ],
