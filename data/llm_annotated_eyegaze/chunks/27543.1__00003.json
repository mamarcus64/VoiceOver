{
  "stem": "27543.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You've got to be home when the bell ring.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And if I said, I don't like what my mother cooked, mister, you get away from the table.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Now, this is a funny story.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "This is not a story.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "This is a true thing.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "We had a piggyback, me and [NON-ENGLISH], together.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And we had $0.05, a nickle, a dime.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And I always want-- you don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "You're too young for that, wore this Indian feather hat, with the Indian's hat.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I asked my father, can I have one?",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He says, if you bring me a good card from school, I'm going to buy you one.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So what's a kid to tell a lie?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "One day, [NON-ENGLISH] mother come up, and says to my father, Eddie, maybe [NON-ENGLISH] knows where the piggy bank.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "We don't find [NON-ENGLISH] piggy bank.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And my father says, George, if you tell me the truth that you took it away and you bought ice cream and chocolate, I says, and will you buy me the Indian hat?",
      "word_count": 33
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I says, and you won't hit me?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "So what's a kid to say a lie?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "So my father was very embarrassed that I stole that piggy bank from [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And two weeks, my father wouldn't even talk to me.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't go out with him no more to buy ice cream.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Every night, we went to buy a pint of ice cream.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I think it was a nickle.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Two weeks later, [NON-ENGLISH] comes up and brings up the piggy bank, and says to my father, why did [NON-ENGLISH] say that he bought ice cream?",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I find it other the bed with a piece of cloth.",
      "word_count": 11
    }
  ],
