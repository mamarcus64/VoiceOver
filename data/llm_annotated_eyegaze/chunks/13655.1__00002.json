{
  "stem": "13655.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "He bought a [? car, ?] like in a small town.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "He brought to the slaughter house, and they-- there was people and they took-- they took care, and they brought us into the store.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And my mother was [INAUDIBLE] sell the meat.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And he was more or less on the-- on the bookkeeping, what they used to take-- take on credit, and so far.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "My father was never selling meat.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "My poor mother was working very, very hard in her life-- very hard.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "She had to raise eight children and stay in-- in the store.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was on the main-- main-- on the main street in our town.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In Konstantyn.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The number from the store, I don't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She used to wear a sheitel.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She used to go [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And she used to serve always for poor people.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She-- but mine-- the table was always with somebody, poor people.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Shabbos, and even in the middle of the week, yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My mother, she used to work very hard.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But she prepared everything for Shabbos, a nice Shabbos meal with the children together.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They were singing [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And we were very respectable.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Treated by the parents, and we was very respect the parents.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It was a very close family.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "The fact is, a lot of people they were jealous because [INAUDIBLE] Hofman is a nice family.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "You know, for-- for Shabbos, they put in a cholent, Friday.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But otherwise, they cooked-- she cooked [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In the bakery, not far away.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I used to bring, because it was not allowed to carry on Shabbos for grown-up people.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "The [INAUDIBLE] was not completed.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Then my brother used to go.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "After the [INAUDIBLE] [? shul. ?] After we came back from the services.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I would say about 1,500 Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
