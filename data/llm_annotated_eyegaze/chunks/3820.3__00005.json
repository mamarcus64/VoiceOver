{
  "stem": "3820.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "The war was still going on.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Lublin was liberated.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "But the, the front was in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "This was in the fall of 1944, September, October.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Give us the names of your aunt and uncle and their two daughters.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Harry, Helen Kotlar, their daughters, Gloria and Betty.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They're both married.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Well, my sister Gloria, she's a widow now.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Her name is Gloria Kagasoff.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And my sister Betty and long life to her husband, Lou Wiener.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "They have children.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "They have grandchildren.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Where did you go after Lublin?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We moved to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "From Lublin, we moved to Lodz.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in Lodz in, in part of '45 and part of '46.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We went to school there.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And we ran into anti-Semitism in school because they taught Catholicism.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And we were asked to be excused from the hour where they talked catechisms and things.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So they realized we were Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And things were not easy after that in school.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And my family realized that there was no place to stay in Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And we wanted to get out.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My, my aunt and uncle-- whom I call mom and dad, so when I say mom and dad, you'll know.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They-- my, my dad had family here in America.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And my, my mother's two-- we knew we had one, one brother in Israel, the one that left in 1939.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So we decided that wherever-- whether it Israel or America, we would not stay in Europe, that it was no place for Jews anymore.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So we, we lived in Lodz.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And in 1946, we pretended we were going on vacation and just packed suitcases as if you were going on vacation.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And we took to Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "From Czechoslovakia, we went into Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And in Germany, we went to a DP camp near Munich called [NON-ENGLISH].",
      "word_count": 13
    }
  ],
