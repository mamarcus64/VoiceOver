{
  "stem": "9113.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "Slowly, I break it up, and I put it in the-- in the-- on the-- on-- in the [INAUDIBLE], and I made like a little [INAUDIBLE].",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And I-- and I 1, 2, 3, and I go-- and I went-- and I walked out.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "When I was already on the-- on the-- how do you call it?",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "[LAUGHS] When I came out on the-- on the ground, yes.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I couldn't pick myself up.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "I walked on my stomach on, on, on.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Maybe 30 feet was another guy holding up my friend.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "He said-- I asked him the first question, did you see my brother?",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "He lost his brother, and I lost my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Then we were walking.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We was on our stomachs maybe about another 30, 40 feet.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And we picked ourselves up, and we looked.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Where we looked, and-- and at night, you hear any little-- any little move, you hear.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Then we heard that somebody's talking to each other.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Then I knew right away somebody is from our fellows.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Then slowly, slowly I walked over to them.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It was another two-- two fellows of ours.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They asked me, where-- where do we go?",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I was not too far away from-- we used to live, let's say, maybe like 10 miles from this area where we were-- where I was in-- in the barrack.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And I said, look.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Now we're going to go.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I headed in that direction.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Let's go this in this direction.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We walked over.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I-- yeah, during this time, I stole a lot of things, and I gave everything to a Polack, that he should prepare for us a place to hide.",
      "word_count": 29
    }
  ],
