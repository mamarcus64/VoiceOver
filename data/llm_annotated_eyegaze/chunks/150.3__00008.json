{
  "stem": "150.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "After I got into the Soviet Jewry thing, you know, and I met so many people and ran so many demonstrations and made so many-- you know, became better known.",
      "word_count": 30
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "And to most people, they didn't have the faintest idea that I was a Holocaust survivor.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "And I didn't think that it was relevant for me to bring it up.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "I got involved with the Wiesenthal Center when the Soviet Jewry movement sort of died down when we had actually won.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "I mean, this is one of the few things that you can actually point to and say, yeah, we won this one.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "People are free.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "And that's what I went-- I always liked Cooper-- Abe Cooper of the Wiesenthal Center.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "He was always extremely helpful whenever we needed help with the Soviet Jewry thing, whatever it was.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "And quickly, you know, because anywhere else, any other Jewish organization, you can die from old age before it goes through all the committees and commissions and all the decisions.",
      "word_count": 30
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "I would go to Abe and he would say yes or no.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So I have a great deal of respect.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And then somehow or other, almost by the back door, I got into the Holocaust thing and into talking, speaking at schools and, and doing all that.",
      "word_count": 27
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And this is what I've been doing ever since, more and more and more, as there is less and less to do of the other stuff.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Do you have any children?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I got two sons.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They're both adults.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "One of them is in Pittsburgh.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The other one is right here in Sherman Oaks.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "What's their names?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "When were they born?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "My older one is Michael.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Michael is 40 years old.",
      "word_count": 5
    }
  ],
