{
  "stem": "26699.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Others, who belonged to the Communist party, they didn't dare to bring their children to the Torah.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So I had a proper bar mitzvah.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "After I finished at the age of 17 the high school and had the metric.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I had to pass an examination.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It was an exam, an admission exam, to the Institute of Civil Engineering.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I passed in the first 10, this exam, out of 500 candidates.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And for five years, I learned civil engineering in parallel.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Because I had a lot of affinity with mathematics and mathematics was my hobby for many years before I started the University, I learned in parallel at the University of Bucharest the Faculty of Mathematics Applied Mechanics.",
      "word_count": 37
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "So practically, I graduated simultaneously in two fields.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Things went from bad to worse in Romania in those times.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "The Communist Party was taking control over the private lives of everybody.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I was like most, the great majority of students.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I was a member of the Youth Communist Party section.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And they organized all kinds of meetings in the interest of the policies, which the Communist Party was promoting in Romania.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "It was important for them that people will declare what was their parent's profession and political affiliation before the war, or immediately after the war.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And those youngsters whose parents were considered bourgeoisie, like my father, who was a shopkeeper, or had the private business, were excluded from universities.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "They were not even allowed to be accepted for the examination.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "I lied.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "I declared that my father was an accountant that didn't have a shop.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Otherwise, I couldn't become a student.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "Doesn't matter what marks you have or anything, you were excluded from the university on the grounds of social origin.",
      "word_count": 20
    }
  ],
