{
  "stem": "27409.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 52,
      "text": "Now we landed the fir-- the deportees from Cernauti.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 53,
      "text": "I had to bring then here more growth they had, eh, intended become.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 54,
      "text": "They killed people, and tortured, and send them on and [INAUDIBLE] for [NON-ENGLISH] and also to Bajora, which was, uh, where they killed the Jews straightaway.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 55,
      "text": "I was-- one was the first to come down.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 56,
      "text": "Being the last to be on the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 57,
      "text": "I tried to escape.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 58,
      "text": "Not far away in the [INAUDIBLE], so many pushing, and shouting, and-- we are officer, militia, uh, Ukraine militia, Gestapo officer and some in uniform, and some in, uh, [? nafti. ?] Of course, SS officer, SS soldiers, Romanian mostly soldiers.",
      "word_count": 41
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 59,
      "text": "I try to escape.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 60,
      "text": "And I jumped in the trenches, which were near they were the so-called [NON-ENGLISH, Stalin line.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 61,
      "text": "I jumped into [INAUDIBLE], a rooksack.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 62,
      "text": "It was back on the-- I pushed it down in the trenches and I returned.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 63,
      "text": "I was shouting in German, so they took me as one of the Gestapo officers, speaking [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 64,
      "text": "And I was searching, looking out for my family.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 65,
      "text": "First, I found my little sister.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 66,
      "text": "I took her.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 67,
      "text": "She was about nine at that time-- uh, 10.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 68,
      "text": "I took her out and brought her to my luggage there.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 69,
      "text": "Sit here, wait till I come.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 70,
      "text": "And she was sitting alone in the night in a strange country, frightened.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 71,
      "text": "I found my late father.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 72,
      "text": "I took him out and I sent him to go along the trenches to-- there if we find my sister.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 73,
      "text": "I couldn't find my late mother.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 74,
      "text": "I was searching and going towards the river.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 75,
      "text": "I found her.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 76,
      "text": "She had galoshes on and stuck in the mud.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 77,
      "text": "With the heavy rooksack on the back, she stuck in the mud and couldn't go out.",
      "word_count": 16
    }
  ],
