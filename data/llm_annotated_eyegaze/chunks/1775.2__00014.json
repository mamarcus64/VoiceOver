  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "But you had to go through differents kind of woods because you couldn't walk in the city.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "So we went back there.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And as we were in the woods, some people started to run after us with hatchets.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And we disbursed.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And-- but I was holding on to my husband.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And we went back with my husband.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And my husband says, don't you know which man over there keeps the people?",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He says-- he says, yes, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "That's, that's a hunchback.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I says, oh, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I know that man.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Everybody knows that man.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He had two [NON-ENGLISH] there.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He had one from-- for the Betar and one for the Zionist.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "One he had after the other.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And he was doing it just for the money.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So we went back there.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And, and that was it.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "That's how I came there.",
      "word_count": 5
    }
  ],
