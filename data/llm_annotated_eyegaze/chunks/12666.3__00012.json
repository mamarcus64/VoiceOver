  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "But it didn't have anything to do with my case, so I just looked through it.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And this Admiral Canaris, in his personal diary, was talking about some double agents that were working for the Allies and for the Nazis.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And a professor here in Washington told me, I'm looking for the diary of Admiral Canaris.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "I said, we had it at Nuremberg.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "Says, it disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "So many documents that we had in Nuremberg are disappearing.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    }
