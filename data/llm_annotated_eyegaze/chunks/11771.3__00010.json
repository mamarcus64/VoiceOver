  "elapsed_s": 1.8,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "They gave me a chance.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I'm glad they didn't arrest me or say, there's another Ejszyszki refugee runaway.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "But my-- my sister, Judith, a month later, got hanged in Lida, [PAUSES FOR 3 SECONDS] for running away from Ejszyszki, from running away from the authorities.",
      "word_count": 27
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I know that.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I went to search for her and to look for her.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "When they took her away to Lida, with a wagon with a horse, I was running after her halfway to Lida.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Got, ?] by a Polish policeman, [PAUSES FOR 4 SECONDS] he allowed me to run after the wagon to talk to her.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "She told me all the story, what she went through, how she get.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And she said, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I'll manage in Lida, too, to get out, get away from them.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And she gave me a name when she was in the underground to contact, one Polish man who lives in Woronow also, a neighboring shtetl, with a Jewish population like Radun, Ejszyszki. but also on this side of Russia, not in Lithuania, where the Jewish were still free, not in a ghetto locked up.",
      "word_count": 54
    }
  ],
