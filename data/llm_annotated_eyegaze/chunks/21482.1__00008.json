{
  "stem": "21482.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You could hear the cannons.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And we still stayed in the-- in the cellar every night.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "We were very scared.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was in their own house.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yeah, my aunt and uncle from Berlin--",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They were with us.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They were with us.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "That was very scary.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And then-- then the Germans invaded the whole Poland, and they came into Cracow.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "The war started on September 1, and the Germans walked into Cracow on September 7.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I remember the day, because my father and his brothers-- my father was one of eight brothers.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And a lot of the neighbors who were Jewish, the Jewish men, were afraid.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And they decided they will try to escape.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They will go towards Lvov.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Because at that point, they felt Germans would not attack because they were supposed to sign an agreement, peace agreement with Russia.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "So they left us.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "All the man left.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "From the whole building, I think, all the men left.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And all of my uncles left, thinking the war would be over very soon and then they will come back.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they thought that women and children would be safe.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They were afraid for the men.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But they felt, you know, the Germans are not going to do anything to the women and the children.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "They went to Lemberg.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "It was Lemberg.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And I felt t-- I was very afraid when my father left.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And then right after, the Germans came in.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And you could-- I could hear the trucks, I could hear the tanks, and I could hear the marching.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "It sounded, you know, like a hurricane.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "There were very-- a lot of noise.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And since I lived so close to the Wawel-- that's where they came.",
      "word_count": 13
    }
  ],
