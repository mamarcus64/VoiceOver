  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Where, where did you go?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And I did tell.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I somehow didn't feel any-- anything, fear or anything.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I told him that I heard that the hospital will be taken away.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And I wanted to say goodbye to my friend.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And he didn't say a word.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "The block [? cover ?] told me, the Jewish lady, that you will get it, you know, that I will be punished, and get back to your place.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "So I did go back.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And next morning, I didn't get coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And next evening, I didn't get any bread and so-called soup.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And she gave me a slap on my face in the morning that I just lay on the floor.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "But [PAUSES FOR 3 SECONDS] that's about it.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "I mean, the SS man didn't punish me.",
      "word_count": 8
    }
  ],
