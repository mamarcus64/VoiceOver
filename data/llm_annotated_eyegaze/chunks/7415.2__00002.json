{
  "stem": "7415.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So this-- my grandmother [PAUSES FOR 4 SECONDS] went with us to a place by train-- I hated trains-- at night to Czestochowa, another city which nobody would know us.",
      "word_count": 30
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And it was-- it was cold.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So it probably was end of '42.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And my feet became frostbitten.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I-- I always remember people after us saying that we are Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And they demanded-- in the middle of night in our hotel, some guy came.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And there was another couple, and they admitted they are Jews, and they gave this guy money and they were taken away.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I remember when I was lying in bed and my mother was screaming at the guy, saying she's not Jewish.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And he was insisting she was Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And there was a lot of blackmail going on.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And it was very dangerous to go on the street.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I remember we once went to a place, and-- to a-- an apartment to live, and the guy said that the door are close and he's going to Gestapo to give us up.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I forgot how we escaped, but I am afraid.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "[LAUGHS] I believe that it was bad when you go someplace and a cat crosses your-- [LAUGHS] your street, because that what happened.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And then this guy didn't want to let us go and tell that he knows we are Jewish.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And [SIGHS] well, my grandma-- Polish grandma-- of course told me about Jesus Christ.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Miss Maria, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And about Jesus Christ and how to pray and-- and how to pray for my grandfather.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I always tried to remind her that I would rather pray for both of them.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So I knew a lot of praying at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "I guess it-- I had good memory as a child.",
      "word_count": 10
    }
  ],
