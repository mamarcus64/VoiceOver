{
  "stem": "25114.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And somebody had to try and get-- make some fire, cook something up.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "And somebody had to wash.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "It was very hard to live.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "It was very primitive and very rough.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "And people didn't help each other at this particular time, because everybody was helpless themselves, cause they tried to-- so anyway, we needed-- we needed a man badly.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "My sister lost her husband.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "We were three helpless women.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "My-- my sister was-- in respect of food, she used to bring food and sometimes nice things they gave her, you know, where she was making dresses, sewing for them.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And then word got around, and the German ladies wanted a dressmaker.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So they start taking her to the-- to the houses of the German elite, and she make them beautiful clothes.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "So they somehow gave her food.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And so we weren't really badly off, as far as food was concerned.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We didn't starve.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "How long did you live there for?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We lived there from December, sort of like the first week or second week of December '41 till about eighth of August, seventh, eighth of August '42.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "That's how many?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Nine months?",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Eight months.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The conditions of the ghetto changed.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Not only-- they installed a tower with the searchlights, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They kept searching if we went walking.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Because it was dark at night, and there was no electricity.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We were trying to, with a bit of oil, a bit of-- because there's no electricity.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "There's no water.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "There's no bathing facilities.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "There's no-- everything was in mud.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "But people, you know, Jews lived, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Somehow we managed to keep clean.",
      "word_count": 6
    }
  ],
