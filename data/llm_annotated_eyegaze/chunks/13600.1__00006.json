{
  "stem": "13600.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "But I spoke Polish very hesitantly.",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "I never learned it.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "It was never my language.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "It depends what you say.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "In, in today's terms, I would say definitely, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Very hard living, very hard living-- we could never afford what we wanted, never.",
      "word_count": 14
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "Even in food, we were limited to what we could afford and what we couldn't afford.",
      "word_count": 16
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Enough, yes, but a very restricted diet-- bread, potatoes, not much meat, cake once a week.",
      "word_count": 16
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Cake-- Shabbat.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Only Shabbat.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "Got a slice, and that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "The cheapest.",
      "word_count": 2
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "But ask me about butter or coffee or tea-- here came in the restrictions.",
      "word_count": 14
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "Tea, you used to rinse the same-- we used to buy tea in 10-gram bags.",
      "word_count": 15
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 3,
      "text": "You used to rinse and rinse, since the color was colorless.",
      "word_count": 11
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Every drop, and more than that.",
      "word_count": 6
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "And coffee, used-- we couldn't afford coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 2,
      "text": "So we bought a product called chicory.",
      "word_count": 7
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 3,
      "text": "I don't-- [INAUDIBLE] I think you have it here in, in Australia-- that gives color, but tastes different.",
      "word_count": 18
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 4,
      "text": "Just people should think we have coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Yes, every Sunday was observed holiday, because it was state-enforced, every Saturday because we were Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "No, Saturday was strict.",
      "word_count": 4
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "Sunday was official.",
      "word_count": 3
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 2,
      "text": "And unofficially, you know, then you observed it much less.",
      "word_count": 10
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] 16 days a year-- eight days Pesach, Passover, and eight days in Sukkot.",
      "word_count": 14
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "No learning.",
      "word_count": 2
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "While I was young, I would say at least twice a day.",
      "word_count": 12
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Morning and evening, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "Spend half a day, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "All day Yom Kippur and most of the day on Rosh Hashanah.",
      "word_count": 12
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "No, there was other holidays, if you know.",
      "word_count": 8
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "There's Shavuot.",
      "word_count": 2
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "Jewish holidays.",
      "word_count": 2
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "Was interrupted, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "I do not imagine, because life was very hard.",
      "word_count": 9
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 1,
      "text": "Financially, it was-- we were very-- how should I say?",
      "word_count": 10
    }
  ],
