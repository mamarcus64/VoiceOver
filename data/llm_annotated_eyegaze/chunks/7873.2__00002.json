{
  "stem": "7873.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We used to-- electric poles, we used to carry.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Sit on the highway, cut stones, little stones, about-- [POINTS] crush them.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And they made a highway out of that.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Sweep the streets.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Clean the toilets in the-- in the, the Nazi's houses, anything.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "For that, we never got anything, never got anything.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Like $2 a day.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Like $2 a day.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "That's the right word, 'Judenrat.' That's what they-- that's in German, 'Judenrat.' They were nice people.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They were, you know, big men from before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They were educated people.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, one, the head of the-- head of the whole thing, his name was Tienits.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, he never came to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We had a castle in our hometown.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I took pictures of it.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "That, that castle is a thousand years old.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And they-- I came with the first shipment to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "The second shipment, they took every-- the Jews into that castle.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And that Tienits, that head of the Jews, his son had to hang his father.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Just-- and before he hanged him, his father says, my son, [NON-ENGLISH SPEECH] Amalek.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Amalek was a nation once.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "When the Jews came out of Egypt, they were attacked by that nation.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Their name was Amalek.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And it's a-- it's a verse in the Torah, [NON-ENGLISH SPEECH] Amalek.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "But [NON-ENGLISH SPEECH] Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Don't forget what the bad problem was.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Same place, after he hung his father.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That time, the Germans did, the German police, their state police, Stadtpolizei.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] You mean at-- you're already in the war.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "There were-- Gestapo lived in our town.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The headquarters from the Gestapo was in our town.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They made our town-- it's like a-- it was a nice-sized city in the war.",
      "word_count": 15
    }
  ],
