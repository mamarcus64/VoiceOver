{
  "stem": "979.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "She was like a bit older than me.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "She was 17.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And she-- by the way, we all had typhus while we were there.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "My Nita was the first one to have typhus.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "She made it, and she came home.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "We were all dying because of the water.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "It was bad.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "We-- we were not supposed to drink the water.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "It was green.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "You're supposed to boil it.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "It was very bad water.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "But there was no way to boil it.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And the people would say, we wouldn't drink it much.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You know, others would drink it.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And we drank the tea that they gave us, cause already boiled.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "We wouldn't drink the water.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "So one by one, they were going to-- some died already.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We had-- the opera singers, we had about five singers in the orchestra and they were all fantastic.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "One was from the Berlin Philharmonic.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "She was Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Doris was her name.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "She had typhus and she died while we were in the orchestra.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Then-- then I was one that had the typhus.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And I-- they-- they put me to the hospital, but they didn't give me much of anything.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Just one pill.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "And I was delirious, and I could not think carefully.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "So that week-- and I didn't eat anything.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "The second week, they started to give me a little food.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "And I try-- I said to myself, I have to force myself to eat or I'm gonna die.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "By the end of the second week, I still was very sick.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "So it occurred to me that, if an order comes from Germany that they're going to kill-- they pick up 500 girls for the gas chambers, I'll be one of them.",
      "word_count": 31
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "The hospital comes first.",
      "word_count": 4
    }
  ],
