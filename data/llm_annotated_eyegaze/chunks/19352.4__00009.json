  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "Rosenbergers, ?] they were people who had to do-- the man had to do with the gardens, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And he delivered the gardens to the casinos around there, and to the restaurants for the German officers.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And this is everything for the Germans, the big shots there.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And he was a very nice man.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I told you before that I have to go for the things what I-- for the, no.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "No, forget it.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Not this.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "So finally, I-- my mother said, maybe you can go.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "My mother works there in the gardens there, my father, too.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "But my father, if he would steal something, they will fight every time.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Because when you walk out-- that he had a hat-- and you said goodbye or-- he took it out.",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And there is green beans, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And they laughed there.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And they didn't take.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "Who, who, who laughed?",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The people who stood there-- the guards there.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They laughed when--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "They laughed that it looked so comical that they took out.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And here, you have this green beans.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother told me.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And so my mother said, maybe you will go there.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And maybe you can eat something there.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And maybe you're going to be-- and so I told my Wagner that they have to go.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Because I'm sick.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I'm very sick.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And you don't know what's going on.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "I'm so sick.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "He said, do whatever you want to do.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Rosenberger ?] took me.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I was working in his office, you know, to this [INAUDIBLE] and this and this to went [INAUDIBLE] to this [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "One time, I go out in the fields.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And it was onions you know?",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And I took out the onions from the ground, dirty.",
      "word_count": 10
    }
