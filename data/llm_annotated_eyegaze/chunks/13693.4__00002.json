  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Pinska ?], with his-- he was his group-- with a German to-- into the-- into the village, a hamlet, to buy some stuff for the ghetto, because they were making business with the German.",
      "word_count": 34
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I remained in the-- under-- under the-- The motor.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The motor, the round motor, covered and waiting what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Suddenly, I see four policemen-- Belarus-- lifting up-- lifting up on-- on the-- on the attachment to the-- to-- to the truck.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They looked at me-- and they were sure that nobody will be over there.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "They could grab over there to take whatever it is.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "This is the way they were-- they were grabbing everything.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But they saw me, and suddenly, they-- they looked around, and they didn't know that I'm-- maybe that I-- they left me over there to watch it.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "They moved back, and went away.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "This way, for six hours I remained by myself over there.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And they came back.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "They-- the German truck [INAUDIBLE] was a-- was a-- it was a [INAUDIBLE] where the guys from [INAUDIBLE] came in.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And they connected back the-- the attachment to the main truck.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And we went to Vilna.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And now I'm back in Vilna.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "I-- I-- crew going in, just as we went in into-- into the main-- main area from [?",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Bezanuska ?], what was completely surrounded by-- by wire.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "I came out from my hiding place, and I saw the guys are talking English.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And I told them-- I told them I'm back from-- from Lida.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And they said, OK, we'll take you-- we'll take you in into the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And being in the ghetto, [?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Pinksa ?] took me to the Gens.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "He told me going into to in here.",
      "word_count": 8
    }
  ],
