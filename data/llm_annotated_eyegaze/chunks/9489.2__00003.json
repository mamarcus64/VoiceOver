{
  "stem": "9489.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "If you want to survive, the only thing you have to tied up each other in the-- in the roof of the train.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So we grabbed what we could.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "But weapons was no use to take with us, weapons.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "The only thing we grabbed-- we left everything.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And the only thing to take with us is food, food and water.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "But water was how much you like.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And the station's hard water.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They call them [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "We got-- it was boiling kettle.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And who got tools got in the water.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And food was no problem.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "We still got lots of food.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And we jumped in in the rooftop And we tied up ourselves.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I went for three days.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Three or four days we were in the roof.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Excuse me, no washroom, no nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "What we got to eat we eat, and the train was going, you know, day to night, night and day was just noising to wake us up, to keep us alive.",
      "word_count": 31
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And then we got into [SIGHS] to Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] or-- I don't know the names.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They took us to the station.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They feed us.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And they took our clothes away for-- we got lots-- excuse me-- lice.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "They took away our lice.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They called them [NON-ENGLISH], to go and kill it in steam, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "They explain us.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "We get our-- our clothes back, and they put us in Turkish baths, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And who were these people, the 'they'?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The army.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "It was already the regional Russian volunteers, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Volunteers or army-- who knows?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But they took us in like kings, and they give us what they can to feed us.",
      "word_count": 17
    }
  ],
