  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "I am the 173rd Jewish woman who ever entered Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Jewish woman.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Jewish-- because later, non-Jewish came too.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The criminals.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We were from Slovakia, the first 1,000 Jewish women who were brought to Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "--73rd Jewish woman.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Jewish woman.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The Germans and the Aryan were not tattooed.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They got numbers, but not tattooed.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Only the Jews were tattooed.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So you know, I don't know if it's-- if it's mentioned somewhere, this.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "But except in the I'm sure it is.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "But really, people know that non-Jewish women got not-- not tattooed.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
