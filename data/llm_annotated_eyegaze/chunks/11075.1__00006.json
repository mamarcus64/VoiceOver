{
  "stem": "11075.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "You know, a lot of things was no good, becasue-- but we were happy that we still alive.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In ghetto?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "No, no, no schools.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Synagogues, you know, private.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Some-- sometimes, you know, the-- the-- the-- the service was in our-- in our room-- in our-- where we used to live, you know, it was a big room, you know.",
      "word_count": 31
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "How long it took-- a half an hour.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "We were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "We were watching, you know, from the window, you know, oh, SS men doesn't look in.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Nothing special.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Nothing special.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "The selection, they made in 1942.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "In 19-- made-- they liquidated the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "1940.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I don't exactly remember, but we were there close to two years.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "In 1942, first-- first the liquidation.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "The ghetto was-- there's a liquidation.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And-- the older people will not be able to go, so it was prepared, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The [INAUDIBLE] prepared, you know, horses with-- with wagons.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And-- and there-- and there-- you know, they went over there.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "At first, it was 450.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And between were my-- my father, also, because he was-- he was not able to go.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He was-- he had only one leg.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "My father.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "My mother and myself and my sister-- one sister-- you know, my two sisters, because the one from Stanislawow.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "She was already in Wolbrom, too, with her baby.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We went, you know, to the railroad station.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "You know, the policeman-- the Jewish policeman-- who was in ghetto, you know, came over.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Because they cleaned up the ghetto, so he came over.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "You could go-- go.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So he said, you see it, Henry.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "You know what?",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Your father is dead.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I found, you know, his [INAUDIBLE], his [? select. ?] He-- but he came and he told me that.",
      "word_count": 19
    }
  ],
