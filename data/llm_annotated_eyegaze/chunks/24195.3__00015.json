  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "All I know is, when I get to the camp-- to the railroad station-- there's 500 other men of all ages there, everyone with suitcases and dressed in civilian clothes.",
      "word_count": 30
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No, I went my family.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "My mother and brother took me, yeah, to see me off.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And they thought, maybe it's just a harmless, you know, assignment, probably of forced labor, but not-- you know, not-- little idea did we have of what would happen, I mean.",
      "word_count": 31
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Everything was very harmless when we were there.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "At the-- at the railroad station.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "But we were in regular railroad cars.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "We were not in cattle cars.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And the-- actually, the terrible-- the seriousness of the situation did not become visible until we get to our destination, which was near Zerbst, which is in the German-- near the German-- larger German city of Magdeburg.",
      "word_count": 37
    }
  ],
