  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "No, I think we didn't do something wrong for the people, the Ukraine people will kill us or do bad things to us.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Never he believed it what's is going to happen to Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Now, we all of them, the family no experience for life and experience.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "No, we was listen to the father what he said.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And we did.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And then when the Germans came, my father was speaking very well German.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "It's happened, but it was a conversation between an older German soldier with the father.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "He told the father-- the father told him that I a Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And it's happened, but it was a nice, nice German person.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And he said to the father, you will have very bad time, very bad time.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And maybe I don't know if you will survive from this time.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "After that was one person.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "After this, the father begin to talk with us.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And he said what the German soldier tell us.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Now, it was too late.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We cannot go anywhere because the Germans is here.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And if we will go from the village, out from the village, will be worse.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "The father said to us, you know what we will do?",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Let me move from home now.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "We will go in forest for a while until the forced armies will pass the places.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Maybe later, will be more some government, maybe more protection from the government.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, it was not happened that.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We was-- we went.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We got out now our horse and wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And we stay-- now that's we went from the-- in forest maybe for 5 kilometers.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "It's 5 or 7 kilometers down to [INAUDIBLE] forest.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "It's passed the couple days.",
      "word_count": 5
    }
  ],
