{
  "stem": "27767.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 14,
      "text": "And I was there until about 6 o'clock.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 15,
      "text": "And then I went home.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 16,
      "text": "And I-- I had to do my homework in the evening.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 17,
      "text": "And in the evening, we had only a cup of coffee or some bread with water, something like this.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 18,
      "text": "It was a light food in the evening.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "For the main dinner-- the main lunch was my mother cooked.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And she had pretty-- pretty well-established.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "Like, Monday we had always dairy, dairy.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "We had soup.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "We had-- we had sour cream soup.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And we had pasta with cheese.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "Or we had blintzes.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "And that was always Monday.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And Tuesday she did some other vegetable soup and-- and some pasta or something.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And Wednesday, the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And then Thursday she did-- that was a-- beans.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "There was a bean soup and, of course, some beans made up with some-- with some hamburgers, right?",
      "word_count": 18
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "She made hamburgers too.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Actually, meat we had sometimes Thursday a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "But we had-- for Saturday we had meat.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "She bought meat from the butcher shop.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And-- and we had some chicken.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "And she cooked for Shabbes.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Shabbes we had a better-- a better supper.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "We had always a Friday night supper.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And-- and she had chicken soup.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "She had meat.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "She had, like, gefilte fish, but that was not from-- she was doing it from meat.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "It was a false-- they called it false fish.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "And it was very good.",
      "word_count": 5
    }
  ],
