{
  "stem": "21978.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "We were not allowed to mingle with the others very much, not to spread diseases, because Germans were very careful not to spread diseases.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "They were killing us.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "They were killing people, sending them to gas chambers later.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "But they were very careful not to have epidemics in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "It was a bureaucracy.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "And we have been quite content to work in the hospital, because we were learning how to look after the children.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "We were happy to do something for the children.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "We were still able to give them medications, and change their beddings, and wash them, and feed them, and so on.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "Maybe that's-- life in Theresienstadt gave us then the feeling that we wanted to something for later in our life-- to do something like that too.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "Annetta has met Egon's parents, my parents-in-law, in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And she met also our uncle and auntie.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "They were people who are very used to much better life, much better way of-- the better-- better quality of life.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "My father-in-law was a engineer.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "And he was used to being waited on.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "And his wife was always looking after him very well.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "He used to walk in the ghetto with the white gloves.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "And when my sister has seen them, she was very upset, because she knew that are deteriorated.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "They didn't have enough to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 38,
      "text": "Old people were given only portions.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 39,
      "text": "The other people, the younger people who were working, get-- probably, got probably better rations.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 40,
      "text": "My uncle and auntie were elderly.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 41,
      "text": "And Annetta has met them there too.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 42,
      "text": "And she was very, very upset to see them.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 43,
      "text": "I didn't meet them anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 44,
      "text": "But she told us about it.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 45,
      "text": "They were sent to-- from Theresienstadt-- we don't know where, really.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 46,
      "text": "They might have been sent to Auschwitz.",
      "word_count": 7
    }
  ],
