{
  "stem": "5613.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Hyman Skulsky.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in London, England.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born on May 5th, 1915.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My parents came from Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They ran away in 1905 from Russia to Belgium.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And in 1914, when the World War number one started, they ran away as refugees to England.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I was born in England-- in London-- in consequence of that.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Lazar, or Elazar, and my mother's name was Rosa.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was the same as my father's name, Skulsky, because both my grandfathers were brothers.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And my mother and my father were first cousins.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Very unusual to get a maiden name of my mother and father the same.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had one older brother by the name of Abraham.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And he was born in 1909.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And he was a music critic, and he passed away in 1959 as a consequence of a heart attack in Venice, Italy.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And he's buried there in the Jewish cemetery in Venice.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Then, I have another older brother by the name of Samuel.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He lives in Beverly Hills.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And thank God he is OK, except for his eyesight.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He's two years older than I am.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He was born in Belgium in 1913.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I had one younger sister by the name of Sophie, and she was killed in the Holocaust.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "She was sent to Birkenau and never came back.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I left London at the age of five.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I remember a couple of very small incidents.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I must have been about two or three years old when my mother woke me up, took me in her arms, and took me down to the basement, to the cellar, because a zeppelin was coming to-- was bombing the town.",
      "word_count": 41
    }
  ],
