{
  "stem": "27767.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And my daughter got sick there.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "But we managed.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And we came out in May.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "May 10th we arrived to New York.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "In this country?",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I tell you, very well received.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My brother was at the airport with my sister-in-law, and my wife's two aunts, which were here from before the war, and two cousins of mine-- one cousin who was working for the Jewish committee, [?",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Gelar. ?] He was waiting at the airport.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Actually, he married my cousin in Germany after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "He was in the military there.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And they were waiting for us.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And they took us to-- we got a hotel.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And we didn't know at that time what area is that, at Broadway, downtown, in a small hotel.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "We were there in one room with my daughter and my wife.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Were there for about two months.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And we were getting some help from the Joint-- from the HIAS, actually-- not HIAS, actually, NYANA.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "We were getting some help for food.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And my wife cooked whatever she could there.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "She bought conserves.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And she-- on an electric something, she did some.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And I went right away to the NYU, to New York University.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And I enrolled to-- I enrolled myself in an English intensive course.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "So I was there for about two months.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "I went the whole day.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "We were in the-- because that was even close.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "It was walking distance from Broadway, from that hotel to the university.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And I was-- I was enrolled at NYU.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And I graduated that course there.",
      "word_count": 6
    }
  ],
