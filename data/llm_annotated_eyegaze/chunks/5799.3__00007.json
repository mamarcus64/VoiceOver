{
  "stem": "5799.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 31,
      "text": "We had to go from Franek to a man by the name of Boinski, who had six-- six beehives, three on one side, three on-- that was the sign-- three on the other.",
      "word_count": 33
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "And birches.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 33,
      "text": "And I came there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 34,
      "text": "And I had to tell him that I am Sasha's wife.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 35,
      "text": "One of the partisans.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 36,
      "text": "They all changed names.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 37,
      "text": "So he was Sasha.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 38,
      "text": "That I'm Sasha's [INAUDIBLE], Sasha's wife.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 39,
      "text": "And I came there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 40,
      "text": "And on the third day, he said, you have to go.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 41,
      "text": "The partisans are not coming.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 42,
      "text": "My neighbors know.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 43,
      "text": "And God knows what will happen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 44,
      "text": "I have small children.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 45,
      "text": "But that evening, a knock at the door.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 46,
      "text": "And the youngest Bielski came in, Aharon, he was 14 years old.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 47,
      "text": "He took us out from there, with the other partisans.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 48,
      "text": "And me he took to a [PAUSES FOR 3 SECONDS] house where a sister of a former priest, and the priest was there too hiding out.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 49,
      "text": "[NON-ENGLISH] was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 50,
      "text": "He was hiding out the whole family [?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 51,
      "text": "Boldo. ?] And they were two of my school friends.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 52,
      "text": "And with them, I stayed about a month.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 53,
      "text": "After a month came an order that we all must go to the woods.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 54,
      "text": "Because the Germans-- we would sleep by day, travel by night.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 55,
      "text": "And we would make like 15, 20 kilometers a night.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 56,
      "text": "Surround the farm, even milking, she had to go with one of us, the woman.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 57,
      "text": "That nobody could go out.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 58,
      "text": "And next day, you would move someplace else.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 59,
      "text": "But I stayed with these people.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 60,
      "text": "And then when it came, the order.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 61,
      "text": "Because the Germans found out and send the local police.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 62,
      "text": "At that time, my commander's wife was killed, Sonia.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 63,
      "text": "Her sister Regina-- Regina was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 64,
      "text": "Many fellows.",
      "word_count": 2
    }
  ],
