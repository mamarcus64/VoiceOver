{
  "stem": "16313.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And Ze'ev Jobtinsky was-- I remember when I was young he was in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "It was in 1938.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And it was in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "It was a very big-- maybe it was like people coming to hear him in the thousands.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "There was-- was a couple thousand people.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And I remember like like today he talk in Polish because he was a polyglot.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "The man knows about 10 languages or more.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And he start in Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "And then he change to Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "He talk in Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "And the end of his word was [SPEAKING YIDDISH].",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING YIDDISH]-- I-- this he talk in Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "This premonition in English, [YIDDISH], a catastrophe in Europe of the Yiddish-- of the Yiddish folk, [YIDDISH].",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "This was the end of his speech.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Nobody believe it can happen, and it happen a year-- year later.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "That's--",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "[YIDDISH], [INAUDIBLE], [YIDDISH].",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "He got a premonition.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "He feel it.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And he--",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I was there when he talked.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "This was-- that's why--",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "This was the meeting in [? circus. ?] In Warsaw [?",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Circus. ?] In [? circus ?] can go in about 6,000, 7,000 people in [? circus. ?] It was a lot of people.",
      "word_count": 23
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They hear him and know what they can do about this.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "The borders was closed.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And a year later, we'll start the war, the Second World War.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And then Hitler came.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "The whole treaties with Poland was worth a piece of paper [INAUDIBLE], excuse me.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And this what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And that's how the Jewish people was in big trouble.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "That's-- I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "I was in the army.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I got a piece of paper, called to the army.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And I stay-- I went to the place where's I supposed to be.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "This is the Polish Army.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "That's the one.",
      "word_count": 3
    }
  ],
