{
  "stem": "6277.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And you get very little food, half the ration-- ration what the other-- the Gentile population got in the city.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So they had a small-- little food, but we had even half of it.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was very, very little.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And it was-- the-- the-- the food was rotten, and it was spoiled.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Such things we would get.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he tried.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But it was very danger.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "It was very risky.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He tried.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "They were-- it was under the direction from Germans, but the guards were Latvian.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In our place, what we got-- it depends from the house where you live.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "In our place, we didn't have facilities.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The-- the toilet was on the-- on the-- on the yard, in the yard.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And we didn't have water at home.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was a very, very poor neighborhood.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Mostly Russian workers.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Mostly Russian workers.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The same people who lived there, in this apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "We exchanged.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They came to our apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We moved to their apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Very hard, the life in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But it didn't-- it didn't go on for a long time.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "It was only for a little more than a month.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "In the end of November, the 28th, actually, of November, there were signs or notes on the buildings that the population of the ghetto will be resettled, and we will be taken to another place.",
      "word_count": 35
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And we have to be ready to go.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And you can take only 10 kilograms with you.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "It was a Friday.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Father didn't come from work.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "We were very worry.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And mother told me to go and to-- to learn something, what-- what's happened.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And I went to a house where another man worked in the same place.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And he didn't show up also.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "He didn't come.",
      "word_count": 3
    }
  ],
