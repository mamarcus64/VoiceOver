{
  "stem": "1183.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I had no hair, so no lice could come on my hair.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Should be grateful for that.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Whatever we could get rid of our clothing, we threw in the water when we were on our trip to Sweden.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We arrived in Sweden and were cleaned, and had showered and new clothing.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And everyday, we-- we got some clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We were fed very slowly on a diet 'til our stomachs were-- were used to it.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Also in a kind of a camp in Malmo-- in Malmo, in Sweden.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And they treated us very, very, very, very well, very well treated.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Then we went to another camp near Goteborg in Sweden.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And there, most of the women, well, recovered.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Some women had typhus from the lice, [INAUDIBLE], scabies, well, all the kind of things.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I had also eczema all over the place from a-- but the funny part what there-- not funny part, but a part was that we had-- we had sheets from paper.",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Sweden was known for paper.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "So every time we clean ourselves with the sheets, we broke the sheets.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Then we went in a camp.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "We started back to-- to a little bit normal life.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "A group of girls, the ones who put me up from the snow, we got acquainted with a Swedish family, who more or less adopted us.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And we visited them and we went to-- to a fair and we came a little bit back-- back to life.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "Then I-- I became ill.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I had pleurisy in the worst form.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "My lungs were inundated with water.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "It was on the border of TB, but I didn't have.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So they sent me to a part more in the-- in the middle of Sweden.",
      "word_count": 15
    }
  ],
