{
  "stem": "10358.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I used wake up during the night screaming and crying.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid they're coming to take her away from me.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "This went on for a long time.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Even my granddaughter now, too.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I'd hug my granddaughter, I felt the same feeling.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "Nightmares and flashbacks.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I still get, but not as much as I used to.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "If I see even about Bosnia, I see experiences of the people, I get flashbacks.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Hostages, I get flashbacks.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Everything you see on the news, I get flashbacks.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Everything pertaining wars and [PAUSES FOR 3 SECONDS] yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Even now during the snowstorm, To me it was like, you know, Doctor Zhivago.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And I'm reminiscing life before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Because we had this type of winter all the time.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It never got warm, but we were equipped.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We had warm clothing, and we learned to live with it.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I observe all the holidays, but I'm not a Shul-goer, let's put it that way.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I don't go-- I go just to-- I'm a nationalistic Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I am not really an observant Jew, but I'm very, very Jewish in my heart.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "This is a question that's very difficult for me to answer, but I want to talk about it.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] My father-- excuse me one minute.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "My father was like God to me.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And after they killed my father, I was very young at the time, and I was with my-- I said, where was God?",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Why God wasn't here to save my father, to save all the Jews?",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Why did he kill all the rabbis, all the religious people?",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And God stood still.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Where is God?",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And I really lost faith.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "I tried to believe, because it's a good crutch.",
      "word_count": 9
    }
  ],
