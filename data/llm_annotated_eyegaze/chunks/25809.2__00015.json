  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "And because of that, I'm still here to talk about it, because I was totally-- I couldn't move.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, it was-- [PAUSES FOR 3 SECONDS] where was I?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I-- My sister was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "My father says, well, I've got to get you out of here also.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And we're getting now to the day that we were told, OK.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Tomorrow, in the evening, you'll be transported to a central station to go to be transported to the concentration camp, Westerbork.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So now we have the day that my father says, what am I going to do?",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "My grandmother is there, my aunt, my uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And everybody is in a-- is basically is in a total panic.",
      "word_count": 12
    }
  ],
