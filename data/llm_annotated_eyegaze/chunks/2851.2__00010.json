{
  "stem": "2851.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He makes-- he can make hats.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "He makes hats.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "So, he had-- I do the hats.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And-- and there-- there were people, they need hats.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "So he-- he-- he show me out to do it, and I did.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "He helped me.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And I made the-- I-- I made money to live.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "This is the way I did.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "But I try, and I did.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "But the blouses-- every time another man came, another soldier came.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And one of the soldiers had to-- came in.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "He was an officer.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And he said to me, you tell me your whole story-- how it was.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And he was a writer.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "Now he start-- everyday he came in, and I told him our life story.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "And then the war break out again.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "The German came back.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "We have to run.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 9,
      "text": "And-- and he got killed.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 10,
      "text": "They told me.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 11,
      "text": "One soldier told me he got killed.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "From there we went to-- they took away-- I went to Lutsk.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Oh, good.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I'm happy.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
