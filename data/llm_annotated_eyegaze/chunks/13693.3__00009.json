  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "The other side was the Christians.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And the center was destroyed.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I see, suddenly, on the big track, near our house, a beautiful white stallion, with a German in black uniform, SD-- not S.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "He probably was SD-- [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "The [NON-ENGLISH] was worse than SS.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And the-- and he was talking to the mayor of the-- of-- of Lida.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And I could not recognize.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He was-- he was-- he was gesturing, and moving around.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And I did not know exactly what happened over there.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "But we knew already that this will be trouble.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Because they prepared already trains.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And this time, a lot of Lithuanian, Ukrainian, and Latvian, and maybe some Estonian came in, in town.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And we know that this will be destruction.",
      "word_count": 8
    }
  ],
