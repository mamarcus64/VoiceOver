{
  "stem": "9503.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BEEP]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Judy Straus., J-U-D-Y S-T-R-A-U-S.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Ursel, U-R-S-E-L, Levy, L-E-V-Y.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "February 1st, 1933.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Dortmund, Germany.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My father's name was David.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was Alma.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And she was born a Falkenstein.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Her parents, my grandparents on, on my mother's side, are Moses Falkenstein and Fina Falkenstein.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And she had three brothers-- Ludwig, Julius, and Eric.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "My mother-- my father's mother's name was Hanchen.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And his father's name-- my grandfather on that side-- was Loeb.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "My father had one sister.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "Her name was Regina, or Gina.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I'm married.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You want to know this part now?",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Who lived with you when you were a child?",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born the day after Hitler came to power.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, from what I gathered, it was the end of January, 199-- 1933.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my father immediately lost his job.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he was employed by the German counterpart of Commonwealth Edison.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And so rather than looking for other work, he decided to-- that we should immigrate to Holland.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I was not very long in Dortmund.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was very brief.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my mother and I stayed with my maternal grandparents in a small town called Montabaur while my father went to Holland to set up a business.",
      "word_count": 27
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He became-- he set up an independent business.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My mother stayed-- this is all of what I'm told-- my mother stayed with me when I was a baby for a while.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Then she moved-- went to Holland to set up housekeeping.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I stayed with my maternal grandparents until I was a year and a half.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And then my grandmother brought me to Holland.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "So then we lived in Amsterdam until the camp started in 1943.",
      "word_count": 12
    }
  ],
