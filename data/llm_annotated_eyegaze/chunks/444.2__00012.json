  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "But he managed to run away to a village and lay in a barn in that village.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And the peasant's wife came to our house, and told us that he was lying there with a bullet.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "So we had to get a doctor and go to him.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "But when we got there, he was dead.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "It was, you know, another situation where you couldn't get a doctor.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Excuse me, a doctor could not aid any Jew.",
      "word_count": 9
    }
