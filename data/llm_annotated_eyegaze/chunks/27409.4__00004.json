{
  "stem": "27409.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "I could speak Ukrainian.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And I heard some discussion, oh, they get to their death.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "They don't know what is to expect.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "When I heard this, of course, I tried to reach my parents, my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "I couldn't, but, uh, in the meantime, was one incident which I will never forget.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "Not far from me, a young woman had a child and the babies.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "And one was a-- the soldier-- when a soldier grabbed the child and threw it in the-- the moms are like mad, jumped after, and he shot, they shot.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "I don't know if she survived or if she was wounded.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "I couldn't see.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "It was darkening when we reach the Ukrainian side.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "That was the town Mogilev-Podol'skii.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "[NON-ENGLISH], which had originally Jewish native-- Jewish population where only a few left.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "There were Jews from Bessarabia, which were taking over.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "And they played with them.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "They sent him over and back and forward to German.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "They were there.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "And Jews from the south and Bukovina, Romanian citizen, which were not under the Russian but they are also deported before us.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "And they were there having money, Romanian money, speaking the lingo.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 46,
      "text": "They are-- and in German they give money and arrange with the authority both German and the Romanian to let them for the time being.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 47,
      "text": "They permitted 500, but they close their eyes for the time being.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 48,
      "text": "They were in schools.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 49,
      "text": "And some, which could pay THEM private houses, Jewish houses, permitt-- they were not permitting during the night to go out.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 50,
      "text": "The were not permitted to go in the market only one hours in the day or two hours in the day.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 51,
      "text": "But if you could speak to the local population and had the money, you could buy.",
      "word_count": 16
    }
  ],
