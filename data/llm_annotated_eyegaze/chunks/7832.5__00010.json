{
  "stem": "7832.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "Somehow, I was being pushed backwards.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "And I got stuck in the door.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "Because as you were walking down the gas chamber, the-- the passage became narrower and narrower and narrower.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "And when you came to the door, it was very narrow.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "And I was like stuck in the door.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "And I-- I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 33,
      "text": "I guess God told me to do that.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 34,
      "text": "I hung onto the-- to the edge of the door and I just stood there, hanging on for dear life.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 35,
      "text": "And everybody was like past-- past me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 36,
      "text": "And-- and everybody was in, and I was at the door.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 37,
      "text": "And everybody was up to [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 38,
      "text": "It was so jam packed.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 39,
      "text": "And I still didn't know what they were gonna do there.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 40,
      "text": "But I knew it was a crematorium because I saw the chimney.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 41,
      "text": "But I didn't know the procedure.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I just hung onto the door.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Well, one of the SS men came to close the door so they can throw the Zyklon B in.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Because they were all standing around looking in somewhere, you know, up by-- see, it's close-- it was close to the ground.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And the door was like underground.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So he came to close the door.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And they were yelling to hurry up to close the door.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he couldn't close the door because it was so full, and I was like stuck in the door.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So instead of-- and I was naked.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I had no clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "So that's when they took our clothes away.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I knew we were going to the gas chamber.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And he couldn't push me in because it was so full.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And they were yelling at him.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And he was afraid, I guess.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "He was only a guard.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "So he grabbed me and he threw me out.",
      "word_count": 9
    }
  ],
