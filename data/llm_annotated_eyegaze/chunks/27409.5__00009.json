{
  "stem": "27409.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I was sort of guiding them.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "I was still in partisan side, had my own weapon.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "Entered the town-- it took two or three days still, the town was cleaned of the German.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I found my great grandfather there still.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "He was not deported.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "A sister and my sister, my late father and the uncle in the town.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "They were not deported.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And I went to-- to become the organizer to reorganize the state bank.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I didn't have even shoes properly.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "So I had to-- as a matter of fact, I had to buy a pair of shoes, which were a number smaller than I had.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "I could under-- take off my shoes under the table as a big functionar, commissar-- because there were too small for me.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And so I had to appear.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "I worked from beginning of April in this job, first in [NON-ENGLISH] where I worked before the war, afterwards in Strozhnitz.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And on the-- again, on the 16th of June was [INAUDIBLE] my day when I surprise, as it was the birthday of my late mother.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "I was called up.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "Probably they couldn't finish Hitler off without me.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "I was called up in the Red Army.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "From Strozhnitz, which is about 20 miles from Cerniauti, I came to Cerniauti.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "There was replacement battalion, which recruited the soldier for-- called up the soldier and directed them to units.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "They found out that I can read and write.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "And they needed somewhat for clerical work in particular.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "I had already the medal, and I was still in partisan uniform.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "I had my own sub-machine gun.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "And they took me as a clerk for the unit until July.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "It was the beginning of July when I was sent to Kiev.",
      "word_count": 12
    }
  ],
