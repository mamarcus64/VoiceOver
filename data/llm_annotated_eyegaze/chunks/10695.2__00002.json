{
  "stem": "10695.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 53.8,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of Jewish people run away to the church.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And the German killed them right away.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "With my own eyes.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They killed them.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Later came out the priest-- some of them run away, the-- the Germans didn't saw it.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "When we were there all day till at night, they took us to the train.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I didn't want to go in the train right away.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I said it's gonna get dark.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Maybe I'm going to run away, not to go into the train.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] We were left about 50 people.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Couldn't go in no more because the train was full.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "I understand very well German.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "They said, we're gonna kill them.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "The rest which didn't go in, we're gonna kill them.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I understand German.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "I pushed her in myself inside, in the train.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "The rest, they killed.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] I had to go into the window.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I was by the door.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "I had to go into the window.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "It was impossible to go into the window.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "You have to go on the top of the heads on the people, because there were so many people you can't-- you don't-- you don't have space to go.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My family wasn't-- wait, I forgot something-- OK-- [PAUSES FOR 8 SECONDS] My mother, the sisters, and the kids, they took them away five days before.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] They separated the young boys, the young girls.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They put them in synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was a big synagogue, beautiful synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They put us in the synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And they captured us five days without food.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Without water and without food.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 8 SECONDS] We should lose our strength and fifth day, they took us out.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "The Jewish police came, and they brought over bread.",
      "word_count": 9
    }
  ],
