{
  "stem": "21259.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.1,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And they lived with us, and it was slow.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I was living there four, four, four years, five years, with there.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "We was got a good marriage.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And since I took them, you know, there was trouble.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But she don't like me.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "She's a Romanian.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "She's Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "She tells me, you got married with a Polish [INAUDIBLE], you know?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] I don't know if you understand.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "This is a Jewish, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "But you know, got married with a, a Romanian, not, not a Polish Jew-- [LAUGHS] Polish Jew.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "But the mother-in-law, she was such a-- I tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And we got argument.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And I told, you won't come to the United States to my wife.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And she, she tole me, OK, you go first.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I took my cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "My cousin went to Canada, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "He told me, if she not want.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Now, I was talking with her.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "Everything she tell me, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "Now, I was coming to Canada, to United States, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "I, I got a job in a-- from my cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "He is David Rosen.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "He has his baker's supply, big, big company, you understand?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "He wants me make a baker-- sales baker.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "And I was working with him, you understand that.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "So when did you come to the United States?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "The United States?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When I got divorced.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "In Canada.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I got divorced.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "This was in '57.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Then I came to United States.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And she told me, you go.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You make something.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I'm coming.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And after I have friends in Canada, they told me, you know, with the best friends, I went then.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They, they took my wife away.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] And, and she, she not want to come.",
      "word_count": 9
    }
  ],
