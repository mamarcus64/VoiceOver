  "model": "openai/gpt-oss-120b",
  "elapsed_s": 338.0,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] We stay-- we stay for a while with-- in Karaczun with them.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And the, the Polish people used to take us sometime to, to help them out to-- in the-- we were, you know, we feel better than-- you know, that we can.",
      "word_count": 31
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They used to give us food.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was-- everybody escape.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "This is a-- they escaped from the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Some people escape from, from Brezno, some-- all around-- all around.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] so we were together.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "We were together there for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And later, [PAUSES FOR 11 SECONDS] one time, [PAUSES FOR 4 SECONDS] it's, it's-- came a time where the Polish people-- with the Ukrainian, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "The Nazis make-- the Polish, the Ukrainian became very big enemies.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "The Polacks used to kill the-- it was that if they caught a Ukrainian in-- in Polish, they used to kill him.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "It was very-- between them was a-- so-- and the Polish people used to ask us already to help them, to defend from the Ukrainian, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "We have a few rifles.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "We had a few rifles with us.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And they ask us.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "And it was so bad that they were afraid.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "It was-- a lot of Polish people were killed.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "It came to a point that they must run away, leave that village and run away.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "And they were very rich people there in Karaczun.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "So-- and they asked the Germans to give them-- and there was-- the railroad was near that.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] So-- and the Germans give them-- give the wagons.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "And everybody was-- they left everything, whatever they could.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "And they went to Germany because they were afraid that the Ukrainian got there more-- they going to kill 'em.",
      "word_count": 20
    }
  ],
