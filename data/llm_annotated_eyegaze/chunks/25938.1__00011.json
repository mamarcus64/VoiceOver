    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- I left my house.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "It was in the evening.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "And I look back, I say, how could I-- how could I know I have to go to Russia?",
      "word_count": 19
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "How can I know the direction?",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "But I came to Jeziory, where my family was.",
      "word_count": 9
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "And from there, I and my cousin, we-- we left in a group of young people.",
      "word_count": 16
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 7,
      "text": "What was your cousin's name?",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Bill, [?",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "Berele. ?] His name was [?",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "Berele. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Borowick also.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "A very talented-- talented young man, very talented.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "He would have been a scientist now, I would think.",
      "word_count": 10
    }
