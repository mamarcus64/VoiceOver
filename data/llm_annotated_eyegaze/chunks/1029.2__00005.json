{
  "stem": "1029.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 171.3,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "They took us through Vienna to Strasshof.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Now, Strasshof was a distribution camp.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "We did not know what it was beforehand.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "But afterwards, we found out everything, you know, from the-- from the newspaper articles and people who knew about this, you know, the machinations and everything.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "We found out that Strasshof was a distribution camp.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And we went through Vienna.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Again, they took us at right, in the morning, around 1 o'clock, when it was dark, when people didn't know us.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "They took us in trams, regular streetcars.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I thought we were going to go somewhere, maybe to a restaurant or something.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Or-- although, I didn't know much about restaurants.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I thought we were going to go to a pub where we can get some spritzer or something, you know?",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Did anybody try to escape?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We didn't even think about it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We just didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We went like sheep.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I mean, I can't believe it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "But we-- well, who-- who was going to escape?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "The older people?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Where will they go?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "First of all, they were too weak.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "They didn't have any money.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "They were like so conspicuous, it's unbelievable.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We didn't have any young people around.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "All the young people were conscripted into the workforce.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Some of the other young people were there.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They were practically hostages with their mothers and sisters there.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "How can they-- they go?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't go anywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We were-- we were-- there was just nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't do.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And we weren't violent people.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "So we didn't say, all right.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "We're going to shoot our way out.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And if we die, we die.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "But we'll take a couple with them, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "We didn't even think of such a thing.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "We just didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "But that's the way it was.",
      "word_count": 6
    }
  ],
