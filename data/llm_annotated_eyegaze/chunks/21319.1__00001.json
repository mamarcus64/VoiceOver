{
  "stem": "21319.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Mayer, ?] was two years younger than me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Because I was-- when mine sister was married, she was 17 years.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And when I was born my mother was 41.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And so somehow, mine-- my sister's son was only three years younger than me.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "Mayer ?] was his name.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "They all were taken to [INAUDIBLE] prison, in Vilna.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And from there, to [INAUDIBLE], to the big mass graves.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "They were of the first victims from Nazi Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "They were killed in Vilna, from the first victims.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We were a very beautiful family.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "My father, my mother were very, very devoted parents.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And we were all very much in love with each other.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And my father and mother did a lot of s[ What-- you know?",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Charity.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Charity.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So we always had strangers at that table, eating.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And especially the-- the-- from the religious Jews, the songs used to come to Vilna.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They had to go to the army, this was a law, when they were 18 years old.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So-- and since my family was very strictly religious.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "So we always had three, four young men eating at that table.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And there was-- there was a family, a mother and father, and three children, who were very poor, living across the street, in a little house.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He was-- he used to repair shoes or do shoes.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And they never had enough food.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So they always used to come around.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my mother used to give them food.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "In fact, her, the mother's name I remember.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Dobe ?] was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And they always giving charity, always helping.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And there were some Polish people who lived in that building, and next building.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they were my friends.",
      "word_count": 5
    }
  ],
