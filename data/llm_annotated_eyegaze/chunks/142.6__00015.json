{
  "stem": "142.6",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have any Germans to-- to do.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "They were outside, sitting outside-- nothing to do.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "But one was a terrible guy.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "The other was from Holland.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "I don't even remember his name.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was very bad behavior, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "He was not a nice man.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "Anything that they find you, you did something, he would kill you, or-- or give you-- I don't know, just very bad man.",
      "word_count": 23
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Who, me?",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "I-- I haven't seen him killing.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "But it was his behavior-- everyone around knew that he wasn't a good man.",
      "word_count": 14
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Because, we didn't ever have nothing to do with him, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "He was outside sitting.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "We had two people at the time, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] Everything was done by the capos-- everything.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "They were the people that we tried to be in a good name.",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Which one?",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "They only one I know about that was Moll, I think-- Otto Moll.",
      "word_count": 13
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Otto Moll was a very, very [PAUSES FOR 3 SECONDS] sadistic man.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And he will-- when they were coming in, you know, they would pick up about 20 young girls, you know, and just undress them, and try to shoot them in the-- in the-- in the places, you know, what they call them-- just the breasts, and here.",
      "word_count": 47
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "So that was Moll.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "I was seeing when he was coming and everything else.",
      "word_count": 10
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "I, you know, he was coming always 1, 1:30 in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "And I would see the motorcycle coming in, and I knew that is Moll, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I was there, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was working at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] He-- he-- I think I wrote a little bit about him, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "He was very, very sadistic man.",
      "word_count": 6
    }
  ],
