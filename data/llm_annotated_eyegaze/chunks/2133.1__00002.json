{
  "stem": "2133.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "There was six of us.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "[CLEARS THROAT] Four girls and two boys.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No, I was the last one.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The last one.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I don't think I really want-- was wanted, [LAUGHS] I just came anyway.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother was 42 years old, and I don't believe that she would have, you know, bothered to have another child after having five children.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "But I came anyway, and here I am.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we got along very well.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "There-- there was a big age different.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "There was 10 years between me and my sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And my brother, I lost him when [CLEARS THROAT] he was about 19 years old.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "He just graduated from the eighth gymnasium.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He was a very good student.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I don't know, actually, [CLEARS THROAT] what kind of a illness he had.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He was about 11 years old, and he was very athletic.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And he was playing football, and somebody kicked his knee.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And ever since that, he-- he was constantly sick, you know, with the knee.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And my mother took him to every doctor, and-- and she spent awful lot of time to take-- even took him to Germany to some famous professor.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And they just couldn't find out what it was.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So [CLEARS THROAT] there was time that he couldn't go to school.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I mean, he had to-- he-- he was home for about seven months-- or three-- three-- three months of the year he went to school.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And when my mother went up to-- [CLEARS THROAT] to the professor to find out how is my son going to do and graduate, he said, with your son, he's so smart that he-- you don't have to worry.",
      "word_count": 39
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "If he comes one day to school a year, he'll be able to graduate, you know [CLEARS THROAT]",
      "word_count": 18
    }
  ],
