  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And-- [PAUSES FOR 3 SECONDS] and then finally I-- I thought, well, I'm going to try the next village.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I'm going to try and looking for work.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Maybe this way it'll be easier to stay somewhere in one place.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And some of them didn't want.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Finally, I went to this house on a farm, village, and I tell them I'm a girl from Russia.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I'm an orphan.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I'm-- I'm an orphan.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I'm looking for work.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Can you use me?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And-- and he said, maybe we can.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And the lady, the woman of the house asked me, what's your name?",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And just without any thinking, I knew I mustn't say [?",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Rachela, ?] because [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Rachela, ?] it's a Jewish name.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And I said, Marusia.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And that's a real Russian name.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And they said, oh, Marusia.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "They liked the name right away.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And they said, where you from?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I said, from Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And she sort of took a liking to me right away.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And she says to her husband, I think-- I think we can use her, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And-- and I stayed there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Where was this?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The name of the village?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was called [NON-ENGLISH], I think, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And that's close to a town, Miedzyrzecz, which was-- a lot of Jewish people lived there in that town, [PAUSES FOR 3 SECONDS] also the Ukraine in this area.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And they had two sons.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they wanted me to look after the cattle, the cows, to take them, you know, to the fields and look after them and-- which, I thought, well, of course I'll do it.",
      "word_count": 33
    }
  ],
