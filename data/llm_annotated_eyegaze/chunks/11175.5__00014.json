  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I started to-- I had to walk another five, six miles, [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I walked with that stick in my hand.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And I walked, and I walked, and I walked.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Finally, I came to that corner-- to that-- I made that five, six miles, and I came to that corner with whole-- [STAMMERS] the Russian Army, tanks, and some cars, and everything.",
      "word_count": 32
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I stopped there behind-- by one car.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "It's not-- was not a car, it was a-- a horse and buggy, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I stopped for him.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I looked at the man, and I took out that paper, and I show it to them.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "He looked at me, and he said, [NON-ENGLISH SPEECH]?",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I was, [NON-ENGLISH SPEECH].",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Come on.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "He took me on that wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "We went in-- we drove them to Sokolov.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And we-- they stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "It looks like they stopped somewhere, because they had to cook some food.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He say, you're not going away from here, until we take care of you.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "You sit here.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I sat down.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And they sent over-- right away, noises, and--",
      "word_count": 8
    }
  ],
