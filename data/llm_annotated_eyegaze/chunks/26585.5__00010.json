  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And he said, don't you ever do that again.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "So what?",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "I said, pull over.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Well, anyway, this is too long a story.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "The fear was still in me.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And my husband, who was friendly with the Charleston police, had the guy come to the store so that I could talk to him.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "I was shaking.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "Do you still, today, think of the Shoah often?",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's part of your life.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "You dream, you-- you-- you-- you never-- you never forget it-- you never forget it.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We did for awhile.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "But I'm so thankful for the life I have today.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "All I do is thank God.",
      "word_count": 6
    }
  ],
