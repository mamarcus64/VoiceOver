{
  "stem": "17374.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Some Jewish people know that this bribery.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "That you have to have some money, or diamond, or whatever to be on the list.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "But I didn't-- at that time, I didn't know about all these thing.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I know that my sister wasn't there.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "She was in the beginning, and then she was thrown out with many others.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "To Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And when I was in Birkenau, for only one moment I seen her from distance in another column.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "For a moment, I seen her in Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And then I lost completely.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know in Brunnlitz if she's alive.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "If I got sister or I didn't.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "In Birkenau, nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I was not that sick.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I was just sick.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But girls helped me, most probably.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Women around me.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But I was really collapsing in Brunnlitz.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "That I lost-- that I was in coma, unconscious for a few days, and I have typhoid.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And that in Brunnlitz already there were some girl and looked after me.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "There was one of them with our group who was a nurse.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "She lives here in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I don't meet her very often, [NON-ENGLISH], I think she said, after her husband.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "But they given me some drink.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And in Brunnlitz, they know that was already no shooting.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "We didn't hear any-- shooting.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "We didn't have-- it wasn't burning, it wasn't beating.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "No, no one was beaten up there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "It was strict, but we were told to go there.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And there in the beginning, we live in-- we sleep on the floor on this straw.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "And then was bank.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "And I was with my sister-in-law on one bank.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "Next to me, was the other lady who is still in Melbourne.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And she was in the next to me.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "And we work in the factory.",
      "word_count": 6
    }
  ],
