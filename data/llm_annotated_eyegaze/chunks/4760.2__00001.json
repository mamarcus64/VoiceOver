{
  "stem": "4760.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I had to be a boss already at the age of 15, to bake all the bread, four to five oven of bread daily, and help in the afternoon to distribute the bread to farmers.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "In-- in Europe, the farmers would not pay for the bread.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They would give them grain, you know, their own grain.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And then we would bake the bread and distribute to them.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "They would pay-- instead of money, they would pay with grains.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "So we would distribute around the farm-- around the towns, in-- the bread and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "That was still in Vic-sur-Seille.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And then my-- when my parents had left to Limoges in 1940, when the German started advancing to Holland and [INAUDIBLE] and coming to Paris, it became dangerous for me to live in Vic, so I was going to join my parents in Limoges for being more safe.",
      "word_count": 48
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But unfortunately, I left Vic-sur-Seille on July the 11th to go to Limoges.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In 1940.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And I came to-- to Paris and certainly no train were going out of Paris to Limoges because they were-- Germans were advancing from-- from Belgium, and into-- going into France, because the Germans wanted to be in France on the 14th of July.",
      "word_count": 44
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The Germans loved Paris.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Paris was an open city.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They-- they wouldn't bomb Paris because of all the beauty, you know, everything.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "That's one thing.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "But Hitler always wanted to see Paris.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So I-- I was in Paris on-- on July the 12th.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Stayed overnight in a hotel.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I always had one uncle who was very generous.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He always gave me money.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "When I left, he gave me 500 franc.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And that was a lot of money in these days in 1940, 500 franc.",
      "word_count": 14
    }
  ],
