{
  "stem": "21319.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And I had in my package a-- a blouse and a pair of skirt or something.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And I said to my little girl that she should wait, and meantime go and ask the guys where is here a bathroom where you can change or wash your face, because we're so filthy.",
      "word_count": 35
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So she-- he said, right there.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I still didn't know nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Listen.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "So my baby was sitting there with the rest of the kid, had the packages.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And I took mine.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I went into that room, in that-- where there's water and a toilet.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I took off mine clothes and put on a clean blouse-- I washed my face.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I could see.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "There was a little mirror there, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Washed my face and put on a clean blouse and a skirt, you know, and wiped-- I had a towel with me, you know, in packages.",
      "word_count": 26
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I came out and I felt better.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Some-- somewhere, somebody along the line there watched over me, because five minutes later two of the men who were watching, or three of them, and watching a transport, you know, from the Sonderkommando, came over to me.",
      "word_count": 38
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And he said to me, what are you doing in this transport?",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I have to stop you.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We have to pause and--",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So you will remind me, because I forget.",
      "word_count": 8
    }
  ],
