{
  "stem": "5357.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "My brother was there, my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "The farmer was building in his farmland--",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "--near his farm.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But he knew my brother-in-law from the mill.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And he was an old guy, married a second time.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He had two sets of kids.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But a very nice Polish fellow.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My brother-in-law wanted to sign the mill over to him and he wouldn't take it.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Can you imagine?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Such a nice fellow.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I knew where they are.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And my sister said, if you ever need us, but be very careful, you can come and see us.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And they gave me to another farmer that they knew.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "My sister, my brother-in-law.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And I went to that farmer as they were emptying the-- the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "You see, they were rounding up the people.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I heard a lot of shooting.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And I was on the attic.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And I was crying, because I didn't know if my sisters had-- my sister and her husband and my brother had time to run away.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So I cried most of the night because I heard the shootings.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And then I fell asleep towards the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And she comes up and she says, this farmer, she said, you can't stay in the house, because the Germans are coming with dogs and they want to see if somebody escaped.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "So I thought that I am in a cellar.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And I fell down from the attic, because I wanted to go up in the hole.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I fell down.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And it looks like I have the deviated septum from it.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And she said, go in the fields and-- and I'll bring you lunch.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "So I went very carefully in between the-- the wheat or whatever was growing, not to make a path so they see.",
      "word_count": 22
    }
  ],
