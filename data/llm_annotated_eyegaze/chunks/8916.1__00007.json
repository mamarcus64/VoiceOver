{
  "stem": "8916.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I-- I-- I was sorry to leave my grandparents, but I was excited to come to Krakow and to live with-- where my father was.",
      "word_count": 25
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes, as soon as we arrived in Krakow, we were sent to school and continued our education.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall the name of the school.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I should-- I should remember that.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "It was a public school, and it was within walking distance from where we lived.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "It was-- we lived on [INAUDIBLE], a street called [INAUDIBLE], which means industrial city-- industrial street.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Not a-- not a-- it was a good neighborhood, but it wasn't a high-class neighborhood.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "It was really an industrial area where my father worked, near his-- the company where he worked.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And the housing was actually factory housing.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Not immediately in the-- in the neighborhood.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "There was one at the end of the street, but not many-- not many Jewish neighbors in that area.",
      "word_count": 19
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "That was not a Jewish area.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "We were-- were were across the river.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Krakow is a city that's divided by a river, and on one side of the-- of the river, it's actually called by a different name.",
      "word_count": 25
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Podgorze.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And Krakow was on the other side.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in Podgorze, and the Jewish section-- the Jewish sector of Krakow was across the river in Krakow, in the other side-- on the other side.",
      "word_count": 28
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We were too busy trying to-- to acclimate ourselves to-- to the new environment.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, I was looking at the tall buildings, the first time I ever saw a tall building or a street car.",
      "word_count": 23
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "So there was no time for any of that.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Well, quite a bit in that my mother was isolated by then.",
      "word_count": 12
    }
  ],
