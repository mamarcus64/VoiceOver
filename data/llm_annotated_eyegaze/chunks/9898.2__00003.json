{
  "stem": "9898.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I said that [PAUSES FOR 3 SECONDS] on October 15, 1940, when they moved into-- to him to-- Czerniakow, the Gestapo, at the same time on almost every building in the ghetto showed up proclamations in German, which were-- which on it were written, [SPEAKING GERMAN], which means resettlement of the Jews to work in Germany.",
      "word_count": 56
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] This was on July 21.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Try to remember this date, because I'll come back to it.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "At that day, the whole ghetto was just, by the Gestapo, they were committed to death, to die.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "On November-- on-- from October 1 until November 1, 150,000 Jews who lived on the Aryan side had to move in within the boundaries of the ghetto, and 80,000 Poles had to move out.",
      "word_count": 34
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Now, the Poles got-- the Poles got trucks.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "The Jews could take only what they could take on their shoulders, on a small pushcart.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "This was a madhouse.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I was on the street, because I was going all over.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I wasn't afraid of anything.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And you could see on the street those old Jews with long gray beard, you know, pushing the cart.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And the German soldiers-- kids, 18, 19, 20 years old-- turning them over, and those poor Jews screaming and crying, picking up these things.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "On December-- on November 1, 1940, [PAUSES FOR 4 SECONDS] everybody was supposed to-- supposed to be in.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "It was-- they brought Jews from different small villages around Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So there were around 500,000 Jews living in the ghetto, where there was space only for 200, 250,000 maximum.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And then came the day, November 15, 1940, a day which I will never forget in my life.",
      "word_count": 18
    }
  ],
