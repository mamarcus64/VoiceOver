  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And when we came to [NON-ENGLISH] 38, my mother was very sick.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "She had a boil on the back of her head.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They said because she didn't eat salt for all those years.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "She was very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "They operated on her, they put the thing out.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "There was a very bad odor.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And she stayed on the second-- the hospital, I think, was on the second floor.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "The children were on the third floor.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And they told me to go on the third floor.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "Over there, there was children.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
