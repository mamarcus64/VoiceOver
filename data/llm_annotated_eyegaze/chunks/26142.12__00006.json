{
  "stem": "26142.12",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "All night, I was so sorry that I-- I-- instead of-- instead of giving them-- giving them pleasure and joy at seeing me, I made them-- I made them to see these stories.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "The next morning, the next day [PAUSES FOR 4 SECONDS] there was a guy by the name of [NON-ENGLISH]. he had a printing business.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And my father was friendly with him.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "And he had a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And this daughter, through him, she was the one that had connections with the police that hired this detective that brought us over.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "Everything went for money, for-- you know, to grease the-- so when my father went-- first of all, they took my citizenship paper away.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "I had no more paper.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So when my father went over to this Steinberg.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And he said, maybe we can do something.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And he talked it over with his daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And his daughter talked to other people.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And she said, I'll be able to-- I'll be able to get the citizenship paper back to you.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But you better get out of here.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Don't-- don't stay here.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Another day or two-- another day or two, I got my-- they got my citizenship paper.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They probably wouldn't have given it to me if they wouldn't have known that I have a copy of it.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I left that time.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "That was my joy of coming to see my-- my parents.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "When I went back, I went back to Debrecen, I didn't go to see my brother, because my sister-in-law, I didn't want them to see the way I looked.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I was black and blue all over.",
      "word_count": 7
    }
  ],
