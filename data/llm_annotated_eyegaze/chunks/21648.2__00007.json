{
  "stem": "21648.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "You know, they were so scared, they-- they was quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And the fellow, what he told us to go away.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "For the first two days, he didn't know where we are.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So he was walking and the-- that was in the summertime.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And the-- what they call the-- no, the-- the weeds was high.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "So we were laying there.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And it was just starting to grow.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "So what we was doing, chewing the grass.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And the grass was keeping us moisturized.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Inside barn.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He was walking on their knees crawling up.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And then was in the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He dug a long, long tunnel.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And then he make me the grave there.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So it was enough for us four to lay, lay and sit.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And the light was coming like this, like a tube.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "That's what we had.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And he gave us a path.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And that's where we used to do our duty.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And he brought you food?",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "How did you [INAUDIBLE]?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He was giving us food.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Soup and bread.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "He used to give us a bottle of water before for the day.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Once a day.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The most in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, for all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "That was about 14 months.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "What we do?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "There was full-- excuse me-- with lice and [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "We had this shirt what we ran away.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "That was the shirt that we got free.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "She used to come and take our clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And they have oven where they bake and put the clothes in the oven to kill the animals.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And we was full.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I don't know if you know what it means, [INAUDIBLE] on the head.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Once you get the-- you should know how.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I don't know how to call them-- I mean, between the fingers and on the head.",
      "word_count": 16
    }
  ],
