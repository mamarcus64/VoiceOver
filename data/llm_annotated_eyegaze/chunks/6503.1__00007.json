{
  "stem": "6503.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And if my mother and my father going to come, you can hire the man and he will bring your mother.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "But what happened is that when my in-laws came over the border, they lived in Cologne, and it was a very poor hotel, because the committee there in Cologne gave it to them.",
      "word_count": 33
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "It was cold, it was winter, it was icy, and she slipped down the steps and got killed.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "So she never came to Holland.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "She was buried in Cologne, and my father-in-law came by himself.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "At the time, it became worse and worse, and we couldn't bring my mother no more over.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "It was too late.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "So my mother was later picked up and sent to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] That's how it is.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My husband's name is Abraham Seeman.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I married in 1940, in September 11th.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It was already Hitler.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "My mother still sent me the paper because at the time, you were not allowed to marry out of your religion.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So my mother wrote me down that I was Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "She went also in Vienna to the [INAUDIBLE] who gave the paper that we were both 100% Jewish so we could marry.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Because it was not allowed no more- no intermarriages or anything.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I married with my husband, and I'm married now for 55 years.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "But my brother was picked up.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "So was his wife and her mother, and none of them survived.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "My brother lived-- they told me that he lived by the liberation.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He went to the death march, and somehow he got killed or he-- whatever, he was shot or something.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "My brother never came.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "I had already my apartment where I lived in Amsterdam, and we prepared for him.",
      "word_count": 15
    }
  ],
