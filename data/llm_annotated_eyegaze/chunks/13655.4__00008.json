  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] When they opened up the ghetto, they find each other.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "They saw a few from my town, a few from the other town.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "They was looking to get some place.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "We was staying-- we find a room.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "What can I tell you-- I'll tell you the dimensions.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "It was probably-- --8 foot by 20.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "We was 13 people in that room.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And a couple of days later, again a transport.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And they-- but before the transport, I was hiding myself in a cellar.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "They caught me.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "They brought me in to--",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "--to a room, to arrest.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was a few people there, about 10, 15 they caught.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "They're going to be-- what happened?",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Example, they caught me before lunch probably-- yes.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Then-- When did you--",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "This was a week later, after the first transport, the 20,000 people.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I was not in the transport.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "They didn't come in.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "You mean that for Rzeczyca?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I was-- they took me right away, before the transport arrived.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "They had [? grabbed ?] me and another guy.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Tag-tag-tag-tag, tag-tag-tag-tag, that's It.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "It was a few horse and wagons.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They sent them to Treblinka.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "I'll tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Wait one minute.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "This was-- [PAUSES FOR 5 SECONDS] --yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "That time, when they caught me, they took me in arrest.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "It was about 15, 20 people.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "This was in the morning, before lunch probably.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "By sunset came [NON-ENGLISH] with a few Polish police, [INAUDIBLE] Ukrainian.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "They came in.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "They brought us down from the upstairs to the downstairs.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "From the attic?",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "From the attic, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "No, they was in a room.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Not a legal apartment, but a home [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "He said, [NON-ENGLISH], be honest.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Give up what you have, gold, money, division.",
      "word_count": 8
    }
  ],
