{
  "stem": "18670.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "How we got of Vienna?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Well, I came home when I had [INAUDIBLE] I forgot already how much it.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "It was several hundred shillings.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Austrian currency is shillings.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We had no name for-- they were just people helping us.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Jews.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "But along the road was Gentiles, were Christians.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The guy in Vienna got the money.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And everything was arranged.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was 11 o'clock at night.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I'm leaving tomorrow morning at 2 o'clock, on next train out.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I'm taking my brother along.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Now, that was quite difficult, because my brother was my mother's darling.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "But we showed them, showed them the plan.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I says to them, if everything works out fine, you will follow us.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And we left 2 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "We were up all night talking, talking, convincing they should let us go.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Got to Vienna.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "In Vienna, we took the train to Germany and arrived in Cologne in the evening.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And the very funny-- funny.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "It wasn't that funny to us.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "We were scared, really scared.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "We wound up the hotel called the Bayerische Hof.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "The Nazis had the convention there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Bayerische Hof.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Bavarian Court.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Bayerische.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Bayerische means Bavaria.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Hof.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "H-O-F.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he got there and I said, my god, we can't stay here.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "So my brother and I decide we're going to go to a movie and come back midnight, when it's dark.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Go to the movie and they were showing a newsreel of the Reichstag-- not the Reichstag, I mean in Nuremberg the Nazis had their big conventions and Hitler made that speech and everybody hollered heil.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Their arms were up.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And people were laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They were laughing in the movie theater.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And we've just come back from Austria.",
      "word_count": 7
    }
  ],
