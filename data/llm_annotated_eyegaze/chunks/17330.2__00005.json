{
  "stem": "17330.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 405.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And we had to pay a lot of money to stay there.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "But when the baby was born, we had to pay him a lot of money too every day.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And my father had to bring me meat, otherwise I wouldn't have hardly anything to eat, because that home belonged to two nurses, and one of them was a very mad woman.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And she got-- for all those kids she got coupons for food.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "But she sold the coupons.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And she had a child.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I don't know how she got that child, if she adopted that or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It was not they easy in Haarlem to adopt a child.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "But anyway, she had a little girl.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And that girl was all dressed up and good-looking and ate whatever there was.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "But she did it all from the coupons from the kids.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "Anyway, she was caught later on.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "But let me first continue with-- then when I had the baby, I left there.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And then I want to Hausen.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And then I ran away there, because I was very restless, of course.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "And then I went back there and asked if I could work for her as an assistant nurse.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I can't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And then I worked there from 7 o'clock in the morning 'til 7 o'clock at night.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Every morning for 30 kids i had to do the washing on the washing board, not in a machine, because there was no clothes.",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "There was no money.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And those kids came in really neglected, full is lice.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And you had to cut the clothes off them and put them in special baths.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And it was horrible.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And on top of that, I had to pay 65 guilders a week, on top of my work.",
      "word_count": 18
    }
  ],
