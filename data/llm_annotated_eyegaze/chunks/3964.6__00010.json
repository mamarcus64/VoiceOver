  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Went back to New York in 1951.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] And I went into business for myself, had a business, a candy store in New York, for approximately a year and a half, a year, and decided I wanted to leave New York.",
      "word_count": 37
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Sold the business, and went to visit with my friend in Kansas City, Missouri.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "He wanted me to stay there, because we were friends from way back when.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And Kansas City, Missouri wasn't my kind of town.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "I went on and arrived in California in October of '52.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And [PAUSES FOR 3 SECONDS] I am very happy I made that move.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In 1957, [PAUSES FOR 3 SECONDS] I went to New York.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "In 1957 I went to New York and I met my wife.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We had a very short courtship [PAUSES FOR 3 SECONDS] and we were married in September of 1958.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And she moved to California with me, came to California with me.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "In 1959, our first son was born, Kenneth, [PAUSES FOR 3 SECONDS] who is a [PAUSES FOR 3 SECONDS] doctor of molecular biology, today works for the National Institute of Health in Washington DC.",
      "word_count": 34
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "He's our oldest son.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Mark was born.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Our second second son was born in 1961, I believe.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And he lives here in California, lives in Los Angeles, near us.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "He is a computer [PAUSES FOR 4 SECONDS] scientist.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] Kenny is married, [PAUSES FOR 3 SECONDS] has a son, our grandson, the only grandson we have, Jeremiah, who is 9 and 1/2 years old.",
      "word_count": 29
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And obviously, he's our pride and joy.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My wife, Jeanine, [PAUSES FOR 4 SECONDS] is [PAUSES FOR 3 SECONDS] an artist.",
      "word_count": 14
    }
  ],
