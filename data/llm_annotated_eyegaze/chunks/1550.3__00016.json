  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "The main-- the main industry in Mauritius-- even today, I think-- is the sugar.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Sugar in the cane-- sugar cane, which is being-- being cut down and-- and refined and then sent to England, most the time.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But we were-- we were cut off from the local population.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We were living in this-- in this camp for-- for four years, and had very little contact with-- with the local population because we were not allowed to go out.",
      "word_count": 30
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Except once in a while, we got a day pass to go in to town for a day.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But we had to go back-- we had to be back in in the evening.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And once in a while we were allowed to go to a beach to go swimming, under escort-- under police escort.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
