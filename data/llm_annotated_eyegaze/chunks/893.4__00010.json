{
  "stem": "893.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We-- we did some business in Morocco.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We also-- we were very friendly with the-- we were friends with the Reichmann boys, who were our age.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And our friends, or our cousin, was trying to get somehow visas for us, but it took them two years to get an act of-- by-- by an act of-- a special act of Congress to allow us to come on a special visa.",
      "word_count": 44
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "So it took us two years.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In 19-- in May the 5th, 1948, we came to the-- New York.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, in 1952.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We met through a mutual friend.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It's her cousin and our-- and a friend of ours from our city who introduced us to each other.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And we met in New York, and we got married November the 2nd, 1952.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Thank you very much.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I would like you to meet my wife, Gloria, to my right.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] Bubby.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I want you to-- the fellow sitting in my lap, his name is [?",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Eli. ?] The little girl sitting in Gloria's lap is Tzipi.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Next to her, the baby, Yocheved.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Then clockwise, Tzvi.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "That's Jeffrey's son.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "They are twins, Tzvi and Esther.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "My daughter-in-law, Risa, my son, Jeff, my oldest son, Robert, holding his youngest son, Shlomo.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I have another son who lives in New Jersey-- Teaneck, New Jersey.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He has three lovely daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And my oldest son, Robert, has another boy by the name of David.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Chayaleh ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Dinah. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "All together, 12.",
      "word_count": 3
    }
  ],
