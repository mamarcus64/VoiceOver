{
  "stem": "13198.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Nobody really knew I was pregnant, couldn't see it even.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "But I was thrilled.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I was-- that was my career, being a mother and a wife.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I wasn't a slave wife, but I didn't mind being married.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I mean, that was the time when the women would say, oh, you know, being married, you're your husband's slave.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And we want our careers.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "That was all the talk in those days.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "It was the beginning of emancipation of women, I think-- in Holland, anyway.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't at all.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, that was the end of everything for me.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "First of all, I was English.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So I had-- and I spoke Dutch with an English accent.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So if I'd only gone to work, my mother and everybody said, oh, your English, because there was a strong English accent.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I didn't seem to be able to manage all those guttural sounds.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And-- [PAUSES FOR 3 SECONDS] and then of course, my husband-- although he wasn't religious Jewish, he was involved in a lot of Jewish-- what do you call it?",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Social life for poor people who didn't have jobs or didn't have any money to run their homes.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And he was with a lot of social work for Jews, but not with the religion but more to help-- help.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "What did he actually do?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I think he had clubs for these people arranged that they would meet once a week and have people giving lectures or anything social life, arranging outings, and, well, all sorts of things.",
      "word_count": 33
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I never went to them, because I was busy with all these babies.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't feel socially a bit.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I didn't like-- I didn't like people.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I still don't.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "My husband loved his fellow creatures.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I didn't.",
      "word_count": 2
    }
  ],
