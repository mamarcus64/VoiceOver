{
  "stem": "10397.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Numerus clausus means there was a limited-- either closed for Jews or if you have 5,000-- if the father had a lot of money, which my father didn't, 5,000 and up, and you know the appropriate person, possibly, you could get in.",
      "word_count": 42
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "In my-- in Brody, there was one Jewish student who was admitted to medical school in Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "But his father was the secretary of the court, Jewish fellow, and they had connections, so to say.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "He  was admitted.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "For-- for-- first of all, they admit everybody who had the qualifications and high school education, and then, the-- the immigrant, the-- the foreign student, what bringing money to the country, and whatever they brought.",
      "word_count": 35
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But they were-- there was a certain-- you know, for business reasons.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They admitted these students, from-- mostly Jewish students from all the countries, Hungary, Poland, Bulgaria, [PAUSES FOR 3 SECONDS] Greece, and [INAUDIBLE] Ukraine-- from Ukraine, too.",
      "word_count": 26
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But I mean, they were more liberal.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "There were two medical schools.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "There was a Czech-- Czech medical school and a German medical school.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And both schools were known, because my school was founded in the 15th century and had a tradition.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And they had a excellent upstanding, outstanding teachers.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "That was the German medical school.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "German Medical School of Prague.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We-- we had a lot of Zionist activities, and the corporations under German style, so-called fighting corporations.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And of course, there was-- not everybody belonged to a corporation.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I belonged, you know, just to be a-- have a group of people that are close.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We met every Saturday.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We had one beer, and we were talking about Zionist problems, and had speakers.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And once in a while, dances with the Jewish-- we invited just Jewish girls.",
      "word_count": 14
    }
  ],
