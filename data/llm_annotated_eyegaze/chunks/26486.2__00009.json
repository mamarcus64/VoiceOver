{
  "stem": "26486.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "As I said, I started really with the underground, not knowing what I was doing, until the day she told me.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I had started already.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And she told me well, you know what you're doing?",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "Do you mind, and this and that.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "And then things came so fast, and so fast, and so fast.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 9,
      "text": "Before we knew it, we were arrested.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Not '39.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "After-- '40 I told you.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I told you I knew her in '39.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Then we were working to the fairs.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "About what?",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Well when-- you mean when I was arrested, or how they arrested me?",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was just still working at the Chamber of Commerce, until they arrested me, and going back and forth.",
      "word_count": 20
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And then one day, when they arrested me, they came.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I had been weekend trout fishing with my future husband-- I was hoping-- and friends.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "And when I came back, I was sick.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "I had pleurisy.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And I was in bed.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "And the owner of the building where I lived, came up and he said, she said, there's something funny going on.",
      "word_count": 21
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "There are two Gestapo who want to speak to you.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "I think my heart went up in my throat.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "But I couldn't do anything.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "They were there.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "And they knocked at the door.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "And they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 13,
      "text": "And they didn't ask if they could, they came in.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 14,
      "text": "And they told me [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 15,
      "text": "Get up.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 16,
      "text": "I was in bed.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 17,
      "text": "And they start to go through all my-- all-- everything.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 18,
      "text": "They opened up all the drawers, all the closets, everything.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 19,
      "text": "They took everything they wanted, everything they could put their hands on.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 20,
      "text": "And I had, you know, little books with addresses and all.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 21,
      "text": "They took everything.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 22,
      "text": "They helped themselves to everything.",
      "word_count": 5
    }
  ],
