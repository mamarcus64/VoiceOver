{
  "stem": "27150.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.9,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "You know, there was a fellow, with a big-- who had money, and had a big store of textiles.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So we went cutting 3 and a 1/4 yards.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And people used to go down from one office to the other selling them.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And those people-- you know, let me see, started he gave us a [NON-ENGLISH], a gold watch.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "So we got two suit lengths, and went out to the city to the offices and sold it.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And so he came back for another.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "That's-- that's how they may a living.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And these two friends of mine, they started the same kind of business.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And I was the bookkeeper.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We were living in the Western District, with-- together with the other fellow, a druggist, you see that means who had a drugstore in Warsaw, where he had a few bob, and we were in partnership to do this antiseptic.",
      "word_count": 40
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "It was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That means we were in a house owned by Chinese that actually they were refugees from Canton or something.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "It was a beautiful house, and we had a big bathroom to share.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You see, we live in [NON-ENGLISH], and they were a family.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And they had a-- it was kind of a palace.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And it sounded very cheap.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "That means that the Russian Jews had a club.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we were welcome at the club.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they were helping us, you see, that means with the hospital, with everything.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But this didn't last very long, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Because when Pearl Harbor started the Japanese took over everything.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "You see, that means we traveled by tram to-- to [NON-ENGLISH], to Central Shanghai, to take another tram to Hongkew, to the sort of Japanese city.",
      "word_count": 26
    }
  ],
