{
  "stem": "24130.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And every time we opened a grave-- you know, dug out a body or-- no matter how much I saw killings, I still was like shivering, to-- so and I would say, please forgive me.",
      "word_count": 35
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "It's not my doing.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "When we op-- we, a body, we would find a body, we would apologize to the body.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And we would try to hide it again in sand and cover it up.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish cemetery, because the, the stones were-- the [NON-ENGLISH SPEECH].",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The stones were on, on the floor.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They made steps from the stones.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "It was a Jewish cemetery in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We came out to the [? say ?] appell.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "The called roll call [? say ?] appell.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And they said we should march.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And we start marching.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We don't know where we going again.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And we marched through the gate.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We knew that we, we're leaving Plaszow.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "But we didn't-- we didn't have any belongings or nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "So we just marched out from there.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And there was a-- not far, a train station.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Many times we would go to work on this train station.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "They would deliver things.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "So we would go to the train station, take it off, and put a-- carry it into the camp, like bread, or, or products for the camp.",
      "word_count": 27
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So we went to the train station.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And they start putting us on the cattle cars again.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So they put in more-- they put a man, sick men from the hospital.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They brought men.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And they put in this sick men into the train.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And they pushed and pushed more, more people.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "It was so crowded.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Coming to, to-- from Auschwitz to Krakow, it took three hours.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And going there, it took us two days to co-- go.",
      "word_count": 11
    }
  ],
