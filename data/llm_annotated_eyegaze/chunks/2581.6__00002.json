{
  "stem": "2581.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "People worked-- worked-- my father worked very hard but did everything to keep his family-- to support his family, to see that his wife in the summer could be with the children, away from the house, which was a few kilometers.",
      "word_count": 41
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "It wasn't too far, but the children had the fresh air.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "My father was involved in the Red Cross.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "He was involved in the Maccabi.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "He was-- There wasn't an organization in town that he wasn't involved in.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, we lived downstairs on the grand floor.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And one flight up was our shop, where my mother never permit me to go up.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Her children are not going to be tailors.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And that being tailor-- that being tailor that I learned during the war saved my life.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "You know, when we get to that part, I'll tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "That being tailor saved my life, and it made me be in the United States, whatever I'm now was with that little bit of tailoring that I learned, you know, at home.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Rochma.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Frant.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "F-R-A-N-T, Frant.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She was a quiet person, a very good mother and a very good wife and a balabosta.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It always-- everything in the house shined.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, it wasn't as big as the houses I have now or houses that you see in the United States.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But for that time, it was elaborate, elaborate.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "If I slept in the same room, [INAUDIBLE] in the dining room, so that was elaborate.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Because some people had only one room.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But there was one-- you know, that cleanliness sometimes was going too far.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And, God forbid, I don't blame anyone.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "But the floor was polished with a red color, and it was very slippery.",
      "word_count": 14
    }
  ],
