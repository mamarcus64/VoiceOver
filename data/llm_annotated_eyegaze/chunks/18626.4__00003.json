{
  "stem": "18626.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 271.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Maybe the last half a year [PAUSES FOR 3 SECONDS] or maybe the last year or the ghetto start to be organized, the Zionist organization, [INAUDIBLE] and [INAUDIBLE] organization start to organize themselves quietly and have meetings how to sabotage the German army, how to do damage towards the German soldiers.",
      "word_count": 51
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But it was not with big results.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But then start to get big contacts, these organizations in the ghetto, with the outside of the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "That was the last years of the war-- of the war.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "In the woods, in the forests, were a lot of partisans, Russians.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Regular army Russian partisans.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "They were with parachutes, you know, down in the forests in Lithuania.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And they got contact, the Jewish organizations in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Three, four organizations with the partisans outside the ghetto, communications.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And then slowly, little by little, a lot of Jews start to sneak out from the ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And they had already contacts.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And they went in in the woods, and they were working with the Russian, with the Soviet partisans, against the Nazis.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "I had a friend of mine, he was maybe a couple of years older than me.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "His name was Slapok.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Two brothers.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "Slapok.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "Very strong athletic boys.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And they [PAUSES FOR 3 SECONDS] got in contact with certain, you know, partisans.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And the partisans gave these two boys orders to [PAUSES FOR 3 SECONDS] take railroads, dynamite the railroad, rails.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And these two boys, my friends, the two brother Slapoks, killed, I wouldn't exaggerate, thousands of German soldiers who used to come by train, you know, transport soldiers.",
      "word_count": 28
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "The two boys were dressed like peasant boys, Lithuanians, like farmer boys with shovels wearing like they work on farms.",
      "word_count": 20
    }
  ],
