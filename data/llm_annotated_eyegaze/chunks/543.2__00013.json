{
  "stem": "543.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "Every month, she was-- and if I was-- you know, they could not work on you, the operations, if you had your period.",
      "word_count": 23
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "The doctors find it most probably too messy.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So when I was called, I took-- and you know, there was no clean clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I took her panty on, and went to the doctor.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And said, look, I have my period.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "I can't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "Did that work?",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "That worked.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Two, three times, it worked.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So I was really saved from the big, big operations.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "I, I had the needles.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "I had all the other.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "They, they put, like, injections in one breast.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "And it was like this.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "And a week later, they gave another one.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "They one time-- they gave all kinds of trying experiments.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "What did they treat us, we don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They never going to tell you [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They're going to tell you [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "They don't.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "They took you.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "They did it, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "Did you see any other women?",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "Did you see any other experiments, besides the one that you had?",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "Can you just tell us what else you saw there personally?",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, I-- I know they-- no.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I think that the main thing was the, the--",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And also how you-- we nearly always get the same one, the injections you get in your back, and your breast, in your stomach.",
      "word_count": 24
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "That was for--",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Maybe they put something in the-- the sicknesses in you.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Like when I-- I have-- lately, I have four, five different kinds of rheumatism.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "You know, that I had Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Bell, a specialist, said to me, I never saw a person that have four different kind of four absolutely different kind of rheumatism in one person.",
      "word_count": 26
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "We know one, but four?",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "And Dr.",
      "word_count": 2
    }
  ],
