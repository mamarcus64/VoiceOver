  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 54,
      "text": "They tell us what we-- we spied-- we're American spies, we're Israeli spies.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 55,
      "text": "But we leave our-- our land, no, and we go-- they told us we go to fight in Israel army.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 56,
      "text": "I take my sons-- they told me, you take your sons, and you-- you will fight against us in Israel.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "How we can fight against us?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They-- they tell-- they make si-- the decision that I have military awards.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They send me-- we will-- they take-- we will take your military awards, everything what you have.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "You're not more Russian citizen.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "No, that was-- I'm not [INAUDIBLE] a Russian citizen.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I didn't-- that doesn't bother me.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "They take us from the jobs, they take us-- nothing to do.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "It only was our one-- one thing, what we-- what we got for what we buy-- food.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I-- I am invalid from the war, I received a small pension-- military pension, which they cannot take from me.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "The law-- the Russian law, every single [? country, ?] they actually cannot take.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then the wife, she was working all her life a teacher.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She got over 25-- the-- over five years [? awards ?] for a teacher.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And one-- one man give her advice, a good man, we will give you pension.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We will give you pension.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "She got the pension.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] the pension, we were staying in [?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Kiev ?] one year.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "For this one year, they take me my-- my life, they take me-- not less what I spent all the years in Russia-- what I was-- [INAUDIBLE] what they want to tell me?",
      "word_count": 33
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They-- they want to-- to take me in jail.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They told my wife, leave.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Leave him.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Leave him.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Let him go.",
      "word_count": 3
    }
  ],
