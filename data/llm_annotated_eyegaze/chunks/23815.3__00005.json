{
  "stem": "23815.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] Then I-- I-- I was crying.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And that man said to me, look.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Don't worry, I'll tell that you are my cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I'll get you through.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I haven't-- I haven't got-- I don't know the language.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I haven't got no money.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I've got nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And I said, thank you very much.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I was in her place for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "One day, she came, and she said to me, you know, people came from concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "They're giving money.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They give them clothing.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I can do this for you to bring for you.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "But you have to give me your parents' name.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I'd been through so much.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I was scared to say I'm Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I suffer because I was Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I never done anything wrong to anybody in my life.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Why should I suffer like that?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But I told her.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And I said to her, no.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "I'm not Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "But afterwards, when she came with a proposition that she wants to give me money and clothing for the people came from-- from concentration camp-- I was so young and naive.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I told my father's name is Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And she knew straight away that I'm not Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "That I was Jewish-- sorry-- that I was Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And she said to me, in that case, she said, I don't want you here.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "She went to the Greek consulate.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And she said to me-- she said to them, this girl is here without papers, and-- and she is-- and she is not allowed to stay here.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You have to send her back to Greece.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And then, I-- I went to-- to the street, and I was crying.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "A man came-- approach me.",
      "word_count": 5
    }
  ],
