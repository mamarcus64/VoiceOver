  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I'll-- to the railroad.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And we need to go-- it's the street buses in Kiev.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And no, it's after-- it's not the d-- uh-huh.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The-- the end of the war, it was the 9 of May.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Now we little-- back-- we met a little earlier.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "No, this episode I will never forget, is she began to run to the-- to the-- to-- to the street--",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "To the street wagon, how it's called?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Street-- street cars, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I cannot run.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And the-- the chauffeur, or how to call what-- she said that an invalid canno-- and she was waiting for me.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I come, come and sit, and then I-- I go with-- with her.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And then she need to go in from the railroad-- I say, you know what, [?",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Mina, ?] I don't have where to go.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "You-- you know what, at the time difference, how I don't want to cry, how I don't-- it-- it comes.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She tell-- she cannot say not, and she cannot say yes.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I told her, no she.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I explained to her what-- what-- what I'm not-- not, uh-- [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "It's happened in my life.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But I didn't want to be like that.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I came back by myself to-- to her home.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Her-- her father, it was the same in the war, on the front-- it was only the mother, and the mother's sister, and one brother.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I talk with the mo-- with her mother.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "No, I take Mina to the-- I come, I don't have where to do-- where to-- where to stay, what.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And she begin to ask me, do you have-- do you have anywhere a, a wife, or what?",
      "word_count": 18
    }
  ],
