{
  "stem": "6076.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "She didn't washed her face.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "When going to work, she worked next to my machine.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "I says, Chanka-- I begged her-- Chanka, try to wash your face.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "Try to comb your blonde hair, comb your hair.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "Because blonde hair gets dirty very fast, faster.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "And dark hair, you don't see the dirt.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "But blonde hair, somehow, you see like grease on the hair.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "She looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "She didn't answer me.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "She says-- one time she was so annoyed with me, she says, mind your own business and let me do whatever I want.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "I just don't want to live.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "If I don't have my mother, I don't want to live.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I'm not going to bother you.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But you cannot-- you are like we all here.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Why should you be different than we all?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She didn't answer me.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "She looked up with her blue eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "She stared at me.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "She didn't cry.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "She didn't say-- but it was an appeal.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Every month, we have a selection in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I stood next to Chanka.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And we were about a few hundred girls on that sel-- selection every month.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So the [? fuhrer ?], his name was [?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Batenschlager ?] came out with his, you know, with his whip, with the German shepherd.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And he looked in every girl's face.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Well, some of the girls, they put a little paper rouge they got it, what they tried to, to make themselves look a little red, to look a little healthier.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "They were afraid for this monster.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And he, he pointed to Chanka.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "She stood next to me.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And she held my hand.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "She gave like a shiver.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "She didn't want to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "She knew.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "She didn't want to live, but she feared for death, you see.",
      "word_count": 12
    }
  ],
