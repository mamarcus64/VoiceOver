{
  "stem": "19518.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 111.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "And my sisters liquidated the-- the home as well as they could, some things if they were able to sell, if they are able to give away.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "Or whatever that man that transported us to Tarnow, some of the things he took and brought to us, mainly clothing and whatever.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "And then he bought tickets for my sisters, and they joined us.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "And we were-- were again a family.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "My grandmother's sister and brother lived in Tarnow.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "That's why we chose that town.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "But apartments were scarce, because there were influx of people from different little towns that were made Judenfrei or whatever.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "People kept on running from big city to small city, from a small town to a bigger town.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "It was just like the Tower of Babel.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "And we stayed together with my mother's-- with my grandmother's sister.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "And again, my uncle had to register.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "His underage son had to register, [PAUSES FOR 4 SECONDS] my mother, my father.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "They did not ask for my grandmother.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "And we did not register her.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And I-- at that time, I think I turned 18 already-- or did I work?",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I think I worked already, so I had some piece of paper, an identification that I worked.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they had a list.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "So they formed in Tarnow the Jewish police.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "We heard rumors [PAUSES FOR 3 SECONDS] that Warsaw ghetto is being-- people are being shipped out of Warsaw ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We heard rumors that transports went out from Krakow toward Przeworsk.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "That was a town in the eastern part of Galicia.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And we did not know what transpired, but that people were transported in cattle cars.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "This we heard.",
      "word_count": 3
    }
  ],
