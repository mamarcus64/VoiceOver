{
  "stem": "25809.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "So I got a job in the Blue Mountains in-- in Leura about 60 miles outside of Sydney in a [? pension ?] run by Hungarian people.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And I said, well, I said, I-- I can come as a waiter, I said.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "But I had one suitcase that had all my waiter clothing in it, and I don't have any clothes left at the moment because that-- that case was stolen from me.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "So I need to get some new clothes before I can go there.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And he said, well, OK, get yourself some clothes, and we'll accept you.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "So I got this job.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "Actually, I got this job through the Jewish Advisory Board, had a Jewish Advisory Board there, and they helped me to get that job.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I went to Leura, and I'll never forget that first day.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I was given my station, and I said, well, I got to pretend like I'm a waiter.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I walked up to the-- to the kitchen door, and I said, three soups, like I had done it all my life.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And carried three soups to whatever place I had to carry them and just carried on from there.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I worked about from-- worked from the morning till-- till night, because they were very nice about giving tips.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "So I started to make a little bit of money, and I started to get ahead in my life.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "You talked about Surfers Paradise before.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Where's the--",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "As I was-- as I was a waiter, I didn't enjoy really that much being a waiter because I was getting a lot of-- pardon my French-- shit from the cooks.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So one day, I-- I looked in the newspaper, and they were always looking for cooks.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Waiters-- eh, a dime a dozen.",
      "word_count": 6
    }
  ],
