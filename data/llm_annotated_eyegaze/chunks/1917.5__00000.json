{
  "stem": "1917.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was a sergeant major in the Israeli army.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was very proud to be in the Israeli army, and I liked it.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "What happened was really I had a fiance who was very, very religious.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And I'd dated him for two years.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And then he wanted me to become more religious.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And I was hoping he would become less religious.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And so we-- I realized that that was not going to work out.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And so we broke up.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "He got married.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And he kept visiting me in Tel Aviv on the weekend, when I would have a date there.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And he got rid of one of my dates.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "I went to the kitchen to fix coffee.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "I came back.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I said, where is-- so and so.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "Well, I talked to him.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "He doesn't have any serious intentions.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "I said, I didn't know you were my guardian.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "He said, well, I feel responsible.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "I said, you shouldn't feel responsible.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "But the truth was that he still loved me, and I still loved him.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "Otherwise I could've kicked him out.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Second time it happened, I got a little bit mad.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I said, well, I guess I will have to go far away, where you cannot come and interfere with my private life.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And as things went, I-- I was very good friends with a family, very prominent family in Tel Aviv.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "She's Hungarian, actually Czechoslovakian-- Sarah Kor.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And they had a wonderful family.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And they kept telling me that my-- that her brother-in-law is coming from United States, that he's a survivor, and would I be interested in meeting him?",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I mean, what do I care?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I meet one more guy.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they were really very pushing that shidduch very much.",
      "word_count": 10
    }
  ],
