  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] So I, I applied to this-- [PAUSES FOR 3 SECONDS] to, to the medical faculty of the Warsaw University.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And to my surprise-- I don't know how much I was surprised, but everybody else was surprised-- I was accepted to study medicine.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "At that time, my father was working in Brest.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He, he was-- undertook that he will send me every month, 150 zlotys.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "That was zlotys, Polish money.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "But after the first month that he sent me this money, he wrote a letter that he's not going to be able to-- to send me money.",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "That was 1929.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "That was the year of the Depression all over.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "It was a depression in this country, and it was Depression that was there even from before.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So here I was, left to my own devices in, in, in Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And, well, anyway, I studied six, six years medical.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I did the medical studies.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I supported myself.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "In order to support myself, I-- what I was able to do is, I was giving in-- a notice in, in the Warsaw papers.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "There was a, a Jewish paper in Polish, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And there was which was a Polish paper.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "A student of medicine teaches, [PAUSES FOR 4 SECONDS] teaches Latin, mathematics, and physics.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I used to get pupils.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And then-- and then, well, that's what I did for a while.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] Well, yeah, what I wanted to say-- so I met one from, from Wlodzimierz, a, a woman.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Kosovska ?] was her name.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "She studied-- whom I knew.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "She studied to be a teacher-- met her in the streets.",
      "word_count": 11
    }
  ],
