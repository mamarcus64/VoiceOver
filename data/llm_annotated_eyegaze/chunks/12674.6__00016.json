  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 26,
      "text": "They throw them away when they have holes.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 27,
      "text": "And we all thought he was crazy.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 28,
      "text": "He was putting on.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 29,
      "text": "Nobody, nobody would throw away-- anyway, so we were there.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 30,
      "text": "And then, when we came to Bremen, which was a pile of rubble with a few suburbs.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 31,
      "text": "The center of Bremen was completely obliterated.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 32,
      "text": "It was nothing but rubble.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 33,
      "text": "And all the bridges across the Danube were gone, except for one.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 34,
      "text": "And, it-- Europe did not look pretty.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 35,
      "text": "It was very much destroyed and things.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 36,
      "text": "So when we came to Bremen, there was a stevedore strike.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 37,
      "text": "And we had to wait for six weeks before the longshoreman went back to work because there was no boats.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 38,
      "text": "And then we came over to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 39,
      "text": "And the Hebrew Immigrant Aid Society put us up in what is now the Astor Library on Lafayette Street.",
      "word_count": 19
    }
  ],
