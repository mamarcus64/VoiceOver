  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And not too far away on a field there was laying a friend of ours.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And the German-- from the army, from the Wehrmacht-- was watching him.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "He shouldn't run away.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And we had to-- the German claimed that he was wounded, and we had to put him on the stretcher and bring him to camp.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "On the way, we spoke to him, and he said he is not wounded, but they caught him with a gun.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] They caught him with a gun, and they brought him to camp.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 6 SECONDS] While he was in camp, they put him-- and they had a little jail there-- they put in that jail.",
      "word_count": 24
    }
  ],
