{
  "stem": "2568.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "The windows was closed.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "The-- papers, anything they shouldn't know even anybody's there.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Inside, in the room, in a little pot.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Couldn't help.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "You were-- we were maybe ten people.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And he was sometimes there.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "Once he comes to us, he says, I can't keep you any longer.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "He was leaving, or the princess threw him out, or something.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "Maybe she left.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "You have to leave the place everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "So I tell you what to do, to me he says.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "The rest of the people, I don't know where they went.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I want you go back to the labor camp, where you used to be.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "You go upstairs in the attic.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And we're going to keep you there and some more people that I met.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And I'm gonna arrange-- they're going to take you to countries out of town.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "And you're going to be having some Polacks.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "They're going to save you.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "They're going to keep you.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And everything was for money.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have already the money they took away, but I had other people.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "The want us to help the other.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "I'm laying in that attic.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "I know I left my brother, still in the ghetto, in that bunker with typhus.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "And I said to one guy that was with us, I can't leave him there.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "He said, child, he's probably-- if he's alive-- so let's take him out.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "He went, he took him out during the night.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "He brought him over.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    }
  ],
