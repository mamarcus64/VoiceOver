{
  "stem": "10397.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 352.9,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He say, talk some nonsense.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And then he said, did you hear?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "They found a Jewish woman in a basement in the village hiding.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So what did they do?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "He says, they called the Gestapo.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "They took her away to Brody.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And then he says, you know, people talk in the village that your landlady also is hiding a Jew.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "So the sergeant says, no, that's not possible.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "We are there eight hours a day.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "How can he hide himself?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "And I hear every word.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "Every word.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "The sergeant went away.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "He didn't sleep there.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "He slept somewhere else.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "Were you scared?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I gave a signal to my landlady, Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Huzar.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I say, I have to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I have to get out from here.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "So what do you mean you want to get out from here?",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I give her a report what they say.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "You know, a rumor goes around.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Pretty soon-- Ah.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Nonsense.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "So no because if you hide a Jew, you get killed and the Jew get killed.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Or your whole family gets killed and the Jew get killed.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "It happened.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I say, no, I'm going away.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Where are you going?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I'm going in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Say, look.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "She started not crying but she started to beg me, stay.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And never heard.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "She gets around.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "No, I don't hear anything.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I say, I'm going out because your life is in danger.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "6 o'clock in the evening it gets dark.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was March.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And there was a pump, a water pump by the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans walk around.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Here, there, you know, a solider.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I went down.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "After dinner, the sergeant went away and the corporal went away.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I sneaked through, you know, behind their house.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And I lied down behind the pump.",
      "word_count": 7
    }
  ],
