{
  "stem": "2938.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "His name was Hermann Levy.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "The Polish people lived around the cemetery-- in 20 feet of the cemetery.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "They looked out the windows and saw what's going on, and some of the people even recognized Mr.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Hermann Levy.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He was the most respectable business people in town.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "From the Polish people.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I were-- I were in the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I were in the camp, and after this happened, they segregated in the small camp, all the people.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Out of the 1,500 people, 900 went Huta Ludwikow to work, and Henrykow, and two camps in Kielce.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Me and my brothers went on a transport from Kielce, by truck, to Pionki, Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It was the largest manufacturing of ammunition in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "While going to Pionki by truck, several people jumped the trucks, and the police killed them.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "We stopped in a forest for a rest for 15 minutes.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I had a gun and a grenade in my pocket, so I took and hid it in the forest, under a tree.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I dig it in, in the soil.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I said to myself, this isn't the end-- Pionki-- I will escape, I will return and continue my life someplace else.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "When we arrived in Pionki, we went to work to manufacture ammunition.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Life was very, very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And very bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "My oldest brother worked in one part of the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "My other brother worked in another part of the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "My friend worked in a different section.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "I worked [PAUSES FOR 3 SECONDS] in a section where we used to make NC-- nitroglycerin.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Used to-- every two or three days, we used to have explosions.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Lots of people couldn't breathe from the nitroglycerin.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And myself, I saw that this is no future.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Long I'm not going to live here.",
      "word_count": 7
    }
  ],
