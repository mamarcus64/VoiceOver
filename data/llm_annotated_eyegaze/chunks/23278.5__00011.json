  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "It is a picture taken when she was a school girl and she left it with me after her stay with my grandparents, just before she left for Switzerland.",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "In 1943.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I brought it with me.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I kept it with my treasures.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of the grave of the mother of Rita Thalmann, born Helen Haussman.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "The grave was-- was changed.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The body was transported, you could say, or transferred from the potter's field where it had been laid during the war.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "After the war, Rita and her brother arranged to have a mother, their mother, buried properly.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And it is still like this in Dijon, France now.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish cemetery, which is the same as the other cemetery, just it is an annex, but I never went to that grave.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I wished it be happier memories, but there are no happy memories of that time.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
