{
  "stem": "7739.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "When got to the gypsy camp, the Zigeunerlager, on one side, on the right side as we walked into the camp-- there were gypsies, I mean, German-speaking gypsies, families of gypsies.",
      "word_count": 31
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we were assigned the left side of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The camp must have been approximately a kilometer long.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "There were barracks on either side and a road in between.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And past this, there were barbed wires and another camp like this and another camp like this.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "There were camps like this as far as your eye could see.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we-- on the way there, there was a Mr.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "She was a friend of my father's.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And he got sick, and he had to be more assisted to-- to-- to-- to that camp.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And I-- I still don't recall what happened with him.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I don't know-- he-- he's no more alive.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "He got-- was taken sick.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "When we got there, we were assembled in front of the barracks.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We weren't allowed to go in to-- we were told to line up according alphabetical order.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And we were given a tattoo, a number.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "At that point.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "This was late in the afternoon already.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I was given a number.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We lined up according to alphabetical order, like I said.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It's A19831.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And after this, we were given the rations.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We were given the-- I think it was a piece of bread and a-- a bowl, what you would call, with some hot broth or soup.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "This was quite welcome.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We haven't eaten for most of a week.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And then we were assigned in the barrack.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "The barracks, as far as I can recall, I don't think had any bunks.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "So we were standing there.",
      "word_count": 5
    }
  ],
