  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 35,
      "text": "I says, if they take me, I am finished.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 36,
      "text": "I got the anemia.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 37,
      "text": "And I says, I don't know what's going to be.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 38,
      "text": "When I came, they have to take me.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 39,
      "text": "I says, from doctor-- you know, doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 40,
      "text": "I don't feel so good today.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 41,
      "text": "But he was sure I have the menstruation.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 42,
      "text": "[PAUSES FOR 5 SECONDS] How up-- they didn't take me.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 43,
      "text": "The girls, they passed away.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 44,
      "text": "Not all the girls-- but the first girls, they couldn't take it.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 45,
      "text": "They took a half of blood from you.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 46,
      "text": "A liter.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "A German-- a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I was lucky I don't see him anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And-- and here was a--a nurse by him.",
      "word_count": 8
    }
  ],
