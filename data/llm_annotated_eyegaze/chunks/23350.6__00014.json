{
  "stem": "23350.6",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "When I arrived-- and when I let him know that I was arriving to Victoria, he came running like mad to Victoria.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "I had swollen eyes, crying that all my stuff is in Ostend.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "But he arranged it all and had it all- everything was given back.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "That means we had to go to, to-- from Ostend, it arrived to Dover.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "I mean, I arrived in Victoria, but the stuff arrived in Dover.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "And I had to go one day to Dover to claim all my things.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "And he came with me, because he could speak English.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "He told them I'm from the concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "My sister gave me all of this for the we-- they let me through with a lot [LAUGHS] because I was afraid to take a sewing machine.",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "Anyway, this was that.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And then when I got back, straightaway we got engaged.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "His mother made me really a nice engagement.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And then we got married the 7th of November.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I was, in 1948 in Germany, Pesach time.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "It was March, April.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And I got married the 7th of November.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was a really nice wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I mean, we didn't have music or, or you know?",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "But my mother-in-law made it really nice.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Most of the things were all baked by hand.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Because she was from Vienna, she could bake so beautiful.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Everybody was saying how wonderful everything was, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "This was more of a reception, not dinner, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "But beautifully prepared and done.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Everything was very, very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And we went away.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We could only afford to go away for two nights.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "To Brighton, we went.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "You know where we went?",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "To that hotel where it was bombed.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] What was it called?",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "In Brighton.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I've forgotten.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Grand Hotel.",
      "word_count": 2
    }
  ],
