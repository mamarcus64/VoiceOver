{
  "stem": "9415.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "They had bought some ammunition, some revolvers or some-- whatever you could on the [INAUDIBLE] on the other side, on the Polish side.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So they contacted the Polish side, and some stuff came in to some-- to be able to start the resistance.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They thought maybe by starting a resistant, maybe the outside world would do something.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We were not protected at all.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Could do nothing about it.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "The Germans came with heavy armory, and the result-- shooting on the buildings and put fires all over.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "As I said, they were coming through the building, and everybody was called go down, and they took the people out to the railroads, and they send them away, and marching the people to the railroad, and they took them away by the trains.",
      "word_count": 44
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we never heard of them.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "We have-- as I said, through the building-- we couldn't go out of the building for the eight days.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "After the eight days, the Germans came, and they said, everybody down.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And we came down, and they took us to the railroad.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Very simple.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And they took us to a concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "The first camp was Poniatow.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Poniatow.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "P-O-N-I-A-T-O-W.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We were there by a couple weeks only.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Then they took us out of this camp, to another camp, Dorohucha, D-O-R-O-H-U-C-H-A.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Dorohucha.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "There, we were working on the [? turf, ?] cutting [? turf, ?] so using it as coal for the building.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It was out and the winter comes, the wintertime, so you used this coal-- coal.",
      "word_count": 15
    }
  ],
