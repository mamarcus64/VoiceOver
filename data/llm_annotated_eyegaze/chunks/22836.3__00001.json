    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "They was good to us.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And we went.",
