    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They don't [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They see the German, Ukrainian, [? run ?] with the with the Polish people.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We was in between maybe a dozen Jewish people between that group.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Nobody ever mind.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Nobody knows us.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We was a couple.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They know us.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "We stick to them together.",
