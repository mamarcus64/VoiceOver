  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But when we decided to come to Australia, Stefan had two brothers here, and things in Poland were becoming unpleasant.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "In what way?",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the-- you know, the feeling about Jews was getting unpleasant.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And we decided-- and there was also a very great fear of war in Europe.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The Soviet Union was arming heavily.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And from a friend who was in the-- in some high position in the army, we heard of plans that, in case of war, Poland would become the area of total destruction, to allow the Western armies into the Soviet Union.",
      "word_count": 41
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we decided to come to Australia.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My mother was very unhappy about the decision.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She came with us.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "She wouldn't have stayed on her own.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "She'd come with us.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "What year was that?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "That was '62.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We were-- oh, we were trying for visas and passports for-- it's taken us four years to get all the documents.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We've started in '58.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We completed our papers and left in February '62.",
      "word_count": 9
    }
  ],
