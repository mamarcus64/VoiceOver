{
  "stem": "16503.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "If us and not take everybody-- if we could have finished the war in Theresienstadt, our family would have come out well.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The sanitary conditions were terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They had toilets, but they didn't run most of the time and were stuck, because there was not enough plumbing.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "There was lice.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "There were fleas.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "There was not-- you know, you could wash something in a-- in a sink.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "There was water.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "But there wasn't-- I mean, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I mean, it was like night and day.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "Coming even from a crowded apartment in Prague, which was overcrowded, it still had a huge impact of the filth.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "But again, on the outside of the streets and everything, it didn't look terrible terrible.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "There was food.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You went into a kitchen, which you were-- like you were allotted to go to.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And you had a pot.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And they would give you some soup or some kind of a mush.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And that's what you had.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And that started the shortage of the food.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "They gave you a piece of bread and so on and so forth.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes, people were working.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My mother was working in a laundry, which was outside the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And she was escorted with a group of women outside the ghetto into the laundry, which was very hard work.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I was working in a-- in a land-- like digging around the plants and potatoes and stuff like that.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And again, that was outside the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we would be-- a group of youngsters would be escorted outside the ghetto and brought home.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I was young and I was in a-- I was living with my mother only about three weeks in that particular accommodation.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "She stayed there.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But as a child, I wasn't allowed to.",
      "word_count": 8
    }
  ],
