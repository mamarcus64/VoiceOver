{
  "stem": "6076.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "I was busy with my girlfriends.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "But meantime, boys used to come in.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "They used to say they're taking them to the Polish army.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "They said goodbye to my parents.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "They wanted the blessing from my parents, from my father specially.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "And my mother allowed me to come home from Suchedniow from my sister, because they're talking about the war.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "Everybody was talking about the war, war, war.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "But, to me, war, war, war-- it seemed like, a-- like war.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "I knew it was horrible, the way they sounded.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "But then we heard about the Crystal Night what was doing in Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "How my father used to-- my mother used to cry for burning the Jewish law with the-- with the-- with the Hebrew-- with the, you know, Talmudic law what they were burning.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My father-- oh, god!",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He says, the world is all still.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Nobody is stopping them!",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "What will happen?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "What will happen?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It was so much fear for the people, especially for the Jewish people.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Because-- only for us.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Because we were talking between us.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Young men were [? taken ?] to the Polish army.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But this was just so fast.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "When I left my sister, she took me to the train with my brother-in-law Josef.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "She was holding her child on her arm.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I didn't think then that was-- this would be my last good bye to them and my last kiss in love to that little boy-- to that little child-- that I would not see them anymore.",
      "word_count": 36
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Would I think about it?",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But I left them.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We're going to stop now.",
      "word_count": 5
    }
  ],
