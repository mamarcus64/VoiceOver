{
  "stem": "26609.12",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They said, she's one of the Russian officer's wife, one of them, a wife who, whom they took and they tortured her so badly that she wanted to commit suicide and cut her veins and arteries.",
      "word_count": 36
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And no doctor attended, but she was still alive.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want her to die.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They want her to suffer only, without food, without anything.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And they locked her in there and that healed up, but that's what I have seen sticking out, like cut muscles sticking out.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And that-- and they-- and she got mad there because of all the treatment, or anything-- everything what happened to her.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "She got mentally ill.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "She was mental.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And they threw in to her, like myself, always another person.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Some survived, others not.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And she was very strong and very thin.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "What I have seen was not like a, like a-- a human being.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "She looked to me more like an animal.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "But she was kept there for-- for months and months.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "They didn't kill her.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "They want her to suffer or to-- to scare others.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And then they got me out.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And finally, when I came back, they all looked.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "They said, you, you survived her, others didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And then a day later-- get a headache-- a day later, they called me again.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Whoever was called in to the Chief of Gestapo-- that was another room-- from our room, a door into there where they tortured people.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "They called me in and I thought another torture.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "But no.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "Somehow, when I came in-- a prisoner comes in, they took-- take away everything from me.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "Not only they, they take out from the pockets, but they took the whole coat.",
      "word_count": 15
    }
  ],
