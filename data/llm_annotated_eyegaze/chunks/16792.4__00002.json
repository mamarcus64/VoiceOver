    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I was already higher.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I was already a kapo.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I was already higher.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I had two stripes already.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Before [NON-ENGLISH] is two stripes.",
