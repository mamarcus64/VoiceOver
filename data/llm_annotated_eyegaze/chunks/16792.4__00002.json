    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Fighting.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, not a soldier.",
