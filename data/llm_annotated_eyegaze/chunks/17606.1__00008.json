  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "It came-- that is that today they wanted to start to put, this is a Polish store.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "That started in 19-- late '30s, '37, '38.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I remember one episode.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "What-- when they started to put 'Polish Store,' my father put 'Polish Store.' And they ask him.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "He say, I am Pole.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I'm a Polish citizen.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I cannot put 'It's a German store.' A religion is-- is-- Jewish is a religion.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "However you slice it.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "Some say it's a nationality.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "Like I said I had in my documents, military documents, Polish citizen, nationality, Jews, religion, Moses belief.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "I Have a triple loyal.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "But this was already my nationalism started to play.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "If you want it this way, I'll have it-- you'll have it this way.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Finally, he took off the sign, my father.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I was left-- I went to the army.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Polish army.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Couldn't go to any other one.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "That was 1937.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "In 1937.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In the-- the-- for divisional-- for division-- at this school-- school for division of infantry.",
      "word_count": 15
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "In the-- for reserve officers in [POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "The town is [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Three to start.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "About close to-- close to 300.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And the only reason I got in is again my father's influence with the high ranking-- this-- members of Polish parliament and government.",
      "word_count": 23
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "That was main-- and I really wanted to go.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "Thus my father used his influence.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "There were three Jews admitted.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "The-- the course in the-- in that school for the officers was usually nine months.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
