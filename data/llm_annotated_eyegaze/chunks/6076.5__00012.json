{
  "stem": "6076.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "And I envied them so much.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "They were free to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Me, where are they going to take us?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I did see after walking and walking on that hot day a sign, [GERMAN].",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The gates opened for us.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "The SS men with their rifles-- the-- the-- the Lithuanians-- the Lithuanians were worse than the SS.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They were wearing dark uniforms with their rifles.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "But their smiles on their faces-- Jewish girls, proud of the beautiful Jewish girls, young, 16 to 18, perhaps 19.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "The oldest are 20-- ha, the cream from the-- from the Jewish people, yes?",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "The beautiful daughters, they're marching into that camp.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "How long will they last, they thought to themselves.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "How long would they last?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "They didn't last long.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was the lucky one and a few others who survived Skarzysko camp, I can tell you.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We're always talking about Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And Auschwitz, we all know in our heart how it was.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But Skarzysko-Kamienna it was like an Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "There were many thousands and thousands and thousands of people were killed.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "First of all, Skarzysko camp was divided in three sections, work [INAUDIBLE], work, [INAUDIBLE]-- I was the lucky one.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Work [INAUDIBLE] wasn't bad.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Work B, 'Bee'-- we say it in English 'Bee,' B.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "C was the worst.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "Whoever was in camp C had no hope, had no possibility to survive.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "If a handful of people survived Work C, they were the luckiest.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "It was just a miracle.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
