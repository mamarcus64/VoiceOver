  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And we started to get, to get in contact with inmates that were liberated from different camps.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "They came to us.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And, little by little, we went to their camps, using all kind of transportation that we could find.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And this is how we started to get together, and we started to talk and to hear things.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Some of them went back to, to their-- to our home towns or cities, to look for relatives or family members.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And then we started to hear things that no one, no one is alive and so on.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "So most of us decided to stay where we-- where we were and not to go back to Lodz.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "I never, I never went back to Lodz.",
      "word_count": 8
    }
  ],
