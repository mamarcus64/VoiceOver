{
  "stem": "2539.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "We got Paragraph 13, which meant that we were too rich to be tolerated in Lutsk and allowed to live in Lutsk.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We had to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "So my father was-- actually, they tried to deport my father to Siberia.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "He was on a truck going to the railway station.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "He jumped off the truck and went into hiding.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "He knocked out, I think, a tooth.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And he went to hiding somewhere under-- in a small village somewhere-- I don't know how many kilometers-- in the Olyka area.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "It would have been about, I don't know, 70 kilometers or so away from Lutsk.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1939.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The Russians.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And then, in 1940, we moved out.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "No, we left in 1940.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "We lived in that unit for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We lived in that unit for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And in fact, they put a Soviet-- [PAUSES FOR 3 SECONDS] Soviet-- [PAUSES FOR 3 SECONDS] employee for the Soviet government, some high-up family, a chap with his wife and a child, because we had three rooms, two bedrooms and a-- we had two bedrooms.",
      "word_count": 45
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I shared one with my sister and my parents had one, and a big sitting room.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So we had to give them one of our-- one of our bedrooms.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "The big bedroom we had to give to the Soviet family, so that my parents took over the sitting room as a bedroom and I and Lola stayed in our bedroom.",
      "word_count": 31
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So we'd never had a proper apartment already.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Since we left the house, we hadn't had an apartment to ourselves.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Another thing I remember from childhood-- from this area is that-- this era is when the Russians came in, a priest stayed with us for a while before they came in.",
      "word_count": 31
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And he hanged himself in our bathroom.",
      "word_count": 7
    }
  ],
