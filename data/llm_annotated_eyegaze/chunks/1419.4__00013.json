{
  "stem": "1419.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "You know, we could walk around.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "And he had a villa outside of the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "I went to his villa and his name was Metfess, Mr.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "Metfess, Herr Metfess.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "It was an Austrian company named [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "Anyways, I ask him, I said, Herr Metfess, I'm sorry.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "I beg you, we would like to go home to pick up some, some, some clothes and some food for the people.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "Could you let us go?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "He said, get out of here.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "Not allowed-- nobody is allowed to leave the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "So I came back to the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "It was already darkish, about 5 o'clock in the-- in the afternoon, the evening.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "And I told it to the guys, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "And I, I, I'm going to go to the Bahnhof, to the station, railroad station.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "I'm going to buy a ticket and go home by, by train.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 28,
      "text": "You were not allowed to, to do that.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 29,
      "text": "Jews were not allowed to go by train.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 30,
      "text": "Period.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So-- but I didn't have no, no star armband, no Jewish star.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I'm going to go, nobody's going to recognize me.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So I had another two friends, being on the same barrack, and they said let me go with you.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Let me just take a shave and I go with you.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And I went to buy the ticket and I bought three tickets.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And we went to-- into the train.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "The train was in the station because it was an end station.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "City of Zakopane is the end of the-- of the border of the-- of the Polish Czechoslovakian border.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we went in the train and we were waiting till the train will start to, to, to, to move to, to our destination, Nowy Targ, which take about maybe 25 minutes by train.",
      "word_count": 34
    }
  ],
