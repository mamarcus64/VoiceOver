    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Leibish-- ?] and-- and-- and-- [PAUSES FOR 4 SECONDS] Reuven Shmuel is Richard.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "This is it.",
