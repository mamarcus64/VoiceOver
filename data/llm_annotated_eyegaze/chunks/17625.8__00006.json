    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Four grandchildren, and-- and I hope more.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My grandchildren's, English?",
