    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "This English.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In Yiddish, is Zahava Eve.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "The other one is after their family.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I don't even remember what I told you.",
