    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Double F.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Here.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
