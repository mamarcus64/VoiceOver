{
  "stem": "9538.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "They shouted, [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Everybody out!",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I mean, the old people-- and we were frozen.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "People had their limbs frozen.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Later on, you know, they broke like matchsticks.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "They-- their fingers broke off like matchsticks, and their toes.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And gangrene set in.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And they died a terrible death-- and a stinking death because this gangrene, it smelled something horrendous.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "Anyways, this was our-- we were received like this in Riga.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "[GERMAN], everybody out, with truncheons and the dogs set up, up on us, and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And we had-- and it was cold.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "I mean, the cold-- I'm cold now.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "But, I mean, it's absolutely undescribable.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And you had this cold wind coming from Siberia.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "The men had-- you know, we had on our lashes, and-- I mean the frost, you saw the frost on our lashes and our eyebrows and on our hair.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "We were dressed like, like Muselmann, you know, all wrapped up in the little bits we still had.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "And we had to be in rows of six.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "We had to assemble in rows of six and march.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "It was icy.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "The grounds were icy.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "And we had to march towards the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "We had to just-- to assemble and to march.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "Always loud-hailers-- six rows of six, three rows of six.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My parents, they're with me, and the family Grunberg with their daughter, Gerda.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The six of us, we were in one row.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And the loud-hailers-- the SS were saying, the old people, and the sick people, and mothers with children, for those, we have provided [PAUSES FOR 4 SECONDS] wagons-- not wagons, like--",
      "word_count": 31
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "--lorries, warm lorries.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And you don't have to walk into the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Who is not able to, go on these lorries.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And these lorries never arrived.",
      "word_count": 5
    }
  ],
