{
  "stem": "27543.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "And I couldn't-- my first one was in Worcester, the wealthiest woman there.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "She says, George, you're not educated.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "But you're enough intelligence.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "And what I told you, try to-- try to look a little higher where you are.",
      "word_count": 16
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "Well, I told you I got no schooling.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "I told you that.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "And I'm very careful who I go out with, where I live.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 12,
      "text": "I love nice restaurants.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 13,
      "text": "And I love the theater.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 14,
      "text": "And I love-- traveling has gone by me.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 15,
      "text": "I don't think I can travel again.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 16,
      "text": "You imagine, go down to Florida, go down to Budapest, go down to Israel in nine months.",
      "word_count": 17
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Well, what I told you-- number one, be good to yourself.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "That's the most important thing in the world.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "You think I'm right or wrong?",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "If you're no good to yourself, you're no good to nobody.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "That's the way I feel.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I'm wrong.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "You're very welcome.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "On on the left-hand side is my father.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "His name was-- [INAUDIBLE] or Riechfeld.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Right next to him there is a-- name is [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "He's a Hungarian.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "He was a good friend of my father.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "Next is [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "He's a friend of my father.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "And this guy who's coming up, his name is [INAUDIBLE], Frank [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "His-- his son was my best friend.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 9,
      "text": "After that, I don't know what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 10,
      "text": "This-- this guy's a Polish guy, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 11,
      "text": "And this name is [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 12,
      "text": "He's a German.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "This was taken in Chicago, 1920, on Sedgwick Street, by Oscar Mayer.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Remember the factory down there on Sedgwick Street?",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Way down.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Mm.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] Go ahead.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "The left-hand side is Benji.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "He was, there, about a year and four months old, I think.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "Today he's 42.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "With him is Steven.",
      "word_count": 4
    }
  ],
