  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The Duke of Edinburgh came over here last year, but after 50 years to say it should-- to give them a bit of pleasure for themself before they die that they know they have misdone against us.",
      "word_count": 37
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Is that the way they came there?",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that's the way they came there.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "But there is no excuse.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "The whole world, everybody, every person in this world who lived at that moment when that started is guilty what happened to our people there.",
      "word_count": 25
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "They're guilty.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And now, even the Vatican, these priests, now excuse themself.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "My sister won't be back.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "My family won't be back.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "The rest of my peoples' family won't be back.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "But they are there-- they are there that excuse themselves.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "The past has done wrong in those years.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Now, now, now, is it?",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Now?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "But no, there is no-- the guilt is on them and they can't take it away from us.",
      "word_count": 18
    }
  ],
