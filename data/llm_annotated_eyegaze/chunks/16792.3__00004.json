  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "And she came, and she asked me if I am Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "I said yes.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "And she said she is also Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "And-- [PAUSES FOR 3 SECONDS] and we was talking, and we were start talking in Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And she asked me where-- what I-- what I did, what I do.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know who-- who she is.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And she said, you know what-- in Jewish, you know what?",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "You come with me to my house.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I said thank you.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I was going with this-- with this woman to the house.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I came to the house, she give me to eat food.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then she told me that she is Jewish, her husband is engineer, and the husband will be right home.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And, um-- and she liked to help Jewish people, [PAUSES FOR 3 SECONDS] because she is Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "[SOBS]",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And she give me to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And she was-- she was also working in [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "She-- she was a [NON-ENGLISH], this woman, a [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH] means you're working in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You know what a-- a [NON-ENGLISH] is?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But she write prescription-- if you have a prescription, you go to 'for-macy'-- Oh, 'farm-acy.'",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Pharmacy, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Sorry, I-- I'm speaking in Russian, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And uh, and then she said, if you want, I give you a job to work.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I said, I don't care where I work.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I [INAUDIBLE] the job.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "She said, you can sleep here in our house, and give me a special room.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And um, she talked over the phone, she talked to a friend of hers.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And the friend of her is a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "You know what [NON-ENGLISH] means?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "[NON-ENGLISH] is one of the top of the pharmacists, is a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And the [NON-ENGLISH] was the head from the-- from [NON-ENGLISH] number one.",
      "word_count": 12
    }
  ],
