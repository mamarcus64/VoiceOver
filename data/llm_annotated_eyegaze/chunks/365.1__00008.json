{
  "stem": "365.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "It was a kitchen with a coal-burning stove, which we used also in the winter and the second room you'd put in a cast iron store in the winter to heat it, with a pipe going out.",
      "word_count": 37
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Everything was burned with coal, Like I said, we came from coal mining town.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Where the villages outside were-- would have wood burning stoves, we burned coal.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And toilets were outside.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "Water was outside.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "There was no running water in those days in the Polish towns.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "It was just pumps outside that you had.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "It was already city water that we had, not wells.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "But there that was just the pump outside, which you pressed and put water.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "In the winter it used to be insulated, so the water wouldn't freeze.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "There was a bedroom, there were a couple of book cases.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] There three beds.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They were folding beds, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "We had 10 people.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Well, most the time, like oldest sisters worked out of town, or the neighboring town.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "So they had rooms there where they lived.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Most of the people liked to work the salespeople in stores.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] And the others stretched out on folding cots, sleeping in the kitchen.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "That was the life in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "It's not like here where every child has a room for itself.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "It's pretty well hard to understand it when you look from a standard of living that is centuries ahead of what it was in rural Poland.",
      "word_count": 26
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Fairly good.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Satisfactory I would say.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Not a high standard, but satisfactory.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "I had clothes on my back.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I didn't go hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "I went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "That was-- we were satisfied.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Our next door neighbor-- well-to-do.",
      "word_count": 5
    }
  ],
