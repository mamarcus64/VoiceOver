{
  "stem": "13690.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Being that I wanted to go to Philadelphia, the person who waited for me was from the HIAS.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And he said, Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Zborowski, you're going to Baltimore.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I said, I'm not going to Baltimore.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "I'm going to Philadelphia.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "He said, no, no, no, no.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "You have to go to, to-- I said, look, don't start up with me.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "I'm a very nervous kid.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "I'm not going to Baltimore.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "I'm going to Philadelphia.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "You have to.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I said, if you have to, if you could change, then I want to change to New York.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Why do you want to go to New York?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "All the refugees, all the foreigners, or whatever description I have.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I'm very proud to say that I'm a refugee, of course.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "People, my friends, I keep on saying, being here in the States for 40 whatever years, you still consider yourself-- I said, that's the way I came.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I came as a refugee boy.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I mean, it's nothing you can do about it.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "So anyhow, I said, if you could change to Baltimore, you could change to New York.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "So why do you want to stay in New York?",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "I said, because I have somebody here in New York.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Anyhow, to make this a little bit shorter, she gave me the permission to stay in New York, but the provision that I will not ask for any assistance and any benefits from the organization, because I refused to go to the place, the destination, to Baltimore.",
      "word_count": 47
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I said, I do not need anything, and thank God I did not need anything.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And it's a matter of fact, I paid back my passage, which I got through the organization.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I paid everything 10 times over for the graciousness of bringing me back, bringing me to the United States.",
      "word_count": 19
    }
  ],
