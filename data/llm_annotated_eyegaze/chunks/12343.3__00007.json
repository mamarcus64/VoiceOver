  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Put with the-- I think now, it wasn't fall.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It was cold, very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They transferred you.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know myself.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know if I'm going to work.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I figure I'm going to the gas chamber.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They took us to a barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes, oh, well, the clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], how you call, the stripes pattern.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, striped.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, striped.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "That's what they give you, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Holland has-- how you call it?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Like ladies wear sometimes shoes?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, wooden clogs, that's it.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Holland's.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "That's what's happened.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Often over there, they took you all the time, a lot of time to [NON-ENGLISH] out, for work, the ruins, after the bomb.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "The ruins, I was working over there.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "Out.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Because I still-- no, you-- I was afraid you can't take nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "If you take nothing, you go in, they take you right over there to the gas chamber over there, right away.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "I was afraid to take nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "I don't take.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I was careful with this.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "I think, maybe I'm going to get over.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "[INAUDIBLE] kilometers.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "That's happened same when I was in Buchenwald.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "They make a selection.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "They take out of other places to work.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "Then same, a father and a brother.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "Father and a son with others.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 20,
      "text": "And they take my brother last to take my place.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 21,
      "text": "But they take me [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 22,
      "text": "Their place was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 23,
      "text": "And father, someplace else, and son, someplace else.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 24,
      "text": "Then the father asked me, maybe if I want to go with them, and he want to go to my place.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 25,
      "text": "I said, oh, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 26,
      "text": "That's my luck.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 27,
      "text": "Mine.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 28,
      "text": "My [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 29,
      "text": "If I die, I die.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 30,
      "text": "If I live, I live.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 31,
      "text": "I don't change nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 32,
      "text": "That is my [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 33,
      "text": "[NON-ENGLISH] is gone, everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 34,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 35,
      "text": "I was lucky.",
      "word_count": 3
    }
  ],
