{
  "stem": "3097.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "So we stand behind big trees there, and I saw three people coming with the guns, like that.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "They go with the guns like this.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Rifles.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And one guy-- two stand by the entrance of the bunker, and one guy goes in inside.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] So I knew that something-- they want to do something.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "So I looked a little bit more, and probably they noticed me-- one.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And he shot me right here.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "Right by the heart.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I had some documents here.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "Maybe this deflected a little bit the bullet-- and broke my rib.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "I started to cough.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "But I have to come back-- tell you about the grenade.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "I had a grenade in my hand.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "Where did you get it?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I threw the grenade.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And everything got quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "If I killed them, if I didn't kill him, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We started to run, and we survived.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The grenade I got that way.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We are sitting in the forest, one afternoon-- or it was late in the afternoon.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And somebody surrounds us.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "One of the men says, grenade.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Grenade.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "They threw a grenade.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And they-- one guy comes to me right away with a submachine gun.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "He had a tattoo here of a Polish bird-- you know, the national bird-- the eagle.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "He had a WP-- means Walczaca Polska-- the Fighting Poland, you see?",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And he knew about me.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "He said, where's your gun?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "He saw my gun here.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "He took the gun.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "Where are the bullets?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "I got 35 bullets, already.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "They threw the bullets from a plane, and we found one of those magazines with nine-millimeters bullets.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "He took away from me.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He took me.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The rest dispersed.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "He took me.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "He took another three-- three guys.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    }
  ],
