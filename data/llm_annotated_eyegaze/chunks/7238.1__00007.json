  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And would you tell us about what happened in your town then, November 9th?",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "First, on November 9th, the well-known Kristallnacht, this was the first step to destroy the Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "It was a cold, rainy morning.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "We wrote up-- we woke up in panic-- all around us flames, fires.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "We ran to the backyard and stood in silence.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "Soon, we found out the truth.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "All homes of worship, gone up in flames.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "About how many synagogues were there in your town?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I hardly can count it.",
      "word_count": 5
    }
  ],
