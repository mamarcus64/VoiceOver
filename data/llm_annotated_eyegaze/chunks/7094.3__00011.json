{
  "stem": "7094.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I know it sounds, uh, very-- uh, I always-- I sound controversial when I bear witness to the situation-- that not all German knew what was going on.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "They were all pro-Hitler.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "They were all patriotic.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "They were all very disciplined.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "They were all obedient.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "But the things which were done were done by a very small group which were trained to do it.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "All Germans, uh, followed the instruction.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "You know, it started by all kinds of gradually, gradually, uh, indoctrinating them.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "They all had the herrenvolk mentality.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "They all believed in their thousand-year Reich.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "They were all hoping that I will-- I mean, her preoccupation was that after the war I'll stay on, because I was a good domestic.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "I mean, she-- they all expected the East Slavian working for them, and they'll manage, and they'll be-- this is true.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "But also is true that they didn't know the extremities.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "They all-- when they were talking, talking about Jews being resettled back where they came from.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "It's a very controversial point, but they didn't-- they-- The same man, next door, who lived, who was an SS man-- he came home.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "He never talked about it.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "They were very, very disciplined.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "They never talked about it.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "He was a very nice neighbor.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "He was a very good father.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "He was a good husband.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "You know, there was a sort of split personality.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "They were not, uh-- This family, for example-- I'll just give you an example.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "They had a modern television-- a wireless, with three loudspeakers.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "They could have called any international station they wanted to.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "But they were disciplined.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "They were obedient.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "It was verboten.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 40,
      "text": "It was forbidden to listen to a foreign station.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 41,
      "text": "As a domestic, I would know what was going on.",
      "word_count": 10
    }
  ],
