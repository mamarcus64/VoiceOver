{
  "stem": "11771.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "She took me 1 kilometer, [INAUDIBLE], on-- on-- on horse and wagon with hay.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "Under the hay, she covered me. 1 kilometer, I'm coming into Radun [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "I'm going in, into the Judenrat, to tell them what happened with the Ejszyszki Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "I'm going to tell them what happened when I was-- Wednesday-- in the group, in the last group.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "I took off the bandage.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "I show them what's happened.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "I got shot.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And what's happened to the rest of them?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "It's only the women [INAUDIBLE], probably they're going to kill them.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They killed them, too.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I knew already.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But [INAUDIBLE] went to Ejszyszki, went to [INAUDIBLE] for Radun, when she went back-- through Ejszyszki back to here-- to see what's happened with the women.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The women was already, all day Thursday, in execution.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And a couple-- a couple groups, remain on Friday.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And that was the end of the all women, Thursday and Friday.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I was with the last group on Wednesday night.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I came to the Judenrat.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "First, to the Judenrat, I got in.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I say what's happened.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I tell them the story, what happened.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I ran away from the graves.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "[SIGHS] It's very sad to tell.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "But I got to tell the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "The head of the Judenrat from Radun, Noach Delinksy-- his name was Noach Delinksy-- stood up [? and ?] [? he ?] [? says, ?] And he give me a [INAUDIBLE] in my face.",
      "word_count": 34
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] And he says, we don't like to see you here and to panic all the community.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "I don't want you, to see you anymore here.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "Get lost.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] [SIGHS] I got lost.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "I have-- I have no choice.",
      "word_count": 6
    }
  ],
