  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "But when that air hit us, somehow slowly he reached down, pulled us out-- the kids first and then-- and we started to come to.",
      "word_count": 25
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "Another-- another three minutes and that's it.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We passed out, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "So that-- and that-- that was the closest thing we came.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And what?",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I think another two months, a month and a half to liberation after that incident.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We were up on top.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Most the time we were up on top.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And there's all kinds of room.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "We could go dancing there.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
