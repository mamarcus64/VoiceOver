{
  "stem": "6503.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "We had nothing that showed that people lived there no more.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We lived in the hiding place at night.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I slept inside there.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "My husband was sleeping outside the hiding place.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "So when something would have happened, we both would have gone inside and closed the door.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "But we had nothing left no more, like a bed or a blanket or anything.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "You couldn't see that people lived there.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I will never forget that. 380 [?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Kapstadt, ?] in Amsterdam, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We were right near the Amstel, near the water.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Two minutes away from the Jewish district, where later was the [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Where the [NON-ENGLISH] was.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Amsterdam has a lot of water, and a lot of bridges.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "All the bridges around the Jewish district were pulled up, so Jewish could not go out no more.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "They were automatic locked inside there, where they were picked up.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We heard the screaming, we heard the screaming, and we heard the commotion, what's going on.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And we lived right a half a block away from it.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "We couldn't see anything, because we couldn't open the windows, but we listened to what was going on.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there were.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My husband, I think, told you already.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "The SS came to the door.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The woman was at the time in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She had a second baby, that little boy.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "The first one was given away to friends, because so-called nobody was in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "So we couldn't take care of her, because we were alone.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "She was at the time in the hospital when they knocked on the door.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "He was at work.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "But we had underneath of us, on the second floor, a woman, who was a Catholic.",
      "word_count": 16
    }
  ],
