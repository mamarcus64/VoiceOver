  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I got-- now, that was on the road a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We-- we meet.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We all together, you understand?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "You see.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I don't know that I don't know three friends.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I got good friends when I was in school, in-- in-- in cheder, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I went-- I have the pictures tucked in the-- and we run away.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "One got killed on the road.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "They left home.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They stayed home.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother, you forced me, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Go [?",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Shmil, ?] go.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Go, go, go.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I run.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And after, let me tell you, I won't go back.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I-- I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I was about 17 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I was crying, and I won't go back.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "I-- I-- I told myself, I-- I live.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "My mother was sick, you know, she-- very nerves with everything, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And I won't go back.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "I couldn't go back no more.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "Was fire all over, you understand.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And I-- we went.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "We went till we was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "I remember after.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "Oh, it was Janow [INAUDIBLE]-- Janow, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And after Krasnik, Krasnik I got family.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "They give me a-- a few dollars.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "I should go away.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "And they went too, other places.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "And when I went to [INAUDIBLE] Ukraine, [INAUDIBLE], I see it's no planes, no nothing, quiet.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "And I don't know what this is.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I walk.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We walking.",
