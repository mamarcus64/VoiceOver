{
  "stem": "9215.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "My two brothers, the older ones, they worked by the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "They came home every night to sleep, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "By my mother, there with the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Not only ma.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "You know, there was about 15, 16 people in a-- in the room.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Because the other people whose-- but for burned-- for burned the house-- they didn't know where to go.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "They-- they put the-- the German put all the people in the-- in the-- in the same-- in the house of us in the ghetto-- 15, 20 people in a room.",
      "word_count": 31
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Don't ask.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In my house?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "It was about 15 or 16.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Who remembers?",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "You sleep wherever we could, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We slept.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "A-- a year.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto started, I think, in '41.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "It was after the Jewish holidays-- after all the Jewish holidays-- something like this, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "--yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean somebody take me?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "We've been there.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "We'd lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "They called it a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They closed the street, and that's all.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't go nowhere.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "If I-- I can leave, but they-- they would shot me when they catch me.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They told us right away.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They told us the ghetto, and that's all.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Here, you're gonna stay.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "A street?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "The street was a kind of street.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We could go only in the ghetto, to the neighbors, to, you know, but not-- and then farther there was the Ukrainian street.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "We couldn't go there.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "We didn't get.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "They gave us, every day, a piece of bread for-- for a person-- a little piece, a little piece.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "It was-- I'll tell you that it wasn't bread-- 1/2 maybe it was dairy-- sand or something.",
      "word_count": 17
    }
  ],
