  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And my father had no knowledge whatsoever of being Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "So he completely ignored everything.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And they couldn't get along in that respect-- with my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My father bought in a-- a tray for food.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And he wanted to put it in the Frigidaire.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And he was hollering that I don't want it in my Frigidaire.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "I said, so what should I do between the two of you?",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "So I was a-- a bit-- a bit in a fix.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Mama was running the household for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And my father thought that he pays the mortgage on the house since he paid me $55 once a month.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "This was for food and for the rent-- he contributed.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "He thought he pays the whole mortgage.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And bad feelings came of it account of we didn't agree on a lot of things.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "So one day, he got mad at me account of some keys, and moved out.",
      "word_count": 15
    }
  ],
