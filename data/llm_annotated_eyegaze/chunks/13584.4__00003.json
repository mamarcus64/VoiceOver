{
  "stem": "13584.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "Well, [PAUSES FOR 4 SECONDS] right before we left Poland, in-- in-- after the Six-Day War when I got married, we got already-- our son was born.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And it was in '68-- you know, in '68, when they started anti-Semitic riots in Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "This, probably, my wife will be able speak-- to tell you much better than I do.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "A woman walked in, are you Jewish?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And there's the Jewish child.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "This bastard should not be on our soil.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And she threw my boy from-- from the carriage.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "My wife was-- was holding him, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Did anything happen to your family about speaking out in communist Poland?",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Anything like that?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my brother.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My brother was sitting in a-- in a-- in a coffee shop with his friends.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "There were five friends.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he was talking political jokes-- jokes, politically jokes, not against Jews, not against Poland, just political jokes.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And one of his friends, not a [INAUDIBLE], a Jew, was probably working for-- for the secret service.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And he probably delivered.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Because, otherwise, how in the world all of these five boys, sort of, were arrested, kept in separate cellars for 72 hours in a-- in a cold, wet cellar-- kept.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They were arrested.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They were just-- just the-- they came to my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My daddy was not alive anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They came to my mother in '68 when my son-- when my brother was arrested, the youngest brother was arrested.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "They turned the apartment upside down.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They were looking for some evidence of spying, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And finally, they found.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "They found an envelope which the cousin-- my father's cousin world to my father in 1949.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "A-ha, you have somebody overseas there, in the West.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Do you have any contacts?",
      "word_count": 5
    }
  ],
