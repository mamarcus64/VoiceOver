  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "Basically, you arrived and you went to the gas chamber and you went to the crematorium, and that was it.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And it was a very small camp.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "It was just a pure killing camp.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "It was not like Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "Big, and lots of barracks, nobody stayed.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "They had a small team of people who helped with the gassing and the bodies and all that.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "There was hardly and barracks in Treblinka and Sobibor.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Found out about that after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So that was the four grandparents, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know that in Westerbork, just that they had all been deported to the East for resettlement.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I think perhaps I'll stop at that point.",
      "word_count": 8
    }
  ],
