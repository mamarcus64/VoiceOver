  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "Now, it wasn't weeks before my flight that two other Military C54s bound from Westover to Paris loaded with GIs had crashed, one in Newfoundland and one in the Azores.",
      "word_count": 30
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And we were very aware of that.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "We were flight three of that infamous trio of bad luck accidents.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And all those GIs on both flights were killed.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Everybody on those planes was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "So we landed in Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, you know, October 31 was the Halloween party.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "That's all-- or-- or, 30-- I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We landed in Paris, I presume, maybe about November 2.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And we were billeted-- I was billeted in the hotel around the Champs-Elysees somewhere with others, because we had to wait for the continuation of our trip on a military C-- a military small plane, C47.",
      "word_count": 36
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "C47.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And it was about two-- two days before.",
      "word_count": 8
    }
  ],
