  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He said, but nowadays, when you will be speaking with Germans, you will get the impression, Mr.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Peters, that there were no Nazis in Germany, no National Socialists in Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "But there must have been 180 million Jews in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I say, why 180 million Jews, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Kurtz?",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He said, because every German saved the lives of three Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Since there were 60 million Germans times three, it gives you 180 million Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Of course, there were only about 40,000 Jews in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But he wanted to convey to me how the Germans changed from one moment to the next.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "At least on the outside.",
      "word_count": 5
    }
  ],
