{
  "stem": "26609.10",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "But I hid there.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Another one-- went out.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "This one didn't know that I was before.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "So he went out.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "He went in.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "I didn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And he finished and went out.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "As he went out, I could hear children coming.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "So it was a relief.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And as he went out, I went up to them quickly.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "I said, I'm [?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "Christina's ?] sister.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "Come, come, quick, quick.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "Dragged me into there-- came into that place.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "Awful, terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "All clothing-- heaps on the wall-- on the floor.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "The floors, there were no boards, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 30,
      "text": "One bed was here and a bed there.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And she said, all right, but where's your child?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "In hospital.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That was-- I was lucky that it happened that I had to leave her to the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "So I came to her without the child.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And she took me in.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Took me in, and she said, look, I go to the market every day.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It's not a market like here.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "It's a little place.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It was a few benches.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I go to the market every day.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I come back late.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I haven't got food here, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And you haven't got either.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "How will you live here?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I said, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "You have water here?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I lived on water.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how I survived.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "For years-- years-- I didn't eat, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I was thin like a skeleton.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "That's another thing.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "In the morning, she left.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "But she came home earlier and cooked a bit of black coffee.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "She gave me too.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Her children ate there with her.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "She brought them some sausage and bread she had.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "But she didn't bring home bread.",
      "word_count": 6
    }
  ],
