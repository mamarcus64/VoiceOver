  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I have to admit that the local population, Jewish population and not so Jewish population, and particular Jewish population, didn't welcome me so much when I arrived here.",
      "word_count": 28
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And it took a long time to create ties, friendly ties with people.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "But this didn't bother me too much.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The first time I returned to Iasi was when I was living in Bucharest after graduation after each the 1958 application for immigration to Israel when I was sent to Iasi in way of punishment.",
      "word_count": 35
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So I came back to Iasi for the first time after we left during the war as sort of a punished person.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was difficult.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I avoided to go in the area where we were marched to death.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't do this.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I lived in a totally different area, and I was busy day and night on the construction site.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I was doing the things which didn't bring me the memories of the place.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I survived.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I think that I didn't feel too much about what the past brought to me.",
      "word_count": 15
    }
  ],
