{
  "stem": "10588.8",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "All of a-- all of a sudden, the Auschwitz, the kapos with the-- with the commandments, with the-- all the things flash before my husband-- my-- my eyes.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I very gently ask her, why not?",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She said, there are still dishes here.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I said, there will always be dishes here.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I just walked out.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "A few minutes later, the good manager, as I called her-- I don't even know her name-- either this one or this.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "But I-- she was the manager from the general hospital, for-- it was for tuberculosis children, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Comes in.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And she says to me, Itka, I heard what's happened.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I know you're right.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "But do it for me.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Go back.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I was torn.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "My head told me, go, because after all, you're working here, and she's nice to you and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "My heart says no.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "The beginning is the most important.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "If I give in now, then I am again a slave.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Even though I'm free.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I cannot do it to myself.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And I started to go with her.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "First I went with her.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "Halfway.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "The kitchen was on top.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "We had the-- the lower level, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "So I going.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "I felt, no, I can't do this.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And I started to run.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "Tears were pressing to my eyes.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And then I know-- I say, I cannot do it.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "When I came to the room, again the teaching of my family helped me.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I was taught never make a long way serious decision when you're under emotional strain.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So I talk to Sovek.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Calmly I said, suppose I left already.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Where will I go?",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "At least here, I have a roof over my head.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I know I'm going to get a meal.",
      "word_count": 8
    }
  ],
