{
  "stem": "11641.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And my mother's name older is Moehler, at that time, many names they have.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And she came from a Steiner family.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "So I-- I go up the line, and the guy wanted to hit me.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I said, wait, Steiner.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I said, hold it, hold-- I said, I think that we are related.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We are related?",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "You and I?",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "I says, maybe.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "I said, do you come from Bielsko?",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "He said, yeah, what's your business?",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "I says, I think that my-- you and my mother are cousins.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "He said, where do you come-- what's your mother's name?",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "I said, Sara, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "He said, [NON-ENGLISH], where do you come from?",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "I said, Chorzow.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 12,
      "text": "Are you Sarah's son?",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 13,
      "text": "I says, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 14,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 15,
      "text": "What do you mean, what am I doing here?",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 16,
      "text": "Look at me, I'm not waiting for a bus.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 17,
      "text": "Of course, I'm doing here-- I want to go to-- out of here.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 18,
      "text": "I said, I'm from Bochnia Barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "He says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "So he said, come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I said, look, I have a friend of mine and we're going together.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "He grabbed us both, put in front of the line.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "This how I end up with Schindler.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "So you never can tell, you see, how things turn out.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "That's how I ended up by Schindler, eventually.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "When I was by Schindler, I was working--",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I was taken to Schindler.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Right then and there.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "We were assigned to--",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "To outside.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Schindler has his barracks outside the camp, in Amalia.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Separate barracks.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "We were staying there.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "We were staying there, we' had a sign over there.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Must have been the end of summer '43, or beginning of fall '43.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember the exact date.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "I knew only it was a good day at that time.",
      "word_count": 11
    }
  ],
