  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I was staying next to my baby, and giving her water, because she was unconscious.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "The temperature was so high.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "If she would have died then, she wouldn't have had to go to the-- [PAUSES FOR 3 SECONDS] to the gas chambers, you know?",
      "word_count": 24
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "I wanted to save my child.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] So I'm sorry.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "I just can't talk about it.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "We're going to take a break now and change the tape.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
