{
  "stem": "293.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 19.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I never come back home.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Sometime I sneak home during the day to see my parents or my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My father was working in this particular time because they took all the businesses away with Jewish [INAUDIBLE] as one of the work at there-- volunteer.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Not volunteer.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "They get paid a little bit, but not too much.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He didn't make too much money.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My money was-- my mother was the biggest supporter of--",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They came in, in-- about in October time with the order that every Jew over 13 years of age has to carry the armband.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Now, I carried the armband when I considered it's important to carry.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Mostly I keep it in the pocket, or I didn't wear it when I was out.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I have a--",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather then was not alive.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My grandmother was alive from- from my father's side.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "From my mother's side, both parents were dead already.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But the family was intact.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "This means that his brother and sister and a cousin and uncle, family-- close to 100 members of the family was a tremendous-- from both sides-- was a tremendous family.",
      "word_count": 30
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I was working till the gymnasium was closed.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "This means till the 1st of January, 1940.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Then they closed the school.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "So then you have to do something.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So because I was very well known between the Jewish circle as a teacher, and my students' parents-- some of them were very wealthy-- when I-- for example-- I give a small example.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "One of my student's father has an import of the velour hats.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "In Poland, velour hats were expensive, like about $5 in this time.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Like 35 zloty or 40 zloty, which was quite a bit of of money at this time.",
      "word_count": 17
    }
  ],
