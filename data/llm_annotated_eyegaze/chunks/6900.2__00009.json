{
  "stem": "6900.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "When we were in Belsen, they used to say the German people never knew anything about it?",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "That was a big lie.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Because across the road were houses.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "They must've known.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "We only saw civilian population when we were in Hamburg, when they-- they were losing the war, the Germans.",
      "word_count": 19
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Up.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That's what I meant before.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I shouldn't have said Westerbork.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "That's when we saw the people living in houses across the road, and we were in the camp.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In Belsen?",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "The SS.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The SS.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "The SS.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, that Irma Grese, she was hung after the war, she was there.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And I don't-- that was the one I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "She was worse than some of the men.",
      "word_count": 8
    }
  ],
