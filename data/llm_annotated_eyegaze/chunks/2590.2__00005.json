{
  "stem": "2590.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "It's easy to say, but you know, I didn't know if she'll come, if she'll come with police.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Maybe she-- maybe she was one of the mean ones.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Sure enough, she came by herself.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And she told me I should follow her.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And I came to that village.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And she had a little house, a little farm.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "She had two cows.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "She had four children.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "One daughter was my age-- six years older.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "One was my age, one was six years older.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And the six years older was retarded.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "Anyway, she-- she gave me some food, and she gave me instructions that I should get up in the morning, and I should milk the cows.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And do this, and do this and do this.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "All night I couldn't fall asleep, but you know, when you're young, nature took care.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "And I fell asleep.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And she woke me up in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "She said, you know, you have to milk the cows.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I am leaving.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "And I started to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "Not only I knew how to-- to-- to milk cows, but I didn't-- I was afraid even to go near a cow.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "I was a city girl.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And cows, if they're not milked after several hours, you know, they fill up with milk.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "And it's very painful.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "And they started to make so much noise-- moo.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "And they woke up the whole village.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "And this young Pole came in.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "He introduced himself.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "He said, he is the brother of this woman, Francisca [NON-ENGLISH] is the name of that woman.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "And he took one look at me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "And he said, do not be afraid.",
      "word_count": 7
    }
  ],
