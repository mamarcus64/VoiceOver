{
  "stem": "18294.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "So he had to make another room, he make a toilet, he make a shower, he built-- built completely our own apartment, a two-bed-- two bed-- a one-bedroom apartment.",
      "word_count": 29
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So it was a lounge, and there was like a bedroom, and a little kitchen, a shower, and a toilet.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "It was something out-- out of the world.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "It was something beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And-- and then we was living there about a couple years.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And then we were shifting in a new home.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And when we're staying one year, in the new home, my cousin from Canada come visit us.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And she said to us, no.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You have-- you have such two golden hands.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "You're sitting here?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Come to Canada.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "You make a fortune.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "She said, I'm going back.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I'm going to make some papers for you.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "You sell the flat.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And we had 10 [INAUDIBLE], so one from the richest people in Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I had my own apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I had a fridge, when nobody has only of-- of ice to keep.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I had a fridge.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I have built furniture.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I had a washing machine.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I had everything.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "It was so good, I never want to go out.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Anyway, I didn't want to go out from Vilna when I did nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "So from-- from Israel, my husband wanted to go.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "He was all the time in the army then, every four weeks, they schlepped him that.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "He said, I went through so much now.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "All right, I can go to Canada.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "He's easy.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I'll go.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So we sold everything, and we were sitting in-- in [INAUDIBLE], with my cousin in a room.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We're waiting for the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Suddenly come a letter it's [INAUDIBLE] make agreement with Canada that doesn't let in Israelis.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So we stay with nothing.",
      "word_count": 5
    }
  ],
