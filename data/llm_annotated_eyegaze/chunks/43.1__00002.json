{
  "stem": "43.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "A Judenrat-- the Judenrat came and-- and took us all to the-- took us-- they told us they want to talk something to us about the post office.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But they didn't took us to the post office.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I was with the three children.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And my husband was working.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "So they took them from the work.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And they took us to the forest over there.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I was-- the woman with the children he took her-- left.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And the men ride.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] And we were standing this side and a-- and in the left side.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And the men was in the-- in the-- in the right side.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And they start make-- to-- to do the graves.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "[NON-ENGLISH]-- the graves.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Then-- but before, they took out all my-- my brother-in-law's-- my father-in-law-- they got the tallisim with that film with them, they took.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "So they took the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And they-- they [NON-ENGLISH] everything and was laughing from-- from our-- of our religion, from everything, they was laughing.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And then he told them to-- to take out the-- the-- to take out the-- the-- the [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Some words is-- all the-- the [NON-ENGLISH]-- naked.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And he start them one after one.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And one he got.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Even a boy from 13 years was belonging to father, and he must be killed.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And-- and this.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And later when they killed all of them.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "So they start to-- and to take us back to the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "The woman with the children and all of us come back to the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "But none of them come back there.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "So my-- my brother-in-law's-- my-- my husband-- every-- everybody was.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I don't cry.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I don't cry.",
      "word_count": 3
    }
  ],
