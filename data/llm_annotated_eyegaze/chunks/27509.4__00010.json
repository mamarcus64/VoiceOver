  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Klematynowski, the man whom I saved, the-- the leader of the k-- told me when I sat in his very spacious cabinet that when he goes to-- when he goes now to-- to the-- to the locales where he was prominent only a short few weeks ago and everybody sought his friendship and his advice, suddenly, he said, everybody's shunning him.",
      "word_count": 61
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Nobody's coming near him.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Nobody wants to have anything to do with him because he's-- he's-- he's a-- a Jewish Zionist leader.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not really.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Well, there were such momentary-- momentary things so that, you know, parents want to protect their children in the last minute, but I was not doing the actual activities.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I was not called into the army because I was not quite 21.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "By the time that they-- they looked for younger people, it was all over, and-- and I was not really in.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "But-- but the whole thing took three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "The-- the whole campaign took three weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Poland fell to pieces in three weeks. 1/3 of it was taken over by Russians, 2/3 taken by the Germans, so that was it.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "It was just carved up and cut-and-dried.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Tape four.",
      "word_count": 2
    }
  ],
