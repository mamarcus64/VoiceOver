{
  "stem": "18294.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.7,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "It is our God that's helped me through go such things?",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "Because my mother used to say, goodness me, how can you live?",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "You're so skinny, your bones will fall to pieces, so skinny I was.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "And the girls that survived, were they bigger?",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "Where they stronger?",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "Were they smaller?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The girls who-- who survived was smaller girls like me, most of them.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Because the healthy one couldn't take the hunger.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They was very strong, and they eat it.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They needed it.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "We passed by a lot of them, the young-- like we went-- when I-- when we come to it.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "It was 2,000 young woman that went.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "But the liberation might be 200.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "There was a toilet.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "There was a toilet.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And there was-- what shall I tell you?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "This is like-- like a-- like you put the spare thing on it-- on it.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "This was long one, and there was a tap with cold water.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "You could wash yourself with the cold water.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "So in the nighttime, you cover with your blanket, took everything out, you wash under the cold water, keep them under the mattress.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And in the morning, we wear it.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "There was 1, 2, 3 4-- four rows like that, you know, one under another.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And what can I describe?",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "It was just-- I was sleeping together with my cousin on the same-- on the same piece of metal that was there, made from nothing.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And there was girls where they was very energetic in-- in-- in-- in the concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "They used to have contact with the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "They couldn't care less, if they have a good-- if they have a good time and had something to eat, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Not everybody was so stupid, like me.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't care less.",
      "word_count": 4
    }
  ],
