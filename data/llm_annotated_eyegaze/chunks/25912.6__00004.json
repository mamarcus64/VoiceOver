{
  "stem": "25912.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "She's looked up to herself for so long.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "If she says she's going to do it, she's going to do it.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 5 SECONDS] And the school were wonderful.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "Throughout the Easter holidays, a retired headmistress, friend of Ms.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "Bishop, took me for English every day.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "Ms.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "Bishop herself took me between lessons for English literature.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "All the other teachers were helping me.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "And I took my school certificate in the summer.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "I could probably show you the note-- my result note from Ms.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 29,
      "text": "Bishop.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 30,
      "text": "I passed.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 31,
      "text": "I got distinction in Polish, which, it may sound easy, but it wasn't.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 32,
      "text": "Because I had to translate into English a thirteenth-century Polish hymn.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 33,
      "text": "My English wasn't up to it.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "My Polish was fine.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "But it was the English, of course-- absolute hell, trying to think of the right words.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "But I got distinction in that.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "I got a credit in French.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "I passed-- I got a credit in English.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 39,
      "text": "I passed in English literature.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 40,
      "text": "I passed in maths.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 41,
      "text": "I think I passed in geography.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 42,
      "text": "I failed physics and biology, but I got exemption from matriculation.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 43,
      "text": "And by that time, we were talking about what I was going to do.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 44,
      "text": "My father really wanted me to do something which is international, like pharmacy.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 45,
      "text": "But without chemistry and so on, that wasn't an option.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 46,
      "text": "And I wanted to do something with languages.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 47,
      "text": "So we compromised that I would try and do a B-com degree, which included a foreign language.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 48,
      "text": "It was going to be French.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 49,
      "text": "Ms.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 50,
      "text": "Bishop was most surprised, and said she'd never heard of a girl doing it.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 51,
      "text": "And it involved doing a group four higher school certificate, which they were not doing at Godolphins.",
      "word_count": 17
    }
  ],
