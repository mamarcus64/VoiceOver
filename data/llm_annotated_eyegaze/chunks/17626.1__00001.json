{
  "stem": "17626.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 95.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We lived in an apartment and we had-- what I do remember is a very long kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "At the end of that length was a window.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "On the right hand side of that room where two cots, one after the other.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The first cot was where my grandmother slept.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The one and the head of that was where my Uncle Saul slept.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And I used to run in the morning and cuddle with her.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And then I would run into my uncle's bed.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And till this day, we joke about it.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "I take my shirt-- As a matter of fact, we have it on film.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "On his 80th birthday, I took my shirt and tied up to his because that's what I used to do, tie up my nightgown to his so he wouldn't leave me.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "So my-- my uncle and my grandmother were a very big part of my life.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "My father was busy working, mother did not.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father is a tailor and he had, in those days I guess, that was the norm to have a factory inside your own apartment.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So he had a factory and he had people working in the apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was I guess after I was born that things became a little easier financially for them and he was becoming more and more successful.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he was quite successful towards the end, just before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember there were always a lot of people coming around.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My parents were very active in the drama group and choir, and they always tell me that they performed in the [INAUDIBLE] Theater.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So they were quite an artistic bunch that used to come up.",
      "word_count": 12
    }
  ],
