{
  "stem": "151.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born and raised in the eastern part of Czechoslovakia.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, in our region which in the 20th century belonged to five different countries.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "At my birth it was Czechoslovakia and of course in '38 it became Hungary.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It was a lovely town and",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "--I never went back.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was Uzhorod, when it was Czechoslovakia, and then became Ungvar, when it was Hungary.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And now it's Uzhhorod.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "It belongs to the Ukraine.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I come from a very loving middle-class Jewish family.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My parents were not religious but I remember my only grandfather I knew was Grandfather Rosenfeld died at the age of 96 in an accident.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And he used to go to the temple every morning and every evening.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I remember when I went to his house that he had a rack with these fancy pipes-- long ones, short ones.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "As a child I was always fascinated by that.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And I-- I have fantastic memories about my grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "He was a real character.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "He always, at summertime, wore these starched white suits like he just came out of a box.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And when he saw the grandchildren, he reached in his pocket and started to crackle the paper that was in there and we knew that there was candy.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And we used to ask him for the candy.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "My father was a businessman and he had a textile business and a tailor shop.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "He was a very fine craftsman.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "My mother, when she was young before she got married, she was already a business woman.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "She and two other sisters went to Vienna and they had a millinery shop.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And then when my mother got married, then she became a housewife.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "I have a brother who is four years older than myself.",
      "word_count": 11
    }
  ],
