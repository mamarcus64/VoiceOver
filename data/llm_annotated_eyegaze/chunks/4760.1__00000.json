{
  "stem": "4760.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Marcel Baum-- B-A-U-M.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Germany, in Bad Kreuznach.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was born there because my mother was in the hospital because of an illness of my father.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My original hometown is Laufersweiler-- L-A-U-F-E-R-S-W-E-I-L-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born March 16, 1924.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Moritz Baum-- M-O-R-I-T-Z.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Laura-- L-A-U-R-A.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "He was a butcher and [? handlesman, ?] what they call in Germany tradesman-- tradesman, trading with cattle.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And my mother was a housewife.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a brother and a sister.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name is Alex Baum.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Alice Hanau, now.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Her marriage name is Hanau.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I-- I grew up in Laufersweiler as a-- when my mother came back from Kreuznach, I was a very ill child.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My mother's milk did not nourish me enough, so I was fairly ill until the age of three months.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My mother took a trip to her parents.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "My mother's parents lived in France, in Vic-Sur-Seille-- V-I-C S-U-R S-E-I-L-L-E.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And when my mom-- grandma saw me, she felt sorry and she got good cow milk, and that made me come back at life.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And I went back to Laufersweiler until-- until my-- my-- and then my father passed away in 19-- on August 29, 1925.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "So my mother was a widow at the age of 20-- 25 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was a year and a half old.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And, naturally, I never knew my father.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My mother was left alone with two children, and a father-in-law, who lived in the same house.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And it was very difficult for a young woman at that age to make a-- she had to maintain the-- the household and make a living for the family.",
      "word_count": 29
    }
  ],
