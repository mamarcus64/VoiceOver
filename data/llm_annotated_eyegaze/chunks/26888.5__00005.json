{
  "stem": "26888.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "You didn't-- I mean, we didn't work.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "We just-- most people-- skeletons.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "I also saw my father there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "I saw him.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I didn't speak to him.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "It was like I told you, on the other side was men.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "They came marching there and it was a cousin, second cousin, actually-- he's alive.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He told me that your father is in the back there, and I saw him, but he was like a skeleton.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "It was awful.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "All the men were skeletons.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "He also had wagons with full of dead, but they're pulling-- I saw him when we were marching they told us to go in, in the forest, we shouldn't see because men were marching also through, and they were just skeletons marching.",
      "word_count": 42
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if he saw me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "You weren't allowed to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They hit me because I went close there.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It was separated from the women.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I mean, it's like a big, iron door there.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "You know, a huge iron door, and they were on the other side.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And you weren't allowed to go to that door but I went.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "They hit me.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I was running back.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I saw him but I don't know if he saw me.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Traubach.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] Janko Traubach.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He's alive.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "He's in Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Maybe four weeks, not long.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Then they took us to Mauthausen.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Because again, the Russians were coming there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I remember they burned all the papers there, in Gross Rosen.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I went out from that place.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "So they put us on, again, on those cattles, and they put 120 instead of 60.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Nobody had a place to stand.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "There were people fighting around there, inside in the cattle.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "No food.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "No nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "It was just awful.",
      "word_count": 4
    }
  ],
