  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He cooked for the foreman.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "She knew about it.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "She sort of found out the second or third day.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "She saw it in my eyes.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "She says, I knew that there's something, that you staying there too long, and you're leaving in the afternoon.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "You're going over there.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And be careful, you know, they will catch you.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And if they catch you having any kind of relationship with a non-Jew, you know, you'll be shot.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was in love, and I didn't care.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I didn't care what will happen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I just dared so much in many other occasions that it is hard to explain.",
      "word_count": 15
    }
  ],
