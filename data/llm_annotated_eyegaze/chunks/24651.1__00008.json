{
  "stem": "24651.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And I-- I remember my mother got very sick one time.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And once again, there was very little medical treatment.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "She-- I remember this, because it was so frightening.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "She had leeches put behind her ear and they sucked out the blood.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "I guess she must have had infection or fever.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And she got better.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Winniki.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Mhm, right.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't recall being in contact with them.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember-- I don't remember that at all.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I recall that there was something terribly wrong.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "No one sat me down and explained anything.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "But somehow, I knew-- I just-- I always felt, as a child during the war, I knew what was going on, without having really been told.",
      "word_count": 26
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Because I heard the adults talking.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "But I knew there was something bad happening.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Months, maybe-- months.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And my-- that's when my sister got-- my baby sister got sick with diphtheria and she died.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I remember her being sick.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember the burial or the death, or I don't remember that.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I think that must have been in 1940, or close to '41-- something like that. '40, '41.",
      "word_count": 17
    }
  ],
