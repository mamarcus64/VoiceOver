{
  "stem": "1775.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And the other one were taken out from the bunker where we worked in the [GERMAN].",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "That's the place where the Germans kept the people that they absolutely needed to work, and they were good workers.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "And still, they realize that they're not good workers, and they took them all away.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "That was to Majdanek in 1943-- May-- the 2nd of May.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "And then, my brother was in Majdanek.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 28,
      "text": "And then they took a bunch of people to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 29,
      "text": "So him, and my cousin, and my cousin's father-- my uncle-- that did so much for myself and my brother, during the war, they were taken to Auschwitz.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 30,
      "text": "My uncle got killed in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 31,
      "text": "My brother and my cousin were lucky to not to perish.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "They lived through the war.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 33,
      "text": "My brother escaped when they evacuated Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 34,
      "text": "My brother escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And he came back to Meserich.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My cousin came back to Meserich, after the war in May, '45.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "She came back to Meserich.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Just before, maybe three, four weeks before I left Meserich, she came back.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well, people started to just-- to take apart houses.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "They just plain took-- took apart everything-- especially the ghetto places.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They were taking everything apart, brick by brick, wood by wood, they used to take out everything.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, when I came back after the first action in 1942, when I came back to my place, it was almost empty.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They took out all the personal things.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I didn't have nothing what to wear.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They just robbed everything.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "They just went in and robbed it.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We were in the marketplace with the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And the people, the Poles, mostly Polacks, they helped themselves to all the Jewish [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You know what [NON-ENGLISH] is?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "For all their fortunes.",
      "word_count": 4
    }
  ],
