{
  "stem": "9489.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And this was in-- in coal, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have gas.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "Was on wood, wood and coal, the motors were working, not on benzine.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And I start, and he says, he wanted the right to check me out driving.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I was shaking, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "He took me to the city.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "In Russia, when a bus stops you can't pass a bus.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "You understand me?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "You have to stop, and then, when the bus start to go, then you can pass it or the tramway, things like that.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Plus regulations, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "You know, got signs.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, so I passed that, and he give me the hand that says you're going to do good.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And then they sent us away to Zlatoust.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "Before we go on to there, can you tell us a little bit about the daily life in Magnitogorsk?",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "The daily life-- I'm not going to tell you the secrets.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But I was there a multibillionaire.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "You know, we kept our money here.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "They told me-- they told me how to cut off a hole and put the rubles here.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Golden teeths.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "We were billionaires.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "You know, everything was payoff.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "You-- you understand me?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, and I could-- one day I come in.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "They give me a three-ton truck.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't reach it.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "The steering, the steering was bigger for me.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So they-- they-- they got so sorry for me, and they brought me cushions, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And they give me a cushion to-- to put me higher to the steering.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You understand me?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't reach the steering.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And-- and that's the way it was.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "So [SIGHS] then, they say you're going to Zlatoust.",
      "word_count": 9
    }
  ],
