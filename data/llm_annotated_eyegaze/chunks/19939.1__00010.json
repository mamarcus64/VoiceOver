{
  "stem": "19939.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I was sitting in the back.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I guess this was very important to me because I wasn't called to answer.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And when I got my first grades, I had C's and things.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And it was heartbreaking.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "It was so terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "It was my first big, big-- Disappointment.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Disappointment, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And I was sitting, you know, and my think my head and crying.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But then saw my stepmother.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I never realized how good she was.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "They took a tutor for me, started.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "But then I didn't need a tutor.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "So the second, the end of the year, I already had everything, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I made friends.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I had Polish friends.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I was very good in school.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I was praised for my Polish, for my writing.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And then I finished the-- how much do you want me to talk about this?",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "My stepmother, who was, you know, a very good housekeeper, then she had two children of her own.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "I loved these children.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "I was babysitting, taking them for-- for walks.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "And we were going on vacations to the mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "But I had no communication with her like with a mother.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
