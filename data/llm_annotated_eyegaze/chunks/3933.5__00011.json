{
  "stem": "3933.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "They are located in [INAUDIBLE] Park Avenue.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "They are-- employed several many retired teachers and volunteers.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They have meetings, and they have done lots of clerical work.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They are very polite.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "One of them, you always find the black sheep in the family.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "But the supervisors are very nice to me.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't know nothing about me, very little.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, maybe the supervisor, a man, is very, very dull.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "A young man, Walter.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Before I end it, I was-- when I moved to Israel--",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Before I end it, when I moved to Israel in 1972, when I rented-- and I bought a little apartment, I wasn't working.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I looked for something, but then I sit down, and I was reading-- writing my biography.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was shocked and surprised that I didn't do it so far.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "My old biography's in my son's home, edited, but he was-- he was the one who was supposed to translate it into English, because I wrote it in Polish, which is my native language.",
      "word_count": 34
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He never did it.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Put us in-- I'll show you my son's magazines here.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He put-- he put two articles, and I wrote the articles in Hebrew.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "My Hebrew reading, I can-- Yiddish is-- I'm fluent in Yiddish writing and reading.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "In Hebrew I'm a little worse.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Then-- according what I-- I didn't like it.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "He polished it up a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And I didn't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Boy, did I didn't like it.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I was very angry.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And I said, Eric, first of all, you should ask my permission.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "How dare you say you polish it up a little bit?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "This is hell.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "He said, mother, he says literature, he says this and this.",
      "word_count": 11
    }
  ],
