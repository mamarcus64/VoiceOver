  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They got the chemical factory from-- they had tar and roofing supplies, roofing paper.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Their name was Schkowsky.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "I met one of their granddaughters-- twins-- that used to play with me when we were children.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "I used to love to go to their house.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "And we used to slide down the banister down the stairs-- which was a wide mahogany banister.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "Slide down.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "I still remember it like today.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "He had two employees.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "One was Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And one was a Pole, non-Jew.",
      "word_count": 6
    }
  ],
