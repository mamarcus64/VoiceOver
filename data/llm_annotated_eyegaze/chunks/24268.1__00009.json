{
  "stem": "24268.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And one of the sons, what I mentioned-- one man who-- young man who went to school T my brother, to engineering, after he became a fiance with one of the girls later on.",
      "word_count": 34
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Bundt-- the name was Bundt.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And they got engaged with [?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Lonav ?] Davinsky.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] they were already older than we were.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "That was just before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And we used to have fun with them.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And the parents used to associate and play [INAUDIBLE] whatever they get together with each other.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And family-- we used to get very close tie with our family, the cousins.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "The worst part is, when it came passover, I had all the beautiful clothes, and I had to stay home, because I always got sick.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "That seems like it was terrific timing.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "My grandma, [INAUDIBLE], she was over.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And she came to visit when my grandfather passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "She used to bring the [INAUDIBLE] to the children.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "They all-- she was always treated as a-- she was very gracious lady.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And she was always treated like a princess.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "She never did anything, not like I.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Everything I do for the grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "She wouldn't-- no comparison.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "I think there was a different way of living.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "I think now we live different.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "That time was different.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "We have respect.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "We have-- I didn't went to school.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "If I had to go to school, I have to kiss my daddy and my mom in the hand before I left.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "Otherwise, I thought the sky will fall over me.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "And then school, like I said, we try always our best.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "And our parents were very proud.",
      "word_count": 6
    }
  ],
