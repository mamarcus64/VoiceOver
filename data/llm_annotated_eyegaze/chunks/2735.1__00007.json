{
  "stem": "2735.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And we used to spend the days.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "We used to go to the river to bathe and to swim on Shabbos.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And we used to have company after lunch.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "They used to come visiting or my parents went visiting.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "That's how we-- and when I got older, we used to gather-- get together at the end of Shabbat with friends and wait till it gets dark so we can do the things that we want to do.",
      "word_count": 38
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "We also had influence from Zionist organizations.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And I was involved in an organization which was not-- not on the extreme right and not on the extreme left, but rather middle of the road.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And we used to get together and sing songs and talk about Palestine and have discussions.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was very interesting.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "The main street was a very, not like in that small town, was a very big street.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It really crosses the town.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And every evening, that was the thing, the youth went out to-- for walks and used to meet each other.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "On one side of the street, the Jews were congregating and on the other side, the non-Jews were congregating.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And it seems like if you don't go on the other side of the street, you thought you're all beating Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "I mean, from different-- this city had a lot of gymnasiums, different.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "They had the Hebrew.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "They had a [INAUDIBLE] gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "They had a Polish gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "They had a Russian gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "They had a gymnasium that had-- they had like also schools that you could learn how to sew and all kind.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "Anyway, so all that youth used to come out.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "They used to pick their beauty.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "They used to have all kind of things going.",
      "word_count": 9
    }
  ],
