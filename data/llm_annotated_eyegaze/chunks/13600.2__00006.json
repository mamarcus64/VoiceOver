  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Large city.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Wait for-- wait to be registered, and sended-- send away with the Russians to another place.",
      "word_count": 16
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No I was free.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't kept.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "It was a few weeks, I was there.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "My mom was still in Poland under German occupation.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "So she came a few weeks later.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Not in Bialystok.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "She joined me in a city called Babruysk.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "This is-- Belarus it's called now.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I didn't go.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I was taken, registered and sent away to a city.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "By the Russians, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And there I worked.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Timber mills.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "That was a large factory that made doors and windows.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "I was just put in a place and-- and worked.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Later, yes, a few weeks later.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "My sister went to another place.",
      "word_count": 6
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Two sisters, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "They both went to different places, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Mother.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "In Falenica, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Stayed all through the bitter end.",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Tough, like in Soviet Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "The basics, not more than the basics.",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "Very tough, the basics.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "At the begin-- at the beginning, before my mother came, I was together with other single people, eight or 10 in a place where we just had a place to sleep.",
      "word_count": 31
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "The basics.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "Yes, we didn't suffer from any shortage of food.",
      "word_count": 9
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Work was hard work for a boy of 16.",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Hard, physical labor, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "At the begin-- at the beginning very grateful, because I escaped the Nazis.",
      "word_count": 13
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "At the beginning, very grateful.",
      "word_count": 5
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "I-- I started seeing the false, but you cannot express yourself in Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "They used to say in Russia words-- I don't know where we heard a joke-- that in Soviet Russia, the only place you can open your mouth is at the dentist.",
      "word_count": 31
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Start observing, yes.",
      "word_count": 3
    }
