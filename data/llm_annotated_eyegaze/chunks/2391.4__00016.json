  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "I was very fortunate.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "So I worked with him until my first child was born, my daughter, my eldest daughter.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Jacqueline.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We named her Jackie.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I had another child almost three years later, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "So I have two daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, I would say when I-- when I see how things can degenerate between humans who-- who own the power and who misuse it in a most horrible and cruel way, I became even more concerned about protecting the weak and the powerless than I had ever before.",
      "word_count": 48
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I go all the way, you know, children, women, those who have no power, and animals, you know, cruelty to animals too.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I'm even an animal-- I could call myself an animal activist, and I'm a vegetarian.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So I-- I went all the way, me and my daughters.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And-",
      "word_count": 1
    }
  ],
