{
  "stem": "8352.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So it was the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The Germans took over in that time.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And we were in their hand.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And they gave all the orders what to do, and when to move, and when to go, and all kind of things.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They were in charge of us at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We were in their hands.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Well, we know that we were going into Hell.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We knew.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We had feelings that we don't know what is going to happen.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "We might all die out and never come back again.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "We already had a feeling that this is end of all of us.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "That we will never survive anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Because the way they were treating us, and they were screaming, and hollering, and beating, and punishing us, and giving us nothing to eat.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "We had a feeling that this is it.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "Who knows what's going to be with us.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "But how we will die, how we will do, and what it going to happen later on is time to tell.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "We prayed a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We prayed a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Even the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We gathered groups of little groups together.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And we have to hide so they didn't see us.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Because they did not allow any groups to be together at all.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "We were being watched from big towers through the guards.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And they said, no groups together.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But if you are three, four, five, a few people together, they let us do it.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "When we got together, we prayed every so often, and that's all we could do.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "A Minyan was important.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "But if you didn't have a Minyan, whatever how many people there it was--",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It didn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We just prayed together.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We said a few words.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And we kept the religion.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We kept it in our heart.",
      "word_count": 6
    }
  ],
