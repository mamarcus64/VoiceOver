  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And then the, the youngest one, she also wanted to go.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So they decided-- there's a group of them going.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They'd rather tour the country for awhile for a, a week before we settle down.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And then there was a-- they went-- they ordered a car from here or from there.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "There must have been a tire burst.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And they went over a ravine.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And they were all injured, but she was the only one that was killed.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "She was 21, [PAUSES FOR 3 SECONDS] yes.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And then my third daughter was pregnant at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And she loved her sister, that [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "That trouble-- that was trouble, then.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Her husband, instead of being a decent fellow, realizing that she wasn't ready for sex during the week of shivah, and so on, he goes out with another woman.",
      "word_count": 29
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "So eventually-- she eventually divorced him.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And there you are.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "My life story.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And so I've been 60 years-- 50 years in, in Hendon, this next year, which is '97.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "And, please God, I will be celebrating our diamond wedding.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "October, 1966.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "1996-- that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Then suddenly, I get a-- about what?",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Oh yes, all right, afterwards.",
      "word_count": 5
    }
  ],
