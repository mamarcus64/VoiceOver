{
  "stem": "10272.6",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We cannot go now there illegally further because the British are patrolling the, the ocean, the beaches.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And they will catch us.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And then we can get killed.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "We're better off waiting in this-- in this camp in Cyprus.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I said, no way.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I was in camps.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I am not going to go now to another camp.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to-- better go work and see in Italy what is going on and see the world.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I'm free now.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I'm going to go in a camp?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Wait till, till Israel is going to be independent?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I'm not going to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "So I decided-- I took my, my bags.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I boarded the train without any money.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And I was going from, from wagon-- from car to car, so they wouldn't catch me for, for the-- for the-- for the ticket.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And sometimes, I was caught without a ticket.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And they took me off.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I went on another train.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "It took me a whole week to get from there to Rome.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "In Rome, I went to-- I went to Cinecitta.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "On the street, I found a-- an American jeep-- with a jeep.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And I saw it's written there, UNRRA.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And I came to him.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And with  broken English, I told him the story that I am now a refugee from Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "I don't have nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "I want to go to America because I have an-- I have an aunt in America.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "I didn't know where she lives.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "But I know that she's an American.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So he put me in this Cinecitta thing there.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And there I was-- I was there sleeping, sleeping there and getting lunches and getting packages.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And during the day, I was walking and seeing Rome-- Vatican I got to visit.",
      "word_count": 15
    }
  ],
