{
  "stem": "18581.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I had a room about seven feet by nine feet.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It is kind of a dilapidated thing.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "It was overlooked.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And then somebody-- I found it.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And they agreed, the ghetto administration, that I should live there.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I'm not quite sure how many there were left.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Vilna had about 80,000 Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And there were two ghettos.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "One was destroyed.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The other one was sort of cut down to-- to small.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So I believe that must have been about 26,000 or so.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The cultural activities were-- first of all, the ghetto administration was in favor of these activities.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The Zionist youth groups, of course, in order to continue their spiritual affiliation with the Jewish people, were also very much interested, and also to give people who were always tense-- to give them an opportunity to relax a little.",
      "word_count": 40
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Some of the activities, well, it was Hebrew theater.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "There was a choir.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I participated in both.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "There were other activities.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "There were libraries.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "There were books.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "There was a secret yeshiva, a small yeshiva.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "That means people studied the--",
      "word_count": 5
    }
  ],
