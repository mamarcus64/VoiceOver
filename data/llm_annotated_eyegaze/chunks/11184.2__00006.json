{
  "stem": "11184.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "So-- Had you stayed in touch with them in the ghetto?",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But nobody was that close.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "I mean, it's just-- I often think about it.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Nobody-- everybody was just busy with their own--",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "--serious, you know, survival and hunger, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I mean, even when my father died, nobody came.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Me and my mother-- that's the only thing-- we went to the funeral, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "But then, it's 1944, and my sister's girlfriend begs me to go with, because they were selected to go-- to be sent out from the ghetto.",
      "word_count": 26
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "You know, they promise-- the promises were that they're going to-- you going to work.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "You're gonna have it good.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "You're gonna-- so they were excited, you know-- some of the people I knew.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And she said, Rose, you must go with us.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "I have a mother, you have a mother.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "We have to go, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "And by that time, my mother was selected to go too.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Had been selected, yeah-- to go-- to go too.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And I was hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I was hiding out in my neighbor's house.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "But I told you about that.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, yeah, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "So I was-- I was.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And by the time the selection was over, I come down to my room, and my mother is not there.",
      "word_count": 20
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "So I knew already, you know, where she is.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And the same policeman-- our friend, came over.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And he told me.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "You know, your mother was taken.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I said, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I'm gonna take my-- I took my little-- what do you call-- back-- backpack, and I ran to that-- to the wagons where all the Jews were in already.",
      "word_count": 29
    }
  ],
