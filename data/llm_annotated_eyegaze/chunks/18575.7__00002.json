{
  "stem": "18575.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 95.5,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They had tennis courts and basketball courts and soccer courts and swimming pools and television, which was rare.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I'm talking 1946.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We have dancing where girls from high schools used to come in to our place.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They were the best basketball team around.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "We had wonderful director, Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Kaftov.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "There was a family he introduced to me to that invite me for dinner, one of the Big Brothers who supported the house who wanted to adopt me, and-- because they lost a son in a war, a soldier.",
      "word_count": 39
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "But I did-- was not adoptable.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "But I met some that were outright idiots, some of the Big Brothers.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "There was one that was bragging to me that had-- he was importing oil, bringing oil from Venezuela, and had the war lasted another year or so, he would have been multimillionaire.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And another one, I had that-- in English, by the way, because we could speak English-- told me that wasn't so good in the States during the war.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "All he had is chicken, chicken, chicken.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "There was no beef at all available.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And I felt very sorry for him.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I learn English in two ways.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "One, I listened to radio broadcast.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I went to movies and watch very closely.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I tried to learn some of the-- some of the pronunciation of English words just in front of a mirror.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But mostly, I learn by reading books that I knew well as a child.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I read English or American authors-- Jack London and Lewis and whatever the authors that I used to swallow them.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I read every Jack London book and Sinclair Lewis and Upton Sinclair and others, Western books-- the-- all the things as a child I went through [? series. ?]",
      "word_count": 29
    }
  ],
