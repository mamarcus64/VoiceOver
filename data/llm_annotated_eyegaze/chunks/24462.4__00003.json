  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 30,
      "text": "And the German officer left me with my papers and told me that from [NON-ENGLISH], which means the railway station, [INAUDIBLE] railway station, I will go to Brandenburg and so forth, so on, and to get to my town where I have my position.",
      "word_count": 44
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 31,
      "text": "So I went by myself from Berlin to Brandenburg.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 32,
      "text": "Nobody was watching me.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 33,
      "text": "I came to Friedland in Mecklenburg late in the afternoon, I remember, Friedland in Mecklenburg.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 34,
      "text": "And the Polish man was waiting for me.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 35,
      "text": "And they welcomed me.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 36,
      "text": "They were very happy, because he's going home to his family.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 37,
      "text": "And I got his room.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 38,
      "text": "His room was very nice furnished with a beautiful bed, washing basin, no running water, toilet outside.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 39,
      "text": "And the family was [?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 40,
      "text": "Shultz ?] family, [?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 41,
      "text": "Shultz, ?] of course, old-- older people whose son was in the army in Africa core, in Africa, [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 42,
      "text": "And the daughter was married with children someone living else.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 43,
      "text": "So I got the room.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 44,
      "text": "And I stayed in this room for three years.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I gave my name in the Warsaw [INAUDIBLE]-- Warsaw employment office as [?",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Watslaw ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Friedaman. ?] Because I was afraid that they will check my Russian passport.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And in the Russian passport, I could only change from Jew to Polish and from Friedman to [?",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Freidaman. ?] I couldn't change more, because it was too much.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And nobody saw it.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And nobody would see and nobody would believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Because it was very bad change.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "So my-- I came to Germany as [?",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Watslaw ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Freidaman. ?] And this Polish man took me to the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "This was a potato produce factory.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "They produce from potatoes different things like flours, and chips, and syrups, and other things only from the potatoes.",
      "word_count": 19
    }
  ],
