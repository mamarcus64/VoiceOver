  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "But she was a wonderful old lady.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I suppose they did.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "She never did.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "She never did.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "She never did.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Oh, Yes.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And she had-- she came from a family of 12.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They were 12 brothers and sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And I remember some of them-- not all of them.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "They lived in the country in a little village, and we spent many holidays there.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "My grandmother took me and my cousin many times to the little village where her sisters lived.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "Two sisters lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Ah, it was about 50 kilometer, but for us, that was a great distance in those days.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And my mother had a sister whose daughter was my cousin, who we were brought up together.",
      "word_count": 17
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "That was my cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And my mother had two brothers.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "One lived in Hungary, and the other left Hungary at a very early age.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "He was working in a big circus.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "He was an acrobat, actually, to begin with.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And then in the-- I think it was in the late '30s, he married a girl from Vienna.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And then just before the war started, they went and settled in Scotland.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And that's how we went to Scotland eventually, because that's-- my mother's brother lived in Scotland, and he helped us to go there.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, nothing, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I was a child living a happy childhood-- had my friends, and that was it.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I can't remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Well,   we had  to.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "We had to, unfortunately.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "It had to come.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And we had to be aware of it, especially in the late '30s when I was about 16 and 17.",
      "word_count": 20
    }
  ],
