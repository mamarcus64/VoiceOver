{
  "stem": "16571.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 425.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And they were saying that the-- I had three sisters on the trot, and they were going bananas because no boys.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And then after that, three boys were born.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "My brother is the oldest who lives-- at the moment, he lives in [NON-ENGLISH] with number two.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And the third brother, which was called Yontle.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He was only 11.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And he was with us together in the Auschwitz, and they picked him out and said he's too young for work.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He's going to his mother.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "That's the last I saw of him.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "--hard-- hard to imagine, hard to believe what it was like.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I mean, they used to do their own baking and their own everything.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We had sort of two bedrooms and a big living room.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It was a great big oven, sort of-- it was built from brick where they had hole in to cook.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Saucepans.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "There was always three or four saucepans on that.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And next to it, there was an oven which they baked their own bread and pretzels and all that.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And we used to come home from school or cheder.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "We used to go up on what we call on-- on the pitcher, which was very, very warm.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Because when the-- when they use the oven, we come home freezing.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "We used to go out there and have a good warm up.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "It was-- hard-- it's hard to explain, hard to imagine.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "But that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Used to have snows six feet.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "It-- it was no problem in-- in Romania where we lived.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Very, very.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because we were all mucking in almost like with friends.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I mean, everybody was very, very close to one another, sisters and brothers.",
      "word_count": 13
    }
  ],
