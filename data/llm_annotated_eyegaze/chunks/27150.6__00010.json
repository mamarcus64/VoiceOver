  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You see that was the Central Reserve Bank, all the dollars issued by the Nanjing, the Japanese puppet government.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "It was a big pack of money, and we were afraid to board the bus.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And we walked all the way.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "You see, back, you see because we had to take a bus.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And all the way back.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "This was-- no, this was before the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "When we lived above the Shiva.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "You know. and we got this money.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And we came back.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And on the way back, we bought a pound of biscuits, and two pounds of lard, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And we cooked the lard in-- in this hibachi.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And the lard tipped over.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "You see, and there was strife.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And the floor started burning, but we just saved up the lard.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And the money I spent on-- on medicines.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "That was shortly before the ghetto was formed.",
      "word_count": 8
    }
  ],
