{
  "stem": "19211.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "To what extent, we didn't know anything about that, no.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I had a grandma, and my grandpa died just before the war, and my paternal and maternal grandma.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I remember my mom's mother, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "My father's mom I vaguely remember.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "They-- they were killed.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "All, everybody except our family, everybody was killed.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "The only survivor was my uncle, younger uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And he ran away to Hungary, and he survived it.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He just passed away last year.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was killed, everybody, my aunts, my cousins, the whole-- there's not one except my--",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We'll never know.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "They was in the ghetto in Brody.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They all lived in Brody.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And that's all we know.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "There was a ghetto in Brody, and what happened after that, we went to that village.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We never heard from them again.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "What happened to them, we don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Hiding in the woods, part of the time.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Part of the time we were hiding with farmers.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We were in hiding places.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, we paid them.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We had some-- a little money left yet, whatever we had left.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And then at the end, the money ran out.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So we were-- they were sympathetic.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And they, like I said, that Polish he was like a knight, what you call him that-- I can't remember.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "He was from the no-- nobility, Polish nobility.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "He was our friend.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "He was a wonderful guy, and he helped us a lot.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "He hated the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Most Polacks hated the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "But they also disliked the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "That was a problem.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And Ukrainians, they were just terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "They were very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because they wanted the one thing the Germans promised them, independent Ukraine.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They wanted independent Ukraine.",
      "word_count": 4
    }
  ],
