  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "And when they'd finally get something everybody turned on about, we'd discuss it all day.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "The little kids and everybody used to step up and discuss.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "All of us were involved, everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "All of us read.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "All of us did those kinds of things.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "So culturally, it was amazing.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I always say that I was-- I was-- I was poor.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I was without money.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "But I was never poor in spirit.",
      "word_count": 7
    }
  ],
