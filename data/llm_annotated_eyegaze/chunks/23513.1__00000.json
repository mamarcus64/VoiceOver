    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We got a small farm, too.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we got a business, too.",
