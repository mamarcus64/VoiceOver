  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "But yet-- I don't know, three stitches, two stitches.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "He was a young man, what he come back from the-- he was in army.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "He came back.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And he saw this blood.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "He start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "And he cried.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And their old man put-- picked up this-- the other piece, and left.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "Then she came with me there, in the ambul-- in the clinic.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "Was there Germans, womans.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "But they-- they were, sitting-- man and woman, with children, and doctor.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "And they saw how I was look, and how this bleeding.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And they said to her that she should go in with me before them.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "And she said, the SS woman, no, she have to wait when her line will be, when her turn will come.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "And then she have-- she have to wait.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "Then another told her, you take her in right away.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "She wouldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "She was sitting with me, a long-- I was the last to get-- I mean, was behind me, you know-- last to get in.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 32,
      "text": "Then I didn't went more to work.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 33,
      "text": "She took me back in the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 34,
      "text": "And I was sitting there, how long all the finishing.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 35,
      "text": "And then she took me home.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 36,
      "text": "And I was staying in the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 37,
      "text": "The girls was going to work.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 38,
      "text": "And I was working clinic again, by the SS-- the rooms.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 39,
      "text": "And I was washing.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 40,
      "text": "And after this, I was in the kitchen, helping in the kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 41,
      "text": "[SIGHS] [PAUSES FOR 8 SECONDS] I can't-- I don't know if-- [PAUSES FOR 7 SECONDS] then I was-- I was staying-- I [? was ?] cleaning by the [? man. ?] Then a woman was-- then the SS woman met me.",
      "word_count": 41
    }
  ],
