{
  "stem": "26790.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 42,
      "text": "If you are a Pole in Poland, you have to go to the Polish-- if you are in the Red, the Red Army, you have to go to the Polish army.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 43,
      "text": "If you are born in Poland, you are in the Pol-- in the Red Army hospital, you have to go to Polish, Polish hospital.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "After we have tea, the same day after we have tea, the [INAUDIBLE] comes along.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Ganc, [SPEAKING POLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The [INAUDIBLE] Hospital want, wants to see me.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "What can they wanted from me?",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "The [INAUDIBLE] Hospital.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "What I've done?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Did I do wrong?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I did not anything wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "If the [INAUDIBLE] Hospital call you, you have to go.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I went to the [INAUDIBLE] Hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "In his office, he was sitting and doing his papers, the books as he looks.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I standing there about five, 10 minutes and he doesn't, doesn't say nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Look like he forgot something or he's busy.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I was nervous.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And I said, [CLEARS THROAT], like that.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "[CLEARS THROAT].",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I wake him up.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Hey, I hear what a [CLEARS THROAT], like that.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "He lift up his head.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "He looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Hey, Ganc.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "You already here.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "All right, [? he ?] said.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "He told me it's a order from the, from the high command, if you was born in Poland, you have to go back in Polish hospital.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "That's mean if I go to the Polish hospital, as I was reading in the paper, if the Polish, The [?",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "Akcja ?] will find out I am there, they will take me out, and they kill me.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "As I hear that, I stood up I salute to [SPEAKING RUSSIAN].",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "I will not go.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "You can do with me what you wanted.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "I will not go to the Polish hospital.",
      "word_count": 8
    }
  ],
