{
  "stem": "14687.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 21.3,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So one night when I was working-- we used to work with the-- like I told you, with the Italian, with the Russian.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "The Russian prisoner near, one day, he gave me his lunch, you know, to me.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "So I keep it.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I put it here.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And we had nothing here, you see?",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Or there was just-- and I said to my sister, come.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Let us go to the toilet to warm and eat the thing there.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "We ate.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "At least we were a little bit-- and another German-- he was Austrian-- Austrian.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "He came and he say, ooh, that's good, good, the machine.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And he open-- he opened his bag where he had the lunch.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "He was in-- on duty.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "He gave me two little apples, you know, from his food, because the-- the Austrian people, they were very nice, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "So you alternated one week in the day--",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "One--",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "--one week in the night.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, right through.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "The end of the war, these-- when they-- these Germans, they say you must come--",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No, no-- nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "All the time in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "All the time we were there.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We were about 14 of us, together.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "It was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "We were lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "We-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I-- we knew we were working for the factory.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "But we didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "German factory, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And do you know the German, they used to cut the hair to here?",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And they use to have the blue jackets.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Because we never really thought to look.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "I was with the-- you know, Esther [NON-ENGLISH]-- Esther [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "We worked together--",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "--till there were-- liberation.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And Mercardo Chadev-- I was together, you see?",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, nothing, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    }
