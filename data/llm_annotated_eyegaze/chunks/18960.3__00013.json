  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 78,
      "text": "Constant investigations day and night.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 79,
      "text": "They-- they-- sometimes they-- they gave me a big bowl of ground-- something ground.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 80,
      "text": "It looked like meat.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 81,
      "text": "And then for three days, no food at all.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 82,
      "text": "And they were really torturing me.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 83,
      "text": "One day-- and they were always investigating.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 84,
      "text": "One day-- [PAUSES FOR 3 SECONDS] there was always, of course, a translator-- I was sitting in the room.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 85,
      "text": "And they were investigating me.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 86,
      "text": "And there was one dark-haired and one redhead Gestapo man.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 87,
      "text": "And I-- I heard the dark-haired guy say to the redhead man-- say, you know, I think this guy is harmless.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 88,
      "text": "Maybe we should let him go.",
      "word_count": 6
    }
  ],
