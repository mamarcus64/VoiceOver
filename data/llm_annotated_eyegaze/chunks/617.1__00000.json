{
  "stem": "617.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Margaret Smaye.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name is Mancie Drummer.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And my Hebrew name is [HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was born in Sighet, Maramures, Romania.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "But my parents didn't live there.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We moved to a city in Judetal Salaj.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "In Romanische that's what it was called, the area.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And the city's name is Carei Mare in Romanische.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And I lived there till about-- till I was about 8 years old.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My immediate family?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My-- I had the-- we were five children, three girls and two boys.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I was the oldest of the family.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And my sister is the next one, Ella, who was with me right through concentration camp.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "She's alive, and all the others were killed.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The one who's alive is Ella.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The next one was Michael, Jachil [INAUDIBLE] in Hebrew.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my little sister was Esther Chaia.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I had a little brother.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "His name is Sloma Yoseph.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It-- what I remember, we were a very religious family in those days.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And we had just a typical-- nothing really extraordinary.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We-- me being the oldest, I was always expected to help.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I did, I think.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And that's about what all I can say about the family.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My parents--",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "David, David.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Drummer, D-R-U-M-M-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Regina Taback.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And my grandparents lived in Sighit, where I was born.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And therefore, many summers I used to spend there with my grandparents, aunts, and uncles.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "My mother was-- her family were sisters and brothers, nine of them.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "My father's family were 10 in the family.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "So it was big families.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And we used to get together for simchas, for-- and it was very nice for holidays.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Just being there and being with my-- the whole family, with my grandparents and aunts and uncles.",
      "word_count": 17
    }
  ],
