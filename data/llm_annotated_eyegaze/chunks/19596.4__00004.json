{
  "stem": "19596.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.2,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I was amongst the 10.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Not all, no.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Four Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "The rest was not Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "The foreman was not Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "There was no beating.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] I saw beatings every day.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I saw beatings every day and I saw hangings everyday.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Every morning.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Some of them were Serb partisans, Serbs, with the-- you know?",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And some of them were people who tried to escape.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I was-- they put a board around them.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I-- I-- I was trying to escape.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And they hang them up.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And some of them were-- that means local prisoners, Poles mostly, not Jews, Poles.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And some of them were Serb partisans, they caught them.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And-- [PAUSES FOR 4 SECONDS] some of them were punished prisoners.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They killed them.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They didn't have to hang them.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "They killed them in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "They didn't have to string them up.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, some of the people they hanged-- there was a fellow, as I said to you, a [INAUDIBLE] called Tadek.",
      "word_count": 24
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Tadek was a Polnish, fellow, very good looking, tall.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He was in love with a Jewish girl, a Slovakian girl, in Birkenau.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He fell in lover with here.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "They had something together.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "He stole a-- he had free access to go anywhere.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He stole a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "He stole a uniform.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "He took her and he drove away, to Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They caught him and her.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Both got hung in front of everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah. '43.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "End of '43.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We all saw it.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "The hanging was taking place in the appell in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Was prepared a table and on that table was chairs.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And they stood on the chairs with a noose around us the thing-- around the structure.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And then the chair-- the chairs were kicked away by the SS.",
      "word_count": 12
    }
  ],
