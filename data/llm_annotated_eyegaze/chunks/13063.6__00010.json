  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "At the very end-- I think it was in March '45-- there was a transport of emaciated Hungarian Jews that came into the camp.",
      "word_count": 24
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they didn't come into the camp, really.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "They were in, in, in cattle cars.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And then they remained in the cattle cars, right at the, at the riding terminal of the camp.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I saw them.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They were living skeletons, living skeletons.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't do anything for them.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But I think Schindler put himself out, really, to help feed them, in, in, in the best way he could.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "But there were-- I'm sure that there were many deaths, right there and there.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Because the, the people were just at the end of their tethers.",
      "word_count": 12
    }
  ],
