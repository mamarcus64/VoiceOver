    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "From my town, my friend was shot there.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "When I came home, they told me-- they told me he was shot in [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "The Jewish [INAUDIBLE], the committee in Lublin, they were very active.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "They went door by door to Jewish people in the whole city.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And they took everything-- not but first, they were begging them to give gold, diamonds, money-- everything what they have to stop shooting the soldiers.",
      "word_count": 25
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
