{
  "stem": "12343.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "They said, [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Run, to run.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "[INAUDIBLE] center of the city, sitting on their knees, everybody.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Everybody sitting on their knees from the morning, almost all day, sitting on the [INAUDIBLE] over there.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "I know the street, even.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "Then he goes around, around, and look what to do with them.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Which one to take out right away and which one to take some later.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Then they took out my uncle, [?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Soha. ?] He worked for them.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "They paid him back.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "Put up the wall.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "He shot him.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "[CRYING] They said to him, we not going to send you to Treblinka.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "We can-- we finish you here.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "And they kill him right away.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "Then I sitting next to my-- [INAUDIBLE] a girl from [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "She was a pretty girl.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "I remember her name, [?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "Shita. ?] They took here.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "They shoot her right away next to me.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "Never so lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "I was lucky they didn't shoot me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "My heart [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Left the wall.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They come over.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They decide to take us all over in-- in the cemetery because they'd rather dig the ditches to bury-- to bury us.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I went to the cemetery in [INAUDIBLE], going with him.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I know they can see.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "What can you do?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "You go behind us, Gestapo with guns and [INAUDIBLE] with their rifles.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You can't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "After all, the [INAUDIBLE] order to take us back out.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I said, out?",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Then they took us on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Train-- cattle train-- not a real train, cattle train.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Close up, locked up, and then they took us over there.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Takes about two days to take us around with no water or nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "People died on the train.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "You never believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "My uncle-- cousin [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "People sit on him.",
      "word_count": 4
    }
  ],
