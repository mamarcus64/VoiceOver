  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "To the world, that there's a great deal of unfinished business and a great deal of confusion about some things such as the Holocaust, that we need not remain so impotent against the Holocaust.",
      "word_count": 34
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I think many of you will be familiar with Emil Fackenheim's famous statement, don't give Hitler a posthumous victory by giving up on Judaism.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Well, I'm saying don't give Hitler a posthumous victory by giving up on science.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "That is the science of human behavior is now about where the physical sciences where 1,000 years ago, that a good deal of our failure to control or to produce more decent human existence is simply because our level of science when it comes to human behavior is just extremely backward as yet, and that the challenge is to be more imaginative and more daring in how we construct our ways of looking at human behavior, and that I believe we can be far more effective than we have been at this date.",
      "word_count": 93
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "That is, we are surrounded by impotence when it comes to human affairs, but we don't need to remain so impotent.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, I've deliberately tried to return to Judaism and the belief in God.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I've been a member of a congregation for the last 18 years.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I've deliberately tried to return and become active in it.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I have not turned the corner of finding a nurturing God, but I'm working at it.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So in a broad sense, I have gone past the notion of God was absent.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I don't think God was absent, but I really don't understand yet.",
      "word_count": 12
    }
  ],
