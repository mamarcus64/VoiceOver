{
  "stem": "12564.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 18,
      "text": "They were beating them with the other end of the rifle, that the blood was all over the wall.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 19,
      "text": "Actually, they left them.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 20,
      "text": "They were laying without movement.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 21,
      "text": "And she was begging them, Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 22,
      "text": "Matisek, to them in Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 23,
      "text": "She sweared them by God, leave them alone.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 24,
      "text": "They already have death, like this.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 25,
      "text": "And finally they left.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "So when they left, I crawled out from under the bed.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And we took some water.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We washed them, Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Matisek and me, until they come to themself.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We went on the attic, not in the house already, just on the barn, where they had to keep the cows.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We were there maybe a week.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "But we were afraid to already to be over there, should they come back and finish off.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "But they were in no position to move.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "In that time we changed.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We went to another family by the name of Golec.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "When we went into them, it was by the end of 1942.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "It was around April, May, of 1943.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "On the top of where the cows are in the barn, upstairs, until it took three, four, weeks to build a bunker under where the cows stayed.",
      "word_count": 27
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And many times, when the cows were peeing, it was straight going down to us.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "So we had not only sit dry, we were sitting in wet.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And we were there almost five, close to six months.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Mostly two, three, potatoes daily, and some bread and water.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "We had a small opening to the outside, maybe 2 inches, for fresh air.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And this was the light and the fresh air.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "We were afraid, after the beating already, to leave until after that time.",
      "word_count": 13
    }
  ],
