{
  "stem": "16163.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I don't know her.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "No, I didn't-- I didn't-- I saw her, but I didn't know her.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I saw her in street.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "We had a girl who was-- her name was Dolly.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I forgot her last name.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She was from the mountains from Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "She was a couple of years older than us girls, and we were like 16 and 17, and she was already 19, 20 or more.",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And also the-- [PAUSES FOR 3 SECONDS] her father's name.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "No, she only knew her mother.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "She was an illegitimate child.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And it turned out that her father was a Jew from Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "They arrested her, and she ended up in Theresienstadt.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And she went to Auschwitz and didn't come back.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "As a matter of fact, my sister-in-law and I always talking about her, because we were friends with her.",
      "word_count": 19
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And we must have been the first two-- I mean, not only us personally-- but when she got to Theresienstadt, we must have been the first Jews she ever saw.",
      "word_count": 30
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "She didn't even know anything.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "So people ended up like-- like that too, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "But I remember seeing the nun with the big cross, walking around in her habit or whatever you call it.",
      "word_count": 20
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "So she must've been arrested somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And I don't think she was Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I mean, that--",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Not in Theresienstadt.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We had-- I was in a gypsy camp in Auschwitz [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I shouldn't really say that, because I know somebody who is here in New York, and his mother was a Jewish woman from [INAUDIBLE] or [INAUDIBLE], and his father was a gypsy.",
      "word_count": 32
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And he and his mother and his sister came to Theresienstadt, and the sister-- the mother survived and he survived, and his sister didn't come back from Auschwitz.",
      "word_count": 28
    }
  ],
