{
  "stem": "18294.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "[SINGING IN YIDDISH] Zog nit keyn mol az du geyst dem letstn veg, himlen blayene farshteln bloye teg.",
      "word_count": 18
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Kumen vet nokh undzer oysgebenkte sho- s'vet a poyk ton undzer trot- mir zaynen do!",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "There is-- this song is in every language, in every language now.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And he was such an ordinary little-- ordinary boy, young boy.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Very-- just very-- didn't-- I don't know if he finished his school.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "He was so clever.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "And he was sitting in ghetto and write these songs and books.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "Even books.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "He had books from the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we know him.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "He was in the concentration camp with mine-- with mine-- with my husband.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "If I have radio-- at home, I had.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "There wasn't such a radio like you hear today with news and things.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "No, there was music.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "There was not really news especially on the radio.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "I never heard it anyway.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "Maybe was, but I never heard.",
      "word_count": 6
    }
  ],
