{
  "stem": "17299.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.8,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And then I went back to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "But then it wasn't-- ghetto was-- was already being dissolved.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Systematic, every few days a transport would go to concentration camp Kaiswerwald.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And two weeks later, I was in Kaiserwald.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "They were going on already before.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And we knew that Kaiserwald was no sanatorium.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "We knew that already.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "On trucks.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "30 or 40 on a truck each time.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "You-- they were taking 200 at a time, each time.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I had no other choice.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My parents and my younger brother was-- and sister-in-law and my sister and brother-in-law were still in the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Big, barbed wire fence, guard posts, and barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Wooden barracks.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Miserable.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I would say yes.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Because we were greeted by antisemitic Poles and German criminals.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "There were maybe 1,000 Jews in Kaiserwald, in two barracks, and maybe 1,000 Poles and a few hundred German criminals.",
      "word_count": 20
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And the SS who was in charge came from the concentration camp Oranienburg.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "The Jews-- equal to-- there was no problem.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "But the, the Poles were very abusive.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans were even worse.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "First, we got stripped of everything what we had.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Then we got stripes and big Xs made on our clothing and got our hair cut.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "4250.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "When I came in the barrack, I met some friends there.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And I said, can I sleep next to you.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And they said, yeah, and you can have my lice, too.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "So I look at-- what do you mean?",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "Well, everyone is having body lice here, because the sanitary conditions are terrible.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- a lot of noise and a lot of beatings.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "The Poles were beating up on the Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "In that barracks.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "5 o'clock in the morning, we were chased out in a washroom to wash up.",
      "word_count": 15
    }
  ],
