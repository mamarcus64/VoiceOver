{
  "stem": "3994.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And I gave it to her.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "And that how I saved the second time from Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "We went to the Lippstadt.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "That Lippstadt is on the border of Holland and Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "We worked in a munitions factory.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We were all three [INAUDIBLE] together.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And all my pregnancy, I was working day and night, most likely at nighttime.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We went for shift work at night time.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Which life?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In the munitions camp?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Well, the munition camp, when we arrived-- of course, after Auschwitz, it was luxury.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We had a wooden bed that we can sleep on it.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We had a bathroom that we went to the toilet and wash ourself.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And we got some food.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "We got some food from outside every day.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And there was always somebody else who was in the kitchen, who served.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Most likely, the people who could speak German-- they took the German people from against us.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And when I was with my pregnancy, really on the end, I still went to work.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Only the last three weeks of my pregnancy when I was already nine months old, they kept me in the-- at home.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "But I didn't-- I had to do cleaning.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "I had to go to the kitchen, different things.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "When my child was born, it was a very quick birth.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "She was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "But after that, I became very ill.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "I couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have to hide it.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "There, I didn't have to hide it.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "There was other two woman who was pregnant, too, from different sections.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They came from different lagers.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Their child was born there, too.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And one of them live in America, that child.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "It's a boy.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I can't remember their names, because it was so long ago.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And there was a nurse, a Czechoslovakian nurse.",
      "word_count": 8
    }
  ],
