{
  "stem": "14687.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And I say, no Auntie, Aunt Amelie, they are-- they are going to come back.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "Maybe they went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "They never came back, you see.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And then my sister, Felicie, also she got sick.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "They took her to the river, to the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "We never saw her again.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "So we were myself and my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "My sister, she was older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "And I [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 18,
      "text": "I used to look after herself, because she was sick also, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 19,
      "text": "And then I'm going to remain alone.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 20,
      "text": "My brother was in the other camp.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 21,
      "text": "I never saw again, because they transferred him to the other camps, you know, Buchenwald or-- I don't know where he went, [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 22,
      "text": "But he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 23,
      "text": "In any case, I was looking after my-- my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 24,
      "text": "So my food, I used to give her.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 25,
      "text": "I was so hungry one night, so went to lick the barrels, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 26,
      "text": "And the German came.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 27,
      "text": "He said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 28,
      "text": "Come, come.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 29,
      "text": "So they sit here, too.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 30,
      "text": "Now, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 31,
      "text": "And I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 32,
      "text": "They're going to kill me.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 33,
      "text": "They had the scissor.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 34,
      "text": "I don't know what they're going to do.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And my sister say, why you did this?",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Why you did this?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I said, because of you.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Because I want you to survive, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "So what they did, my hair they were growing already a little bit.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And they cut all my-- again, my hair.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And they put me in the snow from 6 to 9 o'clock in the evening.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "From 6:00 in the morning?",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "In the morning?",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "From 6:00 in the night--",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Until 9 o'clock.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And then I went to work, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the punished me.",
      "word_count": 4
    }
  ],
