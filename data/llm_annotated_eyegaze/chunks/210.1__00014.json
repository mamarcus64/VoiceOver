    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "And [SIGHS] there were no doctors.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "There was just like a-- like a-- what they call a [NON-ENGLISH], you know, like now you could say in-- like a nurse-- nurse's helper, or whatever-- something like this.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So he came to see what's going on with my father.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And he had a high temperature.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And he just stopped eating.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And my father was very tall and a very strong, strong man.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And he just dwindled down to nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He just stayed in bed.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He didn't want to get up anymore, and just stayed there.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    }
  ],
