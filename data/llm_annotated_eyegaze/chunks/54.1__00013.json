  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The same girls, the same people, came to Salzwedel.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And we came 1,000 people, 1,000 girls.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was girls, and some-- you know, it were the mothers there, but without the children.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "It was sisters, to two sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I know only one was-- she had a sister.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "It was one of my friend from my hometown.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "She came with her sister.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "But the rest of the people were all single people.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "No.",
      "word_count": 1
    }
  ],
