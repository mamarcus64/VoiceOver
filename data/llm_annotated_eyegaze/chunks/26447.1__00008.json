{
  "stem": "26447.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And we came to the ghetto to Kolki.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And that's time when we went to the ghetto Kolki.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They beat us.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "They are doing terrible things.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Now, when we came to the ghetto, now, the ghetto become that was maybe in Kolki, maybe a 10 blocks around.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And it's full with Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And they take us in our room where it's a small room.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "The take us five, six until to 10 persons in the room, no food, nothing with we can buy anywhere.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "No what, the food it was dry.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "Who got the clothes, we got a little.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "If you can exchange somewhere you got suit for, you give up for a piece of bread.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "For a-- a pound bread, you give the best-- the best suit.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "And I will no beside, beside that what they was doing, they begin to do more wrong things and bad things.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "They put us up front, a piece-- a piece of clothes that's yellow color.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "They big.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "That's approximately by, oh, by 6 inches the diameter.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "One piece-- [COUGHS] excuse me, please.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "One-- one piece up front and the second piece in the back where they can see-- [COUGHS] excuse me.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Where they can see but we Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "They came-- they at night time, at day time.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They begin to shot in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They done what they want.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They rob us.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They now take us to work.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "The work, it was a different kind works-- work.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Where they cannot send-- find to work from the Ukraine people, they send us.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "The work, we work in the farms.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "We work in the where the horses, they got the Germans, to clean the horses, to clean their bathrooms.",
      "word_count": 19
    }
  ],
