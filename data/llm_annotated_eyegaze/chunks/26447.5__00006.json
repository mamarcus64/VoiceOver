  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And I came to a city that's near to Kiev, very close.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "A city like Brovary.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "There it was 19-- I think 1970, or '71, approximately.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "No, and we stay, and I was working in a building organization.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "No, we tried to work how we could, the best-- because if you will work bad, somebody [? who ?] don't like, and I-- I won't to promotion too.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "It's better for yourself and the-- and the children.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "Then it became a time when people begin to go out from Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "I helped know a lot of people-- helped to go now [? in ?] Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "No, by myself, I didn't get the time like in that time to go out-- I got afraid.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "Maybe who knows how it will [? be ?] children.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "I-- we didn't care most for ourself, I and my wife, we care for our children, how it will be.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "And I got time what to find a cousin in Canada.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "That was in 1973.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "And I-- she sent me for an invitation to come to Canada for a-- for a couple of weeks.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "I come to the government, the Russian government, and I told them that I want to go.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "From Russia, they don't give permission to go, at that time, to go out from-- from the country.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "No, I was nice-- I got work here, and nobody can tell me what I'm not-- drunk, or what I can be drunk, or what.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "No, and they give me permission-- 1973, I went to Canada, and I saw this life in Canada.",
      "word_count": 18
    }
  ],
