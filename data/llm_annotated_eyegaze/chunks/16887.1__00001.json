{
  "stem": "16887.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "The baker's daughter, she was about five years younger than I was, and she was a little retarded and needed help in school.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "So every day after I did my homework, I used to go to the bakery and help his daughter.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "I can't recall her name.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Help with the lessons.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "For that, I used to get paid $3, like three [NON-ENGLISH] a week.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "Which I never collected, because my mother would go every morning and get bread and rolls for the family.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "By the end of the week, there was nothing for me to collect because she used up all the money in bread.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "And after I finished school, and I went to work, I went to work with a dressmaker.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "When I finished school, I was 14.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I went to work to a dressmaker, learning, worked very hard.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And got paid a little of nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And still after work, when I returned home, before I used to go home, I used to stop at the bakery and help his daughter with the lesson so my mother would continue taking bread everyday, bread, a roll, whatever, a [NON-ENGLISH] for Saturday.",
      "word_count": 44
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And that's the way I used to help out my parents.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents were very simple people.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My father had no education, and so did my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They had no education.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But they were very good parents.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "In the wintertime, my father didn't work because my father was a saddle maker.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And in most of winter, he had no work.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And sometimes, he used to go to shovel snow, clean the streets, so he could get some money to support us.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "In the time that he didn't work, he used to play with us.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Not only with us, but I remember neighbor's children used to come up.",
      "word_count": 13
    }
  ],
