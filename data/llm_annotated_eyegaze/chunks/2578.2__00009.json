  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Because in the-- you see, all these-- all these informations came in later on, when we started to gather and to talk to people and to read about it and so on.",
      "word_count": 32
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Because in 19-- in 1945, they-- they stopped exterminating, because they didn't have the-- any more facilities.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Most-- I mean, some of areas in western Germany was already liberated by the-- by the American army or the British army.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Part of Poland, or most of Poland, was liberated by the Russian army.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "So that-- people were still dying by the thousands, by the tens of thousands.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "In my camp alone, hundreds of people died after the lib-- after the liberation, because they were so far gone that the-- the care that we got didn't help anymore.",
      "word_count": 30
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Dornhau.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "This is the ca-- the camp where I was liberated.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "This camp primarily was for sick inmates, except for one group that still did some work.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And I would imagine, according to the work that I started to do eventually in this camp, that it was not for the sake of work, but it was for the sake of the German SS to guard us, and of the civilian few German men who supervised our work.",
      "word_count": 50
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Only to keep them occupied, or for them to have a reason to be occupied.",
      "word_count": 15
    }
  ],
