    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And they were-- and he was going there at night.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't have contact much.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But then the Germans start taking people on a selection.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was in September.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They were taking people on a selection, and they put us out like soldiers.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And whoever had a child, or who was-- looked older, they put on one side.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And the other people they put on the other side.",
      "word_count": 10
    }
  ],
