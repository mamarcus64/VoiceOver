{
  "stem": "25639.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[SIDE CONVERSATION]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good morning.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "At the time of my birth, my name was Zora Hollanderova or Hollender.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "H-O-L-L-E-N-D-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My birth date is January 20, 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My age today is 67, and I live in San Francisco, California, USA.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I was born in Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In a small town, in the suburb of Beregszasz.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Nagy Bereg-- N-A-G-Y B-E-R-E-G.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Beregszasz is B-E-R-E-G-S-Z-A with an umlaut, S-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We lived only 8 kilometers from-- from the city, so--",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My dad, and my mother, and grandma lived with us-- or we lived with them-- in a seven-room house.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And we had a big barn with cattle, horses, cows, and we had chickens, ducks, turkeys, geese-- animals you find on the farm.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And we had cats, and we had our dog.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And we had a well on our property, which was unusual in our area.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Later on, we had indoor plumbing.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] My dad and mother owned fields-- grape fields, a vineyard.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And so dad was a winemaker.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And we had 24 pieces of land.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "We had a threshing machine, which went from farm to farm.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "It was rented out when we didn't use it.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And it-- we all-- it-- it provided us with additional income.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "This was in partnership with two other non-Jewish partners and friends of my father's.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Mother and dad also owned a-- a store.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "He was-- he was a [HUNGARIAN]-- that's a Hungarian word for someone who runs a variety store.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Mother and grandma, really, ran the store, and dad and mother would shop on every Wednesday in Beregszasz or Berehove, which was its Czech name before 1938.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "Unfortunately, in '39 we had to close our store down, and we had to depend on the farm for sustenance.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My dad's name was David Hollender-- H-O-L-L-E-N-D-E-R.",
      "word_count": 7
    }
  ],
