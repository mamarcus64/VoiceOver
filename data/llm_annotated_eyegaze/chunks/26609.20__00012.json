  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "She want to keep her for Jesus Christ.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So when she left with her children for the market, well, she fed her children and didn't bring home anything for my daughter.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She looked up and had seen the sugar there, and she needed sugar because she had not eaten, low blood pressure.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And sugar helps, she felt it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I don't know how she got up there.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I don't know-- she had a ladder.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "But she said-- she told me later.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Said Mommy, I went up there-- maybe she had a ladder-- licked it, the sugar, a little.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "She came home, the woman, and had seen-- it was all dusted and when she licked it off it was white sugar underneath.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "She had seen it.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And said, did you touch that sugar?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And she was afraid to lie.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "She said yes, I was hungry.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "She hit her a few times.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Said, I didn't do it anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Then she said on the-- that the place where she was, it was a big square-- We'll continue next tape, sorry.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "End of this tape.",
      "word_count": 4
    }
  ],
