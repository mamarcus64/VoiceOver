  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, during the, the period when I was in Poland, or what, I-- being in the army, we went out in the army.",
      "word_count": 27
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And it was there three couples walking on the street.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And they recognized me, or I recognized them.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "They are Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And we start to talk to them.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And they told us they had been hidden on a tree-- on a tree in the, the first time.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "They used to go out at the evening to get some-- this is during the summertime.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "During the wintertime, they couldn't go out on the street because they'll be-- they'll be marks from the foot.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "So they didn't go out.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "They went out during-- when it used to snow.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "Then they go out to get some-- get some food.",
      "word_count": 10
    }
  ],
