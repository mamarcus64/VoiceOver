{
  "stem": "9245.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "We had a grocery store.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "And everybody pitched in to help out in the business.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "We had a very, very happy life, a happy childhood.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I had a very happy childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We were-- we were an huge family, probably close to 200 people.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My father comes from a family of five brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And each one had about five children, four children.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Berl Barman.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Sonia Barman.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And we kept together.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Friday night, everything stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "My father went to schul.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "We observed the Shabbat.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "The Shabbat meal was a very happy occasion.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "We sang the zemirot, the Shabbos songs.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And everything was circled around religion.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And also, we were also tuned into Zionism.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Our dream was, one day, to immigrate to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was-- I was, ever since I can remember.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I must've been about maybe seven, eight years old.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I was in-- I belonged to a-- a Zionist organization called the Halutz, which is 'pioneers.' And we used to get together and sing songs and celebrate the fact that someday we'll all be united in our own homeland.",
      "word_count": 39
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Because Poland was a bad place to live in.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we had-- we had neighbors.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We actually lived on the outskirts of town.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We didn't get involved, except in business.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They used to come and buy merchandise from us.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And the outbursts was always remarks about the Jews are cheating them, and the Jews are no good.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "The Jews are a threat to their Polish society.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And in school, actually, up until I was 14 years old, I was in my Hebrew school.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "So everything was in Hebrew.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "As a matter of fact, there were no gentiles.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "But after that-- I graduated in 1937.",
      "word_count": 7
    }
  ],
