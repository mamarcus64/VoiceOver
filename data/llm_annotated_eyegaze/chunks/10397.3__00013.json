  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING] The father-- farmer was crying, everybody.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "[SOB] Took her back.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I never saw her again.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I never saw them again.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "[SOBBING] 20th of May, liquidated.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Took them to the woods, everyone.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "That's their technique.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And the-- the Ukrainian police helped them.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And the Polish fire department helped them.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And the Polish fire-- firemen carry a-- a hatchet.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "You know, if they go to a-- a-- a small hatchet.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "You know what is a hatchet.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "They go to, when there's a fire, to break up, when something is in the way.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "You know, to take care of the fire, they break up, with the hatchet, the wooden structures.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "And if that-- the Jews didn't want to go, they break their feet with the-- with the hatchet.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "That's the Polish-- Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And Ukrainians had guns.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "It was the militsiya, the police, with the guns, with everything.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "That's the-- the end of it.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "And the 20th of May, that was the end of it.",
      "word_count": 11
    }
  ],
