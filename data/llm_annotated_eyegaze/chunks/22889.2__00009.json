{
  "stem": "22889.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We were, like I said, we were deprived our education and so forth on.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Different was we start to go to work.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We become right away a slave.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "My first job for instance-- I was just 13 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "My first job was I was assigned to the chief of the Gestapo.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I knew this fellow before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "He become a chief.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "He must've been a spy or something.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "He lived in our town before the war, never used the language-- German.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "He spoke perfectly Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "Later in the program, I come back what happened to him.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "When the German came in, he become a-- we used to call him [GERMAN].",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "He used to wear the party-- he was a party man.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "Hakenkreuz he used to wear on his lapel.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "And he knew my family because used to come to our house, used to drink the soda water.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "See, we had a big porch in our house and people-- we had a table.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "People used to come down-- beside what we sold to the stores, people used to come down and buy a bottle of seltzer and sit down and drink.",
      "word_count": 28
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "The Monsignor from the church, he used to come every day to our house.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "He were very good friend of my dad, and they used to drink the water too.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "And he, this guy, this fellow, he used to be organist in the church.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 20,
      "text": "His name was Roman like my name.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 21,
      "text": "Polish, I'm Roman, but his last name was Roman.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 22,
      "text": "Nobody, I mean, thought about things like that.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 23,
      "text": "When the German came in he became was a chief of the Gestapo.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 24,
      "text": "He knew exactly every-- he knew all the Jews in town.",
      "word_count": 11
    }
  ],
