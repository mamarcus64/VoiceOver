{
  "stem": "6837.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "After I went into the door, which was pointed-- he pointed me to, I looked back.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was very sad that I had to be separated from my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And my mother looked back, and we waved.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And that's the last time that I saw her.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I went to the group that it was before me, and I knew some of the girls there.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And I was happy that I knew somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "But I was very sad that I still was alone without my family.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Then after a while, my younger sister, who gave her child to my mother, came running.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And we embraced, and we kissed, and we hugged, and the two of us was together.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "So it was a little relief that I wasn't alone.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "We went to a big hall where we had to get undressed.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And they took-- took us in another room.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "We had to shower.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And they gave us gray uniform dresses.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "We were not allowed to go back to take anything from our own clothes or anything.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "We just left them in that hall.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I also carried with me a briefcase with my-- with our citizenship-- with our citizen papers because the first ones who were deported from our city was those who came from different countries and they were not citizens.",
      "word_count": 38
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "To prove that we are citizens, proudly, we took that with us but we left it there.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They shaved our hair completely.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Girls.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "They were prisoners, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They were prisoners who were there before us.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And we begged them not to, but they didn't-- they didn't help.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It came to a point that we looked at each other, and we were laughing.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We looked like-- everybody looked the same.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "My sister hardly recognized me.",
      "word_count": 5
    }
  ],
