{
  "stem": "443.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I was already almost 19, 18 and 1/2, 19 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And this is what we did for a while.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And after that, things start normalize a little bit more in the camps.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And the Joint-- that's a Jewish organization-- they started to give out clothes, started to give out shoes.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "They gave us better food already in the camps.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And they started to organize businesses.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "People opened up a little bakery, if you were a baker.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "If you were a merchant, you were selling stuff before, you started to handle.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "You started to make business.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And then, we started to deal with coffee, with cocoa, with cigarettes, liquor.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "This was all on the-- on the black market.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "[BACKGROUND NOISE] You couldn't buy in a regular store, because the military used to get that stuff.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And somehow, it wound up in the camps.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "In the camps, they started to make black markets.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "So we used to take this stuff, we used to go-- now, later on, we already had trucks.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "I mean, not our own.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "We used to rent someone's truck, and we used to go.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And we used to go into the cities.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "We used to sell the stuff to make some money, till the Germans started to clamp down on the black market.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "That's when we stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "We stayed in the camps.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "And I waited till I got the papers to come to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "1949.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I had-- actually, I had two uncles that time that I waited for the papers.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "One lived in California, one lived in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Whichever one's going to come first, that's the one I'm going to go to.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So I happened to get the papers from New York.",
      "word_count": 10
    }
  ],
