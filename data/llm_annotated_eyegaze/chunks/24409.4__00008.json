{
  "stem": "24409.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And for whose arrival not proper, preparations are being made.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I got some money.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I got 300 pounds form Mrs.-- she was a very known millionaire into Zionists.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "The owner of the Marx department stores.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I don't know her name now.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "It's mentioned in my book.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I got the 300 pound contribution, which is a big amount.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "It was a fortune.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And the day afterwards, she called Jabotinsky.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And told Jabotinsky she did not know that this is the revisionist undertaking and she withdraws her support.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And I hadn't cashed the check yet.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And Jabotinsky said, you have to return the check.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "And I said, I don't want to.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "But he was very much of a gentleman.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "He said, you got it under false pretenses.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "You have to return the check.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "I told you this.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "We can save many people because we have already the down payment for another ship.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "No, you have to return it.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "It was obtained under wrong pretense.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "And I returned the check.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I was in England and some other people were-- prepared the next transport.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They went to Athens.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They got money again, foreign currency.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "You know, this is, we said, foreign currency.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "It was foreign currency in Germany at this time was like diamonds because they needed all a foreign money in order to get more weapons.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "They were preparing for the war.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "But they had again got foreign currency.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Had gone to England, to Athens, and had paid 2,000 pounds for a ship this was showing to them with the name of And then when we were back in Vienna, and trying to correspond, this belonged to other people.",
      "word_count": 40
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "They had been the victims of swindlers.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And it was what happens.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "They decided to leave anyhow.",
      "word_count": 5
    }
  ],
