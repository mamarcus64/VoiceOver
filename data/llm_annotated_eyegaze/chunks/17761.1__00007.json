{
  "stem": "17761.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 141.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And we were deported together.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I do not have any brother alive now.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I had one brother called Menashe, [NON-ENGLISH], M-E-N-A-S-H-E.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He passed away at the age of 11 and 1/2 on a heart condition in Arbore and is buried there.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "A few years ago I was there and his gravestone is still there, fully readable, and I have pictures of that.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I could say kaddish there, despite the fact [PAUSES FOR 3 SECONDS] I didn't have any minyan.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I beg your pardon?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Next child--",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "--that's me.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And then I have a sister called Chana.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She is born 1932.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "She lives actually in Israel, in Hadera.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Married, has three children and grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Baruch Hashem.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Gur.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Chana Gur.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Her husband is [NON-ENGLISH] Gur.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And then I have two twin sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "One is Miriam, married to Baruch Friedman, F-R-I-E-D-M-A-N.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And they live in Petah Tikva, Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They have also four sons and grandchildren.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Baruch Hashem.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And then the-- the missing kid, that is Rachel.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "She is born two hours later than Miriam, about two hours.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And she's married to [INAUDIBLE] Rabinowitz, R-A-B-I-N-O-W-I-T-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And they live in Immanuel, Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My daily life in the little village, I have to make-- to separate my little village from what went then all in Vatra-Donrei.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But in the little village, I used to go to the cheder.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "That was all the day.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "We used to play very simple play-- games like hiding-- like hiding on trees.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And when I came, as I told you, 51 years later to that village and I found the tree that we used to play around in the garden of my grandfather at a little river which is going there, a lindenbaum, I can tell you I cried.",
      "word_count": 47
    }
  ],
