  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "But judging from the age of these young inmates, that they were shipped to Auschwitz because they were not capable of doing any work.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I knew the-- I-- I-- he mentioned to me the name of it, but it was some sort of a remote, small camp that it didn't register and it didn't-- it didn't have any consequence for me to remember.",
      "word_count": 39
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, a mutual--",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "He was, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But he was not returned to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "No, because-- no, because he was older than my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- a-- a usual, a normal inmate, that he did work in the camp, that-- together with the others.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "That he saw my brother in this camp, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
