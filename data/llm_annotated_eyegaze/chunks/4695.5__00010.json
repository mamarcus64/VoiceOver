  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "If he was afraid, then he has not a right to be.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "You know, he was crying.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "He tell, nobody, nobody give me this to understanding like you showed, like even from the history a little bit, you see?",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "Then he understand that.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Now, so is life.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You see, now you hear in  the papers this wasn't true.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And this wasn't true.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And this wasn't true.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I don't know-- it's been deep in my heart when I see the-- from hundreds families, nobody survived, even [INAUDIBLE] not survive-- like from my cousins, from my mother's side, from my father's side.",
      "word_count": 34
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "It is, it is the story.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I like something must be learned from that.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I like children in the schools supposed to know that, not to hide how hard the truth is.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "But give it to them to children and [? keep ?] children.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Let them know what was our past.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "OK, thank you for listening.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "After we left Poland, we went to Germany, in Heidenheim.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We came to Germany through Austria in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And we went in-- to Heidenheim.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "In Heidenheim, I start working as employment officer in the UNRRA.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But that was a short time, only 18 months.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Because I cannot take it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "This was a long time.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And the first immigration that was open was Norway and Holland.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "So I chose Holland and come to Amsterdam.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We have-- when we arrived was around two o'clock the, in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We arrived in Amsterdam I think in 19-- [INAUDIBLE] 1951, no, 1947, [INAUDIBLE] 1947, and I think in December, was it in?",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And comes people on the station to us from this city for this city, survivor [? was. ?] And comes one gentlemen.",
      "word_count": 22
    }
