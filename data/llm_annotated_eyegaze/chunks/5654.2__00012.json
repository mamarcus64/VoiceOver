{
  "stem": "5654.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And we found out they were working for the-- for the German unbeknown to the Swiss people.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "They followed, and this-- this couple, at the end of the week, at the end of the week were allowed to go out shopping for all of us.",
      "word_count": 28
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And they managed to compile a whole list of the people.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Because people used to come daily from - from France, or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And they'd compiled a list.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And they'd put it into a tin in the forest outside Geneva.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And it was an espionage.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And this is how they used to pick up, say, parents that you had left over there, that you had left in France, or whatever.",
      "word_count": 25
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So they arrested these people.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And we moved away from the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "They put us into another camp.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Can you tell us about the-- the interview that you had with these people?",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Well, they ask us, actually, where are you from.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They asked us, you know, are your parents still living there?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Or, do you have an auntie?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Do you have cousins?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Where do they live?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They wanted to know everything about.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And they did the same thing with my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And, of course, my sister, you know, she was older than us.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "She was six years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So she knew exactly what to say.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "She was 16 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And yet, she didn't trust anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "She's a most amazing woman she is.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "You know, she had suspicious.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I mean, you know, she didn't have a-- a youth life.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "She was born, and immediately she was an adult, because she looked after us.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes, as well.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Well, we missed our youth, virtually.",
      "word_count": 6
    }
  ],
