  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "And I went back to the-- I stayed with the-- in the boss's house, by the way, in the engineer, because it's-- it's a common thing when you go to work in those years, you stay with the boss, and he gives you room and board, and so on and so forth.",
      "word_count": 52
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "And of course, his wife, and his son, and his daughter-- they were all there.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "They were terribly upset.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "And finally, the order came, whoever pays enough money or has ways to leave Germany they would release from Dachau.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "So about three, four weeks later, this engineer Guggenheim was released from Dachau and with his commitment and promise that he would leave Germany.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "And he had some relatives in Bogota, Colombia.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 32,
      "text": "So that's where they migrated.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
