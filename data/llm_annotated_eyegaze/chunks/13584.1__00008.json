  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "My mother used to-- told me to be quiet-- shush, still-- that I shouldn't say a word.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And they were crossing the border.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "The border, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And that's what I remember-- night, these, these walking through the freshly--plowed fields, and my mother saying, [NON-ENGLISH], don't say a word, you know, be quiet.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I remember that we were not alone.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "There were another group of also refugees crossing the border.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "We were not just, just alone.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Apparently, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I even don't remember this.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I know I had a tag here, with apparently my name and address and whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "This I remember, attached in case if I will get lost or whatever, to find me.",
      "word_count": 16
    }
  ],
