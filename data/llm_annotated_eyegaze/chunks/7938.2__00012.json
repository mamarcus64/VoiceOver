  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I told him that I have a notebook.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And I wanted to reach in the packet, but then he jumped on me.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "He caught my hand, and he told me, don't reach for the packet.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "What is there in this book?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And I told him.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Finally, I took out the book.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "He was reading it And what was in the book?",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "It was a book I had notes.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Whatever I have to do today, what I have to bring back, what I have to adjust, some people, some on the job, what I had to do.",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He gave it back to me.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "He hit me twice in the face, and he give me-- give me a kick.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And he said, OK, you can go in.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So we were lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I think that this was a distraction, and that's why he didn't ask for anything else.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But it-- it reminds me a certain passage from from the film, where he-- where he, Schindler, tells him once, he said, a sign of power if-- if you can forgive.",
      "word_count": 31
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] He-- he stuck to it for a few hours, and then he came back to his normal life.",
      "word_count": 22
    }
