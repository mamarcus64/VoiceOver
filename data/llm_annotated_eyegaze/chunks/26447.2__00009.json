{
  "stem": "26447.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And I hear from the-- from the barn how they cry, how they-- it's terrible voices what how long I will live.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "They-- [SOB] [PAUSES FOR 11 SECONDS] I will never forget.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And in a couple hours, it become quiet.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "They killed everybody, and it become quiet.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And it's come in maybe-- I don't know how you say.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "What, in a couple hours come the owner from the barn and say to the survivor, who was a lady.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "I don't-- I don't know who was that.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "And he said what the policemen, they-- the Germans tell her to take the-- the-- where they killed the people.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "Put them and to bring them to the-- to the places where they shot the-- all the Jewish people.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "And I hear what he explained to the-- to the lady.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "What they shot a lot of people and what they're doing.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "They shot all of them.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And he left for a while.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "It's hard to tell, a half hour or 40 minutes.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "Then he come back.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "And he said what he put the killed people.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "He put them-- he take them to the place.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Know what to do.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I hear-- but I cannot come down.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "What to do further?",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I don't know what to do?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Then, I stayed that's the-- until night.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I need to wait to the night, nighttime what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I decided I was beginning something.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My brain begin a little to work.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I was thinking-- I was born in the Komarove-- that's the village.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I know the people.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Where I know the-- the places where I can hide myself.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I-- I-- I need to go, and how to go.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "If I will come back to the ghetto, they have a bridge.",
      "word_count": 12
    }
  ],
