{
  "stem": "26609.14",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "I said, don't do that, because I knew it was a talk before that no rape [INAUDIBLE] it was not allowed in Germany, not with Jews.",
      "word_count": 26
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I said, you know that's not allowed to do it.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You said I'm Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I say that you are Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Why you are doing-- why are you coming just very near me?",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I said, otherwise, all right, I'll go with you.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I knew that they were married men.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Take me to your place.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Then you can do anything you want to me.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Just take me to your place.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I want to go with you.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I rather like you.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And the other one said, leave her alone.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Just leave her.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "They left me for good after this.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "They tried everything.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "They couldn't get far.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "So they left me.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "As they left me, I took a deep breath.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "And I thought, no, in middle of the night, I'm not going.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "They left me for good.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "They couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "Or they believed me.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "I acted, you know, as a non-- not a Jewish woman.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "But I couldn't go home to see my daughter.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "So I waited all night.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "In the morning, I had a good look around.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "They were nowhere to see them.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "And I started to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 25,
      "text": "If they would see me walking two hours, they would be behind me.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 26,
      "text": "No one there, they left me.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 27,
      "text": "They had enough.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And as I went in, the child started to cry, and said, Mommy, Mommy, [?",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Trisha, ?] the name of her daughter, of the woman's daughter. she was 9 years old, was [?",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Trisha. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Trisha ?] said that the German killed mommy.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Mommy's dead.",
      "word_count": 2
    }
  ],
