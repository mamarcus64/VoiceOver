{
  "stem": "11771.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "They used to come to us.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "He came back home.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "And he beat up my mother so badly that they took her into the hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "Well, now got-- they start to be after me.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "But I was on the farm.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And that was a German, a passing by German.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "It's like a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "They're not stationing in the-- there that was a SS, an army SS.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "After two days, they left.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "The unit left Ejszyszki.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "And we almost forgot the incident.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "I wasn't in-- at home.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "For three days, I was in the peasant house in the farm, hiding in the barn.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "And that's the way we live till Rosh Hashanah, 1941-- all kind of humiliations, embarrassing the Jewish people.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "And 1941, Rosh Hashanah came.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "A order came that all-- all the Jewish people had to concentrate in the three synagogues from our shtetl.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "The-- the Lithuanian police came from street to street, from house to house.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Everybody should concentrate them-- all the Jewish in the three synagogues.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And it was Rosh Hashanah.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You know, everybody got a little something prepare, according his-- possibilities.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But everybody has something on Rosh Hashanah-- challahs, soup, [BACKROUND NOISE] and chicken, whatever they're preparing.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] Mine three sisters, like I tell you before, wasn't at home at that time.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They were over at their boyfriends or with their girlfriends.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I came.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I was-- is at home with my younger brother, my mother, and my father, and also a sister of my grandmother.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "She was living with us.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "When I came in our home, I find only my mother and my-- and my brother.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "My father wasn't already-- he was already in the shul, because I wasn't home.",
      "word_count": 14
    }
  ],
