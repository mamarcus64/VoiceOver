  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And after he went to Los Angeles for a specialty-- Los Angeles, City of Hope, hematology and oncology, blood disease and cancer-- when he finished this, [PAUSES FOR 4 SECONDS] they-- I think they moved over here before, I don't remember exactly.",
      "word_count": 42
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "I think they moved to Los-- they moved-- yeah, they moved over here.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "And they got an apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, this is-- and then they moved over here.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And he got-- he was working.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Where he was working?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Oh, oh, no.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "While he was still in school, when he was finishing the school, two people came to the school-- if the school could recommend somebody in this-- in this-- in this hematology and oncology, they're looking for somebody, a good doctor.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "So they recommend him.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And they took him in.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And later, he became a partner.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And now he has an office for himself in Cedars-Sinai Hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And she works in Los Angeles, Yeshiva University Med.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And they-- they got the two kids.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "One is-- one was two years, [?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Leslie ?] had bar mitzvah.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And the other one is going to be, I think, next year, something like this, yeah.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And they bought a house.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And they are very-- they are living a life.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I mean, very-- he's a very, very nice man.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "His mother died-- she was 42 years-- died for cancer, I think, in Brooklyn, before the wedding.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And his father married another time, a very nice woman.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "They live in Florida.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And he has still in Brooklyn, in Long Island, a sister.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "She's going to have a baby today or tomorrow because they coming home tonight from the-- they went skiing someplace, Utah or someplace.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So he's going to go.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "But they know now what's going to be a boy or a girl.",
      "word_count": 13
    }
  ],
