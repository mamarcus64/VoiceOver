{
  "stem": "597.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I finished there with where I was, in the attic, with my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And my-- my sister came up.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Because the place where she was sit-- staying there, the woman says she cannot keep her.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So she came back to [INAUDIBLE], to [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "She know-- knew that I am there.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And she was talking to him.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "He says, you can go to see your sister at night.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But I cannot keep you.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I cannot keep two people.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I keep only one.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "If you want to stay here, you have to go, both of-- both of you have to go.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And he didn't know that I am there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "My mother was there, too.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So she came up, and she start crying.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And all night, we stopped talking.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My mother picked herself up with the-- with my sister and left me there.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It was gone-- it was really cold already.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was winter, December, November, the end of November already. '42, November '42.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Then my mother said I could-- she couldn't-- she didn't want to go see me no more.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But in down-- downstairs in the-- in the-- in the barn, she used to come up.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And she-- we'd-- I'd talk to her.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "She says I have to come up and talk to you.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "So come downstairs to the barn.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And there is some-- some cracks between the-- between the wood.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And look me up there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And I'll talk to you.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I'll tell you what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So every evening I used to go down and look through the cracks, to see my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I-- and I used to spare food, whatever she bring-- the-- the woman gave me, the Tedoch-- Mrs.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Tedoch give me.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And I hand it over to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Because maybe she was hungry.",
      "word_count": 5
    }
  ],
