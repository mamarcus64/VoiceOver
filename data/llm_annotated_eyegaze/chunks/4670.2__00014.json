  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "There was a sign along-- in-- inside of the-- the vestibule, there was a sign that said [GERMAN], which means restaurant [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "They had a Magen David.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "Not only that, he had a very large-- he had decided on a very large white sign, a glass sign-- you know, one of those block things-- and it will-- should have a Magen David, you know, the Star of David in it, which was audacious.",
      "word_count": 46
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And we thought he was crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "We-- you know, why advertise something like that?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And he felt, well, the Jewish community needs a restaurant.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We're here and we're going to give it to them.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And we said, they're going to break the sign.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They're going to come [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And my father said, I'll handle it when it comes.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So he opened this restaurant, and again, we were the waitresses.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "He did even more.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "He hired two-- well, this time, my mother was not the cook.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "She just sort of supervised.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "We had a woman-- a man who was a-- a cook, who was Jewish, a woman who was his helper, who was Jewish, one waitress, and then there were two other waitresses who were not Jewish.",
      "word_count": 36
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "It was interesting.",
      "word_count": 3
    }
  ],
