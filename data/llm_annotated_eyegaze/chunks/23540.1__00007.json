{
  "stem": "23540.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Oh, 7:00-- he was working, sometimes, night time, my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And he come from work, and I go to work.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And we see each other only a few minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And I come back around 4:00, 5:00.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "I cook something there, and he come.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "Now, he was coming in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "He left for work.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "By matter of fact, we didn't work hard over there, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "We're talking.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Do-- we clean a few rooms.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "It was not much work.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Very nice.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I have very good friends.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They bring me food.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "They come not in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "They come to the work where I was working, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And it was a German man over there, looking-- guarding us.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "But it was nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "I can still talk with somebody who come.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we have.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Wait, we have radio?",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember that was allowed.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Because once radio-- we have it in-- not in ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And the German one day come knocked to the door and pick up our wireless.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "But in ghetto, I don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "Maybe it was not-- we are not allowed to have radio.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "I don't-- I don't-- I don't think so.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes, absolutely.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Everybody, the people listen, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "It was not allowed.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "But that people listen still to the radio.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "Everything we know was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "What you hear, that everything is-- that the German are going.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And they take everything, whatever they can.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Everything was good for them.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Even when it was not good, they say it's good, you know, what you can hear.",
      "word_count": 16
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "Never you see the truth in-- in wireless.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Synagogue?",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "You know, I don't think so, there was synagogue there.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "I didn't go over there.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "Maybe it was.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "Maybe people pray.",
      "word_count": 3
    }
  ],
