{
  "stem": "18626.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And she kept it until then.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Your mother--",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Actually, she didn't give up my little brother.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "She went with him on the lap.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But I mean, she--",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In secretly, everything.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "The Jews had to wear that Jewish star.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people who walked-- who were in the ghetto, they used to go out-- out of the ghetto, you were all the time had to wear that star of David.",
      "word_count": 30
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "That was the order in the ghetto when-- [PAUSES FOR 3 SECONDS]",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "It was before, before the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It was August-- it was July the 12th.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "July the 12th was given that order with every Jew must wear a star.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "If they are caught without a star, they are going to be shot immediately.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Everybody had to make stars.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Material.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "You give-- you went to the committee if you didn't have, or you went [PAUSES FOR 3 SECONDS] to friends, and you to find yellow material.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "One got from the other, you made stars.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was a certain size, the star.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I think it was like 3 and 1/2 inches.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I don't know on the centimeter now.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But 3 and 1/2 inches.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Almost like 4 inch stars.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "On the left side, [PAUSES FOR 3 SECONDS] right, actually, on your heart.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So when people walk-- walked out, you know, as you were walking outside of the ghetto, you were still wearing the star, unless you took a terrible chance and you took off the star so you could go in-- in a lot more areas, because the Germans then didn't know if you are Jewish or not.",
      "word_count": 56
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But you took a big chance.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "If another Lithuanian would notice that you are Jewish and you are not wearing the star, she would right away give you out.",
      "word_count": 23
    }
  ],
