{
  "stem": "22889.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Our house, before the war, as a matter of fact, what they used to call [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "It's a Jewish word.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "It was an open house.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "Any poor people, any dignitary came to our town, stay in our house.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "My parents, they never turned down anybody, never.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "Before the war, these people used to come to our house.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "They used to play cards every single night.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "It was brought-- it had been like this for years, for generations, from my grandfather.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "Because he had this kind of business years ago, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "So they came to our house and stay over there.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And my aunt used to live across the street.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "They-- she had to get out from the house.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "She had the two children, my Aunt Mala-- and moved to our house-- my aunt, the older-- my mother's older sister with the two girls.",
      "word_count": 25
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "She was one of the professors of the university that was in Dresden.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "They were grown up people already.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "They were in their 20's-- late 20s.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "They all moved to our house.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "They had to get out.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "So we lived like that.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "August the 30-- when I came home the 28th from work, my father came home.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "It was 10 o'clock.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Nobody knew about it, but the people for the-- from the Jewish-- [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "How do you say?",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "Leadership.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Leadership.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "They knew what was going to be.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "The order came out-- all the Jews must report to the stadium in the morning by 7 o'clock, 8 o'clock in the morning.",
      "word_count": 23
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "My father had to leave early, because he had to go gather the Jewish people.",
      "word_count": 15
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "He was the councilman in the Jewish community, my dad.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "So my father told my family, everybody, what we have to do.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I never forget.",
      "word_count": 3
    }
  ],
