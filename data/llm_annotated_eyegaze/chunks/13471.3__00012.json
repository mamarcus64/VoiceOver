{
  "stem": "13471.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "The backup-- one of these double names, Hoodington-Smythe or something, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Something like-- anyway.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And as anything you cannot do it in a court like that is have everybody's English come up to the super Oxford Cambridge aristocratic levels-- I can't do it in one word.",
      "word_count": 32
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, frequently.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And we'd just have to-- mostly we just ignored him.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Quite-- quite well, quite well.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Talking about this alternate British judge-- I wish I could remember his name.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "We had Sprecher, Sprecher--",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, not Sprecher.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Well, anyway, a US-type from New York-- Brooklyn, I think-- had, had, the, the, the Deutsche Stunde on the radio.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Prior to the war, you know, they'd have the Deutsche Stunde and the Yiddish Stunde.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And then they would have a-- a French hour and a, I don't know--",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "In the States.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And we, we picked him up from that, you see.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And his English was quite good.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "He was quite sharp.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "He was a-- He was a captain in the US Army.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes, an interpreter.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Why don't we take a break and change tapes?",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And we'll talk some more about the court.",
      "word_count": 8
    }
  ],
