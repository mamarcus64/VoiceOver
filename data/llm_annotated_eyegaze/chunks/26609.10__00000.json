{
  "stem": "26609.10",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I don't think you-- pardon?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The doctor was in the other part of the hospital.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And doctors, they started-- they treated her.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And the Ukrainian sister told me this, and how I begged her to keep her if she survives.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And she said to me, where did you come from with her?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I said, from the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "She said, you can't go back to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Because if she will live, she needs her mother.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It's not what you said to take-- we don't take children.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But we want you to survive.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "If you survive, then you'll have your daughter-- if you both survive.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Don't go back to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "But I said, that is my family.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Where can I go?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Find someone.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "She was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They all-- people were good to me.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Find someone [PAUSES FOR 3 SECONDS] outside the ghetto, someone who will help you, and come back here in a few days later and find out about your daughter, what will happen to her.",
      "word_count": 34
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We don't promise you.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We have no food here.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The Germans are not giving us food.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans are coming every day, because there were children from before the war with illnesses that they had to stay a long time there.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And if boys, the Germans come, and they take them straightaway.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "We can't do much.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You know how it is.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Gestapo comes, and they look through the beds, the children.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "If there is a little boy, a Jewish boy, they take him out, and they kill them.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Girls are a little bit luckier because they don't know exactly who is Jewish, who is not.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "We can keep some children here.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We don't have here many Jewish children.",
      "word_count": 7
    }
  ],
