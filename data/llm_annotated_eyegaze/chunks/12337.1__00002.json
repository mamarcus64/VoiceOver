{
  "stem": "12337.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "You know, don't leave me!",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And they kept looking at me and covering me up.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And they were busy with my mother, because she had seven holes in her head, and they crushed her-- all her bones in her head.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And she had a broken bone right over her eye and her nose.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "And-- and they were trying to, you know, treat her and-- and tried to wash all the blood away from her, as she was gushing with blood.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And they left me alone.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "And I thought, you know, that was the end of me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "Luckily, my sister, some-- for some reason or another, wasn't even touched.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "But my mother had a friend visiting-- it was on a Friday night-- and her baby was killed in the house, a nine-month old baby.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And that was the beginning of, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So, of course, the next morning, my father gathered up my mother and I and my sister, and he moved us into a poor section of the town.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And we were not allowed to get any medical attention.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And then we found out later on that many people were killed and injured.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But my mother and I were one of the most severely injured.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And my-- I must have had a blow to my head so severe that it probably caused like a stroke on my right side, because I was paralyzed for almost a year.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And my head was like a ball, very soft.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And-- and my whole face started-- it was swollen.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I closed my eyes.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They were all swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And I remember lying in bed with my mother, and she was all bandaged up.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And she was praying, please God, let her-- let her die.",
      "word_count": 11
    }
  ],
