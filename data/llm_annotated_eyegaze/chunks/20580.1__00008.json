{
  "stem": "20580.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And I was there managing-- I had food, they had eat, and drink.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And suddenly, 1937, then I got it off-- your-- they're playing the chess.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "The captain plays in chess some of the other.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I ask him permission.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I have to say it-- Polish, shall I say Polish?",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "If you want.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "[POLISH] Says, why, sure.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "His national Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH] And I start to look in the game.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "He says, you know how to play?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Says, a little bit.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And he start to play his own game, the second game and that's how-- Then he says to me, you going to get first bent, in the-- first line, which I had it.",
      "word_count": 33
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I lost it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I was in the first line.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And the Polacks in Ukraine [NON-ENGLISH SPEECH].",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I take the first place in the first part.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And he send me to the barber, to make my hair cut.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "He make me-- the barber make me the front like a little bit of hair.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And he says to me, [NON-ENGLISH SPEECH].",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "[BACKROUND NOISE] He says, don't worry about the money.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "Just give me the change.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "Whenever I left, I give him $20 and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "I give him more and more.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "But later, on, he gave me [NON-ENGLISH SPEECH].",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "Nothing is for me to be in the army anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "A white ticket.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "They call it a white ticket.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "And I'll be using that ticket.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "Either way, they send me home.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I were a couple weeks, a couple-- about two months, something-- three, or-- and they send me home.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And the Captain Neiman, Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Neiman was the-- he-- gave me the x-ray.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "He told me to eat that stuff before.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "You know, I've been told already what to do it.",
      "word_count": 10
    }
  ],
