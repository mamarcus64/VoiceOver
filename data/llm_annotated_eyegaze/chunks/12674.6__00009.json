{
  "stem": "12674.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So, so he left me there, and it took me six hours to walk home.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "But I was still me.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I had to stay-- well, we had a typhoid epidemic.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "With all these people coming in from everywhere, and us being very low in, in resistance because of mal-- serious malnutrition for a very long time, I developed a very bad thyroid condition because my-- as a survivor mechanism my thyroid set itself down to a very low, you know, point.",
      "word_count": 51
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And unfortunately, after the war it never picked up.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "So I, I, I've had this-- I've been stuck with this all my life because of-- due to that, I've had a lot of miscarriages.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I had a lot of trouble having children.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They messed me up real good.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Anyway.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we-- so we were in Theresienstadt until the beginning of July.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But that wa-- it wasn't-- I managed, since I spoke Czech.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I was told never to speak German because if somebody hears me speak German in Czechoslovakia outside the-- we got out through the catacombs and things because we knew-- you know, young people can find a way through anyway if they really try hard enough.",
      "word_count": 45
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "If it's there, they are going to find it.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So they, they-- I went to Prague a couple of times.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I was told never, ever to speak German.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "If I didn't know how to say something in Czech, I should be quiet.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And I was in Prague a couple of times, and we went swimming a couple of times.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And in, in by July, they got themselves a, a room to-- a, a transport together.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They had the train.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And they took us back to-- they took us back to, to Vienna.",
      "word_count": 13
    }
  ],
