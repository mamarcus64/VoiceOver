{
  "stem": "7414.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "She lost two sons.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "She know-- one son in defending Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And one son who tried-- why-- why my story was so plausible, because her son was an officer, the other son, in the army.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And he was in danger because the Gestapo was looking for him.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So he changed his name as well.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And as he changed his name, he was unlucky.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "He was round up on the street of Warsaw and sent to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "As a Pole.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "So she lost them both.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And he-- she told me, look, I was praying my whole life for a daughter, and God listened to me and sent me you.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "She never suspected you were Jewish?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I wore a cross.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "From time to time.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Not often because as religious as she was, she warned me not to go to the church-- to-- to confession, because you never know if you can confide in the-- in this priest.",
      "word_count": 33
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They knew that there were many priests on this Gestapo pay.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And so she did not go to confession, and she didn't allow me to go to confession, for-- which I was very glad, yes.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "But from time to time, I went to the church.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "The-- anyway, I stayed there.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And again, we tried to normalize a little bit the life.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "In two weeks time, I started to give birth.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] Lost water in the morning, and she decided that I will give birth at home.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "I must tell here that Aunt Paula-- as I told, I will call her Aunt Paula.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "You will know that it is this Polish woman.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "Aunt Paula was a midwife.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "She was one of the best midwives in Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "She was known everywhere, in every hospital.",
      "word_count": 7
    }
  ],
