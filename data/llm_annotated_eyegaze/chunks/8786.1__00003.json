{
  "stem": "8786.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "In other words, the Jewish name was not supposed to be recognized anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "These were the times.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But my father-- what more can I tell you about my father?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Tell me about his business a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He was in a business which was actually in Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "My mother's parents owned a large business in Czechoslovakia in a town which was called [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "They were probably the second largest in big junkyard, textile, and metal scrap iron.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And we were a part of that business.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "All of his children were involved in the business, and it was a very successful business.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Whole train loads were coming into our yards and picking up and taking it.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "It was export, import, whatever it was.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And he was a-- I wanted to say something about him.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS] He was a very, very, very correct person.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And wouldn't-- and anything which had to do with something to do with not the correct way, he was not a part of it.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My mother was like an angel.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Gisella.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It's hard for me even to recognize-- to record-- how-- to picture the way she looked to me.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It was 50 years that I saw her.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I was about 16 and 1/2.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And we were parted like in a second's notice.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "She was going-- she was remaining and I was taken into a forced labor camp.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I had three beautiful sisters, and we were three brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Out of the three brothers, my brother and myself-- we did survive.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Yes, I wanted to say about my father is this.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "That while he was in a labor camp, and he saw the situation.",
      "word_count": 13
    }
  ],
