{
  "stem": "22004.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I got a lot of hobbies.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I would like-- I like always to fix things.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And when we got in the-- in our shop the electricity, and like anything that happens to the electricity I was fixing myself.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I was-- I liked to do things.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I was-- I--",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No radio, no nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was playing in-- the instrument was a mandolin-- you hear about it.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "It's like-- rounded like a  guitar.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "That's what I was playing myself-- I was trying to do it.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I didn't do it for a long, long time.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was singing in a group.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I was-- and we got-- our organization was a Zionist organization.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We used to play-- we-- we played-- I got even a group in Israel where our people now in our hometown was-- is-- written a book many years ago.",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I got that book in Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "But they were writing about me.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I was in the top players.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "It was all kind of these theaters we used to make with their names maybe.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "But it was in theaters.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And I used to participate in the theaters.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, I was-- I was acting.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I once-- I played-- I played in a   play.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It was from the Zionist organization.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "If he wrote it about a big-- this officer that was in the Jewish-- in the Jewish Army-- he was-- he was-- the-- the Arabs killed him-- by the name Trumpeldor.",
      "word_count": 31
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Have you heard about Trumpeldor?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "A big officer.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He was-- he was in the English Army with-- with one hand.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He's got-- he lost an arm in the English Army in Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And he was from the first-- the first kibbutzim-- first kibbutz in Israel.",
      "word_count": 13
    }
  ],
