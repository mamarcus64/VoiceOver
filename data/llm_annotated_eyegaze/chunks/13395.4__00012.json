  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And they were still catching young girls, mostly at night.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "They would come, bang on your door, and take out whoever was-- so I was hiding in a barn every night with a friend of mine.",
      "word_count": 26
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Her sister was caught together with my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So they were in the same camp.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And I was hiding in a barn with, with her sister.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Every night, we were sitting there in the barn, all winter.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "The mice were our company.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We were counting how many were jumping over the straw.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And it was Passover.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And the last night of Passover, April 11, my mother said to me she heard rumors that the camps are full.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They don't need anybody anymore.",
      "word_count": 5
    }
  ],
