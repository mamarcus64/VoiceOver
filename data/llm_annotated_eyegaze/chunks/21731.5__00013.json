{
  "stem": "21731.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And they had golden teeth made.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Well anyway, I got not involved with this man.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I was very friendly to him, kept Jan near to me, and tried now to do something with my life.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Somebody from the Polish Red Cross arrived, asked me whether I would like to be in charge of the community there.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Because suddenly, a lot of Poles came from the country.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And they didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "They couldn't write.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "They couldn't read.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "They didn't know very much, so I had to make a list of them.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "The Ukraines came to be also on the list.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "Not one Ukraine was on the list.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "They suddenly were all Poles.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "They came from Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "They had Galiciana on their-- on their passports, or on their identity cards.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "There was not such a thing.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "You were either Pole or Ukraine.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "There were no Galiciana.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "So no Ukraine, but we got very good-- very good-- I'm tired now-- boxes from the Red Cross with fruit-- with food, fruit and also some kind of clothes.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 24,
      "text": "And-- but that was not enough for me.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 25,
      "text": "I had to do something with my life.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 26,
      "text": "I met there-- they came somewhere from the country, but they were not peasants.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 27,
      "text": "They were very educated people-- a Mr. and Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 28,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 29,
      "text": "He had only arm.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 30,
      "text": "He lost his arm during the First World War in Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 31,
      "text": "They were-- they came from Russia somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 32,
      "text": "And I got very friendly with them.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 33,
      "text": "And I wanted to find my husband.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 34,
      "text": "I knew if-- the one thing I heard once that he's in England.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 35,
      "text": "So Jan had the bicycle for himself now.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 36,
      "text": "So he went around everywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 37,
      "text": "And he had a cart with him where it was written, I'm looking for Dr.",
      "word_count": 15
    }
  ],
