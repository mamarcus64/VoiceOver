{
  "stem": "21004.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Now, those people, what they had money, they used to pay.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They used to pay us.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But giving out money for the kids, giving out food for the kids, what they have to give them.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Also they brought my whole family from Lublin.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "My grandmother died.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Died or she was killed.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Or she was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I really don't know because they took her bed.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Ukrainians came and they took her bed away.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "My uncle used to send money.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Say, Ma, buy yourself a new bed, new furniture, and this is what's by her so-- so dear.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "That's when they took her out from the bed or she died, or they took the bed and they killed her.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "My aunt came to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "My cousins came to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "My uncles came to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "So I saw the whole family.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Also, my mother-- this was my father's family.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Then my mother's family also came from-- from the villages, what they had a ghetto there.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "So they came also here, and I came to visit them.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "You know, and I came from the concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "Came to see them.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "So whatever we could, I say, send the kids.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "You know, mainly the kids, the cousins used to came.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "We used to give them food.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "Now, on April was the liquidation of the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "This was the finish.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So my wife's cousin had a ghetto-- had a-- had a bunker not far, right next to the Gentile people.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "There was his house, and he build-- he had a bunker there, a cellar.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And he told a lot of his friends and family where he has a bunker.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He himself, when he heard the shots, he was by the cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "By his cousin, by my wife's cousin.",
      "word_count": 7
    }
  ],
