{
  "stem": "18397.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "No, maybe a year or something.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I had the papers.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "You didn't-- then you got a wife, you cannot stay over there like-- [LAUGHS]",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Where everybody lived, we went to New York.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, I had a contracting, used to make something.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I made good, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And everything was like this.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "But I had-- still my leg was-- not so good.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "If you got a-- I'm telling you.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "You should know it.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "If you got something with the knee, that-- that never heals 100%, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "You see, a knee is the-- is the worst part in your body.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And that's what I had.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "You see, if you put a-- a knee in a cast, more than a couple of months, it never heals like it was.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Because it's not a finished part.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "You see what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "That's what I'm-- I'm telling you.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "You should know it for somebody, not for yourself.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And tell us how many children you have.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I got two.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Shelley-- Shelley and Charles, this I know.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Oh, boy.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "She--",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "But she didn't-- she didn't show me?",
      "word_count": 7
    }
  ],
