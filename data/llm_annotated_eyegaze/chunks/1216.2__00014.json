{
  "stem": "1216.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "And us children were sent there in a sort of a fireman's line, the old fashioned fireman's line, to give boxes from one child to another.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "The boxes contained the ashes of the dead.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And they were loaded on trucks and taken away.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "I didn't know then what happened to them.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "I found out much later through reading that those ashes were dumped in the river.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And that was one of my jobs.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "To pass on the boxes from one child to the next.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So I received from one child and gave to the next child.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "By that time, I didn't feel anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And it was perfectly normal.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It felt good, in a way, because we got 'paid,' in quotes, for that.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "We got an extra little tiny piece of sausage.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "When you're that hungry, even that little bit feels good.",
      "word_count": 10
    }
  ],
