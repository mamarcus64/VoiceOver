{
  "stem": "131.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] They came screaming that we have to leave now.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] That-- that's all that I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 7 SECONDS] And they said you could take a suitcase.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] My mother had a tiny suitcase just with a nightgown and one dress to change, and so did all of us had that, one change.",
      "word_count": 29
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And when they chased us from the ghetto already, it looked that it was-- my mother couldn't run, because they chased us-- not walking, just running.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And she stopped already there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "They beat her with a big like a baseball bat in front of me, in front of my sister.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "[CRYING] It was terrible to see that, the first time that they hurt my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Then they chased us in the wagons and they locked us in there with a pail.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And my grandfather was there and my grandmother.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And I saw a lot of people.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "My cousin and my aunt from the brick factory, they were there.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "My cousins, a lot of people, my relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I can't remember everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I remember my grandfather [PAUSES FOR 8 SECONDS] very well.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] We didn't even have enough room to sit there.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Already there it started the trouble in the [PAUSES FOR 3 SECONDS] cattle train.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] You couldn't move your legs.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "You couldn't move.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "The way you sit down, that's the way you were, because like herrings, each-- everybody sat near each other.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 9 SECONDS] I was there and I thought to myself, that's the end.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "We all will die.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I didn't even think of that they will kill us there.",
      "word_count": 11
    }
  ],
