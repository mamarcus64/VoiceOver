    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "But he lived with the war times, with the people he saved.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "He knew about everybody's children's bar mitzvah.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "And he was telling me that this one has a son.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "He has so much [INAUDIBLE] from him.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And this one is this.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
