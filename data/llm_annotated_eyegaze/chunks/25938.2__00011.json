{
  "stem": "25938.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "It's a misconception about kapos.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 6,
      "text": "They're-- they're-- not-- all kapos were not bad.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 7,
      "text": "There were a few people who were good people, good kapos, they didn't beat any-- anyone.",
      "word_count": 16
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "And that kapo saved my life.",
      "word_count": 6
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "Kaminski.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "Was called Chaim Benesh, they called him-- Kaminski.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he was a landsman from my little town.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "About a year, or-- about a year or so.",
      "word_count": 9
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "I was altogether about a year and 10 months, and eight-- eight months, or something.",
      "word_count": 15
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "So we went to Kaminski.",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 4,
      "text": "He had-- and he bribed the SS man.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 5,
      "text": "He was working in the Sonderkommando.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 6,
      "text": "You heard about the Sonderkommando.",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 7,
      "text": "They used to take the Jews to-- make the Jews ready to go to the-- to the gas chamber.",
      "word_count": 19
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 8,
      "text": "They used to work in the-- near the gas chambers.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 9,
      "text": "It was a terrible place to go.",
      "word_count": 7
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 10,
      "text": "We all prayed not to go-- to be sent there.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "They was to take their own brothers and take-- some recognized their wives, I read about later.",
      "word_count": 17
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "And-- they couldn't-- they couldn't-- couldn't do anything.",
      "word_count": 8
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "So he saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "He talked to the SS men, and they-- they cancelled my name, and--",
      "word_count": 13
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "My brother escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "He said, just came to Chaim Benesh.",
      "word_count": 7
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "I talked to him, to Kaminski.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "He said it was all right.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 4,
      "text": "You don't have to go.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 5,
      "text": "They didn't call me.",
      "word_count": 4
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "They went.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "Everyone went.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "I was one of an exception.",
      "word_count": 6
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 4,
      "text": "I was maybe one of all-- of all the others-- the other thousands of the survivors who were sent to the crematories, and didn't go.",
      "word_count": 25
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "It was an inferno.",
      "word_count": 4
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was a hell.",
      "word_count": 6
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "People-- the first few months, people died.",
      "word_count": 7
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 3,
      "text": "Hundreds, hundreds of people used to-- some committed-- before I came was even worse.",
      "word_count": 14
    }
  ],
