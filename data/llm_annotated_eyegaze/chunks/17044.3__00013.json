    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Forget about something.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We were joking just.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "I said, so what do you have in mind?",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "I said, we go and we go out of town.",
