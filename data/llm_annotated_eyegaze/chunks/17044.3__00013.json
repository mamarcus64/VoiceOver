    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "We can make a job something.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "We have to steal.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So we go out of town to see laundry drying outside town.",
      "word_count": 12
    },
    {
