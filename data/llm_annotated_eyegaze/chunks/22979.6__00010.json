  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It was bombarded, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We saw bombarded city.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "People, you know, the German people wander and go over back and forth.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "It was nothing there.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "How could we, how could we have transportation if it was none?",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And still the armies, you know-- only the Russian army.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "This part was all, you know, occupied by the Russian, you know, armies.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Then we came to Dresden.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "You know how Dresden was destroyed.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "We went all around Dresden.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "So it was all destroyed that we couldn't.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "And besides this, after we had experience, many probably the Russians who went with trucks, would take us.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "But we were afraid because they took everything from us.",
      "word_count": 10
    }
  ],
