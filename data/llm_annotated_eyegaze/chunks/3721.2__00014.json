  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And I was supposed to go with all kind of orders and take so many people away, mainly-- they were mainly women.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "The men were not there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "Women and children-- they got names of people who were taken away.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And I was-- be able to-- they, they made false papers from the Ministry of Interior or the police.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And we went there in uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "I was the lieutenant.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And I had two other soldiers with me.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And we took them.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "We were saying, these people stole typewriters-- I'll never forget the one of them.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "And therefore, they are responsible to the police.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "And I am part of-- and we took these people out.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "And we took them into safe houses, those days, that we had.",
      "word_count": 12
    }
  ],
