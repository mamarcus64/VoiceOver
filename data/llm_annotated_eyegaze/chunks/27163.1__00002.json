  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We went to a school which was a public school, but also a-- [PAUSES] it was a-- [PAUSES] public school.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES] I'm trying to think.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It-- it was a public school, but mixed with a-- how should I do this-- how should I-- [PAUSES] it was mixed.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES] Oh.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Well, they were all Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And as far as-- how did they interact?",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Well, inasmuch as we were all Jewish, they interacted quite well.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They interacted quite well.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, sure, we-- we-- we did have-- we did have interactions.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Not too severe, but we did have-- excuse me-- interactions.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Budapest had-- let me see.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Budapest had-- [PAUSES] Budapest had a million-- Budapest had a million-- [PAUSES] oh, shit.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Trying to think.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES] I was too young to have really that many favorite subjects, when you think about it.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I liked-- I liked-- [PAUSES] before, I liked-- [PAUSES] No.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Writing.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And it was-- it was-- yeah, I liked writing.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I liked writing.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we played-- we played soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Normal boys' games.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The first-- can I move this?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "The first big change was in 1930-- wait a second, 19-- [PAUSES FOR 8 SECONDS] 19-- let me try to figure it out. 1934.",
      "word_count": 24
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "1934, the-- the-- the Germans came in officially.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They took-- they took over, let me see, 1934. 1934.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, the Germans came in, took over officially.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure it did.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Day to day, every day there was a new rule-- rule or regulation.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Affected me?",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was rules-- rules and regulations were coming in as far as-- as far as-- [PAUSES] there were rules to the extent of-- it became like-- anti-Jewish laws became constant-- constant-- constant harassment.",
      "word_count": 33
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And so it was constant-- constant harassment.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "word_count": 3
