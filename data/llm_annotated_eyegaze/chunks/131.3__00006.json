{
  "stem": "131.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "She came from not far from my city, from Kosice.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I was with her, but most of them were French people that I couldn't speak to them at all.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "They separated me, right away.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "After that, they beat me up.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And they hurt my hand.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I was in the hospital, and they took her away.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I just met her late, later.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "You see, I was liberated by the Americans.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And it was there, a chaplain, a rabbi.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You say chaplain, yeah?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And he brought a book with him from Belzenberg with the names who got liberated there from the English army, because there were English army, not American.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And he brought a book with names.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I was sitting and looking the names to find some of my relatives.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I find Hannah Schoenfeld, and I started to scream.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "My sister!",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "My sister!",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Where is she?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "My sister is there!",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "I was screaming that she's alive.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Where is she?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And that chaplain took me cross Germany-- it was all over bombed-- in a Jeep, to find my sister in Belzenberg.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I came there.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I was clean, already, from the American.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I could wash myself, and I had a dress on from there.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I don't know who gave me-- the Germans, or who gave me, I don't know.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "But I know I had a dress on, and I looked half-human.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And when he heard that I was screaming, my sister, where is she?",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Is she alive?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "That's my sister!",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So he says, yes, she's in Belzenberg.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I want to see her.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "How could I see her?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Is she coming here?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He says, I take you there.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And he put me in his Jeep and he took me to where she was.",
      "word_count": 15
    }
  ],
