{
  "stem": "10272.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And these boys and girls in the Czech school, we were-- Jewish people were more-- were the majority of the school, see?",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "There were-- there were not so many Czech boys in school-- and girls who went to the school because they came only-- they were sent from Czech Republic to this area, to this area [PAUSES FOR 3 SECONDS] to do a job, like, like the state employee be, or working on the train, working in the post office, like these area-- these jobs.",
      "word_count": 63
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And they were not-- it's the Czech people are not-- very rarely when somebody is anti-Semite.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Maybe he is in his heart, but he doesn't show it.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So I didn't know-- and never encountered any Jewish anti-Semitism from a Czech person, never.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "For hobbies, I was-- draw my-- to, to draw people, to draw faces, to draw all kinds of things, animals.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I liked to draw with a pencil on a paper.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Once I draw the, the portrait of president-- our president, Masaryk.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And the teacher send this portrait to the president, to Prague.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And I got a letter from him that he was very happy to-- that such talented kids in, in-- And I have to mention, also, that this area where I'm from is a unique place on the map-- on the European map.",
      "word_count": 42
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "This is not a big area.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "It's the size of, like, New Jersey, let's say.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And it was-- it's changed hands-- [PAUSES FOR 3 SECONDS] so I don't know many-- how many-- how many times.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was under occupation of the Romans.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "The Romans were there.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Then there were the Turkish Empire, the Turks-- under the Turks.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And then came the, the Russians in World War I.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And then it was the Austrian-Hungarian Empire.",
      "word_count": 7
    }
  ],
