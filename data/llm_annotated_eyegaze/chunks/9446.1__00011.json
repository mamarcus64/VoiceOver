  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "They gave me a pile of about a thousand dishes to wash-- you know, the dishes for the army-- cold water and sand.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "You know, soap, no nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "And I couldn't lift that stack.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "It was a huge stack, and I was hungry.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "So they hit me, and almost killed me.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my father was still in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Because, you see, I had a hope to remain-- return towards--",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Shall I continue?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he remained in Warsaw, because he could not liquidate everything so quickly, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He had some business deals there.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And he was hoping to see me in-- in eastern part of Poland a little bit later.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "He was hoping to be able to be able to make the same trip I did, not knowing that this was impossible to do with, you know, no knowledge of that.",
      "word_count": 31
    }
  ],
