  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "As I came-- oh, and it was a huge building, infectious.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "Open the door with the child.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "I didn't know what I'm doing.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "But I was still-- I waited-- I don't know, I would have fainted before.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "But I wanted to reach the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "Open the door.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "It was-- I can remember exactly-- stony floor, those squares, stone.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "There were a few steps to go in.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "I still went up [INAUDIBLE] the steps.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "When I came to the hall, suddenly I fell with my child to the floor and fainted.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "It was too much.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "It was so much.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "I fainted.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "I don't know anything because I fainted.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "I didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "I woke up.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "I didn't have the child.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "I was in a room, inside somewhere there on a bed lying.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "And a Ukrainian sister, with the black, [PAUSES FOR 3 SECONDS] came up to me.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "Third thing what happened to me, I didn't have anymore my cover.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "And I had a-- I felt here.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "She said, no, we burned it.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "I was lucky always.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 40,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 41,
      "text": "We burned it.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 42,
      "text": "I said, where is my child in Ukrainian.",
      "word_count": 8
    }
  ],
