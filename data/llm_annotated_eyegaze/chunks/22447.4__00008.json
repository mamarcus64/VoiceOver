{
  "stem": "22447.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "There was a cinema in the barracks, which the Germans used to go.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "In their spare time, they used to go to the cinema.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They used to pay to go in, admission.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And I went down there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We, we went into the cinema.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So someone comes up-- German, he was-- about 16 stone, mouth full of gold teeth.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I said, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "He says he manages the cinema.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I said, you manage  the cinema?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So who does it belong to?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "He says, it belongs to my sister-in law, the world famous Marlene Dietrich.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] And I thought, it doesn't add up, if, if-- Sorry, where actually, is this cinema?",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In the barracks, in the tank training [INAUDIBLE], in--",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "In Bergen.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It was about six kilometers away from the original camp, where the SS used to go to, to their entertainment.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So I said, it doesn't seem to add up.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Where do you live?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "He had a luxury flat above the cinema.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We went up.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We  went to see.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "He had a luxury flat.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "He had a Steinway baby grand up there.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "He was living the life of Riley.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And on the door, there was a--",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "George Wills.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "German, he was German.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and when I went upstairs in the projection room, there was bundles of papers written him, why I'm a Nazi.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "There was bundles, hundreds of them there.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I should have taken them.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But you didn't think of these things at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And there was three projectors.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "So I say to him-- ?] one was a spare.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And two was for showing the films.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And the projectionist was a Yugoslav prisoner of war.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "He was a radio operator in the submarine service.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And he was a prisoner of war.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    }
  ],
