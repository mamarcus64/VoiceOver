{
  "stem": "10745.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "Which we didn't have no money.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "But to go on the streetcar-- we didn't pay.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "When the conductor came, or something like that, we yelled at him.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "We were not afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "There's one thing we learned after that, we were not afraid.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "We were just on the way, we all planned to go to Israel and Palestine, and that's the only thing.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "In our minds, in our soul, it's not Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "Just Palestine.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "We went to movie houses-- we didn't pay-- because we didn't nowhere to pay.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "And we went to a marketplace-- we took away from them.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "The Polish used to scream.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "We swiped some food.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "We take away food.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "We took all kinds-- we were rough.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "We didn't take from nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "At that time if a Polish guy would say anything about a Jew, or anything like that-- so what do you want to make out of it?",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Didn't kill enough?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Or anything like that.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "A lot of times they said that we take away their children.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They start-- the incident [INAUDIBLE] children, which they came to us, it's true.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "They wanted to take away-- they said that we took away Polish children, which they didn't-- we didn't.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We took Jewish children.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Who is they?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Polacks.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "To the ground.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The ground was with a big fence-- steel fence.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And they came up to the grounds, and there was screaming and yelling.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We never gave in to them.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes, oh, yeah, all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Because I kept with my mother-- I used to go down all the time, two, three times a day sometimes.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "If I didn't go away with the boys, I used to go with her.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In the hospital it was very bad.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was very bad.",
      "word_count": 4
    }
  ],
