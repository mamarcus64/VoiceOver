{
  "stem": "16395.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "No, we went to the city hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "But it was a hospital for people when they took sick.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "But like having a baby and like a different sickness, what they couldn't do it, they-- we went to the hospital, yeah.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "We came.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "To America.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "It felt wonderful.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "It's the most beautiful country what you can't imagine.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "First of all, your freedom.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "We really love it.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "[SIGHS] Nobody appreciates freedom, I think, more than us.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "This is the most precious thing in life, where the person can have his freedom.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "It's worth-- it-- it is worth fighting for.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "We came in here, and my husband worked by constructions all his-- all his life.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "You'll see he worked in camp.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And that's how he learned.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "But first, he worked in [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And he made already $28 a week.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And it was a lot then.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I was cooking and baking.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "But we still didn't have a place where to live.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "We lived in a two-room apartment by somebody, like a sublet [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Sub-- how do you say it?",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "A sublet?",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "A boarder.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Like a boarder.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And we lived there maybe for quite a few months.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "She was pretty-- she was a nice lady, older lady.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And she had a big house.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And she subletted us two bedrooms, me and my brother-in-law.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And-- and they both worked, and we put away some money.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And my husband was making a little bit money, and later they gave us a thing, the Germans gave us some money, and we bought a house.",
      "word_count": 27
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "But this was already in 1947 or '48.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, people were very-- this I cannot say.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We got to Rochester, and I-- we were sick.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And the-- the doctors didn't take no money.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And people tried to help us.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    }
  ],
