{
  "stem": "2568.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And people after the war, they-- they were running, they didn't know where they're going.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "What to Germany, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I say no, I can't live here.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I can't, somehow, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And I went back to Dubno.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Went back to Dubno.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Somehow I used to take a little merchandise, bring to another town, and-- Was this in 19-- what?",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In 1944 already.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Well, where we were was sort of liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "My town, and where I was staying, there was still fighting.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But-- then I met my husband.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I married.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "He moved before I married.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "He wants to marry.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want to get married, so he moved to Lwow, Lemberg, big city.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "He was already in business.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "He was--",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "He was a little older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And after couple days, I say, he left, he wants to marry me.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I should marry, not marry.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Then I say to myself, I'm gonna take a ride to Lwow.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "So my girlfriend's husband say, you know what, I go with you.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Because she was afraid to leave me alone on a train at night, you know, the Russian, and-- We went on the train all night till we stop in one place.",
      "word_count": 31
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "In Lwow, we took a room [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "Next day, I went to visit him.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "So he say he settled there, he's in business already.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "He's working and--",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Black market.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Gold, [INAUDIBLE], dollars and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "As always.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I decide to marry and stay there.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And my brother came back to stay with me.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "When he came back, he didn't like it.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "So he went to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "No, first we went to Germany, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "We live in Lwow for some time.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "Then we were thinking to go to Germany.",
      "word_count": 8
    }
  ],
