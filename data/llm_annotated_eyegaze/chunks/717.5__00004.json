{
  "stem": "717.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I was very active in Jewish life, in the Yiddish theatre.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I played in the Yiddish theatre very actively for 15 years.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "We had a very good theatre.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Very high standard, professional standard, even though we were amateurs, we had a professional standard because we had two people that were very famous before the war in Yiddish theatre.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Jacob Weislitz from the Vilna Troupe, one of the stars living here was there.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And one of the great.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "The first lady of Yiddish theatre, Rachel Holzer.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "In fact, she's still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "She's in her late 90s now in Melbourne.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And they were leading the leader.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "They were directing, putting on plays, classics, Yiddish classics, and translations from-- from the Italian theatre, from the American theatre that we played.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And that kept me very busy.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "And also I worked in my trade, worked in the fur trade.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "Regina had an aunt here that came from Belgium through Israel to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "In fact this is an aunt, Regina will tell you about that later, that married us in Brussels.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And when she came to the United States, she came to Los Angeles.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "She kept on bombarding us with letters.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And you know, the name Los Angeles at that time had a magic sound, Los Angeles, Hollywood.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "So in-- I think in 1960 or '59, no, '59 because Sylvia wasn't born yet, we registered in the American Embassy to come here.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And since we are again on the Polish quota and it was a five-year wait, [PAUSES FOR 3 SECONDS] we registered to come to the United States.",
      "word_count": 27
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "You know, I don't want to pass by Australia that fast because Australia has a big place in my heart, a very beautiful place in my heart.",
      "word_count": 27
    }
  ],
