{
  "stem": "27409.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 70,
      "text": "And in my times, it did not kill us so-- they were probably paid.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 71,
      "text": "I couldn't tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 72,
      "text": "In any case, everything went through the Judenrat.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 73,
      "text": "The winter was a bad winter, minus 40 degrees.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 74,
      "text": "Many-- most of us, including our family, had typhoid fever, and lice, and hunger, and cold.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 75,
      "text": "Many died, more than half in Shargorod In our case, less when you could-- could wash ourselves.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 76,
      "text": "There are not many and-- uh, who worked.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 77,
      "text": "You see, the German asked from the local population, uh, food, and also gloves, woven gloves, different woolen things, which look like a-- uh, population didn't know how to make.",
      "word_count": 30
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 78,
      "text": "Our people knew, they-- so they started working.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 79,
      "text": "And they give them food to us to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 80,
      "text": "And says, I worked in the stables.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 81,
      "text": "I worked as laborer.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 82,
      "text": "And I got friendly with the local population, visit priest, which was in the village.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 83,
      "text": "It was a old priest who couldn't see.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 84,
      "text": "And I, from my years in the church school, could read the Slavonic language.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 85,
      "text": "So I was reading in the church service, the [NON-ENGLISH], in his place.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 86,
      "text": "He gave me to eat bread and this.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 87,
      "text": "He lived in the house of the chief of Ukrainian militia.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 88,
      "text": "So I was persona grata there.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 89,
      "text": "I got to eat, and my father knew well, eh, the tobacco.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 90,
      "text": "So I worked for the tobacco plant which he had drying in this-- in the [NON-ENGLISH].",
      "word_count": 16
    }
  ],
