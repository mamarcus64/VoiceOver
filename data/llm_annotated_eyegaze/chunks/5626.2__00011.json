{
  "stem": "5626.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We were chased out from the camp of Mauthausan.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we heard on the second day that the Russian army already liberated the camp of Mauthausen.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "We were chased through three days and three nights without food, without stopping.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Then we arrived to Gunskirchen.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "That was a small, unknown camp within a forest.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We had to go through a row of drums, which we found out next day that they are full of gasoline.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The German army was pressed.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The American army was already down close to Salzburg, which was about 70 kilometers from the Gunskirchen camp.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "The Mauthausen side, the Russian army was coming already.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And naturally, again, work-- what will be your work?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "This camp did not have gas chamber or oven.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "This one had killing place.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Row by row, people were stood up and just machine gunned them down, one by one.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Our job was carrying these dead bodies into a big, open grave, and put them in one layer of body, one layer of this white stuff, lye, smelled chlorine.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "That's what we had to cover the body-- layer after layer after layer, no water, no food, no bread, no nothing.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We heard nights the guns already.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We were in this camp eight days.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "May 4, 1945 came.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "In the corner of the barrack where we were, we were having and saying our Friday night prayer-- I don't know, six, seven, eight of us together.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We're saying the prayer.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And suddenly, we saw the first-- we didn't know who they are.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "A soldier came in a tank, top of the tank.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "It's a good time to stop.",
      "word_count": 6
    }
  ],
