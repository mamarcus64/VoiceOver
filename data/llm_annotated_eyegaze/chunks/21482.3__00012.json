    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Again, I was lucky because the parts that was making pots and pans was very hard work because you had to dip those heavy pots and pans in very, very hot water or something.",
      "word_count": 34
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "So it was so unbearable hot over there.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And I was working in the factory on a little machine, a lathe.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I was making shells for the bullets.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I liked it.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I like actually doing it, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "What was the name of this factory?",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Emalia.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Emalia factory.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And then, of course, when the time came that we-- you know, he had to liquidate the factory, move the factory to Brunnlitz.",
