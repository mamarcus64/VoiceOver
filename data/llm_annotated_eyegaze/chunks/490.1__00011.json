{
  "stem": "490.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Especially these people that I knew.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They had no children, so they were glad to have me over for dinner.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So when the war broke out, they asked me to come and stay with them.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So I became a part of this family.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And so I was not married.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I was too young for that.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, my Hebrew I learned when I was a-- when I started.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I started out-- the only language that I really enjoyed was Hebrew, because in-- in Yiddish, when we'd-- the teacher or the rabbi or the-- used to speak, and you want to make notation.",
      "word_count": 34
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And Yiddish is very difficult to make-- to write down.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So, in order to write it down, I wrote in Hebrew, because Hebrew is like shorthand for Yiddish.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They say, you know, [SPEAKING HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "It is short.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It's like shorthand for Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And there I learned my-- my Hebrew, because-- and, of course, all the books that we read was Hebrew.",
      "word_count": 19
    }
  ],
