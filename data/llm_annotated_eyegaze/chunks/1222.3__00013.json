{
  "stem": "1222.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Even my children will say-- my daughter, Brenda, they're Canadian-- they will feel they didn't feel any added danger there.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They were tourists.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And Ukrainian people, they don't believe so much to break up stones.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "They will kill you, but they believe maybe they scared, forgot, or something, they will not break.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Maybe they'll break up more on the States or in Canada than in Ukrainia.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So far, it's already two years.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We have guards, a contractor.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They didn't touch.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They only putting in flowers there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "If I wouldn't do it, what would become there?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "What would my children say?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] we going to look at it?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It will be growed up, covered with-- with grass, or herb, or garbage.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "It will be nothing to look like that.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "We have a memory.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And that's the way I feel about it.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Is there anything else that you would like to add?",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I would say again, to me, what you did, Susan, and what's his name?",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Stephen, and Susan, I have no words for thank you that you picked me [SOB] in all the people.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how many that you're interviewing me.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I offered you to pay for the video.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "You say no, you're going to get it free of charge.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Like I went into Fontainebleau.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I said it to you again and again, it was sold out, the tickets.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Who did it to me, the-- the second time, the front, [?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Esther. ?] She says, Sam, I didn't know what's going on in Fontainebleau.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "But they said it's $125 a ticket.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "I said to them-- to her, please, fund Fontainebleau.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "She said, you have no ticket.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I said, I don't-- here's a good example, you have to have guts.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "I said, I'm not taking the word no.",
      "word_count": 8
    }
  ],
