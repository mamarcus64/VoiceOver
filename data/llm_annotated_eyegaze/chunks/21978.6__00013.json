    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I just want to say that I am fortunate that my children and my grandchildren are always on my side, that they love me and all that.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And even if they don't show it so, show it so much, that they understand me.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I have sometimes certain things that they bother them.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Because it's a bit different for them what, you know, young people think.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "But that they all should know that I love them and that I have done this here for them, that they should know.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    }
