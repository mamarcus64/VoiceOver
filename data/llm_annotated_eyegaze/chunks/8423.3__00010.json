{
  "stem": "8423.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And that they could smell very pungent smoke.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They said, oh, pew, you know, it smells so bad.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And some people said, well, maybe it's a rubber factory, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And different people were pushing to have a look.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Did the train ever stop on route to Auschwitz?",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it stopped about three or four times maybe.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And they let us empty the two buckets, which were our facilities.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We were just handing it down-- just handed it down.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Nobody got to get off the train.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "We just handed it down, and they handed us back the bucket with filthy words about us being dirty pigs and all this sort of stuff, you know?",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No, it didn't stop during the day.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "We stopped at night.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't see anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We got to Auschwitz, right.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was just about the last one to get off the train.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I just didn't want to get off somehow.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "My older sister got off, and she got-- my mother handed down the two little ones to her.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And then my mother got off.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And my mother was yelling for me to jump.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And you know, to show you what a kid I was, the cattle car is about this high.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "So here, I keep saying that I wasn't scared for myself.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "I was scared to jump.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Because, you know, for the animals, they put this slanted down, to walk down.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "But for us, they didn't do anything.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "Some of the prisoners who were there from before-- like, I guess a lot of them were Polish prisoners because they got there way years before us-- they were trying to help us down.",
      "word_count": 34
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "Because there were a lot of people there, you know, really old and sick.",
      "word_count": 14
    }
  ],
