{
  "stem": "2581.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But anyone from our town thought of my father-- there's a Jewish saying, [NON-ENGLISH], which means to god and to the people.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My father's name was Herschel Piernakarz.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Even the Gentiles, the Poles, liked him.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He was an officer in the Polish Army.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "He was involved in so many charitable endeavors in a small town.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Of course, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He was on the board of the [NON-ENGLISH], which loaned money without interest to people that needed just to carry over from one season to the other, from one holiday to the other.",
      "word_count": 33
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Or in business-- [INAUDIBLE] when I say business, it's not American business.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "You know, help a tailor buy some fabric or a shoemaker buy some sole leather, that sort of thing.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And for families that just had more bad luck than usual, to borrow some money.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "My father was involved in a group of Jewish theater amateurs, where they played [NON-ENGLISH] and [NON-ENGLISH] and [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "So many, so many.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And the rehearsals were in our shop, so it stayed with me.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And the money that they made went for poor people for-- we're talking about Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "The money was going for coal for winter, for matzahs, for poor brides, a little bit of a trousseau, that sort of thing.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father was a custom tailor.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "But he employed, at one time, nine people, which was a tremendous amount.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "At times, it was less.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And I remember how I came before the Easter, Christmas-- Christmas too, but mostly Easter, which is the gentile holiday.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "So we had some Jewish neighbors, people that never worked.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They had other kind of businesses where they were so envious that the people were working day and night, that like the wheel is turning, so gold is coming out.",
      "word_count": 30
    }
  ],
