{
  "stem": "27351.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Occasionally we would go to see my father also during spring break or these type of things.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well financially, the situation was very bad.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We never had money.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "My father's earning from his writing, from his other work, were very scanty and very irregular.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "My mother was an incredibly brave and energetic woman, and the burden of running the family, keeping us clothed and-- and fed, and bringing us up was on her shoulder.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "She did all types of things.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "She-- before she had children, she was working in a hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I'm not exactly-- I don't know exactly what capacity.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Probably helped to nurse.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "So she learned how to make injections and other little medical tasks.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "She would do it privately.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Later on, she learned how to do a manicure, and she would have her clients coming to our room.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I say 'room' because we lived in one room.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "It was a large room, a front room of a nice building in the nice part of the city.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "However, this room did not have water and did not have a bathroom.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "We had nice furniture-- a little, not very much.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "But the furniture was designed by my father and made-to-order, so I remember this wardrobe that was a combination of bookshelves and wardrobe.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Now it is more common to see this type of thing, but then it was a novelty.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And there was a daybed, and I, with my mother, slept in the daybed.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And then on the other side of the window, there was a little sofa, and this is when my brother slept.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And there was also a small desk where we did our-- our homework, and a table where we ate.",
      "word_count": 19
    }
  ],
