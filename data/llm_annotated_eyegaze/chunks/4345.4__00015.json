  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I didn't touch it.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But I said, Sally, [SPEAKING POLISH], I said the Polish, [SPEAKING POLISH], Hot-- hot-- you got hot coffee.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And she would bring me the hot coffee, and I would put this coffee into my mouth as if it was a piece of ice.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And I felt that with this heat somehow I killed the fever in my inside.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "If this is at all possible, then this is what happened to me.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "That's how I came through it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "My fever went down.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "To-- and then we hear that the British invaded, that the British liberated Bergen-Belsen.",
      "word_count": 14
    }
  ],
