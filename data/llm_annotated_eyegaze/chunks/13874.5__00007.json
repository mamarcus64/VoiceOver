{
  "stem": "13874.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "This is a wedding picture of my parents, Isidor Selling and Ida, nee, Laub.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It was taken 1911.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In Anspach.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It-- it was part of the stuff we brought along.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of my father, Isidor Selling, when he was in the army, during World War I.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And did--",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I think it was taken in Anspach, or wherever.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "This is a picture of Hugo Laub.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "This is a brother of my mother, who was in World War I-- wounded twice.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And when he finally-- his Germany didn't exist anymore, he committed suicide.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 6 SECONDS] This is a picture of our house in Lehrberg.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "That's where we were born and where we lived till we were pushed out of Germany.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "That probably was taken shortly after World War I.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "This is a picture of the street where we lived.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Our house is hidden.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "It was taken before 1930.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "In Lehrberg.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "This is a picture of my mother, and with my twin brother and me.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It was taken shortly after our birth, in 1918.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name was Leo Selling.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "My mother, Ida Laub.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I'm on the left.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "This was taken when we were about seven years-old, in Anspach, which is near Lehrberg.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I'm the one on the left.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My--",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Over my right, that's my twin brother, Leopold.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "This is my passport with which I emigrated from Germany, in 1939.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "It was issued in Munich.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Of-- it's a J-- means I'm Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And as you see, the name we were all forced to take-- the Jewish name-- is in the-- in my name.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Isidor-- no, no, Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] This is the data on my passport.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "The picture was taken shortly after I came out of Dachau.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And you can see my hair is still cropped.",
      "word_count": 9
    }
  ],
