{
  "stem": "5255.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My life in the ghetto?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We were living in the area that they declared it to be a ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It was the Jewish neighborhood.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And when the war broke out, we were already living in the Jewish neighborhood.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And they just put a fence around it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And we were enclosed.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And that constitute the ghetto of Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And we were living right in the center of it.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have to move.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, they were fences made out of brick.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "All over, wherever there's an opening, they, they did, they made a-- certain streets were cordoned off.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They, they, they built a brick walls.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And you couldn't get through.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And one side was the ghetto, and the other side is the Polish, the non-- the Aryan side of the city.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't-- It wasn't-- it was impossible to leave the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You risked your life to leave the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Eventually, I left the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But it was under these circumstances.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I risked my life.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto?",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "There was a half a million Jewish people living in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It was a large part of Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The gates, where they used to bring in or take out merchandise or people were guards.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "There were German guards, Polish guards, and Jewish police.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "You could go in and out if you have the proper papers.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "If the government needed you for some reason, or you worked for the Germans, or for whatever reason.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "There were a lot of people going in and out all day long.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I didn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there was always restrictions.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And the conditions changed almost daily.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "One day you could go out because you worked there.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The second day you couldn't get out even if you worked there.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Every day the conditions changed.",
      "word_count": 5
    }
  ],
