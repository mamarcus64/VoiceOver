  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "She knew what she wants to-- she didn't want to live anymore, not only because she had nowhere to go.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "I was then with a Polish woman and my child.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "That Polish woman was not far there.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "She has seen her.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "She gave me the last-- she told me the last words what she said.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "She said she didn't know my [INAUDIBLE] name.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "She said, [?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 25,
      "text": "Eda ?] is happy.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 26,
      "text": "She's lucky she's with you.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 27,
      "text": "And she has seen it.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 28,
      "text": "She told me that she has seen it.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 29,
      "text": "[INAUDIBLE] She went out and on the street to the first gestapo man who patrolled the streets.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 30,
      "text": "She went to him and said, you took my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 31,
      "text": "You forgot me and my child.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 32,
      "text": "Gave herself up with the child.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "That was at the beginning.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I think it was all in '42.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I think the beginning [INAUDIBLE] ghetto started there.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "That's the same sister.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "You mean-- during the-- in the Nazi occupation?",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, no, in the '30s.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Before?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "The younger people were all Zionistic.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "There were some Hasidic.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "We didn't mix with them, not like here.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "We knew who they are, but they were Hasidic.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They didn't mix, and they never went together with the Zionists.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] There was even an antipathy, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They didn't like each others-- here too.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "The [INAUDIBLE] don't go to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "[BACKGROUND NOISE] So we were not concerned about the others.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There was a case.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He was a professor, our professor in gymnasium, Professor [?",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Taub. ?] I remember-- still remember him.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Professor is-- Some people are here.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I don't think-- I never met anyone who was in Grodek.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "He was later professor of university in Lwow, Professor [?",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Taub. ?] He had a son and a daughter.",
      "word_count": 9
    }
  ],
