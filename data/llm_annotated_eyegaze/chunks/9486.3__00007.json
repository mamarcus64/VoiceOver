{
  "stem": "9486.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And the Arab, they came in in-- in Degania Alef.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "The Arabs went in, and they killed all the cows, all the chickens.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "They left there just like thousands and thousands of chickens.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Thousands of cows.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And they were already close to Kinneret.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "My brother had-- took six [INAUDIBLE] Molotov.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Meir.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That's-- that's the brother-- that brother what I have here, he was-- I find him-- not long ago-- when I came to Canada.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "My brother, Meir, took six, seven [INAUDIBLE] Molotov.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "In event the first-- when the first Jeep came with the Arabs to go into our kibbutz, he threw himself with this.",
      "word_count": 22
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And all was burning.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And they saw the Jeep burning.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "They run away.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They didn't-- they didn't come into the kibbutz.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "His body I didn't find.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "It was just pieces.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "To bury him, we couldn't walk.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We needed to find pieces from him, what we find.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "We took a piece of wood.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We put it in.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And we were crawling like [? soldiers ?] crawling on floor.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "They-- they were shooting from the mountains, Kinneret and [NON-ENGLISH] Kinneret is in the bottom and [NON-ENGLISH] top.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "They were shooting.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "We were crawling, just like soldiers crawling, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And we will take him there to bury him.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 7 SECONDS] [SOBBING] I left again alone.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "From the kibbutz?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "My brother.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My mother was in Haifa, in a-- in a school.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "All the parents was there, with little babies.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "At that time, my mother was drinking a-- a coffee or a tea.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And [? your ?] glass fall down.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And she said, my son got killed.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] They didn't know how she knew.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Two hours later, they find out.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] My mother came back to the kibbutz.",
      "word_count": 11
    }
  ],
