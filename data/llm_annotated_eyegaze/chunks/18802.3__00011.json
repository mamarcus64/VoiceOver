  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "I don't live-- I don't live in a sink like that.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "I said, I don't think you should live.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I think at the weekend, we should use it.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "We have a nice apartment in San Francisco-- in Tel Aviv.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "But for the weekend, it would lovely.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "Man says no.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So I spoke with the Argentine consul.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And I said, would you give me one month to convince my husband?",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "One month is not the end of the world.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "After one month, I said to my husband, I tell you one thing.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I don't want to fight with you.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "But I paid in advance this consul a sum.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "If you don't want it, we forget it.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "We lost already money under Hitler.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "If we lose again, what could happen?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I don't want that marriage suffers about.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "I don't know which-- how much I told him I had paid.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "He said, if you paid already, take it.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "That's nonsense.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "So we took it.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "He was the proudest owner lately-- later.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "Because we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "And it was very-- only weekends or vacation.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "It was a drive from, let's say, from our store, 20 minutes.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "It was later one of the best neighborhoods, what I told you.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "So we had this trailer.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "And after a couple of years again, when money came from Germany regularly, we had the idea to build there a house.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "And we sold the trailer.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "And the trailer had still a future.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "A archaeological company bought it and took it to the desert.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "And we bought-- we made on the same plot a house.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "This house-- as my father built plan-- build houses, I was used to the plans, yes?",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "Before I could read, I understand the plan for a house, yes?",
      "word_count": 12
    }
  ],
