  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They want to make place for it to happen again.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Those are the guys, because there are no bad people.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "There are bad leaders.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "If people have good leaders, they are good.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Looking at America, I've never run into bad people.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Really.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Sincerely.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "I went to-- I want to do something in the house, and I was sent to some people in Parker to get some references and see.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I called them up.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I said, I want to see the job that they did.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Come over with pleasure.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And you should see that they invited us, how beautiful, like we would have been old acquaintances.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "It's that warmth that you can give to people.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I think we covered, more or less.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It was my pleasure.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I hope that our conversation will have some bearing on future generations for the good of the future generations.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
