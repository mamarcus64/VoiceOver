  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And the-- the mademoiselle had their own room, and the maid had a room, and my parents had a bedroom.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And then we had a-- a large living/sitting-- a dining/sitting room.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "In those days in-- in Europe, the living room had a huge table.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So if you had guests, you automatically set them around the table because you had to serve coffee and cake.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "There was no such thing as just coming in for, you know-- [INAUDIBLE] somebody came, they were served coffee and cake on the best dishes-- homemade cake usually.",
      "word_count": 28
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And that was the-- the norm.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So this was a huge, huge room.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we had these old credenzas with my mother's [INAUDIBLE] glasses and stuff.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "She had beautiful things.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And [INAUDIBLE] our apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And I don't remember too-- oh, we had a bathroom, which-- you know, with a heater.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "When you wanted to take-- you had to turn on the heater and-- to have hot water, because there was no running hot water in those days, even though Dusseldorf was an industrial city and much more advanced than some of the other cities were.",
      "word_count": 45
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It was a very modern type of city.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "So you want-- ?]",
      "word_count": 4
    }
  ],
