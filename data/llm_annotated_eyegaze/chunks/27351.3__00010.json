  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And they started to talk to me.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "At the beginning, sort of a friendly way, sort of laughing, you know, and where do you go?",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Where are you from?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Such a nice [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH] means mademoiselle.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "They would-- they would not say you to me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "They would say [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "But I-- I blocked.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I just stopped talking.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And then they looked at me again.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And they told me, oh, you must be a little Jewish girl who is escaping from the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And then other people started to watch.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I saw there was somebody sitting there and reading and started to look.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And I felt all the eyes on me.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And then I-- I felt that they were getting less friendly.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And the word Jew was already pronounced.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And I was terrified.",
      "word_count": 4
    }
  ],
