{
  "stem": "7592.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I got the one thing in my life-- I never gave up.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And that's what I think kept me alive.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I never think, oh, I never go, live through this war.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I always say, I'm going to live through.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And never bothered my head over what I'm going to do next, this.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Every day was a different day, and I knew I'm going to-- I talked myself into I'm going to survive.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Listen, you haven't got time to think about it.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "You take as it is.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You came, you saw people, squeezed three families in one room, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Like they say, just--",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was sharing with my wife.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I moved-- I was sharing with my wife, with some kind of relatives who helped me to get to Madritsch.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He was a tailor before the war, and with a big business.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "How you call this-- [GERMAN] they call this in German.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He put me over there, and taught me how to cut goods.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I became the number one cutter.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And my wife used to work over there, too, as a dressmaker, a seamstress.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "He came over there and he got one of the businesses in Krakow, which before the war produced ready made garments.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He took this over.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And the owner was taking care of it-- a very nice guy.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And he, through connections, too, he opened a big, big [GERMAN], working for the German government-- military, private things, you know, labor [NON-ENGLISH], you know.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And we got there with 1,000 people on day shift, and 1,000 people on night shift.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "All Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "This was already from ghetto, we used to go, because the building was outside.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And then when they liquidated the ghetto, in Plaszow concentration camp, they got the barracks over there.",
      "word_count": 17
    }
  ],
