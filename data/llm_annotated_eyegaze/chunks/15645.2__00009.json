  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] And [PAUSES FOR 5 SECONDS] [INAUDIBLE] I think it is a little [INAUDIBLE] like a window from one side, from the backyard And I think this could be the way we can run.",
      "word_count": 34
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "But it was very high.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "So I think the-- the vice.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 13,
      "text": "We took the vice, and with the vice we can do something to jump.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 14,
      "text": "And it was dark.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "And we see through the-- through the planks in the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "We see when they take everybody from the jail outside in-- in the garden.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 17,
      "text": "And-- and they take-- take-- they tell them to take their clothes off.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 18,
      "text": "They take-- and then they take the clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 19,
      "text": "We are sitting and looking at everything what's happening there.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 20,
      "text": "And they take the clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 21,
      "text": "And they took them away without the clothes, just to-- to prepare before they have the trenches with-- with-- with-- with-- [NON-ENGLISH], [PAUSES FOR 4 SECONDS] yes, ready to bury.",
      "word_count": 30
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 22,
      "text": "And it was quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 23,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 24,
      "text": "And so I think we wouldn't jump through the window.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 25,
      "text": "And I have a look through the-- through the-- through the little door.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 26,
      "text": "Look down, and nobody's there.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 27,
      "text": "And I said, I jump when somebody's standing, I jump on him from the back, and I-- maybe I can take the rifle from him.",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 28,
      "text": "Oh, but when I jump down, and I say to him nobody's here.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 29,
      "text": "Nobody's here.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 30,
      "text": "And I said, come on.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 31,
      "text": "Come down.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 32,
      "text": "And we go down, and I tell him not to run.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 33,
      "text": "And we walk.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 34,
      "text": "We walk back in the backyard.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 35,
      "text": "And we go through the back yard to the main road-- to the main road.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Nobody saw us.",
      "word_count": 3
    }
  ],
