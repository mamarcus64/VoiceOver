{
  "stem": "24462.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "And she is very well accepted on the peninsula-- [?",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "Rye, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "Rosebud, ?] everywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "They want her as a replacement teacher or full teacher, or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "She's absolutely magnificent.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "I-- I-- you know, to do the degree at her age, it was really an effort.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "She had to do some matriculation and the three years of Monash.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Jacob is-- went to-- Phillips, as an electronic apprentice, which was the best thing we have ever done.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "No Harvard, no other universities.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And then he went to RMIT.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He graduated as an Electronic Technician.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And he's very, very useful now in-- with computers-- EDI, everything which has to do with the computers.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "He is the-- he is the man.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "He married Shoshanna, which is Israeli girl.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They speak Hebrew at home.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And the children speak Hebrew.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "They went to Mount Scopus.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "We took them out from Mount Scopus, because it's too much-- too much problems.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And they are succeeding very, very well.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "The younger is a pianist, a magnificent piano player.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "And they are very good children, very intelligent.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "My big daughter has a son who is 24.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "He graduated this year from Monash, Industrial Design.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "He has done well.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "We didn't expect him to do so.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "But he did well, fortunately.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "And the other children are a girl, Michelle, and Andrew.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "They are at school and doing well at school.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "My little daughter, Ruth, who was born in Jerusalem-- Jacob was born in Netanya.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "My little daughter who was born in Jerusalem wrote she has married Peter-- Dr.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "Peter [?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "Hartung. ?] He wasn't a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "Now he is  a doctor, Peter [?",
      "word_count": 7
    }
  ],
