{
  "stem": "3002.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And I got into this household where my new boss-- his name was also Erwin Hadrian, H-A-D-R-I-A-N, Hadrian.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And that was already '42 .",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "So I stayed there till '44.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "While the baby was born.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He had two children.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The older one was [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The younger one was [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "He had a old-- [PAUSES FOR 3 SECONDS] his sister, a spinster, an old maid, lived with them.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And she was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "His wife was wonderful, very, very nice, decent woman.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I think before the war, she was cleaning houses for the Jewish Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "But she was very nice, very decent.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "She was afraid of him, [PAUSES FOR 3 SECONDS] because when he went in the morning out to his office or so, she was listening to the BBC.",
      "word_count": 28
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS] And she had part of the family, which was visiting Sundays.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Sundays was always a special meal with rabbit.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "That was the treat.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And I used to go, actually, from Berlin-- oh, when I arrived in Berlin, the first thing I got is a P letter.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "I was supposed to wear that P for Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I was supposed to wear outside the coat or whatever I wear and underneath, too.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I used to go to Berlin with the two girls by streetcar, it's so near.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "But I always took off the P.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Not to-- because they didn't look so friendly at foreigners.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I used to go with those two of his daughters to Berlin.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No, didn't know anything-- didn't know anything.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "For two years in this household.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I had a little room in the attic, which was just room for a bed.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] But I helped her clean the house.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And Sundays, I could go with the girls to Berlin.",
      "word_count": 10
    }
  ],
