{
  "stem": "9987.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I got a registration number-- very low-- 182nd person from the Polish quarter-- 182, 183, 184, because we already had a child.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And I thought, well, since it's such a low number, in the hundreds I probably going to go soon to America.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "But they let in 50 people born in Poland, and they closed the immigration for the Polish quarters.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "So we're staying there.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "It's already 1948.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And I don't want to be in camps anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I was acquainted over there with a welfare officer, a Jewish girl from London.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She says, Berger, I can help you if you want to.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "If you're willing to go to London, I can get you to London.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "So I says I'll go anyplace, just away from here.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "She says, I'm going to write to my brother-in-law.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "He is a very wealthy person.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Less than three weeks, I got papers from England to come as a domestic resident couple.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "That means I'm supposed to be the butler, and my wife supposed to be the maid.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And they-- we went to the-- to the English consulate.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They gave us a six-months visa to go to England.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We came there.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "He didn't need me, but he found me a job right away.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I went to work in a shop, was making nice money.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "We got an apartment-- my wife and my child.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "We went every day to the nursery.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed there for two years, and we had a pretty nice life.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "After about six months that we came to England, usually I'm supposed to get extended my visa all the time-- the extension, like all my friends over there had to do every six months.",
      "word_count": 34
    }
  ],
