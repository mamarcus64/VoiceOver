  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah I-- I tried to learn English at-- English for foreigners at Hunter.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Where I really learned English-- my uncle said, go to the movies.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It's air conditioned.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Match the action to the-- and it was very good.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "It was a very, very good technique.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And I just wanted to work, which I did.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And then I met my husband on the tennis courts.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "I loved to play tennis.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "My husband was an American--",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "--many gen-- many generations on his mother's side.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "His name was Paul, Paul Keller.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "We were married in-- on December 23, 1950.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We met in-- in the spring of 1950, on the tennis courts in Central Park.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And I just-- really, when I first came here, I wanted to have nothing to do with anyone I knew from Europe.",
      "word_count": 22
    }
  ],
