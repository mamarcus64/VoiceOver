{
  "stem": "13141.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "But that affidavit was no good because my waiting number was not up.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So I had the affidavit, but I couldn't use it.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But I had the affidavit with me.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And I showed it to them.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So they got a new affidavit.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And they got me the, the visa to go to the-- to the-- to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And your mother's cousin was in the United States?",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It was my mother's cousin once removed.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "He had come to the United States in the '20s.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And he had a business in the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He was doing quite well.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He gave me the affidavit and he paid half of the, the, the passage with the boat.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And the other half was paid by two friends of mine who had immigrated earlier, whom I also sent the telegrams through the Joint Distribution Committee.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they both paid about $120 each.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "That cousin of my mother paid about $240.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "It was about $480 or $485.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] So I left from Barcelona.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "When I left Spain or Germany?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Well, I left-- I left Munich at the, the second part of July, '41.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And I left Barcelona towards the end of August in 1941.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "It must have been very close to the last day of August.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And Herbert, he got his passage from, from Bilbao.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "That's at the west coast of Spain.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Barcelona's at the east coast of Spain.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So he left from Bilbao.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "I left from, from Barcelona.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And the ship I was on was We were about 580 people on that ship.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "It was a very small ship.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We were about 300 people in the hall of the ship, the aisle part of the ship, you know?",
      "word_count": 19
    }
  ],
