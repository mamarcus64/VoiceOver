{
  "stem": "13851.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And I was unloading big trains.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "It's called cox, C-O-X.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "It's something-- a material.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "It's light but gives a lot of heat for the metal.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "And I was unloading the trains.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "And the trains was bigger than this house.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "Unloading them, about two or three boys and a wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "They worked, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They worked with civilians, the other people.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Did some work.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "There's only one.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "The oldest one had a child, but-- but what happened during the-- they took us out in market.",
      "word_count": 18
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I told you about this.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "It was a Sunday.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And Saturday night, I worked at night shift in the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "So before I went to the factory, I looked at my parents, and thought, this is the last time I'm seeing them.",
      "word_count": 22
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "And my brother was working during daylight, so he was in the time when they took us-- took out the Jewish people all from all in the market to send them away.",
      "word_count": 32
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "So he was on the list from working with me in the-- the factory.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "So he came down in the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "He told me that the oldest son was-- had a baby.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "It was a bris, where the Jewish people-- they come to circumcise.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "I didn't see him, but he saw it.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "But that's-- then they had to go out.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 13,
      "text": "And they made everybody get-- had to get out.",
      "word_count": 9
    }
  ],
