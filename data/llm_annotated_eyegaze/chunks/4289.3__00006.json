{
  "stem": "4289.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't make the affidavit here.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So she went to one of her sisters and brothers of Jehovah Witnesses, and they are really nice people.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They did it for her.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "They signed, you know, an affidavit that I can come.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they will be responsible for me.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I came with my husband and my daughter.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And we came to Chicago, where we stayed for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And unfortunately, my husband did not learn very well English.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And he was-- he was only-- he only knew one profession, photographer.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And I, at that time, started to think of learning a little more than just being a housewife.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "And I started my night courses.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I was going, and first of all, I learned how to drive.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "And I kind of grew apart from him.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "Because we are also a generation apart.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "My husband was 14 years older than me.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "And I thought to myself, that when my daughter will be bat mitzvah, I'll divorce him.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "Because I wasn't happy.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He never did.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "The son, when he finished high school, he went to the Israeli army and remained in Israel, where he got a very good education, a very good position.",
      "word_count": 28
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I understand he's a diplomat.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And he's very well off in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "While I was going here to school, I studied bookkeeping.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I took all kinds of courses to learn what was important and what was going well, for a person who doesn't know very well English.",
      "word_count": 25
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "So I learned bookkeeping and data processing.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And I had quite good success with it.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And every time I changed jobs, I got a better job, a better position.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And my daughter grew, and so grew me and my husband apart.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And we finally got divorced in 1971 when Ester was bat mitzvah.",
      "word_count": 12
    }
  ],
