  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And we was delivered, with my brother-in-law of one wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "He was so nice, that German.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "He delivered us till they opened the gates to go-- that gates, it's called.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "He was there.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Every day, I saw a different picture.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "What was the picture?",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Oh, he was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "He was catch because he bought a chicken.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "He was a bullet.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Then, there was one time where you pump water.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "You know, where you pump water?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "They took out beautiful girls with motorcycles, young punks, you know, maybe 16, 17 years.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And they tell them to take off their blouses.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And they was drunk, you see.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And when you're drunk, you don't can do nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "They have a satisfact-- take off the blouse around.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "There was six beautiful girls, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Beautiful.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And it was so cold there.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And the girls [INAUDIBLE] He have a pipe like the police.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And he give it right over the head.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And she start to run so fast until they almost fall down.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And this was almost dark.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And they say, go home.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I looked this through, through the top.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I said, what, Daddy, what be next?",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "This time-- you remember, the time was a time to run to the Russians.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "This was the time before closing.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I said, Daddy, let's leave everything.",
