{
  "stem": "14463.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was-- [PAUSES FOR 3 SECONDS] I was in cheder, right, or whatever I was-- anyway, the broke-- the war broke out.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "The whole city was screaming.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "There was a lot of commotion.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was running around, running around.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The war broke out.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "What are going to do?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "What are we going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "What was that-- what's that mean?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "You know, what are we going to do?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And I don't want to call myself I was smart.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I was more-- I was maybe, what shall I say.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "What would be the more appropriate English name would be-- [PAUSES FOR 3 SECONDS] it doesn't come to me.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, it'll come later on maybe.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I said-- I always had my-- a mind of my own.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "That was since childhood.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I had a mind of my own.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And I came to my father.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "I came to my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And I said, look, I spoke to some of my friends, and I see what's going on.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And I know what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "Let's leave the city immediately, because we are from the border one hour from the German border.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Once they breakthrough, they're coming here.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My father say there won't be a war.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "You know, the Polish army will take care of them.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It's only nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It's a small thing.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "No, I want to run.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I want to go.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Where you going to go?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "East, right?",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And-- so he looked at me, and I can never forget that.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "He said, do you really want to go?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Let me find out who else in the family wants to go and you go with them.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "I and my-- my son, Moshe, will stay here to look after the-- after the houses, after the flats, after the business.",
      "word_count": 22
    }
  ],
