{
  "stem": "11175.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We know we're going to the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They took us to the barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "They gave us a shirt and different clothing.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "I was wearing a pair of pants-- I fell out from them.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "They were like that-- they didn't fell out from me.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "No, I fell out from them.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And they sent us back to the-- to that barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "Not to the Taunton barrack, but to the handwerker.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And I remained.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "This is the way how I remained there alive.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And I was still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "That's the-- the-- I came in.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "This was before the holiday.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "That's what I'm saying.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "That's before the holidays.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was assigned and-- I was laying already under there-- not a bed.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It's also the-- [INAUDIBLE] you had a little pillow, and they have blankets to cover themself.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And some straw was laying in behind.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "It's different.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I was accidentally was assigned to sleep.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "The next-- the next one from me, he was the baker, the Jewish baker, from Treblinka.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And he was from Warsaw, a very known bakery in Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 8 SECONDS] I'm going to remind myself the name of him.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I was laying with him.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people-- the-- the-- the boys, they ask him, give me a piece of bread.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "You have bread.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Give me a piece of bread.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I was laying with him about two weeks, three weeks, and I never ask him for a piece of bread.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "One morning, I got up from-- he-- he left early.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I got up in the morning, and make my bed.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I take a look.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "It's-- it's a piece-- a half a bread is laying under my pillow.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "What did he-- I-- after he left, I usually did for him the bed, yeah, every morning.",
      "word_count": 17
    }
  ],
