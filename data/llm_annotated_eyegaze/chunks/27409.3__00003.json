  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And they pay through the bank.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "So as nobody has-- in addition to the petty cash, nobody has money.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was-- we had to study.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "So they made-- because they needed staff, so they made a short course from the different university to train us.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was from the institute [? cost ?] bank, [INAUDIBLE] state bank institute that was a branch.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We got teachers from Odessa and Moscow from the state bank institute, which taught us-- it was three months.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And then we finished-- I finished also one of the top and our-- it is called the English name, the chairman, director general, was Bulganin, which afterwards became Marshall Bulganin.",
      "word_count": 30
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And the government [INAUDIBLE] the government.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "He presented me with my diploma, which it gave me some priorities.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I could choose where I want to work.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And I got 2,000 ruble, a price.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "In order to give you an example, it was 2,000 ruble.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "My father, as director of the beer brewery, [INAUDIBLE] director, got 400 ruble a month.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "I got a surprise 2,000 ruble, plus all the volumes of Lenin, plus all the volume of Stalin, which were-- I wouldn't have been able to read them all.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "They were good for [? tie ?] present.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Not.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I did not know.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I could speak Ukrainian.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I could speak because I had servants.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I knew the Cyrillic language from the school, because the old Romanian was written in Cyrillic.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And being a so-called church school, they learned the old saltier, to read the saltier.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "So I learned it also.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "But I did not know Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "My grandfather found the old, from the Tsarist time, dictionary, [? produced ?] dictionary.",
      "word_count": 14
    }
  ],
