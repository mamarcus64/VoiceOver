  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 9 SECONDS] 13 days in the month of July, [PAUSES FOR 3 SECONDS] the verkstaden were liquidated.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Warzog got a promotion to Hauptsturmfuhrer.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And he was given the job to run the camp in Lemberg.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 22 SECONDS] We were transferred on that day to Janowska camp in Lemberg.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] I'd like to tell you a little bit about the camp in Lemberg.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "It was [PAUSES FOR 3 SECONDS] a place where Nazis came to get trained in brutality.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I have a series of books about Janowska written by my friend, Mihail [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "His name was Borohowicz, a poet from Poland who was with me in Janowska.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And after the war, he wrote many books about Janowska.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "One of the books he named [NON-ENGLISH], Every morning at Appell, they used to have an orchestra from famous musicians from around Europe.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And they were playing, playing music.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And as the people were walking out from their barracks [PAUSES FOR 3 SECONDS] with the music playing, [PAUSES FOR 3 SECONDS] many of the Jews that were not healthy enough were pushed into the sides between barbed wires and were shot.",
      "word_count": 42
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Others, for any kind of [PAUSES FOR 7 SECONDS] things that was done that was out of order, like not putting out their hat in time or not taking it off on time-- they were hung.",
      "word_count": 36
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "They put people, and they hung them on poles with their feet up, their heads down, and took them until sometimes two, three days until they expired.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It was-- they had trained dogs to rip you apart.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "People were walking out to many different places to work-- into town of Lemberg and into other verkstaden-- places where his own people from Zloczow was brought.",
      "word_count": 27
    }
  ],
