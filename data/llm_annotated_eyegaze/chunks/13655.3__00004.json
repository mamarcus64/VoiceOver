{
  "stem": "13655.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The Polish police, they looked away a lot of things for me, because they knew it from before.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But a lot of times, was they came in, the police, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "This [INAUDIBLE] prison guard.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I had to go to the [NON-ENGLISH] to get [INAUDIBLE] for that.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They knew already Louis could do something.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I had a lot of trouble.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I fill one out.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I have to help him, but I [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And this was the rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I'm mixing up a lot of things, because-- I will mix them up, because--",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Right now, we are in 1940.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Let's come to 1942, the liquidation from ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Because that is for weeks and weeks, you're going to sit with me. you wouldn't go through.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yom Kippur [INAUDIBLE] 1942, this was already after June the 6th, the liquidation.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "There came another story.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We have to go to Biala, and there is going to be a Judenstaat.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And everybody is going to go to the train.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "There is going to be prepared for them the cars.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "What can I tell you?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "This was on a Monday night.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Tuesday, Wednesday, and Thursday, they got to be cleaned up.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "No Jews anymore in the city.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Who gave this order?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "The Judenrat announced what they received from Biala, from the main headquarters for the Gestapo.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "This come-- they sent a Polish guy, Polish people, with the horse and wagon.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "They took out, everybody gone, to the railroad.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And there, they went to Biala.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "In Biala, they took in-- wait.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I was the last one to leave my town, me and a few more from my family.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Not the whole family, because my whole family went out a day before.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My sister took the mother.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "My mother was not conscious.",
      "word_count": 5
    }
  ],
