{
  "stem": "12053.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And we loved when they went to the pictures.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Because then we would raid the larder a little bit, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We were really hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And, and Inge, she, she was sent shopping.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And she used to snitch a few pence here and a few pence there.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And she told me only a few months ago what she did.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The-- all the village-- that was after  the Coventry blitz when we evacuated, the whole village must have known about the state we, we, we were kept in.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Because the neighbor, she used to ask for my sister when her husband went-- he was a traveler-- when he went away.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he-- she asked for my sister to sleep there with her.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She pretended she didn't like to sleep alone.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And the foster parents couldn't say anything.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "She-- they couldn't say no.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And Inge loved going there to sleep.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And she'd have a nice breakfast before she went to school.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And she used to spoil her at night.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And you know, and she used to bring things over for me sometimes.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "It was-- so that means the neighbors must have known.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And especially when I worked in the cotton mill, they also knew.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And we used to-- Inge, when she went shopping, she told me about a bottle of pop.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She fancied a bottle of pop.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So what did she do?",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "She put it on the bill, which wasn't itemized.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But she was afraid to bring that bottle of pop home.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "She kept it in the shop.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They kept it for her.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And she'd go and have a drink from that bottle every time.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "It's dreadful, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It, it seems funny now.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "But it wasn't funny at all.",
      "word_count": 6
    }
  ],
