  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "You know, there was a special-- when they started to you-- you know, the [INAUDIBLE], interior police.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "You must stay on the corridor with the face to the wall and their hands on the wall, you know?",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "It was all.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No, I say in Tajikistan, it was within Jewish prisoner, you know, what about the religion.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So there was a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "No, you can't-- you can't see, is-- he's a Tajik or he's a Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The wearing.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "You know, they don't work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I haven't seen in Tajikistan a synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I never have seen.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I don't-- I was always in the brick factory, [INAUDIBLE], not in the town.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, more or less.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, no mix.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The Polish people, when there was the Polish army, you know, they go to the Polish army, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "No, there was mixed.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "They was from Poland, you know, a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I start at the army.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I got back my-- these.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "In 1943, started-- we go to the front, yes?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And after, come back to Novo [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "To the front?",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "They take us with the train, you know, and walking, again.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "So we started in-- near Kharkov, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "In the army, in the Czech army, the first beginning, we have been over thousand people.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "From these thousand people-- I will remember the place.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We're near to Kharkov-- was nearly 700 Jewish, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "All Jewish, Czechoslovak Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And their died, I don't know, few hundreds, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "'43-- it was spring.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We go to the front, you know, and we helped liberate Kiev, the town Kiev on the Ukraine, yes, the Czechoslovak tankist.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "It's difficult to tell, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You stay in the tanks and move and move and move.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You don't see nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
