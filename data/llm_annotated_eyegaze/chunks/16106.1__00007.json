  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "There was Uncle-- Uncle [?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Boris, ?] the only brother.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Who-- [LAUGHS] who, who one day announced Being Jewish is dangerous.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] turned into a Dane.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Married a Dane, left for Denmark, and was never heard of again.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "It was before the-- before '39.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And my mom never-- didn't want to forgive him.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But during the war when things-- when the Germans marched in and things were really horrible, she said, Well, Boris was very clever to become a Dane.",
      "word_count": 27
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And from then on, I had this image being a Dane is the most wonderful thing to be.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And I think I told it to you when I came to America first time, my mother-in-law [?",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Erna ?] took me to see And high and below, they were all saying, There is nothing like a Dane.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And I was not at-- not surprised at all.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Not surprised at all.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "There is nothing like a Dane.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And well, there was-- and then there was my beloved aunt, Tante Minna.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "She was glorious, beautiful, talented, avante garde, interesting, charming, and lucky.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "She had-- she was very talented.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "She had this lovely salon where she, where she sewed the clothes-- dresses.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "In those days, people didn't buy-- well, people who are somebody wouldn't buy clothes from the rack.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "They went to a seamstress, to a salon, and sat in the waiting room and looked at the magazines and picked something out and went to the shops and got the material, came to fittings, and et cetera, et cetera.",
      "word_count": 40
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "My aunt was very good at it.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "She was one of the top.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "Libau was a town where there were many Jewish people who were in that business.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "There were the people who did the coats.",
      "word_count": 8
    }
  ],
