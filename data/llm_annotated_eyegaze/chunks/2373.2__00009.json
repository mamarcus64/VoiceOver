  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "The miracles, well, everybody who can tell this story, who survived, has some miracles.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "I call it miracles.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "They-- they were accidents or incidents.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "You didn't know if you are doing the right thing or the wrong thing.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "It-- things were just happening to you.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "And to me, it was for my good what had happened.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "Because when I couldn't study medicine and I study nursing, that was my lifesaver.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "Because I would have never stepped out where they said, 'Qualified nurses step out.' If I wouldn't have been a nurse-- so that has its reason that I made that course.",
      "word_count": 31
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "Then when-- that saved, actually, my life.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "Because that's how-- how I-- I wouldn't have survived under the conditions working in a factory or so.",
      "word_count": 18
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "I was a nurse.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "And I had better conditions-- human conditions.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "And I survived it.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 12,
      "text": "Then when we were freed, liberated, I-- I was such a big eater and so eager on food.",
      "word_count": 18
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 13,
      "text": "And if I wouldn't have that sore on my mouth, I would have eaten myself to death.",
      "word_count": 17
    }
  ],
