{
  "stem": "7860.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes I did.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I thought I did.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was rebelling against them too just the same.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I-- for me to survive the war, I was conditioned myself evidently, and subconsciously.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I love dogs.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And dogs were more or less like therapeutic for me to bring in home all the straight dogs.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And so my mother used to kick me out, chase the dogs away.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So then why bother coming home?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I didn't bother coming.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Many nights I stayed out with the dogs.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And then my mother used to catch me and drag me home.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And in one of them instances, when my mother was dragging me home after I was making a somersault after inciting some kids to throws stones at a neighbor's house, when the neighbor threw my little dog over the fence.",
      "word_count": 40
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So I put my hand under-- between my legs-- and I sprained my arm, and without telling my mother.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And the flesh on the arm grew together.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And my mother noticed that.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "She said what's wrong?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So I used to have-- she used to have to give me treatments, soak it in salty water and massage for my arm.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, I didn't bother coming home to massage it because it was painful.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She got a hold on me one day.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And she's dragging me home.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She grabbed me by the arm, pulling me.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So I fainted.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And this-- this rejoined the-- the sprain went back in its place.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And a Polish policemen-- my screams came out of nowheres, and started accusing my mother, calling her a dirty Jew.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Why you punishing this little boy?",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My mother started pleading.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Put him in jail.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Put him in jail.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "He's a gangster.",
      "word_count": 3
    }
  ],
