{
  "stem": "18932.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 364.0,
  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "This was a-- a couple of apartment were spread out, and we had a little bit of ground in the back.",
      "word_count": 21
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "And all the tenants used to divide a little piece of ground, and we used to put some-- grow some vegetables-- radishes, beets, cucumbers.",
      "word_count": 24
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "And we also had three fruit trees, which really helped us in the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "But so we used to divide whatever fruit would grow against the tenants, and everybody got a little bit.",
      "word_count": 19
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "And one day when I was in the back there, I heard somebody come in and yell, Eva Zysman.",
      "word_count": 19
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "And I had a bad feeling about it because I knew my name was on the list.",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 8,
      "text": "So I ran in the back, and I lay down between the-- the beet-- the beets, and I covered myself with the beets.",
      "word_count": 23
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I put it all around.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "And they came to my mother and ask her, where is Eva?",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And she says, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where she is.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "So they said, well, we're going to wait.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "Says, I don't know how long it's going to take when she comes.",
      "word_count": 13
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "But she says, here-- she gave him a bag of apples.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 8,
      "text": "Please write down that she's not here.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 9,
      "text": "So OK, they took the apples.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 10,
      "text": "They went away.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 11,
      "text": "And this was the first time that-- to save me.",
      "word_count": 10
    }
  ],
