{
  "stem": "21978.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "When my daughter didn't cough at night, I came to see if she's still alive, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "When my son cried because of something small, I was worried something might happen.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I must lose them, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I was always worrying the time I'd lose them.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And I was always very appreciating that my husband was so understanding.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Was there something else?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Do you think about the Shoah often?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I have to on Monday morning when I go to the Holocaust Center.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I have been told by many people and by doctor that I shouldn't.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But I feel like I can't get out of it.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I feel it's my duty.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "It's my duty, even if I do suffer by it.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Because I don't do it for pleasure.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I do it because I feel that there are so very few of us who can contribute to the history, to put it down that other people know about it.",
      "word_count": 30
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And it's not only history of the Jewish people, just humankind.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, I think I have been very fortunate.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I was very fortunate I had a lovely parents.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I had a little sister who was a little darling, even if we called her pest.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I was fortunate that I have been healthy and brought up in healthy way.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Our mother never spoiled us.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "We have been always looked after.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "But we did have to look after ourselves just as well.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And that might have contributed to the way that we survived.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I was fortunate that I was a twin.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "That was my first fortunate thing.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Because of my being twin, I have been always supported somehow.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Or I supported Annetta.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I learned how to deal with other person.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And I was fortunate that I survived.",
      "word_count": 7
    }
  ],
