{
  "stem": "6837.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "And you're going to come to somebody that's going to ask you how old you are.",
      "word_count": 16
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "Tell that you're older, and make yourself look older.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "And we took his advice, I didn't know.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "We thought he's Jewish, he wants the good.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 12,
      "text": "He's on our side.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 13,
      "text": "And that's what I did.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 14,
      "text": "And my--",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "He was from Poland, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "He spoke Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And um, They separated us.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "The men lined up separate and the woman, the ladies--",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "They had an order-- somebody who spoke to us German-- in German-- soldiers, must've been SS, I guess.",
      "word_count": 18
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "My father with my brothers, they were on one side, and my mother and the rest of the ladies, girls, went on the other side.",
      "word_count": 25
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And then they stayed like five in a row.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "And we stood there for awhile, and then the-- they started moving.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "The line started to move.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And my sister didn't know what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "Should she listen to my-- to that certain person to told her to do what-- to give away the child.",
      "word_count": 20
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And she did, and the older sister said what shall I do?",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "She says, shall I give my children also to an older person?",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "And she was looking around to who she would give it to.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "But then she decided no, I'm not.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "Whatever happens to my children, I want to be with them.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "I'm not going to separate myself.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "How old were all the children?",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "There was 5 and 3.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yes, her name was-- the little girl's name was Miriam, and the little boy was named David.",
      "word_count": 17
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "And my other sister's was Taube.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "She had one child who was about four years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "The day like-- it was-- it was-- I don't know the weather.",
      "word_count": 12
    }
  ],
