{
  "stem": "18770.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 368.5,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "It's quite a wide range.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "While we were in Chelm, I remember the Polish army retreating.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I definitely remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "That was very-- the colors.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "They used to have these funny kind of pea green uniforms.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "They have practically no mechanized-- it was all horses and wagons.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "It was very primitive.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "But I remember them withdrawing.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "There were a couple of sort of mini air raids.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "I remember one time, we-- there was like an improvised air raid shelter behind the house.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "And it seemed that the air raid was over and we went out-- or I went out of the shelter-- and the next thing I knew, there was a German plane overhead.",
      "word_count": 32
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "And somebody grabbed me and pulled me back down into the shelter.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "I, I, I remember that.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "I remember my sister and my cousin, who were the oldest of us children, finding-- this was after the Germans had already come in, because they did come into, into Chelm-- finding a pistol.",
      "word_count": 34
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "A German Luger.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "And it was-- which we thought was fantastic.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "Of course, if you were found with a gun, everyone was instantly killed.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "And I didn't know that.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "By the Germans, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "By the Germans.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And I remember my sister and my cousin taking the pistol somewhere in a field and burying it and getting rid of it.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So they had enough sense of that.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The governess leaves at some point here.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember exactly when it is.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I do know that when she leaves, somewhere around then, and I know it's connected with it, I get very, very sick.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I develop a terrible ear infection.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And now, there are no doctors to be had.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "There's no drugs to be had.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "There are curfews at night.",
      "word_count": 5
    }
  ],
