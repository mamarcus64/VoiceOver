{
  "stem": "1938.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "After the war, I-- I was raising my son, and after five years later-- five and a half-- my daughter was born in Cleveland, Ohio, and my son helped me a lot to raise my daughter.",
      "word_count": 36
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They were very close until now.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "They never had an argument between themselves, a brother and a sister, because they were helping their mother and father.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I was the bread giver.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I was working all the years, and my husband was working, maybe all together, maybe a year.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "He was a mechanic-- a precision mechanic-- and he was working for the Lear Corporation here in Los Angeles.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "But then-- then got slow, and he was the last one to be hired, so they let him go, and it was very hard on him.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And I was-- my profession?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't get to a profession, so I was taking care for a-- in a convalescent home in the office for a little time, and then I was managing a-- a wholesale clothing shop.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Here.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Cleveland I was working in a factory of a-- packing locks, all kind of-- I was working machines, and very hard.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was working in back alleys, whatever it took to make a living for my family.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and my husband's family was living in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They came from Belgium-- Brussels.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And the weather in Cleveland was impossible, so we decided to come here.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And-- and we stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "It was much better than Ohio, and I raised here the-- the children, and I worked, and I never really was sad for myself, because I was very appreciative being alive, after what I went through.",
      "word_count": 36
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I always think, it could be worse.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't have a family, now I have a family, and I thank God for this.",
      "word_count": 16
    }
  ],
