{
  "stem": "10397.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 22.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "She likes to dress.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "She makes parties at home, 25 people.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "We went there for the Thanksgiving party.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Well, it's a small party, 12 people, 14 people.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "She's an excellent cook and baker.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "And she is very active in the UJA, in the temple.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "She has all kind of duties.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "They appoint her-- Ellen Brand, Ellen Brand.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "And she works in the office as their administrator.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "Because nobody can-- she-- they have five employees.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "But the-- the-- the most important things, she takes care.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Richard.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Jean.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "In Stuttgart-- in Stuttgart?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "In Rockford, Illinois.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Rockford, Illinois, that's 100 miles.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It's on the border with Wisconsin.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Of course, she has-- she has three children, Abraham, Benjamin, and Shira.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They were bar mitzvah.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "She didn't want bat mitzvah, because they-- there was not such a thing.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And they had Hebrew teachers and Hebrew school and whatever you-- whatever the temple had to offer, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Grandchildren?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] Grandchildren-- my Rachel teaches adults for-- prepares them for bar mitzvah.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "There was an accountant, also from Brody.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "From not Brody, close to Brody.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He lives next door to them.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He never was bar mitzvahed.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "He has-- he is maybe 50-- no, more, 60-years-old.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "He wants to be bar-- Rachel is teaching him.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "What are you talking?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Religious to a point, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The-- the-- [PAUSES FOR 3 SECONDS] My mother was very religious.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We had all the holidays.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Everything was kosher.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And she had only Jewish friends, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And she was-- she-- she subscribed, in-- in-- in Warsaw, there were two Yiddish papers, and",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh, can-- oh, can I talk?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I belonged to the temple.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I belonged to the Chabad.",
      "word_count": 5
    }
  ],
