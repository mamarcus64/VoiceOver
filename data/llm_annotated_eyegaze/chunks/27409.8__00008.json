{
  "stem": "27409.8",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "A Dutch man, nice chap, but the-- the chairman told me-- boss, manager of the bank told me, we don't need people who promenade in the army all the time.",
      "word_count": 30
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I was called up, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It was something-- we mobilized.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And so I-- '55 I came to England on a work permit.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I worked here.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "First in-- in the industry, as a specialist in the food industry.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "In [INAUDIBLE] City.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Afterwards they found of my knowledge of languages, my technical knowledge.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I worked, officially it was scientific information consultant, which was a part of intelligence work.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Scientific intelligence work.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Mostly Russian products, Chinese, and so on.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I came on a work permit.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "My wife was British by birth, through her father.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But until Prince Philip, also he was soldier in the British army-- navy.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He was still not British citizen.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Also, he married the queen.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Then come [INAUDIBLE], that facilitated.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "But I had already had my work permit to work in Britain, so I came as food specialist-- food technician.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I did, but I did not really study.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was special course, which I made scientific intelligence officer from the home office.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I applied for the British citizenship.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My children were born.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My son-- two sons were born.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And to lived happily further here.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "One, '55, 1955.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And one-- no, '56, sorry. '56, 12th of June.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "The other, 3rd of February, 1956.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Not married, but they studied, both, and are in the jobs which help the community.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Not only the Jewish community, the general's [? estate. ?]",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "The older son, Selwyn, is a senior executive at the [?",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Center ?] to the University of London.",
      "word_count": 7
    }
  ],
