    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They are just here for killing.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "So she said, you will be working inside with me and help me, because I can't-- you see my legs are swollen.",
      "word_count": 22
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I can't work so much.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "So that's-- so I did.",
