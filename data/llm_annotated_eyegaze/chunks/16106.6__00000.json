  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, those guys get very annoyed with me, with my so-called chutzpah, which is called [GERMAN] in German.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They just yelled at me all the time, that something is wrong with me, and they're going to really show me the-- the ropes at room 70-something.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "[BACKROUND NOISE] It think it was 79.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Off I went to 79, and what did [?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Catherine ?] do in those situation?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "She did-- she preempted.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Before the guy could say something, I already said it.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "This is-- I said, what is wrong with those people out there?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "All afternoon, they have nothing better to do than to talk with me and harass me, me, Veronica [?",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Reimers? ?] I mean, did we win the war already?",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "That was always a like, did we win the war already?",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And that guy was on the phone, he turned around, and he laughed.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "He said, [GERMAN], which is very tasty, delicious, delicious, he yelled.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And he complained.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Can you imagine, he said, that I have all day long, all week long, to deal with you [GERMAN], which means those stupid people who are not intelligent, and stupid, uneducated people?",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Would you like to be in my place, he said.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "You have something to complain?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And then he said, [GERMAN], Fraulein, what is it I can do for you?",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "I said, first of all, I want [GERMAN]-- that is bread-- bread coupons.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "[SPEAKING GERMAN], what other [GERMAN], and a [? pass, ?] please.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "[SPEAKING GERMAN] Fraulein, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "Fraulein, Fraulein.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "He couldn't have been nicer to me.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "I mean, absolutely, here I come out of [GERMAN].",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And I-- I got all those doo-dads in my hand, and I walked through the main office, and I howl-- and I yelled, auf Wiedersehen.",
      "word_count": 25
    }
  ],
