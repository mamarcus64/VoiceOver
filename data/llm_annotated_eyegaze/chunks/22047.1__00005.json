{
  "stem": "22047.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Well, Sola Street was not too far from-- from La Cumbre Junior High School.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Anapamu was right across the street.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "So-- so we moved to Anapamu, and I went to junior high school all the way across town.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "When-- when I went to high school, we moved over right near the junior high school, so I went all the way across town to high school.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "But I thoroughly enjoyed school.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I was a good student, A student in-- in high school, and thoroughly enjoyed it.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "I was-- enjoyed math and-- and science and art.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "I liked art.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And I-- I-- I believe my high school experience was really good.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "I was in ROTC at Santa Barbara also.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I was a bit shy, so I-- I don't know that I was-- I had a lot of friends though, a lot of friends.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I palled around with-- with [PAUSES FOR 3 SECONDS] guys.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I had a-- a particular friend that lived a couple of blocks from me, and-- and we played two-man football, and we challenged every other two-man football team that we could find, and we always won.",
      "word_count": 36
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Bill McGuinness.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Billy McGuinness.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And we-- we just palled around all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And then in school, I had these other friends, that we were together at school.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "One of them was named Vince [?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Garno, ?] and he-- he kept my '29 Ford, when I was in high school, my-- my 1929 two-door sedan in-- in good shape.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "In fact, he hopped it up [LAUGHS] so I could race with other guys.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And another was Dick [?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Dockposo, ?] Jimmy Pike, Bill [?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Herdman. ?] Those were some of my friends.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I really had a-- I think, a wonderful childhood.",
      "word_count": 9
    }
  ],
