{
  "stem": "9987.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "He was caught by the Russian-- by the Soviet Army, and they were taking him to the Soviet prison camps.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Somehow he slipped away on the-- on the train station someplace east.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "Instead to go east, he went west.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And he came to Sambor and we just met him.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Now we are three of us already.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And he-- as soon as he could, he threw away his uniform.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "We got some civilian clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And now the three of us are trying to do something to make a living.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "It came I think sometimes in December, 1939.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "The Soviets put in an announcement that they take in volunteers to go to work to the coal mines in Donbass, in-- I think in English it's called the Don-- at the Don locations, whatever it is.",
      "word_count": 37
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So my younger brother Mike and two of his friends went to Lwow.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And they went to sign up to go to work to the coal mines.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "That was at the Eastern Ukraine, I think-- I think east of Kiev.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My brother was short.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Our family was very short, about 5'4'.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The other two friends of his were tall guys, about six foot tall.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They stayed all night in the frost and the cold, probably 15, 20 below zero, until in the morning, they came in to-- for registration to go to work in the coal mines.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And the Soviet commissar happens to be a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So the other two guys, they were tall, so he signed them up.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "When my brother came in, he says [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "If you're going to be working two years underground in Donbass, you're going-- supposed to look like you look today.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Go back home.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "It's not for you.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So he picked himself up, came back to Sambor.",
      "word_count": 9
    }
  ],
