{
  "stem": "26790.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "A little tin of the-- on the roof to, to to, to stop the rain coming in.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We, in our hostel-- I call it hostel-- was a big hall-- public hall, and he was-- this hall we were-- we was living, about 60, 50, 60 people, young people like we was in this same hall was living.",
      "word_count": 40
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And some people of this hall have Primus, to cook something.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I have-- we have our Primus, too.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "One day, the Primus got broken, not working.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I tell myself, no worry.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I'll just take the Primus to this man and he'll fix it.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I took the-- the Primus to this man.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I tell him we are [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "That means we escaped from German, from Hitler.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We're living here in this hostel.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Please, can you fix it, the Primus for tomorrow?",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Can't fix it for tomorrow, because tomorrow's [NON-ENGLISH], Fasting Day.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Yiddish or religious people fasting.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Not-- I will fast tomorrow.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I will not working tomorrow.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I can't say, you must do it, because you can't, if a man say like that.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "But come in my mind, if the man told me he's a-- according-- he's a religious man, something like that, this man will be able to help me with the chuppah I went-- I went home.",
      "word_count": 36
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I didn't ask him on the spot, because I didn't want it on the hot spot to-- to-- to the interview or something like that.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I went home, I tell my Leja.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "She tells me, oh, that's [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "Next week or two weeks later, I was working the fifth-- the fifth shift, because I was working two shifts, the morning shift and the afternoon shift.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "I went into this man's-- I work, I worked in the fifth shift.",
      "word_count": 13
    }
  ],
