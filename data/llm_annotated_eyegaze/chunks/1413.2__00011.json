  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "He made a nice little package with all kinds of remnants of bread, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And he put down cigarettes only for people-- because we had people with us who smoke, who had a smoke an [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "So you worked together with the non-Jews?",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I didn't work together with them.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I didn't work together.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I met them at the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "We worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "But we worked as a group.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And they might have worked with individuals or whatever.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Barracks, barracks-- now, I want to come back to, if I may--",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "To that-- to that Gentiles who did-- sent to get to Holland.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "One day, one guy went back to Holland-- went back to Holland.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And I don't know where he was from, but said he was from.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And my sister moved-- my sister-in-law moved from there.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Now, you asked me before how was it living in Holland between the Gentiles and the Jews?",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I happened to know that guy, an Aryan and Gentile guy.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "He's--",
      "word_count": 1
    }
  ],
