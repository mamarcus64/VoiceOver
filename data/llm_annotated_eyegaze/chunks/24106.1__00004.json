{
  "stem": "24106.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I said, oh, why do you have to go to Gordonia?",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Let's go to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "So I became a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "It was also nice, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "Every-- all the Zionist organizations was really something look forward to that.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And then my last organization was [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And that-- that was it.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It was like a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "You know, like not too left and not too right.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Just in the middle.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Now it's called [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But for my time, it was [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, they were-- yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I have a lot of friends.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They used to come to me, like for-- they had then a sefer.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "They used to come to my house.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I used to go to their house.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And I had-- I had a very busy life.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Sort of.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I had a rebbe coming to teach.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And then I had a Yiddish [YIDDISH] who used to come here.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I didn't go to like a beit yaakov school or a beit rivka.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "That was my-- that was my Jewish education, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I have a rebbe was teaching me davening, and then I have [YIDDISH] in Yiddish.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish community.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was the same.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We were all not rich.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Everybody had the same-- it was close.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "It's come Shabbos, everybody go to shul.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And then after shul, you come home, you have your lunch, and your family come to visit you.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Especially my-- the family.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "My mother had four brothers, and they used to come every Shabbos and sit and talk.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "Reminiscing about the good old days for the Tsar, when the Tsar was-- when the Tsar was the Tsar, yeah.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember the rabbi's name.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "No, I don't.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It was a shamash and a rabbi.",
      "word_count": 7
    }
  ],
