{
  "stem": "3100.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He had a lovely wife.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And when the war broke out, he had already two children.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "A younger brother after him was named Sholom, which I will tell you about him later.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Then I had a sister, Golda.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "We called her Goldala.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And she married just-- just around before the world war broke out, and she lived in Belzyce.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Belzyce was a town also in the [POLISH], but it was on the other side of Krasnik.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And her a husband's name was Shmiel, Shmiel Gradel.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Her name was Gradel, and she lived there in-- in I would say, a reasonably comfortable-- comfortable way.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Then I came.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I was the fourth child.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Then after me, I had a sister by the name of Chavahla.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Then at two years younger than her was her sister, Nechala.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Then two years younger than her, I had a brother.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "We called him Yehshua or Shuale.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And the youngest sister of mine was named was named Rosala.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Rosala must have been about seven or eight years old when the war broke out.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I went, first of all, to elementary school or as we call it here, public school.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I finished public school.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was the equivalent here to high school.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I had to go eight-- I don't remember-- eight or 10 grades, which was [PAUSES FOR 3 SECONDS] was a-- quite a liberation.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "There were times that we were only four or five Jews in that class, and we were constantly harassed.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But I was a young guy.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I didn't let myself.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I taught them back a lesson whenever I could.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But we were harassed in school and we felt anti-Semitism.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "You see, the school was open on Saturday, too.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And the Jewish students did not attend on a Saturday.",
      "word_count": 10
    }
  ],
