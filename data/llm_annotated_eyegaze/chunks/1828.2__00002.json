{
  "stem": "1828.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 228.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "None of that happened to us.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "That's why I always say you can't really say the story is the same.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "It's so different for so many people.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And we arrived there.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "We were all in one enclosure.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "There was barbed wire, which was electrified, we were told.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "If you touch it, you're gone.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "And one side of the barracks were the men.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And on the other side were the women.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "And the next day, they separated us from the children.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "But on the-- on the day we arrived, they tattooed our arms.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And I remember my mother giving us instructions.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "My sister was very tall for her age and developed.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And I was just about the right level.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "I was a child.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "And she said my sister was to go ahead and not look back if she was told to do something, because she thought maybe they wouldn't let me through because I'm so little.",
      "word_count": 33
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "And she was going to-- and I was going to be in the middle.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "And she was going to walk behind me.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And wherever I went, she would go with me.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "And my sister was to go ahead.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "That was the way it was going to be.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "And I had an exquisite little number on my arm.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "That girl that did it was a Polish prisoner, a political prisoner.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "She had a round red circle that means she was a prisoner for political reasons.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 32,
      "text": "And she tattooed this little number on me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And my mother said to her, how can you do this to a child?",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You're sitting here doing this.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And she said, don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "She's going to grow up and get married.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And her husband will buy her a bracelet, a diamond bracelet that will cover it.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I never forget that.",
      "word_count": 4
    }
  ],
