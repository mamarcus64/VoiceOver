{
  "stem": "13911.7",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Meantime, I-- like, I got conceived and-- when I was in Berlin.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And all this running and jumping off trains, pregnant, and didn't know any better.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Jumping off moving trains.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] I-- when you're young.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "And you just have to, also.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "You have to.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "And in Eschwege, I gave birth to my little girl.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Jeane.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Her name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Gote, ?] but then, oy, she might not like it.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "She said she didn't like the name because it kind of German sounded. or-- so she changed it to Jeane.",
      "word_count": 20
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And then, other friends came from another camp.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "That's another story.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "Maybe I should eliminate it.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "It's actually not friends.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "I-- I didn't know these people very well, only through somebody who lived in Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "And he worked in our hometown.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "It's just too much--",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "So they came, and they said-- no, Berlin, we went to Eschwege.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the camp I remember now-- Schlachtensee.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Schlachtensee, the-- the-- from Berlin.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that was the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, oh yes, only.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Only, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "You know, because from then, everybody was crawling out from the holes.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And hey, I'm here.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "I'm alive.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "What-- what will you do with me?",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "So you had to guide people what to do next, where to go.",
      "word_count": 13
    }
  ],
