{
  "stem": "597.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I was stoned like a stone.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't move from the place.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I got like-- I was paralyzed.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "He says, go back.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I was paralyzed-- practically paralyzed.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "But my sister already had-- she start kissing him and begging him.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And he said, you don't need nothing, nothing-- and took away everything-- whatever we had.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And she was begging him, and kissing him.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "So finally, he let us go-- let us go somewhere.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "We went-- father there.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "My mother had a-- a woman.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "They knew some people-- what she was dealing with them in business.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "She went in to the-- to the people there.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "It was around five, six kilometer from the town.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "So we slept over the night.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And the woman says, we-- I cannot keep you here, because over there on the city, they're going to look for you.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "Somebody neighbors saw you that you went into my place.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "You have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So there-- I said-- my mother said, well now it's in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Let us stay till the evening.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And then we will go away.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I was staying until the evening.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And in the evening, we start marching for 30 kilometer deep into the Russian-- the Russian occupied Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "That was Russia there already-- in the place where my mother was born.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And the place was named-- it's a village, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "My mother was born there.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So it took us all night and all day.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "During the day, we was hiding in the bushes.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "At night, we was walking-- you know, walking.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "The night, all night, we walked.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "We didn't-- we had to look.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My sister was a little one.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So we took her.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I took her on my shoulders.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "My mother, she looked on the-- on the signs how to go, where to go.",
      "word_count": 15
    }
  ],
