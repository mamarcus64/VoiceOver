{
  "stem": "10745.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 69.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He said, no, no, no, you go back to sit down, I'll call you, and don't you go away.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That's all I wanted to hear.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Because all of the stuff that-- soon as we got to Malynska, he went to the other side.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I took the stuff, and I went on the other side and under the train.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I was gone.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Yeah, it was a lot of fun to make a living.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "But that's how we stayed till about May the 1st, May Day.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "In Malynska, from all of us-- oh, no, there was a lot of Jewish people.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I mean, a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "There wasn't just 60 people, there was about 25 or more.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But they were not Malynska people.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "From Malynska survived-- oh, I think I had some time figured out it was seven of us.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But they were not all in there.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Because some of them, they took them away to the Russian Army.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "After the war, we were small.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I was 15.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Yeah, I was 15 or 16 at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And my brother was two years younger.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "So that's what-- anybody over 18, they took away to the army already.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "But we survived only from Malynska.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Came out from that forest where we came out, there came out 70 people.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "But there were people from few hundred kilometers away.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "There was one guy, he was from Chelm.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And Chelm was Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "It was never Ukrainian.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "How he got to us, I-- we don't know how he ran through.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "I never knew how Moniek came to us.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "We didn't at that time.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "We just-- and I know one thing.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "When we left on the May of 1st, we went to Chelm.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "Train stopped for the Chelm, we went to look for him.",
      "word_count": 11
    }
  ],
