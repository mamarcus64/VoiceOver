{
  "stem": "4919.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "But at the-- and the next morning, I was really exhausted.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I can't stand anymore here.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I got to go back to the rear, you know, to-- to the west.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And went back for, maybe, 30 kilometers.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Again, I find a home as a-- as a shoe repairman.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So I worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I did everything there.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But this-- this village was 80 miles-- or 80 kilometers from the city of Khar'kov.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And at the same time, in Khar'kov used to live over hundred thousand Jews.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And at the same times, they started to deportate all Jews from the city-- and, not far away, to a village.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And they killed all of them.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And the villagers, the young villagers, every day, they went by sleds to Khar'kov to loot the-- the Jewish homes.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And they bring goods every day.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "They used to bring goods in at there-- the home where I was sitting-- they gathered all together, 10, 15, 20 people, and they're bragging each other.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I got this.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I've got this.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And I'm sitting and doing something, but my heart was bleeding.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And it was one guy, an old guy.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "I remember his name-- [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "A [INAUDIBLE] Ukrainian guy, [NON-ENGLISH], with a big cross here, a wooden cross.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "He started, you know, to talk to me.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't like this.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Asking me, where are you from?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "What are you doing?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "What were you doing?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Where are your parents?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "What is the name of your parents?",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I didn't like it.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And, on the fourth day, maybe on the fifth day, the-- the owner of the home, it was evening, he said to me, [?",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Ivan, ?] you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "This guy [NON-ENGLISH] said you're Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "I said, no, I'm not Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "Well, he started to yell at me.",
      "word_count": 7
    }
  ],
