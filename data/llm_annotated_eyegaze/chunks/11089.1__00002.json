{
  "stem": "11089.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "At that time, to have a Persian coat, it was something like, to have today an airplane or something.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And I remember when he asked her several times to go-- to come with him to the city for entertainment, to have a good time.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "She never, never, never, put on that coat.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Her words were, how can I go for entertainment and have a good time, when the people of the village haven't got what to eat?",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "She never put it on.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Twice a month-- I was the oldest of my family.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "There was only one grocery store-- and she took me.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "There was no lights in the village.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we went, a Thursday night, to the grocery.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And she told-- his name was Moshe, Moshe Neuman.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He had a little horse with a wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And we said, Moshe, tonight or tomorrow morning, 10 kilograms of potatoes to Avraham, to [?",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Avromseh, ?] he was called. 50 kilograms of potatoes to [?",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Jakob. ?] Five kilograms of sugar to this family.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And we delivered.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "He delivered.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And he wrote down what we owe him, the money.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "My mother didn't pay cash.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I remember when the month come to an end-- came, she had to pay.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She ask my father, Joseph, I need money.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So he turned his head like this.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "You need again, money?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "But he gave her.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He gave her.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "That was my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She worried if people don't have to eat, she wouldn't be able to enjoy life.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And when I went to school, when I left home, even so I was in boarding room.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "She always made me a package.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "The delicious cookies who can stay for a few days.",
      "word_count": 10
    }
  ],
