  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "We saw those wagons come and clean it up.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "The clothing I brought with me, that's all I had.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "But when I got in touch with my father, I could got-- in the early days we could get some more clothing.",
      "word_count": 22
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We-- I got some more clothing, what-- winter clothing, pants, shoes, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Absolute nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But except in the early days, they did perform some religious prayers.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Again, it was a Jewish camp.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And in those days it was before the Russian war started.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And they let us be.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And so they didn't mix in too much into the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't have a Jewish calendar, no.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "But the religious people had their signs, good or bad.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "They came up at certain dates.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I was there until February 1943.",
      "word_count": 6
    }
  ],
