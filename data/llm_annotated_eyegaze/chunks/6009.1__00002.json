{
  "stem": "6009.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "They stayed because the war broke out.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In 1939.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Sailed around back to Gdynia, lay our boards down, where we growed up, all of us.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He worked there in Dabie.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I came home in 1940 because I didn't know where they are.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "But I found out the last months I got a letter from them.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "They know that I'm in prison.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And so I got the letter, and say I was in Dabie back.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "When I come home in 1940, when they released the Jewish prisoners.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That was the time I was supposed to go home.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In Choijnica.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It's on the border.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "C-H-O-J-N-I-C-A.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "When the war break out, we was right in the big fire.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "We was on the front right away, early in the morning, about 4 o'clock.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans run us over.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "It's a-- they-- they run us over with a very big army, much stronger and bigger than we were.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And we had to draw out form there.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We drew out to the middle of town.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And it didn't take long.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "They bombarded the town.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "Everything was on fire, the whole town.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And wherever we went, we saw soldiers of-- our soldiers laying dead.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And there was a town full of many Polish Germans, who would say this town belonged to Germany before the First World War.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "And then when the Germans lost the war, this town went to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "All the Germans stayed there.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "They didn't run away.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "They become Polish citizen.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "Everybody thought they're Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "And all of the sudden they start to shoot on the Polish army, all the citizens in town.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "How I managed?",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I managed with the whole army.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "We drove out from town afternoon.",
      "word_count": 6
    }
  ],
