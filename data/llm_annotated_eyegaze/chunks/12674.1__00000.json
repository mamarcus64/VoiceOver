{
  "stem": "12674.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Liz Manning.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born Lizzie Sussmann.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Deszoe-- David Sussmann.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The original name was based on a Hungarian man's name.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It's the capital D-E-S-Z-O with two dots on top of it.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Malvine von Sonnenfeld.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "M-A-L-V-I-N-E.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Vienna, Austria, on January 4, 1926.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Actually, all my papers say that that I was born on January the 2nd, because there was a child born to my parents 11 months before I was born that only lived 5 days, a girl.",
      "word_count": 36
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And when I was born, my father was so excited that he had now had a living child that looked and acted much healthier than the first one, that when he gave them the date, he made a mistake.",
      "word_count": 39
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And I have had to live with this all my life.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "All my papers said the second.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "But since we were a religious family, and everybody knew that I was not born on Shabbat, but on a Monday, I knew that they were right, because I looked at the 1926 calendar.",
      "word_count": 34
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And the fourth was a Monday.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The name of the child was named after a first cousin of my father's who had died two years-- a year before the first child.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Was Emma.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father came from a small village in a province of Austria which is called Burgenland.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my mother came from a place in Czechoslovakia, in Slovakia, what is now Slovakia.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "It was called Dobra Voda.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And my father came from Lackenbach.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And Lackenbach was one of the communities that had been given by the then Austrian emperor, whoever it was, between 1500 and 1510 to a group of Jews from Spain that came north during the Inquisition.",
      "word_count": 36
    }
  ],
