{
  "stem": "304.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "And when I came I had to tell her exactly who I am, who my father is, is because she had hundreds of great great grandchildren.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "So we have to always explain to her who my father is and who my mother is.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "And then she'll put her hand in-- in the pocket and give me [NON-ENGLISH], cube-- the sugar cubes.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "And even though we had enough of it at home, but when she gave it to me, it was very special.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "So special that I remember it till today.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "And then, every Friday, my grandmother used to bake challah and fish.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "And even though she had enough-- she lived with her youngest daughter-- she always felt that she wants to send to her mother from her challah, from her fish.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "So when I was there in the summer, we used-- I used to go bring it to her.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "And one of the visits, she showed me the tachrichim she had prepared.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "Tachrichim is the clothes that a person, when he dies, he puts it on.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 37,
      "text": "They put it on, he doesn't do it anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "They put it on him.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And also, they have a little bit of eretz Yisrael, soil, soil from Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So she had it ready.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "She was probably in her 90s.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She had the clothes what a-- that person wears and the soil.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But she ended up in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "She lived long enough that she didn't die and didn't use these clothes and the-- the soil from the Holy Land.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "So this was my great grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "My other grandparents, my mother's family, was more complicated.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "My grandmother was a very beautiful woman.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "She had four children with her husband and then he died.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "I don't know anymore from what he died.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Probably was sick.",
      "word_count": 3
    }
  ],
