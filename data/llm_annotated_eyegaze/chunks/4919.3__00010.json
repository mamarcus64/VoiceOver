{
  "stem": "4919.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "David.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "He was, at the time, 36.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "His wife was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "One, the older son, he was about 12, I think.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "He managed to escape, and wandering over the villages.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And the-- the police were just the Ukrainian [INAUDIBLE] there.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But I've got all so many relatives.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And altogether, I don't know, you can account maybe 50, maybe more.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Maybe 50, maybe more.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They were killed.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "All of them.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "My father was killed at Yom Kippur.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "He was 80 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "In 1946, after I was dismissed from the army, pretty soon I came to the village, to Piliava, to see.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I didn't recognize the village.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "There was no homes.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "No home, nothing there.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "But my home, can you imagine, my home was there.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Because it's not in the shtetl, it's in the village.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "It was occupied by a Ukrainian.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So a neighbor, who knows my father, she knew me, she told me, she saw them at Yom Kippur.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She saw him.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So he rode a wagon.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He was dressed in a tallis, because it was Yom Kippur.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And, yeah, and he said goodbye to them.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And he was killed that day.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "They shot him.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "So it had been all them-- all of them.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "But one guy survived.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I saw him then.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "He survived.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "He was there, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "He was there, and somehow he survived in the nighttime.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "He get out and a peasant in a village, she saved his life.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "So before you came to the United States, what were you doing in Kiev?",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I was working as a design engineer, structure, design engineer.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And that was my work.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "OK, I got to tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "In 1977, we visited Milwaukee.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "United States and Milwaukee.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Because my sister, she was writing and begging me, come in, come in.",
      "word_count": 13
    }
  ],
