{
  "stem": "26792.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 26.8,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And then while I was supposed to go to school the following day, my mother-- who spoke a rotten Latvian-- came up to me and said, my child, it is a disgrace.",
      "word_count": 32
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You are a Jewish child and you can't speak German.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "So I went to school and the next day, I spoke fluent-- German fluently.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I knew it but I did not speak it.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "So I have two mother tongues, also happens.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "My-- my parents' friends were Yiddish speaking people, as well as German speaking people.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And I learned to write in Yiddish by myself because I knew the Hebrew alphabet.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I used to write letters for the poor people of Kuldiga to their American relatives for help.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I-- with great pleasure, wherever I could, I spoke Yiddish until the day I left Riga for Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I loved the language.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I was a member of Betar as a very young child, wearing a uniform, like my sister and my brother.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And we sang and danced all the songs of the Betarim and we knew exactly what was going on in Palestine.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And we did the Horah and we celebrated everything that was connected with Judaism and Palestine.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "We knew everything about [INAUDIBLE] and what happened in this country.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I even remember a song in Yiddish, which no-- nobody in this country knows.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Of course I can.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And now [INAUDIBLE] in prison.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "[YIDDISH]",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I can't sing because I sing as a cow.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "A very-- I left it very early.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Until the age of 13, 14.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "When I started thinking and understanding things, it was not enough-- it was a bit a limited approach.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I was a Zionist and I remained a Zionist until this day.",
      "word_count": 12
    }
  ],
