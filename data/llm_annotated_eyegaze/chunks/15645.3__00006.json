{
  "stem": "15645.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I have-- I have-- I have a-- not a friend, a, a, a, a, a, a pair of teachers who was living not far from the-- from, from Janow Poleski, not far, in a-- in a small, country village, a very small country village.",
      "word_count": 44
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They were teachers in the school.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And they were-- they were from the same little town where my-- where my wife come from.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And we, we all were thinking, maybe we can hide in their place.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "But I came back to them, and I was with the rifle.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And they were very afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "Because they didn't-- they was afraid that somebody saw me with the rifle in their place.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "It could be suspicious.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "But I went in the night.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And I told him what's happened.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "And I have a rifle with me.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "And they keep me on the-- again, in the loft in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And they give me some food.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And I have some clothes in their place because when we was ready to run-- so we put some clothes to their place.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And I-- and then I have some shoes, because my shoes-- what I was walking was destroyed.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "And I have some shoes in their place.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And I take-- this is what I went, for clothes and shoes.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "And I take my shoes, what I have some shoes what I used to go skiing.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "And I-- and I take the shoes.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "And they give me some food.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "And, and, and, and, and, and next, next night, I went away.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "I went away to, to a group of Jews when I know where they are.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "But they was not in the partisan, just a group living in the-- in the-- in the woods.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "It was a Jewish family.",
      "word_count": 5
    }
  ],
