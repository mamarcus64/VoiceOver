{
  "stem": "7777.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 61,
      "text": "We staying over there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 62,
      "text": "And we did business.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 63,
      "text": "We did business.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 64,
      "text": "Meantime, there was good business to go to Sachsen-- from Sachsen to Berlin to bring in coffee and bacon.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 65,
      "text": "Is we arranged-- one was sitting in Berlin, and one was guy with a car back and forth.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 66,
      "text": "And I was in the store.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 67,
      "text": "This was until probably October or November.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 68,
      "text": "I got a telegram from my wife, from my girlfriend.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 69,
      "text": "My [NON-ENGLISH] they call it.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 70,
      "text": "She is back in [NON-ENGLISH] if I want to come.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 71,
      "text": "Is I left the store and I went, and I got married with her.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 72,
      "text": "And we come back to Sachsen with her.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 73,
      "text": "And we decided to go to Berlin.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 74,
      "text": "We sold the store, and we split.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 75,
      "text": "Is we got the $3,000 made in this time.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 76,
      "text": "Only this guy what they were sending to Berlin, he got already $20,000, he was doing business.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 77,
      "text": "And this guy what he was driving, he get $5,000.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 78,
      "text": "All I have $3,000, and I went with my wife to Berlin to [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 79,
      "text": "And we was in the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 80,
      "text": "And I have a cousin in Chicago.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 81,
      "text": "My cousin, I wrote him a letter, and he send me papers to come to United State.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 82,
      "text": "As I arrive in United State, in June 21, 1947.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 83,
      "text": "My wife was pregnant, and we was caught.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 84,
      "text": "The counsel was not allowed to go when she pregnant.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 85,
      "text": "We wait until 1947.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 86,
      "text": "I come to United State.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 87,
      "text": "I come to United State.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 88,
      "text": "I come out from an orthodox family.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 89,
      "text": "I was thinking to be orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 90,
      "text": "I was looking to get a job by an orthodox place not to work on Saturday.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 91,
      "text": "I find a job in a department store by the name Mr.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 92,
      "text": "Robinson.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 93,
      "text": "The name is Robinson.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 94,
      "text": "He have a department store he have closed Saturday.",
      "word_count": 9
    }
  ],
