{
  "stem": "12343.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.4,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I said, I want him to help me to do this.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Look.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "OK, he give me the other men to help you to carry the stuff in.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And he let them see that I help him.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Then we going on the way.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "All the time it was one man, old men, the Gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "He was from Majdanek.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "He was a murderer.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "Every time you said, [NON-ENGLISH], Shoot him.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "[NON-ENGLISH], shoot him.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "The only time we stopped in the night, we stopped in a barn to sleep.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And two man hide under the straw.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Straw?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Straw?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Straw?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "It's straw, yeah?",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "I hope so.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "They hide under this.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And the German come down and said, somebody took two Jews, hiding over there.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "They took them out.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "They kill them both.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Both right away.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, in front of everybody to see, not to run away no more, To show everybody what they can do.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "There was no run away.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They kill every person.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "You cannot walk no more?",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Shoot.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "The line was going to from Colditz, all of them, Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "Go on the street.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "You see the Germans said, we don't know nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "We passed so many so many little towns.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "The Germans was on the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "He was-- [SPITTING] --by the fence.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 11,
      "text": "Used to do like this.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 12,
      "text": "They said, we don't know nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 13,
      "text": "They knew everything.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 14,
      "text": "What they said is all lies.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 15,
      "text": "They knew everything, But they don't--",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "You know, the Russians, later on, the airplanes used to throw [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "How you call, papers?",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "How you call it in English?",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Fliers.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "You know, to the Germans to put away the guns.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I mean, you can see the plane over us, over us.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And they do not-- because they see who we are.",
      "word_count": 10
    }
  ],
