{
  "stem": "20580.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "This is going to be your wife.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And the other one, she has him.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "She doesn't go with you, she go with others.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "But this is a good business lady.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "She said, oh, we need [INAUDIBLE] the business.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "So she signed.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "She knows I've got a letter.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "She said, I don't need that stuff.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "I tossed her with money, with cash, with everything else.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "She say, I never leave it.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "She says, I don't like to see that.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "And this lady will tell you the story, which I tried.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "You want her to come, she come right away over here.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "And she goes away, and the other one comes.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "She says stay over here.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "But I don't want to stay without [NON-ENGLISH] It was still Friday, Thursday, she called up the father.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "Not so easy to call up.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "You have to go a telephone.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "She called her father.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "Her father comes Friday, and stays over Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "He brings me 5 [NON-ENGLISH], about American $500 or $400, Russian money.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "He said, this is your dowry.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "And this I go-- I didn't ask him.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "He gave me.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "He says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "Now I says, I don't stay over here.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 40,
      "text": "I want to go.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 41,
      "text": "The world, I don't want to stay here.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 42,
      "text": "I says, you go back go home with your father.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 43,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 44,
      "text": "I go.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 45,
      "text": "I stay with you.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 46,
      "text": "And I went right away, September I went to Germany, September 5.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 47,
      "text": "September, September, the month of September.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 48,
      "text": "I went to Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 49,
      "text": "I came to Germany in the Russian zone.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 50,
      "text": "And over there, I'm-- a few of the Jewish survivors there, Russians there.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 51,
      "text": "And looking for a job, I remember, they gave me a job to do.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 52,
      "text": "And she's pregnant already.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 53,
      "text": "She became pregnant, yeah.",
      "word_count": 4
    }
  ],
