  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "If I look back to those photos, I realize that it was a existence, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I'm interested what kind of girlfriends a refugee, Jewish, Hungarian, impoverished toolmaker had.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I had Belgian girlfriends.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I have two girlfriends I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "One name-- her name was [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "A lovely woman, a good-hearted woman.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I was very fond of her.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And we were very close to each other.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And then, later on, was a-- she was about-- she could have been two or three years older than I.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I met another girl-- [NON-ENGLISH], I forgot her other name.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "She was a much younger girl, a more intellectual girl.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And she was-- I was very fond of her.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "We went to concerts, and she provided me with intellectual material.",
      "word_count": 11
    }
  ],
