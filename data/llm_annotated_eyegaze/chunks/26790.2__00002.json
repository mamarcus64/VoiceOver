{
  "stem": "26790.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Because [? you won't ?] get of the anti-Semitic Polish-- Polish government.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "How anti-Semitic were the Polish government--",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean are?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You can't measure with a tape measure.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "You can measure it [INAUDIBLE] they are [INAUDIBLE] the both.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "They're both anti-Semitic, that's all.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They try to-- to boycott Yiddish business, they try to-- not to deal with Yiddish people.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And that's how-- what that-- you can't measure it on a tape measure.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "You can't measure it on a scale.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "High [INAUDIBLE] both.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "You can't measure.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Anti-Semitic but that's all.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "They got ?] anti-Semitic fascists, that's all.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "That's enough.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Oh, this is a story-- a very terrific story.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, I must give up.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "In 1939, in first of September, Friday-- I remember like it was today-- I went to work.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I was working.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It's a beautiful day-- Friday, a beautiful day, a sunny day.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I come to work, I start to work. 8:00, that's the time I started work.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "I did work.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Ten past nine I remember like it was [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My boss-- my [INAUDIBLE], they called [? maester, ?] boss-- he thought he would put on Berlin on the radio and he would listen what Berlin say.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "A radio in that time, who can afford to have a radio?",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Transistor didn't exist.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Only [? single ?] people in the [INAUDIBLE] bought radios.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I remember there was a man who used to have an electric shop.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He used to live in the Main Street in [INAUDIBLE]-- the Main Street in [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He used to live on the third floor on a balcony.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "He would come home from the shop, he used to take the radio when it was a nice day, he put the radio on the balcony.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "He put the radio on.",
      "word_count": 5
    }
  ],
