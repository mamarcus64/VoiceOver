  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And lots of them-- they just-- just-- lots of them died because they couldn't live on that little bit of food that they were getting.",
      "word_count": 25
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "Where we, we knew already the little soup.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "We knew how to manage it.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "But they were not used to that.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And then they were held there in this group.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "There were taken out and taken away and not to be seen again.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "But the clothes came back.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The clothes-- lots of clothes came back.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We-- we saw-- we-- we suspected that-- that something is going on.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "You see, we didn't have the luxury to confront the truth.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Because we were in it.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Because we had become so hopeless-- helpless.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "This way, you-- you kidded yourself.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We-- part of survival was to kid yourself.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So, how is it going?",
      "word_count": 5
    }
  ],
