{
  "stem": "17426.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I took some personal things of my-- photographs, little bit of clothing, I remember one suit that I had been made for me for that particular Rosh Hashanah and a couple of just ordinary, ordinary things that I would feel that are necessary as a first need.",
      "word_count": 47
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And the home and the land and the furniture and everything that we had was given to a Volksdeutsche.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Volksdeutsche were Germans that were living in, in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They were left over, after the First World War.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And he became the owner of all of that.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And we looked down from the attic across the street and saw him using our home.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "It was very painful for my mother and my father.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "My father was an optimist.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "My mother was more of a pragmatist.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "My father said, oh, it won't take long.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "It will be over in a year, and we'll go back to our house, be like it was before.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "It never was, Louise.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "It never was.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It was just our family.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a large room, where I believe the supplies were kept of the school.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And my mother put some curtains around, to provide the minimum kind of a privacy for herself and for the children and for ourself.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And that's how we lived.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It was small and, it was all that we could have.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Working for a Jew was not allowed.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I was tending a little garden in back of the school.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And it wasn't very long, because we were only there for about six months, probably from about September through next April.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Of 1940, 1940.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Then we were ordered into a ghetto, in the center of town, in the poorest section of Dobra.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "That's where the Jews were brought into, encircled, fenced in, got it, ghetto.",
      "word_count": 13
    }
  ],
