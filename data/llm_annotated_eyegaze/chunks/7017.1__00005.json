{
  "stem": "7017.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "They sent them-- they called it [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "They took it, that place.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And they sent us away to Kaufering, to the concentration camp-- to Judenlager in the beginning.",
      "word_count": 16
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "The year was maybe end of '41 or '42 beginning, something like this.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody in the family.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Soon, my brother found out.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "I was the last one at home.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And my brother found out they sent me away.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "And he was at a good camp.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "So he came home to see the parents.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "The same day was-- they took all the Jews and he went too.",
      "word_count": 13
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we have to work every day.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "All kinds of work.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I mean, to make insulation or something.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "All kind-- what they need.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "Every day, you didn't have the same work.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "Most of the work was that they took you in a place where they cement, the things from the cement ate you up.",
      "word_count": 23
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't work long over there.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "They gave us not enough food.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning, I got somebody, a girl I knew of from home, she worked in the kitchen.",
      "word_count": 18
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "And then, concentration camp, the Judenlager, where she helped them out once in a while for a little bit of food.",
      "word_count": 21
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "In Judenlager, you could wear your clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "In concentration camps you got stripes.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "In which camp?",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "In Juden-- I think a year, maybe.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "I was healthy in the beginning.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "But later, I was really weak.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Later, they took out the people in the Jewish concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "So they make a concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "He went in a concentration-- In the beginning, I was feeling better.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "A couple days-- a couple weeks we didn't have to work.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "We were just there.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "So it was better.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "But later it got worse and worse and worse.",
      "word_count": 9
    }
  ],
