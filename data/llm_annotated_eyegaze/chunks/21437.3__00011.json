{
  "stem": "21437.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Some people say Ben-jean, which is B-- without the N.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And this is where the business was.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "This is where my, where my grandfather's business was.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And it was taken over by a treuhandler.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "A treuhandler.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "That was a German that came, that ran the business.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They took it.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "It was theirs.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But they needed somebody to run it.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "So it was called treu-- troy-- perhaps the spelling was T-R-O-Y-- and then handler, with the H-E-N-D-E-R, treuhandler.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I just know the sound of it.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And my father had to be there something like two weeks at a time.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And he came home for two days.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "So this is where he was then.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it wasn't far away-- perhaps 3/4 of an hour by train, something like that.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Maybe an hour, not longer than that.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My father was there, in the business, running the business.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was like forced la-- he had to do it.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He had a gun over his head held.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "He had to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But they let him go for two hours.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "For two days.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Now, I--",
      "word_count": 2
    }
  ],
