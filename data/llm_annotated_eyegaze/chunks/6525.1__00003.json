{
  "stem": "6525.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "They were the most beautiful things, were the holidays.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "My memories go back.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "The nicest things were the holidays and the Friday nights.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "The brothers.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "How much older?",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Two years apart.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We are all two years apart-- every two years.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "They made beautiful shabbat with Zemirot, and the good food was also good, with white tablecloths and with candles and singing and telling jokes.",
      "word_count": 24
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "This was the most beautiful things I remember back from my childhood, the good part.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Mother.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "She wanted me to help her, but I didn't like it.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "But I helped anyway.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I had to.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I had an older sister, but she passed away.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "So then I was the oldest.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Purim.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "We-- we were wearing all kind of costumes and going from house to house.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Simchat Torah was a beautiful holiday.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And every Friday night was a holiday.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Till this day.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I made the same holidays out of Friday nights.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "In school.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I got free books.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "The rest of the kids had to buy their books, and I got them from the school.",
      "word_count": 17
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "They had poor people to take care of.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "They had poor people to take care of, the Kehillah.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "We weren't that poor.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "We had a steady income for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "But when the Hungarians took over, the income stopped.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "From tourists.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "How we were able to-- we had a garden, which we had our own vegetable and fruit.",
      "word_count": 17
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And we had our own milk and milk products.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "So we didn't have to shop much.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "So mother was trying to do a little black market business.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Buying and selling some stuff, and we helped her.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I went to Hebrew school.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "But it wasn't called Hebrew school.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "A Cheder was for boys.",
      "word_count": 5
    }
  ],
