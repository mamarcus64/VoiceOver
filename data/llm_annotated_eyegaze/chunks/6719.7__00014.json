{
  "stem": "6719.7",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "She says, no, I'm from Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "Well, she told me, when the Russians came in, they used to rape everybody down then.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "And she got scared.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "And she got away.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "And uh, that's when I knew.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "And then she told me about her father, that her father was Buchenwald and got killed down there, either in Buchenwald or in Auschwitz.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 19,
      "text": "He was arrested, I think, in 1939.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 20,
      "text": "Her mother went to England.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 21,
      "text": "Her sister went to England as domestics, but she was left with her father.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 22,
      "text": "And uh, that's-- that's the, uh-- the ninth wonder of the world, when I met my wife.",
      "word_count": 17
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 23,
      "text": "She's beautiful.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 24,
      "text": "Oh, she gives me a lot of hell.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 25,
      "text": "But she's beautiful and I love her.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No, not at all.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "She-- uh, she has forgotten-- just the other day, we were sitting down.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "We were talking about it.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I tried to get something out of her.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "She does remember, and she doesn't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Because she-- she is very, very lucky that she get rid of her past.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And uh, so that's-- we uh-- oh, I forgot something.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "But I'm going to tell you later.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Because I think that I haven't got time now.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "But as I said, my sister was in England.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Uh, my-- my children-- one child.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "One daughter.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "In Salzburg.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "1900 and 47.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Marilyn.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Well, actually her name is Marie, M-A-R-I-E, after my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "But then I had an uncle, in Switzerland.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And he called her Marylee.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And so from Marylee, it became Marilyn.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And she doesn't-- she doesn't want to go by the name of Marie.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "On her passport, it says Marie, obviously-- Marie Marilyn.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "But it's Marie.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "That was my mother's name.",
      "word_count": 5
    }
  ],
