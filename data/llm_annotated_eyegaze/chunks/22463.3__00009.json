  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In '93, about August, end of the August, something of this kind.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The day before, or a few days before, was the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the-- was-- Schindler was-- [PAUSES FOR 5 SECONDS] he give a order from-- from-- I believe, from Goeth, That he have to give about 1,000 people or 800 people, away.",
      "word_count": 32
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "They have to keep bombing this-- the people who-- who he need to-- evacuate the factory.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Because there was a Russian offensive.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And they stay in some-- they [INAUDIBLE], or whatever.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And the German had been in very big distress.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And they're running away, prepare for themselves to-- to [? catch ?] what they [? have kept, ?] and so on.",
      "word_count": 21
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And that was a lucky thing.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "Because all the barracks were empty now.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "It was burned off completely.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, none at all.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "This-- they-- they-- they was-- as I-- as I find later, they went to Austria, to the-- one of the convents.",
      "word_count": 21
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I couldn't tell you the [? very-- ?] and next to the [? green ?] [? grass. ?] Very, very-- there is a little [? kidding ?] [? place, ?] not by [? kidding, ?] but you have a stone and-- to take from one place, 100 step out, 120 step [? out. ?] And one back.",
      "word_count": 59
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And we are not running.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "We have been hitting.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And they hit you on the [? head ?] [? and ?] [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Now, that one I-- I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "What-- how-- what-- how-- oh, the-- Mauthausen.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "About 1,200-- 300 people.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "About that, after-- before the [? all ?] [INAUDIBLE], we have to take about 800 and something of these people.",
      "word_count": 20
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They had been sent to the Mauthausen.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    }
