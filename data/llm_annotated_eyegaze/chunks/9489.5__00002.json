{
  "stem": "9489.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I come back and he says to me, it's very bad.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "We have to operate it right away.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "I'm short on blood.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Anyways, so he finds me a donor.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "I got friends right away, a few Italian friends.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And they donate-- they volunteer to give me blood.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And they find it was Prince [INAUDIBLE], from the princes [? in ?] the villa.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I got pictures with him.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "His-- his blood was good.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "So they give me 60 cubic.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "They put him alive in a table, me on a table.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And they put in needles with pipes in him and in me and like that-- 60 cubics.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And they took me to the operation table.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "And nuns-- and they give me the freezing [INAUDIBLE] for me.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "I was so weak.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "Like I said, they give me blood.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "And he operate four and a half hours.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "And he was very [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "You know, what they did to me-- you know, everything was-- and he took out the stomach, and he showed me on a-- on a-- what do you call them, in a silver plate.",
      "word_count": 34
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "I'm not-- not telling you, you know, lies or, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "And after the surgery-- I passed out in the middle of the surgery.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "And they gave me a needle here in my heart.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "A nun-- was nuns there.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "And there was an Israel representative like a, you know, representative from Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "A doctor, one from Milan-- a woman doctor-- and two guys from the Haganah.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "[INAUDIBLE] he says, he don't want [? me ?] blame him.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "He was a fascist.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "He says, they can put him in jail.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "He's not going to operate with me.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "Want to be witnesses.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "So they give him Jewish two doctors.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "And after the surgery put me in a dark room.",
      "word_count": 10
    }
  ],
