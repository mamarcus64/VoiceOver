  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And my other aunt also, she was, just before being arrested, somebody-- she worked in a town, and one of the Polish women went to the Nazis and told them, there's a Jew working in our office.",
      "word_count": 37
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And the director, who was a Pol, came to my aunt, and he says, you know somebody went ahead and said that there are some Jews working in our office, and I think the Gestapo was going to come and look through everybody's papers.",
      "word_count": 44
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So she understood what that was.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "It was a not very nice warning.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And she escaped out of the town and hid and went to another town.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And they both survived the war.",
      "word_count": 6
    }
  ],
