{
  "stem": "769.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "So my father felt he lost a lot of [NON-ENGLISH], I like to say, to make a living.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "He started to buy off himself, grain.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And he got that big place like the-- made to hold stock the grain, and they send it to Warsaw.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "He not send it to the mill, for the mills that are owned, for a time, by the Jews and, after, the Christians buy up the mills.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "In 1929, the whole world was there in bankruptcy, he'd like to say, just a big depression, they called this.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "My father was bankrupted too.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "Before they went bankrupt, my father lost everything to-- what he owned-- even my mother's jewelry.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "He lost it.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "My father was very depressed, and my mother, too.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "But they very much loved to fight.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "I never saw in my life a father and mother that had arguments of the fight.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "As a matter of fact, they are married-- they was cousins, when they married.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "I, myself, seeing what is going on, I ran away from home, half run away, have not.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "I ran away to Lodz.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I've got one brother and three sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "There were five children in the home.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I-- no, my older brother, in 1927, he supposed to be registered in the army.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My father is a religious man-- not fanatical religious.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "No, a religious man.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He was very afraid my brother would eat no kosher food.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And since in the same city in Ciechanow, but the Polish army, and my father knows how they treat the Jews there.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "The Jewish people, they have Friday.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "But the Jewish community leader makes the deal with the officers from the camp, from the army camp, to let Friday might, all Jewish soldiers to come to the shul.",
      "word_count": 30
    }
  ],
