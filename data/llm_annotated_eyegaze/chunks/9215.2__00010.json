{
  "stem": "9215.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "But she didn't walk.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "She crawled like a dog, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "But she couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "If they-- if she would have walked, somebody would see her.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "But she walked like-- crawl like a dog.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "And there was, in the backyard, mine brother got a-- a-- what do you call this?",
      "word_count": 16
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "A-- not a garage, a-- a-- how you call this in English?",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "Like there we used to hold the-- the horses, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "Stable.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "A stable.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a stable.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And she went there.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And it was quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "The next one, I went.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "And then my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "We didn't run.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "We crawled, all of us.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 8,
      "text": "And it's-- then it was raining terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 9,
      "text": "And we washed the faces, and we drinked a little water.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 10,
      "text": "And we start going to the woods, because my brother knew the village very close.",
      "word_count": 15
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 11,
      "text": "Because he used to make the same business with my father-- father used to make.",
      "word_count": 15
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 12,
      "text": "Then when he was older, he used to go to the same villages.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 13,
      "text": "He made business with the-- there was a Polish village.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 14,
      "text": "But they-- people, they-- those people wasn't Ukrainian.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 15,
      "text": "It was Polish people.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 16,
      "text": "And they was very good people.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 17,
      "text": "They was very-- what we say-- like Orthodox, you know-- very, very good people.",
      "word_count": 14
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 18,
      "text": "When they came-- when we came, and my brother came, they gave a piece of bread and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 19,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 20,
      "text": "They told us-- they told us that in church, the priest said, if you were to give him food, don't give it.",
      "word_count": 22
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 21,
      "text": "But don't shoot.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 22,
      "text": "Don't shot him, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 23,
      "text": "Don't doing nothing to him.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 24,
      "text": "This is the way they was.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "When you-- they-- we used to go back, and they used-- no.",
      "word_count": 12
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "They didn't give a bread.",
      "word_count": 5
    }
  ],
