  "elapsed_s": 1.9,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "It was-- they opened those doors-- all what we had with air, a little air for a change.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "But there were these-- at the time, we didn't know they were called 'Sonderkommandos,' these men in stripes.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "Schnell, schnell, schnell!",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "And go-- you know, and so on and so forth.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "We didn't know where we had arrived.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "And they said, give the babies to the older women.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "Older women-- my mother was 46.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 24,
      "text": "So behind us was a young woman who had a baby.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 25,
      "text": "And she gave it to my mother.",
      "word_count": 7
    }
  ],
