{
  "stem": "5371.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I know my sisters were gassed.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "My brother was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "My two brothers were shot.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "My father was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "My mother was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "But still, I believed.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And I went home to my hometown, and I had two girls with me, which were in the hospital with me.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "One-- [CLEARS THROAT] One was from Vilna and one was from Romania.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Cluj Klausenburg.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Her name was Terry Rosenberg.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And the other girl's name-- I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "Her last name, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "But her first name was Nellie.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "She was from Vilna.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "She's still alive.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "I see her in Israel a few times.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "Her husband passed away also.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I came home to a not very good surrounding.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I met-- so I came straight to my house, to my parents' house.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "There was a Polish man living inside from a village somewhere, from a farm.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I told him, I says, this is my parents' house.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We lived here.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I was born here.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "My-- so he's laughing at me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "He says the government gave him the house.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So he said, but you go.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "There's a big building not too far from here.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "There's the headquarters of the Communist party, and the guy by the name Mehler.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And he will give you quarters.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I knew I heard the name Mehler because my father's brother-- not the youngest, but next to him-- was a lawyer.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "But his license was taken away from him because he was a little leftist, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "He belonged to the [? poaletzion ?]-- but not the right, but the left.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And we had a-- like a, not a burgermeister, but higher than that, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And he was-- I don't know whether you heard.",
      "word_count": 9
    }
  ],
