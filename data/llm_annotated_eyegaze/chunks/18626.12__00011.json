  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "He didn't come out.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So then after the time, I figured, I got to go to my uncle.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "My uncle think, God knows what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I went out to lunch.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So I walked over to Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Blitz, ?] was the name, the owner.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "Blitz, ?] I says, I got to go back to my uncle, to the shop.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "He says, don't go back.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "Finish the day here.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "I says, no, I cannot finish the day here.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "My uncle is going to know God knows what happened to me.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "I got to go.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "I have my-- my clothes there.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "This is my working clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "My good clothes is there.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "I got to go and tell him.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He says, OK, but leave the tools here.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Don't take the tools with you.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I'll take it in my office.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "He didn't want me to leave, to have security.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So I went to my uncle, and I told him.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He was a little happy and a little angry.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "He was happy and a little angry.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And I said, how much, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Blitz, ?] you planning to pay me?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "He says, we'll start out with $75.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "I-- from my uncle, I got $30.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Here he's giving me $75.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And as time goes on, he says, they're gonna get a raise $5, like, every other month.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I worked in-- for Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Blitz ?] for maybe five, six months.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Then I saw the big noise on Lafayette and all the [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I saw the jealous in the shop.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "The old men didn't like me.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "You know, older people don't like when they see a young boy can make three times faster the job than they do, which I didn't want to do it, but I did my duty, you know.",
      "word_count": 36
    }
  ],
