{
  "stem": "16792.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And we-- we was bombarding all around the Reichstag day and night, 24 hours a day.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "We was-- we was in Berlin.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "We was doing a very big job because we they bring in-- they bring in the toughest division from the Russian Army from the second-- the second front.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "We was from the second front, we was.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "The second front and then they came in from the first front and came in.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And it was-- it was big.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "Unbelievable.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "We did, but we was-- we was against it also.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "It was a lot of rapes on the German-- from the Russian Army to the Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We-- we was against it, but-- and we didn't like it.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "We took them off from things and we send them to the back.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We didn't put them in jail or whatever it is because we don't have jails down there.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And it was a lot of problems.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We interview him and we send him back.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "If he is a sergeant, we lower him to a soldier.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Taking-- taking things from German was no-- was no-- against it at all.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "When I was-- the Reichstag didn't blow up.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The Reichstag still stays.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I was there on the side.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But I was not in the Reichstag at this time.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "But the Reichstag stays.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I was there, but I don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS] Mostly for officers when we took Berlin, mostly were drunk.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Not drunk.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I mean, you know, instead of 200 grams vodka a day, they give us 500.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Personally, no.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It was the 4th, before the transfers to-- to-- to Grabov.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I got a big cut on the finger.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Grabov?",
      "word_count": 1
    }
  ],
