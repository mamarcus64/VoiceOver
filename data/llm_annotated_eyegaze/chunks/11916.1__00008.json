  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Because he's tooth was broken off.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And he was looking just like a half-dead man.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I ask him, how badly that he was beaten.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And he said, they did not over do it.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And he got quite a bit of money with him when they took him.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And we was very poor, but they gave us this money.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "It was about $1,000 which-- not dollars but 1,000 pengo, which was probably his monthly taking or something.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
