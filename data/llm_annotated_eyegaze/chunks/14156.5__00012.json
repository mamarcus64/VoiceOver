  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was in Israel till-- well, then came the war of liberation, the-- the-- in 1948.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Hmm?",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Independence or liberation-- independence.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I joined.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I went through the-- one time they had me in Akko, with-- with machine guns to-- you know, to shoot.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Akko was on the border, on the-- right on the-- on the beach.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And we-- we had to practice shooting with machine guns-- with German machine guns, or Czechoslovakian machine guns.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "We would practice there.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And we were ready to go to battle.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And some of the-- some of the guys said, do we have to go?",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So the commander said, oh-- you-- you will not go.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Forget it.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "You are not ready for that.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "We won't send you.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "You cannot be a real soldier if you worry about what's going to happen to you.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "So-- This is the end--",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was the end, there, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "My cousin--",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Oh, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
