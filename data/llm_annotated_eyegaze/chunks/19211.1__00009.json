{
  "stem": "19211.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "So I was 13 years old, right, 13.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Not till after the war, no, didn't have one, no.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They didn't allow us to congregate.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "We were not allowed to pray or congregate.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They were not-- we were not allowed to do that.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I remember Yom Kippur.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "We went to a private house.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And we had guards posted outside.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And we were praying there on Yom Kippur in this regular house.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "There were about maybe 20, 30 people in that room.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And then we were posting guards outside to see if anything happened, they would let us know.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "We would-- we had to escape now to congregate.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "We were not allowed to.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "This was in Brody.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "All that is in Brody, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And I lived there until 1942, approximate-- '41 to-- I was about a year, a year and a half with the Germans in Brody.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And then we were-- got a little lucky.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "My father got hired in a little village which was about 30, 40 miles from Brody.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And he was working in a brewery as an accountant, too.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "They needed somebody there that-- nobody could speak German.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And the Germans like beer.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And they allowed him to work there.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "So he worked there as an interpreter and also as an accountant, chief accountant.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He knew he was Jewish, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "He was known Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And I got a job in the machine shop there.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I remember working in the brewery machine shop.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "So we both worked for about a year, year and a half.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And that was a lucky streak that we moved away from the ghetto, from the larger city where they started ghettos and moving people to Auschwitz.",
      "word_count": 26
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "We didn't know it at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "But that's what was happening.",
      "word_count": 5
    }
  ],
