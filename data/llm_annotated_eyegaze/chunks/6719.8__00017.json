  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And you see, I'm almost there, and I forgot the word again.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "I just had it.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "And I got-- forgot it.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "It's a funny thing-- to dehydrate.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And so the word was reconstitution, to reconstitute food, to add the moisture back in there when you use it.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "So I went to the psychiatrist.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I said, what do I got to do?",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "He said, well, we have to look at something that you assimilate with it.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "So you found another word?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And I gave him the word.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And he said, think on the-- on the-- on the-- see, and here I go again-- on the Constitution of the United States of America.",
      "word_count": 25
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "So every time at a meeting, when the word reconstitute came up, in my mind I said, the Constitution of the United States of America.",
      "word_count": 25
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And I said reconstitute.",
      "word_count": 4
    }
  ],
