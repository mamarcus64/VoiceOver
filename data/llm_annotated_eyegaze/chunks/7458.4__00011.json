{
  "stem": "7458.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 51,
      "text": "And she offered to buy me a ticket and bring me to Rochester.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 52,
      "text": "Now, I hesitated to leave, because my brother couldn't come with me.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 53,
      "text": "The United States was not taking in refugees either, but they made an exception.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 54,
      "text": "They decided to take in youngsters under 18 years of age.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 55,
      "text": "And I was under 18 years of age, so I could come here.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 56,
      "text": "My brother and my sisters could not.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So my sister Baile ended up going to England.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And from England, she ended up in Australia with my niece Roske.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "My sister Feitche ended up-- she married Schleime after her first husband was killed.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And Schleime had a sister in Mexico, so they were able to get to Mexico.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So she ended up in Guadalajara, Mexico with Schleime as did Elichaim and Maishe, my brother.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My brother Maishe eventually ended up going to Australia also.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "My sister, once she settled there, was able to get him over there.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So I was the only one who managed to get to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And my family was spread all over the world.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I left-- I came there in-- sometimes in early '45.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I left-- I came to Rochester on May 22, 1947.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I left on May 12, 1947 from Naples on a little boat called And of course, I did not speak a single word of English.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Even though I had knowledge of a number of languages, English was not one of them.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We did not speak English in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So my first few words of English I learned on the boat when they would announce in Italian and then in English, attention, attention, the correct time is such and such, and the first serving of breakfast is now being served.",
      "word_count": 41
    }
  ],
