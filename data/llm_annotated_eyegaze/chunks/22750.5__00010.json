{
  "stem": "22750.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 10,
      "text": "They caught him 14 days later when he came back.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 11,
      "text": "And he mentioned the name to somebody, that my brother was killed and that he saw it.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 12,
      "text": "It's-- it's a big history.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 13,
      "text": "And you couldn't tell the history exactly in order like it was, what came to your mind.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 14,
      "text": "And the mind, don't forget, it's 55 years-- 55 years I'm from there.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 15,
      "text": "And my mind is not the same.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 16,
      "text": "I'm older.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 17,
      "text": "And my situation, I explain, is not the same situation what was two, three year-- three years ago.",
      "word_count": 18
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 18,
      "text": "I admit.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 19,
      "text": "I know it.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 20,
      "text": "I know my failure.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 21,
      "text": "But I couldn't help it.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Faiga was killed with two children in other city, where she lives.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "She was married to another city.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Faiga was killed with two children and with her husband.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And she was hiding by a policeman.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "A-- it was a Polish policeman.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And then they find them there.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "He didn't give them out.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "They find them there.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "Them",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Hiding.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Because she was from another city.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Up there they had a ghetto like by us.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And then-- and then she find a place.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And the same [INAUDIBLE], what I find out.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "She escaped-- not escaped.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "She left the ghetto and went to [INAUDIBLE], when they start to kill the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And it was about 40 kilometer from us.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Warvek, that time the name from the-- from the city.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "W-A-R-V-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "The year, I can maybe guess.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "In '43, yeah, the year maybe.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "But I couldn't guess.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "Matter of fact, it's not necessary.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "I was by her house after I survived.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "Went by there to look.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "We still was strong enough to go.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "But the house was taken by Polish family.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "That's-- I'm only saying-- this is-- whatever I say, it's not necessary, even today's story, from this.",
      "word_count": 17
    }
  ],
