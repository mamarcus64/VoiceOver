{
  "stem": "18778.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "None of their accompanying people were on board.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "We had-- we had a rabbi and a-- and a priest and a minister on board as well who all said prayers.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And we threw flowers into the water for the people who didn't survive.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And then afterwards, there were many parties and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "We got the key to the city and all that sort of thing.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And we came away with good feelings.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "But-- but to my regret, we haven't been able to stay in touch much with each other.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "The next contact with people was the one that was in Skokie, Illinois to make a documentary, [PAUSES FOR 3 SECONDS] the one that I showed you the tape to.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I can't think of the name right now.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It's-- it's over there.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It was nine of us got together.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And some of us have been together in Miami.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We made this documentary.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And then one more time a documentary was made in 1993.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And that was made by a Canadian film company for a television presentation.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "The producer was an Iranian Christian man-- the director, rather.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "The producer was a French Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "The camera man was Dutch.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "It was a very international crew.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And there were I think again nine of us who were together.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Some of us had met before in Miami or in Illinois.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "Some of us hadn't met before.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And we did a film on board a cruise ship to get the feeling of being on high seas.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And that film is called and as a matter of fact has been shown in France, in Finland, in Canada, in Britain and Ireland.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "It will be shown here on August 29, 1996, on the Discovery Channel.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And that experience was a very interesting experience as well.",
      "word_count": 10
    }
  ],
