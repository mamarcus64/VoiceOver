{
  "stem": "21004.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "And you go with me.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "So anyway, before that I told my friend if anything will happen, anybody where there is one person want to grab us-- when there's two or three, for sure you can do nothing.",
      "word_count": 33
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 16,
      "text": "But you try.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 17,
      "text": "But there's when one person, you don't let yourself go.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 18,
      "text": "I'll tell you what to do, and I'll give you a sound like we used to do in the woods.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 19,
      "text": "We used to do a click.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 20,
      "text": "Something like that.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 21,
      "text": "So he should know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So I gave him the one side under his ribs right here.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And he-- and Godfried gave him from the other side, and he's already laying on the floor.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I knocked his teeth out this way.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Keep knocking in till he was-- he didn't move no more, and kicked him with his feet.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Kicked him in his face, and all over he was finished.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And then we got up and we were going.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We were going.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Finished him up.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I don't think he could get up after he was all bloody and all-- and all the hits he got.",
      "word_count": 20
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So anyway, we went-- we didn't have even to run.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I know he wouldn't get up.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "So-- and we went another day till we came to Jaworow ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I have to go also through Lemberg.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I had to go through the city of Lemberg.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "A city what it's unbelievable.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "On the way, we changed our clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "There was an old house, and nobody just was lived there.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "So we went into that house, and there was a lot of clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "We threw down our clothes and we put on all-- there was big.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "One was big, one was small, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "And we put on difference clothes.",
      "word_count": 6
    }
  ],
