    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't have a trade, didn't have a qualification.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And I have a little bit money.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And I was attending a concert in a circus.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And I saw a magician was performing.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And I would say, with God's help, I catched, you know, most-- a couple.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And I start to repeat it into work.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And I see I can make it.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "It's nothing complicated.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And then I met another guy who was a performer.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "And I told him, I am very interesting.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "And I'm from the army.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "I have no qualifications, no trade, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And he give me a couple secrets.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "They were old secrets, what is old for him.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "But it was new for me.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "Well, he's not using them.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
