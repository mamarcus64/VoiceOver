  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "We were the European orphans.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And when we came on the dock, there were women there in white dresses, you know, in white uniform.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And they had cheese danishes and, and all kinds of danishes.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I came out and I saw those danish and I thought, it would be nice to buy something, but I didn't have no money.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And after a while, one of the ladies says to me like this, I should go over.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So I go over, she gives me one.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "She says, take more.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So I took a few and I stuffed them into my shirt.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And then they came in buses to take us to our home.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "But we didn't want to leave, because the danishes were there, hot chocolate.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Who-- I don't want to go any place.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
