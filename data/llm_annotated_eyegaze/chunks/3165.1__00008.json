  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And my mother [SOB] took him around, and she says-- and she said to him, God will be with you, my son.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And then the Gestapo screamed out.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He says, OK, that's enough, let's go.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And-- and he went.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And they took all my brothers and my father outside.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] [SOBBING] And I went to the window, to the bedroom window, to look out where they take them.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And they-- they took them to a-- a-- wagon, a big wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And with the [PAUSES FOR 3 SECONDS] rifles behind their necks.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And they told each one to go up to this big truck, or [NON-ENGLISH], whatever it was.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And I saw them going all up, with the Gestapos behind them in the doorway.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "[SOBBING] And darkness took over the house.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "It was a Sunday morning, but after that it was-- it was just unreal.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And my mother, [PAUSES FOR 3 SECONDS] God bless her, she took us around.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "And I didn't hear her scream or yell.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "She just was holding us, and praying, and praying.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "[CRYING] And it was very bad, very tragic.",
      "word_count": 8
    }
  ],
