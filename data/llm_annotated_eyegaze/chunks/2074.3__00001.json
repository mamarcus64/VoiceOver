  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And the public Pollack was fighting back the Ukrainians.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "So during the night, the Ukrainian bandits were getting together, having axes and knives and attacking Polish colonies.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "So one time, the-- the man-- that man told me-- I'll tell you later how he-- told me a story that they-- they-- that he was the Nazi leader when they attacked a Polish colony.",
      "word_count": 35
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "He saw what his colleagues did, the young Nazi bandits.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "There was a Polish pregnant girl.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "They cut her stomach open, took the baby out, and let the Polish girl die like that.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "You-- in the daytime, the-- the Pollacks got united with the Germans, and they'll attack colonies where they suspected these bandits and surround them during the night and also kill-- kill-- kill the people and put the farm on-- the farm on fire.",
      "word_count": 43
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "They put-- That was 1943.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "It was burning day and night.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "In a way, I was happy to see it.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "That now they're killing each other.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "The Jews are all gone.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "There's no problem with the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "Now they're killing each other.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "But the problem was I was hiding in-- in-- in barns.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "So now I have to continue here the story.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "So when he-- my brother-- when the guy told my brother to run, they couldn't come back to the barn where I was sitting because full of Nazis were laying in the barn, and I was walking over them and not one woke up to catch me.",
      "word_count": 47
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So when start of daylight, I took whatever I had.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I-- was a straw roof for the pigs-- pigs-- where the pigs were living.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And then I got into the pig barn.",
      "word_count": 8
    }
  ],
