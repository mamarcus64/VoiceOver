  "elapsed_s": 224.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I said goodbye to my mother, and I said goodbye to my sister, and to my friends that I-- I loved.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And as we were standing there and waiting to be taken away, all of a sudden an order came in again, going back into the barracks.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Because another transport was coming, and they needed our help again.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "So we turned around, and we went back to work some more, and find some more clothing, and find-- I found an infant, a dead infant between the clothing in-- in our barrack.",
      "word_count": 33
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And that was a terrible shock to me.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Because that was a horrible-- I remember my-- my relatives, and they had babies.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I thought to myself, this could have been one of them.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But I know that they went away, too.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I mean, they-- they were killed too, with my-- with my aunts and my cousins, and my uncles who-- who looked old.",
      "word_count": 22
    }
  ],
