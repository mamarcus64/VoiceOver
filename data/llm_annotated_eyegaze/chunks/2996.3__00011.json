  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And on top of it, you could walk from one side of the street to the other side of the street.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So you could use three entrances, leave, or enter, or leave.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "I met with them there.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And we had, we had understandings, how to meet, when to meet, how to reach each other, and so on, and so forth.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And that's what reminded me of the Ku Klux Klan statue.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "She saw a statue of the Klansman.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to have it here, but I forgot.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Once, one of my undercover men, who was the chief intelligence officer of the Ku Klux Klan, reported that the Klan was going to scare the hell out of those Jew producers at the studios.",
      "word_count": 35
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "On the desk of every one of the Louis B.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Mayer-- what is Cohn's first name?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Harry.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "--Harry Cohn, Jack Warner, there would be a little statue.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "On the bottom it says, KGYI, Klansman I Greet You.",
      "word_count": 10
    }
  ],
