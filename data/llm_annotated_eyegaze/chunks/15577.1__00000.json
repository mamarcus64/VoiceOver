{
  "stem": "15577.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[ELECTRIC TONE]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Jonathan Dresner, J-O-N-A-T-H-A-N, D-R-E-S-N-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My nickname or my name that I was use at home is Janek.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "J-A-N-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cracow, in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "On September the 4th, 1923.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "72 and half.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was 16 when the-- when the war broke out.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was a student in the high school.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was attending the Hebrew school, from the very beginning.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I went to the Hebrew school as elementary school, then to the high school, which was part of-- the second part of the elementary school.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was a private Jewish Hebrew school in Cracow.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "We had been living in a region which was mostly-- [PAUSES FOR 4 SECONDS] where mostly Jews where we living, although it was not the real ghetto of Cracow.",
      "word_count": 29
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] All my friends were Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] I have no contact with Poles, whatsoever, until the war broke out.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "All my friends, all my teachers, all my surroundings were Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] We-- I came from a family-- I come from a family which wasn't very religious.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "But I should say we were traditional.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "We have been belonging to an orthodox synagogue, but-- and observing Shabbat.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "But not to-- nothing very special, more.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "I have a very, very comfortable and good childhood.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "I had-- I was living in a very comfortable conditions.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "My parents were very wealthy.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And if you think about the conditions from before the war, in Poland, so we were living in a-- as children, I and my sister, in very comfortable and good conditions.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "And-- [PAUSES FOR 5 SECONDS] we-- we didn't feel anything that-- bothered us, until the-- until the war broke out.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We have been meeting friends.",
      "word_count": 5
    }
  ],
