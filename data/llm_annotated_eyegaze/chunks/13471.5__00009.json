{
  "stem": "13471.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "We had a flyby at Frankfurt.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And they said, well, now, we're getting rid of all our cigars.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Would you like a couple of boxes?",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Well, I said, I don't smoke cigars, but I go hunting in the woods, and the German woodsmen would love-- I said, yeah, give me about four boxes of cigars.",
      "word_count": 30
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So I took these cigars and went to Berlin.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And I went down, and we had to see a whole bunch of people, and Sieg had to see some people.",
      "word_count": 21
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And I came back at the end of the day.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I got to my room, and Sieg [LAUGHS] was sitting there in front of these packages of $100 bills, like this.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And he pushed a whole bunch-- and he says, these are yours.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I said, mine?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "He says, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "He says, I sold your cigars.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "I said, I didn't tell you to sell any goddamn cigars!",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "On the black market, you see?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] He sold my cigars.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Anyway.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "So we got-- we got the material.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And then we got down, and we got the-- we got set up.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And they set up the press and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "And Sieg, at one point, was trying to-- we were trying to see-- it was the best deal in Nuremberg-- would it be better if we went to Munich to have it printed, you see?",
      "word_count": 35
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "And I said, well, Sieg, go down to Munich and take a look.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And so he came back, and he says-- he says there is a German newspaper, in German, called I think, or something-- something-- anyway.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I read it.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "It's superb.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Absolutely superb.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And, he says, I went to see them, and there was a Major Rosenthal-- army-- a US military government major in charge.",
      "word_count": 22
    }
  ],
