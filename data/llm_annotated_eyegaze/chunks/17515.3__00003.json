  "model": "openai/gpt-oss-120b",
  "elapsed_s": 413.1,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You know, they were the same, with the two, three strokes to the skin, broken.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Then I have to count it.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "[GERMAN], two whips for [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "[GERMAN], [GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "If you make me [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Start, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So I-- I-- I was very strong.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "But many people got whips too, 20.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And they bled throughout-- from out here.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And the person died.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I was so strong.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "It was unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Like-- like-- like 100.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Because two-- two whips, they were counted as one.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Told me 50 whips.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "If you counted-- and--",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So-- like correctly, that's it, 100 whips.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I've been-- and the next day I-- I went to work.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "No-- no forgettings.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I know the skin was black.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And no, there's nothing, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "No-- no care.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And so I been struck a couple times by the-- like yesterday, [INAUDIBLE], which my ear is almost broken.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "But I got good-- good sounds.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Only I have noise in my head.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But I got excellent sounds.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I hear.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I got broken drum from-- from the hitting.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Then all day, 24 hours, I got noise like a motor.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Like you know while I talk, I hear the noise.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I-- I get-- I get used to it.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "No, I got good hearing.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I don't know, a miracle.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Ah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I was sick, I believe, 1942, in Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Like, there was evening appell.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "All [INAUDIBLE] men forward, after-- after appell.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So-- so-- ever-- whoever sick, or got [INAUDIBLE] on their foot, forward the-- for the checking.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So the-- my captain-- like, the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They ask me in Polish, do you have temperature?",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "You have a-- they say Polish, [SPEAKING POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Show me your tongue.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I mean, [SPEAKING POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They speak beautiful Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Kept on like a-- a-- a doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Then they left, left me to [INAUDIBLE] Hospital.",
      "word_count": 8
    }
  ],
