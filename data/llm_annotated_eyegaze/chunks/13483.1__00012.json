  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "In fact, they were block houses disguised to look like houses.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And the Germans had their guns in there, and their sharpshooters or snipers, whatever they were.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "But they were quickly blasted out of the way, you know, or captured.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "I don't want to be a hero, but I didn't feel anything.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I didn't feel anything.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I think most of us were relieved that we landed.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "Because, as I say, we had a pretty bad two days on the English Channel.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "And I think most of us felt-- we were glad to get on land again.",
      "word_count": 15
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
