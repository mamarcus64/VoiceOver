{
  "stem": "1537.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I mention to you, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "You will probably have a problem to pronounce it.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And all the education problem for me and for my brother, you know, who, unfortunately, didn't came back, Betzalel Josef, they send us to [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Because there, from my mother's side, the whole family was there, my grandparents.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "My mother had four brothers there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And they were quite wealthy.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "They had a flour mill.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And my sister was married there.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I was sleeping in my sister's place.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "She had a business, you know, a textile business.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And every day, I went to my uncle to eat-- two days by this uncle, two days by other uncle.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "That's the way we used to solve the problem.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Would you like to mention the name of your grandparents from--",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather, I never knew because he died before I was born.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And his name was Dovid Lieb.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Kohn David was his-- But I remember very, very well my grandmother.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And my grandmother's maiden name was Weinberger.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And they had-- she had a brother.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] Moshe we used to call him.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And he had the flour mill in [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And my grandfather had 25% from the mill.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And I know, because I was a child, the 25% was divided between my four uncles and my mother.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "So we had-- we owned 5% of the mill.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "Actually, we made a living from this, not from the tavern what we had.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "Because the tavern, you know, when the Hungarians came in, they, they came into the town.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "They saw the sign, Rubin Tavern.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "Right away, we had to take down the sign in the door to be closed.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "We are not supposed to sell.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "They took away the liquor license right away.",
      "word_count": 8
    }
  ],
