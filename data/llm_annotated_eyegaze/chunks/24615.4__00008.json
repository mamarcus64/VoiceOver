{
  "stem": "24615.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But it was-- it was just one-- one-- one time, you know, two sisters came there.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to make it short now.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Two sisters came there to this guy.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "He didn't have no farm.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "He didn't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "He just had a cow and two pigs.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And me and the Hershel, in the wintertime, we were hiding, you know, it was-- where they used to keep potatoes in the house.",
      "word_count": 24
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And they used to cook on top.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "At night, we used to crawl in and down there.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if it was Ukrainian or-- or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "You know, they came-- they came in.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And the ladies, it was two-- two sisters he took in and another lady and two kids, you know, after.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And and what-- well, before they come in, it's real long.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "It will take long, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But what is it-- what do you want to tell me?",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "What is the point?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "About how you were hidden?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, two-- two sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And they had a little boy with them.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And he took them in too, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I don't-- they knew the farmer.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know the farmer.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "He was not farm-- he just had a house.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "He was like a tradesman.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "He used to fix shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "He used to fix anything.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Ciechanowiecki.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Ciechanowiecki is the name.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And her name was Olga.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "We slept in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "You know, on-- if somebody used to walk in, we used to crawl in and hide.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And we used to walk around in the-- in the village.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Just one guy, he was the head of the village.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "He used to walk through and look at us.",
      "word_count": 9
    }
  ],
