  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "This is my wife's uncle, Friedl is his name-- in the German uniform of World War I.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "He was later, during the Nazi time, sent to Sachsenhausen concentration camp and died there.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "This is the only picture that's in existence of my mom.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "It happened to be in somebody's possession-- a friend of ours or something.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "It happened to be also that I remember very, very well that this was the picture she always wanted to have destroyed.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And now this is the only one that is-- that's around.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Well, so--",
      "word_count": 2
    }
  ],
