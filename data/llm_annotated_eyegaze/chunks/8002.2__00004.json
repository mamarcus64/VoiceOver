{
  "stem": "8002.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And the people went right, they gave us a little book a red card, a red card that means you were a worker.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Was a little older than me-- Chaim.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And he says, we are surviving because we, we got red card.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And my mother says that she's working for the German officer.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "So they took my mother from my brothers away.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And they give her a red card.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And my, my brothers, they moved to the block where all the people went to the left.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I worked with my mother for about a month.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And the German started to trust us.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The Obersturmf-- Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Hesse.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Alfred Hesse.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So he, he let us take care of the house by ourself.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I says to my mother, now we have a chance to escape.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I know they were in the ghetto-- in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No, we weren't living.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We were living in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But we were separate from my brothers.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We were on the right side.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And they were on the left side.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't get in touch with them.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't go near them, because they put guards there.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And my, my mother says to me, we're going to escape.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So the first thing I thought about it, to go back to Viski.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "It was 20 kilometer from Dvinsk, where I was born.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And we saw-- at that time, it was maybe around 8:00 o'clock at night.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "We went to the marketplace in Viski.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And we saw a couple of trucks and a lot of German and Latvian police.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And on the market, there was a lot of Jews, maybe a couple of thousand at least.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And the marketplace had only two ways to go out and go in.",
      "word_count": 13
    }
  ],
