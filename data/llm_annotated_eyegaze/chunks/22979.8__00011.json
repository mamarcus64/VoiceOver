  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "His-- from his first wife, he has two, Caroline and Steve.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And recent marriage, he has one boy, 7, who is also raised Jewish and attends the Hillel Brandeis school and a very happy marriage.",
      "word_count": 24
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I am, you know, after I-- when I was working, I was very busy.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have time.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I just wanted to be successful not for my sake, so I can give a better life for my children.",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I can't complain about the life here.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "But for me, you know, until the retirement, it was work, work, work, work.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "But you know, work doesn't kill.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And now, since I'm retired, I spend all my life for-- I mean, I'm very involved in the Holocaust.",
      "word_count": 19
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "I was the founder of the organization, Tikvah, where I was the first president.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "I am still very involved with them.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "I was volunteered at the Montefiore Center for many years.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "I am still.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "And I am still involved with the Holocaust Center of Northern California.",
      "word_count": 12
    }
  ],
