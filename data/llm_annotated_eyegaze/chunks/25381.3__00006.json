{
  "stem": "25381.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I walked for awhile.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And I sat, and I wrote, I'm Hannah.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "My name became Hannah [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Hannah, that's a Ukrainian name.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Hannah-- you see?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I still remember up til now-- Hannah [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I'm looking for work.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I wrote that my father is an alcoholic.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "My stepmother is very mean to me.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I signed the-- the-- the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "That means the mayor and the-- the worker under the mayor.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I signed with my right hand.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So I walked in and I gave them the-- and he-- they're asking me for a piece of paper, if I have something to prove.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And I show it to them.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he says to me, how-- something is fishing, because you signed with one signature the mayor and the-- how do you call like a-- a president, vice president?",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The lower the lower count?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Like the governor or the--",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Something like that.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "So he says it sounds-- and there's no stamp.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You don't have any stamps.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So I said, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Now is the war, and he's very busy.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And they're busy with the-- with the Germans, to look for the Jew, to kill the Jew, and everything.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I came in this moment.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And the-- the police was bothering him.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So he said he didn't want me I should bother him too much.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So he said [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "That means, the heck with you.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And he signed his name, and he signed the other-- this name.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And a stamp, I say, he was looking and looking, and he couldn't find a stamp.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "So I gave him this answer, and he took it for granted.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And he said, OK, you can work at me.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "While I was working there-- so then it became two undergrounds organizations, [NON-ENGLISH] and [NON-ENGLISH].",
      "word_count": 15
    }
  ],
