{
  "stem": "24884.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 4 SECONDS] but [PAUSES FOR 3 SECONDS] financially, I had no worries.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] He got-- on the black market he got food.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Everything was available on the black market.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I mean, it was harder times.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "You had to know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But he got it.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Meat, poultry, butter.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "There was no social life.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "There were-- we-- we were glad if we could be alone and left alone, and afraid to go out too much.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So we went once in a blue moon to  a movie at night.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "He rented a very nice apartment under his name.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, god.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I knew it the other day.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Ansbacher Strasse in-- Ansbacher Strasse.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Ansbacher Strasse [GERMAN], 56.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Also in a quite nice neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "His friend, Han Hagen.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I had another friend who was a Mischling.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] And that was it.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We didn't keep much.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "You tried to stay away from everybody as much as possible.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And even your best friend, you wouldn't say where you lived.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "You were afraid if they get caught, and they were put to the question, whom else can you bring in?",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Then we let you stay here for another six months.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "For each person you bring in, you-- you get a certain period for yourself that you don't get transported to Auschwitz or wherever.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "So then they would know where we are, and they could finger us.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Didn't tell anybody where you lived.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there  were bombings almost weekly.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Daily, at times.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I loved it.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It was always a lot of confusion.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And everybody was much-- it was easier to get around, because everybody was confused.",
      "word_count": 14
    }
  ],
