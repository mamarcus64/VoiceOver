{
  "stem": "5225.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "He say, I tell you the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "The Russian is here.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "In a big house the Russian going to nationalize.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "So how much you can take it out, take it out.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "So he said take a quarter of a million zloty.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "What I know?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "You said, so and so and so.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "Until I get it, the money, I got 120,000.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "He took it, but 30,000 for his job, and he paid there 10,000, to pay this one.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "I don't know where it was I got 120,000.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And the 120,000 I make myself a pair of boots, and I bought myself a pair of pants and a sweater, and I bought for my cousin the same thing.",
      "word_count": 30
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And it cost me $50,000. 60. sexy.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "You make a big party in the kibbutz and all the money is gone for the kibbutz.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "What I've got left only is the shoes with the pants with the sweater.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't come with nothing, I go with nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And we was going to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We were supposed to go to Israel illegally.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "So they gave me-- I was there in this time as I really was going as Greek Jews.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "As Greek Jews back to home.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And they gave me a passport, I was 16 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And you're my girlfriend, but you are 32.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And you are Greek too.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And we supposed to talk only from siddur.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "You know from the--",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No Hebrew.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] just from siddur.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Because Jewish they wouldn't understand, Polish they understand.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Russian they didn't understand, whatever you talk about.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He said, just talk from siddur.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH] We just talk from siddur.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And if I saw he wants a cigarette I say, [NON-ENGLISH] So I give him a cigarette.",
      "word_count": 17
    }
  ],
