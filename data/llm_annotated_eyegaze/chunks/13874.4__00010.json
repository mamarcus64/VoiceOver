  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Meanwhile, his sister had been pulled out of the camp and was in a factory near Gdansk-- hard labor.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "After the war-- during the liberation-- I don't know exactly whether it was before or after-- they had typhoid in the camp.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And the older brother died of typhoid.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "[DRINKING]",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So the younger boy, somehow, through Sweden-- he was all the way up there near Gdansk, in the East Prussia-- got back to Germany, made his way to Leipzig.",
      "word_count": 29
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "You know the big railroad yard-- one of the biggest?",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And by chance, he met there his sister.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "What were their names?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "It was Itzhak Selling and Katie Selling.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They lived with us in the same village.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "It was the other Jewish couple in our village.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "So I was able to get him over-- I mean over to-- to the relatives.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "They had a sister here, and they put the apparatus in motion to get him to the United States.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't do much more, except while they were there, I fed them, make sure they got better housing, they got clothing, and made it easy for them.",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I was shipped out of Germany in December of '45.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And I was shipped back to the United States on a freighter, and got there in January.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "'46.",
      "word_count": 1
    }
  ],
