{
  "stem": "16395.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They gave us only three hours to pack the bags and go out.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "This was in '39, about December.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And my-- the older brothers and the brother and all their brother-in-laws came.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They helped us pack, because they lived in a different-- a different part of the town.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And they-- they were not relocated.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And we packed whatever we could.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And they found us a place.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "It was horrible and it-- on the second floor, a walk up, with a little kitchen and just one room.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No furniture.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "No, we left everything.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Just the beds we took.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And-- because it-- this place where we went to was a place just to put two beds, really.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And we moved there.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And-- and from then on, we already started feeling the war, because [INAUDIBLE]-- when you are not in your own home, you already, you are a refugee right way.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And the place where we moved was by the big shul.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "They converted the shul to a displaced person place.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And they started bringing people from the smaller towns into our town.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And they located them in this big shul.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "We had a beautiful shul.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, we really went to a shtiebel, where it was-- it was smaller.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It was a nice synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "But that was on the same street where we lived.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, they made-- they took all the homes, and they made it for a commandant too for the Germans-- not only my house, it was hundreds of houses. 100 houses on this place, on this street.",
      "word_count": 36
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "The whole street, nobody could go in.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I-- later, we went in, because we went every day to-- to clean for the Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, I never went as far as my-- my house, no.",
      "word_count": 11
    }
  ],
