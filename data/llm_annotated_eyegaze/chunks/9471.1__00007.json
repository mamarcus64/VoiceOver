{
  "stem": "9471.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "She did all the cooking, and she-- we have other help, you know, who help her.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But my aunt, she was cooking.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "She was cook.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "My favorite?",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Hungarian goulash and chicken paprikash.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That was my favorite food then.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Do I-- I remember once, Minister of Agriculture came from Belgrade through-- through Slatina.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And he stayed in our hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And that was a big sensation.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "That, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "But otherwise, just ordinary people, you know, who came business reason.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And they stayed for over the night, or maybe two, three nights.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "That's all what-- what I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] What should-- what should I remember?",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] What should I remember.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "How-- how was it?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Favor--",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "You know, we have every-- [LAUGHS].",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "You have to laugh.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Every Saturday evening and Sunday afternoon, we went to the other place for dancing.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "We-- we had all-- every Saturday night, young people went dancing.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Chaperoned, naturally.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "My mother always-- we never could go without.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "You know, it's different, like now.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And that I remember.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "That was a beautiful time.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "Beautiful time.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And we went to movies a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "And sometimes they came from the big city, concert.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "And I remember [PAUSES FOR 3 SECONDS] the operas, they came.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "I-- I remember, it was-- what is the name of the opera-- and I was in it, too.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "They asked children to be in it.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 16,
      "text": "[NON-ENGLISH] was the name.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 17,
      "text": "I don't know how to say it in-- in English.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 18,
      "text": "That I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 19,
      "text": "It was fascinating.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 20,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 21,
      "text": "I was [PAUSES FOR 3 SECONDS] reciting something.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 22,
      "text": "I still remember what-- [NON-ENGLISH SPEECH].",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 23,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I am a little mouse.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I don't know anything else, only health and happiness.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "That's all I know.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I was maybe eight, nine years old.",
      "word_count": 7
    }
  ],
