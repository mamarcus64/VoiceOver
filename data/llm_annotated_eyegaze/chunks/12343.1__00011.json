  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 16,
      "text": "And after all, they run out in our city, this-- [? they said, ?] oh, he's still alive.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 17,
      "text": "I was alive.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 18,
      "text": "My mother doesn't believe it yet, but there's not [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 19,
      "text": "Then one night, everything else happened in not in same time.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Then that little door it open, open, never opens.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They come in.",
