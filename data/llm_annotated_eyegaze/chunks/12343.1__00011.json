    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "They go to my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "She was laying in bed with my mother, taking off the shirts.",
