    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "I run out, and they run after me.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And I run of-- of the fields.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "Across a gardens there, and run over there, to my-- to my cousin, different city, used to live on a gentile street.",
      "word_count": 22
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "And I said, [INAUDIBLE]-- this is a cousin, [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "She-- I said, my mother been dead.",
