    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "How you call it?",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "The police [NON-ENGLISH]-- cane.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "With a club.",
