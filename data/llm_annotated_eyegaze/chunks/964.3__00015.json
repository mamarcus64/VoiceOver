  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "Because as I told you, they were fixing trucks and all these kind of things.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "One day came in a truck in to be fixed.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And you know who came?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "A guy from the company that we escaped.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "We were in hot water.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "So we disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "He came to the-- to the mechanical division where I worked with his truck.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "Because there had to be some welding done.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "Something got loose in the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 19,
      "text": "So he came there.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 20,
      "text": "So then I says, I saw him coming in.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 21,
      "text": "I walked out the other door.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 22,
      "text": "And then I gave him a message that I had the stomach ache, I don't feel good.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 23,
      "text": "So [NON-ENGLISH] and Jakob [NON-ENGLISH], they watched him already.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 24,
      "text": "So when he left, I-- I-- I came back.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 25,
      "text": "So we had a close brush with our life.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Now, it comes to the-- in the-- we used to go out with girls and with-- with girls and with the--",
      "word_count": 21
    }
  ],
