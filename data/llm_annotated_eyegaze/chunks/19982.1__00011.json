{
  "stem": "19982.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So I was with them there from-- I went, like, end of January till beginning of June.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "No, pardon me.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "End of March, because from January to March, I was with Kenel.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And I think it was end of March or beginning of April, because it was just before Pesach.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So he came and he took me to Sambir.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "He lived in Sambir.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And I was there with them till June.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I was there.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And then we heard-- this was the beginning-- end of May.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "We heard that the people could to go back to-- to-- to Germany-- I mean, on the German part.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And I started to cry and to scream that I want to go.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Maybe they're gonna let me go.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So we came in the-- there was [NON-ENGLISH], there was the border town.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And my uncle went with me, and-- and-- and cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And this cousin which came for me originally, he also went.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And we supposed to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We came there.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "That must have been-- there were Ukrainians, which wanted to go-- Polacks, Ukrainians, what they wanted to go back home.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "There was the line, which you had to sit-- stay there for two or three days.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And there was-- one day, was [INAUDIBLE] evening, I was in the line.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And it was coming, night, and I was frightened.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "It was close to the evening.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And I went over to the guard which was there and standing up front.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And I start to beg him.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "I says, listen, I'm afraid to stay here in the line.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "Please let me in.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And it seems he got pity on me.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I was frightened, small.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And he let me in.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I came in before the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And I start to beg them.",
      "word_count": 6
    }
  ],
