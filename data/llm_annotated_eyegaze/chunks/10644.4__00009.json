{
  "stem": "10644.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 50.3,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 25,
      "text": "But the scientists were already in the hands of the Americans.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 26,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "--yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "With another friend, with my friend we moved, you know, we went to-- we went to Laumberg.",
      "word_count": 17
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "We found an apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "The Germans fled-- fled-- but we found their bread or something else to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And that was-- was, for us, the main problem-- food, food, food.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "We had enough food.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "And here, you know, three Russians-- officers are coming-- Russians are coming in and started to talk like this.",
      "word_count": 19
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Do you have food?",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "No, we don't have any food-- the mentality over here from concentration camp.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "We don't have any food.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And they left and came a soldier with the whole sack, with all possible foods.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Then he disappears and brings us different clothing.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "And after this comes one of the officers.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "Did you receive the food?",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "Did you receive the clothing?",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "And we start to thank you-- him.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "He says, why are you thanking us?",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "We are Jews too.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 14,
      "text": "That was-- and here, you know, ends my time with concentration camp.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I go to Laumberg.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I spend a few days there with another friend, Paul [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "He was veterinarian doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And we headed-- with-- went to a foot.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "He was much in a better condition than I am.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "He's a veterinarian.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "He went, you know, to-- to the-- he supplied right away with meat-- meat.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "But then Russians send epidemiological hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "A hospital, a administration-- doctors-- doctors and administration to treat people with infectious conditions.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "We're among-- in this-- in this the doctor of the-- this, the doctor, the chief doctor of this unit was [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "He was a Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "The men who supplied us with all the food was [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He was also a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "But the--",
      "word_count": 2
    }
  ],
