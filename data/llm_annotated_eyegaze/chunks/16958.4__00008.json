{
  "stem": "16958.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 358.7,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Because it was mud-- it was-- the field was a lot, rains and was bad to walk.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Me and my brother, Nissen, we were walking about 10 kilometers in mud like that.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And Every came over the village.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And he knew exactly, my brother, where she is, what house.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We down the mountains, we came down.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Didn't knock on the door, just forced the window open.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And we came in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And in the room-- shh, don't talk!",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "We are Chana's brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And my br-- my sister came out.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "She was so-- she looked so good.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "Because we were in cave and she was dressed clean.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "And she was fat, nice.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "I say, Chana, they know that you are here.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "You can't stay here, because they'll catch you. you have to come with us.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "That woman didn't want to let her go, she says.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Tell Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "[INAUDIBLE] we taking her only for a day.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "We'll bring her back.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "But the mother is not feeling good.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "You bring her back.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "We took Chana with us.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "After we initially came to the, to the village, three or four days later, they told them.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "They, they weren't-- the police came to that [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "And they took apart the house.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "They-- the barns, they were, they were looking for Chana.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "If we wouldn't take her at that time, she sure wouldn't be alive.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So this was in, this was-- and Chana came before the holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And she says to my mother, I fast already.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She see the-- she took the, the holidays like the calendar from last year.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, it came Yontif.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It came Yom Kippur.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We were all fasting.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And we didn't sleep the-- in Kippur, the day.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "We prayed all day.",
      "word_count": 4
    }
  ],
