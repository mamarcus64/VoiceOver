{
  "stem": "18061.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 250.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name is Abraham Bomba, B-O-M-B-A.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is June the 9th, 1913.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "83 years old.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Beuthen Oberschlesien.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "B-E-U-T-H-E-N.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's the city.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Germany.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "That is located on the border of Poland, next to Katowice.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in Poland, in Czenstochowa.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "C-Z-E-N-S-T-O-C-H-O-W-A.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "That's in Polish spelling.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Like-- just like any other city in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "There were all kind people, all kind organization.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Mostly which I attended was Jewish places, Jewish organizations.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We went to school over there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We had special public school for Jewish children and for non-Jewish, which I attended the Jewish schools.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Just the public school from that city.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Six.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Before noon-- that mean from 8:00 to about 12:00 we went to cheder, which is a Jewish educational school.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We learned of the Bible, or other study of the Jewish history and of the Jewish Talmud.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In afternoon, I went to a public school, which started at 1 o'clock-- 1 o'clock.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And it finished sometimes seven, sometimes 8 o'clock at night.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "The entire population, it was around 135,000.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And Jewish people was around 35,000, 38,000 at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "They were scattered, but not in a big group.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Mostly the Jewish area was the lower part of the city, in another word also the poorest part of the city in Czenstochowa.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Beginning was under whatever it is called.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Now, that mean under water.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And then I lived on [INAUDIBLE], which is mean under old marketplace.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well, describe-- there's nothing much to describe.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It was a very small apartment, very small apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, there was only one room, the whole apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "How many people lived in that apartment?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Five.",
      "word_count": 1
    }
  ],
