  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "It changed hands constantly between Germany and France, depending on who won the last war.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And so I got my French visa in my passport.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "The French were not very friendly towards Jews and, generally speaking, did not issue visas.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was able to prove that we had business connections with France, and so they gave me the visa, a limited transit visa, not an immigration visa, a transit visa.",
      "word_count": 31
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "A lot of them had left already.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Some were smart enough, enough to leave early.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And others-- some left illegally overnight, made their way across the border somehow.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "There were people, undoubtedly Germans, who for a nice consideration would take them across the border, especially across the German-Dutch border.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] So the ranks had thinned already by that time.",
      "word_count": 13
    }
  ],
