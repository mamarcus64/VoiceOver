{
  "stem": "71.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "This is staying in front of my eyes.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Every time I went out and I looked at the-- at the wires, they talked to me.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They said, come here.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Come here.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I said to myself, if I come there, and my sisters are going to take the same example, and nobody will be left from the whole family.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I cannot go to the wires.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I went back into the barrack and-- and laid down, and I could not sleep.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And this repeated a few times.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I-- I-- Subconsciously I wanted to end it.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I really did not want to end it.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I did not want to leave my sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I said once to myself in a dream, I says, how happy will I be when after the war I can show my parents that we saved ourselves for them?",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We were taken that time from that barrack to go on a transport.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I was 16; my sister, Regina, was 14; and my sister Ruth was 12.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I was from the three of us the oldest, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I had older sisters that were not with us anymore, but I was the oldest one in the three of us.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did feel an obligation.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And we was taken to--",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Thank God, we are all together here in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we also have a sister that came back.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We lost one sister in Russia-- who-- who died of typhoid fever with a child and one came back.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "She married my brother in Russia and came back, and we brought her from Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "They lived in Israel and we brought her here, and she lives now with us together.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "She had a child and a husband.",
      "word_count": 7
    }
  ],
