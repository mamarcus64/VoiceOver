    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know who it was.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "I had no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Because--",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Before that, see I--I grabbed one--",
      "word_count": 6
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "--before the other.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "While I was helping with those kettles--",
      "word_count": 7
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Then I-- somebody called out, oh, you the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "You the baby.",
      "word_count": 3
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "You're the youngest.",
      "word_count": 3
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "You're the baby.",
      "word_count": 3
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 4,
      "text": "Oh, she thought that I'm in her kitchen that I have access to--",
      "word_count": 13
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Food or something.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "And she looked a bag of bones.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "And she told me who she is.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "They were the most-- the richest people in the city, probably like you would say New York, Rockefeller was the rich, something well-known, the Ehrlich's.",
      "word_count": 25
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "I think somebody's still in Israel alive.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "Because one of them went-- or two of them went to Israel to save themselves.",
