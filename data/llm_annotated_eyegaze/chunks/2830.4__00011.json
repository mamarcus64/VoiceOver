    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And every day, I felt a little better.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "And then [PAUSES FOR 3 SECONDS] I was transferred from data to a block where I met Anne Frank.",
      "word_count": 19
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "29.",
