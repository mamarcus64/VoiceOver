    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "So that was really disturbing.",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "You know, the place didn't belong to you anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "OK, let me tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "I have to read.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "In April '41-- April '41.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "The-- when they put somebody.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "And then after, let's see.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "[FRENCH] The new law came in June, where you have to register in the police station.",
      "word_count": 16
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "All this was '41.",
      "word_count": 4
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "And then August 13-- you see how slowly it go?",
      "word_count": 10
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "August 13 was confiscation of all radio.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "OK, the two last-- the two last laws was the-- the most difficult.",
      "word_count": 13
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Oh, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "How do you--",
      "word_count": 3
    }
