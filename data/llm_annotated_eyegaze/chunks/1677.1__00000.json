{
  "stem": "1677.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Kitty Fischer, F-I-S-C-H-E-R.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "K-I-T-T-Y.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Katarina Haasova.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "H-A-A-S-O-V-A K-A-T-A-R-I-N-A.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Kitty was Slovish adjective to Katarina after my grandmother.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "On the 12th of July, 1927, in Olomouc, present Czech Republic.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "No, Czech Republic is only in existence for five years.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was Czechoslovakia-- Moravia.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "68 in July.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, that I can, because I only was born there because that was the only place available for a cesarean for my mother.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we went to Puchov-- P-U-C-H-O-V-- in Slovakia, where we all lived in my grandfather's household.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My mother has married a Moravian house.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I was born, as you can see, between the wars-- nine years after the end of World War I, and six years before Hitler came to power.",
      "word_count": 28
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Completely assimilated, absolutely non-Jewish, with big Christmas trees-- I was the only Jewish child on Yom Kippur to go to school.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I was so ashamed.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I did not know what Yom Kippur was.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "They called it very posh [NON-ENGLISH], the Day of Atonement.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "But my father said that's for children to play behind the synagogue.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And I had to go to school.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And everything went smooth, assimilated-- French governesses, German governesses.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "No Jewish friends.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "To my mother, every thing Jewish was poor.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "I was invited to a Seder.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "My mother would say that's for poor people.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I was invited for Purim.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "That's for poor people.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "My mother was Hungarian, and a very snobbish, uppity lady.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And I was brought up exactly the same way.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "No jargon-- [YIDDISH] that was Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "If I said, [YIDDISH].",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And suddenly came 1939, the Slovak Republic was brought into life on the 13th of March, 1939.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "That I don't know, and I don't remember, and I don't want to know.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Probably by merchants there-- I was the fifth generation born there.",
      "word_count": 11
    }
  ],
