{
  "stem": "26790.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "We cross-- We cross the border.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The old Russian-- Russian-Polish border.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "At each station or village, station and village, people from the station or from the village was coming.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They took off people from the train.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "They took off 10 people, 20 people, 30 people, 10, as many people that can have arranged work, and as many people that can arrange for accommodation according to size for the town.",
      "word_count": 33
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And we was on the train another 10 or twelve days.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "As we come a few stations from Vitebsk, a few stations from Vitebsk, that was the middle of the night.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Two man was-- the train stopped.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I don't know what was, a station, or a town, or a village.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "The train stopped middle of the night.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Two men was coming with two lanterns.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "You know, lanterns?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "They took off 120 people.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And they start to walk, and walk, and walk.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They looked around, no houses, no people, nothing, step, pushed.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I don't know how long we was walking.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Might be one hour, half hour, or two hours, or what I, I, I don't know, because we didn't have watches.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "As we're walking, from far away, I saw light.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Not electric light, lamp, kerosene lamp light.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We come there.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Barracks.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Full of barracks.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "They give us a, a, a hot, a wash, a place to, to have a wash.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "They give us a meal.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "They took us to the barracks, and the barracks was [NON-ENGLISH] In Russian, [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Not a bed, a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "From, from, from pieces of iron, pieces of, of wire, like beds to, to sleep.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "In each bed, was a big bed with straw, and a little back for the cushion, and a blanket.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "That was all.",
      "word_count": 3
    }
  ],
