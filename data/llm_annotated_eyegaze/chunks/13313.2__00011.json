{
  "stem": "13313.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Plus slurs and insults all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Like-- first of all, we were starved, like we were-- the-- these people were pretty well off because with the money that they received from my mother, and it was a nice little house, it had a vegetable garden, where just about every possible vegetable was grown.",
      "word_count": 47
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And the-- Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Roggeman worked at the plant that was making parts for the German air force, called the Erlae plant, E-R-L-A-E, big plant near Antwerp, and brought home quite a bit of food from there, for own consumption.",
      "word_count": 36
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "He would have gladly shared it with us, but she won't let us have any of it.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "So they lived quite well.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "When we went to school, for instance-- because we went to school for a very short time for a reason that I'll explain in a moment-- so we went to school.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We would get, I would say, half a dozen slices, fairly thinly sliced bread, with a little bit of jam put on it, and that was our food supply for the day.",
      "word_count": 32
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We used to had it finished by the time we got to school, and there was nothing else to eat.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And they wouldn't get any other food during the day.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "We were also not allowed to touch the-- the-- the water supply in the house so-- so we were always-- the one overriding feeling was always, always, in hunger pangs and thirst.",
      "word_count": 32
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "This I remember very vividly.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So we-- we-- we-- we scavenged.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We-- we became little thieves.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We used to go-- there were some-- some cottages from people who lived in the city, and there were some fruit trees on season.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I used to go climb through the hedges and over the fences.",
      "word_count": 12
    }
  ],
