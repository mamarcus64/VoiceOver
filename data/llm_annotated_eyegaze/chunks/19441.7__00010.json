{
  "stem": "19441.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.3,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "But we know that you helped the people.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "So we are going to hide you in the woods.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Because there are-- we already know there is a mill.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "We saw it.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "There is plenty food.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "We are going to settle there.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "And close, while we are going to hide you.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So they didn't want to take all.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They took three girls.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They put us between the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "They made branches.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "So they made like, a little house.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And you will stay there till we explain to the Russians, when they come, who you are.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And really, the Russian arrived the same day.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "So they was telling them.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "First they were settling down.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And then they was telling them about us.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And how much we helped them, and so-- and so where are they?",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "So we-- we hid them.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Because we been afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "If you are not doing anything to them, you bring them out.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Why should we, if they-- Keep going.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "If they helped you so much?",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "So we want them.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "So they came.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And they usually-- they brought us, always, food and drink.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Because we couldn't go out of it.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And then they--",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Only three of us, was.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Three of us, the one who-- who helped me when I had that typhus--",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Who organized it, all the things.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Ruzjenca.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "And the other was-- [PAUSES FOR 3 SECONDS] --it was her cousin.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "But she was the one who was working in the kitchen.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And he supplies us with all the food, what we survived, in.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And so they came to pick us up.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And they put us to the half table.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't let us to do anything.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "Oh, no-- no cooking, no washing.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "And we had to sit with them and talk.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "But they weren't there too long.",
      "word_count": 6
    }
  ],
