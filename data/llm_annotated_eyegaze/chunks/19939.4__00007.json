{
  "stem": "19939.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "They belonged to this [NON-ENGLISH]-- you know, the railroad things, the one that supervised the trains, all these trains from Krakow, right?",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "It was in the Shoah.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "So I really worked for the, the, the railroads, for the German railroad.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "She showed me.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "I went to such a barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "This was the [GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And he-- this was the construction supervisor.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "That's right?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "He had his office.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "And there was a, a Jewish bookkeeper.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "Because there was another camp.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "This was still a labor camp.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "So they were taking some people.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "I came.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "And I-- and you know, he said maybe there is, I think, work.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "Yeah, I was hired.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "I was hired as a cleaning woman, girl.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "And I was supposed to get up at-- in the morning and come and start the fire and the, and the iron thing, little stove.",
      "word_count": 25
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I was given a little room opposite this, this canteen.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Because they could take whatever they wanted.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They paid, let's say, in coal, right, the Polish owners.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "There was a little room, tiny room, with four beds.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "There were some-- already was this Wanda-- she lived there-- and two Russian girls that somehow were stranded in Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They were in this transport.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So I was going there.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And let's say in the morning, I came.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know how to start the fire.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He was coming, this Austrian-- was an Austrian helping me.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I was there for two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I had hardly anything to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And I am sure this is how it worked.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The, the, they was coming, the representative, some former lawyer, Jewish lawyer, well-dressed, from the camp, right?",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He was coming in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And he was getting-- spoke German.",
      "word_count": 6
    }
  ],
