  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "So he wanted to save as many Jews as he can.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And he, not once, he risked his own life to-- to save a Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So we-- the whole group went on cattle cars.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We went to Gross Rosen.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And Gross Rosen was an extermination camp.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "It was-- was-- everything where we went was worse than the other one.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It was worse than Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "They took us in-- in the front of the [? entlausen ?] where they are-- want to clean us up.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We had to leave our clothes here on one side and go into the door, and then they-- we went to showers.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where we going.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We went to showers, and then we went out the other door.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And whatever we had possession from before, it was gone.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "The give us just-- just the long sleeping gowns to wear.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And it was in November.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "It was cold.",
      "word_count": 3
    }
  ],
