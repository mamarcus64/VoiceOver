  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "And we went to-- we went to Grenoble, up in the mountains, au Chateau des Manoir.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "Chateau des Manoir was run by Rabbi Schneersohn.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Chateau des Morelles, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "We always-- we never split.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "My brother and I, we always got-- we were always together.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And she was-- my sister was virtually like, like a mother to me.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Because if I-- if I did the wrong thing, that -- I'd get the back of her hand.",
      "word_count": 18
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "So I had to be very-- she was very strict with us.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "Looking back, it was a good idea, maybe, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "But--",
      "word_count": 1
    }
  ],
