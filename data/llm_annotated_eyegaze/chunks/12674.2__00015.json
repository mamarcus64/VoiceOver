{
  "stem": "12674.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] You were talking about coming back to Vienna from-- from Theresienstadt on the-- on the train.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, I know.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So one day in July, in the end of July, there was a-- a movie.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "It was called [GERMAN ], where they showed pictures, movies, of concentration camp liberations and what they found.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And I went with a couple of friends.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And when we came out, I remember to this day.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I said to my friends, I've just been there.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I said, nobody's going to believe it.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I've just been there, and I don't believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Nobody's going to believe this is true.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It took me 50 years, but now nobody is telling you that this is true.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It began with the Nazi-- it was insidious.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It worked on me.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I didn't really-- I was belligerently Jewish, but I never displayed any sign of Jewishness.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "There's something else that I did which was very stupid.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I'll get to it in a minute.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I-- it has to do with-- with wearing the Jewish star.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "But that was stupidity and belligerence, but I did it anyway.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "But I didn't display-- I-- I had the mezuzah that I was wearing.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And I never-- I always wore it under my clothing because I didn't want to advertise it.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Because I know that everybody would hate me as soon as they would see it because it was true.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They did, even when the government didn't tell them to.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Jews are looked down upon in Vienna to this very day.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "They-- they found Waldheim and they-- they put him in there.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They don't like us.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "No-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I had non-Jewish acquaintances.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes I went to somebody's house or something.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "But their parents weren't too keen on letting their children play with us.",
      "word_count": 13
    }
  ],
