{
  "stem": "21482.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "She doesn't have any paper.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "You have to take her to the-- leave her in the orphans' home.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And I remember somebody said to me, why are you so worried.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "She will be OK.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "Look at all the people, all the children in the orphans' home.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "So I took her by her hand.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "And she was such a pretty little girl.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Jenny.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And she was-- you know, she was blonde eyes-- I mean, blonde hair, blue eyes, smart.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Ulrich.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Jenny Ulrich.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And so I took her to the orphans' home.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And there were a lot of-- hundreds and hundreds of orphans.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I remember one of the women who was a friend of my mother and she was staying there with her two children, and she says you don't have to worry.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I will take care of her.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So I left her.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "There were, I know, people all day long, even the day before, all I could-- all people talked about is if they could just find somebody to give the children to.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They wanted to give the children to Polish people, too.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "What was the date?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "What was the date?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "That was March 13, 1943.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I ran to the corner to meet my group, my mother was already either behind me or ahead of me.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I don't know because I actually walked without my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid of what happened to my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where my mother was.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "But we-- you know, we walked and I walked with the people from my workshop.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And there was a couple there that had a little boy.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I think he was maybe two.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And his mother had him on her-- in her backpack.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "They smuggled him.",
      "word_count": 3
    }
  ],
