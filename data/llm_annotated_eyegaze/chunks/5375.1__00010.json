  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And everyone on the shoulder, you know, 250 rounds on your shoulder-- the box on the shoulder, you know, to schlep up, you know, into the trenches for the soldiers.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And sometimes, the soldier himself shot you.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "They kill you, they kill you.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So you were, you know, like a dog.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They aimed like on a dog, you know, point blank.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Nothing, really.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Where did just sleep when you were--?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "In the-- in the bunkers.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It was bunkers.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So what I wanted to say before-- I'm skipping from one place to the other.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "The partisans came, and--",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "--they captured all the Hungarian soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The captain was in town somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He was away.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And they took the soldiers right away in the front of us.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "They killed them.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "From us, they just took away our knapsacks.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And we would remain now only with the clothes that we wore on, we had on ourselves.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "But it started-- the Russian offensive started, and we were running.",
      "word_count": 11
    }
  ],
