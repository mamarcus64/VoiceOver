  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And he had arrived in the beginning of October 1943, back into the, in the cloister of Nonantola.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "At that time, nobody from the more adult teenage children, which were hiding by the farmers, existed anymore, because they took off and went south to the American and British lines.",
      "word_count": 31
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Then Joschko got the notification from Chichibo that the way is open.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He made an emotional goodbye to the nuns, and to the priest, and to Dr.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Bocari.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he decided to take the children, including my mother and Mr.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Avien, our cook for many years, and make the way from Nonantola to Modena, and from Modena to Milano, and from there to Como Chiasso and Varese by train.",
      "word_count": 29
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, my mother survived and she came with me to, later on, to Palestine, to Israel, and finally, to the United States.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes, she told me the story.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And, of course, I told this-- I got the story told many times from Joschko.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Directly, and from the children.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I met the children later on in Switzerland.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "At this time, I was interned in Busserach with Edgar Asher, and Arnold Weineger, and [NON-ENGLISH], another fella.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Four people, four boys were interned in Busserach under the most brutal and hard condition you would never have expected to be in Switzerland.",
      "word_count": 24
    }
  ],
