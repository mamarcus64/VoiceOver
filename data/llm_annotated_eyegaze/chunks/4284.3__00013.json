  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "It had a very serious reason.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "They wouldn't nurse.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And we were then forced to milk the horses.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And instead of having to go on the ground, [POINTS] it went into us.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "And so we had horse's milk, a very important nutritional bonus other people didn't have.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "The number of hours we worked-- 16 to 18 per day.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "We had four to six hours of rest.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "We had to march half an hour.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "But we had, at least, a life that kept us away from the selection to be exterminated.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 4 SECONDS] I didn't know we had that much.",
      "word_count": 11
    }
  ],
