  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "That's why I came back to-- to talk about grandparents.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But now coming back, you asked me what was the attitude of my parents.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "To--",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "As the war, you know, broke out, I remember only my-- my mother-- if nay, probably she knew that the war is inevitable.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "What she did is she was a very extremely smart woman, extremely energetic.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And because of her we are alive.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Me, and my brother, and my father survived.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Because she decided, probably, she heard during the First World War that they didn't have textiles, and she bought textiles-- big, big pieces of textiles.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And she rented a room in the same apartment that we lived.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And she filled up this room with textiles.",
      "word_count": 8
    }
  ],
