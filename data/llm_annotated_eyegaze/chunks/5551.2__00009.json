  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "These are the elders, the sick, the crippled, and the children.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Those who were fit, who were-- who-- young people, vigorous people, and so, were again, they were-- they were displaced into an ever smaller living quarter for use, as slave labor, as it turned out.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We came into the city at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And we became part of this residual group that was meant to be shipped for slave labor, as it turned out, to the camp in Plaszow.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    }
  ],
