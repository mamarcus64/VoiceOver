{
  "stem": "4670.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And the information I have, she was taken to Westerbork, a concentration camp in Amsterdam.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And from there, eventually, she was taken to a camp called Sobibor, which was not a work camp.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "It was a killing factory.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And she perished in Sobibor.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I have the date.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I can't remember exactly, but she died there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "The rest of the family, my cousin, who was a very favorite cousin of mine, had gone to Australia.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "He had gone, had been interred in a camp in southern-- in-- excuse me, southern France.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And then he immigrated to Australia.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "He literally he tossed a coin.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "It was came up.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "It was either Africa or Australia.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "He decided on Australia.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And the rest of the family all came out.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Some went to Argentina, the rest all came to New York.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] We were all still close together.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "But I myself worked in a bakery in Cleveland.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And I worked in a Jewish bakery.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "I worked with this very lovely family there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "And, then, I applied-- I decided-- it was a small bakery.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "And I decided I wanted a different more responsible job, because I was just a sales girl.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "I knew that there was a job available.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "There was a-- since baking, bakery was my line at that point, I know there was a chain.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "It was called the Kaiser Company, you know, like a bakery chain.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "But I had heard that they didn't hire Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "And I decided-- I was surprised that this was happening in the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "There was anti-Semitism here too.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "But I decided-- a foolish thing.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "I decided to make an application.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And they had religion on there.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "And I wrote Jewish.",
      "word_count": 4
    }
  ],
