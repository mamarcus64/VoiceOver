    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But you asked for the Ludendorff.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Now you are taking me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I knew.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
