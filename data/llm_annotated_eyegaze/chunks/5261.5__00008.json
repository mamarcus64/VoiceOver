    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I am not German.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "No, I am Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I am displaced person.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, then we shall go to the Ludendorff-Villa.",
