    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Oh, it's pleasure.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And he took me beautiful villa.",
