{
  "stem": "26699.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I met my wife at the same design office where I was working in Bucharest.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "She was a drafts woman there where I was an engineer, but different sections.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "It was a huge share government company, about 1,500 people working for industrial projects of the steel industry.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH SPEECH] Her name was Lillianna Weiner of Jewish Transylvanian origin.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Her parents were speaking Hungarian in their house and of course Romanian.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We married in 1966.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And since we married, we had in mind that one day we may be so lucky to be able to emigrate from Romania.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "The opportunity came in 1968, 69, when the turmoil in Eastern Europe happened with the occupation of Czechoslovakia.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "Her father was a manager of large hotels in Bucharest and at the sea resorts.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "He was speaking a number of languages.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "He was a very interesting.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "He's still alive in Bucharest, Franz Weiner.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "He had the a life that many people would be envious to have stories like this to tell.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "During the war he was involved in an espionage network for the allies.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And he escaped from Romania during the war, went to Istanbul, and held there a pub where all the spies of various sides were meeting.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "It was a meeting place for spies from England and America and from Germany and Italy and Japan were coming in his pub.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And actually his story is partially told in a movie, which was shown on the television.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "It was called And his pub was also shown there.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "His name, Franz Weiner.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "He was decorated after the war by the Marshall Alexander of the British forces.",
      "word_count": 14
    }
  ],
