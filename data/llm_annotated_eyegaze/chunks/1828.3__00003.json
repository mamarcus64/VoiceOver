{
  "stem": "1828.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And we made a chain, and we threw it--",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Only women.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We never saw our men again.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And we-- we did this work, and weary.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We got some food.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It was not very much.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It was less than before.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "As things got worse for the Germans and the Allies were advancing, it became worse.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And the bombings went on all the time, and we had to clear these things away.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And going up on the truck to go back-- that's on the ferry.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "That's to the-- the-- they-- they drove us to the ferry.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "On the way back again after a day's work.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And my mother sometimes had trouble getting up on the truck, and we went behind her and helped her.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "She was going through her change of life, and she had this mission to get us through that.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "She felt somehow that she was our backbone.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And she was.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "She really was.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "She had such standards, and such dignity, and such wisdom.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "It was be too much to enumerate that.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "I-- we-- when we changed over to the next location, I remember, we-- it was a new-- a new camp.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "We had to fill our sacks to-- that we slept on, and it had been a very tiring day.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "We had walked for hours.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And there was one faucet with a trickle of water.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And we lined up to drink and to wash our faces and hands.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "And other people lined up in the meantime for their food.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "They were giving out food.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "And when we got our turn, this-- they had run out of soup.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "The soup was usually a watery concoction with some turnip floating around.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "And it was no-- no chance of eating anything non kosher.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "It was water and a potato.",
      "word_count": 6
    }
  ],
