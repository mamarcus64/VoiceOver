{
  "stem": "8352.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 39,
      "text": "Other ones-- all the people what they were pretty old-- to the other side.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 40,
      "text": "[PAUSES FOR 3 SECONDS] When we were all finished on that line, [PAUSES FOR 3 SECONDS] we arrived to a place.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 41,
      "text": "[PAUSES FOR 3 SECONDS] Big buildings.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 42,
      "text": "And that was in Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 43,
      "text": "We had to go on in that building.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 44,
      "text": "I was holding on to my father.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 45,
      "text": "[PAUSES FOR 21 SECONDS] We went in that building.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 46,
      "text": "[PAUSES FOR 4 SECONDS] We had to take our clothes off.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 47,
      "text": "[PAUSES FOR 3 SECONDS] We had to go through a shower.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 48,
      "text": "[PAUSES FOR 3 SECONDS] And on the other side of the building, there were lines of barbers, whatever they are.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 49,
      "text": "Shaved our head off, our hair.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 50,
      "text": "Shaved off, we all look alike.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 51,
      "text": "We took the shower.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 52,
      "text": "We went there.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 53,
      "text": "They shaved our hair.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 54,
      "text": "They was set up tables with striped clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 55,
      "text": "We left all our clothes, all our shoes, everything there.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 56,
      "text": "[PAUSES FOR 4 SECONDS] We had to go to those tables and pick shirt, pants, a little hat.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 57,
      "text": "A cap, not a hat.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 58,
      "text": "And a little long-striped coat.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 59,
      "text": "And there was all the tables set up for those wooden shoes.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 60,
      "text": "Everybody took one of those, a pair of shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 61,
      "text": "[PAUSES FOR 3 SECONDS] From there, we went into the barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 62,
      "text": "We were assigned to big bunks or something like.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 63,
      "text": "Big buildings.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 64,
      "text": "[PAUSES FOR 7 SECONDS] We were [PAUSES FOR 4 SECONDS] staying there.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 65,
      "text": "Seeing people.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 66,
      "text": "Whatever before us there, just sitting around on the ground.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 67,
      "text": "On the floors.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 68,
      "text": "They were speaking different languages we could hardly understand.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 69,
      "text": "[PAUSES FOR 4 SECONDS] And they said to us that it's a very scary place.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 70,
      "text": "[PAUSES FOR 3 SECONDS] Next morning, we were sleeping there.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 71,
      "text": "We had those bunk beds three floors up.",
      "word_count": 8
    }
  ],
