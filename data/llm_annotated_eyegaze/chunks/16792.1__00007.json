{
  "stem": "16792.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And, uh, also, I speak a little bit of Russian in this particular time when I was young.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "My mother teach me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "My mother speak that.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "She is not from Russia, but she-- she was intelligent person.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And she has got friends, Russian friends when she was young, and she learned the Russian language.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And it's-- for me, it was good, because in the future, I-- I knew it.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And this is the way it was when I go from one rabbi to the other one.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And when I was 11 years old, they send me to the bobov yeshivot.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Bobov yeshivot means, like, here you go, and high school special, this is.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And the rabbi was a cousin of mine, Reifer.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "He was the head of the yeshivot.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "He was the head rabbi for the yeshivot.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And he prepared for me for the bar mitzvah for 13 years old.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And he teach me two years, from 11 to 13 years.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "I was very religious down there.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "And uh, I was going-- in the meantime, I was going several times to the bobov rabbi himself.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "He was a very, very, very, very big person in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Very big person, the bobov rabbi.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "He has got-- in every city, he has got a synagogue.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And, uh, he has got at least in Poland alone, he has got-- he has got, in Poland alone, over 300,000 followers.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "He was big, very big.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And then [INAUDIBLE] was his-- it's a city in Poland, which was the headquarters.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "Very big headquarters.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And I was prepared-- I was going normally every month, every six weeks, every eight weeks, I was going to the bobov rabbi.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "He knew me already.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "I mean, it's not easy to get to the rabbi, but I got in.",
      "word_count": 14
    }
  ],
