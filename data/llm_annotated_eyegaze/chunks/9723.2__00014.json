      "text": "Uh.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That's it?",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That's half an hour already?",
