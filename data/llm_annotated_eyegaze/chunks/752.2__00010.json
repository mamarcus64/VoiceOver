  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And she gave me a teddy bear.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I put it at the side where Zayde used to sleep.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "He was a very good man.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Very giving.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "A good man.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And he saved my life, because I gave up.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "I didn't want to run anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I had no use for my parents.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I had no use for my sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "So what's the use to be alone in the world?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "[SOB] But he says, oh no.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "You're not going to give up, not as long as I'm alive.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And he say, and as a matter of fact--",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "--he used to tell me very often.",
      "word_count": 7
    }
  ],
