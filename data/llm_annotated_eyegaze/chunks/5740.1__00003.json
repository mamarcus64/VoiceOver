{
  "stem": "5740.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "If she came to school and they said that I didn't know something, she sat with me, not knowing even what I was-- she bought a map or she bought this.",
      "word_count": 31
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And I had to know every city and every river on that map, which wasn't even necessary.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "But she kept me so strict, because she wanted me to be the best.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "But whatever I am today, if it's anything left of me, I have to thank my mother for it.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Because she really wanted me to be educated.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "My father didn't think it's necessary for a young girl to be educated.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Because he said, what for?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I-- I shall buy you a [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I shall buy you a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And you don't need to have any education.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "But my mother insisted, and I went to school.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And I was learning piano, and I was learning dancing.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I was-- you know, I was really having the best of everything.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But God forbid I came a minute late home.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "My mother was furious.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And I was scared of my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Let's say, every so often there used to be information in school, how you do-- it's how you are doing in school.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The mothers used to go.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "It was always on Sunday.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And that Sunday, when I stayed with my father, father home, we both had tummy aches.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The disciplinarian.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But she wanted the best for me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But I was scared.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I would say she-- she-- she was religious.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But I remember that I had a birthday party maybe when I was eight.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And my mother was wearing a piece of a wig-- not a whole wig, but a piece.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And I said, please, Mom, take it off for my birthday party.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "She took it off.",
      "word_count": 4
    }
  ],
