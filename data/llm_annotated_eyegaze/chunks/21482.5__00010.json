{
  "stem": "21482.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And so when she was diagnosed, there was already no hope for her.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "But she fought-- she fought for three and 1/2 years.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "She was on radiation and she was on chemo.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "When she was on chemo, she was so sick.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Her little girl was just two years old.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "Just two years old and three months when-- when Anita was diagnosed.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Amy.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And Anita suffered a lot.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "She had two femoral bone replacements because the cancer made her bones so brittle, like Swiss cheese, the doctor said.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And they had to operate because they said, if the bone will break, she would be in such pain that no amount of morphine would help.",
      "word_count": 26
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "So she died six and 1/2 years ago.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She was 39 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Bert.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Bert got remarried, married a-- a wonderful girl.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Her name is Terri.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And we're very close.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "We're very close.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We see them a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "They come here.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "We're going-- in two weeks, I'm going to babysit.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "I sis-- babysit for Amy when they go away.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "So this way I have Amy.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I'm able to spend time with Amy, and they're able to go away and not feel too pressured.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So Amy, of course, is a wonderful little girl.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "She's 12 and 1/2.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "She will be bat mitzvah next May.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And she's a princess amongst the boys.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "We have a-- a 20-year-old grandson who is a freshman at the University of Wyoming.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And we have an 18-year-old-- no, excuse me, the 20-year-old is a junior.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And the 18-year-old, Adam, he's a freshman at the State University of Utah.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And whose children are they?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Those are Marilyn's children.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And then Debbie's little boys are Jason, who is nine, and David, who is six.",
      "word_count": 15
    }
  ],
