  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They made a plan which sections are gonna be in-- in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was in Slobodka, not in Kaunas.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And it started two or three streets in of [INAUDIBLE] Strasse, [INAUDIBLE] Gasse.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And it took a lot of, a lot of homes, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "It surrounded I cannot mention how many streets, how many-- how many sections.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But in the beginning of the ghetto, I think was about 25,000 or 30,000 Jews in the ghetto.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "It was most of the Jewish sections and a small part of they took it away from the Gentile sections, but a very small part.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "But then the Gentile sections was given back, because they made selections.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they killed many Jews, so the ghetto became smaller.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So the ghetto, the Gentile people start to get back, you know, their homes.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
  ],
