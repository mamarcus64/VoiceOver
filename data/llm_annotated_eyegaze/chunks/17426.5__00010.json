{
  "stem": "17426.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 79.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We had contact with Auschwitz inmates that were there for a year, year and a half.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Difficult to believe, but some of them survived, mostly non-Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They were treated differently as we were.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "No non-Jew was ever gassed in a chamber.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "They had to be accused of something, in order to, to lose his life.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Jews were the victims, just for being Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In Furstengrube?",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We were sent to the coal mine.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And each of us was assigned to a certain foreman.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And the foreman was assigning us to work.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "My father and I were assigned to a foreman.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And he brought us into a small little [PAUSES FOR 3 SECONDS] area, where coal was just that night sprung off the walls, dynamited.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And we had to bring this coal out and put it outside on a roll-- a lorry, which was on a railroad, small railroad, rails.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And my brother was assigned to move these lorries to the end of the, of the coal mine.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And that's how they brought them to the surface.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And there they were put on big wagons and driven to Buna, where they were producing synthetic rubber from coal, extracting the [PAUSES FOR 3 SECONDS] properties from coal to create the synthetic rubber needed for the war-- tires and et cetera.",
      "word_count": 42
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Well, this was a complete different life.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "It was torture at work.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "Because we had to bend down-- it was only about three feet high-- carry these heavy blocks of coal.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "Our hands became braised and our faces were covered with the dust of coal.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And when we came back to the camp, it was hard to find a bit of water.",
      "word_count": 17
    }
  ],
