    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "So then when our name came, I wrote every day, and you could go to one of the offices and get a card or letter to family.",
      "word_count": 27
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And every day, I went there and I wrote to my parents-- my father, especially, get me out of this place.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "Because you put a lot of money into it, and we are still here.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And that--",
      "word_count": 2
    }
