  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And then I packed up all my things I had in Houston, Texas, and drove my old car to California and finally found the family near Olympic Boulevard on Wilshire Boulevard in Los Angeles.",
      "word_count": 34
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And her name-- and we came to the aunt-- was Lisa Leon,.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And they lived on Plymouth Avenue in Los Angeles.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So I stayed there with them for a couple of weeks till I could find my own apartment.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "But I figured I would wait till my wife, Marget, would come over.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It took awhile because of getting her paperwork and so on.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And finally, she came.",
      "word_count": 4
    }
  ],
