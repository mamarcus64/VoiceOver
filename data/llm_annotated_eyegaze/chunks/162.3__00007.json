{
  "stem": "162.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "My girlfriend took me to the beauty parlor.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She made up my face.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I started to wear silver lip-- I mean, silver nail polish.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "That was the in thing.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I thought I had been dropped in paradise.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I had never seen a place like Los Angeles, and I had the most wonderful time.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And after two weeks, I get on the plane.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I cried the whole way home.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I cried.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I get off the airplane, and it's a blinding blizzard.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "The snow is going, and it's freezing.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "It's 20 below zero.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And my parents are standing at the air-- in those days, you had to get off the airplane outside and walk into the building.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And they're standing there.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I didn't say hello.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'm not staying.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Just like that.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "After that I said, hello, how are you?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "But the first words out of my mouth were, I'm not staying.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I had sort of fallen in love with some guy that I was introduced to here, and I thought I had a mad love affair going.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, it took me about a couple of months, a few months, and I came back here.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And I settled here.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I was going to go back and study voice and drama.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I started working.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "To make a living, I started working at an allergist's office, Dr.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Pinasse. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Because I had only had two years in Minneapolis.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I was going to hopefully continue here.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I started working at the doctor's office and my girlfriend-- I-- you know, I started going out.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I was having dates.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And-- and I had this big romance with this fellow that I had met on my first time here.",
      "word_count": 19
    }
  ],
