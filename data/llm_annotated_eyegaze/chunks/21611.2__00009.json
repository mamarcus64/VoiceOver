{
  "stem": "21611.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And proud, he went to a factory, and he told them that he can press.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And they paid him $18 a week.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "You couldn't live for $18 a week.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "So when he asked for a raise, they were very upset with him.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "So he left.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And at that time, he went to the Saint Lawrence.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "He met those people, very nice and very helpful.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "And they trusted him.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "Without a penny, they gave him dry goods.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "And he made customers and the customers loved him.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "He was a honest, and a very-- my husband was a very special person.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "Everybody loved him.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "They always say that this man didn't have an enemy in his-- enemy in his life.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "'48.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "After my first pregnancy I was scared of pregnancies.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I had very bad time with the first one.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Running, sleeping on the floors.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I didn't even know how to sleep on a pillow.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "So I was very scared of pregnancies.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "But my son started to complain that he doesn't have a sister, doesn't have a brother.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "So I realized I'm selfish.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And I have another little boy that he was-- that apple of our eye, Gary, after eight years.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "He was very special.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "He was a good scholar.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "He was already in the Talmud Torah.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "He was a very good scholar, very capable.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "But after my-- I lost, first, my husband to cancer 18 years ago.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "And then, eight years ago, I lost my son.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And I have one son in Vancouver. where I get the strength, I don't know.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "Maybe-- maybe the love I received, I can still love and not to hate.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "I don't know what hate means.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "To me, charity is very important, to help.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "I always helped.",
      "word_count": 3
    }
  ],
