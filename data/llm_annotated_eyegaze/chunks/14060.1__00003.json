  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "She was already an elderly lady in my childhood-- [PAUSES FOR 3 SECONDS] was married to a gentleman called Heitler, Gyula-- or Julius in German-- Heitler, who had a successful shoe shop in the main thoroughfare of the town.",
      "word_count": 39
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Having had one son who was also considerably older than my generation, and was also deported with his wife and their young child.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "The youngest being my aunt called Margit Weiler, she was married to an industrialist in a town called Papa, which was also in western Hungary, not very far from our town.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Today, it's basically an hour's drive.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And she is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "She has a son of my age and a daughter who is two years younger than me.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "They were-- basically survived because, as you know, in the time of 1944, after the Germans came in on the 19th of March, the important people in every town, about 10 of them generally, depending on the size of the town, were immediately arrested.",
      "word_count": 44
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "This was a kind of a frightening move.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And also to chop off the head of the communal leaders and, therefore, disrupt the orderly management of the community, and advice of these same people.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "My uncle, the lawyer, was one who was arrested immediately, practically a day or two after Germans marched in.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And so was my aunt's husband, being an important industrialist in their town of Papa.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And these people were kept in the local Gestapo headquarters.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And I have personal knowledge of the circumstances how they were kept, so much so that they did allow kosher food to be delivered to the inmates.",
      "word_count": 27
    }
  ],
