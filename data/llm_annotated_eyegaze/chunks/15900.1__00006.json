{
  "stem": "15900.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "That's why I made-- that's why I lived and paid everything.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you have pastry.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "You have other kind of stores.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And they need supplies.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Cheesecake, danish, danish or bread.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they were very delicious, the biggest stores there.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Once it was-- the fifth city in-- in the world.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "From Warsaw to the small towns.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And there they gave me an order-- and later on they gave me some percentage.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "That's what I did.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Later on, when I worked with my brother, I helped him.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it's a-- it's a big story.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "When I was a child, I got spinal meningitis, nine years old.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And millions of people-- children died, thousands of children.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And I was crippled.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "Do you know what spinal meningitis is?",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "I was crippled.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "I had-- I had like this with a [NON-ENGLISH], and with-- with the-- with the iron on--",
      "word_count": 17
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "On the legs and everything, and I was blind.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And they pronounced me dead.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "This is a true story.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I was eight, nine years old.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "My younger brother, who you see there in the picture, I didn't walk.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "And he didn't walk either.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "He followed me.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "And my mother's sister lived next to us.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "And the doctor went into her, and told her, look, Mrs.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "Galek, he's not gonna live.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "Why the mother has to see-- he's gonna die.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 11,
      "text": "I want to give him a needle.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 12,
      "text": "That's why I believe in taking life.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 13,
      "text": "I give him a needle.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 14,
      "text": "And my mother find out, and she throw the doctor out.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 15,
      "text": "I don't want to see you.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 16,
      "text": "You want to kill my child.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 17,
      "text": "I do everything to save his life.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 18,
      "text": "Later, when the doctor came in, a couple of weeks later, pronounced me dead.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 19,
      "text": "I was dead.",
      "word_count": 3
    }
  ],
