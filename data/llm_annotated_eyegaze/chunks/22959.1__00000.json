{
  "stem": "22959.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Mira, I'd like to begin today by having you tell us your name, and spell your last name for me, please.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My name is Mira, M-I-R-A, my last name is Shelub, S-H-E-L-U-B, like in boy.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "During the war I was called Mira, M-I-R-A, and Scelubski, S-C-E-L-U-B-S-K-I.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born January 13, 1922.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in this Zdzieciol, Z-D-Z-I-E-C-I-O-L, Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Before I start to tell you my story, I would like to convey to you a message.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "[BACKROUND NOISE] Never say they it is too late.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Never say that it is the last road.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Never say that you cannot see the light at the end of the tunnel.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Because we, young men and women, as partisans in the forests for the courageous battle against enemy for a better day, for a better tomorrow, for a better future.",
      "word_count": 29
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I was born, as I said before, in a little town in Poland, Zdzieciol.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] I had a nice family.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We lead a beautiful, quiet, nice life.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "I attended an elementary school, a Jewish elementary-- elementary school, but all the subjects were taught in Yiddish, only history, Polish history, geography, was taught in Polish.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My family-- I had my mother, my father, my grandmother, my brother, and my sister.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Chaimmichel, C-H-A-I-M-M-I-C-H-E-L.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Raznov, R-A-Z-N-O-V.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was Chana Raznov.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My grandmother's name was Henie my sister's name, Sarah, and my brother's name, Moris.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I started this elementary school and I graduated, and then it was time to move on.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My--",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father was a very clever, smart man.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He was the director of the Yiddishe shule, of the Yiddish school in our town.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] We had a very nice family life.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 7 SECONDS] And-- [SIGHS]",
      "word_count": 6
    }
  ],
