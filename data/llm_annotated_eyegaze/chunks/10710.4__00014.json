  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I have a sister.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I'm not alone yet.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "So it was like, you know, we wrote letters, love letters back and forth, back and forth.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I used to send her packages from Italy when she lived in Poland there.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And it was hard for them.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I was alone, and I would manage some way.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And my wish was to see her.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I mean, from all those years I never saw her before.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I mean, if I would meet in the street, I wouldn't recognize her.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And--",
      "word_count": 1
    }
  ],
