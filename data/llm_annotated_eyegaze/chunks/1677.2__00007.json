{
  "stem": "1677.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 487.3,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I still think, as I talk back of her, how she adapted.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "That must be Jewish, this.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "I lived in a dream world.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "To me, this was only material for my book.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "I didn't give a continental what was happening to anybody else.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "My mother volunteered in the laundry.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "She has never seen a laundry from inside in her life.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And there was a Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "Pokorny.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "This Pokorny was there, because he, by a fluke of bad luck for him, he was, like very many quislings, denouncing Jews who were in hiding.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "And in the end, they caught him.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "And they brought him to Sered and made him manager of the laundry.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "To go-- be ready to go to Auschwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And in Auschwitz, they burned him alive.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They waited for him.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "They knew in which transportation, the ones whom he sent there.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Pokorny, a very famous figure in Jewish persecution in Slovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "P for Paul, O-K-O-R-N-Y, Pokorny.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And where he was cleaning there in the laundry, my mother worked in the laundry, a few others.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "She made friends with Jewish women she never met, she never knew.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They were talking about their experiences.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I was stunned.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "My mother, from that arrogant Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Haas, became just somebody with a great big Star of David, got up at 6 o'clock in the morning.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And she had a bad limp, one leg shorter than the other.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And my poor father could not go anywhere.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "One day, they had this wonderful idea.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Would everybody over 60 step out?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Over 60-- my father-- or maybe over 55, because my father would have been in that category.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Maybe they meant 55.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I went there instead of him.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They said, what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "You're not 55.",
      "word_count": 3
    }
  ],
