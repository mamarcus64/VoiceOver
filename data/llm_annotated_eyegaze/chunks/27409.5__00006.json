  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 53,
      "text": "It was a group led by Storozheshin, a member of the-- high member of the party, Communist Party, which was part of the famous Korpak partisan unit.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 54,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "They brought me there.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They interrogated me.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I told them the truth, I am a Jewish deportee.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And how I escaped, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "The last what I knew, was that I let myself drop backwards in the pit.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He asked me question different, what I was and how-- what I did under the Russian when they were in Bucovina and so on.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I spoke with him in his lingo.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "He saw I bona fide And [INAUDIBLE] he told me, would you like to join?",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I was in a very bad state, hungry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And they-- they gave me to drink.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They gave me-- it was a particular paramedic, if it were, feldsher, paramedic.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] Aleksandar Vasilyevich Tizhnivoi was his name.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "He saved me really.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "He bandage me, and he saved me really, without cold compresses.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And he brought me to life.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And he asked me, do you want to help me?",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Do you know first aid and this because we need it?",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "So I worked first with him.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "When I came to myself I could already walk and run.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "So they [INAUDIBLE], oh, you will help us.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "You have to join.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "We moved all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "We were near a place, Berdichev.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And there was this large German garrison.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And they asked me to go in the village, dress as Ukrainian youngster, and to offer my services to the kitchen, a German kitchen.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "So I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "I didn't speak to show that I understand German this [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "I [GERMAN] and made the [INAUDIBLE] clean.",
      "word_count": 7
    }
