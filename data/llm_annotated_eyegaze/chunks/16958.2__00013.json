{
  "stem": "16958.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "And as we come down there, was not till the knees, water, mud.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "And we look this way.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "We see a hole like a fireplace.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "Exactly like a fire-- round hole.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "At the bottom of the ravine.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And we look in there.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But we have no flashlights to see what's inside.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "We don't know if somebody's going to move in, if he's not falling down a hundred feet.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "So who goes first?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "My brother.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 7 SECONDS] They-- I remember on a piece of wood, I think that we tied on a rope on him.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And he was going with the feet for.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And he run down.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And he says, OK, I'm standing already.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Come in.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And we all crawled in there.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "We had the light.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And we find ourselves in a little cabin, a room like 10 by 10, something like that.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Stones.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And we had a big stone here.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And we thought, that's all?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "We look.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "We see a-- there's an opening somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And we started crawling.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "This was about four feet high.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "No more.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was 21 and 1/2, 21 years.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We were five people.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We were five people to come to explore, to see.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And-- and it was about four feet high, and very low.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And we started crawling.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Lie down.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "You have to crawl.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "We crawled about 40 feet.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "Or maybe 50. 40 feet, I would say.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "And we came in in a big place.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "Huge.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "High.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "Maybe 20 feet high.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "Maybe 50 feet.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "You could-- with a car, you could-- but the stones, boom.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "You see a big stone, and you see it came from there.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "It fell on.",
      "word_count": 3
    }
  ],
