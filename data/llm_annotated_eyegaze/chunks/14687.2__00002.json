    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And we saw all these ladies there.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But we-- we forgot to-- we-- we were already shaved ourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So I said, look, these people they are men with the boobs-- [NON-ENGLISH].",
