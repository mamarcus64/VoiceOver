    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It was 2 o'clock.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We arrived there in that barrack, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "That house where they used to sleep these--",
      "word_count": 8
    },
    {
      "segment_idx": 28,
