  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] When I-- my father was a regular listener to Radio Free Europe and the BBC.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So we-- he was always very much aware of what was going on outside of the country in the normal world.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And one of the memories I have growing up under those circumstances was, shut your mouth, never say a word.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "Don't ever even think about talking about your father listening to Western radio.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "Shortwave radio is the way you got it.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And don't ever talk about anything.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "Once you're out of this apartment, you don't talk about anything that happens in this apartment.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And I have clear memories every day as I left the apartment to go to school, that was the last thing my mother said to me.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "Remember, don't say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "The other interesting memory is this high school, the gymnasium that I went to, the woman who was the principal-- this is all-girls' school.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "I went to all-girls' schools because that's the way the system worked, both elementary and, and high school.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "The principal of this school was a half Jew, [PAUSES FOR 3 SECONDS] married to one of the army high mucky mucks, a major general in the army, who was not a Jew.",
      "word_count": 33
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "She was brought up by Catholic nuns.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "So she combined in this school that she was the principal of, she combined-- we were called red nuns.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "Anybody who graduated from school under her principalship was called red nuns.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] We were under extremely strict [PAUSES FOR 3 SECONDS] ethical requirements.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "But we were also under-- which was combined with the communist ethics.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "So it created a very interesting environment to grow up.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "You basically have to understand that I had two lives.",
      "word_count": 10
    }
  ],
