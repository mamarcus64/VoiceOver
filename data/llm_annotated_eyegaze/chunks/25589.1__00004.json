{
  "stem": "25589.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You have to first climb a fence, and then you have to go to-- it's like where they keep manure.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "So we had to go along a ledge.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And we go along the ledge, and we're picking apples.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "As soon as I'm up the tree, and my buddy yells there, the farmer's coming with his dogs.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I'm getting out of there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And as I go along the ledge, [INAUDIBLE], I go into the manure.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I smelled pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So it was good thing it was summertime.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So there's-- around where we live, there's a pond.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So you know what, I says to my friends, we better wash out our clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So we wash out the clothes, and we lay out in the sun until the clothes are dried.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "We come home, and my mother says, Mey-Pie, you smell from something.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "What did you do?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I said, oh, I didn't do nothing, ma.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "She said, yeah, you smell from something, and it doesn't smell good.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "You better tell me.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And we didn't lie.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I said, yeah, well, we went to pick apples, and I fell into the manure.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She says, good for you.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Serves you right.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "You should have fallen [? headfirst. ?] You should have go put your head into the manure.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I said, no that I didn't do.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "So she washed off our clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And that was the end of that story.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "But the other story that didn't go so good, was-- I was playing-- I'm a soccer player from when I was 6 years old.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I don't want to sound conceited, but I was good.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I was pretty good at that.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Because I liked it.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I'll tell you a story during the war, what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I'm getting ahead of myself.",
      "word_count": 5
    }
  ],
