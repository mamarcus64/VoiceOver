{
  "stem": "18813.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 436.5,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Were discussing that, but [SIGHS] you couldn't help it.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Like, I always was discussing with my mother, why don't you go where your whole family is?",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "Your whole family lives in Vancouver.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Why don't you go?",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Why did you stay here?",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "She said they came to this country from-- because from a small city because of poverty.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "And I married well.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "And business is good.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "And my two sons came into the business.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "I cannot leave everything and leave.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "One day, we'll go just for a visit.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "1938.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "They were too much involved in the business.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "That was the tragedy because they could have get the papers to come here to Canada with no problems.",
      "word_count": 19
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "She had, I think, four or five brothers, sisters, and mother and father here, everybody in Vancouver.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "So there was no problem.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There was no persecution, really.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We didn't hear nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Poland was the first country where the-- stepped in, in right away to work.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "It was a Wednesday morning.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I remember like now.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "It was around 10 o'clock in the morning when they came in, September the 5th, I think.",
      "word_count": 17
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember what I ate yesterday, but that I remember.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "But we-- they were greeting from us very nice.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "But the next day wasn't so nice anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Which one, the next days, after two days?",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "The day after-- huh?",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "The day after, they came to my father.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "I remember like now.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "No, that was Wednesday when they came.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And so Friday morning, knock on the door.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "Can I have your keys?",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "My father said, from what?",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "You know, from your business.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And they took the keys from our business.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "Our tragedy was very big because my father only believed in the merchandise and only in the business.",
      "word_count": 18
    }
  ],
