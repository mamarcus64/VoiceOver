  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Some people grabbed right away, they opened up, they ate, and a half hour later they died.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I was lucky nobody threw out to me, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The only thing-- one time, a soldier brought us over to a house, and he asked the lady from the house-- there was five people, I think-- feed them.",
      "word_count": 29
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I don't know, she said something.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "She hasn't got something or what.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So he opened up the stove.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We took out [BACKGROUND NOISE] the dinner and put on the table there.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Because potatoes, the potatoes didn't kill me, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And I would eat something wrong, I wouldn't be killed.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] Good.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "OK, we'll change the tape.",
      "word_count": 5
    }
  ],
