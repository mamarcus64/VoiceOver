{
  "stem": "26731.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Took a bus downtown, saw the art gallery down there, and came back.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Took the evening Zephyr to Saint Paul.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I was met by-- it was William Hoffman.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "He was a case worker at the St.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "Paul family service.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "He took me under his wing.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And I was in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I was 21 on the boat.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Exactly I came here, the 30th or 31st of January, I arrived in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "'48.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Saint Paul, I got to work at first a refrigerator company.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Actually, pretty rough work, that glass, fiberglass.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But I got used it and there too, they try to teach me ah, we're going to teach him some four-letter words, and embarrass him.",
      "word_count": 25
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I had to tell them, don't try.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "The four-letter words are Anglo-Saxon.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They are identical or almost identical to the German one.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "It doesn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And then I worked at a hospital as a kind of orderly or porter.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And then I finally started-- in October, '48, I started school, University of Minnesota.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "Had a job in the morning, noon, and night.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "I worked at the-- as a busboy, at the union.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "And in the summertime worked as a janitor.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And sometimes at night I-- they had earmuffs.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "The earmuffs had funny faces, if you recall, with earmuff.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And outside was funny.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "I did those.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "And actually at the Hillel House, I got a room there.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "I was assistant caretaker.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Of the Hillel House, particularly at nights helping out, weekends when the regular caretaker wasn't there, Sundays.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And that's school and work.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Actually what happened, I got a scholarship to get some money toward tuition from the family service.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I forgot the name.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "It's a Jewish women, association of Jewish women.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I get some help there.",
      "word_count": 5
    }
  ],
