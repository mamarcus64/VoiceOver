{
  "stem": "7873.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "All-- the whole time, there's all Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "There was a death camp, like Birkenau.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "We didn't do any work because there was no work to do.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "I stayed there for awhile.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "One time I got beat up.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "They used to-- five people used to push a wagon, a flatbed wagon to pick up the deads.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "There's a lot of dead bodies laying all over the place, and they were getting close to me.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "I was laying on the ground, unconscious, and one guy knew me.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "He knew my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "He ran and called my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "He was in a different block, a different barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "My brother came.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "It's all he had to do.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "Stood me up.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "They came with a push cart.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "They looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "They were just laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "I wasn't still-- I was still unconscious, but I was on my feet, so they wouldn't touch you.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "In that place it was always foggy-- from burning the people.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "There was no crematoria-- they were burning them.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "There was a crack in the mountains and that's where they were throwing the people down, their bodies down.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "And they had a group of people who would burn them.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "These people would never see the shine.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 30,
      "text": "They never came up.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 31,
      "text": "They stayed there.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 32,
      "text": "When you looked down you couldn't see them.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 33,
      "text": "That's how deep it was.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 34,
      "text": "That's the place that separated me from my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 35,
      "text": "That was a terrible thing for me.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 36,
      "text": "And I was assigned, again, for a march.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 37,
      "text": "It wasn't far.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 38,
      "text": "Put us in a train car and we were wind up in lower Bavaria, building a airfield for the airplanes. 12 o'clock every day, 12 o'clock the Americans used to come and bomb.",
      "word_count": 33
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 39,
      "text": "There were a couple double mortars, airplanes.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 40,
      "text": "The American burned them.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 41,
      "text": "They used to go solo.",
      "word_count": 5
    }
  ],
