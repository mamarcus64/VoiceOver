{
  "stem": "14251.5",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 33,
      "text": "And I see this little figure kind of dragging the feet with the baby carriage, the-- that woman's baby.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I stop-- and I was actually not with the group.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I never was with any group anywhere.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I looked.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And finally, we met up and I said, is that you, mommy?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I thought you were dead.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I know I've said that sentence before.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "It happened several times.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And she, as it turned out, had had lockjaw and was very, very sick.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And of course, the Russians had no way to treat their own.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Hospital in Russia was conscripted to death.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "No one went to hospitals because you'd never leave again, only dead as a corpse.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And in fact, the property behind the orphanage was-- they'd lay them out there after they would die.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But we were used to that.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Just like prior to that, I had gotten used to seeing shrunken bodies in the snow.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "You know, you just get used to it.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Or a woman who appeared to have her head cut off.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "That was not unusual.",
      "word_count": 4
    }
  ],
