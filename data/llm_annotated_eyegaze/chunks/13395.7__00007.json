{
  "stem": "13395.7",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It's almost ere of yontif, and no one stops to ask, who are you?",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Why are you sitting here?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Are you Jewish?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "What are you-- it's yontif.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Where are you going?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Nobody bothered to ask who we are.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "The three of you were together?",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Right, and a few other people with us.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we sat there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So we decided to go to the Red Cross.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And they put us up in the school.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And wouldn't you know, middle of the night, Russian soldiers came into the classroom.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "My mother, my sister, and I, we threw a bench at them.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "It's this story of my life.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And we realized there is no point.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "If we can't even be safe as women in Bratislava in a cultured country, how are we going to get through Turkey or Lebanon to get to Palestine?",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "This is a hopeless mission.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And my mother, and my sister, and I decided to turn back.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And go where, back to Bielszowice?",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We heard that the Allied have set up camps for Holocaust survivors.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But my mother still was not ready to go to a camp again.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "But she knew all these resorts, Austria and around there.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Because the family was always going to these resorts, in Czechoslovakia, to Carlsbad, Marienbad, Bad Gastein in Austria, and so on.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And so she was hoping-- she says, you know, we're going to go to these places.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We'll get-- we'll settle there and see what we're going to do.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "My sister was ahead.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I said I knew how to sew.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "We spoke the language.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "We'll start a new life, see what we can do.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "We stopped in a town.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We went from door to door, from hotel to hotel.",
      "word_count": 10
    }
  ],
