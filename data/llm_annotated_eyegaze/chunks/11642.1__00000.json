{
  "stem": "11642.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Frances Flumenbaum.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "F-L-U-M-E-N-B-A-U-M.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Frances.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "F-R-A-N-C-E-S.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "June 10th, 1923.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Blady.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "B-L-A-D-Y.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The name of the city is Slawkow.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "S-L-A-W-O-K.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I remember about my childhood.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I was born to a very orthodox father and mother.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Mine father's name was Wolf Ber and my mother's name was Bela.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Bela [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You want me to tell you now what I remember?",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I remember being raised very orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And as a child, I not knowing even being uncomfortable and why.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I did go through my life till I understood because I respected and loved my parents highly.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And I thought, whatever they tell you, this is the way how it should be.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I loved them dearly.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "I came from a home where we were comfortable making a living.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "My father was a scholar, my mother also educated in several languages.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "I do remember my mother giving lessons in Hebrew and in Russia in order to make a little bit more comfortable our life.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We had a grocery store.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And my mother helped in the store because my father was a scholar.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "I also remember every Saturday, people are coming in to our house, and listened, and learn from my father a lot.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "At that time, I was young enough, but I liked to listen also.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And I was sitting in a corner where they didn't even see me, because, as a girl, I wasn't allowed to be in the same room.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "But I liked it a lot to listen whatever they had to say, at that time, whatever I understood.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "When I started regular school, I also two years before, I start Hebrew and Jewish education.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "I remember a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "When I did play outside with my friends, it was very pleasant.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I liked to play.",
      "word_count": 4
    }
  ],
