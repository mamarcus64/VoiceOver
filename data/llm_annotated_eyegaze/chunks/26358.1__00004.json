{
  "stem": "26358.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Friday afternoon, my mother used to tie his-- trim his beard, trimmed his-- I mean, his hair washed.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "She used to take care of them.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "My mother-- see, like, I was the princess by my father.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "She was the princess by my grandpa.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "He loved her very much.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "And he got-- she used to do everything for my grandpa.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The same town, like 2, 3 miles each other.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We used to go.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Walking.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "No horse and wagon.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We have a train go by, you need to go to the station.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "That time, I took the train, and I went to the city shopping when I was older, like--",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Was Peremyshlyany.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, typical things-- I'd loved to fancy-- underwear.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry to tell you.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I used to buy nice day slips, you know, silky.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I used to buy gorgeous bras-- satin one.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Never wear their cotton one.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Well, I used to ask my father for money.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And he give it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And I used to buy-- I used to-- my dresses to make, I need my father.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "We used to go to the store in that city, used to call [INAUDIBLE], the store.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "We used to go.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And he used to have a lots of clothes-- material.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And we used to pay the material, go to the dressmaker, and made the dresses-- shoes, dresses, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And I loved that.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "I loved to go shopping.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "Until today, I still love to go shopping.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "She was a housekeeper.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And she was arranged every time to what-- well, we have a lots of field.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And we liked to plant potatoes a lot, not-- you know what I mean-- [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And we have corn for bread.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "You know the corn-- the wheat, corn-- that we have it.",
      "word_count": 11
    }
  ],
