  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But the future has shown that, because of that split, we were not a strong society whatsoever.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We had a representative into Polish, same-- how do you call it? legal representation after the elections.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "It was Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Osais Thon, well-known personality.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "How do you spell it please?",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "T-H-O-N.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "By the way, I have to mentions that Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Osais Thon was [INAUDIBLE] for my brother, Joseph.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "My father liked very much the doctor, and we were in very close contact.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "My friends, my colleagues.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "I had a very nice [PAUSES FOR 4 SECONDS] group of people.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We understood each others and we were studying the Jewish history.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We had to pass examination.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And everybody had a nickname.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Funny or not funny, I was having a nickname Juen Juen-- J-U-E-N, because I had a [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I had a- something what my friends didn't like it, but that made me popular.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "First of all, we had meetings.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Then we had some sort of entertainment.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Then we had some collections of different cases.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] It was always-- a directive came from the top.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't say that they were religious, but they were very sympathizing with Jewish faith.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "But not all were practicing.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They had to belong somewhere.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You had to have some ideas in that time.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "You can't say that you are not believing, but everybody was practicing what he understood was in his reach.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh yes.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We all belonged to the Zionist organization.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We always paid some membership.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Once, I lost my book with the receipts for my membership, and it was picked up by one of my professors, a woman, Jewish lady.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I remember her name, Arnold.",
      "word_count": 5
    }
  ],
