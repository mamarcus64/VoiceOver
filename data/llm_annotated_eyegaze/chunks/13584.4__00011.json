{
  "stem": "13584.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We received a one-way document to leave Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And to receive this one-way document, we had to sign an agreement that we are rejecting the Polish citizenship.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "For some of us, it was painful, for some-- because we grew up there.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "For some of us, we could not care less.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "So we received the one-way travel first, to Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "In Vienna, it was Sochnut.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "An organization, Sochnut.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Ask her-- they asked us-- to ask us-- I mean, tell us to go to Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Because, officially, all of us were going to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And they asked me why we decide not to go to Israel, but to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And I said, in Israel, they do not offer Yiddish.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "In Israel, there is no way no-- for-- for a teacher of Russian, same thing, my wife.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I said-- and this is true-- I'm bound before I left Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I wrote two forwards to the Jewish newspaper, forwards.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "If I come to the United States, to New York, if I will be able to work at a Jewish newspaper, they apparently knew me from writing in Polish Yiddish newspapers.",
      "word_count": 31
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And the-- and the editor or assistant editor named Moishe Crystal-- I remember his name-- wrote me, listen, as long as you are in Poland, we cannot answer you this way or that way.",
      "word_count": 34
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Come to the United States, we'll talk differently.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And that's what I showed-- showed at the Sochnut, the letter.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "They said, no problem.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "You'll be-- be transferred to Rome.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "In Rome, we were about 5 and 1/2 months.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "We found out my wife was pregnant with our daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And the organization, the Jewish organization, the HIAS, tried to find for me a sponsor.",
      "word_count": 15
    }
  ],
