{
  "stem": "23506.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So I changed the place of somebody who sit next to him.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And I said, let me-- let me talk with this man, because I know him.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I was afraid he didn't know what my name was, that he will do something.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So I sit there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I-- you know, I elbowed him.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I said, hi.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Remember me, Wanda Gajda?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And that's how I gave him the clue what my new name is.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Where are you going?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He said.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I told him I'm going to-- to Cracow.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "He offered to go with me.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Because he has places that I will sure find a place where to stay.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And so we went to Cracow.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, my brother is on a job somewhere by Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "By myself.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I see two-- two Selbschutzes, with the German blue, Volksdeutscher, and somebody else.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And they're gesticulating and talking.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I know they're talking about me, because he's not bashful.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I said, like that-- I go get a newspaper.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I buy the newspaper and I look, you know, with the-- with the-- with the corner of my eyes to prepare myself.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they talk, came over to me.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And he said like this, this German Volksdeutsche-- one was a Polack who was just fishing out all the Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And he says like this, you-- where are you going?",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He ask me, this Volksdeutsche.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I said, I am going to Piotrkow.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "What you doing here?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I'm waiting for a train.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "So he said like this, this Polack-- calls over another Volksdeutsche.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And he says like this, listen, this woman says she's going to Piotrkow.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Which mean she is from [POLISH], you know, parish.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "So he ask me, what is my parish?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And I told him.",
      "word_count": 4
    }
  ],
