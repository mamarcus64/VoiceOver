{
  "stem": "6777.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And with other words, he lost his fortune.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "And I've been only young, about what? 12 or 13.",
      "word_count": 10
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "And I started to work.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "Apart from going to school, I've [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "And once he lost his fortune, he reverted to grain merchant, because that was where he came from, from his parents.",
      "word_count": 21
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "And as long as he was alive, he kept his family in this way.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "But my father died in '38, and there have been still the twins at home, 10 years old, still young children.",
      "word_count": 21
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "And my mother, who has never worked in her life and wasn't used to this change of lifestyle, she couldn't really take it, and a few months later committed suicide in '39-- January, '39.",
      "word_count": 34
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "And there have been the two little children left.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "And this, at that time, Vera was already married and in Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "And I've been in Warsaw, because I studied at the university.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "And our grandmother adopted one.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "That's a [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "Looked after the two kids at home.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "When my parents died, then the two twins-- we wanted them to finish the school year still at the schools in Kalisz.",
      "word_count": 22
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "They went to a Jewish-- each to another Jewish family who kept them till the end of the school year.",
      "word_count": 20
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And then we brought them over to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "And they lived with us.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "Vera's husband was the manager of the Jewish students' hostel, boys hostel.",
      "word_count": 12
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And I've been the only girl student in the hostel.",
      "word_count": 10
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "They often thanked me.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "They are 100.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 5,
      "text": "She is one.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 6,
      "text": "There have been 100 boys, and I've been the only girl.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, we brought over the two kids and Ida into Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 8,
      "text": "That was at the end of the school year.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 9,
      "text": "And not to very long afterwards, the war broke out.",
      "word_count": 10
    }
  ],
