{
  "stem": "3933.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "They took me out from this driveway.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "With this little-- I'm holding this little soup, and here a little package with a [INAUDIBLE] is left-- where I was having for my son, a little pancakes or something for myself.",
      "word_count": 32
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was writing to this old lady where she was-- I rented just recently a little corner where I can pay her.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And they take me-- excuse me-- they took me, and I said to myself, he takes me over-- I know, and I know who you are.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I said, sir, what is it?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "You got the wrong-- look, look, my document.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Look, my document.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Here I have a document.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I am Polish Catholic.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Let's go just-- he took me to his-- it's a little-- it's kind of a-- a precinct like you would say.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It must have been a private house there, and it's only Ukrainians.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "They were cooperating with Germans, also going in uniforms, Ukrainian uniforms.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "They don't like it in Ukraine when you tell them here in this country.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I saw marching in the village once, and they were-- well, anyway.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And then I say to myself, Mary, that's the end.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "I wonder what's going to be there with [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "What's going to be end?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Maybe the old lady's going to raise him maybe.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I came in, and I sit, and right way I feel like going to the toilet.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "You know, the nerves.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I took out the-- the ID with my picture there, from the Polish Comitet.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I said, here, here sir, here.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He gave it back to me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "He said, ma'am, there is a  Polish [NON-ENGLISH], like the one when I was standing for bread.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "You remember, I told you she excluded me.",
      "word_count": 8
    }
  ],
