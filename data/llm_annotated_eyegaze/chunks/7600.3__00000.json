{
  "stem": "7600.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--by myself, and I lived at my Uncle Artur's house, who was a dentist.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "He had a very nice apartment, and he had his dentist office in the apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He had two rooms set aside.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "One was the waiting room, and one was the room you went in when he dealt with people.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And he had-- in those days, Vienna, to me, was a big shock.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I had, all my life, my young life, heard about wonderful Vienna.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "My mother played the beautiful songs from Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Vienna, city of my dreams, and the Lehar songs, I knew all of these things.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And I heard so much about Vienna and the beautiful city.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "It was a total shock when I got there, because I thought it was backwards.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I came from a modern industrial town-- city.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And Vienna, for all it's splendor-- and it was beautiful-- it was backwards to me.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "Because my uncle, of course, had a large apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And he had a bathroom, but most people didn't have a bathroom.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "They had to share a toilet with two other tenants on the same floor, or something like that.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And a lot of people didn't have running water in the apartment that I found out.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "I was totally shocked.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "I had never heard of such a thing.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "They also had to share one spigot of a basin outside, like we once-- we finally had an apartment like that.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "Where you went outside, and you had one of these great big pails that you used to fill with water and take it inside so you had for cooking and washing and stuff like that.",
      "word_count": 35
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "But there was no running water.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "Now, he had running water.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "Cold water.",
      "word_count": 2
    }
  ],
