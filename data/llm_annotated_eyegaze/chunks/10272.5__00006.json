{
  "stem": "10272.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "Poli, ?] the leader came out and says, hold it.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "I'm the one who said this.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "But it was not-- we know it's not true, because he just wanted to-- to save from us this trouble of the 10th per-- people to get killed.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "So he said, he stepped out, and then the [?",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Nilosh ?] came with a gun, like this.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And he says, move it, and they took him away.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "He was waving like this, I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "But we never saw him back.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So we were there, in this backyard, after that.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And they told us to line up again, and we are going and moving away.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It was night and cold and it started to rain and-- with snow together like now, this kind of a weather-- sleet and [INAUDIBLE].",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And we went in this rain, get wet and cold.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Don't ask.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And we were going.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So we went for a while, for about 15, 20 minutes.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And they took us inside in the side street.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "There was a-- some kind of a farm was there.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "It was on the outskirts of the city was it.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Some farm.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And we-- we had to go inside.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "In the ground was an opening, like-- like a-- like a-- like a--",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Like a bunker.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Like a cellar.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "But for the summer, the-- the farmer would keep their potatoes stored, you know-- storage thing inside.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But there was no floor there.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "It was wet and mud, and was dripping from-- from the floor and cold.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And the potato was taken out.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We found a few potatoes in-- on the floor.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And this small-- the whole-- the thing was so big like this room.",
      "word_count": 13
    }
  ],
