{
  "stem": "15115.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "[LAUGHS] You know?",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "He was sharp.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "He was a New Yorker, a real character.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "But he thought.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "He says, OK, how much I owe you?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "I says, $32.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "So he gives me $35.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "I work for him.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 33,
      "text": "I made him a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 34,
      "text": "I worked for him for 10 years.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I made him a lot of money.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I bought him a Jaguar, and I sent him to Europe, because I really went into the business.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I was the business already.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "But I was getting paid very well.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "He paid me-- I, when I quit this job in 1961, [PAUSES FOR 3 SECONDS] I was making over $20,000 clear, tax paid, plus all the benefits for the house.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "You know, when I got married, I was working there.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He brought me a dining room set.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He-- you know, he was very good to me.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I made a lot of money there, and I saved it.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "You know, and then I bought a little house on Marquette Street.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And it was very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I worked there for 10 years.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I can see I'm getting big pay, and I'm getting everything.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "But it's no future for me here.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "I'm still going to be a working guy.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And I asked my boss, because I want to open more stores, and I want to go into the wholesale business.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I asked Lou, I says, listen.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Let me buy a half, or let me buy one third-- one third to your son, one third to you, and one third to me.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But I want to have something on paper.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I'm traveling to New York, to Chicago, different places.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Sometimes, you know, your airplane can fall-- fall.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I'm die, what is my kids going to have?",
      "word_count": 10
    }
  ],
