{
  "stem": "27443.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "This was also a good DP place for displaced persons people.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "We lived in Ladispoli a short while.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "And from Ladispoli they transferred us when they called us for our papers to go to Bagnoli.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "Bagnoli is the embarkation center that transferred people to the boat, to Naples.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "We were in Bagnoli in an embarkation center waiting for the boat.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "We went through very rigorous paperwork, investigations.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "Health-wise they checked us by so many doctors, which later we found out that only Jews were interrogated that way.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "Because on the boat that we were on, Marine Jumper, there were a lot of Germans, a lot of non-Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "They never had that problem.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "Only Jewish people had that terrible problem to be interrogated that way.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "But we came.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "After 11 days we arrived to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Very, very good.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "When I learned the language, and I told them that I am ebreo, it means Jewish, they couldn't understand the difference.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And we met a lot of Jews, Italian Jews, that they lived through the war.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They never encountered hardships like we did.",
      "word_count": 7
    }
  ],
