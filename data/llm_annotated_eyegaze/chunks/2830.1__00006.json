{
  "stem": "2830.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "So my sister mentioned that my brother was supposed to, you know, hide out.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "The mayor from the city-- Right.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "--was friendly with him.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what-- maybe he did him favors before-- that he's gonna hide him out.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And she told her where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "She gave her our address.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "She wrote down on a paper where to go and ask if he is still there.",
      "word_count": 16
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "She left, and she came back.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "It was already like nighttime.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And she said, your brother is not there anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "And OK.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "That was Sunday morning.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "We stayed there.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "Sunday-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "That was Sunday night already.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "About-- we went to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "It was some-- on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "We slept on the floor with bugs and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And about 12 o'clock, after 12:00, we heard a knock at the door.",
      "word_count": 13
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And she went.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "She opened the door.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "And three men walked in in, you know, German uniforms.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "And the minute they walked in, we were frightened.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "And then she-- they recognized us.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "They recognized my sister.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "And they didn't said anything.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 12,
      "text": "They-- they just looked.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 13,
      "text": "And my--",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "So my sister said, we can pay you to leave us alone.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "We had money.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] The first thing was said-- she took our things.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "We had nothing, you know, with us.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "She took all her things, and she put on the-- in the barn.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "She hide our things.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "How can we get some things back?",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And then he told her to go and bring the things back.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "By the time he told her to bring things back, he told us, run.",
      "word_count": 14
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "Don't look back.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "He opened the door.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "As fast as you can-- don't ever look back.",
      "word_count": 9
    }
  ],
