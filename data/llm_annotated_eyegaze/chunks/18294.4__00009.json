{
  "stem": "18294.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 242.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We have not a house.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "He has notice his-- his work, he was working, nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "So he was thinking.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Wait, I have a cousin in Australia.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I write to him a letter.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "He write a letter.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Take a month, he sends the visa to come.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In the meantime, it was 1956.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Break-- break of the Sinai, the Sinai War.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So they took him.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Till I saw him back, when he come.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Then he said, whatever it is.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I'm going out.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "We have no connection to going to Melbourne.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "There was the Olympic games.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "So we're going into [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "We had some money.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "We went into [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And we go into a Jewish restaurant.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And he ask him, look, do you have a place?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "He said, yes, I have a boarding house.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "You can stay at my place.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "So he stayed there for a months.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "And this was winter, very cold.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "I said, look, with two small children, you have something to warm up?",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "He said, go in the station.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "And the station is very warm.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "You can warm up there yourself with the kids.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And my husband didn't have any-- he couldn't sit in one place.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "We had some money.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "So he went to the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "He bought some gold for $2,000, gold he brought up.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "He said, with this we're going to Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "And when we come from-- from the-- from-- to Australia, and when we come to Australia-- to Australia, and we have to go the-- the migration office.",
      "word_count": 27
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "He asked him, what do you have?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "He said, what I have?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "I have nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "I have a wife with two children.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 31,
      "text": "Didn't you bring-- nothing, he said I bring nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 32,
      "text": "That's what I have.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 33,
      "text": "He said, you went to the concentration camp through?",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 34,
      "text": "He said, yes.",
      "word_count": 3
    }
  ],
