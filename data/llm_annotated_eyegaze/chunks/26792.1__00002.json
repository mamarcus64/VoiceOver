{
  "stem": "26792.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And-- and she had there a sister and two brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "So they were-- no war victims.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And we were in touch.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "We were in very close touch-- a very loving-- loving family.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish population in Kuldiga was very similar to the German population in Kuldiga because there were fewer Latvians-- natives-- than Jews and Germans.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Actually, it was regarded as a German town.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "For instance, my mother's friend-- lady friends-- were all German.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "German was spoken in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We recited German poems and there was no anti-Semitism on behalf of those Germans living in Kuldiga.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Very friendly, I would say.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "It was a typical provincial life, although it didn't remind me of [NON-ENGLISH] in Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "It was absolutely different.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "People were very cultured, well-bred, educated, I would say.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And led a nice life.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I believe about 300 families.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "About 8,000.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Candles were lit to Erev Shabbat.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "So as I mentioned before, my mother and father went to synagogue, and so did we, the children.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I attended, as well as my sister and brother, a Jewish primary school.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The language-- subjects were taught in German, but we had a Hebrew rabbi who came three times a week and we learned [NON-ENGLISH] and we could make ourselves understood in Old Hebrew.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Mind you, that's a big difference.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Sekunda, Herr Sekunda.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He-- he died here in this country.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "S-E-K-U-N-D-A.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "A former halutz.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, I can.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I can describe it.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, it was a very sad bar mitzvah because my mother gave birth, the same day, to a little boy, who was born-- was premature born.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And this was the reason why the bar mitzvah was celebrated only in synagogue, but not at home.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I remember exactly the day.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    }
  ],
