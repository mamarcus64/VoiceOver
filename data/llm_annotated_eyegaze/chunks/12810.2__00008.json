{
  "stem": "12810.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] And I went to my father place.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "That was oh, so quick!",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "You know, they-- they don't realize that what I doing.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "It was the gates open, and the two soldiers standing, and all the other soldiers around it.",
      "word_count": 17
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No, they can't.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "They have to--",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "To the gate, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "They look after the gate.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "And even that boy, he don't.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Because he have to watch who is going out and who is coming in.",
      "word_count": 14
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "And they-- they don't realize it what I doing.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "It was so quick.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And they just-- a-- a-- a second, and I was out.",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "They even don't-- don't know what's happening.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And I turned straight away to the other street, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "And I was disappearing.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "Nobody came after you?",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "They don't realize it-- I belongs to them-- to they.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "When they are realize it, I was so far away.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "I go to my father.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "How far?",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] About 20 minutes running.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Have no-- every-- when was a-- a--",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "--air raid, that it's everything stopped-- no moving, no-- no horses, nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "Everybody stopped.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "And everybody run to the bunker.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, no, no, nobody was in the street-- no.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I ran to my father, and when they see me, they get the shock in their life.",
      "word_count": 18
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "And [SIGHS] my father said, what-- what you doing here?",
      "word_count": 10
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "What you doing here?",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "I said, I run away.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "He said, but you can't do it.",
      "word_count": 7
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "I have my family, my-- my son, my wife.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "I said, all right, let me sit down and catch my breath, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "Because I was running.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "And then-- He didn't want you to stay?",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
