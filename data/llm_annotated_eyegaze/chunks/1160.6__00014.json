  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "This is my grandfather, my grandmother, my mother, and I am sitting on my mother's lap, my brother, my father, my other brother, my sister.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And that young man is there, my Uncle Moishe.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "This is my aunt on the other end.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And on the other end, my mother's sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "This is my Rosenberg grandmother, my father's-- father's mother.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 6 SECONDS] This is my Aunt Margot, my father's sister.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "She was 21 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "Engaged to be married, but they killed her in Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And this is one of my cousins, this child.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "I don't know her name.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "I don't know which one is it.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "And she was murdered in Auschwitz too.",
      "word_count": 7
    }
  ],
