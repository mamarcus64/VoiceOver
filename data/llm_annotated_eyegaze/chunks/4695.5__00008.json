  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 56,
      "text": "And when I hear that my father comes back 1922, after eight and a  half years, with the hope never war.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 57,
      "text": "Because he passed this.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 58,
      "text": "I come back 1945 with the same hope-- no more-- God forbid, special in this time.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 59,
      "text": "Especially I was afraid not for the illiterate people.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 60,
      "text": "I was afraid for the cultured, [? the revered ?] people, people who give out Wagner.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 61,
      "text": "People who gave us Schiller.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 62,
      "text": "The people who was wrote the Nibelungs.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 63,
      "text": "When they can fall so low and kill children, I don't know what to think.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 64,
      "text": "[PAUSES FOR 4 SECONDS] Only sometimes, I will ask, yes, on my way to-- on my way from, from Amsterdam to Canada, I was on a boat, on the boat And I had a [INAUDIBLE], a philosophical book Spinoza's in my hand-- Baruch Spinoza.",
      "word_count": 44
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 65,
      "text": "You know  the discussion and how he was excommunicated from Jewish life.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 66,
      "text": "I was even in the synagogue [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And across from me sitting by the table was sitting a man-- he, he observed me.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It was a priest, a minister.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He asked me, Baruch Spinoza?",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I told him, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Then he asked me, you are from the survivors?",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I told him, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "He asked my opinion about the Germans .",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I told him, no, I have nothing against the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I do not hate the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Then who?",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I tell him, I will give you only a sample.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "In the history from the Greeks, we have there a little history passed away two people, 5,000, 6,000 years ago, the mythology.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "One was a criminal, a murderer and the other a righteous man.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But according to the law in the heaven, the criminal, he passed away 10 minutes before, 15 minutes before.",
      "word_count": 19
    }
  ],
