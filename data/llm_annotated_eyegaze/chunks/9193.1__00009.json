{
  "stem": "9193.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "Papers came to see me and the Penhaus family.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "I mean, it was-- I was quite famous without knowing it.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, completely-- unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Well, the boat left at night.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "And they begged me and begged me.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And one of the boys said-- from the boat said, look, this is a fantastic offer.",
      "word_count": 16
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "Take it.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "You can come in a fortnight to-- to Shanghai.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "Shanghai doesn't run away.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "And the next day and the day after, the press was coming and going and photographing me.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "And papers were full.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "And you have no idea.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "Telephone was ringing.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 11,
      "text": "And it was unbelievable-- unbelievable.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 12,
      "text": "And I was staying in my separate little house with the two eunuchs.",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Well, the first time, the second time, I went to play tennis.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And-- mo, I was invited-- another young man I knew, who was a far-related cousin of mine saw my picture in the paper in Singapore and rang me at-- Penhaus is the name of the people I stayed with-- and rang me there and said, what are you doing there?",
      "word_count": 50
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't know he was there.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "He didn't know I come-- I emigrated to Shanghai or whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And he said, look, tonight I have a dinner party.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And I need a woman for one single gentleman.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "And well, Abe-- that is the gentleman that took me off the boat; his name was Abe-- was not very keen to let me go to another party.",
      "word_count": 28
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "And he said, all right, I can go.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "I'll take you there, and I pick you up at half past 10.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "So-- [LAUGHS] he took me there to that party.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 8,
      "text": "And this gentleman opposite me was my late husband.",
      "word_count": 9
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "I met him then for the first time.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "He was an engineer and architect.",
      "word_count": 6
    }
  ],
