{
  "stem": "598.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So he made me a receiver, but I had to go to the big town to get the-- alcohol, all kind of good stuff.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "All kind of good stuff for our [? sugar ?] factory.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "So I work-- I was working there in that capacity till '45 in April.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But the director was anti-Semitic.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "You know, tried to-- tried to take advantage of me.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "At that time, they were writing documents, whoever belongs to Poland, they could-- Jewish people and Polish people can go to Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "So I'm registered.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I'm going back to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "At that time, they wanted-- they call me in to go to army again, but I show them I have papers to go to Poland, so they didn't touch me.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I went to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "They give me a machine.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "At the time, I already knew my girl-- my wife.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And it's her mother, and her sister-- they have their belongings.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "They went-- we didn't have a railway station.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "We went 30 miles with the machine, and the let us go to the railway station.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "They threw out all our packages on the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I came in and there was a lot of Polish people going to Poland, too.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "We had to stay waiting for-- for a rail car a month time-- under the blue skies, rain or shine, stay a month time.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "It was still the war in-- in April.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "They didn't let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "The day they finish the war, 8th of May, they give us a-- a rail car.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "They put our package in, and go to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "So we're sitting down.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "We weren't sure, we thought maybe it can go to Siberia, too.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "But I saw the direction, and we went to Poland.",
      "word_count": 10
    }
  ],
