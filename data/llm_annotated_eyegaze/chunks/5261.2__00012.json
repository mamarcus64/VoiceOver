  "elapsed_s": 15.6,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And there was written-- there was the address that the families were writing, for members of soldiers, for friends to ask [? in ?] [? there. ?] I wrote this-- I address this street secretly.",
      "word_count": 35
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I came home.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was fighting with my thought what I have to do.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Maybe I will write to the-- the letter to Willi.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I didn't receive from him.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Maybe he couldn't write.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Maybe I write to him.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "It will be a great pleasure, a great joy to him-- for him.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I did it.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I never forget this letter.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "I wrote in my child meaning.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "It was written, Dear Willi, I miss you very much.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "I-- I never received a letter from you.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "I never go to this place where we were always.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "I-- I am thinking always about you.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "I cannot sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "I prayed for the god that you come healthy again and that we stay together for the whole life.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "Please write me as soon as possible.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I'm so anxious for you.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "I thank you in advance for your letter with many kisses and greetings.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "Yours, this and this.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "And this letter I sent [? stupid ?] with my [? sender. ?] It was also big fighting in my soul whether to put or not to put.",
      "word_count": 28
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "I put it my [? sender. ?] I never received a reply.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "But one day, it was exactly--",
      "word_count": 6
    }
  ],
