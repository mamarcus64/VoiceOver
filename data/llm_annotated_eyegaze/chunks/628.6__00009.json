  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "So I smuggled myself over on the boat from Dieppe to New Haven.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And as you can see, I arrived there.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And the next day, all the newspapers, not only the all the newspapers, was full of me.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And some of them had even said, 'The Wonder Boy.' Because after those-- I was the first one who arrived in England out of a concentration camp, who came there.",
      "word_count": 30
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "They didn't even know about anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "They didn't even hear from Birkenau then.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So that is the-- the-- the story.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They wanted to keep under story, to make a whole thing out of it.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't want to talk.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want to talk.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I kept quiet until now.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, this is the premiere of in March '94.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "As you can see, that to the right, Simon Wiesenthal.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "On-- in the middle, me.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And on the left, my also friend, Max-- Max [?",
