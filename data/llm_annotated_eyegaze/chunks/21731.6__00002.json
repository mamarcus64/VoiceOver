{
  "stem": "21731.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Yes, they started at once looking for me, and couldn't find me.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They knew my false name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I had disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But they got a letter from a priest who was in Auschwitz, that Eva Cernetska was in the camp and killed herself by touching the-- the wires.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "But she never said that she has a son.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Which was no-- nothing special, because nobody said that they had a family.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So Lucia was sure that I'm dead.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And she sent this letter to my husband, who she found in the meantime, and he found her, and so on.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how they did it.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "But he knew that his wife is dead, and no sign of his son, they thought it would be a good idea to bring George to England to give him a good education.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Because Lucia always thought that England, she was a bit of a snob.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "England is the best for education.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I don't agree with her.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "But anyway, so my husband did everything to get the papers for George.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And there was a rabbi Shoenfeld.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "As you must have heard of him, who brought Jewish orphans over.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "But that comes later.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "But I was, in the meantime, in Italy.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I was quite happy.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I had a good job.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "I was very much liked.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "The job was not too-- too heavy, too difficult, rather.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Yan went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "I knew my husband is alive.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "I just wasn't very patient.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "My husband came for two or three weeks, went back.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And then suddenly, I got a visa.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "My husband sent me the tickets, and some postal orders.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "I didn't know what a postal order is.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And I went via Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "I found a friend, a lady, who was called, [NON-ENGLISH], who later came to England, also.",
      "word_count": 16
    }
  ],
