{
  "stem": "7832.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "And there was another door to go up.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "But it was small, and she couldn't fit in there.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "Because the-- the rest of the food was I think on the other side.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "I don't know how she figured it out.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "But she came down with all this food and of course there was a panic down there.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "Everybody wanted food.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "So there wasn't enough for everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "So everybody was trying to get a piece of food.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "So there was a lot of noise, a lot of commotion.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "But they found this other door.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "And it was-- and I was like small so they helped me up there.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "And I went up there, and I was throwing down whatever I can find.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "Potatoes and-- and whatever was there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "I just kept on throwing down that hole.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "Because I knew I couldn't take down enough for everybody.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 46,
      "text": "And there was such a noise going on there already.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 47,
      "text": "They were fighting whatever was down there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 48,
      "text": "I just kept throwing everything down.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 49,
      "text": "And the noise was so bad, the doors opened and they caught me.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 50,
      "text": "They caught me up there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 51,
      "text": "And all these people fighting about the food.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 52,
      "text": "And this Gestapo pulled me off.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 53,
      "text": "He-- he-- you know, from the top.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 54,
      "text": "And he-- I fell down from the second floor down on the-- but it was snow.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 55,
      "text": "So, you know, And he hit me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 56,
      "text": "I still have a mark today on my head.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 57,
      "text": "He hit me.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 58,
      "text": "He beat me up so bad with the back of his rifle.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 59,
      "text": "And my head-- my head was bleeding.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 60,
      "text": "It was the middle of the night.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 61,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 62,
      "text": "It was freezing, and left me there to die.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 63,
      "text": "And he says to me, [SPEAKING GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 64,
      "text": "And he walked away.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 65,
      "text": "And that's all I remember.",
      "word_count": 5
    }
  ],
