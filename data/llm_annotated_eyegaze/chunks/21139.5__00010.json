  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes I fasted on a day.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I had no idea was it the day or not.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I felt it must have been about that time.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "But we were deported.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "It was the last days of Sukkot.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And so I knew before that was Yom Kippur, you know, a week before and-- and Rosh Hashanah, so approximately.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "No, I never knew until I came to England.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "It was always with me.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I never lost it completely.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And I-- how shall I say, I could not observe the way I was taught at home because I was in training, and I was the only Jewish girl there.",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "My brother [?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Siggy ?] was in a Jewish-- in that home that was all Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They were not very observant.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "They did observe some of the holidays and-- but it was not-- it's only-- actually, I would say, I observe properly again when I got married.",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    }
  ],
