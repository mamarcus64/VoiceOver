{
  "stem": "428.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And I came to Poland and I find out that my family is completely gone.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And my-- my parents, nobody knows where they took them.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I think they were Treblinka, a camp where they used to take the people and kill them there.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "My sister, she no want to live her-- her husband's parents, and she went with them.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My brother, they told me, I find-- I find a-- a man from the other town, Gorlitz, he was with my brother to the last time in-- how do you call that camp?",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I forgot the camp already.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So three days after the war, he died.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "When the war was finished, he was very hungry, and then he started to eat and he got Typhus.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And he died three days after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I came to that little town where I was born, and it was a family they was hiding by Polish people during the war.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "The family that you were--",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "That lives already, after the war they was already in that town.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Because it was only two Jewish families, what they came back already before me.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Well, they lived through that war.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "The war was finished, and they came back to that town.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "She just died in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I came to her, and it start already, she gave me.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I met there a few people.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I have them on the pictures over here.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And I was by her and she gave me to eat and things like this.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And I was by her about two weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And-- I, with another friend, I have them over here now by the name Getz-- Getz.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And we smuggled again.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "He had in Czechoslovakia, he has an aunt Bardejov-- in Bardejov, Czechoslovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And we smuggled to that Czechoslovakia again.",
      "word_count": 7
    }
  ],
