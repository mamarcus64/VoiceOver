{
  "stem": "7414.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "So when we come to the Schupo, they really loaded us on a truck.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "Chained.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "With the baby.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Now they gave me the baby back.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They put us on a truck.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And they took us to [POLISH] Avenue, which was a notorious place in Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Even Poles rarely came out from there.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] They took us to the fifth-- fifth floor to a room that was a waiting room.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "So there was standing my sister, my brother-in-law, their niece, who was by then 13 years old, the Prowiszaks, and the-- I with the baby.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And in come a German, the chief of this that was the-- apparently the Jewish-- this-- Department of the Gestapo, and a Pole, which was not in uniform.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "He was his right hand, the Pole.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "They looked-- oh, brother-in-law.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "A man, you know, you can't deny that a-- a man can't deny that he's a Jew.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "You see, he had his trousers down, and that was that.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "So he took my-- him and my sister and the niece to the other room for interrogation.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And we were standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Ah!",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And he approached me.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "He approached me, the German.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "He started to measure my head.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "He started to look at the lobe of my ear.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And then he pronounced that I am Aryan.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "That I am not Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So the Pole, they knew better their Jews, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He looked at me and he thought he wants to interrogate me.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So he got angry, the-- the German.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "He told me, I give my head that she is not Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So they took my sister and her family to the next room.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "We were standing so next to the wall.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And we could hear everything, what is happening there.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Every blow, every scream.",
      "word_count": 4
    }
  ],
