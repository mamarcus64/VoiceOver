{
  "stem": "769.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK, my name is Peretz David Rotenberg.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "In the home, they called me Peretz, and in the street between friends, they called me David Rotenberg.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "So I got two names.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I am born in Ciechanow, 1912, the 17 of August.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And-- I am born by parents, where there is merchant, middle-class people.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My father was always a merchant, grain merchant they called this, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And lots of Jewish people make their living from this one.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They buy it all grains when the farmers came from the farms.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "They bring grains to the market.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my father went around, you know, and touched the grain-- but then he ordered it bad.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "It have to be dry, you know, because with some farmers, they cut them outside.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They went wet, so they had the kilo wet, and when there is dry, it adds three quarter of a kilo.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "So my father know what kind is good and what not.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "They send the grain to the mills, and the mills paid my father plus percentage, the difference, how much is the market.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "If the market, let me say, is about a kilo $2, or 2 zlotys like that, and my father buys them from the farmer for a $1.80-- each one is then my father got plus commission extra.",
      "word_count": 37
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "So he makes a living from this one.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "Since the-- in Poland, started to go around like buyer, but Polaks only.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "So the farmers, they had got instructions from the church, and I'm saying from the church really, and from the city government, not to say too much to the Jews.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "So the market started to go around a lot of Christians.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "They sold them, then another one at the sale, to the Jewish people.",
      "word_count": 13
    }
  ],
