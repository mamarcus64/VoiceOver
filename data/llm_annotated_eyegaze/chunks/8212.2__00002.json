{
  "stem": "8212.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And we got to Brussels, and we immediately went to where we knew my aunt was, and we stayed there for a day or so-- for a day or two.",
      "word_count": 30
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And then, already, there sprung up a lot of committees in all those places like Brussel, Antwerp, that helped people like us, because this is a country where we were not expected, and we-- we are not allowed to work or anything.",
      "word_count": 42
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "So they gave people like us a little bit of money to be able to exist in that time.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And we just lived in one room.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Suddenly, coming from Vienna, the whole family just lived in one room.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "We cooked in that room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "We washed in the room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "We slept in that room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "We didn't have a lot of money, but my mother somehow managed to feed us.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "But I remember that she bought always one-day-old bread because it was cheaper, and all kinds of odd meats because it was cheap.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "But she managed to feed us.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "My sister and I went immediately to a school and learned French very, very fast because we started talking to each other.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And my parents-- there was another family living on the same floor-- were working during the night sewing Belgian slippers, which still exists.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "The Boucherie, they're the best slippers in the world.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "They're very expensive.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "They are sewn by hand, and I know they're sewn by hand.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "They were not allowed to work, so they worked at night to make a little extra money.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And life was whatever it was.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "We went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "And we were there from 1939 'til 1940.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "In 1940, the war started.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "The war with-- first, the Germans attacked Czechoslovakia and Poland.",
      "word_count": 10
    }
  ],
