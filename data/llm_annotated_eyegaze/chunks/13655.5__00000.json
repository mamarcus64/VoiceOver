{
  "stem": "13655.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah--",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I went to Konstantynow because I didn't have the guts to go back to Miedzyrzec.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I knew I have a few people from my family-- nieces and a nephew.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "What I couldn't-- I make my decision to go to Konstantynow.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "It was very hard to go there.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I almost lost my life there.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "But I came back a few days later.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I went in under that attic, where I left them.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The nieces, with my nephew.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They all had frozen feet.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was Esther Hofman-- no, Silverman.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Chana and Esther Goldring, Moishe [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Rosin-- oh, my God.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Rosinger-- ?]",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Only Chana is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "She survived on the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "She was in Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "She was all over.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They were crying.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They were happy to see me back, because they was outlaws.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "But they opened up the ghetto two days later.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "They were in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "They were sitting all winter till Pesach.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In 1943, in a small room, very bad, no food.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "But I had to go every couple days to buy, sell something, [NON-ENGLISH], go to outside of the ghetto and bring in a piece of bread or potatoes.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "So you were helpful to supply food?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was a father from five children.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "There was nobody to supply to them.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "There was no help.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "What happened then?",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And what was the situation in the ghetto?",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto was-- they was predicting-- that time, they was predicting [INAUDIBLE] maybe they're going to leave us.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Maybe not.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Maybe this, maybe that-- all kind of stories.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "It was typhus, sickness.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It was destruction, everything, you name it.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "What everybody was thinking, how can I get such a luxury [INAUDIBLE] [? death ?], like [INAUDIBLE], or the [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I cannot-- [INAUDIBLE] I cannot die.",
      "word_count": 6
    }
  ],
