{
  "stem": "159.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And, and then the factory went on strike for 90 days.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And that was very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "That time, I got pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "I had a little boy and--",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "He was born in 1950, February 23, a day after Washington's birthday.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And I got very sick because, apparently, the doctors didn't do such a good job on me.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And I had the best doctor, Jewish doctor, but I hemorrhaged a lot.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And I was laying in blood, like in a bathtub up to my neck.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And my neighbors came up and put the chairs under the bed.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "I should lay with my feet up high.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "Then, the doctor came, and he gave me shots.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And so everything should come out.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "For a whole year, I had to go for shots, iron shots.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "And I had to drink Ovaltine.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And the first three months, I didn't handle the baby because I was too weak.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "So my husband took care of him.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "And after that, I was OK.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "After Detroit, my neighbor was going in-- he had a friend living in Los Angeles.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And he wrote to him that the climate is so good, you can get work, why he doesn't come here.",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in the same building, so he talked me into come, too.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And we already had a nice furnished apartment and friends, and, and I decided.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I said, OK, a better climate, we'll go because the winters were very hard.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "By the time you dressed up, you had to go back up to the room.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So I said, OK, we'll go with you.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "So, one day, my husband comes home from work.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And I sold all the furniture.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And he had no place where to sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "I sold the bed, too.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And I said, we're going.",
      "word_count": 5
    }
  ],
