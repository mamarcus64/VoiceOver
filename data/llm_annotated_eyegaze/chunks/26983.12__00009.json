{
  "stem": "26983.12",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 66.6,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "We were the very first real repatriation--",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Refugees and children.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "So these few days, we were staying in a Czech family, [INAUDIBLE], I remember was the name.",
      "word_count": 17
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Well, from the Czech consul, most probably they gave us this address.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Must have been because they were--",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And we came to Prague in the early morning, my friend and I.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, on these lorries.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "They were not trains.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They were not trains.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "And we didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "But my friend was from Prague, so we went to the Jewish community in the Meisel, street number 18.",
      "word_count": 19
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "There was nothing prepared for the children.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "These people came, were liberated recently from Theresienstadt.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And they just rebuilt or reorganized the life of the Jewish community, whatever was left.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "There were no children from the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "They were the first refugees coming from Theresienstadt or from other camps.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And here, we have been the first children.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No one to take care for children.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "We asked, what shall we do?",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "So they told us, we have nothing ready.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "We just arrived ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "But there is one man, a wonderful Czech, who thought about it, that you children come back.",
      "word_count": 17
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And he has a kind of home-- recreation home for children.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And you will go there.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "And he will take care of you.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "And so it was.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "And this man was one of the most extraordinary men I-- well, in modern term.",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "You would call him angel, who helped us enormously.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "His name was Premysl Peter.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Premysl Peter in Czech.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And he was a social worker who was very well known in Prague.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Not Jewish.",
      "word_count": 2
    }
  ],
