{
  "stem": "18397.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They are two, and I am one, and nobody else on the streets.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So I figure, that's it, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "They're not going to wait for me, they'll see with a guy.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "So I figure, it's no good.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But what do I got to lose?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "I took my gun out, I-- I put them in the pocket.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "I had a-- I had a jacket, you know, like we were in the city.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "This we didn't wear in the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And I figure, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "But I know what I'm going to do.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And they don't know yet what-- what to expect.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And I went on the other side, and they smacked a [LAUGHS] [INAUDIBLE] right between the [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "Cops smell that good?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And they say to me, [NON-ENGLISH], I figure, that's it.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Nobody there.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And you know what?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "The worst thing is when you've got one by yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "You know, when you have to go like, die or something.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "When you're by yourself it's a very feeling, you got tense, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "And this is-- [? you see it. ?] You know, they're professionals.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "But they went and then, and they light me in the eyes.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "And they say, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "[NON-ENGLISH] means, excuse me?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Maybe they had a feeling.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was ready.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I went over, and this was a fence.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "It was a 6 foot, maybe 6 and 1/2.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I was so excited, I jumped it over.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "You know, like-- like.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "That was-- you had a feeling.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You get-- you get excited.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "But by yourself, it's way bad, you know, to take a chance like this.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Or you're going out, and dead, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "That's what happened.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "I jumped over the fence again.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And then-- then-- I could stay over there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "They asked me to say, you know.",
      "word_count": 7
    }
  ],
