  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't have even sign their names, a lot of them.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And when you haven't got educated, and you have a choice in a poor situation to get something for nothing of this--",
      "word_count": 22
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Of course I know a lot of names.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I don't know if I have still-- I still have a little paper from when I moved to my farm-- from my farm they gave me, because they made me to move somewhere else when the Russians came in, after I was liberated from the Germans.",
      "word_count": 51
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "How much land they had, and a sample from the city in that time, like over here, the mayor was a-- lord and a mayor.",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Yes, of course.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "At that time, about seven acres or something.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Not 15 acres.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I have a lot of names at that time, because I was a Jew, and they were Ukrainian animals-- you  know, enemies and animals too.",
      "word_count": 25
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Their nature was animals-- some of them, not all of them.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They did what they could.",
      "word_count": 5
    }
  ],
