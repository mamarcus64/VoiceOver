{
  "stem": "24106.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We came right after Thanksgiving in 1949.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We were with-- on a boat for about 11 days.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Sick, sick, sick.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I-- I was one of them.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Couldn't eat.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Couldn't look at food.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "But I lived on-- on grapefruit.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't know about grapefruit like-- like orange, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "It was good food, but I couldn't-- who could eat?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Everybody was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Did you have other children?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I went-- yeah. 19-- 1953, my youngest son was born, Henry.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He was born in America.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, my husband-- he was a [NON-ENGLISH], like I told you.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "He got right away got a position.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "His first position was on Vermont Street.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That was in east New York.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And they paid him pretty good.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And from then on, he was more well known, everything.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "But I want to tell you about my first apartment when we came to America.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "It was in Brownsville, on 27 Bristol Street.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "We lived in Brownsville for eight years.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "It was hard.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "Nobody supported us.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "Nobody gave us anything.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I could not work, because I have to take care of the first, the child, then the children.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I could not work.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, now?",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Now I'm-- I call myself, like, a society lady.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Not exactly.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Well, I'm a volunteer, first of all, in this building.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "In this building, I live 14 years.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And I think-- that's the best thing that could happen with me.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "It's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I have a lot of friends.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "I'm active.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "I'm the-- the treasurer of the tenants association.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And I take care on a lot of things.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "And this really keeps me going.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "I'm always busy.",
      "word_count": 3
    }
  ],
