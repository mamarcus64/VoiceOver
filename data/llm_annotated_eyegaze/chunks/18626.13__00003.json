{
  "stem": "18626.13",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 91.1,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "We send it-- we got to send it to New York and wait three weeks for that piece of wood.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "Everybody looks out for themself.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "If he gets a [INAUDIBLE] woodturner here in Miami, he wouldn't have to send it to New York and wait two weeks.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "So the five or 10 cabinetmakers promised me there was so much work.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "There was almost no work at all.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "But I took a job.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "And little by little, I start to go around shops, you know, to show my work.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "Found a couple of other cabinet shops.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "But it was still not enough to make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "Then I-- I was-- I met my wife on the beach.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "And we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "And I had a child.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "And I need money.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "And couldn't make a living here in Miami.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "All tourists.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "It's not like now.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "It's got industry and Hialeah factories with all the things.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So one day, a lady came in-- in the shop, which I made a little shop I had in Florida.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Made in a small, little place.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "A lady came in.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "She said, can you turn me out lawn mower rollers for my old lawn mower?",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "The old lawn mower used to have wooden rollers underneath.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Now they don't have that.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The old lawn mowers used to have-- each lawn mower had four or five wooden rollers.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "With the rollers--",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I want to show you there, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The rollers-- the lawn mower repair people needed-- they used to get them from New York and pay $0.50 apiece.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So I'll make it-- the-- for the lady.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I made her the five rollers.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And I charged her a couple of dollars.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And I used good wood, you know, maple out to make the rollers.",
      "word_count": 13
    }
  ],
