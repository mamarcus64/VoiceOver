  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They would make, make up a nice meal for us, prepare it.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And I see one man is going out from the, from, from their, from their home.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Their house.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Half an hour later, he comes back.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He, he, he got a-- a collection outside for the-- the people.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And they give it to us, a few ruble, a few zloty, they give it to us.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And [? already ?] 2 o'clock, 3 o'clock, we have to go back, because take a while till we come back there.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "One man stood up and he's like that.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Kill them.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Get out from here, like that.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "You'll get lost here.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "It's not your work.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "Work in the forest, cut trees.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "You will try this.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "You [? will try it ?].",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "You [? go to the town ?].",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "You will be people-- like people, not like, like that.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "You will get lost.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "Kill the-- I warn you.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "Get out from here.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "Get out.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "I say, if a Russian man say to me like that, must be something wrong.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "Must be something good.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "When we come home, next day, two days later, we already, a few kolkhoz is already empty.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "More people, they're already gone.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "I tell the [INAUDIBLE] we have to go.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "We have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "I took our little bundle [NON-ENGLISH] what we have.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "The little trousers, and dresses, everything we have.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "Went to the station.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "We come to Vitebsk.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "Big town, Vitebsk.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "I went straight to the government office, straight to the, to the city council, or something like that.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "I knew already what people was coming from.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "They give it to me, a paper, a recommendation to get work, and to get-- get place to live.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "I've got, still, the paper here somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "I got it, still, the paper.",
      "word_count": 6
    }
  ],
