  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Because I didn't have people that are alive and strong enough to cut my leg off, or cut my buttock off, or cut my arm off.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I thought they only ate the--",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No, dead carcasses?",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Why should they eat the dead when the could eat alive?",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, I guess the dead have no blood in them, have no warmth in them, where the live ones still have warmth.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I mean, there's a lot of explanations that you could give.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] So, what I decided-- what I decided right after the war, I'll go back home.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I don't believe that everybody is dead.",
      "word_count": 7
    }
  ],
