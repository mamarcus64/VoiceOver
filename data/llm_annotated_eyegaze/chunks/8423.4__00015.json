  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And sure enough, they picked me to come work in the kitchen, which is partially responsible-- a good-- good part of the stay over there is part of-- you know, responsible for my survival, because I had more food in the kitchen than the people that went to work.",
      "word_count": 49
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "Besides I wouldn't have lasted a month, because in the dead of winter, they had to walk miles, like eight, 10 miles to work for the factories, depending which factories they were in.",
      "word_count": 33
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And they would come back every night, looking just like aluminium robot.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Their entire face was aluminum.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "All you could see is just the inside of their eyes and the inside of their mouth.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "Everything else was covered in aluminum.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "The aluminum dust covered them completely.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And there was no way to even wash it off.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "It just didn't come off, that stuff.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "It got into their pores and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] No.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We were both very fortunate.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We both went to work in the kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "She worked in the part of the kitchen which they called the [INAUDIBLE], where they peel the vegetables for the Germans's meal.",
      "word_count": 22
    }
  ],
