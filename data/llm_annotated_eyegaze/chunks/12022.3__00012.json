  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 38,
      "text": "And my brother was drying the-- the socks.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 39,
      "text": "We was wondering all night by the fire.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 40,
      "text": "When you start to give him hell with the language, that's a real language.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 41,
      "text": "And my brother don't answer anything.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 42,
      "text": "And I laying [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 43,
      "text": "That's shaken me.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 44,
      "text": "That kind of language for what, I think.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 45,
      "text": "Why we brought the two people.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 46,
      "text": "And they've been Communist, them two-- two people, because they are Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 47,
      "text": "And I see her swearing on-- on my brother with all kinds rough-- and my mother, mother, mother.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 48,
      "text": "And answer them.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 49,
      "text": "They said to him, you better shut up.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 50,
      "text": "And I told him the same thing.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 51,
      "text": "I-- he get same lesson.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 52,
      "text": "But I have [INAUDIBLE] took out the pistol.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 53,
      "text": "And I said, I'm pretty good at target.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 54,
      "text": "I said, don't think I'll make a mistakes, too.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 55,
      "text": "If you want to try it out, let's try it out.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 56,
      "text": "We'll find out.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 57,
      "text": "Finally, he said, I'm-- it's not going anywhere.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 58,
      "text": "And finally, they went back.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 59,
      "text": "And then, already, they-- I wasn't belonging to the Communist party.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 60,
      "text": "It's such a long story.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
