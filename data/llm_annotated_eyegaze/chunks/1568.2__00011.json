    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But anyway, I went to Belmont High School, which was on Beverly Boulevard, for half a day.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I went to work the other half a day.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I worked in a knitting factory again.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "My job was to make big rolls of wool, and I would put it through a steam press that would shrink it.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So I put the roll in one end and took it out the other end.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Very hard work.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I-- Vista Del Mar found a room for me.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "How they found a room, Morris Pearl had an aunt here.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "The aunt knew a lady named [?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Sarah ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Rubenstein ?] who was not economically well-off-- had a big house of the other rooms, rented out a room.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And Sam Steinberg rented a room by Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "Rubenstein. ?] Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "Rubenstein ?] had two kids.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "One, a daughter named Selma [PAUSES FOR 3 SECONDS] [SIGHS] and one, a boy named [?",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "Maxy ?] who was six years younger than Selma.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
