{
  "stem": "7777.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 95,
      "text": "Is I went to work for this Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 96,
      "text": "Robinson.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 97,
      "text": "And when I was not working, I went over there-- I lived with my cousin in Chicago-- was a little park, was Wicker Park, was over there.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 98,
      "text": "A man, he walked the next street.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 99,
      "text": "And in the night, I saw him in the park.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 100,
      "text": "When I went to take the job by this Robinson, I know all he will pay me $30 a week or 35.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 101,
      "text": "And in Germany, it was possible to make $35 in half an hour.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 102,
      "text": "Only he told me-- he knocked me in my neck-- you will make a living already.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 103,
      "text": "When I go to this guy Robinson.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 104,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 105,
      "text": "I work with this Robinson, and '48, my son got born.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 106,
      "text": "I said, Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 107,
      "text": "Robinson, my family got bigger.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 108,
      "text": "Maybe you can give me a raise.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 109,
      "text": "He said, in three months later, I'll give you a raise.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 110,
      "text": "All I got little bit money from Germany, was not enough, $35 to live.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 111,
      "text": "My cousin give me the apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 112,
      "text": "I don't pay.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 113,
      "text": "Only we got little bit money-- we used up little bit money.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 114,
      "text": "After being-- [COUGHS] After being 22 months work for Robinson, he start to give me already a raise.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 115,
      "text": "He comed up already to $70 a week.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 116,
      "text": "This was in '49.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 117,
      "text": "Meantime-- [COUGHS] Excuse me.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 118,
      "text": "My cousin have a candy store, and I live behind the candy store.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 119,
      "text": "He told me not too far from him is for sale a candy store, a good candy store.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 120,
      "text": "If he go in with his son-- he have a son Alex-- he can do over there-- he did about $600, $700 a week business.",
      "word_count": 25
    }
  ],
