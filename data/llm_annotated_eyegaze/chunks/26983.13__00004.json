{
  "stem": "26983.13",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Not only the same camp, in the same block, in the same [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And all of them had typhoid.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "They survived the typhoid.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But this block didn't get any more food.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And they let them die.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "This woman's sister died.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And then my sister died.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And then my mother died.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And she told me exactly the date and how it happened, and all the details.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "So I knew-- I know now exactly--",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "This one woman survived and lives today in Jerusalem.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "She knew them because she was from the same surroundings and so on.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "She was looking for me.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "A little-- to illustrate it, when I had bar mitzvah, it was still in Ostrava, '42, just before the deportation.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "She brought me a little Bible, and wrote a dedication in Israel, for my brother, to his bar mitzvah.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And later, in the beginning of '46, in March, April, '46 when I arrived, she gave it to me.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "So this Bible I carry and I have it with me.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And the other Bible, which I [INAUDIBLE] from the ghetto [INAUDIBLE], from Theresienstadt, I still carry with me.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I have with me.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It's an Old and New one.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do remember.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We arrived in-- just after Pesach.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It happened at Erev Pesach.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We left Marce.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I mean, we went through from Prague.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "My friend left earlier and went to London, where Claude Montefiore took care for a group of children, for orphans and so on.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And he went to London, where he studied mainly religious subject.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Because he came from a family of rabbis--",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And he wanted to be a rabbi.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And he became a chief rabbi of Ashdod later on.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And he wrote a book about it.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "The whole time, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I came  with Youth Aliyah.",
      "word_count": 5
    }
  ],
