{
  "stem": "232.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "We were standing there while S men-- SS men came.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "He said to us, do you feel good?",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Does anybody feel sick or something?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "My friend's father says he doesn't feel too good.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "He had two surgeries.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "He says, OK, you go with the women and men.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "They went straight to the gas, what we found out.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Straight from there, they went into the gas chambers.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We-- we were left 13 men.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We were chosen to go into the camp for work.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So [PAUSES FOR 3 SECONDS] we came in.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "We came into a barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "We had to undress completely, were shoven-- shoven hair, under arm, wherever there is-- we were shoven.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And those people who did the hair cuts to us told us right away.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "You see, you see-- we saw the chimney.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We saw through the window big chimneys with big-- big buildings with chimneys, and was a lot of smoke coming out.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They says, you see, this is where your-- your your people are coming out now.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We-- we thought as a joke, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "He said-- I said, what do you mean?",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They went to the other barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "No, they went to the gas chambers, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "At this moment, everybody realized we were in Auschwitz, in the death camp.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "So when we were shoven, we were put in from one back to the other to go to a shower.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "We went to the shower.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "We came out-- we left out our clothes, our shoes and pants.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Everything was left.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "We got into the next barrack, and we came out prisoners in-- in stripes.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We were put into a quarantine for four weeks, where we worked inside the camp.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Then we did-- after this, we are put in-- a-- in-- this was Birkenau.",
      "word_count": 14
    }
  ],
