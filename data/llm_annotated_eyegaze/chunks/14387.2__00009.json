{
  "stem": "14387.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He didn't want to carry it because we had all our valuables tied to our bodies, so he gave them to us for safe keeping.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "So we were with Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Lindstrom when we came to Japan-- [PAUSES FOR 4 SECONDS] I'm trying to get this all straightened out.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "So we got on the-- we got on the train into Tokyo, that's it.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "We got on the train, and we went into Tokyo.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And they made us put the buggy in the cargo compartment.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And when we got to Tokyo my husband had to go and retrieve the buggy, so we were-- Mr.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Lindstrom and the baby and myself, we were standing on the platform, and it was terribly, terribly windy.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "So my husband said, you go into the waiting room, and I'll go get the buggy.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "But we had the luggage standing there, and my husband said to Mr.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "Lindstrom, you stay here with the luggage and don't move.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "Don't go anywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "He said, you wait here until I come back.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And then my husband came into the waiting room.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "He said, well, where's Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "Lindstrom?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "He said, isn't Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "Lindstrom here?",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "I said, no, you left him on the platform.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "Well, he said, he isn't there.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "There's no luggage, and there's no Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "Lindstrom.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "So we were running around the Tokyo airport there-- train station, I mean.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "Tokyo train station looking for Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "Lindstrom, and he was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "In those days, the Japanese didn't speak English.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "They finally found someone who said, yes, he'd seen a white man getting on another train.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "Where's that train going?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "It was going up to Yokohama.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "So they called Yokohama, and Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "Lindstrom was at Yokohama.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "My husband spoke to him on the phone.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "He said, what happened to you?",
      "word_count": 6
    }
  ],
