  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So they shot him in the bed.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Yes, a lot of people die in the ghetto, a lot of people.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Sure, we saw that.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "We took a horse and buggy.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We took the dead body on a horse and buggy.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Everybody can see it, sure.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And lot of people died, too, from starvation, not enough food.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "For some, yes, and for some, no.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "We had bread.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "With that bread what they give us, we can build, we can put the bricks.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "That bread was like a clay.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "That was not white.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "That was a brown, brown, dark brown.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "Because they didn't put no wheat, no nothing, just the lowest what can ever be.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "That's what the horses probably eat, because we never saw white bread or any even close to white, just dark brown bread.",
      "word_count": 22
    }
  ],
