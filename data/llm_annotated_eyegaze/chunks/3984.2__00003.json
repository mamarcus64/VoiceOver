{
  "stem": "3984.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "But it was very bad situation, because the old man was talking for himself.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He was drinking.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And I was all the time afraid that-- she-- you know, I was a little girl alone with him in the other room.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "It was two rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I have another room.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Even I clothe myself-- I clothe, I can clothe myself.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "I cannot be over there.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "So the [? gentle ?] come all the time, to see what going on.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Hey, after two, three, three days, he came to see-- because the people was working over there.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And I told I, I, I cannot be afraid.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "I afraid.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "So they take me again, over there.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "When I came back, I feel a little better.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Because I don't afraid from the old man.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And I feel a little better that I can-- I am near to my family.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So this is went through about until my-- my family moved to, to ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It is almost a year.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And it was terrible, terrible, terrible-- a very bad situation.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was sad.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I cannot eat.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And the woman was very nice to me.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "She bring me food, and to drink, and to do everything, because she loved me.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "She want to save me.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And I told her, you make me a very nice job, but I love my mother.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I love my sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And want-- And they told, listen, Gizella-- she spoke with me in Hungarian.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "We try to save you.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "When everything is go over, you can go to back to your mommy.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "But it is-- you know, for a child to be alone all the time, with only your mind, and to-- to get-- only you know that your mommy's over there, five minute from me.",
      "word_count": 34
    }
  ],
