{
  "stem": "16922.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 536.3,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And he didn't send for my father.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "But my father moved away, ran away from Rabka.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "He went to his sister to [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And they killed him there.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "They-- all the-- all the Polacks [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And they say, [NON-ENGLISH], all the Jew they took to Bobowa.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they killed in Bobowa all the Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They make a mass grave, a mass grave.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "In Bobowa.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I don't know when.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "No, the Germans.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I remained in Rabka with my mother and sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "My sisters were working in Gestapo.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And I was working also.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And we wait till that one evening, they came, tomorrow, we have to-- people-- my mother has to go.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "They killed them all.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "So I said to my mother, why you should go away?",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "We ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "All of us ran away from Rabka.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "And they were looking for us.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "They couldn't find us, because we, we didn't went together.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "Everybody went in different direction.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "I had a sister.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "She's still-- I don't know what happened to her.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 13,
      "text": "She-- they probably killed her.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Necha.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "It was my home, but a ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "They close up the street.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We have to go out from 3:00 to-- no, from 3:00 to 4:00, or 4:00 to 5:00.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And if we need something we have to go out in this time, just small city.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "No, this a-- this was a country.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] It was beautiful there.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Not nice.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, no wire.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "No wire.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] We never went away.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "From the Gestapo-- no, I don't know from, the Gestapo or from the Judenrat, I don't know.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] We know about-- they were talking about all the children, hear about this in the Gestapo.",
      "word_count": 20
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "They were working there.",
      "word_count": 4
    }
  ],
