{
  "stem": "18626.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 36.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Because it was rumored that a lot of the Jews were caught, and they were digging, you know, [?sod?] you know, like we are putting on the lawn, here in, this in Miami, these were digging [? sod ?] in a small little town out of Kaunas called [INAUDIBLE].",
      "word_count": 49
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It was just a rumor.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And there's a lot of Jews working there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "See that, they grabbed a lot of Jews from the rail-- railroad station, and they took them to [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "So I thought my father was in [INAUDIBLE] too, and he is going to come any day home.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And till then, even till the ghetto, I used to climb up on the second floor and look and see if my father's coming back.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I can never forget that.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, not till we went into the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Because a lot of the rabbis and big leaders were already taken to the forts too, to the fortress, you know, to be killed.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "They took-- the real leadership and educated Jews were taken in, [PAUSES FOR 4 SECONDS] were taken away when the ghetto was closed.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Then they could really surround them, [PAUSES FOR 4 SECONDS] you understand?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "When the ghetto was closed, when the ghetto was closed, August 17th, 1941.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto was closed August 17th, 1941.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The ghetto was closed, with-- with the-- with all the wires and everything.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Then the Germans gave an order-- there was already Jewish committee in the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in June--",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "August the 15th.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was already they start to grab Jews, to dig holes and start building the fences around a certain neighborhood where the ghetto was established to being made.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The Germans already and the Lithuanians all together start to lay out.",
      "word_count": 12
    }
  ],
