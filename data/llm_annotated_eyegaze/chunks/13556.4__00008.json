{
  "stem": "13556.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 14,
      "text": "And this is because the policy in this time was a very tough to get a steady job.",
      "word_count": 18
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 15,
      "text": "And what happened, happened was my sister was already here.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 16,
      "text": "And we sent her a letter.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 17,
      "text": "And I told my wife, I feel we'll never go to Canada.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 18,
      "text": "Something opportunity will be for us.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 19,
      "text": "We have no chances.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 20,
      "text": "We have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 21,
      "text": "We're poor people.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 22,
      "text": "What we make, we spend for food.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 23,
      "text": "I don't believe to save money for stomach.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 24,
      "text": "And my child's supposed to have what I-- he needed every day.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 25,
      "text": "And I don't drink, I don't smoke, and my wife the same thing.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 26,
      "text": "And we just break even with the money what we, we made.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 27,
      "text": "And this why we decided to leave Israel, why--",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "--with work is very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And my wife was teaching.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And was-- they considered her a very good teacher.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And your money was-- teachers, at this time, received very little, similar what I received, like, a worker, same money.",
      "word_count": 20
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I didn't like to leave the country.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "I liked very much Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I have no choice.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have a choice.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "My sister sponsored me to Canada.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 8,
      "text": "And I came to Canada to prepare a little bit for my-- which I borrowed money to get a ticket.",
      "word_count": 20
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 9,
      "text": "I didn't have money for a ticket.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I arrived in Canada in 1964.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I came by myself.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I-- we didn't have money.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I borrowed money for ticket for myself.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And then I was working hard to--",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I was welding.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I received minimum wage.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know the language.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And these people, where they could understand to speak German, or Polish, Ukrainian, or Jewish, then they used me, and I received minimum wage.",
      "word_count": 24
    }
  ],
