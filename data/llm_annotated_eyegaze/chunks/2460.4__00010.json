  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 58,
      "text": "So in the evening, I made plans already, if something happens, I can climb through those beams that are holding the barracks together to jump out of the window.",
      "word_count": 29
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 59,
      "text": "It was claustrophobic.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 60,
      "text": "I didn't know what it-- I didn't know the word 'claustrophobia.'",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I just felt it, that I don't want to be in this barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Later on we found out that the intention was to pour some liquid into those channels and to burn those three or four barracks.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how many were-- maybe they were more.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I remember only three or four.",
      "word_count": 6
    }
  ],
