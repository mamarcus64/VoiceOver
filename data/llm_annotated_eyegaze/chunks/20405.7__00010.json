{
  "stem": "20405.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And we went over there I think to a bar mitzvah or to-- [PAUSES FOR 4 SECONDS] what was it?",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Anniversary or a big party, because in Israel they do big parties, beautiful.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I went with my sister, my brother-in-law, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I start walking to go in the-- the room over there, the ball room.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "At the-- of course, I saw a few people, which they knew me from [INAUDIBLE] years, which most of them I recognize.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Most of them I didn't recognize, but they recognize me.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "So I was ready to go into the room.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And two guys standing over there, Venezia, Venezia, calling.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I look at them.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "You don't know-- you don't know us?",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Maybe somebody from [INAUDIBLE] years.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "Do you remember that night, they said, when that guy, the SS came looking for Sonderkommando and you laid down and we sit down on top of you?",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "I could believe it, Carol.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "How did they recognize me?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "Because it was impossible to recognize me or me recognize them, because we were like this.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We were some other people.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We're not the same.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They recognized me and they remind me they were sitting on top of me.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I became 75 years old already, Carol.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "What-- I don't care anymore and I cannot remember anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "First they put us to one hotel.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And then from a Jewish family over here, after the hotel they found us an apartment.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, I didn't belong to come in Los Angeles.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I was going to Ohio, Cleveland, Ohio.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But in the meantime, Dario came before me.",
      "word_count": 8
    }
  ],
