{
  "stem": "2170.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And as I was running with my sister and my brother-in-law, the head of the Gestapo-- his name was Graf.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "He was a redhead.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "He was a cannibal.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And he recognized my brother-in-law.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And he said, Zynsztein, come here.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "[GERMAN].",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Go on this side.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And I saw already, my mother, my sisters, and my brother standing on the other side.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "They were already on the side, the one which go to die, and the one which go to live.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And my mother and my sister were screaming, [INAUDIBLE], come here.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "She thought that I'm going to go on this side.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I was called.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And then the Gestapo came over.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you stay this-- on this side, the one who goes to live.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Meantime, I see-- I see little wagons with horses, dead bodies already on the horse-- on the wagons, blood all over.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And all of a sudden, this same policeman, Ukrainian Kobaliuk runs again near me.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I was standing.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I saw a grandmother-- a mother-- no, a mother with her little baby, and her-- and her mother, which was the grandmother.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "The mother was running with the baby and Kobaliuk, again, puts in the bullets and shots the mother with the baby in the hand.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And the mother goes like, oh, oh, and she falls on the snow near me.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I see her laying, already dead.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "The baby falls on the other side, alive.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So the grandmother grab the baby.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And then, again, Kobaliuk pulled the trigger, and he shot the grandmother.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And the baby, they throw on the wagon, alive.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "This took up to time-- maybe 12 or 1 o'clock.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Thousands-- they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The ones that are going to survive-- that was tailors, shoemakers, furriers.",
      "word_count": 12
    }
  ],
