  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "There was a gray bench with red webbing, [PAUSES FOR 3 SECONDS] and a mirror with a small shelf and an umbrella stand.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Do you remember anything regarding the home that you had lived in earlier as a younger child?",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] That was also-- it was a very sunny apartment, smaller.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I had my own room there.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And there was a living room-- living room, dining room, and my parent's bedroom, and a bathroom, and a kitchen, and a maid's room.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And my room was off the hall, small, with a tall stove.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And I had a crib there that I remember.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I had a canary, which somebody hung out of the window one day to give him a chance to have some sun.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And the door flew open, and the canary was gone.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And that was a big tragedy.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It had no name.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It was-- I don't know-- maybe he had a name.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "That was in-- now I'll have to spell it-- that was Prague 12.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And it was S-- with an accent-- M-I-L-O-V-S-K-E-H-O four, number 4.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was located in a-- what is now a very touristy part of Prague.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was two blocks from the old squaring, from-- and it was a very short street which led from-- there were about three houses on each side.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And across from us was a-- [PAUSES FOR 3 SECONDS] was an office which stamped silver or gold.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "A state office for stamping, giving the official stamps to anything manufactured out of silver or gold.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And then it faced on a little square, [PAUSES FOR 3 SECONDS] a round square.",
      "word_count": 15
    }
  ],
