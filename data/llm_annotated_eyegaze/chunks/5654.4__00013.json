{
  "stem": "5654.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And my son lives in London.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "His-- his-- his job took him over there.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes, well, I've got one daughter, who-- the youngest one.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "She is 26, Rahel.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "She's married.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Her name is Rahel Shagrin.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "She's married here, in Sydney.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And she's working with me in the-- in the office.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "We are manufacturers of swimwear.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "We are a swimwear manufacturer.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "And I thought that I would never ask my children to go into the rag trade.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "And I must say, that after two years, she's virtually taken over.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And she's so capable.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "And it seems to me like she's been there for 20 years.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "She's terrific.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "The elder one, Simon, is in London.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "He's married, has a child.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "And he's in the money market.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "He went to university.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "They all went to university.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "Because I didn't want them to come in the rag trade.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "I said, it's a tough business.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "You got to get an education, better yourself, better than what I did.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "And so his-- they sent him to London.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "And my other daughter, she also married.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "Her name is Ilana-- Ilana Kaplan.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "She married a South African, Morris Kaplan, who is a-- a-- [PAUSES FOR 3 SECONDS] an accountant, chartered accountant, went to Cape Town University, a wonderful chap.",
      "word_count": 27
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 25,
      "text": "And to us, he's not a son-in-law, but he's a-- he's a definitely a son.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 26,
      "text": "She has two little boys, which are so clever.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 27,
      "text": "[LAUGHS] What else can I-- And they're wonderful kids.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 28,
      "text": "They come here on the shabbat, stay with us.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 29,
      "text": "And they already now going to Mount Zion kindergarten, where all my children went.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I hope everything is OK.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    }
  ],
