  "elapsed_s": 16.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And finally we reached Kiev-- me and my friend.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We reached Kiev, but we have no money, and we are hungry, and we don't know what to do.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The plane?",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But we had to-- we-- we had to go to to to Brest-Litovsk-- I'm trying to remember now.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 15 SECONDS] No, I was right.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We went to Kiev.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "We went to Kiev.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I don't-- I don't even remember how we wind up Kiev.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "We wind up in Kiev.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "In Kiev, I I went over to a flea market.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] In Brest-Litovsk, [INAUDIBLE] [PAUSES FOR 12 SECONDS] OK.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Now it's coming back to me.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We lined up in Brest-Litovsk now.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "First we lined up in Brest-Litovsk.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "In Brest-Litovsk, OK, I lined up with a family-- it's interesting-- I lined up with a family who it was-- the woman was born in Radzyn, and she got married in Brest-Litovsk and lined up there.",
      "word_count": 36
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And I lived there with them.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "They had a daughter.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And as I was living there, we fell in love, and we got engaged.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "At that time, my brothers and sisters only was-- yeah, my brothers and sisters came to Brest-Litovsk, too, from Radzyn.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And they moved from Brest-Litovsk to a town called Olyka in Ukrainian, and [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Two towns.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And we [INAUDIBLE] was engaged.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "I was living in Brest-Litovsk.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And I wanted to tell my my brothers and sisters that I'm gonna get married.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "So they should come to the wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "The only way I could do it is go on a train, and go to Brest-Litovsk, to go to Olyka and [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I went to Olyka and [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And as I'm on the train, Hitler attacked Brest-Litovsk.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't go back.",
      "word_count": 4
    }
  ],
