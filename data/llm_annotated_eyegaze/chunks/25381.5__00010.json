{
  "stem": "25381.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And I opened my eyes.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "First of all, I was not hungry.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "But I almost lost my little girl, because in the attic, the small little windows-- and she turn around, and she almost fell from the attic, all the way on the cement on this.",
      "word_count": 34
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And when I turn around, and she's almost there.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "So I ran fast, and I grabbed her for the skirt.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And I pulled her out from the window.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "Another second, she would've been dead, because on the main floor outside is all sidewalk cement.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "So I saved her.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "So we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And then we rented a flat on-- on 12th Street.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "I don't know if you're familiar with 12th Street.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Because that time-- at that time, [PAUSES FOR 3 SECONDS] Dexter, you know, Davidson and that places, it was like here in West Bloomfield-- very expensive.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "We couldn't afford it.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "So he made $0.90 an hour.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "He brought home, already, $37.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "I became a millionaire.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "I have, already, $37 for a whole week wages.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "So we rented the room.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "And I had two dresses.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "It was like a three-family flat.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "So I go in the basement Sunday to wash.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "I had two dresses.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "And there was a janitor in the basement that took care of the flat.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "And I go wash.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "I don't have the sheet, and I don't have the pillowcases, and I don't have the dress.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And I started to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I say to the janitor, you took it!",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I spoke-- I didn't hardly speak yet, a broken English.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "You took it!",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You took it!",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So he took a big knife like that, and he comes with the knife to me, in the stomach.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He says, here.",
      "word_count": 3
    }
  ],
