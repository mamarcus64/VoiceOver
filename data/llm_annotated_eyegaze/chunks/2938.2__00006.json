{
  "stem": "2938.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I went out from Radom, and I went by 30 kilometers on the way of Kielce.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I looked for the place where I unloaded my gun.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I had a very good mark-- it was near an electric pole, with huge transformers.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And there was a certain number, a big number.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And according to numbers, I found-- the-- the electric pole with the transformers, I went there, nearby, and I started digging.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "Didn't took me more than one minute, and I found it.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "I checked it out, was in good condition.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "I took my grenade-- I had one grenade, one gun, and five bullets.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "When I bought the gun, I had six bullets.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "I couldn't get any more bullets.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "Before I paid for the gun, I tested one bullet, to make sure if I wasn't cheated.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "It worked, I paid for that, and I only have five bullets.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "So the five bullets were dear to me.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "I couldn't use them-- I have to have them for the last moment, so I saved them.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "I picked up the gun, and I went on the march of Kielce.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "And slowly, I didn't go too fast.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "I made five, 10, 15 kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "But slowly, I arrived in Kielce.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "When I arrived in Kielce, I didn't arrive through the city.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "I went through the forest, through the fields.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "And the city was located-- the camp was located on the outskirts of the city-- Huta Ludwikow.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "I camp near the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "I walked over there and waited until the people come home from work, 5 o'clock.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "While they've been going home from work, I jumped over the fence, and went into the camp.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And then I came into the camp, they start asking questions.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "How?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Where is everybody?",
      "word_count": 3
    }
  ],
