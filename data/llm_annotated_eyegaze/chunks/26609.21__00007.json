  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They didn't-- they thought that people here, they sent [NON-ENGLISH] here from United States to give the people, to the welfare here.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And I, whenever I worked, I dressed myself as-- I didn't care much about food, but I wanted to be dressed.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "So we went, and out our case.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And we went back over to that cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "He left.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And I slept there.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "She couldn't believe it, such a long way to come to look for, for relatives there, if sisters and brothers.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "I said, who else could help me?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "I had to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "I told her the story about in Israel, that woman, and then said that inspired me.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "And that's why I came.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And they couldn't believe it, what I did.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "They live there like in ghettos in United States, people.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "And he said, a doctor, medicine, and a lawyer, they started in Poland, both and the lawyer.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "But he wasn't recognized United States.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "You know how they had to study again?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "So he worked with the That was a newspaper, a Jewish newspaper, there where he worked with his two degrees, that he was elderly already, more than middle-aged, that cousin of my husband.",
      "word_count": 33
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "They went later to Israel and both died in Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "So I stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "That other, that Myer left.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And next day, I said, why did you come here so for?",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "They live like in ghettos there.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "They eat like in ghettos and live like in Ameri-- people think that America.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "It's much better in Australia than the United States, much better here, cleaner, a better life here.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "Maybe there are others, those people that went from Jewish small places.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "They live just as they lived before in, in Europe.",
      "word_count": 10
    },
    {
