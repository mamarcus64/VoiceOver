  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "But we didn't know if you are-- you'll kill us or you'll give us a-- a-- at least a piece of bread.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Sometime we used to go, you know, in the morning, when the goy used to take out for the-- for the pigs the potatoes with-- with all kind-- dirty.",
      "word_count": 29
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "We used to take out to-- to steal, and ran away with these potato, with the cold potato.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And I-- I didn't get sick.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Was our-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I will tell you something.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I-- I was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I come from a very religious home.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I was special religion.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "My sister, the bigger sister, wasn't.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "She was a Halutza-- Hashomer Hatzair, Halutza-- you know, more left.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And my sister, Mindel, also not so.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "My brother, the youngest, I need to watch him when he daven.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And he used to, you know, to-- to jump over.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "But then I-- I-- I was the one, you know, where-- where what I--",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No, at home-- at home.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "When we ran away, then I picked up Mondays.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I used to fast-- or Thursday-- to make, you know, a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "If-- if-- if I'll be still alive. then Thursday, I'll fast.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "If I'm still alive, I'll be-- next Thursday.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And you know, so feelings, intuitions, my-- my girlfriend told Jaacov my intuitions were so good, that when later on-- later on, I had-- I had, you know-- when I ran from house, we had-- we had a lot of jewelry.",
      "word_count": 41
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "This gold--",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- gold [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They told to bring the jewelry.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "If not, they kill us.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I was-- I said-- go to my mom, don't-- don't give them, because they'll kill anyway.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We hide them.",
      "word_count": 3
    }
  ],
