  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And that's why my marriage was for 45 years so nice and good.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And I never tell that anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "I only telling you.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "Even my children don't know we-- I have three marriage.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] I never tell them.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER] Maybe we leave it out, then.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I have my little girl born there around-- she was one year old.",
      "word_count": 13
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "We-- because they ask me.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "They wanted to give me some positions to the-- [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "And-- and I don't want it.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "It was not my way life.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And my husband, my dear husband said, look, mommy, we have to go away, because you tell what you want to say.",
      "word_count": 22
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "And that's no good for you.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "They put you in jail.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "So-- and then--",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "He has a-- a leather shop.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And he earned a very good money.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "We was very--",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yes, his own shop with his cousin.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "They was partners.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, he was in the perfume business.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "He selling before the war.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "But he-- he's-- he learned, because every Jewish boy have to have something--",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "--a trade, so he learned a gloves making.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "He was a very good gloves maker.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And then after the war, he-- he was working-- given the perfume.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "He loved those things that, you know, he was very particular.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And after the war, he opened the shop, leather shop, with his cousin.",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And he make a very good money.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "And we live nicely and comfortable.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "We walk.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "We walk for two [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "We go to--",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "--two borders to Czechoslovakia, and then Czechoslovakia to Vienna.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "With my one-year-old baby.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "We pay the men who carry him-- carry her, but when she started to cry, they give it to me.",
      "word_count": 20
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "So I have to carry her.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    }
