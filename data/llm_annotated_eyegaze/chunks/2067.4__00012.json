  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And so he offered me a job at the-- at the embassy, or the consulate-- either one.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But he said, first, you have to rest a while.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I started working at the consulate, [PAUSES FOR 4 SECONDS] and helped liberate Dutch men and a few women from prisons all over Spain-- and was very successful.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I got an official employ, and a very good salary.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And all monies that had been advanced to us by the Dutch government was struck out as past salary, which was a huge sum.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Dottie ?] had been operated, in the meantime, on-- on appendicitis.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "That was also included.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "So all that money, all of a sudden, was struck down.",
      "word_count": 11
    }
  ],
