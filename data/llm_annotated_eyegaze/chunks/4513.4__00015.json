  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Onto the trucks.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And we brought stretchers for those who couldn't move.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "They brought stretchers.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "We helped them to bring the people out on the-- get the people on stretchers, and all the other things we were doing.",
      "word_count": 23
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "So we were very busy.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And we didn't really care about the camp at all.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "You know, and so that's why-- we kept saying, we ought to blow it up.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "And the officer said we couldn't blow it up.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "He said, I think that's what ought to happen.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "It ought to be destroyed.",
      "word_count": 5
    }
  ],
