  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It's a wonderful city, cosmopolitan.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "You could go by subway to a lake inside the city after school.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "We had a car.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Money was a subject that was not mentioned in my home, because it was there.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "In '36, one of the edicts-- or maybe even it was '35. '35 was the beginning of a different life.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "The Nuremberg Laws came-- were published, and they defined our lives.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Jews could no longer be teachers, civil servants.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Jews could no longer appear on stage, perform any instrument in public.",
      "word_count": 12
    }
  ],
