{
  "stem": "766.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "So everybody wanted to go, the earlier the better.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "And it was winter already.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Because you had to have transportation.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "We didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And we took bedding probably, some, but I-- don't-- [? don't remember. ?] We took what we had, a couple pots.",
      "word_count": 21
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "I imagine so.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "I saw people moving.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "They had a-- a pail with a broom, they moved.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "That's-- the main-- you didn't know what to do first.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Later, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "There was-- there were wires, sure.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "We were completely, completely, hermetically isolated from the world.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and mother.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "No, in the same house, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "And that were the slums.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Because later, when everything was organized and all doctors were-- I wouldn't say mobilized, for sure.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "We were the first mobilized.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "Because everybody was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And everybody got an assignment, where to work.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "So I was making-- finish?",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "I was making house call.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "And I saw all these apartments.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "They were slums, like-- like-- like nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "I never saw this before.",
      "word_count": 5
    }
  ],
