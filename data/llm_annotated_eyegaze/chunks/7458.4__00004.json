{
  "stem": "7458.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We all came back to Jasionowka.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "My family, even though our house was still there, we decided we would live with my cousins in the same house that my cousin Schleime owned, which was a little further out of town still, at the end of Kolonia [INAUDIBLE].",
      "word_count": 41
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They also had a tannery.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "All of Jasionowka were tanneries.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "So my cousin Schleime had a tannery and a large wooden house.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And we decided we would all live in his house for the time being, until we decide what to do and where to go.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] We started actually producing a little leather, which we would sell in order to get some food.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And one of my cousins, the youngest, Maishe, the one who is now in Mexico City, he became a high officer in the Russian army, actually.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And he had an office in Bialystok.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And he's a very bright man.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "He speaks something like eight languages fluently.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And he became an officer in the Russian army.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "And he-- [PAUSES FOR 3 SECONDS] the other two brothers lived in Jasionowka with us in the same house.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And one man who lost both of his legs-- they froze and they had to be amputated-- Yankel Dunska, he also lived in that house.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "He was a friend of Schleime's.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And a couple other people.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "One Thursday afternoon-- now, by that time, we started hearing rumors that the Polish people formed an organization called AK.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And they were dedicated to finishing off killing every Jew that survived.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And they were going from town to town attacking Jews and slaughtering them in cold blood.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It was probably I would say maybe March or April of 1945, after we were liberated.",
      "word_count": 16
    }
  ],
