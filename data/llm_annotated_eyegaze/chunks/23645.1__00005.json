  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And she was very slim and had blue eyes and blonde hair and had a very, very stern voice, but very gentle with-- with all of us.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And we wore ?]--",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "It was a public school.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Mixed boys and girls.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And, it's funny I should think about it now.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We we we  wore slippers when we went into school, because they had these-- these floors.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They had hardwood floors, and they were very, very shiny, and we used to slide on them.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We had these wonderful slippers.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I was in grade 2 when the war broke out.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "They were wonderful years.",
      "word_count": 4
    }
  ],
