  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "They just at that time.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "So went her the same.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "And then I had some relatives also going with me the same one.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "And we came into the railroad station.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "They put them in the-- in the railroad train.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "They locked us.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 9,
      "text": "There was no train of people to ride, but they're just like for animals, I think.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Between-- in every car was between, I would say, 140 to 160 people.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Hardly.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "We just stayed, one-- one on top of the other.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "And there was some job of it.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, no food, no water.",
      "word_count": 5
    }
  ],
