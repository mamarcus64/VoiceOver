{
  "stem": "26914.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And she went to the ovens together with Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "Korczak.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "When I was in Korczak's home, I wasn't a communist.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "When I went out, I had a girlfriend which she belonged to the organization.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And she pulled me in.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "But when I was by Korczak, no.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Sport.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "When I come to the Maccabi, it wasn't a communistic organization.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Later.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "But even so, Maccabi was a sports club.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "To me, it was everything sport.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "But when they planned to make the Makabijada in Israel, as a communist, I was against it for Spartakiada in Russia.",
      "word_count": 21
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And I had worked against the Makabijada for Spartakiada.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Spartakiada.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Spartakiada.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "This was in time before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "So they catched me on the work, on the anti-Zionist.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And they threw me out.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I was the only one to go to Makabijada without money, because I was the captain of the volleyball and basketball.",
      "word_count": 21
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And I was the best player.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So I was rewarded with to go without paying a penny.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And they gave me ultimatum.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "You sign that you are not a communist, and you will go to Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I cannot sign it.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "It's I am not still a.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "I am still a.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "Then they said, then you will not go.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "And I decided to go.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 10,
      "text": "And I talk it over with the one from the organization.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 11,
      "text": "He said, you cannot sign it.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 12,
      "text": "If you will sign it, you will be stamped as a [? opportunist. ?] And you might be killed.",
      "word_count": 19
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "A communist, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to be killed.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't go to the Makabijada.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "This what wrecked mine life.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I was dreaming of going there.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Everything-- everything would be changed.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Who knows what would be?",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Most of the people which went there, 65% stayed there.",
      "word_count": 10
    }
  ],
