{
  "stem": "8703.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Five days after, October 6th, when I was already in Skarzysko, they took all the helpless people-- mostly young kids and elderly people and some young people if there are not too many.",
      "word_count": 33
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And they called them to the targoviste, to one place and they--",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "This was the targoviste.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "It was a marketplace where the farmers, the Polish farmers brought their stock, cows, and food, and horses and all other things to sell to the Jewish people.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And, and they can't-- they told the Jewish people over that everybody should go over there.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And if not, they will-- whoever will not go, will be shot.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "As a matter of fact--",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was told later on.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, October 6th, they liquidated the ghetto in Chmielnik.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I was not there anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Later-- we were in Skarzysko camp.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We found out from the Polish people that they liquidated Pol-- this Chmielnik.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We were not sure, so we, we paid one Polish man.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He should go to Chmielnik, and find out and let us know immediately.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "We sent out and paid a Polish man.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And he went there, and he came back.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "He said, the ghetto doesn't exist anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "All the Jewish people were taken away from Chmielnik.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "But later on we found out they went to Treblinka gas chambers.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And when did you find out about the Treblinka gas chambers?",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "This was the first time from the underground.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Later on-- later on, we found out from Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "In Warsaw, they, they took also from Warsaw, every day, a certain amount of people, and they send them away.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And the Judenrat wanted to know.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "First they said that they were relocating them to, to work.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Labor camps, they're taking the people.",
      "word_count": 6
    }
  ],
