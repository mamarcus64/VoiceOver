{
  "stem": "20684.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They had a-- they bought a house, half a house, in South Caulfield, 23 Steele Street, South Caulfield Brought us here and we came by boat that lasted a long time, for weeks, weeks, weeks.",
      "word_count": 35
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Through the Suez Canal weren't allowed to leave, Jewish people weren't allowed to leave in those days.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And we came and I still remember like today another one of those episodes.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We got up to my-- my uncle's place.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "He had a son-- I was then 14, 15, he had a son of about 10, 11 that was born during the war and another little one that was born in Paris on the way through that was only about five or six.",
      "word_count": 43
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And auntie and uncle and my mother, we were all sitting in the kitchen and in those days, they had bottles of milk, glass bottles of milk.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And my cousin pours a bottle of milk and as soon as he started pouring it, I just said, I've learned my lesson.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So I sat on my hands.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I sat on my hands, I didn't take any food.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I'm a quick learner.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I didn't touch anything, I didn't pinch anything.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Nothing in my shirt, nothing at all.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I [INAUDIBLE] and says, why don't you eat?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "I says, what can I have?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I was very well brought up.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "After four and a half years in the orphanage, just you get struck and that.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "No question about it, you survive.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "If you don't, well, the manners go with you.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So what would you like to eat?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And I said, what-- what can I eat?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "Anything.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Can I have some milk?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "How much milk can I have?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "As much as you want.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And I still remember pouring.",
      "word_count": 5
    }
  ],
