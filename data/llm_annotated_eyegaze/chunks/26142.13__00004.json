  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Was, was put up exactly-- he was able to put up a, a tombstone in, in a month before he, he was rounded up.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "And we never, we never, that, that, that ended that.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "And I think now, we'll, we will, we will go our different ways.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "My mother went back to [INAUDIBLE] as a widow.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "My brother Tvsi, my brother Tvsi went back to, to Mariapocs to his cousin, where he worked as a teacher there.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "I, I stayed, I stayed in, in Debrecen.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "And my brother, Moshe, went from there to [INAUDIBLE] He had some kind of a job.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "And that was, that was 1943.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "In May of 1943, one day I got up.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "And, and we see all placards all over, all over the city, that all Jewish males between the ages of 20, or 18 to 20, to 40, have to register in, in this and this place.",
      "word_count": 36
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "And then those that were born on this year have to register in this place.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "And so that was, this was in 1943.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "I, I, I, my father was dead.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "My mother was a widow.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "And my, and we had no means anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "And, and there was no, no, no way, no way that, that you can, you can get out of this hell anymore.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "So whatever, whatever go round like the destiny will be with, with the rest of us, I registered.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "And I came into, to a city called Karszow.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "And over there, they, they organized groups.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "This was a very infamous place.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "Because the, the, the head of that, of that organizing group was a guy by the name of [?",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 46,
      "text": "Mikolac, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 47,
      "text": "Mikolac, ?] a terrible anti-Semite, a zoological anti-Semite.",
      "word_count": 8
    }
  ],
