  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And you had to stay in line again for roll call.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And then we got the six and one half ounce of bread, always stale, hard and black.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And then you got a soup with some rutabaga in it.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I never think that they wash those rutabagas, because you found sand in it, not to speak of the foul water.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "You had to close your eyes and close your nostrils in order to be able to somehow swallow that without looking at it and without smelling it.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And then, occasionally they would give you razor-thin slice of some kind of sausage.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We always suspected what it is, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And a spoonful of jelly.",
      "word_count": 5
    }
  ],
