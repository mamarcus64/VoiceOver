  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "But-- so that was a good thing economically.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "Because you have access to special stores where we can buy food and other things that were not available to other people.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "The school where I went became a Russian language school, too.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "Many Russian officials came to, uh-- to, uh, to Poland, uh, with the occupation.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "The teachers did change.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We did not have any Russian teachers.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I remember that the new teacher was actually a Jewish woman who lived in Luck.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "He spoke-- she spoke fluent Russian somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And, uh-- so her, I remember.",
      "word_count": 6
    }
  ],
