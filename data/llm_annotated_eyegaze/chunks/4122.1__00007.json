  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "And they took them there to work.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "He, this [?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "Romich, ?] specially, he was very bad to them.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The women also was taking to-- took to work.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "But they took them, like, to do their houseworks, to wash their clothes, to, to clean toilets-- they-- and-- by everything, they were beating us.",
      "word_count": 25
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Me, yeah, specially the young ones more than my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They used to took, to take us to field work that-- daily.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And this work was unnecessarily.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Because they wanted just to humiliate us and to, to beat us, and to make us work for them.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, when they, not-- they had, like-- [PAUSES FOR 3 SECONDS] they had-- they-- like-- what was it?",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "The, the, like city hall.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And that, they took us to clean out those houses and put them privately where they were living.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "The-- my mother was at home.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Her, they didn't take to this work at this time, no.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "My brother was taken to work, too.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Also to this kind of work, [INAUDIBLE] they-- to sweep the streets, to, to wash, to wash the, the sidewalks, the-- such things.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No, in '41 when--",
      "word_count": 4
    }
  ],
