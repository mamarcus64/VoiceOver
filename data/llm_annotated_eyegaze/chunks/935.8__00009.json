{
  "stem": "935.8",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "I remember one guy telling me, we just don't have room for all of them.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "It's strange, the things you remember.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "Not enough room.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "It was the last camp that was being held.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "I couldn't go anywhere either.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "They didn't have room anywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 35,
      "text": "We hid for-- it must have been three weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 36,
      "text": "Not, we hid.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 37,
      "text": "We didn't have a place.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 38,
      "text": "We didn't know it then-- in the crazy block.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 39,
      "text": "It was the only block which would let us in.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 40,
      "text": "They didn't want us anywhere because they were so full.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 41,
      "text": "They didn't have that much space.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 42,
      "text": "So the first one who let us in turned out to be the crazy block.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 43,
      "text": "And I'm talking about people who were not crazy at all when they came to Ravensbruck.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 44,
      "text": "One side of the camp were all the lesbians which had also stolen.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 45,
      "text": "I don't know whether they were in because they were lesbians, or because they'd stolen, or both.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 46,
      "text": "The other side, not of the camp, but of the block, were all crazies.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 47,
      "text": "Now I didn't know this.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 48,
      "text": "I woke up in the morning, and my clothes were gone.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 49,
      "text": "The one I wore.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 50,
      "text": "It was pouring rain.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 51,
      "text": "And the one the [NON-ENGLISH] gave me to change-- nothing was there anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 52,
      "text": "This is the block which the Nazis over there used for their own entertainment.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 53,
      "text": "They would come every morning-- it was kind of fenced in-- and start the show.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Then they had a race.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They were tying their arms and their legs.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they had to hop to the end of the block.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And whoever made it first without falling-- what did they say-- gets sausage and sauerkraut.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Sausage and sauerkraut for whoever makes it first.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And then they had a wrestling match.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And the more you screamed, the better it was.",
      "word_count": 9
    }
  ],
