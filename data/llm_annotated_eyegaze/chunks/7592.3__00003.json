{
  "stem": "7592.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "They send him to over there, and they made him chief.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "This is Chilowitch?",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "One day Goth already was checking on what he was doing, and he didn't like something.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He called him a slap in the face, or the face got swollen.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Either way.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Goth, Chilowitch He didn't know him yet.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And next day, or two days later, he came over there.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He says, what happened to your face?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Oh, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He didn't tell him he hit him.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "No, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I got bitten by a bee.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And Goth liked this and made him big shot over there, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And that's why he became chief of the concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "A powerful experience is when one day they cleaned the ghetto and I lost my parents.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I was in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "My wife and my parents were staying over there because you have to line over there.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And the German came, and this on this side, and this on this side.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And there was a few seconds, and I never saw my parents since then.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "They came in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "During the night, they surrounded the ghetto with army, police, everything, and called in the morning everybody out.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Form a line here, and there will start separating you now.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So that's the way-- that was the way it works in ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I lost my parents in two seconds.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "In the same month, I got a-- [PAUSES FOR 4 SECONDS] my brother was killed in Mielec.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Over there they shot him.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And one month I lost the whole family.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I stayed.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Only my wife survived.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No, this was-- this was another thing, and I got Madritsch was protecting us.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Madritsch-- we got-- [PAUSES FOR 4 SECONDS] how you call this?",
      "word_count": 11
    }
  ],
