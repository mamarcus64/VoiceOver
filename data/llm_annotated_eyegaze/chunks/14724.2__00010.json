{
  "stem": "14724.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "And my foster father never did-- let her do anything-- never do anything except look pretty, and go play whist-- no, bridge.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "Bridge.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I hate bridge.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "It has bad connotations for me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "But I had to take over a business and a workshop because there were people making these goods.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "And these girls-- as they were known-- were old enough to be my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "So I would run the business-- I mean run, from stock taking, to seeing to customers, to doing the books.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "And then I would go home to wash, clean, polish, bake and cook.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "And that lasted until we couldn't bear one another anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "Because whenever we had a disagreement, which was about once a week, she'd turn round to me and say, if it wasn't for me, you'd be in the gas chambers with your brothers and sisters.",
      "word_count": 35
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 36,
      "text": "She once called my father a Nazi and I threw a plate at her.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 37,
      "text": "[LAUGHS] I missed.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 38,
      "text": "But she was not a nice person.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 39,
      "text": "She really wasn't.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 40,
      "text": "And eventually I couldn't-- I couldn't take this any longer.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 41,
      "text": "And very foolishly, I married her nephew.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 42,
      "text": "I was 19.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 43,
      "text": "And because I was underage, I had to get permission from my father.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 44,
      "text": "We were still corresponding and I wrote to ask him for permission.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 45,
      "text": "He gave permission and said he had just remarried.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 46,
      "text": "That was the last I'd ever heard from him.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 47,
      "text": "I sent him letters and photographs of my children.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 48,
      "text": "I had them delivered by hand.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 49,
      "text": "And I know he received them but he never, ever contacted me for the rest of my life.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "He had no more children.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And he died in 1976, 20 years ago.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I think he was only in his 50s-- no, early 60s, I'm sorry.",
      "word_count": 13
    }
  ],
