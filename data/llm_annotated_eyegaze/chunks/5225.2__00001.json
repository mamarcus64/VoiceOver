{
  "stem": "5225.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "They said, you [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "You got clothes on yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "You got what to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And you got what to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "If they gave you-- if you need a ice cream or something, we gave you $0.50.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "That's very fine.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "But, you know, you desire a little bit more and more.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And after you start going out with a girl already, you cannot say, you pay for your ice cream.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And I pay for mine.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "You must pay for her ice cream, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "It start going we are difference [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "So you demands are very more and more demanding.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Tell to them, and they don't want to listen to you.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "They say, who told you [INAUDIBLE] girl.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "When ?] [? you ?] [? could ?] [? be ?] already?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We going to see you got a girl.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Because in Europe, you know, they're matchmakers.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So we didn't fight too much.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "We just did what we could, do the best.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "So was going on, going on, till the war broke out.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And when the war broke out, I wasn't even home.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In Krakow, I run away.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I run away from the house.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I heard it.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But my parents took all the stuff, [INAUDIBLE], it was a big city.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So they took it, all the stuff, and hired a buggy and a horse.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And they took it to his parents.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And this was about 40 kilometer in a small town.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "After them, I come home about 10 days or 12 days after the war-- after the war started.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And they are home.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And it has calmed down.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And they say, OK, we must go and bring some stuff back.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "But you cannot already hire a buggy, because they're going to rob you.",
      "word_count": 13
    }
  ],
