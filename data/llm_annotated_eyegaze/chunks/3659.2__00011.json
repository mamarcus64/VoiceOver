  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And my father was two and a half years until his quota would be open.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So he got-- took a number.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "We always had to take numbers on quotas.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we all got numbers.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And my parents decided that they would split.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "We received the affidavits from our relatives here.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And an affidavit, if some of the listeners don't know what it is, is that your relatives in this country sign for you that you will never take a penny from the government in-- at that time there was no welfare-- but in any way, shape or form will never, ever go to the government for any help whatsoever.",
      "word_count": 59
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And they signed for that.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And that's the only way you could come to the United States, a little different than it is today.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And so we did have the affidavits they signed for us, and we split.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And what we had to do was split our affidavits so that my parents could leave the country.",
      "word_count": 18
    }
  ],
