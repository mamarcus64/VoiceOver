{
  "stem": "9665.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "As long as I was in Lyon, there were, every month, 20, 30 which I know of.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "They came to our place, because we bought the tickets on the black market.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We gave them something to eat, and they went to Annecy.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "They went to Annemasse.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "They got caught before Annemasse, because they didn't have the right sauf-conduit.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "They took a risk, and I couldn't get them more sauf-conduits.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Then Jacquet went to get them out of prison, or Sally Noach went to get them out of prison, because Jacquet got him a diplomatic passport.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "How he did that, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "I saved a lot of-- I saved, I would say Jacquet saved a lot of people.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "But I gave them the route, the way to Switzerland.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "There were hundreds of people.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They went to Switzerland.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I didn't want to go to Switzerland, because I was convinced that Switzerland is going to be occupied by the Germans.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was convinced about that.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So in the month of December, my brother and sister-in-law arrived from-- and the two children.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "They stayed in Lyon for a short while.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I got them the sauf-conduit. and they went, I think, either by train or by bus to Nice.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They want to stay in Nice.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "But they got this application form, all right, stamped by the police.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "In March-- everything I did went via Leizar.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "In March, 1942, my brother and-- married in Amsterdam.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And immediately after the marriage, my father and mother, within one or two weeks, arrived also in [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "My sister Anna, who spoke excellent French, got also sauf-conduit.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Between the two of them, between the two of us, we picked up our parents.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We took them to Lyon.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We got them that piece of paper.",
      "word_count": 7
    }
  ],
