{
  "stem": "25114.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "You arrived-- you arrived to-- to the right place.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "He-- he made us sit in one-- it's in-- in those peasants' huts-- houses.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They have those big ovens.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "You sleep on them.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "This-- so we went to sleep on the oven-- [LAUGHS] on the oven, where it was warm.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "He made us a hot meal.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "In the morning, he said, you know, I can't-- nobody will come now, because it's night.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I'll take you to a little-- a-- a-- wooden-- wooded place where you can sit all day till the-- till it gets dark.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Because at-- at-- at daytime, Germans can come, and, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "At night, they don't go.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But in-- in daytime, stay off the known roads.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So he put us in-- in this little forest, and we waited all day.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And then in the evening, when it was dark, as he promised, he came and took us into his house.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And not long afterwards came the Bielskis.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The three brothers came in.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "All of a sudden, I say-- I say-- I heard a noise.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And horses, I hear-- big horses.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And three-- three huge men, dressed in like, military black, with sub-machine guns-- short machine guns, they used to call it.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "[RUSSIAN], in Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And I sat.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I just said-- and I says, who's that?",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "He said, those are the guys.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They're coming to-- to collect us, or something-- to kill us or something, I said.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I said, that's the-- that's the Bielski brothers.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Here they are.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They came to fetch you to the partisans.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And that's just absolutely unbelievable.",
      "word_count": 5
    }
  ],
