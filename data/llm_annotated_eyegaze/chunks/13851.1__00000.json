{
  "stem": "13851.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Joseph Gringlas.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "G-R-I-N-G-L-A-S.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, it was a different spelling-- instead of 'I' was a 'Y.'",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "May 20, '26.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "69.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Ostrowiec Swietokrzyski, and it's in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "O-S-T-R-O-W-I-E-C and Swietokrzyski, S-W-capital K-C-Y-S-K-I.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Blima.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Her maiden name was Fleishman.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My father was Leizor [INAUDIBLE] Aaron.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I had-- we were five brothers and one sister.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The name of my oldest was Mendel, Shlomo, Jankel.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My sister was Beila, and there was Sol.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I was the youngest, Joseph.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "All boys and one girl.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in my hometown in Poland, the same town what I told you before.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they are originally from the same town.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "How did parents meet?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] I couldn't tell you that.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They never-- never told me about it, and-- I don't know.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They met-- this was not a big city.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Probably-- probably through family, through acquaintance, or something.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "It was a farming-- farming and outside the city.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But down in the city was a-- was a big factory.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They built trains-- not passenger trains, commercial trains for loading things, you know, for shipment.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And it had a [? hot ?] oven.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "There was like a-- they-- makes metal for-- metal for building trains.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It built all kinds of metal.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, in the same, there's a big oven.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "They use all kinds of equipment for the oven to bring the metal to liquid.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "It's a liquid.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "So that's what place I worked during the war.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He did sell shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He used to go to big city, capital city of Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Brought it to my hometown, Ostrowiec.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He used to have in the market, selling shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It was twice a week, Monday and Thursday, went to market for selling the shoes.",
      "word_count": 15
    }
  ],
