{
  "stem": "15943.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "We were still modest.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "So we switched.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "I gave her the long petticoat, and this covered-- that little baby-doll dress was good enough for me.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Because it covered me.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "But for the appells outside, we had to go naked.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So they could see-- we couldn't hide anything.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "So that we still-- the bones there.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And whoever couldn't stay straight and fell down, that was dead.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It was August.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS] We came in-- we left the ghetto August 24.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We came in August 27.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And it was one week.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "But it seemed like I was there forever.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Because I-- I guess I was the lucky one because I was sold-- literally sold as a slave, to go to the-- a factory in Germany, to work in a factory that was making parts, [BACKROUND NOISE] parts to airplanes.",
      "word_count": 40
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] They put us on trucks.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And it so happened that Karola and Tola, Rifkele, we all were on the same truck.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "They didn't tattoo us in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But when we came to the camp, they gave us number, where we were standing.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "There was no specific system.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And mine was 55082.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "We came-- they-- they gave whatever to, what they had piles of clothing.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "We were 400 girls there.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "It was a camp called Mittelsteine in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "We were sold to a factory that was making parts to airplanes.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And we all had the same shoes, though.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "The clothes is whatever they had.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "But they had the same shoes, which is wooden bottoms and rough canvas tops.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "And it was literally pulling the skin of our feet, as we were always being chased.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "We were put in barracks, 50 girls in a barrack.",
      "word_count": 10
    }
  ],
