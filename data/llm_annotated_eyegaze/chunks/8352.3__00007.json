{
  "stem": "8352.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "They used to light up one cigarette, and about five, people were standing around there, just smelling the, the smoke, getting a little taste of it, the feeling.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, they-- for somehow they put it in the, in the-- somehow in the clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They were working in different places.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They were working in the fields.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They were working in the cities.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And they could get if from some of the Germans, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "They could-- they could steal it, or do something, or, or, or bring in something.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And for a cigarette, you could get a slice of bread, because people were not smoking some of them.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And they were selling the cigarette for a slice of bread.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And the people, while they had only the slice of bread, rather give the bread up just to have the cigarette.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So it was going on, a few things.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Not too often though.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No women at all.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "All men.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We were all-- Absolutely.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "All the way.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We were not together with women until we arrived to, to Theresienstadt later on.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "If somebody got sick, [SIGHS] they had a hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They called it revier.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Let's say people got sick, infections.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They couldn't work anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "They sent them to that building there, the revier, that hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "There was no medication.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "There was no doctors.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "They collected a few hundred people, and they sent them out to get gassed, and burned, and things like that.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "From the hospital?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "From the hospital.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Now I'll tell you another thing.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was in the middle of the summer, in 1944.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "We were marching to the factory to work.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I was with that cable kommando.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We had to walk through a little village from the factory-- from the camp to the factory.",
      "word_count": 17
    }
  ],
