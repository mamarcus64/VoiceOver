{
  "stem": "8834.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Paula Mintz.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "P-A-U-L-A Mintz, M-I-N-T-Z.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Is-- my maiden name is Herling, H-E-R-L-I-N-G.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was Pesa Herling.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "P-E-S-A.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born the 3rd of October, 1919.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And where were you born?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Suchedniov near Kielce.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "How do you spell that?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Suchedniov?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "S-U-S-H-- C-H, excuse me, E-D-N-I-O-V.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This is Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And this is [POLISH] or this is like region Kielce.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Itzhak Mayer Herling.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I have very, very great memories of my father.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He was nicknamed the good Itzhak because he was doing so many good things to kids.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They loved him, Gentile and Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he had a soul of gold.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "He did help lots of people.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And he was a very honest man, religious, but not fanatic.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "He even kissed the ladies' hands.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Because we had all kinds of people in our business where my father belonged.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And he was very generous.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "People knew him.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "He was a very honest and humble man.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "I have great memories of him.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "Unfortunately, he died in the Treblinka.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "So my heart is bleeding for that.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "But I can't help it.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He was a clerk and expediter in a large iron factory.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And he also, later on, we had our own little business taking from-- we sold from a company, clay for porcelain.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And we send it with large-- from the large wagons from the-- with the train.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So we had this company.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And they liked my father very much.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And he gave them the clay.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He had clay mines.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He took the claims for free and gave it-- that's why we had it.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And my father made a living out of that.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He was born in Suchedniov, the same.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Suchedniov for a long time, maybe for hundreds of years.",
      "word_count": 10
    }
  ],
