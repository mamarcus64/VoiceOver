{
  "stem": "18061.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.9,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Some-- some of them, they got life.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Three of them got life.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "The other got 15 years, 10 years, 6 years.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "One got free.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't know the name.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I was there when he came out of there.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Seeing the people on trial, that is-- that's a difficult.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "You see the men which went around all day long with a gun, killing people.",
      "word_count": 15
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And he says he is not guilty, he didn't do anything.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "He just did what the Fuhrer told him to do.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "He had an order.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "Just according to order, they went.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I just saw him outside going around.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But I never had any word with him.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "I never--",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "--spoke him.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "He wasn't at the trial.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No, I never-- I never know what had happened to him.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Just the-- just the two trials attended, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "That's more than enough for me.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Believe me, when you get back from a trial like that, you are more sick than alive.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "It's not a pleasure.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "Even coming here, believe me, it's not a pleasure.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Inside, even if you say with a smile all this, that, inside you can never forget.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "You will never forget what a turmoil you went through.",
      "word_count": 10
    }
  ],
