{
  "stem": "21259.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "But they said that's to Siberia in a coal mine.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Novosibirsk, Novosibirsk in the coal mine, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "This I can-- I wish my--",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I wish my dead, you know, my dead.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "We used to work there 18 hours in the coal mine, no food.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "They got 600 gram bread a day.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Is this-- the bread was like a stone, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] a little bit, and used to work with a little [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] what there was, a little water with a salt pickle.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And this you work 14, 15 hours in the coal mine, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And every day in the coal mine, you know, when they take the coal, they put holes and they put dynamite.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Falls down and the coal, you know, a lot of-- every day, eight people, 10 people got killed in the coal mine.",
      "word_count": 22
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I was there 18 months in the coal mine.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I tell you, no, hunger-- hunger in this.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "I tell you, now, I must go in the army, kill a few Germans, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And they ?] [? come ?] them in like this.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And took me, you know, long, from eight months, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And this was every day?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Every day, every day.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And I used to work, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And hunger, I remember I went to the doctor, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't work, to do the work, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't work, and I couldn't work, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They hit me, this.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I should.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "But I couldn't, no, till a half an hour took, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I got this and they, I used to.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I was a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "You know what's [INAUDIBLE]?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I used to carry big bins.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Then they take the coal, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "They hold it there, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Now, there was gas.",
      "word_count": 4
    }
  ],
