  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I had a dream one time-- it was rather frightening.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I had a dream that the Rabbi from our city-- in a-- in a big Rabbi-- it's-- it's a [? row, ?] a [? rob ?] and a Rabbi.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "The second one-- and one man, the third one, was a big tall man with a white beard.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "In the dream, I was thinking-- in the dream-- this must be January.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And then I saw him.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And he go, and he keep a Sefer Torah, mit a [NON-ENGLISH SPEECH] and he say to me, Mendel, dance, dance, until some [INAUDIBLE].",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I said, Rabbi, yeah, I would sign [INAUDIBLE], but you tell me then [? degila visan ?] [?",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "Gila ?] then [NON-ENGLISH SPEECH] you're coming.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And with this, I was-- in dream-- I was to Holland.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And then my [? babchen ?] and she was like me-- remember [INAUDIBLE] you know.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "Then he took 12 and this-- I was operating and I didn't know to 12 days, to 12 weeks, to 12 months-- there was no television.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And there, I was counting-- you know-- every day.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "Exactly 12 months it took with the eight days together.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "Then they came-- they told me this.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "They told me, you know, here is a stop-- meaning all the-- the-- the-- all of-- all the-- like the captains, all you guys over there on the tram.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "Go over there, and they're going to give you everything.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "We not can come with you, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "We are going off to the ocean, to look and to call it in Russian [? asvietkin. ?] That's a Russian.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "You go looking for-- for-- for the animal, wherever they are.",
      "word_count": 11
    }
  ],
