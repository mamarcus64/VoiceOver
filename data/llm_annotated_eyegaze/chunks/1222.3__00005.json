{
  "stem": "1222.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "Again, God with me, this auntie, what [INAUDIBLE], he knew-- she knew one of my mother's aunty, my mother's sisters, that her maid's name was Zilberstein.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "She wrote me the name.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "The people's name was-- my cousins were still there-- [INAUDIBLE] Sytno-- Jenny Sytno, my mother's sister.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "And the other one was Lina Sytno.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And then in Boston was Golda, Golda Garner.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And went away.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And they wrote me a letter right away.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "And I should ask them-- I should write them back a letter in Jewish how I look, how my mother looked.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "Because a lot of people, they tried to get relatives, used to get money.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "As soon I wrote them a-- a sign, that my father was a crippled man, that my aunty-- wrote a few times my aunty-- they should leave the three children and come to America.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "My mother didn't want to leave him, my father, because they would not let in a crippled man to the America.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "My mother said she's in love with my father.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "She will not leave a crippled man.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "And that's why she was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "Otherwise, probably she would be in Canada or Boston.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "Finally, I said it, and they believed me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "I sent them pictures, and they sent me a little bit money.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "Was easier.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "And then they start making up papers.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And that's the way I became to Winnipeg.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "April the 8th, 1948, I came to Winnipeg.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, I had jaundice.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I was sick [? in the shoulder. ?] They [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I came to Winnipeg.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I had $8 in my pocket.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I-- my uncle offered me $10.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "I said no, I still have $8.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "If I have to spend the $8, I'll come.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I worked.",
      "word_count": 2
    }
  ],
