{
  "stem": "18865.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I didn't meet many other people.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The only people I really met were other refugee girls who were working in households all over England.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And we-- we were-- we felt like sisters, because we had so much in common.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But outside of that, I met very few English people, very few.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "The only people I also met was when I went to Slough.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "After we met-- moved-- after I moved to Slough, there were other refugee families and we were together with them.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "No other people.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Well, we-- we were in-- in New York.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I had the-- my-- my father's youngest sister and her husband were in New York.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And they picked us up.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, they were not-- they were also from Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But we were very tired.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- a very emotional coming into the-- I don't think it was Ellis Island, but it was something like Ellis Island.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We were examined and we-- we didn't know for sure whether they felt we were in health, good health.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We were told that there were some people that weren't left-- let in.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "They examined.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They had something special with the eyes and the chest.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And if everything wasn't 100%, they sent you back.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't get in.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So all this was-- we had nothing to eat almost until afternoon.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "None of us slept very much the night before.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It was all very exciting.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And then we went to my aunt.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And we were very anxious to get to a place where we knew we were going to stay.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So I remember my parents sending a telegram to my aunt and saying, you must come, use any excuse, just so we weren't transitory anymore.",
      "word_count": 25
    }
  ],
