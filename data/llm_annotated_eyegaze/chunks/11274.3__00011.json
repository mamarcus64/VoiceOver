{
  "stem": "11274.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "This is what's going on, and you two are going to Czechoslovakia again.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I hired Tolek.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "I said, mom, I'm not leaving.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I'm sewing, and I sell almonds or something.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "And we can live now, and I can work for it.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And I can milk the cow in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "Because sometimes the farmer milk the cow before I came down to milk it.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "So I got up at 3:00 in the morning to try to milk the cow so we had some milk too.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "The farmer was really mean.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "That was in another town I told you, 28 kilometers, really mean.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "And took all the money from us, and then he wanted the milk from the cow too.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "But anyway, this one hated the Jews, [INAUDIBLE] anti-Semitic, but hated the Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "So I said, mom, you can't-- you're two elderly people.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "Let's be honest, Mama.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I, I heard them whisper the night after this when I told her.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I heard them whisper.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "The whole night, they were going back and forth.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And mom said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Dad said, but what are we going to do?",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "So we're getting up in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I head the whole night they were talking about it.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I got up in the morning, and mom said, make yourself ready.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Tolek ?] is coming.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "You're going to Czechoslovakia, both of you.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I said, mom, I can't do that.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And she said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "Would you rather have to die, go away, you never see me again?",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And I just die somewhere.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I don't care if it's in the street or in the woods or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I don't want to live to see my, my daughters raped, she said.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, I had no choice.",
      "word_count": 5
    }
  ],
