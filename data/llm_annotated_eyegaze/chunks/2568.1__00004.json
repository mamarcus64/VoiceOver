{
  "stem": "2568.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "The youngest one with the picture?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Because her picture was always in the main street in the studio.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "She was very pretty.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And they took out the picture from the window and they came-- they figure maybe she's A communist, maybe she's something to do with the Russians.",
      "word_count": 26
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Who knows.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And my mother?",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I don't know-- just probably somebody show her the finger, the maid, or the-- a lot of Polacks-- you never know.",
      "word_count": 21
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Because there was-- when they took out the [INAUDIBLE] the neighbors, I wasn't there.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Because when they took my mother-- so one maid was staying downstairs, and laughing.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "So probably somebody just--",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "They kept her with my sister for a while in a school-- a business school we had.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And later, they start taking old professional people-- doctors, lawyers, teachers-- and all of them got killed.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "One day, I heard screams in the street.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I was living with my aunt at that time, because I was left with my brother alone.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And I heard screams.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "I go out to the front of the door.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And I saw two trucks with people screaming, and I saw my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And my two sisters, screaming.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And I start running after the people-- after the trucks.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "So [INAUDIBLE] stopped with the machine guns going to shoot me.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "So I went back to my aunt's house.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And I never saw them again.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "They took them to the woods, and they all got killed.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "My father's sister.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "With my younger brother, I stayed--",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "--to the end, till the ghetto was liquidated.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Ghetto was in 1942 in December.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We had to move.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "In January everybody's supposed to be in the ghettos.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "We were living with my aunt.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "She had seven her children.",
      "word_count": 5
    }
  ],
