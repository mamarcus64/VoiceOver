  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "The commandant find out.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "He made an hour, he's going to shoot her, you know, because she doesn't belong here.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 19,
      "text": "But he was the doctor from this SS man, he had a ulcer.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 20,
      "text": "The Jewish doctor was good, you know, for him, because he helped him.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 21,
      "text": "The doctor say to him, look, if you will make this, the whole ghetto will get like a revolution, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 22,
      "text": "You cannot do this.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 23,
      "text": "For me, do me  a favor.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 24,
      "text": "I will tell you something to do.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 25,
      "text": "I will take her in hospital, he say.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 26,
      "text": "They got a little place, you know, where he is there.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 27,
      "text": "And I will give her a needle, and I will kill her.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 28,
      "text": "And then we'll take her out.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 29,
      "text": "Nobody will know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 30,
      "text": "He agree with him, because it's his doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 31,
      "text": "And what he did, instead to take her out, somebody died natural.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 32,
      "text": "So he took her the other one.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 33,
      "text": "And she is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 34,
      "text": "Or he is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 35,
      "text": "I think when after the war, they was united, where he had saved them.",
      "word_count": 14
    }
  ],
