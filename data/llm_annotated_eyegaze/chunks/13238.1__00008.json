  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But naturally, they were lacking medication.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "But we had a number of doctors who were still at the time in ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And we had the hospital, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Privately at home, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "As long we were together, we could bear anything.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "The tragedy started when they took my mother away.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "This was in September, October 1942-- '42.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "When we came back and we didn't find our mother, we knew right away she was sent away with a transport to a certain destination.",
      "word_count": 25
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "People were talking about different places, but nothing was proven, ever.",
      "word_count": 11
    }
  ],
