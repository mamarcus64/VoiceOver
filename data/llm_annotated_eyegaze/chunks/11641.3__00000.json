{
  "stem": "11641.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Because many were sent to Mauthausen, there were many barracks empty at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "One night, we wake up-- a tremendous explosion.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "A cockpit of a plane fell down onto the barracks and went on fire.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "What happened is that one of the pilots was shot down-- Australian pilot was shot down over Krakow by anti-aircraft fire.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And he was still in the cockpit when he was-- fell down on one of the barracks, and it went on fire.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "The whole area went on fire.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And eventually, we have-- we were sent to Plaszow, back to-- not to live there, but to sleep there.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And we were walking back to work in Emalia, back and forth, because everything burned down.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And in-- this was in 1994-- in-- sometimes in November before we were given orders.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "The Russian were approaching.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "The-- Schindler was-- said that he's moving the factory to Brunnlitz.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And we were assigned-- our group stopped working on the construction.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "We were assigned to pack everything.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "In-- in where?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "In Brunnlitz?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In-- in-- no, in Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The barracks were built.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I didn't want to say that, but we were digging graves.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Digging graves-- not graves.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Digging stones.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And the German master was taking out the corpses and pulling teeth-- pulling gold teeth from the corpses.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no--",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "--while I was working in-- in Plaszow, before Schindler--",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "--before Schindler.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And-- and we saw Jewish girls that were stripped naked and shot over there.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They brought them from-- from the ghetto, from Krakow itself, because they were sort of on Aryan papers.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "In other words, they-- they posed as Poles.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And they were pointed by somebody that they were Jewesses.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And they were stripped naked over there and killed.",
      "word_count": 9
    }
  ],
