  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "So every Wednesday was the regular meeting day for-- was their regular meeting day.",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And that was an impossible situation for me because [LAUGHS] I was the only one.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I, I stuck out like a sore thumb.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "Everybody sitting there in uniforms-- 30, 30 boys-- and I am in, in regular clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "So, you know, that was unpleasant.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "When I get up, my-- the English teacher asked me to give a-- read my, my work-- my homework.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "He-- they would call-- they would say, shut up, Jew.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Sit down.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "We don't want to hear you.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "So it was not an unpleasant-- you know, a highly unpleasant situation.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    }
  ],
