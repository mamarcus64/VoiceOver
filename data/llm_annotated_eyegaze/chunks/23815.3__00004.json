{
  "stem": "23815.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The Germans, the German soldiers start to shoot us before we are liberated, and start to shoot.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I was lucky I skip.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I saw shooting.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Many other-- for-- like me, when they saw shooting, everybody start to-- to-- to run away.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, only women.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Never men with us.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't have a clue.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I saw-- I-- I want to go away from-- from the-- from the [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "What you call this-- the gun.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I want to run away from the gun.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So I was running.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I saw other people run.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "So I ran as well.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And all young women, all young girls.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I-- I wouldn't have a clue where I was.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We were marching.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I don't know where-- where I was!",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I don't know the places.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I wouldn't have a clue.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "You can't image.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "You just can't image.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I said to myself, it's really that I'm going to be alive?",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "That I going to tell the people what I've been through?",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Is this possible?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Again, I said, God must love me to let me live.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] Then we-- I saw people running from one place to the other.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "Everybody was crazy.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "They didn't know where they were running to.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "It was Belgiums.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "It was from different-- all countries.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I didn't want to go back to Greece anymore, because I knew it that I haven't got my parents anymore.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "I knew they all were dead.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "Only I knew that my sister-- they told me when I was in-- in Auschwitz-- they told me that she escaped.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And I was very happy for her.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "I said to myself, at least she will be one to be alive.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    }
  ],
