{
  "stem": "7684.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "She had a friend.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "She had a whole family what she wants to help.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So I had to go to another family.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I went to another family outside Utrecht.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I was hidden in Utrecht, and that was until-- in Bilthoven.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "It was a little town outside Holland-- Utrecht.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And that was a very large house by a couple-- a couple and a brother.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "There were three-- three adults.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And I had to do the cleaning.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And there was no food in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "It was already very difficult in Holland.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "That was already in--",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I forgot that I was in jail.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No, that was after.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "No, that was after.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, it was after I escaped.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So-- so I was-- it was a very difficult time.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was very difficult, because the people-- there was nothing to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I had to do-- I was not allowed to talk with anybody.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "The people went home 8 o'clock out of the house, and they came, 7, 8 o'clock back home.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And I was all alone.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I remember she had a bone, and I had to cook soup from it.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And she say, see, you can cook soup from it.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "There's still a little bit fat on top.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And I had to cook that all over again.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And that's what I got to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And sometimes I took a piece of bread and hide it under my pillow for at night when I was so hungry there.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "And also we had apples in the attic, and I slept in the attic.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "And I took sometimes an apple.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And I felt that I stole from her, because I was very hungry.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And I was very, very lonely there.",
      "word_count": 7
    }
  ],
