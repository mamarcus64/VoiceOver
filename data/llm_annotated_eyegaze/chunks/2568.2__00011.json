{
  "stem": "2568.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "My girlfriend, she was a nurse in that hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "We save her life, me and my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "She had no money.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "She fell in the lake.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "She couldn't go out for food.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "My brother used to bring.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "And she say, if I live through, you gonna have everything.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "Because she knew where her family left all her money, jewelry, [INAUDIBLE], everything.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "I said, fine, look.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "So we stay in Dubno.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "When they were liberated, I just came out from the hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't go to my town, Brody.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "She went alone.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "And I stay in Dubno.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "And she came back.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "She didn't help me much.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 22,
      "text": "She became new friends, she got friendly with somebody, and she gave-- which was OK.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 23,
      "text": "My brother, we met some people, Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 24,
      "text": "They used to bring all kind of stuff.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 25,
      "text": "He used to go in those flea markets, sell it.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 26,
      "text": "He make, here and there, couple rubles, they used to call, just to make a living.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 27,
      "text": "We were staying.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 28,
      "text": "One day, I say, I'm going to take a ride to Brody.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 29,
      "text": "Maybe we gonna settle there.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 30,
      "text": "We going to find a little house, and we going to stay there.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 31,
      "text": "We gonna see what's going to happen.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 32,
      "text": "And I'm going there.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 33,
      "text": "And I'm sitting on the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 34,
      "text": "We used to grab, you know, American trucks, they used to take us.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 35,
      "text": "And I'm driving that street where my aunt used to work.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 36,
      "text": "And that woman used to be there like a super there, take care, cleaning, this.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 37,
      "text": "And I see she wears my sister clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 38,
      "text": "And I got so sick, I couldn't look at her.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 39,
      "text": "But still, I went to my friend to visit.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 40,
      "text": "And everybody, why don't you take his house, their house.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 41,
      "text": "Settle here.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it was empty.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "All the Jewish homes.",
      "word_count": 4
    }
  ],
