{
  "stem": "13673.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "A little later in the story, there was another girl in my class at-- at the next school that I was going to in Wellingborough who was a-- a German Jewish girl, and we became friends.",
      "word_count": 36
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "That's it, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "This was a public school that I walked to back and front.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "My children are always laughing at me because I said-- I told them that I had to walk uphill both ways.",
      "word_count": 21
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "But it was true, and when I took my husband later on to show him, he had to agree with me.",
      "word_count": 21
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "You walked down the hill and up the hill, and then you walked down the hill and up the hill again so-- [LAUGHS] The schooling was different, of course.",
      "word_count": 29
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "It was high school by now.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And I was learning French.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "No, they were trying to teach me French.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And Latin.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "Oh, yeah, I think we had Latin in-- in the boarding school as well.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] It was a little more serious.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "Different teachers for different subjects.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "And again, all girls.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "The schools in England were se-- segregated.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "My schooling went downhill.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "It was-- I don't know what happened.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Partly because, perhaps, there wasn't anybody around to really help me with my studies anymore, and it felt like nobody else was really interested.",
      "word_count": 24
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "This may not be true, this is-- but this is how I perceived it.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And I lost interest.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "So I did quite poorly, except in music and art and the-- the subjects that I liked, and probably English.",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "What kind of a kid was I?",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I was a s-- well, I had friends, but I-- I liked being alone.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I was always-- I always thought I was different.",
      "word_count": 9
    }
  ],
