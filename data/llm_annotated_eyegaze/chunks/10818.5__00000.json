{
  "stem": "10818.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "In New York, in this part boarding house apartment, with my mother studying to be a nurse and getting her license as a private nurse and my father having made some connections in England to be a salesman of piece goods, that is, woolens, and then later he was in cottons.",
      "word_count": 51
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And myself going to Julia Richman High School for a year.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1940 to '41, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And there I was registered as Miss Gardner with a D.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I don't know why my cousins did that.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I mean, they were with a T-- whether they were afraid that you know, they might get mixed up with us.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "But they recommended that I would be Miss Gardner with a D.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And the day I started high school, my mother started work in a factory that made-- well, it wasn't even costume jewelry.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "It was fake jewelry, you know, putting rhinestones into something or other.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It was piecework.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And that's what she did, while she was studying to get her nurse's certificate.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And we came home that night.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And she said-- and my mother, you know, nobody-- in Germany, everybody's very formal.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And a stranger addresses you as Frau Gaertner.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "And she came home, and she said, you know, it was very funny.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "I got to the, to the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And they called me Hannah.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And I said, that's funny.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I got to school, and they called me 'Miss Gardner.' [LAUGHING] I was all of 15.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "I was 16, I guess, by that time.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "And so we got used to being-- doing it the American way.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "And my mother got to be a nurse.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "And I got to graduate from high school the next year.",
      "word_count": 11
    }
  ],
