  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 27,
      "text": "Baggins ?], he was all so well dressed, and his nails were done and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 28,
      "text": "And I was starved.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 29,
      "text": "And I was so thirsty.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 30,
      "text": "I had a fever.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 31,
      "text": "I had pleurisy.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 32,
      "text": "And I asked if I could have a glass of water.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 33,
      "text": "And he said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 34,
      "text": "I couldn't have water.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 35,
      "text": "I couldn't talk anymore anyway.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 36,
      "text": "And he had great big silver trays come up with food.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 37,
      "text": "He did it on purpose.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 38,
      "text": "He knew I was hungry, probably, and thirsty.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 39,
      "text": "But I couldn't have anything.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 40,
      "text": "Anyway, they questioned me that first night.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 41,
      "text": "It must have been--",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Enough?",
      "word_count": 1
    }
  ],
