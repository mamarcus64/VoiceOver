  "elapsed_s": 115.4,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 22,
      "text": "And on the end, they had two-- two-- two-- what do you-- what do you call it?",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 23,
      "text": "Which-- which-- which the plates were laying.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 24,
      "text": "It was a-- it was a-- Handles?",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Not handles, but to move it-- to move it on-- on-- on the--",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "--ovens was a-- was-- was a-- a-- a trestle, like, like, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "To put up the rail, this-- this-- this--",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Heh?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Long poles.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But-- but in the middle, was-- was to take a body.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Like a-- like a dish.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And it-- it-- it rested on the two rails by the oven-- and then to move it in.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And then it was a-- he gave--",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "He gave-- he-- he learned how to do it.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Two sides from-- from-- we had a stick.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And-- and-- and-- and the-- the-- the-- the plate was laying on-- on-- on the stick, one stick from-- from front, one stick-- stick in the back.",
      "word_count": 27
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And in the-- in the-- in the back, all together was-- was two handles.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And when they load-- we loaded the dead bodies, one on the other.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And the one-- then it went on top-- three.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "So we-- we--",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
