  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Because-- because-- because I wasn't able to-- to let out my grief.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] I had to repress it.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I was afraid, like to mention, even my mother because there was the stepmother.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I'll give you an example.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I had a picture of my mother from my-- from my great aunt.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I was afraid to show it in the open that my stepmother shouldn't see it.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She shouldn't feel bad that I'm looking at the picture.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So I never put it out till my stepmother died.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "That's when I put the picture on the wall.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
