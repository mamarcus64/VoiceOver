  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "I have-- I have five grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "My oldest is Rachelle.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "She finished college in Chico.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "She works for a telephone company.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "My next is Debbie, my Aron's daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "She is-- she's a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "She's optometrist.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "Is married to a doctor which is a podiatrist and just had a little baby, which made me a great-grandmother.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "Then is my granddaughter, Darlene.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "She finish college and she works in a doctor's office.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "Then there's my granddaughter Liana.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "And she finished as doctor's assistant.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "And she works for a dentist in Miami.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "And my grandson, Sam, he was just-- he just graduated from UC Davis.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "And he-- he got his bachelor's degree in economics.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "And he's going to go for-- for master's degree.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "He wants to be a CPA.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 26,
      "text": "So all the children are well-to-do.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 27,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I'm-- I just-- I am married-- just celebrated my 35th birthday to Eddie.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I was married 20 years to Sam.",
      "word_count": 7
    }
  ],
