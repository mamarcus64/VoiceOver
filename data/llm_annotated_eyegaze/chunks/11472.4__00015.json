  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "Because in the DP camp, you know, the, the food that everyone got was not as good as the food that the children got.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "Because the children, we were looked after like-- we were like their diamonds that they found.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "[PAUSES FOR 3 SECONDS] Anyway, the orphanage is going on.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "We're already in 1946, the end of '46.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 31,
      "text": "The beginning of '47, the orphanage, the children have to register-- or to go to Israel or to go to America.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 32,
      "text": "They have a choice.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 33,
      "text": "They're not forced to go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 34,
      "text": "They are given a choice.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 35,
      "text": "Because some of them remember that their parents had relatives in America.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 36,
      "text": "So they are given a choice.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 37,
      "text": "I decide I'm going to Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 38,
      "text": "I joined the Betar.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 39,
      "text": "My father belonged to the Betar.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 40,
      "text": "I'm going to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 41,
      "text": "And my mother also thought perhaps she'll go to a kibbutz.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 42,
      "text": "She's a widow with two small children.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 43,
      "text": "And she--",
      "word_count": 2
    }
  ],
