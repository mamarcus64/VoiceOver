  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "We don't feel the other way.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "There was.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "There was.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "There was from them.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "There was, especially Christmas, when they come some other days.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "There was.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "Well, everything was-- everything was a law.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "Was Poland was taking care of that.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] Uh oh.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 7 SECONDS] Everything.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 9,
      "text": "And that's the way it was.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 10,
      "text": "In America, we got too.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 11,
      "text": "We got it here, too, but we don't know it.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 12,
      "text": "We don't hear.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 13,
      "text": "But a lot of anti-Semitism here too.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Well, beat up, that happened just with boys.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "With boys and girls, maybe, they beat up, but not-- not the older ones, no.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Never happened, no.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "There was bothering me that we see Poland alone was against the Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Poland like, let's see.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I got a grocery, and a Polish man have a grocery.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "Each sending the kids and pick up my grocery in the front, not to go to me to buy.",
      "word_count": 19
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "This show up from the Polish people.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "That time, was not showing up much from the Ukraine.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "From the Polish more, and was the anti-Semitism.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "And we saw it lately.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "That's another way.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 9,
      "text": "But we don't have other choice.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 10,
      "text": "That's the way it was going.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 11,
      "text": "That's where we saw it.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 12,
      "text": "It was pick-- and the Polish-- the Polish boys was bothering more time than the Ukrainian.",
      "word_count": 16
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 13,
      "text": "Only Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 14,
      "text": "And they would send us to Palestine.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 15,
      "text": "Go to Palestine.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 16,
      "text": "Palestine, you have nothing to do here.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 17,
      "text": "I got a grocery-- well, I got a grocery in [INAUDIBLE], and I got a [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 18,
      "text": "And the people like me.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 19,
      "text": "They don't like him.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 20,
      "text": "He was-- he was doing a lot of bad things to me, a lot of bad things.",
      "word_count": 17
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Like one time, he put me in with another Polish together.",
      "word_count": 11
    }
  ],
