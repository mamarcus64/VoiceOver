  "elapsed_s": 106.0,
  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 9,
      "text": "We never got sick.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 10,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 11,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "There was nothing there.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I just traveled, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "I went to Munich.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "It was not too far from Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "Some people went there to live.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "To visit my friends, because they stayed there.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "They told us.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "You know, I mean, they didn't want to stay in-- in--",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "They didn't want to stay in Feldafing.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "So I went to visit them.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "And we-- we talked.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "We had so many people to talk to and exchange our experiences.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "And so-- and then-- and then some people came and told us to get to-- to-- to Switzerland.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "They said, Switzerland will let you in because you are refugee.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So my ex-husband, I was there with him and my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And he said, oh, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "We all going there, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "So we went first to visit.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "And it was a beautiful, beautiful city.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "What city was it?",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Konstanz and Bodensee on the Kreuzlingen border, Kreuzlingen border, about an hour away from Zurich.",
      "word_count": 15
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "But who would let us in?",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "Nobody let us in.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "The minute I came to Feldafing.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "And I was on the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "On the truck to go down, he was there.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "He was-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "He was liberated too.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Oh, he was in Buchenwald and Auschwitz and Poznan and he was in many camps.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "He was already there.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Spotted me on the truck.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "That was my luck.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "We came up.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "But he came into the bunk, to the--",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Barracks, yeah, at that time.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "You know, and you know, it happened.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Lodz.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "My mother.",
      "word_count": 2
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "My mother knew his family.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "So she was very stoked that he's also from Lodz.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "In a way.",
      "word_count": 3
    }
  ],
