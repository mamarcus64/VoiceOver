{
  "stem": "543.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "I had to put the sugar in.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "And I want to go back to Lillian.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "And I heard somebody saying in Dutch, they said, are you Dutch people?",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 13,
      "text": "I said, yes, I'm from Holland.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 14,
      "text": "He said, where are you coming from?",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 15,
      "text": "I said, I'm born in Amsterdam.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 16,
      "text": "And he said to me, oh, do you look lousy.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "He said, but I-- we have an-- an-- an cabin from the Germans, and we have a stove.",
      "word_count": 18
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And we have food.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And we have water.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to take you with other people, and take about six or eight people.",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And we gonna care for you.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "We are with four Dutch boys who want to help you.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "So I wanted to get-- not go with them first, to Lillian.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And Lillian was-- they came to Lillian.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to pick her up.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "She was so skeletal.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "So they get an-- an wheelbarrow, and they put her in.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "And they take her with.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And the same night, we were laying-- and they-- and they took hot water, and they washed us.",
      "word_count": 18
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And who were these people?",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "The Dutch boys.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Just--",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "--they-- they were in a work camp there.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "They were also picked up.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "But if you-- if you were able, they had to work for Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "So those people were not SS's.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "They were just-- not in a-- in a-- in-- they called it a work camp.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "That was not like, like we, not in a concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "So they-- then we were-- so then, the boys took us in.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "In the night, they leave for our bed.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And we said, we can't, keep them.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "The little one, Lilli, is going to die for sure.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And that the other one is also not far away.",
      "word_count": 10
    }
  ],
