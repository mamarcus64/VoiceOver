{
  "stem": "25114.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So he just kept putting this huge pieces of gauze-- he had this purple liquid, he had something crystals he-- to sort of kind of antiseptic, and he put them in.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And every day he pulled them out with a thing, and the milk kept coming because I was pregnant-- seven months pregnant, or eighth month.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And the pus kept coming, and the milk kept coming and draining the pus because this was infected.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So all this took place, and I was-- I didn't know what was going to happen to me.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But otherwise, it was peace and quiet in the-- for the time being.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We ate well, and there was warm weather, and we could wash ourselves and clean and everything.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "So this was the only problem I had.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And then it kept-- you know, it kept going and going and going and the wound grew smaller and smaller and smaller.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And the thing around it kept getting harder and harder and harder.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "So, you know, I wasn't expecting to survive it.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But one day it sort of all disappeared.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And the doctor said, you're very lucky, because this wasn't medicine, and this wasn't reason.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "This was just luck.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "I had a very strong immune system.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "I was young and nature was very strong under those condition.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "I was covered with scabs, and we found-- everybody used to carry something like the sulfur ointment.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "This was like-- somebody-- this was just as important as water.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "Because if you didn't have this, your whole body got thing-- got-- And then after, just before I went into labor, I had a-- I had an attack of shingles.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "So I was very, very sick woman.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And I expected a very difficult birth.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "I was very young and very small, and very everything.",
      "word_count": 10
    }
  ],
