  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was very strict.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Hard for them and strict.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, for a certain category or certain [? fit ?] of prisoners, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "If you was-- it was-- no, as I told you, that were 41,000.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I was in charge of the security of this what they called hospital and general camp.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "It was half hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And the other half, there had been barracks with the VIP German people-- generals, marshals, ministers, and so on and so on.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "This was about, well, 200, 300.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Only the VIP.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Skorzeny, for example, or this man who liberated Mussolini was in this camp, and so on.",
      "word_count": 16
    }
  ],
