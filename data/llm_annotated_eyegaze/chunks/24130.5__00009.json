{
  "stem": "24130.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And then, all of a sudden, we see trucks [INAUDIBLE] come-- coming.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "Trucks covered-- the trucks were covered.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And they're coming up the hill and coming down.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And the trucks stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And they-- there were also men that were there working, the Polish men.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And they opened up.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "They already knew what to do, these Polish men.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "It was the first time for us, but these Polish men were already there working before.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "So they open up the trucks.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And we saw people coming out from there-- these trucks.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "There were people, men and women, no children.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "But like middle age some were very young.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "Some were, like, in their 20's.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "Some were older, let's say.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "Not very old, sort of maybe 50 years.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And they were very nice dressed.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "They were-- you saw that these people were better class people that they were dressed.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "They took them-- lined them-- they didn't line them up.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "They just took them from the trucks off.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "And they told-- one was a commandant.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "He said that this and this date, a solider-- they found a soldier on this and this street killed.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 33,
      "text": "And they took all these people political.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 34,
      "text": "And you have to pay with your life.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 35,
      "text": "And I says, oh, my god, they're going to kill these people here.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 36,
      "text": "They-- blind-- we put on-- they told us to blindfold the people, took off their jackets.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 37,
      "text": "They had raincoats.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 38,
      "text": "We took off their boots.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 39,
      "text": "We took as much clothes as we could.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He-- he-- they were just-- they didn't cry.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They were just standing there.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I remember one girl held onto a boy.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They were walking together.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[SOBBING] And they told them to walk.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And when they walked, they just fell into the ditch.",
      "word_count": 10
    }
  ],
