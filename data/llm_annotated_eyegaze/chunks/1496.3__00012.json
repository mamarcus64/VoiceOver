{
  "stem": "1496.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 77.2,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I brought the chicken to camp, and we killed it.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We cooked some chicken soup.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And this was the biggest mistake.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Because I-- after eating a little bit of chicken soup, I got sick.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "My stomach couldn't take it.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I was sick for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And luckily, that wasn't serious.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And then, after a few weeks, the Russian authority came to the camp and said, announced, who wants to go back to Cracow-- to Poland?",
      "word_count": 25
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We will establish a train, and you're going to be escorted.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "We'll take you back to Cracow.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And we were-- I, I took the train.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "I went by train to Cracow, came to Cracow.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And unfortunately, we were not welcome.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "I went to my former neighbors where I lived.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And their only question was, are you still alive?",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Well, we-- I-- what happened in Cracow-- Cracow was liberated in January of 1945.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "A Jewish community center was established.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They took over a few buildings where before the war like was a, a, a, a Jewish orphanage.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they established hotels for the people when they were coming back from concentration camp.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "They gave everybody a cot and a blanket-- an army cot and a blanket.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And people were starting to come from camps, hidings, from other places.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And they joined together.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "We were looking for some survivors.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "I was hoping that I was going to find somebody from my family survived.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "Unfortunately, nobody survived.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And in this house, that's where I met Helen, when she came back from Czechoslovakia to Cracow.",
      "word_count": 17
    }
  ],
