  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "That's how I saw how they're killing the people who fall behind.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I said [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Blockfuhrer comes up, and he knew me because I was working in six.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He said [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I say, [NON-ENGLISH], I can't go anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And suddenly the guard loads the rifle, and loads it up and puts it up just like that.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And he's from a distance like you from me.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And believe it or not, I got up from that stone, and I started to move.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And I came in the village in the first row.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "It couldn't have been strength, it was just-- I don't know what it was.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "But I knew I have to run away because I'll never make it.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "From the church, next day, I run away with two other Polish boys.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And out I was of Stutthof.",
      "word_count": 6
    }
  ],
