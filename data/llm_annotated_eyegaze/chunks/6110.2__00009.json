{
  "stem": "6110.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They were treating us sometimes terrible, you know, like we used to work and I was tired, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We girls, we had menstruation, so we couldn't walk so fast, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We were bothered by that.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We had pains here, so we walk slowly.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Well, they would knock over the back, you know, to walk faster, faster.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But Schindler was watching from the window of his office.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "He was staying and looking down.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "He didn't like something like that.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "That's why we felt safe because we knew that he's watching us.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He was watching.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And she used to come to the factory to help out, his wife.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "She used to come.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "She didn't like to come because he always had a lover, always had a woman, lover, and she didn't like that.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "But when she was, she went to the kitchen.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "She used to cook up a storm, a lot of meat.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "She was so good to us.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "She was like a mother, wonderful.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Once, she passed me by.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She got a baked potato.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "She held a baked potato and the baked potato was hot.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how she hold it.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And she saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I was walking too.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "She took the potato and threw it on me, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "So I catched it, and that was hot.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "I picked up my [GERMAN] and holding that [GERMAN].",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And this I remember, and this I remind her when she was in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "She came to New York, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "I'm grabbing thing over thing.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "We honored her in that big hotel in New York.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "What is the name?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Plaza?",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It was a Jewish organization, a very religious Jewish organization who's all around the world.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They call it Aish HaTorah, Aish HaTorah.",
      "word_count": 7
    }
  ],
