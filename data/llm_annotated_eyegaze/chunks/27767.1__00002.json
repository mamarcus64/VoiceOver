{
  "stem": "27767.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Like I say, my-- my family was also some middle-class people.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "But they were struggling.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "They were working very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And some, they had some stores.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Others, they worked in different professions-- carpenters, tailors.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "They-- some, they worked in agriculture.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Some, they worked with-- they had horses and little wagons.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And that was, in general, the work what they did.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The Jews lived-- some of them lived in the middle of the town, in the center of the town, actually, because it was one main street.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "The whole town was a big main-- a long main street.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And there were some small streets besides.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Some, they lived on that main street.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And some, they lived in different small streets.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we lived in-- in the center of the town, but on a-- on a-- not on that main street, on a-- on a secondary street.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I recall very vividly.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Our house was built right on-- on a little river.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They called it Sasar in Romanian, or-- or [HUNGARIAN] in Hungarian.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And we looked from the window, and we had the river right-- right on our-- right near our house.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And we had the store in front of the-- in front of the house.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "The store in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "In the house.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Part of the house, the store, a small store.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And we had our bedroom there.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And we had a living room.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And we had another room where we-- I-- that was our room, my-- my brothers and myself.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We were four children.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "My brother, myself--",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name was Adolf.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And his Hebrew name was [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And he was four years older than me.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "He was born in 1921, May 10th.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And I had two sisters.",
      "word_count": 5
    }
  ],
