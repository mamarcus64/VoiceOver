  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 68,
      "text": "They threw over there, and it would have kept people to eat because there were no German no more.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 69,
      "text": "And finally, I was so fortunate.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 70,
      "text": "I caught a piece of margarine this big, long piece of margarine or fat or something.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 71,
      "text": "I was so happy.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 72,
      "text": "The same time another guy caught at the same time.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 73,
      "text": "Give it to me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 74,
      "text": "Give it to me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 75,
      "text": "It's mine.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 76,
      "text": "Give it to me.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 77,
      "text": "It's mine.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 78,
      "text": "It's mine.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 79,
      "text": "He pulled it out of my hand.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 80,
      "text": "He pulled it out.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 81,
      "text": "I look at him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 82,
      "text": "He's my father, and he was in the same train.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 83,
      "text": "I didn't even know about it.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 84,
      "text": "He was in a different barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My brother, he started to cry.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He said, how did you make out?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Where were you?",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He said, I was in the same camp.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "It was a different barrack in Neckargerach.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And he started to cry, and he kissed me and kissed me right on the train.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And I hurt, from the bottom I hurt.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Someone screamed.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "The opened up the gate from the train.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "I heard some screaming, Mendel, Heim Schteinberg.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Heim Schteinberg.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Mendel.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Everybody was calling these names.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Finally, my brother was walking around.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "He was in a different camp.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "They combined all these cars, that tunnel, they all belonged to Dachau.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "So they organized one train where all these people from all these camps.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "Finally, my brother, he saw me, oh, start crying.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "He wore a German uniform because he was naked.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And he took off a German uniform from a German guy who was killed there.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "When the Germans escaped, the first thing they did, took of the uniform, the SS, and they throw it away.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "They went away.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "They left with their underwear.",
      "word_count": 5
    }
