{
  "stem": "17625.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 133.2,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "She-- she-- she herself was in trouble, with a-- with a-- with a six-month-old baby.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And she gave me this.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I told her to-- and I took it from her.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And they loaded us on-- on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And they-- they brought also-- they brought-- they emptied out also, in Cracow-- it was a main jail, which was called-- a criminal jail.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "What was it called?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Montelupich-- Montelupich in Cracow.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "They emptied out the jail in Montelupich, and they made a transport-- us with them.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "So these were Jews and non-Jews in the jail in Cracow?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Criminals, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Criminals.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They emptied out the jail, and they send us on the railroad.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Stayed in jail.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Stayed in jail.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And this was the end.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "The end was this here.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "It was in Cracow, as I said, in January 19.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They shipped us.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And I'm familiar, because I-- I saw the way going.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It went-- went-- went towards my town.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And we learned that in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I saw already the lights, with the-- with the-- with the-- with the-- what do you call it?",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Where-- by the-- where the guards were there on the top of the-- and we landed there.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was already dark.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "It was winter-- 6 o'clock or 8 o'clock-- 6 o'clock and-- and-- so-- How big was the transport on the train?",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "How big?",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "How far?",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Not trains.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You mean-- you mean cars.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Cattle cars.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Cattle cars.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I suppose there are a few hundred.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And from there, it was more.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "So it was-- it was-- it was a transport.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I didn't count how many, but-- but they-- they took us-- they-- they took us to Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Coming to Auschwitz, [PAUSES FOR 5 SECONDS] when they unloaded us, I didn't even-- even know what I saw.",
      "word_count": 19
    }
  ],
