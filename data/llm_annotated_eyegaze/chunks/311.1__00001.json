{
  "stem": "311.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The Jews were the educators.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Most-- you know, the doctors, the lawyers.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "In Krakow.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And there were teachers not only for us.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I mean, there were teachers for the Polish schools.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I went to public school.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "It was, first I went with-- it was Jews and Polacks.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And then, I went-- there was only Jewish school, only boys.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And it-- it was closer.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And I don't know, my father liked it.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I didn't care for it, but he want it this way.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "About the seventh grade.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I must have started very early, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Before, before the school, they already send me to the cheder all the time.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "From three-- oh, I-- I used to-- after bar mitzvah, I used to cheat already, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I-- let's say I didn't like too much the cheder.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't too anxious about it.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "They had very great teachers.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I like-- I was occupied.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I don't know, I had-- I wanted to go play soccer, instead.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I wanted I wanted to be-- a little thing, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I-- For some kind of reason, I was [LAUGHS] the black sheep in a religious family, who just didn't like the cheder.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "It-- it-- and it didn't go into my head, either.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "You know, I wasn't a good student.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Leshon Hakodesh.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It was Leshon Hakodesh.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "OK, so it was not a Zionist sort of Hebrew school?",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No, no, oh, no.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "There was a Rabbi.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Not a Rabbi, it was a, how do you call it?",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "A melamed, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And he used to punish us.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And he used to screw it in, and it didn't go in my head too good.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "It didn't work out.",
      "word_count": 4
    }
  ],
