{
  "stem": "15193.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "When I came to graduate from my school, grammar school, I did not want to go to high school, because I did not want to be exposed to that kind of treatment.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "In grammar school, we found a little bit of harassment.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I remember that our teacher would sometimes be a little short on us and would give us bad marks.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And-- but not as bad.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "It was not as bad as my brothers experienced in high school.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "So when I graduated, I wanted to go to business college, out of Kaukehmen, to Tilsit.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I was accepted.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My family, we were-- the boys were all, after graduation, they had to be trained in business.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And they all left-- these two boys.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I had Paul and Esau, and they were trained in the business world in different cities.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We had to pay the big companies for them to train my brothers.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My sister Jenny, who also graduated from high school, became a legal secretary.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And she left for Berlin to work as a paralegal secretary in Berlin.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My sister, Dora, she was trained to be a seamstress, but she didn't like it.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So she was trained to be a secretary.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And she worked as a cashier and as a bookkeeper in a Jewish department store in Konigsberg.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My family, because being that I was born during the First World War, it was very hard.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "When I was two years old, we moved into a larger apartment and which had a store.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And my father would supply farmers, small and big farmers, with material and fur to make suits, coats lined with furs, and he would travel.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We had a carriage and a horse.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And he would travel to visit the farmers.",
      "word_count": 8
    }
  ],
