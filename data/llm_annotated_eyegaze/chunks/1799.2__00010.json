{
  "stem": "1799.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "We had rations that were given to us once a day of a bowl of soup and a hunk of bread.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And the soup, sometimes, was lots of water.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "There was hardly anything in the soup, but it was hot.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And the hygiene conditions were substandard.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And the work was quite demanding.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were pressing gun shells into, you know, with a machine into-- from powder into shells.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And the pace of the work was incredible.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And you had to produce x many, you know, x many shells, various dimensions.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, at that point, it was pretty well automated.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We used machinery.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "The strength-- the following camp after that one was where you had to use strength, And that was a coal mine where I worked-- and it was winter, also, where we were tending to a lorry.",
      "word_count": 36
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Those are cars that you tilt sideways that were loaded with slag coming out of the coal mine.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And that was physical work, where you had to push them and undo them.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "That was back in Silesia.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "That was in the spring of 1941, spring of 1941.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I don't quite remember the name of that particular camp.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry, 1943.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I didn't get there until 1942-- 1943.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Spring of 1943.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In the coal mine-- and I did not work in the coal mine.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I worked on the top surface dealing with the slag of the coal mine.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I was there about four months.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "They got progressively worse.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Conditions got worse and worse, to where people were bartering for extra food with whatever they could manage to-- like some people were dealing with cigarettes, and some people were dealing with some food that they may have stolen from a guy next to them who was sick.",
      "word_count": 48
    }
  ],
