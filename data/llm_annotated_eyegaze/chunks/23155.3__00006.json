{
  "stem": "23155.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "On one side they were on the water, the other side on the street.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And they were in two big rooms with 500 girls, I believe.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And that's where we stayed, and we went to work.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "The first night we experienced a very violent storm or whatever it was.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "We didn't know what it was.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It was an air raid.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "We were not going anywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "They didn't take-- let us go anywhere.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "We stayed, and the air raid was going on.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And in the morning, we saw some places burning and things like that.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And we went to work.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "They assigned us to different places.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I went to a factory where we were cleaning up things.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "We were walking here, there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "There were air raids during the day.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "There were air raids-- air raids during-- air raids during the night.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "We were working with bricks.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "We were moving them from one place to the other.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "Most of the time, we were just standing there.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "We didn't get much to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "We-- we got to eat where we worked, so that wasn't too bad.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "What we lacked was sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "We were just like in a daze all the time, because we had to get up very early.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "During the night, we had the air raids.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "And so we lacked sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "We stayed there in Freihafen, I believe, till the beginning of the fall.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "I'm not quite sure of the time, how long.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "From there, they moved us to Neugraben.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "That was a little camp.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "We were just the 500 of us.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "And we were doing all kinds of things.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "We were brought in a-- in a sandpit, taking the sand and putting on little wagons.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "And I was not working in the sandpit.",
      "word_count": 8
    }
  ],
