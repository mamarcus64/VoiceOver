  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And as I was walking, right next to rails-- railroad over there to the station, I saw a German tank pointing the gun towards a group of Russian soldiers with their hands up.",
      "word_count": 37
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And I was walking right next to the tank, not realizing what's going on, with the uniform of the railroad I was wearing.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And while they were busy with the soldiers, I went behind the tank.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I ran up to the railroad.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And I looked over there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Nobody was there already.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "They evacuated in the middle of the night most of the locomotives and cars that was stationed over there.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I was confused.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "So I ran, and I found my suitcase that I had in one of the warehouses.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And I ran towards the smoke that I saw further up and-- that the locomotives-- I saw them leaving slowly.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "So I ran towards them, where one of my friends that was also going to the same school recognized me from far.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "He slowed down the locomotive.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And I jumped on it.",
      "word_count": 5
    }
  ],
