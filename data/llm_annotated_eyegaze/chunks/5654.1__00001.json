{
  "stem": "5654.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And I think he was also doing things with my uncle, my mother's brother, who is today, incidentally, still alive in Paris.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "He's 89 years old.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "His name is Cybulski.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Maurice Cybulski.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he has a son, my cousin.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "His name was Henry, Henry.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And we see each other whenever we can.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "We speak to them on the phone and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And I'm very fortunate to have that, at least, left over.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "He's still alive.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Very vaguely, I know that my father was-- well, of course, we were a very close family.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I was his-- I wouldn't say favorite, but because I was the youngest one-- and if I didn't eat, I remember he used to say to me, if you eat your meals, then I'll give you 20 centime and you can go down the road and buy some halva.",
      "word_count": 50
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Because I was mad on halva, even today.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So being a Jewish quarter, we always found somebody who was making halva in their area.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "In-- near-- it was Belleville.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Belleville is 19th arrondissement.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And your family?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Your brothers and sisters?",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We were-- right up to present time, we were together.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My sister is six years older than I am.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Her name is Raymonde.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She, she lives in Switzerland.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "She's married, and her name is Feuerwerker.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And she has two, two girls, Shulamit and Beatrice.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Beatrice lives in Geneva.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Shulamit lives in London, and she has three children.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And Beatrice has two children.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "My brother lives in Switzerland, as well.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "He has two, two boys.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Two boys and a girl.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "His name is Henry, Henry.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And he's 19 months older than I am.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We, we speak on the phone quite often, and I saw him recently, in January.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I can't-- no.",
      "word_count": 3
    }
  ],
