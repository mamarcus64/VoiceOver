{
  "stem": "58.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "Once, I still have a mark on the skin, like a burn on the skin.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "And the other one I was in my-- got my shoulder.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "About 10 people died, and we all backed out.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "We opened fire also, and about 10 people died.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And now I'm going to come back to Majdanek.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "When I came into Majdanek, I had my bullet.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "It must have come from far away.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "It was stuck in my shoulder.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I asked if there are any doctors.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They say, doctors?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Butchers.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They called and two guys came in.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They told me to lie down on the table and move-- move out when my-- where the bullet was, to move out of the table.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They-- I don't know what they cut it, a razor blade or a knife.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "They cut it open and the lead fell in the glass.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But it was already infected, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They put in some gauze.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They washed it out, put in some gauze.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And the next day they came and started pulling it out.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It-- it was hurting like hell, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It was dry.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "But they did the best they could.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They cleaned it out again.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "They put a band-aid about two inches wide on it.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And then I'm coming back to going to Skarzysko.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They picked the people to go to Skarzysko and I-- I went in line.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I said, anything will be better than here.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And they told us we were going to an ammunition factory to work.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] I stayed in line, and they used to have the SA and SS.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "The SA was Hitler's first support group.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He was-- they were the SA.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "A tall guy, about seven feet.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "His name was Zeidel.",
      "word_count": 4
    }
  ],
