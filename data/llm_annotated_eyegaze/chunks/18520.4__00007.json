{
  "stem": "18520.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "I'm crying now, a happy cry.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And this what was.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "You had-- was no had, was no had.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "You were a plain dumb person, plain dumb-- nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "You licked from the floor, you-- you-- you eat worms, you eat grass.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "I ate grass.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "I had a grass that was delicious, sweet as sugar.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "We were going like-- like-- like sheeps.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The trucks that took us to the hospital, where the hospital is, [YIDDISH].",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We got-- if this was a crematorium, you go to the crematorium.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "They-- they-- they were clapping on your back, helping you walking into the truck, helping you up to the truck, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "They put down things that you can walk up, human.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "So-- so it was good.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "You saw.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "They put you in the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "You saw that you're going from bad and not for worse.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Right in this town.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "A few days.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was good.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "I was walking, just not eating.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "They didn't gave you food.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "They gave you just cereal a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "Thousands of people, even from this group, thousands died-- thousands died of dysentery.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "Dysentery, how you say it?",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Dysentery.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "They died.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They couldn't eat, and they came in and ate everything, fill it up.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And they died, destroyed-- thousands, thousands.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I was walking with another guy.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I was walking by foot till Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "A nice few miles.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I don't know-- 40, 50.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "I was walking to Munich to go to the camps there to see if it's-- because they start making names and a shield on the outside to see who was in the camp, your names.",
      "word_count": 35
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "We start looking--",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "We were walking.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have-- I didn't-- oh, how I did connect.",
      "word_count": 10
    }
  ],
