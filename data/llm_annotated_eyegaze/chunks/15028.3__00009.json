{
  "stem": "15028.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The name of the factories in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "They made machine-- tanks, guns.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "They had factories all over Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They had factories in the tunnels in the mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And I-- this Funfteichen was [GERMAN] factories, I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "I don't know how many people we were there when we came there, put us in a barracks, on the same type of barracks.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "There was in late August, August and September.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "On Film was I came already in the fall and winter.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And we went out to the [INAUDIBLE] to work every day from morning till night.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "I still had my friend Yankev Hirsch from the town of [NON-ENGLISH] with me.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "And he became already-- he had swollen feet from water in the feet.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "He got [INAUDIBLE] or whatever he developed.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "And I was already in-- in that camp, we had Jewish blockeldester.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "Instead of German, we had Jews as blockeldester.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "And we had Polish-- I had a Pollock, Polish, blockeldester, kapos, and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "And there already in that camp, you had French people-- Jewish from France.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "You had Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 17,
      "text": "You had Czechoslovakia.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 18,
      "text": "You had from all over.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Jewish, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And we-- in December, 19-- end of December, 1944, I think, and beginning of January, it was very cold.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "The order came that we gonna march-- close the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And we marching.",
      "word_count": 3
    }
  ],
