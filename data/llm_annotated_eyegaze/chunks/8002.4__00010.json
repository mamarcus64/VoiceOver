{
  "stem": "8002.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And he'll make out a check.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And that was Friday.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And the accountant is coming in Monday.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "I says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "You just took in $700.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "Give me $25.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "So, oh, you count my money?",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "I say, I didn't count.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "I know what you got.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "He says he's not going to give to me.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "I said then somebody else will come in and collect.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "So he got mad at me, and he took the knife sharpener.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "That's a big iron.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "We call it in Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And he went after me.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "He was in the 70s.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "So I says to him, look.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "Put this away before I break your arm.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "And he looked at me, and he put away.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "And he went, and he picked up the butcher knife.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "I grabbed him by his chest.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "And luckily, he was wearing a pelt, because he was going in the freezer.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 13,
      "text": "And you had to have warm clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 14,
      "text": "So I picked him up, and I hung him right on the hook.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 15,
      "text": "And the woman started to scream and called police.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 16,
      "text": "And the police came.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 17,
      "text": "And they put me in handcuffs, my hands behind my back.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "And luckily, the sergeant was Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And he told me his name is [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And I says to him, I came to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And now you put me in handcuffs?",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "For what?",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "I didn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "He took the knife to me.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "He says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "I have a friend of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 9,
      "text": "He's a judge, Judge Leibowitz.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 10,
      "text": "He lives on Pitkin Avenue.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 11,
      "text": "I says, you'll call-- call up the judge and see what he can do?",
      "word_count": 14
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 12,
      "text": "So he called up, and the judge says to bring me right over.",
      "word_count": 13
    }
  ],
