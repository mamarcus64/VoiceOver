{
  "stem": "25834.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Cared about the family.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Very ambition.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Very handsome.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And [PAUSES FOR 3 SECONDS] helped people if he found it possible.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And everybody liked my father.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Anna probably was the best mother.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] Oh, something vacation, small vacation.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We was together, the four-- four of us, [PAUSES FOR 3 SECONDS] in the place where, you know, was very nice scenery, near the Vistula River, maybe 50 kilometer from Warsaw.",
      "word_count": 35
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "We spent, one time, a very nice vacation and four children, father.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And that was one of the nicer time in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And still, we was working very hard, I mean our parents.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Sometime my father took-- took two jobs to support the family.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And was all the time successful and was [PAUSES FOR 3 SECONDS] a person who can work and with everybody and has very good reputation, like man who you can trust.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "My mother, in her house, was a little bit firm, streng, keep the family together.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "For example, father never beat the children.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Mother-- [LAUGHS] sometimes with stuff.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS] And was very good person.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "No, I think so-- I was-- I was all right.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My parents has not problem with me, in other words.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "What kind of child I was?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] I know only opinion.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I was very [PAUSES FOR 3 SECONDS] quiet and listen parents.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "That's parents' opinion not mine.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And in the school, for example, in Poland, this time, up to '39, was very hard support for children in a school.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "Because tuition, in the school, in gymnasium, was very, very costable-- costs money.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I was in a school, in a state school, a gymnasium, where I pay only not 65 zloty.",
      "word_count": 19
    }
  ],
