{
  "stem": "8569.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He gave him some money, and my sister was supposed to bring him the three legs of the piano to get the rest of the money.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And she did.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "She went on to the other side.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "There was one of the passages that you can still go from the ghetto to the Aryan side through the house of the-- courthouse that was on the border of the ghetto and the Aryan side.",
      "word_count": 36
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And she took the three legs, and she went to collect the money.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "She got the money.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And as she was coming back, the people that were supposed to transport the piano were going after her.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "They robbed her of the money.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And they told her, if you don't give us some money, we will tell-- we will give you to the SS men telling them that you are Jewish.",
      "word_count": 28
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "So no legs, no money, no piano.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "That was just of a little incident.",
      "word_count": 7
    }
  ],
