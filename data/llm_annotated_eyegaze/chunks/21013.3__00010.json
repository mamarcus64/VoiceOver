{
  "stem": "21013.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And everybody had somebody waiting for them at the ship except me.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And I was there 'til about 7:00 o'clock at night and nobody came.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I'm sitting there with seven suitcases alone in the dark at the dock.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And nobody came.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And I finally found the phone number of my uncle in one of my suitcases and called.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And they lived in Brooklyn and I had to wait another hour before he and his son Merril came to pick me up.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "And they came in that great big car.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "And the radio was playing in the car and it was Toscanini conducting the and we went over the Brooklyn Bridge and it was so beautiful.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And I stayed with them for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And then my telephone book uncle from Chicago was in New York on business.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "And I went back by train with him to live in Chicago.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And their name was Schneider, Benjamin Schneider.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And I lived with them for several months until I found a place of my own and-- and a job.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was an apprentice to a dress designer at a dress factory in Chicago.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And it was my aim to become a dress designer, because I liked to draw and I thought all I would have to do is draw pretty pictures.",
      "word_count": 28
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "What I didn't realize is that a dress designer had to make patterns and be a dressmaker.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't like that part of it.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And that's where I met my first husband, who was a salesman.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "His name is Charles Rubin.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And I was married to him for 28 years and we had a wonderful daughter.",
      "word_count": 15
    }
  ],
