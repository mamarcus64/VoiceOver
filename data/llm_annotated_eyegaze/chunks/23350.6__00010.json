{
  "stem": "23350.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We were not allowed to go out during the week because we had to-- after work, we would come home, have a meal, and then we had to see to our own things like washing and ironing, whatever we needed to do for ourselves.",
      "word_count": 44
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And in the evening, we were not allowed to go out anyway.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "The only time we could go out was Saturday night and Sunday night.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And we had a very rigid matron.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Miss Gostle, she was as big as this room nearly.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I mean, big woman.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "And a very, very-- she was very bossy.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And we knew the rules.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "She told us the rules, what we can do, what we can't do.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "So we knew that we can't go out in the evening.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "Well, when I met up with Kurt on Sunday, he telephoned Sunday evening.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "Wait a moment.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Sunday evening.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 5 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "It's was Sunday.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "No, not Sunday.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "Monday.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "He telephone Monday evening whether I could come out for a little while just to talk to him.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "So I said, I cannot come out.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "I'm not allowed.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "I know my rules.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "And I'm not going to start saying anything to my matron because she wouldn't allow me.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "He carried on so long and so long that I said, well, look.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I'm not going to ask her.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "If you want to speak to her, you speak to her.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "But he had so much charm.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "He was such a charming man.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "When he started to speak to her-- and I knew that she would never let me go out.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "As soon as he spoke to her, she says, yes, Minia, you can go.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "She let me go out.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So we went up and down for a walk.",
      "word_count": 9
    }
  ],
