  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "Paris was occupied June the 14th.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "They came down in the [INAUDIBLE] machine guns and message.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So I was wounded, and I-- [PAUSES FOR 3 SECONDS] it was June the 17th.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Early in the morning, I only remember one thing [INAUDIBLE] holding the position.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We were sleeping on our bellies, and I said to it-- with my arms I made like this.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I said, it's raining.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I woke up.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "When I woke up, I saw the sun.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "There was standing a guy, who had the Red Cross.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And he said to, to me-- he said to me, he said, what are you doing here?",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I only remember, I said, save me.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Later on, I realized it was a student, a Romanian student.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "There was a medical school, and he, he was-- he became a volunteer.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He volunteered to the army.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And that was the guy.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I never saw the guy.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I never heard any trace from the guy anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I was brought into the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And the hospital, the first thing there was on stretchers, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] When I saw the sun, must have been maybe 6:00 in the morning, or 5:00 in the morning.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It was summer already.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And so the three stretchers.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I am [INAUDIBLE] two guys on the stretcher bed.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] So the first thing, they didn't look even what I have anything.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They give an injection, a tetanus injection.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] In-- [PAUSES FOR 4 SECONDS] in the same hospital in the morning-- this was already the 17th in the morning-- I came in the morning, very early in the morning, they said, anybody that can walk should walk out.",
      "word_count": 43
    }
  ],
