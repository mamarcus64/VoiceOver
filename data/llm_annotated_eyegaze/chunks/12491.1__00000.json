{
  "stem": "12491.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Joseph Lipschutz.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "L-I-P-S-H-U-T-Z.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Jowzef Lipschutz.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And it was spelled J-O-W-Z-E-F, L-I-P-S-C-H-U-- umlaut-- T-Z.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "November 1, 1918.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "77.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Crakow.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "K-R-O-W-- I'm sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "K-R-O-- umlaut-- W.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "No, I think I was wrong.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "K-R-O-K-O-- umlaut-- W.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father?",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My father's name was Abraham.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He was a merchant.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He had a dual way of making a living.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He had a small store in downtown Crakow, consisting of-- with selling gifts, primarily food-type gifts-- chocolates, fruit baskets, et cetera.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Rozalia.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "She was helping out in the store pretty much from Monday to Thursday.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Friday, she was preparing all day long, for the-- for the Sabbath.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And she did not work Saturday and Sunday.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "The store was closed.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, I do not.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Predominantly Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But my parents spoke Yiddish to each other if they did not want us to understand what they're saying.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, of course I do.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Our home was an apartment consisting of three rooms, a kitchen, and a small hallway.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] We-- my parents occupied one of the rooms, which was the last room in the apartment.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And the other room was kind of a dining room.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But it had two beds in it.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And one more room, which was-- we used to call it a salon.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "But it was, like, kind of a living room.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And there was also two beds in that.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "The kitchen consisted of coal-burn oven, and a small gas-burning stove with two burners.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Two tables, one for [NON-ENGLISH] and one for [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And we had a maid who slept in the little hallway.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My parents, or my father especially was, quite religious.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Even though he was not Hasidic.",
      "word_count": 6
    }
  ],
