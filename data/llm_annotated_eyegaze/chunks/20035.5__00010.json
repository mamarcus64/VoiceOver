  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Bad Reichenhall was the headquarters of Hitler during in the wintertime, so there was tremendous amount of American soldiers there, where we first time started to get help from the American soldiers, where they first then they started to understand that we have there hundreds of kids, and hundreds of little kids, I mean, babies, from practically babies to seven, eight, nine-year-old.",
      "word_count": 62
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "That was-- they were the big kids.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So we started to organize them and try to teach them.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Part of the teaching was a horrible teaching, of trying to learn how to be quiet, how to suffer, how not to ask for drink, how not to ask to go to the bathroom, because this way, the kids won't be prepared.",
      "word_count": 42
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Our job was to prepare them to go on Aliyah.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "They are the one who were put on boats.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They were the one who were put on ships and sent to first possible way to go to at that time Palestine.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And it wasn't an easy task.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And it wasn't an easy task for-- for kids with whom you spent two, three months of-- gave everything what you had.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Then you had to go and cross another border and come back and bring back new kids, because these kids were gone, so you had to start with a new family.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They became your family.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] A couple of months ago I had a visit here.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I got a phone call from a-- one of my kids.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "He's an Israeli Merchant Marine captain.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "But he was one of my kids.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Most of the kids, where they went to Israel to [INAUDIBLE], which is a kibbutz where most of them went.",
      "word_count": 20
    }
  ],
