{
  "stem": "1222.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They wanted to have us there.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I explained him.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I said, I want to go quietly.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Maybe in time, I'll go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I have relatives in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Maybe I'll go to the states, or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "He says, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "They give me some money and we went away legally.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I came in with the train legally all the way Lodz, [NON-ENGLISH], by the train.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The war was still going on after.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It was deep already.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It was already in-- in close-- I would say very close to Berlin.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It was-- they were fighting there like crazy.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "We saw the paper.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't in much TVs, but we saw.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "So when I came in the first day, I went into the Polish government.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "It was already a Polish [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "They told us, go in that-- in that building.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I went to that-- in that building.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "It was, I think-- I don't remember-- it was 16 or 17 Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And they give me and my friend-- no, my friend didn't go that time yet.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "My friend was still in Miedzyrzecz, by the way.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "He was still in the police.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "They would not let him go yet.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "I went away.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "They give me a room.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "I hear at nighttime, about 2:00 in that nighttime, screams.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "God, God, God, God, God, and screams.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "No shooting.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "I was in the second floor.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "I broke the window, and I hang down, and I jumped in the street-- people walking and everything.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "In the morning, I saw it in the paper.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "It was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "That's the Polish gangsters, like the mafia.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "They didn't want to have any Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "They didn't want any witnesses.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "They slaughter them with knives.",
      "word_count": 5
    }
  ],
