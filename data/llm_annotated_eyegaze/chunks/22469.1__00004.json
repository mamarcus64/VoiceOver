{
  "stem": "22469.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "Because they made a law, what is numerus clausus.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "What they mean, limited-- limited number of Jewish students could study medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "So most of Jews, they went to Prague, to the Czechoslovakia, and Italy, even to England.",
      "word_count": 16
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "I went to a master what was painting and decorating.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And I start to learn.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Painting houses, flats.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my first master what I was learning, was Weinreb.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I can spell to you Weinreb.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "W-E-I-B--sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "W-E-I-N-R-B-E-B.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Jewish.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No-- yes, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Even though I went-- after the-- when I was already skilled, I went to a master, Polish master, was very good to me.",
      "word_count": 23
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And his name was Twardowski.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "You want to have to spell?",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "T-W-A-D-- no, sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "T-W-A-R-D-O-W-S-K-I.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he respect me.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "Because until today, I think I was good painter.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "All together as a painter and decorator?",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "The last job was in '39.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "I was working in another Jewish master.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "His name was Traub, T-R-A-U-B.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And we had been working for a very known optician doctor.",
      "word_count": 11
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "And this optician doctor was married, Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "He was-- had been married with a Jewish woman.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "Because of that, when that Germans came, they took his flat, what was 10 rooms.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "And in this flat was a German general.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "And when the German came, the house, it wasn't ready.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "So the German force us to carry on until the house is going to be finished.",
      "word_count": 16
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "So we-- I was-- I was in this house for the general-- painting.",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Another three, four months.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "With another friend.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "With another friend, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Not very much.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Because this time they already force us to work.",
      "word_count": 9
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "Carry on the David star, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "So everybody saw I'm Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "And it was not very pleasant.",
      "word_count": 6
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "My brother was in pharmacy.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "And he was working.",
      "word_count": 4
    }
  ],
