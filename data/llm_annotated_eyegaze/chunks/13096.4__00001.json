{
  "stem": "13096.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "Once I was telling you about my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "She was very thin, which usually she was plump during all the-- usual time.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "Eventually, one day she said, listen, I've got enough.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "I can't live anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "And I'm feeling very sick in they way that I've got this sore-- I've got a earache.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "Must be an infection.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "I want to go to hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "I beg her not to go.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "But she say, I can't.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 30,
      "text": "Listen, I will die all the same you know, in the-- in the counting or the appell, whatever it is.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 31,
      "text": "That is in the 40 days that we had the quarantine time.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 32,
      "text": "She said, I'll go to the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 33,
      "text": "Whatever happen, happen.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 34,
      "text": "I heard that in the hospital, from other prisoner, in the hospital, they give you a pill when you go to sleep.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 35,
      "text": "And in the morning they find you dead.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 36,
      "text": "It was poison.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 37,
      "text": "I say, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 38,
      "text": "You want to go, you rest.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 39,
      "text": "But don't take any pills.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 40,
      "text": "Whatever medicine they will give you, they will take-- you will take there not any pills.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 41,
      "text": "She promised me.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 42,
      "text": "She promise me not to take any pills.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 43,
      "text": "Eventually, you know, she-- that night, she went.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 44,
      "text": "And they give her the pill that she told me afterwards.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 45,
      "text": "She didn't took it.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 46,
      "text": "And she took it, she put it under the-- she put it under the pillow.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 47,
      "text": "It was the-- not the pillow, under the straw.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 48,
      "text": "There was no pillows or-- or mattresses or anything.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 49,
      "text": "She put it under the straw in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 50,
      "text": "She was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 51,
      "text": "You know, the hospital, there was straw in the-- in the-- in the planks.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 52,
      "text": "But where we stayed, there was no-- no-- no straw in it.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 53,
      "text": "It was just planks.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 54,
      "text": "I'll tell you just now, what that our bed consist of now.",
      "word_count": 12
    }
  ],
