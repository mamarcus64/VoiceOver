{
  "stem": "13063.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Moshe Taube.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was known in Poland as Maksymilian Taube.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "They called me either Moshe or Monusch.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "T-A-U-B-E is my last name.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Moshe, M-O-S-H-E.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Or, Maksymilian, M-A-K-S-Y-M-I-L-I-A-N.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "This was my name at birth, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Not that I'm aware of.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My Hebrew name is Moshe [HEBREW].",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Which means, he was drawn out from water.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And in my life I was really in much of deep water.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born June 17, 1927.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I am, today, 69.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cracow Poland, [PAUSES FOR 3 SECONDS] which was the cradle of the Jewish culture, Jewish learning, and Jewish scholarship.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Emanuel, E-M-A-N-U-E-L.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And my mother's name was Rachel, Hebrew, or Regina, R-E-G-I-N-A.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was usually called Regina.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Rachel she was called only when [LAUGHS] somebody wanted to make her feel good, like my grandmother or some sisters of hers.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father was an industrious man, a man of business.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He had a very great knack of-- for travel, for-- for-- for [PAUSES FOR 3 SECONDS] entrepreneurship, as we say it.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] My mother received a dowry from her family, and the dowry was a house, which later was sold and converted into a-- beginning of a shirt factory.",
      "word_count": 31
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "My father was, of course, the head of the enterprise.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And we had also a partner, whose name was Avrum Wrobel.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Wrobel.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Yes, he was a-- he was [HEBREW].",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And since my father came from a dynasty of [HEBREW], so the partnership was only natural between him and Wrobel.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "W-R-O- with the [INAUDIBLE] B-E-L.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, he and his family were all exterminated during the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The business was named as a shirt factory, [FRENCH] [PAUSES FOR 3 SECONDS] which is like a-- like a French name.",
      "word_count": 21
    }
  ],
