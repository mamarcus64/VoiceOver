{
  "stem": "10098.7",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "While they were sucking in my blood out, they were arguing, the two fellas.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The older doctor was a hell of a nice guy, and he told him that's a Jew-- good boy.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He didn't say even Jewish boy, he say he's a good boy.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Then he asked me to mentally-- any retarded or something.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Then he asked me, do you ever had sex?",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I say, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So the younger doctor turn around and said, I bet you he had sex with a German girl.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I say, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "With Polish girl?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I say, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Jewish-- yeah, yeah, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And they start talking about, and then the doctor-- the older doctor was a hell of a nice guy-- he turned around and ask the German, a young doctor, he asked him, did you ever have sex?",
      "word_count": 37
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "He said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He-- he have to be [NON-ENGLISH], he have to be married to have sex.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And he start laughing up there, and then they applaud me, and older doctor give me a ham sandwich.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Some kind of sandwich.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I don't know what it was-- ham, or beef, or horse, I don't know-- and give me a cookie, and shake hands with me, and told me good luck.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Out of my arm they got my blood, right out of my arm.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And he was abed.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was mad.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I figured, you son of a gun, taking away my blood.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And-- and the German, the younger officer, he-- he was not happy taking Jewish blood.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And the doctor said he got good blood.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I think he told him one time he got as good blood as you or better, real good blood.",
      "word_count": 19
    }
  ],
