{
  "stem": "2830.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "They apparently had enough food, things what they needed.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Underground, a bunker.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Bunker.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And the-- [SIGHS] --they had everything in there.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And so we said goodbye.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "My mother had her earrings-- she took them off.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "She said to my sister-- I remember that was on a Friday-- you take them.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "This is gonna probably help you to survive when you need, you know, to buy your time.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "She said, I can't take them.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "You keep them in your ears the way you always wore them.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "And I was shivering.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "I came up with the idea, actually, to go in on Aryan papers.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Because I hear-- overheard what they said in the, you know, in--",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "--about the Judenrein.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] And-- [CRYING] --she said, take care.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "She should take care on me.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "She didn't leave.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I weren't in the bunker yet.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Because we said goodbye.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "After we left.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "We left.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "We started walking.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "[SIGHS] And we walked-- I don't know how long, maybe a 1/2 a day.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "She kept the earrings.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "She said, don't.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "So we kept walking.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And then my sister remind herself, there is somebody who is doing something, you know, hiding you out.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "She knew a woman.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "This woman, she takes money for it.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And she hides you in-- because if it's only two weeks, you know, we can survive.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "We walked in.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "She said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And she took our things, what we had with us.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "And she put them in-- there was-- she had one room in a barn where the cows--",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "--you know, next to the cows.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And then she said, you can stay here.",
      "word_count": 12
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "That was on a Friday.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Saturday-- Sunday she went to church.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "She said, she's going to church.",
      "word_count": 6
    }
  ],
