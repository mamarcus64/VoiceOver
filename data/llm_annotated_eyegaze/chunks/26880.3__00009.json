{
  "stem": "26880.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I know, I go, [INAUDIBLE] I'm keeping you.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "What, I became a butcher?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "'49.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "October '49.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In '49 and then I was working one day, and he told me I'd have to work on Saturday.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Then I was back in the-- back in the day [INAUDIBLE] and he said no not help, you want to you go for six days-- five days.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Angry, well, who can say five days-- now, not six days-- he say to me, he says, yeah, I know.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But you said should I work Thursday.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, Thursday, too.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "You want should you work all week and one day, Saturday, I should go looking for another man?",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And they didn't want keeping me, and they send me away.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I know they sent me.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "I said not very much to go away.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "I mastered all right, and I know I was keeping well the-- just looking for butchers.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "My son asked where your butchers, you stay kinsman.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "Well, they are kosher butchers.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "So anyway they are kinsman.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I got [INAUDIBLE] but I was working.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And I came over there, then I came to one man, he told me, OK, you want to-- I don't need a butcher.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "No, you want $25 a week, then you can stand to working.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And I decided I go working $20-- I left a job up offering $65, and then I started working for $25.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And then the whole family had told me, [NON-ENGLISH SPEECH] to America.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They used to tell me, who is not working Saturday?",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You want to eat bread, you have to work on Saturday.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Then God made-- was showing me a miracle.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I was-- I never showed to them a miracle.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I didn't want to work on one day, Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And anyway, I became here in America rich.",
      "word_count": 8
    }
  ],
