  "elapsed_s": 105.0,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was living with very close cousins of mine.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "But once I entered in university, I took my own small apartment because I was receiving scholarship.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I received a scholarship that was the highest scholarship.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "In the entrance of my examination, I received this very special-- [PAUSES FOR 3 SECONDS] here would say A with two pluses in my entrance examination, which allowed me immediately to receive after that very high special scholarship.",
      "word_count": 38
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "This was one of the good thing that the government of the socialist country used to provide-- conditions for the education of the young people that are very favorable for their development.",
      "word_count": 32
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I was able, in this time, already, to start build my own life.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] Very close to the end, I took the last few years in one.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I took all the examination in order that I have my, my first baccalaureate bachelor-- finished there.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I win [PAUSES FOR 4 SECONDS] one internal audition for going to study in Moscow.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] I studied there as a [NON-ENGLISH], meaning external student, something like post-graduate studies, with one of the greatest teachers that they had in the time, David Oistrakh.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I had possibility to take some lessons in composition with Dmitri Shostakovich.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS] I stay in Russia approximately three years.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Upon my return, I-- in the beginning, I become assistant professor in the conservatory of Sofia.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And later on, parallel with that, I become one of the concert artist of the concert direction of Bulgaria.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They had this kind of direction that this-- only one, and controlled by the state.",
      "word_count": 15
    }
  ],
