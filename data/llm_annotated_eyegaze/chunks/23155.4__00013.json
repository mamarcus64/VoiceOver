{
  "stem": "23155.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "People were quite surprised that I'm speaking still Czech very fluently, even though it's not my mother tongue.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I met people whom I knew through-- after-- when I came back-- two young-- at that time, we were young girls, with whom I went dancing.",
      "word_count": 26
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "One is a widow also.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "One never got married.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I-- I met a man whom I knew before I left.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He was-- he's a surgeon.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "It was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "He took me to the opera.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "He took me to dinner.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "We had-- we had very nice times together.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "It was-- it was really funny.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "It seemed like the time in between does not exist.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "I'm back, like, 46 years.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] [PAUSES FOR 3 SECONDS] So now I'm back at home, and-- and I'm trying to make the best of it.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I hope that [PAUSES FOR 3 SECONDS] I was kept alive so that I could be a witness to what happened, because we have so many people who are deniers of the Holocaust.",
      "word_count": 34
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And I think that I was left alive to be the witness and to be the spokesperson for six million who do not have a voice anymore.",
      "word_count": 27
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Yes, that was my purpose of my trip to go to Czechoslovakia to see Mrs.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Gerstl, who is today 95 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And it-- she came to be with me 20 years ago.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "But my son said, Ma, you better go and see her.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "You know, she's 95.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "She's not going to wait for you much longer.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "So you better go.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So I-- it was on his urging me that I went, and I'm really very happy that I did.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I stayed with her.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "She cooked every day for me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "She looked after me like I would be little girl.",
      "word_count": 10
    }
  ],
