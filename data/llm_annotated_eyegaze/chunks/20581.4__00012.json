{
  "stem": "20581.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "On top of my uniform-- it was a rainy day-- I'm wearing a civilian raincoat.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I'm having with me, papers, passports.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We had to bring some Israelis from the government, we had to bring them to Salzburg.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So we made false passports for them.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "So I had about seven passports in my pocket.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I had the list of the people who I'm taking.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I had American dollars with me, which was illegal.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I had German Reichsmark, which was illegal.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And I had Austrian schillings, which was legal.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Two MPs come over to me.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And they said, papers.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Because my English, even it's bad now.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "But it wasn't-- it was much worse.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know much English.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "I knew a couple of words in there.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "[INAUDIBLE], papers, papers.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "Show them papers.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "Guy says, come on.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "Take you away.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "They put me in a Jeep and they bring me to the headquarters, to the American headquarters, army headquarters.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "Bring me to American headquarters, they start searching me.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "They find all these goodies what I have.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 22,
      "text": "And they say, well, we gotta put you to jail.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 23,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 24,
      "text": "Put me in jail.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "Put me in jail.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "I was there for a couple of days.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "In the meantime, nobody knew where I disappeared.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 28,
      "text": "This friend, this-- my boss, I mean, he was a friend and a boss.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 29,
      "text": "His name was [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 30,
      "text": "He was in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "They call in Innsbruck.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Jonalah ?] didn't arrive in there.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So they start worrying.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "They say, what happened to him?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Nobody knows.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't communicate with them, with nobody.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "So finally, after a few days, I became friendly with the prison guard.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "You know, I had cigarettes I had with me.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "In that time, cigarettes was a great thing.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So I smoke a cigarette.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I start smoking.",
      "word_count": 3
    }
  ],
