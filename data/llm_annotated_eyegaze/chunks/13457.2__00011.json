  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "His grand total weight at that time, I think-- I think was maybe 40 kilograms, which is less than 80 pounds.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "My mother had jaundice and massively swollen legs from starvation.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I had bloody diarrhea to the extent that I could never get from the tent to the hole in the ground, which was about 50 feet away.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And then I must have stepped on something because where-- I was walking barefooted, and I developed a big abscess on the base of my right toe and which was, obviously, quite seriously looking.",
      "word_count": 34
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "There was no place to go to open it.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "My father then was out of the hospital already.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "He says I will go-- going to open it myself, and he did.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "He cooked a pair of scissors for cutting nails and just poked a hole.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Puss came out, and I felt better.",
      "word_count": 7
    }
  ],
