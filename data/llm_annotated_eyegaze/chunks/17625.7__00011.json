{
  "stem": "17625.7",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 188.2,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And I told him the story.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And I showed him the letter.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "He called up-- [LAUGHS] The-- the-- the [NON-ENGLISH] there.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "They-- they were-- they were the police.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "They gave me-- they gave me my apartment back so fast.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "They didn't even turn back.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "But I wanted to show with whom I was dealing.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And at that time, whoever came to [INAUDIBLE] at the time, from the [INAUDIBLE], in the beginning, came to my apartment and to this house.",
      "word_count": 25
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "How many people came back?",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "They came back from-- from the camps.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "You know, in the beginning, in 1940, [PAUSES FOR 4 SECONDS] the Germans gave orders to the judenrat.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "We need 500 people.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "The order-- the judenrat was-- [INAUDIBLE], [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And one was a-- [INAUDIBLE] was-- was like-- like, the head of the police, the OD.",
      "word_count": 16
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And they gave them the orders.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And they had to bring order-- bring back the orders.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "They make-- make-- what I make-- if-- if they gave-- gave-- gave him an amount, I need 400 to-- to-- to-- to-- to the camps, 500.",
      "word_count": 26
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "So they supplied.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "They didn't go for it.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "But you know, they-- they [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And those ladies, girls, a lot of girls, went to work in Oberschlesian.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "In Schlesian.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Schlesian, near Breslau, near Szczecin, near-- near-- the-- the-- [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "You know what I mean, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "After the war, a lot of them come back.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "After the war a lot of them came back.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "This wasn't-- some of them was concentration camps.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "They didn't survive.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And some of them was working camps.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "And-- and some of them survived.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "Some of them survived.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "So there was a few back.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Not many men.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Not many men.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "My-- my brother-in-law was-- was-- well, didn't come back.",
      "word_count": 9
    }
  ],
