{
  "stem": "18575.7",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 450.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The picnic, the [INAUDIBLE] picnic, in Bad Nauheim-- he met a girl.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And in conversation, she said she's from Warsaw, and he is from Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And she asked him what school did he go, and he mentioned the public school, to which I went.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And she said, oh, I had a cousin that went there, to that school.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And he asked, what was his name?",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And she says, Adam Borensztejn.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "He says Adam is in Hamburg.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And unknown to me, when I came home that-- that evening, my aunt was sitting in my apartment in Hamburg.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "My-- that's-- my aunt is my father's sister.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And they all survived.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "My aunt survive as a nurse in the German army with her tiny daughter, as a Ukrainian.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "She was serving as a nurse.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "My [INAUDIBLE] older daughter was in a Polish convent as a Christian.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "And my uncle was hidden in Polish family.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "So all of them survived.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "The whole family survive.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They were registered to come to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They got a visa.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And when I told her that I am registered to come to Palestine, she says, where are you going to go alone?",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You're the only one in our family that is survived.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Come with us.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And I let myself be talked into.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I'd-- if I went to Israel, by now I would have been a general or something of that sort.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I sometimes resent it, but anyway, this is a wonderful country.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "So-- How did you get to the United States after this decision?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "So we-- I moved to Bad Nauheim, where they lived, and went to Frankfurt and registered with the consulate for visa.",
      "word_count": 21
    }
  ],
