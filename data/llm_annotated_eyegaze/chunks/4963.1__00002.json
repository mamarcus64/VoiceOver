{
  "stem": "4963.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "But came Friday night, I realized right away was Shabbos.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "Everything would go from his pockets.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "I remember it to this day, in a handkerchief, and he-- he would tie it, first one-- one end-- first tie it in one end and then the other end, and it would go into a disc, into a buffet.",
      "word_count": 40
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And there was a key there.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And-- and right away he would start clapping with his hands.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And we kids would be flying-- he would lift us up to the ceiling, and he would kiss us and it was like Shabbos Queen came to our home, like really truly like they say the Sabbath Queen descends on the homes.",
      "word_count": 42
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "My father built a synagogue right next to our house.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "It was a very large synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Well, I mean he contributed the money to build the synagogue.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I suppose it was with the help of other people, but it was right-- there was a fence right next to our-- between our house and the synagogue.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And so, of course, Friday night there was always going to the synagogue.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "It was an Orthodox synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "The women were upstairs, the men were downstairs.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "The-- and every Friday night we would have a guest come to her house for dinner.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The-- my father had-- my grandmother lived with us until she died in 1939.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And she was-- pardon me?",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "What was her name?",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Kaila Mary, and she was truly the queen of the house.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She was very revered and my parents brought-- brought us up-- excuse me-- with the idea that elder people have to be respected.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, it was my father's mother.",
      "word_count": 6
    }
  ],
