{
  "stem": "24090.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Ruth Arkiss.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "A-R-K-I-S-S.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "It was pronounced 'hoy-mun' in Germany, and in America, we call it 'hyoo-mun,' spelled H-E-U-M-A-N-N.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is February 19, 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Today I am 66 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cologne, but I did not live there.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I lived in Leverkusen Wiesdorf, which is now just called Leverkusen.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "It became one big city out of several small ones.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Leverkusen is L-E-V-E-R-K-U-S-E-N.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "That is in Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The community I grew up in seemed friendly.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We, as a Jewish family-- I had my identification as a Jewish child, and a very Jewish home.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We celebrated all the holy days and Friday evening Shabbat.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Later on I took Hebrew lessons.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And I-- my mother-- my mother was a widow.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We lived in that house, which my father built, all my life in Germany, until we were asked to leave.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, there were only 30-some families, and there were no children my age that were Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No, it was not.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was an industrial town.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was built probably-- let me see-- possibly around the turn of the century.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "The IG Farben, which was a factory, and the Bayer aspirin was discovered there.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And it became famous for that.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "That is correct.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "That's where they found the chemicals that produce the Bayer aspirin.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Today they produce many more things.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "This was in the Rhineland.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We were on the Rhine River, and it was near the big city of Cologne-- not too far away.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Leopold, L-E-O-P-O-L-D Heumann.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I think it was 1877, something like that.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "From what I heard about him-- he died when I was just over a year-and-a-half old.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I heard that he was a very active man.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He was a father of four sons, and I was the change-of-life baby.",
      "word_count": 13
    }
  ],
