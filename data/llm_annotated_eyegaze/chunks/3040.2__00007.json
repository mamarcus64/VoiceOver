{
  "stem": "3040.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I moved with my wife to Pilzno.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And my family, the rest of my family, my parents and my brothers and sisters, [PAUSES FOR 3 SECONDS] didn't have a place to go.",
      "word_count": 25
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So I went to a small town near [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The name of the, actually it's a village, was named [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And I was able to rent a little house from a-- from a peasant.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And I went back to Krakow.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I went to to the railway station.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I rented a box car.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I loaded most of the furniture and the belongings of my parents on that boxcar, and I brought it down to [NON-ENGLISH].",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And then my parents and the rest of my family reported to the authorities that this is where they want to go because they had to leave here.",
      "word_count": 28
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And they let them go on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "So I established them in [NON-ENGLISH], and then I went back to Pilzno with my wife.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "It was a day by day, you had to go out to work because there was, in every little town, there was Yiddish [NON-ENGLISH], so to speak.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "This is a congregation which was taking care of Jewish affairs.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And they had orders from the Germans to supply a workforce.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And we had to go to work everyday, and wherever they send you.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Locally.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was locally.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "To do-- it's not that they needed the work.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They wanted to humiliate the people and to put them to work.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "It's not to do work.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Most of it was not factory work, it was not office work, it was street work.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I had a broom.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I swept the streets.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "It was not really work that they needed that you say.",
      "word_count": 11
    }
  ],
