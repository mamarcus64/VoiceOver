{
  "stem": "11589.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "Two children, little children, and there wasn't enough to eat in those days, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "We didn't have enough food for the children, and this and that.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "My wife was working and I was working.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "And I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I came to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to stay there.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Believe me, I wanted to stay there, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "But she didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "She had problems with the language.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Didn't know the language.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And two children, and all that.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And she had a cousin here.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "She wanted to come to America.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, I tried to talk her out of it, and this, and that.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I'd say, it's our country.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We're here.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "We went through plenty.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "You lost your parents.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "You lost your family, I'd say.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "And I lost my family.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "Let's stay here.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "No, she's got a cousin here, which she was very close to her.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "They grew up together as little children, you know, her cousin.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "Two cousins, as a matter of fact.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And she sent her papers.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I'll send you papers.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Come over here.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Come over here.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "We'll help you.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And that's the way we came here, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "It was a bad situation, Israel, in that time, with children especially.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "So when did you come to the United States?",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Good question.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I got to look at my papers.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Yeah-- Well--",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Uh, how did you know? 1962, that's right.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So we came to Boston.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I had an uncle over there.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "We stayed over a little while, and we said, well, we have to go further than that, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "Hollywood was my dream, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Go to that crazy Hollywood, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "So let's go.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And her cousin lived here, you know, in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "So finally-- you know, my uncle was good to me.",
      "word_count": 10
    }
  ],
