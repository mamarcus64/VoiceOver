  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "We made up our mind when we are in the train, if we are going to go by train-- we knew we are going to the railroad.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "But we-- and if we are going to the certain place we are thinking we are going, we are going to jump the train.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So I didn't want to go in in the same train with my mother and with my brother and with my sister, with my family.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "In case by jumping I'll be shot, I didn't want my mother to see that.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So I went in in another car with my friends, with a lot of other people, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And-- OK, let's stop for a minute right here.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
