{
  "stem": "740.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "It turned out we were a 145 fellas in the corner to go to work, or whatever it was.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "I didn't know at that time.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "We formed also five already.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "We were counted.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "The other ones were all marching.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "As it stands in documents, they were all marching into the gas, right there and then.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "Nobody stayed alive out of these people.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "They caught some women out of the transport.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "And in two trucks we went to Monowitz, which is Auschwitz III.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "And we arrived in a camp.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "It was about eight o'clock, 8:30 in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "We stood on one place, that's there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "And about half an hour later we understand already this is eating, because we came from a camp.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "I mean, some of us knew what a camp was like.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "We ate everything we had yet in sight.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "We smoked every cigarette we had in sight.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "And comes inmate number one, Ludwig Wehr.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "Was a German criminal, professional criminal.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "And he was the chief of the camp, or the [GERMAN].",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "Then he greets us in German of course.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "And he says, gentlemen, you are in Auschwitz III.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "This is not a sanitarium.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 39,
      "text": "This is not home away from home.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 40,
      "text": "This is a labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 41,
      "text": "Now, there will be no calling sir, mister.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 42,
      "text": "You have no more name.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 43,
      "text": "You were assigned a number.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 44,
      "text": "You will answer and talk when you are talked to by that number.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 45,
      "text": "Anybody you call sir will be punished.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 46,
      "text": "You call everybody by the number.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 47,
      "text": "You will be assigned an inmate suit like mine, maybe not tailor made, but mine.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 48,
      "text": "You will have a cap.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 49,
      "text": "You will have no hair.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 50,
      "text": "Escaping, gentlemen, is out of the question because the barbed wire is 20,000 volts.",
      "word_count": 14
    }
  ],
