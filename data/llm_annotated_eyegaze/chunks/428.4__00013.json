{
  "stem": "428.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "It's going to be now in January three years where I'm over here.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "January 28 I came to-- to Los Angeles.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "So we moved over here.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And over here, I have her in the house for a month, something like this.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I took a Polish woman.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "She should help me out with her.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't-- I couldn't manage with her.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "She used to cry all night, walk around.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "The Polish woman used to cook.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "She used to take a pot with hot water and throw it down.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "She's very jealous.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "She don't let me talk to nobody.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "For this, she has brains.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Somebody talks to me, she like, shakes like this.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I ask her, you know, what happened?",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I saw it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I saw it.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "What you saw it?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "She-- she's very jealous.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And so she-- she didn't-- and now once-- once I went-- Yom Kippur, I went to shul.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And I left her with a woman.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "No, I left her with the landlady.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "So the landlady's husband comes to-- to me to the shul.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Nathan, come out.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Regina's running away.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "She don't want to stay with us.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "So I have to come out from the shul.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And then I have to give her away.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So I had her for two years in another place.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And it was very dirty, [INAUDIBLE] a very religious place.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And they-- they pack-- one on the other was sitting.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Dirty, she always was smelling.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I paid so much money for that.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So I used to come there.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "A Russian woman used to come to play piano for them.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And that Russian woman told me, Nathan-- she saw I'm coming every day-- why you have to keep her over here in a such a schmutz around such dirt?",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Go over there.",
      "word_count": 3
    }
  ],
