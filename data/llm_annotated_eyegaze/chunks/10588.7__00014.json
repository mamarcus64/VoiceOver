  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "I had this striped tatters dress, minus my hair, minus my monthly cycle, because in Auschwitz, we didn't get the monthly cycle, which worried me, because I didn't know if I'll ever be able-- know if it's temporary or not.",
      "word_count": 40
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "To be able to have a family.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And we came into Sweden.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "The people in the hospital were very nice.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But when I saw myself the first time in the mirror, I became hysterical.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I started to yell.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't speak the language and the nurses didn't know what's happened.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They thought that I suffered some kind of shock or something.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And I obviously must have, because I didn't know who I was.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I didn't look like a woman at all.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "My body was skeletal body, everything.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And only what I have, which I gained, was the number and the experience.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And I was there.",
      "word_count": 4
    }
  ],
