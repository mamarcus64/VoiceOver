{
  "stem": "18307.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So I came back and I told my father.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I says, I found a place for us where to go, Yaski.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And my father says, oh, we have no choice.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Tonight we're leaving here.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And it was wintertime It was cold, snow.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We had our-- me and my sister two little linen dresses, galoshes-- nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And we walked in the snow through the farm.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We didn't walk on the road, we walked through like a farm.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We heard some kind of shooting at night, we didn't know where it-- it came from.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And we finally made it to that farm, to Yaski's farm.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And we crawled in under the straw.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We were hungry and we were dirty and we were cold.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "We all crawled into the straw and we stayed there.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And we were worried about footstep--steps but God was with us again.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "The snow started to fall and covered all the footstep.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "In the morning, we heard Yaski and his-- well, not his wife, just him.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "He came and took the barn and my father came out from hiding.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And he said, Yaski, I'm here with my family.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "You have to save me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And he went in the kitchen and he told his wife and she cooked a real big pot of potatoes.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And he brought it out and [LAUGHS] we devoured those potatoes like that.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And she came out.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "She was happy to see my father, my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "My mother and father were very-- it was a small town.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And we knew the war-- and so we talked about we couldn't stay on the farm because of the Ukrain-- they come at night to burn the farm, we'll die.",
      "word_count": 30
    }
  ],
