{
  "stem": "393.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "From Guben-- because they told us that the sick ones-- there were always several sick people-- they will-- they are going to come by car, or I don't know.",
      "word_count": 29
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "The other ones, they never got there.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So the-- the-- the walk from Guben-- we went to Bergen-Belsen was our next stop, which was the infamous Bergen-Belsen.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Who wasn't in Bergen-Belsen wasn't in a concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Bergen-Belsen was a terrible, terrible thing.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I don't know how much time we have to talk about that.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Do we have?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "If we have time.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "--shelters in the factory, yes, sure.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It took a long time till we went down the steps.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It was all over when we got down.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "But you wouldn't believe it.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We were laughing.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We liked that.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "We loved that sound!",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "They are going to hit it.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "The war is going to-- we weren't afraid to dying.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "It's so interesting.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "When we have nothing to lose, it looks like you-- I-- I don't know how.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Nobody was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "We were laughing-- very careful not to laugh loud.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "They shouldn't hear it.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "You see, we weren't afraid at all.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "They took us down.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "We had to go down.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And then, one day, we didn't go to work.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "It was January.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "That was '45 already.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "We didn't go to what's happening.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "We didn't know what's happening.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "We still hear the bombardment, which meant the enemy is coming.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "We were-- there were all kind of rumors-- the war is going to be over.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "The war is going to be over.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "There were some people.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We had a-- the next lager was a French lager.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "There were only men.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they were-- they were more informed about what's going on outside.",
      "word_count": 12
    }
  ],
