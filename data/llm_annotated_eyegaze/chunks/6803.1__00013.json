{
  "stem": "6803.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "He must have a good dinner or something to [? get ?] that fun.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "So [INAUDIBLE] ripped him up to pieces.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "And he left him there.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "And he walked away.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "That was his satisfaction.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Well, anyway, we stayed there in Mauthausen-- I don't know-- I think it's about five, six days.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "It came the next morning.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "It-- well-- next morning, we got up.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "First of all, we had to sleep like this.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "We had to stay in the line outside.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And we had only our underwear-- no clothes on.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "Only our underwear.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And then we stood there in the line.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And that was the room over there in the wall.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "There was one man--",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No, they took us in a [? block. ?] There they tell us-- told us to take off our clothes.",
      "word_count": 20
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Only the underwear, we should go around on our underwear.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We should not use no clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And then to go to sleep, we had to wait in a line outside.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And there was the wardroom.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And there was the wall.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And when we got there to the door, I saw what's going on.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "One man was laying with his head this way.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And one man had to lay with his head this way with his feet, this way.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "But like sardines.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "Not enough flat-- only sideways.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "And if you didn't push up yourself towards the other man next to you, there was an SS who give you a smack.",
      "word_count": 23
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 12,
      "text": "Up, much closer.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Nothing!",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "On the floor!",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "On the floor!",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "On the floor!",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "When-- and I saw that, and I says, OK, he's laying like this.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Here, I have to lay this way.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "So I run there.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And I push myself up like this here.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "Like this, I push myself up there.",
      "word_count": 7
    }
  ],
