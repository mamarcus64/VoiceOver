{
  "stem": "18294.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 102.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] He had-- he had an offer.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He said, what, so long she's not coming?",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to remarry.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I'm not waiting for her anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So they come up one.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They said, you know what I have?",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "A beautiful girl, beautiful-looking one.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "He said, who is she?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "Oh, she has a mother and another sister.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "He said, oh no.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "I'm not taking three-- three womans on my shoulders.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "No way.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "So, I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "He didn't took it.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "So I come, he took me.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "Then when I was very sick, and he was traveling with his food, surrounding little towns around Vilna.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "So he go in, in a town where-- used to his girlfriend used to live before the war.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "So he said, oh, he go.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "I go to look for her.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So when he's going to look, we went to the police.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And the police-- he went in the police.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "He asked the policeman, you know, by the name such-and-such?",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "He said, I'm her husband.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So he said to him, he said to-- to Sam, who are you?",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I said, I was a friend for your wife once.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Can I go and see her?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "He said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Come on.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "He took him to her.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "But he couldn't stay with them too long.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Because he was in the police.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "He had to go back to work.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "So, she said to him, I know your wife is here.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And I have for you a suggestion.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "Let's go away, both of us.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "Leave your wife, and come with me.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "So, I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "My husband had maybe a little feeling.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "I don't know what was it.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "So he said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "I'm not going.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "So I was a second time lucky.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "He didn't want to go with nobody, just with me.",
      "word_count": 10
    }
  ],
