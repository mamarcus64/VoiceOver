{
  "stem": "894.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] my mother-- my-- my grandmother was always in the business.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So my mother [PAUSES FOR 5 SECONDS] was always brought up with-- with servants.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And, for that reason, she-- she was really-- when it came to the bad times, she was a little bit helpless.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She wasn't accustomed to doing things.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I remember an incident when we were already in the ghetto, and the maid couldn't come in because there was already no maid service in those days.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And my mother spoke to me and said, my goodness, it's going to be Pesach, and how are we going to get the house ready, because she was really just not the type who could clean a house.",
      "word_count": 38
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And I said, well, you have three daughters, and so I'm sure that we will manage.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I said, I'll tell one of my sisters [PAUSES FOR 4 SECONDS] to wash the floors, and I'll wash the windows.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And we'll get the house clean.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And my mother said, oh my god, the neighbors will see you wash a window.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I mean, how-- how can we do that?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I said, well, mother, you have a choice.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Either clean windows, or the neighbors can see me.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "You know, so I remember that times went from good to worse, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But we were comfortable.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "We were always very nicely dressed.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And-- [PAUSES FOR 3 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were brought up-- the children were brought up in a very Hasidic home.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "My father had a beard-- had a long beard.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "My mother always used to say, you children didn't see your father when he was very handsome, without the beard.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "But she used to beg him-- maybe you can cut a little.",
      "word_count": 12
    }
  ],
