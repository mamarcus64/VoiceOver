{
  "stem": "1249.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I just drank, thank you.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I don't know where I was-- they-- one time when we were in-- standing up in line in one morning in Augsburg, [PAUSES FOR 4 SECONDS] I was telling to my sister-- but not telling, just whispering very softly, I had to go to bathroom.",
      "word_count": 45
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They give something, something they said coffee, something black to drink.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "It was-- I don't know what was that.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "But anyway, it was early morning.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "It was cold before we went to the factory, maybe 5:00 o'clock 4:30 in the morning.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And we walked.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And we-- we walked out.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "We were standing to have this liquid to drink.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And I said to my sister, Piri, I said, very, very softly, I have to go to bathroom.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And SS who was not even close by, came over there.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "He hit me left and right.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "You damn Jew!",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "You talking!",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "You should not open your mouth.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "He was beating me up.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And I tell you, I was so scared.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I'm embarrassed to say, but I don't know if I should say or not.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "I didn't have a panty.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "But I peed on the-- you know.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I should say I peed in my panty.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But I didn't any anything, anything under.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I peed.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I was beaten up for-- just because I whispered I had to go, had to, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And maybe 20 years ago, I would not tell this this way, because I'm old-fashioned.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was always old-fashioned.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "But, you know, in time, I think we should tell whatever happened, whatever remember.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I'm sure many more things happen.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "But you can't remember everything.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I'm not-- write-- I didn't write down to prepare.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "It's just asking, and whatever is comes to my mind, I tell you.",
      "word_count": 13
    }
  ],
