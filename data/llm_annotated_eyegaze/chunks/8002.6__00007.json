{
  "stem": "8002.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 28,
      "text": "And I says to my mother, we're going to be in trouble because they'll find us.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 29,
      "text": "And before I said-- because we were deep under the hay-- I heard noises.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 30,
      "text": "And my mother laid down right on top of me.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 31,
      "text": "And they took pitchforks and started to dig in the hay to see if anybody's there.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 32,
      "text": "Luckily, the hay was too deep, so they couldn't do it.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 33,
      "text": "And they walked away.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 34,
      "text": "And they say, we'll get them next time.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 35,
      "text": "And my mother says, we better leave because they're going to find us.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we left at that-- the same night.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And we started to go to Dvinsk because we didn't know where to go.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And on the road, there was a, a Latvius policeman.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He caught us.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And they sent us back to Dvinsk Ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We went back to Dvinsk Ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And then I started to work for the, the German again.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And they let us go to see our brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "It's-- well, we traveled at least 10 miles before-- when we got caught.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "So they didn't send us back to Wiskys, they sent us back to Dvinsk.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And at Dvinsk, they sent us to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "To a different barracks than where we were before.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "The barracks where were our brothers-- my brothers were there and my uncles and aunt.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And then I saw the Germans go up.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "We were downstairs-- there was two flights.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "There was downstairs and upstairs.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And I saw all the German soldiers going upstairs.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And we couldn't figure out why.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And then we find out all the women, they had their little babies.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "They took the little babies and opened the windows, threw out the babies in the-- through the windows.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And the German soldiers were staying downstairs with bayonets.",
      "word_count": 9
    }
  ],
