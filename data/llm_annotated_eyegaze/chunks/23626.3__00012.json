  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "But somehow, it was God's will that he was arrested.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And he didn't have a chance to kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Because he already killed a few people that knew a lot about him.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I don't think there is a word in the in the dictionary that could explain the fear and the enormous-- [PAUSES FOR 4 SECONDS] hate is not the word.",
      "word_count": 29
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It's like I think that he was the most disgusting creature that-- that anybody could imagine.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "How could you-- I mean, he was so hateful.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He was a murderer.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "He was a murderer.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "He enjoyed killing.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I mean, if you would see his face after killing.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "He was a schizophrenic.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He was-- he was-- his moods were changing.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "But at the same time, he enjoyed what he was doing.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "He didn't it as a order.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "He do it-- he did it out of pleasure.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "There was embedded hate in him.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I don't like to use even the word hate.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Because in spite of everything, I don't hate.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Because hate brings evil.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "He was a evil man.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "The Nazis were evil people.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And I'm scared of this word hate.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I carry pain.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Yes, I carry a lot of pain.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "But I don't want to hate.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I don't want to hate.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Because it's an ugly word.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And-- and its related with evilness.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "They were evil.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 4 SECONDS] [SIGHS] He [SOBBING] was standing in his room one day-- excuse me.",
      "word_count": 16
    }
