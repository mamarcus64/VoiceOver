{
  "stem": "10394.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They go-- yeah-- they go inside.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "What they can-- they took it.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "The Russians, they took it.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "But we were lucky we were alive.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] This was in Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "This I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They killed somebody, but I don't know who.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "There was so many people, you know-- it was a very very big building.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And this building, they got the rooms-- who can-- they stay in-- I didn't got money.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And Berel didn't got money.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And they didn't give you money from the Jewish committee.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "They didn't give you nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "I don't know how-- it was a long time.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "Then from Krakow, my husband, he got some Polack-- he used to come to him.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "He put the money, what he got, something he sells-- that he bring him from time to time, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And you didn't got nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "You got nothing to start with something.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "After this, we were in Poland a long time.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "Was-- we got somebody to tell us to go to [NON-ENGLISH], you know.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "Over there there's a big factory.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 16,
      "text": "He started to work, I started to work in the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 17,
      "text": "It was a very, very big factory-- 5,000 people.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "But the factory wasn't in one place.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "It was in different places-- small towns and big towns.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I was together and my husband used to work for them.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And he was so good-- the-- all the-- the presidents from the factory, they came, and they asked him what to do.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "That's why he came here.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He didn't work so hard his whole life like he worked here.",
      "word_count": 12
    }
  ],
