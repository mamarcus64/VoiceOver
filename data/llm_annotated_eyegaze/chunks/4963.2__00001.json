  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Now, my other aunt's name was Chassia Yashuner.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And my uncle was Osher Yashuner.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And so-- and they had-- Osher had-- Osher and Chassia had one son, Monya.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And he was about four in those days, maybe even two, three years old.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "My Aunt [NON-ENGLISH] had a son, Wolf.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And he was the same age as I was.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "He was born in December, 1929, Wolf Prensky.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And then she also had two older daughters.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "One is Genia, Genia, who was, who is about seven years older than I, than I am.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "And she's right now in, in-- she lives in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "And I'm very close to her.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "She's truly like my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Then they had another one, another daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "My Aunt Paula had another daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "And her name was Liena.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "She was an Olympic runner, and she was killed in the ghetto right in the beginning.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So when I came back from camp, from summer camp, my aunt told me about-- my Aunt Paula [NON-ENGLISH] told me about what happened to my parents.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I remember-- I was 11 at the time.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I remember crying, shedding a tear, or crying and then making up my mind that it was going to be OK, that I was going to survive.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Were any of these children, your, your cousins, at camp with you?",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I was all by myself, you know, with my friends, you know, naturally.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "So this was-- this is how it started.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I was all started by myself and determined that whatever happens-- I had a feeling that perhaps God punished me.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "That since I was always so stubborn and I always wanted to run away from home, perhaps it was something like a punishment that I was left all by myself.",
      "word_count": 30
    }
  ],
