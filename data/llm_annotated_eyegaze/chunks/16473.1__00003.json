{
  "stem": "16473.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 437.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Her father was a very [SIGHS] orthodox philanthropic kind of person, always gave to charities.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And he brought my mother up religiously.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "But my mother sort of rebelled against it, I think.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "She told me that one day she tried to bring home a Christmas tree branch because she just liked it, and he made her throw it away.",
      "word_count": 27
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "So nothing like that could be in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "But as his-- my grandfather's children got older, he relaxed and he let them not, you know, be as religious.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And yet my mother was always very moved by synagogues and churches.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And she brought with her from all her-- all the places she had to flee from, from Austria, from Hungary, she brought her prayer book.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And I still have the prayer book.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "She got confirmed, I have her confirmation bracelet.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "She wrote a poem to my uncle for his bar mitzvah.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "So she was raised religiously, but I was not.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I was under two.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "No other child was as young as I was.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And [SIGHS] she told me stories of-- and I guess I faintly remember.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "She taught 'em a song about the washerwoman and the kids would pretend they were washing.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they put me in a washing basket and I just sat there and they thought I was very cute.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And as I grew a little bit older, I got all the parts in the plays that my mother put on, big parts.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And I remember, when my dad came, I'd waved to him from, from the stage.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "But I also remember feeling terrible because I couldn't be near my mother because she had to take care of other-- other children.",
      "word_count": 23
    }
  ],
