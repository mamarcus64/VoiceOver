{
  "stem": "21482.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon, Paula.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Rena Finder.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "F-I-N-D-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My first name is Rena, R-E-N-A.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name is Ferber, F-E-R-B-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "February 24, 1929.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I'm 67.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Cracow, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "It was [NON-ENGLISH], which means [INAUDIBLE] Street, number 8, apartment 12.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a brand new apartment when I was born.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We moved in there just when I was a few months old.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "It was right across the street from the river and right next to a castle.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I always thought it was the most beautiful building ever.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it was a big building.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "It had four flights.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And on each floor there were about four apartments.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And from the back yard, I could see the old church that belonged to the Franciscan brothers.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "It was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We had a beautiful apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "It was probably not beautiful for today's standards, but those days it was new.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "It had hot water in a bath-- bathroom.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And-- it was very-- I said it was beautiful.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "I still do.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My-- my mother and father.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I'm an only child.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother was Roa, or we would call her Roza.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And my father was Moniek, and his given name was Moses.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother's maiden name was Windisch.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "W-I-N-D-I-S-C-H.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My father was a salesman for a company that was making surgical instruments and surgical supplies.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And he-- he was traveling a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He would leave every morning.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Every Monday morning he would leave.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "He traveled by train.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And he would come home most of the weeks on Friday night, just in time for Shabbat.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Since I was an only child, I spent a lot of time with my mother and her sister, because she-- her sister, unmarried younger sister, lived around the corner from our house with my grandparents.",
      "word_count": 35
    }
  ],
