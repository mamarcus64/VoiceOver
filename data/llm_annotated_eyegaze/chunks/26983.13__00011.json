  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And he didn't have the faintest idea how a gas chamber looked, or that I knew it so well that I could correct to somebody--",
      "word_count": 25
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Well, no, that doesn't matter.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "But I wanted only to tell you that even the man who wrote a book about it, his map of the gas chamber and so on was wrong.",
      "word_count": 28
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And I told him, look, the people went on this place to the gas chamber, what you put you on your map is not--",
      "word_count": 24
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "But he didn't care.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "But he just said, we are fantasizing.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "Which was very painful.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Rather late.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Because I wanted, first of all, to study.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And I gave all what I could, for my drawings and so on, into studying art.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "That was the only thing which interest me.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And about family, I thought only when I was 30, over 30.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Then I married.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I mean, well, if you think--",
      "word_count": 7
    }
  ],
