{
  "stem": "9486.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We're going to have our country.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And they brought us over in boats.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And they brought us to Kinneret.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And that was the first thing.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "But Kinneret took us.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "My passport is marked I'm a born Israeli only for that.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Every week, they used to come, the English people, to check in the kibbutz if somebody-- newcomers-- coming in underground.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And the first kids, they brought it here, it right away was passport for them.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And right away, it's marked I'm born in Kinneret.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And this and this year.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And-- and my name was from Henya was changed to Edna.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "A Hebrew-- a Hebrew name.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They didn't change different writing.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Only in Hebrew Henya is a Jewish name.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And in Israel, they thought they're going to find if they changed me on Edna.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And at that time in kibbutz, I started going to school half a day.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I went to school, and half a day I was working.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And in kibbutz, the kibbutz went to find my family.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Slow, slow like.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Then became-- my brother came over, time from the England already.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "His ship was [NON-ENGLISH] ship.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "The day he came 63 kids came to Kinneret.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "He was the only one what I knew.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And slow, slow, the people from the kibbutz, they find my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And they find my mother, then younger brother, Moshe.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And my sister came, I think, in a year when-- when I find my sister when we got-- what year?",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "In '50?",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "1950.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "1950.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "That-- that the last one was me find my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "With my sister.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Two brothers and a sister",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And my mother.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And my mother was with us, but in kibbutz.",
      "word_count": 9
    }
  ],
