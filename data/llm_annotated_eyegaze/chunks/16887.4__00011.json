{
  "stem": "16887.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 502.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "It was a-- it was just a split of a moment that I decide to go.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother, they died in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So did my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "My father was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And so did my sister-- my sister, Hana, died in the ghetto uprising.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And from Canada, I came to this country.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My sister remained in Canada.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "She-- she married.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "She's happily married.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "She has four children.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "She has three grandchildren.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And today, she is visiting Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "That's my sister, Regina.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "My sister Hana died during the ghetto uprising.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So we-- from the whole family, we the only two left.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I had several aunts and uncles, and 50, maybe 50 cousins, maybe more.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Nobody survived.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Maybe 70, 80 people.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Who remembers?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, What can I say?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I-- even as old as I am now, I still miss my parents.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I still, many times, think how nice would be that-- thanks god I came to the best country in the world and I'm comfortable.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And how nice would it be if I would have my parents now and I could give them things that they never had.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "But it wasn't to be.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I am very close with my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And we see each other quite often, and her family.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, I came from Austria to the Jewish [INAUDIBLE], to Canada.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And from Canada, I came legally into this country.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "My husband had a brother here, so--",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "--he send us-- I was in Canada [SIGHS] 3 and 1/2 years.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It I work hard.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I came to this country.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I went to work, too.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "After I was in this country 10 days, I went to work and I worked all the time, till I retired 11 years ago.",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I was a dressmaker.",
      "word_count": 4
    }
  ],
