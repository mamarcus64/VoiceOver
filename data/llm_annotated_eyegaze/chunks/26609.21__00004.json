{
  "stem": "26609.21",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "They in New York for years, and they live in, like in, in Europe in the old shtetls.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "She had a look at me, said, how do you want to go to New York?",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I said, by Greyhounds.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "How do you Grey-- they thought here in Australia, they are on top.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "They are cultured people.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "We here, we know nothing about.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "How do you know about Greyhounds?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "I said, that's funny.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "How do you know?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "They have Greyhounds in Israel, too.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "It's a bus, you know, Greyhounds.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "By bus-- I didn't need to go by trains.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "It's not very far from Atlanta.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "It's distant, but all right.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "She said, I'll ring up Myer.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "That was only one of my late husband's-- he was alive.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "I don't know now if he's alive, a cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "His cousin, not mine.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And I remember him faintly.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I was a little girl, maybe starting school.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And he was already a grown-up man when they left.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I've heard at home, you know, people left for the golden medina, for America, everybody talked.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "You're going to America, a rich country.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And probably, they will get wealthy there, too.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So everybody knew that Myer went there.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He was much older than my late husband.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "That woman Atlanta rang straight away to that Myer to meet me on the stop where the Greyhounds.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "You know, it's exactly where the Greyhounds and train-- how do you call it?",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "You know, where the trains are stopping.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He had to meet me there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And he knew when the Greyhound buses stops there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So he had to meet me.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But he, again, expected a [NON-ENGLISH], something that he would ashamed to go in the street with.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And he was a tall man.",
      "word_count": 6
    }
  ],
