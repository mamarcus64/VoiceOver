{
  "stem": "20710.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "And oh, yeah, and of course, you know, after work, you know, we didn't sleep at home.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "You know, I used to come home, you know, after this thing, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "The-- they didn't take the parents.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 29,
      "text": "They took mostly the younger people to this [PAUSES FOR 3 SECONDS] forced labor.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 30,
      "text": "And after coming home, so my mother used to whatever she could prepare a little bit something to eat.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 31,
      "text": "And then we used to leave the house and go in the fields, sleep.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 32,
      "text": "We-- we didn't sleep at home.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, because we were afraid it-- this Ukraine-- you know, they are police.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They used to come during the night.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They used to come any time.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And they had fun.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They had fun torturing us.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "They used to tell us to-- to-- to turn-- even during the day, to turn around against the wall.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And they-- they looked around the house, whatever they wanted, they took away.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And they threatened us to kill us and to do that.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And every time I felt that there's going to be a bullet, you know, in back.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "But somehow, they used to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "But then at night, they used to come.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And so we used to leave the house and sleep in the-- in the fields.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I'm-- and my mother in one place, my brother was another place, my father on the other place.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "But then when it got cold, you know, late into the fall, we used to go on the, you know, on the attics, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "And they had barns, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "It was a village.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "They had barns with cows.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "But anyway, I used to go there.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "And without these neighbors, without the Gentiles-- I mean, some were quite nice.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "They didn't want to know.",
      "word_count": 5
    }
  ],
