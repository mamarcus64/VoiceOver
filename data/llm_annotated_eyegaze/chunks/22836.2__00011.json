{
  "stem": "22836.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And I see they going after me.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "They going.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "Then I start talking to them in Ukrainish.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "I say, do you need me?",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Where you coming?",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "Do you need me?",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "And I took like, to the bottle.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "They thinking maybe I have something.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And finally, they listen to me.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "They went back to cut-- to cut the trees.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "And I went straight.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "When I went straight, they always looking for you, where you walking.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "And I have these shoes, the-- the Ukraine shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "They can-- then I went on the road.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 8,
      "text": "And with the road, I went with the shoe.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 9,
      "text": "And then I went on the left side, and I came in the wood.",
      "word_count": 14
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 10,
      "text": "And there I stop in the wood.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 11,
      "text": "The wood was not, no-- no leaves.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 12,
      "text": "It was still wood.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 13,
      "text": "And I was staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 14,
      "text": "And I hear shooting, shooting.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "By yourself.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "I'm only one there.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "And they shooting.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And they shooting.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "And I hear a shoot right near me.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "I don't see nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And I-- I was saying to God that I am actually lived so-- two times in my life I talk to God.",
      "word_count": 26
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "And God help me.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "I know that.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "There was real talking to God, that time.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "And he helped me.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 11,
      "text": "And-- and I say to God, just like this-- I say-- I say, God, you help me.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 12,
      "text": "[NON-ENGLISH]-- I want nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 13,
      "text": "I want just one suit for holiday and one suit for every day.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 14,
      "text": "And I don't care what-- what to eat, just if you let me live.",
      "word_count": 14
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 15,
      "text": "And I say to God, please make dark.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 16,
      "text": "It was very light.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't go in the night to see what going on.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 18,
      "text": "It was very light.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 19,
      "text": "I say, make [NON-ENGLISH]-- make-- make dark.",
      "word_count": 7
    }
  ],
