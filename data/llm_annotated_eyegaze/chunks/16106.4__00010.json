  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "So they're are used for all sorts of purposes, not only to-- to clean those boots, for other ways too.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "They were abused sexually.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Just that we know all that.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We lived there a year.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We lived there a year.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "That was-- that always was the politics of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And then [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "Jacob ?] told me always everything.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I mean, [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "Jacob-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Jacob ?] always warned us on certain things.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "He was great in that respect.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "He wasn't great in many respects.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "He got shot whenever he tried to flee.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "He was an old man already.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "By the time he was 46, he was very old.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS] Poor [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "Jacob. ?] Anyhow, for example, in the Riga ghetto-- was an entity in itself.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "And there was a Jew called Einstein, relative of the famous Einstein.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And he was a big shot in the Riga ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "He was very close to the-- to the SS something or other.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And he came with his so-called papers to the Kaiserwald for special treatment from-- but he didn't know that Kaiserwald is not Riga ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "There are different kings, and different queens, and different, different politics.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "What works in the Riga ghetto does not necessarily.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "I just see him one day walking with a lageralteste, and this SS man dressed up and shiny things.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "Christmas, [?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "Jacob ?] told me, you wait what's going to happen.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "They took Einstein, the S-- X and Hannes and the lot, and drowned him in the toilet head first, you know, if the latrine, in the [? caca. ?] That what happened to Einstein.",
      "word_count": 34
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
