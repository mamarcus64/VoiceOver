  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They gave us a buggy, what once was for collecting garbage, with two horses with boxes of documents, that when we travel to Russia, we should deliver to a certain destination those boxes, which we did.",
      "word_count": 36
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "From the-- [INTERPOSING VOICES] From the place where he worked.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, get together at night.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And not only did they got together, one helped the other.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Like my husband was working, and he met an old friend at a [NON-ENGLISH], which he carried down in Dubno from the whole-- his his-- [PAUSES FOR 5 SECONDS] what you may call-- the-- the site from where the [? belong, ?] the [? battery ?] belonged, you know?",
      "word_count": 49
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And he met him.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And-- and we used to share our food.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We didn't eat a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I let him sleep in my place, until he got sick.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And I had to take him to the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I took him to the hospital, he had typhus.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And til next day, two days later I come, they say he died.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And he was a very rich man.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He had a drug store in Dubno.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And died like that.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And why be in Samarkand, we develop [? bold ?] malaria.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "That's why I don't hear well from the high fever.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "This ear got affected.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I went to the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My husband, too.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He had typhus.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I had typhus.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And I had malaria.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And he had malaria.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And before we came to Samarkand, they assigned us to a kibbutz.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And my husband was working in a kibbutz.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "He was cutting hay for the horses to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And then I had a little boy, which died in 1942.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "He lived only a year and two months.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "Then I had Rena in Samarkand in 1944.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Oh, very poor.",
      "word_count": 3
    }
  ],
