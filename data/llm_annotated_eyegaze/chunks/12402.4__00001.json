{
  "stem": "12402.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They told me, they chasing them-- they mentioned a place near [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "There was a camp-- [?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Hassac ?] or something.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "They liquidated the camp, and they'd taken deep Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They want to take them with-- with everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "That probably they finished them, who knows?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "So anyway, I saw-- I heard that.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "They said, they got very nervous and very excited.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And I said-- and I let them go.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And I let them go, and I left.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And-- and I made up my mind, I must go and see.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "And this is-- I know already-- I knew where it is, because it was a really small village.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "I crossed this place, was there a shoe maker.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And-- and I figured, I can't go close to the field because I get spot and it's dangerous.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "So I took-- took a shoe, like boot, you know, on my-- on a bicycle.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And my boss asked me, where you going?",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And I said, I have to go to the shoemaker because I'm going to the city, and I got to fix my shoe-- just an excuse.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I went into the shoemaker, and I looked out of the window, and I saw a terrible site.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "You know, so many women.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, I went right back and from nowhere, the girls came back with the two bread-- probably they found out what's going on.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Then the whole group came over-- it was daylight already.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They came over to our place-- my boss was moseying around.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "He said, what's this?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what is this.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Oh, this is Juden.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "You know, [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And he calls me over.",
      "word_count": 5
    }
  ],
