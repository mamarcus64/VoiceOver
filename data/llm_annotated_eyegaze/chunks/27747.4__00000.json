{
  "stem": "27747.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I-- [PAUSES FOR 3 SECONDS] the priest story was-- belongs to Miedzyrzecz, the town when we used to sleep over at night in the church.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I am now back in Rowne, and Rowne is-- is freed from the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "They retreated, and the Soviet government took over.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Where, after I met this lady that was from my our town-- had a sister in our town, which was my-- my sister's friend.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "She was a kindergarten teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And their whole family perished, but she survived, and she was very, very pretty.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Beautiful, long, long braids.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "She told me that some of the families of Hoszcza, that I also-- she thinks I have a letter from my sister from-- from Russia.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "So that could not keep me, definitely, with the Polish family.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I thanked them and they packed up and they went to Miedzyrzecz and I worked to Hoszcza.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And I did find in Hoszcza the teacher, the one that was our teacher during the Soviet regime.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And she was my sister's friend.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "They went together in gymnasium, and she did have a letter.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "She married from the town of Ostrog to our town, and she did have a letter from my sister with an address.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "My sister was in [POLISH], and she was coming back from the Ural Mountains.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "She found out that her husband survived-- my-- my brother-in-law survived.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And they met in [POLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "That's the town where she evacuated from with my-- with-- with my uncle and aunt.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "And then in [POLISH], I visited our maid, our trusted maid Jurina, and she wanted me to go to-- to bring food packages to her husband that was in a-- in a labor in the Soviet Union.",
      "word_count": 37
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And the one-- my advisor, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Gelman, [POLISH] [?",
      "word_count": 3
    }
  ],
