{
  "stem": "11723.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I was so hysterical that in my mind as a five year old, I associated Auschwitz and the movie theater.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And I did not set foot in a movie theater until I was a teenager.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And by the way, when people came back and they were talking about Auschwitz, and they told me my cousins were burnt in the ovens, I had incredible nightmares.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "I thought that they put the people in to the flame directly.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I thought the gas chambers were something else.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Some people went to gas chambers, some people were just thrown into the ovens.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "So in my mind, I saw my cousins being thrown into the ovens.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And then in 1946, I started school-- first grade.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And I went to the Jewish school.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And I was late every single day because I had such nightmares I couldn't sleep at night.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "So my parents didn't want to wake me up after an hour of sleep or something like that.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "So I remember my father taking me to school like at 11 o'clock every day.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "But they were very understanding at the Jewish school.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And since I was a very bright child and I was ahead of the class anyway, they didn't bother me too [PAUSES FOR 4 SECONDS]",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So the nightmares were horrible.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I used to dream that they're going to shoot me.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "They're going to shoot my cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They're going to shoot my parents.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And every time the shot rang out, I woke up.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And then I had dreams that weren't as terrible as these, like reminiscent of the fire where I was before in Buda.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I would be in a house that's burning and it would be very cold outside.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And in Europe, everybody-- every child wears these high shoes laced up.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I hated them.",
      "word_count": 3
    }
  ],
