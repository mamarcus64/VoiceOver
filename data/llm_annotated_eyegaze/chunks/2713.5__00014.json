{
  "stem": "2713.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "I wasn't so happy, really, because I didn't know if I made the right decision, because I wanted still to see.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "I thought from Italy I might be able to find out quicker than from Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "So I didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "But I already went, and I had to make the best of it.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "The friends were singing and dancing on the ship, and we arrived to Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "Though, ?] really, it was a beautiful thing the way they welcomed us.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "People were waiting, and the orchestra was playing, and they were singing to kids.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "And they really gave us a beautiful time-- a really beautiful time.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "And then they took us to a school.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "The school was called Magdiel.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "It was not far from Tel Aviv.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "And we used to teach Hebrew there for half a day, a few hours.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "And-- and then half a day we used to work there.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "And I was staying there with my friend.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "I was staying there for a while.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "And then after a few months, we left, and we went into Tel Aviv.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 29,
      "text": "And I lived with a family in Tel Aviv.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 30,
      "text": "And then I and my friend, we lived in one room.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 31,
      "text": "We rented a room, and we lived together till I left Tel Aviv.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 32,
      "text": "But while I was in Tel Aviv, I found out about my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 33,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "--she was so happy.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I was in touch whole time.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And they sent me then money.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And they wanted me to come as soon as possible, which I was very happy to do it.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "So I left my friend, and I went back to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "In Poland-- when I arrived to Czechoslovakia, I just couldn't believe that it's happening to me.",
      "word_count": 16
    }
  ],
