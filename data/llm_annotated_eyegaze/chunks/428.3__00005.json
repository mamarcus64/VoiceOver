{
  "stem": "428.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "The hunger, the hunger is terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I just think my mind was occupied how to get something to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And it was no way to get it.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "I used to pick up coals, what they used to run the steam machine.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "I used to pick up coals from the ground and chew it.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "The war was finished, I used to go out with blood because from the constipation from that, everything.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "You couldn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, typhus I got in the camp, in Prokocim.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They took me.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "When it was still-- and Krakau was still a Jewish ghetto when they took me.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It was a hospital and ghetto too.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, I still remember.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Still remember.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The hospital?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Not long, maybe two weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they liquidated the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I still wasn't 100% perfect.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They liquidated.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "There was the ghetto liquidation.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "You got those trombones.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "You could hear the noises outside crying.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "In this time, a Jewish policeman by the name of Puntil, he knows me very good from that labor camp I was working in.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And he took me out from over there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And he took me, he came.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "It was-- no, it wasn't a hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "I don't what it was, just like a room.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And he took me out with a-- he got a-- in Europe, they didn't have taxis by the train or something, horses with that carriages.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "It was a Polack horse and carriage, and he took me back to that camp.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "That camp, in that camp, the camp fuhrer, he was a very nice man, a gentleman, Fischer, by the name of Fischer.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And I was working.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And while I was working, there's a blacksmith there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "And he used to-- I didn't go into the camp to sleep.",
      "word_count": 12
    }
  ],
