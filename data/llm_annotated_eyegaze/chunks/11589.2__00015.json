      "text": "And what do we do?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "What am I doing, I say.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "What am I going to do now?",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I love Hollywood.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I would like to-- I'll tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "I'll give you a address.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Go to a guy over there.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "He'll give you-- go over there and he'll give you a job, you know, as an extra.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So better than doing nothing, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "So I start with that, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Let's stop right there, and we'll change the film.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And we'll talk about it again.",
      "word_count": 6
    }
