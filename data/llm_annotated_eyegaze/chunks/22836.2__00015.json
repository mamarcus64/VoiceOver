  "sentences_input": [
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 15,
      "text": "And they-- and they was Polish people-- the place where I was.",
      "word_count": 12
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 16,
      "text": "And they come after them.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 17,
      "text": "And one time, her daughter come to our bunker-- hide with us together.",
      "word_count": 13
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 18,
      "text": "It was so bad, already.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 19,
      "text": "And we see that's another place.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 20,
      "text": "And the-- and the-- and the Ukrainian was go-- coming in the-- come in there, in the-- in the bars-- not in the barn there, in bars-- in the bar-- in the stalls with the cattle, and with the sticks, looking for something on the floor.",
      "word_count": 46
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 21,
      "text": "Looking-- they know that I-- that I sometime-- maybe clothes or something.",
      "word_count": 12
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 22,
      "text": "I know what they want.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 23,
      "text": "And they come in-- there come in a guy with a stick.",
      "word_count": 12
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 24,
      "text": "And he says, [NON-ENGLISH]-- mean cow, cow.",
      "word_count": 7
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 25,
      "text": "And he sticks.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 26,
      "text": "Then he come in.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 27,
      "text": "Then he come in the other room.",
      "word_count": 7
    }
  ],
