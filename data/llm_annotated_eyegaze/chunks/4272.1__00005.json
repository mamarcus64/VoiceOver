{
  "stem": "4272.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And they said well, we'll try.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "When they said, we'll try, and they didn't have a place for sure, I wasn't going to spend the 15-- 15 zlotys.",
      "word_count": 22
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "It was too much.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "So and that's when I went to Warsaw and I got a job.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And I worked in what we called the perfume area.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And I had a sister living in Warsaw, so when the war broke out, that's where I was working and that's where I was stuck, in Warsaw.",
      "word_count": 27
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't-- couldn't find my-- my way to go back to Plozk.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Did you have any other close relatives that lived near you as a child?",
      "word_count": 14
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Not very far, but not too close.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Not in the same city.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "My-- my mother's parents and family, my father's parents and brothers and sisters.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "But not in Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "They did not live in Warsaw, nor did they live in Plozk later on.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "What were your grandparents' names?",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "My-- my grandfather on my father's side, my paternal, was Lazar.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And as a matter of fact, my oldest grandson is named after him, Joshua Lazar.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And my-- my grandmother's name was Golda.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "On my mother's side, it was Avrum Hyam, and my grandmother's name was Pesa.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And they, of course, lived in two different cities in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "You were telling us that you were working in Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Were you there when the war broke out?",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "The bombing?",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes, I lived through it in Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "It was-- it was-- the only thing we could find to eat were-- were herring and pickles, and no water.",
      "word_count": 20
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "I remember taking, once, a bucket, and I went to the Vistula to get some water.",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And a German noticed me, and he pulled the bucket for me and poured out the water.",
      "word_count": 17
    }
  ],
