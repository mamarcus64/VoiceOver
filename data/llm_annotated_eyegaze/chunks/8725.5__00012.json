  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So at night, I-- the light-- we, we didn't make it light.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "The people could come down, stretch their legs, wash themselves, clean, and eat.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And then-- now, finally downstairs was painted, down-- cellar and the kitchen and living room and this.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Now, they did have only the bedrooms to do.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "So I took them down to the-- to the servant quarters.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And I was thank-- I was so happy that I have a place for my friends.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Food was never a problem, because not only that I was serving, you know, in the, the major-- in-- dinner yet.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So Schultz was giving me lots of food.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But the major, you know, stocked his house with food.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "The Schultz did go with me to the German warehouses and we bought whatever was needed.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
