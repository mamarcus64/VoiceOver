{
  "stem": "17299.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 319.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They were under supervision of German police, and we were under supervision of German army, who marched us out of the ghetto.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But before they-- we were marched out, they took some more people out of those two rooms to give us more place.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "There were 25 in those two rooms, and then we were eventually left with 13.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And in one room were two mattresses on the floor, a closet, and a couch.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "In the other one was a kitchen table, four chairs, and a couch and the oven.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "So we decided that the old people would sleep on the mattresses and on the couch and we the younger people would sleep on the floor.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "There was a gate with a couple of guards.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But for every 20 Jews was one German soldier armed with a rifle when we were marched out--",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "--to the harbor.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Latvian-- Latvian SS or police.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We were marched out of the ghetto shortly after 7 o'clock in the morning, and we arrived by 6 o'clock back in the ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And we had to go in the houses, and there was a curfew.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You could not go out anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The guard would march you on the street where you were living, and that's when you went into the houses.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "There was a family of Nathan Liftman.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It was husband and wife and one daughter, and-- and mother and daughter named Levi.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Nathan was his first name.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Her name I forgot, and the daughter was Alice.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Levi.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The daughter was Emily, and the mother was very well known in Germany as an-- a communist.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And prior to the-- prior to Hitler, she was leading communists in the city of Rheydt, which is next to Munchen-Gladbach, the place where Goebbels came from.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "There was one oven.",
      "word_count": 4
    }
  ],
