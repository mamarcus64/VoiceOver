{
  "stem": "20580.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I took him out from the basement, from the cellar, which he didn't see the light altogether.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Because it was after they did the killing.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I took him out with the [NON-ENGLISH]-- that means the head from the city.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "We took him out, and I bring him to Lokacze.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And we work together with-- living together.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "My brother.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And suddenly, my mother, after three, four weeks, she couldn't stay by herself.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "She put down at night, 12 o'clock at night, the middle of the night.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And she walked to the-- the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And she came to me, my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "We were together in the ghetto, Lokacze.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was-- oh, Lokacze was-- the ghetto actually was 3,000 people.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was maybe 2,500-something, or 3,000 people, 3,000.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The ghetto was a-- a big lot, you know, like a street, like over here is a street.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "It was three, four streets.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But there was 3,000-- all everybody was in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Couple streets, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "In the front-- the front market was-- doesn't belong.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But I had, in the front market windows, with the door, I marked finishing leather.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I bring from the factory the leather.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I work in the-- I went to the front.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I-- only I could go to the front.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "The front.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "But nobody else.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Now, let me give you another explanation.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "My mother, when-- after the killing, the-- in the same city, 5,000-- 500 people, because that city, Horochow, was 5,000.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "They kill-- have to kill 500.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Then my mother has friends.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The night where I do, she says, I going to see what could I do.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "That the lady steal the border, goes here and goes there.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "She has a husband over here and children over here.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "She comes in.",
      "word_count": 3
    }
  ],
