{
  "stem": "22889.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "They were more free than we were, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "So he used to live down there, and he used to help us out.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "But I hadn't seen him since '42.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I was in Auschwitz in 1945.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "The January 1945, January 18, I left Birkenau.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We left Auschwitz.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We were burning the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I was one of the last transport.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So what we did-- we came from work.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We worked to the last minute.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The order came out we have to evacuate the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We're allowed to take our blankets with us.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They give us extra ration.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They give-- instead of once slice of bread, we got two slices of bread and a soup.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] So we started to--",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I was one of the last transport.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "But what happened-- Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Mengele had his hospital in Buna, down there.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "That's where he was performing his experiment-- different things.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Was a big hospital down there.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But there were a lot of kids.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He left kids scattered behind.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So there were some people that just ran away.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Because we knew there were Russian coming in.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But in the meantime, the camp was liberated nine days later.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "We thought for sure they'd be liberated the next day.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Because you could see the sky was all red.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They passed Krakow.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "From Krakow to Auschwitz is only around 40 kilometers.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And we thought they're for sure going to liberate.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "So some people remained in the, in the Buna, in, in the, in the camp.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "And they left some children, too.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "But we marched--",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Because I was the one-- the last transport that left Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We were burning the barracks.",
      "word_count": 5
    }
  ],
