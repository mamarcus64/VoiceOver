{
  "stem": "10335.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.8,
  "sentences_input": [
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 2,
      "text": "Sure, they're putting the people right in the bakery.",
      "word_count": 9
    },
    {
      "segment_idx": 191,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 0,
      "text": "Then who was go to Schindler, he tell them, there in Gross Rosen don't touch the people.",
      "word_count": 17
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 1,
      "text": "Not the men, not the woman.",
      "word_count": 6
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 2,
      "text": "They're mine's, and I take back.",
      "word_count": 6
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 192,
      "sentence_idx_in_seg": 4,
      "text": "In the morning, he take everybody, everybody who belonged to him, and going.",
      "word_count": 13
    },
    {
      "segment_idx": 193,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 0,
      "text": "But not the people that he said don't touch?",
      "word_count": 9
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 1,
      "text": "But about 4,000 people.",
      "word_count": 4
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] Was supposed to talk about the situation was.",
      "word_count": 12
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 3,
      "text": "Was supposed to talk all night.",
      "word_count": 6
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 0,
      "text": "You have to go to home.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 0,
      "text": "So what-- I say a lot of friends, Polacks, Polish people-- I ask, what are you doing over here?",
      "word_count": 19
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 1,
      "text": "Oh, they'll take me, too.",
      "word_count": 5
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 2,
      "text": "You want to go with me?",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 3,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 4,
      "text": "To Schindler.",
      "word_count": 2
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 5,
      "text": "No, I have to go home back.",
      "word_count": 7
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 6,
      "text": "There a lot of international people.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 7,
      "text": "Was German even, Russian, all that kind.",
      "word_count": 7
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 8,
      "text": "What they living in their hometown someplace.",
      "word_count": 7
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 9,
      "text": "It's not if [INAUDIBLE] No, no.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 10,
      "text": "She went over there like that.",
      "word_count": 6
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 11,
      "text": "But they took a big shower-- from the shower, straight to the oven.",
      "word_count": 13
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] Young people, kids, everything.",
      "word_count": 8
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 13,
      "text": "Pregnant woman.",
      "word_count": 2
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 0,
      "text": "It's not a good thing, believe me, not to tell what's going on.",
      "word_count": 13
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 1,
      "text": "What's what over there.",
      "word_count": 4
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 2,
      "text": "Ah, what it can do?",
      "word_count": 5
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 0,
      "text": "And I wish to say, the young people, the young generation over here, to watch your steps, and be ready.",
      "word_count": 20
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] They think I left.",
      "word_count": 8
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 2,
      "text": "I not left.",
      "word_count": 3
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 3,
      "text": "We see that look like now.",
      "word_count": 6
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 4,
      "text": "You see, Europe, what's going on again.",
      "word_count": 7
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 5,
      "text": "Better in a wish, another war comes up in Europe.",
      "word_count": 10
    }
  ],
