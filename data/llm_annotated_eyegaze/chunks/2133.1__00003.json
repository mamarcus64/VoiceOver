{
  "stem": "2133.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "But unfortunately, he died when he was 19.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "There was two doctor who was taking care of him, and one doctor gave him an injection.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "It was a horse serum something.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "That's what they called-- what I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And the other doctor didn't know that this doctor had given it to him, and he gave him one.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And nine days after that, I believe, he died from that.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "The-- you know, it was like malpractice they would call it today, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So [CLEARS THROAT] I didn't know too much about my brother, because there was a tremendous age difference.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I believe I must have been five years old when he died, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So-- and-- and my sisters, [CLEARS THROAT] two of my sisters remained in-- in-- in Berehovo.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And the other two went out to Brussels, Belgium.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My-- my younger sister, who was-- there was two years difference between us-- her name was Helen.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And she-- [CLEARS THROAT] my oldest sister, Gizelle, who was already living in Brussels, Belgium-- they finished school in Brussels-- and my youngest sister went to live with my older sister.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "She felt that maybe have-- have a better opportunity in life in Belgium than it was in-- in Berehovo.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I believe that it was-- the population was about, approximately, 20,000, 21,000 people.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And among the 21,000, I believe about 9,000 was Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It was a beautiful town, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It was a [CLEARS THROAT] fairly prosperous town for people.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, it was like-- they used to call it like a little Paris.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "People was told nothing compared to go up to Budapest or to Paris to have their clothes made, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "It was, you know, very-- very-- very interesting town to-- you know, and very interesting people.",
      "word_count": 16
    }
  ],
