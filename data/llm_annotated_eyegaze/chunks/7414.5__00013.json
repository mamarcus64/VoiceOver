  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "But anyway, they had to-- again?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Can I talk?",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, they had to get me-- tell-- help me.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "The-- they started-- the doctors and nurses, there were no-- they were no help like today, with all the medical-- medications.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "They did not have even an aspirin there in the hospital-- aspirin.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "But the child was born prematurely in eight months.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And I started to hemorrhage.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And the doctor told-- the-- that was the last thing I heard.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Take her to the operating room.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    }
  ],
