{
  "stem": "150.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And eventually I went to Russia with a group of other activists.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And theoretically, I'm a Soviet citizen.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I'm from Lithuania.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "They could've kept me.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And my wife felt that I had put the cause-- because I went against her wishes, and I felt I had to go.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "And I met with a lot of dissidence and brought out film out of there, which was shown on national TV, stuff like that.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And she felt that I was putting this cause, you know, over my family, so she left me.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "It was a shock to me because I'm a very loyal person.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Once I develop a loyalty to somebody or something, I'm there.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "And I felt that as a terrible betrayal.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "And then after that, I had a girlfriend who had come out of the Soviet Jewry movement, and we were very close.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "She was younger than I.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "She was a very nice person.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "And she died.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "She had a brain hemorrhage totally unexpectedly, just collapsed in the parking lot of the Pomona Fair.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "Just like that, never regained consciousness.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 29,
      "text": "So that was a shock.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 30,
      "text": "And then I met another lady, and we eventually got married.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 31,
      "text": "That was Kathy, my wife.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 32,
      "text": "And we were together for something like 16 years.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 33,
      "text": "And she was very, very sick over the last five, six years.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 34,
      "text": "It was a miserable life for me, miserable life for her.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 35,
      "text": "She was almost always in pain.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 36,
      "text": "And she died three weeks ago, a month ago now, almost a month.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 37,
      "text": "So there we are.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 38,
      "text": "So don't come too close to me.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 39,
      "text": "Bad things will happen.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 40,
      "text": "Kidding.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Kathy has a daughter, Michelle, whom I brought up from the time she was five years old, and we are quite close.",
      "word_count": 22
    }
  ],
