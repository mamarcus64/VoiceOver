{
  "stem": "7777.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "If I will be closed, I will not have money to pay the mortgage, and I will not have a place to live.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "I will not be able to live.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "He said all right.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "He went out of the phone.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "When I start my business, I told my landlord I will close.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "My landlord told me you take in $700 to $800 a week.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I ask him, you guarantee for $800?",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He said, if you will take in $700 for comic books, papers-- a candy store-- if you'll take in $700, you will make a living.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I took in the first week $680.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Only when it's come to Rosh Hashanah, he said you will spoil the business.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I said, what will be will be.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "I will be closed.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I closed Rosh Hashanah, Yom Kippur, and the business start to be better.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "Business start to be better.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "In 1952, I bought an apartment building with 10 apartments.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I have already money.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "I call up my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I hear she was very mad-- a greenhorn, he is in business 20 years already in the candy store, and they still live.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "They still have just the candy store, and they have little bit money in the banks.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And here, him just after two years, he bought already-- she was very mad.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "She was.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Only when we went away and I bought this apartment building, and I worked out the store, it took in $2,000, $3,000 a week.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "I make bigger.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "I moved out from the store in my building, and I took an apartment.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "Took in a partner.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "The business was going good.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "Meantime, in '56, I bought a home.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I moved out from my apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I moved in the home.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "In '59, I moved in in the home.",
      "word_count": 8
    }
  ],
