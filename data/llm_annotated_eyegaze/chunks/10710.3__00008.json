{
  "stem": "10710.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 64,
      "text": "One was a woman was cooking for people, you know, private foods.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 65,
      "text": "Wasn't so bad.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 66,
      "text": "But one day, we were sleeping in-- in the barracks.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 67,
      "text": "And on our side, where we were in the barracks was an [? entlausen. ?] It means that they cleaned the barracks for lice and for everything.",
      "word_count": 27
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So we had to move out from those barracks.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And we went-- we-- we went into the other barracks with the other people where they lived.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We were sleeping at night, and suddenly we heard a big noise and a fire.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "One of-- one of the English airplanes, a bomb airplane, fell down in our camp.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And it fell down on the barracks where we used to live.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And there was nobody there because they were-- they wanted to clean it up.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And there was such a fire and shooting from the plane that we didn't know what happened.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Everybody ran out in the-- at night, and we were running to the-- to the gate.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And the SS men were standing with their guns.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He says, you can't go out there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "We thought somebody put the lager on fire, and we're going to be all burned, till we found out.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And in the morning, was saw the plane was burned.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And the pilot was burned, sitting still on the-- on the-- on the seat with his-- with his thing there.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "It was a English plane.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "From then on, the camp was closed.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "We had to go back to Plaszow every morning and walk back at-- at night, back to Plaszow.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "It was back to the horror there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And a lot of people-- they eliminated a lot of people to come down because they didn't need so many people.",
      "word_count": 21
    }
  ],
