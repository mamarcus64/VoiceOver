  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I did want to go together with my girlfriend, but she worked.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So I had to go alone.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And I cried, of course, because I didn't know what was waiting for us there.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And when I came, the wait nothing. 50 girls from there did go back.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "From the 50, three stayed in Kaiserwald.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And me and two more sent back there.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "To Strassenhoff, to clean up the concentration camp before they leave the place.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Because the Russian were already under the head.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    }
  ],
