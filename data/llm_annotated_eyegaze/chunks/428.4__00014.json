{
  "stem": "428.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It's right there, two blocks away.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It's a very Russian place, five-- five women.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And it cost you the same money.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "She is treated like a king.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I come over there, I thought, I'm in my apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "It's cleaner than my apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And I called up my daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And she came and saw it's clean.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "She has her separate room, beautiful, clean.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "The daughter left a deposit right away.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And the next day, I moved her.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And it's going to be now a year she's in this place, very, very clean.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "They cook there.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "They bake there.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "They take care.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "She-- she doesn't smell.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "She's clean.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "She-- like this, she's healthy.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "Because I have a doctor from Century City, Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "Trager. ?] He comes to her once a month, something like this.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "She's-- so she's taking pills, only anti-depression pills, Tegretol, to relax her a little bit, and takes pills for sleeping, something like this.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "And I go to her every day.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "She knows I'm there.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "Sometimes I take her out for a walk.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 27,
      "text": "So I tell her, Regina, when you're going to feel good, when you're going to feel cold, tell me.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 28,
      "text": "So she says, I'm cold already.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 29,
      "text": "Sometimes she knows, what-- sometimes she cries.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 30,
      "text": "I don't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 31,
      "text": "I don't remember nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 32,
      "text": "Most of the time she talks, she talks with-- I don't know what she's talking.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 33,
      "text": "I don't know, she talks, she talks.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 34,
      "text": "And she-- she-- you see, she knows that she's not home because she used to live there in one apartment for 23 or 25 years.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 35,
      "text": "When she wakes up, she looks up at the ceiling, she looks around.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 36,
      "text": "She sees that she's not in the place where she used to be.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 37,
      "text": "But it's terrible.",
      "word_count": 3
    }
  ],
