  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "And in the tape, you'll hear the mayor telling me in Russian language-- and I interpret it for my son into English-- that the mayor says that 350 to 400 young men are in a separate grave.",
      "word_count": 37
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "Just soon as they took them out of their homes, they brought them there.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "And they locked them up in-- in special places and fed them with salt, herring only, and no water to drink.",
      "word_count": 21
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "They thought they will die that way.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 12,
      "text": "They didn't die that fast.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 13,
      "text": "Then they killed them all.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 14,
      "text": "There was another grave, except the one in the picture that I have of 4,000.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 15,
      "text": "This is another of the young men, the same area, in the same wooded area.",
      "word_count": 15
    }
  ],
