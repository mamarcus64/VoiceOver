{
  "stem": "5275.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So I showed him my false papers, and they ask me all kind of questions, and my mother-- [PAUSES FOR 3 SECONDS] that's right, my mother didn't have false papers at that time, no.",
      "word_count": 34
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My mother didn't have false papers at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So she was talking in German-- it was very helpful-- she was talking to them saying that, I don't know, some story she gave them about her papers being in Warsaw, and she introduced me as her nephew through a marriage, OK?",
      "word_count": 42
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And persuaded them that, you know, that I wasn't Jewish, and they said to me-- the Gestapo's name was Fromer-- Herr Fromer-- that I can go to Warsaw and bring her papers.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So they released me, and I, indeed, went to Warsaw to a friend of my mother who was doing those things, and he gave me false papers for her, with the name, Anka-- I have to look it up.",
      "word_count": 39
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I forgot her last name.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I came back to Krakow, went to the Gestapo headquarters, give him the papers, my mother's false papers, and he looked at them and said, fine, your mother will be released soon.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I went to the apartment, my mother's apartment, and I had no money, no food, and I knew that in her wardrobe, she had some bottles of alcohol, and I could sell them.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The closet had a Gestapo seal on it.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I broke the seal, got the alcohol out, sold it, and had some money.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "The Volksdeutsche saw it, that I broke the seal.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Anyhow, I was going to come back to it in a moment.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Anyhow, I stayed in my mother's apartment, and of course, I wanted to communicate with her.",
      "word_count": 16
    }
  ],
