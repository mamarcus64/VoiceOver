{
  "stem": "142.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And my brother passed away in 1994.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "When I was in the crematorium, I knew exactly what happens.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I returned to Salonika for a couple of days, 45 years later.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I didn't recognize anything.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't interested anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "It was only-- you know, from all the 60,000 Jews that went to Poland, only 1,750 return.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, since I was in Greece when the Joint Distribution closed, and I was an Italian citizen living in Greece, and start taking permits-- that was the Truman Doctrine in 1951, where 250,000 displaced persons from-- they could emigrate to the United States.",
      "word_count": 43
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I was sponsored originally from the Jewish community of Cleveland, Ohio, which they pay my expenses to come over.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But I went there for a very short time.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I wanted to be on my own, so I came to California, where the weather is much better for me.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I was used to a warm weather.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, I stayed very short time.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I-- I met-- when I came to Cleveland, there came a very nice lady to meet me.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I wasn't speaking English at that time, so we spoke French.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And he start asking-- telling me that, you know, we give 10 cents for a razor.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I says, I want something to work.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I am not interested in having, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So he says, well, you know, my-- my husband is a sales manager for the Bloomfield Company, of one of the biggest manufacturers of dresses, you know, just bought a new Cadillac, 1951.",
      "word_count": 33
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And he would like a chauffeur.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You know, he's having a hernia surgery now, but he'll be well in a few days.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I says, I'm a-- I'm a chauffeur.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So and I says, why don't we go to the DMV and get a license.",
      "word_count": 15
    }
  ],
