{
  "stem": "25027.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The Soviets were sending out draft notices to all the eligible men, 18 and older.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Most of them were hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "They did not want to join the Soviet army.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Men in-- I would say most Ukrainians-- Gentiles and Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They didn't want to go who knows where.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And many of them didn't believe that the Germans would kill any civilian population.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So I was walking in the center of the city.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was like two days into the war, two or three days into the war.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I was the same height like I'm right now.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Much younger, I should say, and they had military police checking all the passports, identifications of all the men that they could spot in the-- in-- in the street to see how come you're not the army.",
      "word_count": 37
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "You know, you received a notice.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The notice came over the radio.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "All men report for military duty.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And as nobody showed up, they want to know why.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] So they caught me, and I was only 16.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I was 16 May 26, and this was June 21, 23, 24.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] And they brought me into the-- to the barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I protested that I was too young.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I even showed them my passport that I had.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "It didn't help.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You're old enough to fight for your country.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They were desperate to get men.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was held in the barracks for two days, given a uniform, given a gun, and by that time, I was able-- I didn't come home.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My mother realized what was happening.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She came looking for me and she found me on the other side of the fence, which we couldn't go out.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And she went to see the commander, and he says, we-- he's now a soldier.",
      "word_count": 15
    }
  ],
