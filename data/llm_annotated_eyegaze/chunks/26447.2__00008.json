    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I hear the shots with the shots.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I hear how the car-- the truck left with the people.",
