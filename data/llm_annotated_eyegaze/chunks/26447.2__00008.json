    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "It's best maybe, no, I'll tell you maybe three minutes, four minutes.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "It's opened up the-- the barn.",
