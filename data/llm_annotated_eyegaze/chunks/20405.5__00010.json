  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Then from them, he said, we're going route right into the Birkenau on the barracks.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Were going to make a mess over there.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And from there, who knows?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "God knows, we're going to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We're going to get killed.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "We know that.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "But over here, we're working for them.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "We're going to get killed anyway.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "So the Greek people all agree.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "The Poland people, they were so strong and so big, they were afraid somehow.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "They were not just-- to believe in it like the Greek people.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "The Greek people were more-- more courageous.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "In the meantime, this Joseph was talking all the time with a kapo we had, with a-- a short guy of kapo.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And the kapo was agree with him, because it was two, three years working over there with the kapo.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "We're going to stop now and change the tape.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Hm.",
      "word_count": 1
    }
  ],
