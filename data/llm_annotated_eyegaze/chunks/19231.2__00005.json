{
  "stem": "19231.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.6,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We used to wash-- wanted to wash floors.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We help with the families that were living there.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They had-- they were citizens.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I met a Jewish couple that-- there.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And they were very nice to me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They said, why did you come and help me with the child?",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And, you know, they fed me.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They gave me some old clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And my mother, meanwhile, was in the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So on the one day-- I used to go to see her.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "But they wouldn't let me in, because it was infected.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "You know, they were afraid that I'd get infect-- infection from-- infected-- how you say it?",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "An infection.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "She-- she was quarantined from you.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "She was quarantined.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They didn't want-- so I couldn't see her.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And she was on the second floor.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But a couple weeks later, they put her down on the first floor.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "So I could see her through the window.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "But one-- a couple of days later, I came in. and the-- and the bed was made.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I said, where is my mom?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They said, she passed away.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Somebody told me-- I don't know if it's true-- they said that they poisoned the people.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They didn't want to bother with them, so they gave him poison.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I don't know if it's true.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So here I was all alone.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I even went to see her after-- you know, they took me in to see her when she was dead already.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And she-- and later on, I was-- I went to this Jewish family that I made friends.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And they said, well, you have to go to work.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And-- and so I went at-- at this factory.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And I told them that I'm alone.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "I would like a job.",
      "word_count": 5
    }
  ],
