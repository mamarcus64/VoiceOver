  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "They had to have a dispensation place, and statistics for a malaria station.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "She give me the job, and the other girl she gave a job something like typing somewhere else.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "Put us with a family, with a woman, had five children.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And one was not a crip, but you know, like a swing, a wooden swing.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "It was hanging from the ceiling.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "And the baby-- the kids cried constantly.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "They were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "And the woman was-- [PAUSES FOR 4 SECONDS] she was just praying that the baby should starve.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "And we had one time a day some kind of a soup where we were going.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "And it was depressing.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "We were lonely.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "This place looked so-- the whole place looked so strange, barn-like, like somewhere on the other end of the world.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "And we decided to walk home.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "We decided, we'll see, we'll walk on for the weekend and see.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "We didn't have mail.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "There was no telephone, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "When I came back, which my mother tells me that the [RUSSIAN], the director of the farm, learned that I'm a bookkeeper and they need a bookkeeper.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "And he wants me to go and work in the office.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "So I get this job in the office now.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "The bookkeeping is not done like it's done-- because they don't have money.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "They-- the unit of payment was after the whole season, whatever the-- they pay down from the fields and divide it.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "I mean, it's quite a complete different bookkeeping anyway.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 48,
      "text": "But they gave me the job.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 49,
      "text": "And he said that he'll help me, whatever he can.",
      "word_count": 10
    }
  ],
