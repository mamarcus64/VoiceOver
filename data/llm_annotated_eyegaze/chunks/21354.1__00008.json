  "sentences_input": [
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "My parents made this decision and told me that they'd decided it was best for me to leave before we were going to America, because we still planned to go to America.",
      "word_count": 32
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "They considered my sister to be too young, and so--",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "She was five years younger, so she was 11, 12.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I came on my own with another group of children.",
      "word_count": 10
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "I've no-- absolutely no idea of.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "The-- my mother was very active in the community and that all happened within days.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "My ca-- my mother was very active in the Jewish community, yes.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Very active.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "My mother [PAUSES FOR 3 SECONDS] was active with the immigration of children to Israel-- to Palestine at the time-- and also to receive people coming back from concentration camp.",
      "word_count": 30
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "They had a community of women who stid-- stood at the platform to receive the men coming out, to give them food, to give them hope.",
      "word_count": 26
    }
  ],
