{
  "stem": "12506.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "We used to learn, you know, the Talmud.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "You're supposed to learn by heart.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "So what my brother would look through it once, and then he knew it by heart.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "I had to work another whole day.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "So sometimes I got a little bit [LAUGHS] jealous or even upset.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "He was  very, very smart.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "The other one, his name was Jeremiah.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And Jeremiah was more of a businessman.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "He was all brains.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "He always figured out how to make money, and how to do things, and how to-- always, always.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "And the third one  was the [NON-ENGLISH] that passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "The third one-- I was the third one of course.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And my-- my-- my fourth sister-- [INAUDIBLE] there was Chanele.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "She was born-- died at two-years-old, there years after me And my other sister was Ella.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 25,
      "text": "She lives here in Del Ray Beach.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 26,
      "text": "And the little one, [INAUDIBLE] Zeisele, never came back.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 27,
      "text": "Very, very pretty little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 28,
      "text": "We used to be so together and we-- so close and.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 29,
      "text": "I can't put her out of my mind.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 30,
      "text": "She was just a child.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "From Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "From Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "She was 10-years-old.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Yep.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My mother was cooking and baking, and taking care of us, and giving us love.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "That's the most important part of a family.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "She was  very, very-- I loved my mother more than anything else.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "She was the best.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "She was a real Yiddish mom.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Very proud.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Very proud.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, we-- first of all we went to the synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We were praying.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then we came home.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we had our meals, our Sabbath meals and our holiday meals.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And it was sukkahs.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We went to the sukkah when it was Passover.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "We made a seder.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "The way it's-- it's written in the holy book.",
      "word_count": 9
    }
  ],
