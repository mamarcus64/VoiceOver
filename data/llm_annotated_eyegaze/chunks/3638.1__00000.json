{
  "stem": "3638.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BEEP]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name in Australia, John Armer, A-R-M-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Janek, J-A-N-E-K, Armer, A-R-M-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The Hebrew first name was Jakob, Jakob.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "J-A-K-O-B.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "26 of nine, 1925.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have-- I had, you know-- should I share that this is not the right birthday?",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "On passport documents, 26 of nine, 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But my real birthday was 18th of nine, 1925.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I am 69 and 10 months.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The city was Krakow and the country was Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Krakow is K-R-A-K-O-W.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I had two brothers and one sister.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And about my family, my family, my parents were Orthodox Jews living in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And my father was a grain and flour merchant before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my father and his father and his his father was born in Poland for the last three or four generation.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father's first name was Israel, Israel Mordechai Armer.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "He was an Orthodox Jew, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he did belong to Belzer Hasidim.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they were strict orthodox, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But not so strict, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My father wasn't so strict.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHTER]",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, all I remember was I went to the-- to the Jewish school in the afternoon, which called Cheder.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Cheder.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And in the morning, I went to the Roman Catholic Polish School.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So before the-- before-- before lunch, I used to learn Polish and all the other secular thing.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "In the afternoon, I used to learn Hebrew and the Talmud.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Eh, yes, we like it very much.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We played a little bit soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And we fight with the rabbi, but it was all right.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, we always used to, you know, make jokes, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't so-- it was just like a Cheder, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Everybody did what they wanted.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't so strict as in the Polish school in the morning.",
      "word_count": 12
    }
  ],
