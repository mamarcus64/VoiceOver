  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "He had to do the daily work too.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "So the daily work, they-- they give to the Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "So-- so how long could you hold up?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Outside-- [PAUSES FOR 7 SECONDS] Continue, Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Silber.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Outside, how long could you-- could you hold up?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was so cold.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "The first day they could-- they gave me-- when I come alone, a mechanic, they give me-- and the commander for mechanic.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I go over there.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It's a different story.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The inside, it's warm.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] It's warm, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So I said, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "If that's the case, we gonna survive.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I was talking to myself and to my friends.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We survived.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So we came home.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Next morning-- no, no-- the same night, the fellow who-- who marked down that I should go to-- to a mechanic, he told me, don't come tomorrow.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "If you come tomorrow here, they gonna kill you.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "He brought you here because somebody was sick.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Another fellow was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "The fellow was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Come back-- no room for you.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So I said, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Better one day like nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "So I was over there.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I was over there.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I went away.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was scared already to go back.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So I went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I was away at least for 10 days-- no, maybe not-- for 10 days.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I said I cannot hold on happen.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "My back doesn't hold me anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't hold out the back.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So because you had to work outside, and go with stones, it was not much to work.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Stones, bring it here and then bring-- go back with the stone.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So after this, I don't care if I die or not or if they kill me.",
      "word_count": 16
    }
  ],
