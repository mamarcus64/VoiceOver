{
  "stem": "8002.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 19,
      "text": "And she started to scream so loud, a lot of people came.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 20,
      "text": "And the [NON-ENGLISH] right away took us again.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 21,
      "text": "And instead of sending us to Dvinsk Ghetto, they send us to Dvinsk jail.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 22,
      "text": "They took us to Dvinsk jail.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Over there, I was separate from my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And they took me.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And they say, did you see anybody-- did you see anybody has [PAUSES FOR 3 SECONDS] guns or knives?",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Because you were hiding, do you know everybody?",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Do you know where the people are hiding?",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I told them, no.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "I was, at that time, what, 12 years old?",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH SPEECH]-- I'm going to show you.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And he took a whip.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And on the end was lead.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And he hit me with the whip.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I still have a, a broken skull.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And he saw that I didn't say nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And then I saw a wall.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And it had mud on it.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "He says, come over, [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "Stay by the wall.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "And he put me by the wall.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "And then I heard zzzt.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "And my whole body went-- like a shock.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "Then I find out there was electricity.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And he did it for quite a few times.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "But I couldn't tell him anything I didn't know.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "Then he put toothpicks in my fingernails.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "And they put the-- a substance-- I don't know what kind it was.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 18,
      "text": "It was wet, the, the toothpicks.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 19,
      "text": "And he lit a match.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 20,
      "text": "And I screamed, but I couldn't tell him nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 3 SECONDS] He says, you're a, a, a strong boy.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 22,
      "text": "You don't want to tell me.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 23,
      "text": "But you're going to tell me.",
      "word_count": 6
    }
  ],
