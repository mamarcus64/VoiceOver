{
  "stem": "24111.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The mail order business of my mother and father was taken over, what is-- what was called at the time, [NON-ENGLISH] taken away from the rightful owner and it was taken by two Austrian Nazis, one by the name of Krebs.",
      "word_count": 41
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "K-R-E-B-S.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And the second one by the name of Magyear, M-A-G-Y-E-A-R.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They took over the-- the business.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Of course not.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "They came one day, and they say, well, a Jew is not allowed to have a mail order business.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "We will run it.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "That was a government proscription",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And my father had to work for them without any salary for, I believe, three to four weeks to show them the-- the business.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Our employees just were taken over.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The stock and the-- the equipment, office equipment and so on were just taken.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "At the same time, we had to leave our apartment too.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "The building we were living in, 14 Porzellangasse in the Ninth-- Ninth District of Vienna, was declared Judenrein, which means the owner didn't want to have any Jews renting apartments.",
      "word_count": 30
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So he wanted his building free of Jews, and that was very possible at that time.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And the Jews living there could only take along the things they could carry.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "They had to leave all their furniture, all their belongings where they were.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And we moved in-- I'm speaking about my father and my mother and brother and me-- into an-- into an apartment owned by another Jewish family, which had, for example, an apartment of four rooms.",
      "word_count": 35
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And we moved into two rooms of-- of four.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I think that my mother could free my father because she could prove that he was still needed in the business ran now by German owners or something, you know, that nature, which was an [NON-ENGLISH] business.",
      "word_count": 37
    }
  ],
