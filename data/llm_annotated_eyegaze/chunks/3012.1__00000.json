  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Olga Kovacs.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "K-O-V-A-C-S.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "That's the Hungarian spelling.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No, I have not.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Salgotarjan, Hungary, on May 23, 1926.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "69.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "S-A-L-G-O-T-A-R-J-A-N.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "We were a family of 14.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My parents, my grandparents, paternal grandparents, aunts, uncles, and cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I have never known my maternal grandmother, and my grandfather-- paternal grandmother-- and my paternal grandfather passed away when I was a toddler.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We always lived in Salgotarjan and my parents grew up in the town.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I started schooling in Salgotarjan where my parents had a business.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The grandparents were [?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Cecilia ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Jacob ?] Biheller.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "B-I-H-E-L-L-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "My paternal grandparents were [?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Louise ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "Leopold ?] Kohn.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "K-O-H-N.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My parents-- my mother's first name is Sari-- S-A-R-I-- and my father's first name is Dezso-- D-E-Z-S-O.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Kovacs.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I tell you why.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "When the brothers-- father had two brothers-- went to college, then as far as I remember, being told by my father, the dean suggested to my grandfather that Mr.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Kohn-- it would be a good idea if the children take up a Hungarian name.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So the Kohn-- K-O-H-N-- thus became Kovacs, which in English means Smith.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Father had two brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Uncle [?",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Bela ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Nandor. ?] Both were married.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Eventually Uncle [?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Nandor ?] divorced.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "He had a son-- my cousin George-- who died a number of years ago in Spain.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And Uncle [?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Bela's ?] wife-- Mucu-- M-U-C-U-- lives in Budapest with my cousin, Vera, her daughter, Susan, and two grandchildren, Gabor and Aniko-- A-N-I-K-O.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father's two brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My mother's two brothers were [?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Bela, ?] who was married to Irene.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They had a daughter, Edith.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "The other brother was Gino, married to Lilly and had a daughter, Agnes.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Mother's sister Olga was married to Dr.",
      "word_count": 7
    }
  ],
