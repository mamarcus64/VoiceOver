{
  "stem": "6110.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "That was very bad to take care of everything But I had the sister, the oldest sister.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And she, she was very nice provide by her husband He was a nice man, my brother-in-law.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "He had a beautiful job, made a lot of money.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "So he used to help us out.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "His name was Abraham Sauber.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My sister was Helen Sauber.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So she used to help out.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And we were living.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Everything is living, good living, bad living.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "For Jews, terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "First, they didn't let into schools.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to take to schools us.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "They didn't-- the colleges were closed for Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "On the street, they used to make like such a-- the, the college boys, the Catholic college boys, they used to run around in the city, beat up the Jewish boys.",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And it was a, it was a horror.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "It was horrible to live in these circumstances.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "You were afraid of your life.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Later on, they came out with the star.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we had to wear a star, sure.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "They closed up the businesses.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The Jews were making like kind of black market, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It was very-- I can tell you the truth that I-- things like that, it's like somebody wiped out from my mind.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Or I, or I wanted to forget.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "But I forgot.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I, I can't come back with what happened to the, to the, to the businesses or to that.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I can't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "I know people lost a lot of businesses.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "They couldn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "Life was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, she wasn't forced.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "But she couldn't afford anymore to pay for the apartment so much.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And so she moved away from it.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "It was in the middle of the city.",
      "word_count": 8
    }
  ],
