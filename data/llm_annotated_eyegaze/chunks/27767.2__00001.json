  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And my other cousin was Helen [NON-ENGLISH], after her mother.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So they came over.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And they had also a son.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Itzu ?] was his name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And he was younger than me, two years younger-- actually not, I think-- because she was two years younger.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "He was four years younger than me.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And we had another cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And they had father and mother.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Her father was [NON-ENGLISH], my uncle Eugene.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And Helen was the grandma.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And until my grandfather left, we used to go to him Friday night until '36.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I was a small child at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But after that, they came to us.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And sometimes, I had another uncle, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Levy ?] was his name, [?",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Levy ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "Joseph. ?] And his wife was [PAUSES FOR 7 SECONDS] [INAUDIBLE] her name.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 5 SECONDS] It will come back to me, his wife's name.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And that was-- they came-- and she had two children.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "They had two children, two girls, which I will talk about later.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "They were-- they escaped in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "One is Lily, who lives now.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "She is married and has a child in Schenectady.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And the other one, the older one, was [?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "Blima ?] also.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "We called her [NON-ENGLISH] because she was bigger.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "[NON-ENGLISH] means big.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And she was born in '22.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "She was-- I mean, she was-- I think in 22, right.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "So she was older than my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "So we had three [?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "Blimas. ?] And actually, we had another [?",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "Blima ?] in Czechoslovakia, which was [?",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "Gunder ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "Blima, ?] because she had curly hair.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So they were all [?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Blimas, ?] four.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
