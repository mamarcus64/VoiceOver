{
  "stem": "628.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And my grandfather got into-- the women and men didn't sleep together.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He went to the other-- to a-- a-- a men's kazerne.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And-- and that kazerne, it was somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And my-- and my grandpas, he went.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And grandmother and I, we went into what's it called-- into a-- a-- a-- a private house.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "There were private houses in Theresienstadt.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And we-- they lived the first-- the few-- the first week, we lived on the attics.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "But I can remember, when I got there, on the attics-- no food-- nothing-- and fleas.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I remember the first or second night, I got so bitten from fleas, and lice.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I said, Oma I can't stand it.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Because young people, young blood.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, from-- where you-- how do you call it in English?",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Ya.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "A pump?",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a pump.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "A well.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And-- and she sat with me, a stone on there, and I fell asleep until 7:00, 8 o'clock.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Because there the fleas weren't, and so on.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "What I saw-- I looked around already.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I start already organizing.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "My grandparents didn't get-- my grandmother-- they didn't get good food.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Old people in Theresienstadt didn't good food, and very young people, also not.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Old people died already in Theresienstadt, because they were not properly nourished.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "But I was running about again.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I came into-- [BACKROUND NOISE] one day, it was about two or three weeks after, they called me from the youth organization, that I had to go into the Kinderheim.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And that's how I knew.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "So I went in into the Kinderheim, like they say-- Kinderheim-- and school, and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "There was a secret school-- Fredy Hirsch.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "This we had.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "But, you know, I went there, and they were all Czech boys.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And I couldn't stand.",
      "word_count": 4
    }
  ],
