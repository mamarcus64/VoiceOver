{
  "stem": "3933.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "And I could see a crib.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "I could see hanging old pieces for curtains.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "I used to ride it and say to myself, God, look at this places.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "There were people, my people, Jewish people, children, going down with their life.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "Look who they are.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "And the Auschwitz burnt out.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "Oy, God.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, then, finally, they ended.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The Russians marched in.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And would you believe something when I tell you?",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Unbelievable, but It's true.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Would you believe the Russians arrested me?",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Sit down, lady.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "What are you being Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And what did you do with the Germans in a German unit and things?",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Oy.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I said, I am Jewish, and my child is Jewish, and I have a false paper, and I was hiding.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Anyway, they let me go.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I am not crazy-- I wasn't crazy about the regime anyway, the communist regime, which is one big terrorist also.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It's another story.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Because like I told you, they marched in in '39 till '41.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Now, I survived.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I went to the-- to the-- to-- I went to the train.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I wanted to go to Rovno back.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Ask me what the hell for, I'll never know.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "My life would change-- none of these is survived.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Nobody survived.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Anyway, Rovno is, again, not my-- oy.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know nothing, but my husband-- but somebody, when we were in  ghetto, somebody came and said, oh, Chiam Stolar, they caught him in the army, and he was killed.",
      "word_count": 31
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And we were so sure he was killed, my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "I went to a city.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "After they marched in, I went to another city, Lublin, which is near-- farther to Rovno.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And over there I registered and sleeped there with the refugees again and again.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "I went to Rovno.",
      "word_count": 4
    }
  ],
