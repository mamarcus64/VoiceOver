{
  "stem": "24466.7",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He was most probably he was-- he was the head of that commando that took out everyone, they were putting on a fence around that place, and they were burning the whole corpse, and everything was-- so I listened to him, what he told me, and that was the end of it.",
      "word_count": 52
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But the graves from the [INAUDIBLE], from the Russian prisoners of war, were still existing.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "That was 1943.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Actually, he was taken away in 1941.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "In-- sorry-- 194-- sorry, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "In the first of May, '43.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "The first of May, '43.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "There was another-- [PAUSES FOR 3 SECONDS] Bojmin.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "B-O-J-M-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Was another-- Hendel.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "H-E-N-D-E-L.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] Actually, [PAUSES FOR 4 SECONDS] they arrest 20 Jews that time, the first of May, '43, 1943.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] Amongst them was Dr.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Szendorowicz.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Szendorowicz-- S-Z-E-N-D-O-- [PAUSES FOR 7 SECONDS] R-O-W-I-C-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Szendorowicz.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Szendorowicz.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And was another one, Kormin.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "K-O-R-M-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He was the son of a-- [PAUSES FOR 6 SECONDS] he was the owner of a tannery.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Schmel-- his father was [?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Shmuel ?] Kormin-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Shmuel ?] Kormin.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They all perished, no.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "That son didn't perish.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "He escaped when they took him from-- on the second May, to [INAUDIBLE], on a truck from the-- [PAUSES FOR 4 SECONDS] [INAUDIBLE] From the--",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Not ghetto.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It's not a ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They were arrested and they put them in jail.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "From jail.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] From the jail, he escape, he-- from the truck.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And I was talking to him in Lublin.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He told me the whole story.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "That is 100% what I-- what I-- what I am telling you.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "But he escape.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "He escape.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Szendorowicz was sent to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "Dr.",
      "word_count": 1
    }
  ],
