  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "I'm going to lose her by a bullet now.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "And [PAUSES FOR 3 SECONDS] I saw people falling, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "But she had put me-- this was, of course, before I had that food, and before I passed out.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "And she had put up against the wall in the sun, and she said, now you stay here.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "[DRINKS] I'm going to get the-- some food.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "But you stay here, and don't move.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "And was she shot?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I think that we're supposed to stop now.",
      "word_count": 8
    }
  ],
