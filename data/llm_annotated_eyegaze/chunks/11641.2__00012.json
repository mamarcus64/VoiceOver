  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Goeth must have, or somebody else must have told him we have too many workers here-- complained, for the production that you're issuing, you have to liquidate.",
      "word_count": 27
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "So that's what happened.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No, once they went to Mauthausen, they were gone.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "They were gone there.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "Most of them, a lot of them persevered.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "But you know, we stayed there.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And-- and eventually, something happened.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you later.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "We'll pause here for a tape change.",
      "word_count": 7
