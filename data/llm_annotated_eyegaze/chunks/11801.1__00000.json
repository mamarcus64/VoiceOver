{
  "stem": "11801.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK, my name is Hilde Scheraga-- my married name.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Frankfurt, Germany-- Frankfurt am Main-- on January the 29th, 1930.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I, I came from a fairly traditional family-- a traditional Jewish family.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We-- my father worked.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My mother did not.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "My, my grandmother, my maternal grandmother, lived with us.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "My paternal grandmother was often in our house, although she did not-- she lived in a suburb of Frankfurt where, actually, my father and all the siblings were born on my father's side.",
      "word_count": 33
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "It was called Budesheim-- B-U-D-E-S-H-E-I-M.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "We were fairly orthodox-- we observed Shabbat.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "We walked to synagogue.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "We did not ride.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "We were not allowed to do any kind of work on, on, on the Friday night or Saturday, even though my father occasionally had to work, and that was OK.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My father had a-- was in, in textiles.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He traveled and sold textiles, fabrics, or sometimes clothing, items of clothing, specialized in blouses.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But he did a bit of both.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father, my mother, my brother, and myself.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My brother was one and a half year older than I.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He was born in 1928.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't, actually.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We lived in an apartment in a, in a mixed neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "There were a number of Jews around.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We, we had a synagogue within walking distance, a fairly large one, and a Jewish school, also, within walking distance of my house.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, not really, no.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We went to visit relatives in neighboring areas, but I don't ever recall going on a trip.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My earliest recollections are-- well, first of all, although I didn't know it, I went to a Jewish school because after 1935, Jewish children could not go to public schools.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The public schools were barred to all Jews.",
      "word_count": 8
    }
  ],
