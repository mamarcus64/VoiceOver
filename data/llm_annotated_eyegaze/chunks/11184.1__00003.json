      "text": "Volleyball.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We played also with rocks, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Like, what they are called?",
      "word_count": 5
    },
