{
  "stem": "1491.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And everybody had a nail hanging over their bed to know-- to have room where to put their clothes because in the morning, they shouldn't look for it.",
      "word_count": 28
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "The conditions were terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And the toilets were outside.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "I don't know how we managed that.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS].",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Food-- I think they gave us rations.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, oh yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Sure, I remember being hungry and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But still again, I was stupid child things that's going to--",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So we were in ghetto, ghetto B, actually.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And ghetto A was for people who were able to work.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Ghetto B was for families with children.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Which later on, this was designed to go to Auschwitz to the ovens.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But when they were liquidating ghetto, my father was already in Plaszow.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "How, what?",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Don't ask me, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "But he was in Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "And I remember my mother was packing again those big--",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] --big straw baskets to take to-- that's because they said we're going to take you to a nice place.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They didn't say they going to take us to the ovens.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And we were in ghetto B where people didn't work there.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "There were old people and children.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So my father came, smuggle himself into ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "He came running, and he pulled us out from ghetto B in the last minute.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "He was in Plaszow?",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "He was already in Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Smuggled.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "People smuggled ways.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "They-- you know, people tried to smuggle through, finagle.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "You'd be surprised how people used to.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They smuggle in children in suitcases going to, to Plaszow.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Because children weren't allowed to go, so they put them in knapsacks and suitcases.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "You became shrewd.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "You had to fight for your life.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So my father smuggled himself through.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Of course, he risked his life.",
      "word_count": 6
    }
  ],
