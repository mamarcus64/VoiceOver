  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "You see your house, your brother's house, with the children, with your family, and to see the people, which they belong there, and they're laughing of you.",
      "word_count": 27
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The Polish people.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "They was wondering, where were you?",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "We was looking for you.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "I know you was looking-- to kill.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "One fellow told me, a Polish fellow, Louie, watch yourself, [? for ?] they're all your friends, because they want to kill you even now.",
      "word_count": 25
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And it's not Germans they're going to kill you.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "They killed a lot of Jews after the war, when the Russians-- when the Germans was not there anymore.",
      "word_count": 19
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "All right, good.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Go ahead.",
      "word_count": 2
    }
  ],
