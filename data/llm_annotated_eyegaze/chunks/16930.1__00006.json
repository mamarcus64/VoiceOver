{
  "stem": "16930.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The situation was-- with my family was my-- my grandparents moved to-- from Galicia, which was at one time a province-- a province of Austria, and then came back to Poland.",
      "word_count": 31
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They moved from there to-- to the United States, to New York.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But my-- my mother was one year old at the time.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Her younger siblings were all born in the United States, and therefore were United States citizens.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And therefore, they had the right to move to America immediately, whereas my mother and my father, they had to take a visa and wait 'til the-- the-- the number would come up.",
      "word_count": 33
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Parents returned from-- from America back to Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Then they returned-- the grandparents returned to-- from America to Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I think at that time my grandfather needed some kind of operation.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And strangely enough, the-- the-- Vienna had a higher level of medicine than in the United States at that time, back around I guess the First World War period, before the First World War period.",
      "word_count": 35
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "The-- on my mother's side, those who were American citizens, they left.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "My mother had a brother and two sisters, and they and their families left for the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And my grandmother left for the United States with them.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I guess she had an American citizenship.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "She lived in America for a number of years.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But my mother-- but my father's side remained in Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "But you couldn't-- unless you were a citizen, you couldn't go to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They had a quota system and there were visas issued, but only a quota for so many each month.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So my parents were waiting 'til their quota number came up so they could use a visa to the United States.",
      "word_count": 21
    }
  ],
