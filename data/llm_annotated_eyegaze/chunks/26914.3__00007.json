{
  "stem": "26914.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "But everybody was in the states where it is B, not A.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Moscow, Leningrad-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "To this, you cannot get a ride.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "When I arrived at Birsk, I came to Ufa.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "From Ufa, we are waiting to go to Birsk.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And the only way to go to Birsk is by boat, not taxis, not trains.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "From Ufa to Birsk.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "We were sitting there and waiting for a, uh, for a ship, for a boat.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And, uh, I was pregnant.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And I was sick with, uh-- I had a cold.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And all of a sudden, I see a woman came toward my bench where I was sitting with a big suitcase-- written, Leningrad, Moscow, Paris.",
      "word_count": 25
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And she sat next to me, and she asked me, where are you going?",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I said, I am going to Birsk.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Birsk?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I am going to Birsk too.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "My mother lives in Birsk.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Why do you speak so-- not loud?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And I said, I am sick-- bronchitis.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And she took me to a place where she cleaned me.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I-- I was dirty.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "She cleaned me.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "She gave me something to-- another-- another dress.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And she disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And I am sitting on the bench.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "All of a sudden, she comes back.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "She said, oh, we are going with the first class to Birsk.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I said to my husband, what is it?",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "A dream?",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "We came in the first class-- white tablecloths, silverware.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And she opened the suitcase, said, Stella, take what you want.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I said, I don't want anything.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "I don't need anything.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "In the radio, they said, now, we'll play Borisovna Rivchun on D flat.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "He said, oh, oh, this is mine brother.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "I said, that's a dream.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "What is it?",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "She opened the suitcase.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "There is a fiddle, a Stradivarius.",
      "word_count": 6
    }
  ],
