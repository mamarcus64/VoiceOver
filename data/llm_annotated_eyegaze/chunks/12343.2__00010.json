{
  "stem": "12343.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "I never count in my life.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I cannot count-- even- I cannot count barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I was not sure of my life tomorrow.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "What-- what interested me the barracks if I can't do nothing?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "If I [INAUDIBLE], I [? figure, ?] you know, [INAUDIBLE] the people.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I can't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "You can do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "You cannot go out of this.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Gestapo.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Around [INAUDIBLE] with rifles, all around.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Like-- was like here in a jail-- worse.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "All around.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "They took you out from there for-- for labor.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "For what kind labor?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The work in the-- they don't need the labor.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Just to beat you up, all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Sometimes we [? can ?] appel to go outside, and they said, run!",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Run!",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I did sometime [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Not in this line, not in Majdanek.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "In other-- other camps had it different.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "When you left Majdanek, how did you get to Skarzysko?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They pick.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how I get in train.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Oh, they-- they-- going from Majdanek to Skarzysko, they give you bread.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They treat you right on the way.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] where you going because they need you for work over there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Oh, this was work?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Hell-- hell, better than this work, what I got.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "First of all-- first time they took me to Skarzysko, the work not so bad.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I used to work in a factory for ammunition.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "They took us.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, [INAUDIBLE] ammunition, put on-- I don't know you call this-- [INAUDIBLE] ammunition [INAUDIBLE] to make like a-- oh boy.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Take-- I don't know how to explain this, how you call this.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "All kind of work, and I did it right.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I can do it-- [INAUDIBLE] I did right.",
      "word_count": 8
    }
  ],
