{
  "stem": "18932.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "And you had physically recovered?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Everybody wasn't skinny like anything because we had food.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We could eat as much as we could.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Though I think Sweden still was-- didn't have everything as abundant that they-- later on.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "In the beginning was a little bit, but we still had food.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Henry has been in Bergen-Belsen, too.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He was freed also on the same-- on my birthday he was freed.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "But he was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "He went to a hospital, I understand, was very lucky to be alive, yes.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We went-- yeah, on the Yeah, we went on the Me and my mom and my girlfriend that's here in this, we went to-- on the And they were great.",
      "word_count": 30
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They went out, and they ate, and they took all the movies.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And I was sick like a dog after, you know, that I really could eat everything I could.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't because I was seasick.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "But as a matter of fact, that steward that came in says to me, oh, you're just making it up, he says.",
      "word_count": 22
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "So I said, if you only knew how I feel, you wouldn't say it.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And the next day, he comes with a long nose and he tells me, oh, you must have cursed me.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Because the first time-- he's a seaman for 15 years, and he was seasick.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, a little bit.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We came in January.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "We came January 16, 1949, and we came to the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "We land in New York, and my cousin-- my cousin Rene's husband, Dave, picked us up.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And we-- we went to the Bronx where my uncle lived, and we stayed with them for about six month.",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Who is 102 years now, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Isaac, Isaac, Isaac Berman, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They were very nice to us.",
      "word_count": 6
    }
  ],
