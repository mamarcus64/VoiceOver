{
  "stem": "597.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And we went through the same thing-- went to school with-- the same schools, went to Hebrew school, and went to the school-- the public school-- finished public school.",
      "word_count": 29
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And we growed up together.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And we loved each other.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Our mother was-- my-- our mother was very devoted to us.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "She teached us all the good things-- how to be a housewife, how to be-- cook-- and to cook, to sew.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "She's-- my mother used to said-- say to me-- you have-- you have to know everything.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "You have to know everything, but with-- well, God's help, we wouldn't have to do it.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "You're not going to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "But you have to know everything from scratch.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "You have to know how to sew.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "You have to know how to cook.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "You have to know how to clean.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And she teach how this way.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "And she brought us up this-- this way.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And this-- this is the way we are.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "We-- I owe myself.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "I make myself all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "In fact, I got married, and I took care-- took care of my-- my house.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "At least--",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I'm not to--",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "--disconnected.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I continued later on after-- after-- for Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Later on, I went to my-- I was off a couple-- one year I think I was off till the-- the Russian Army came-- the Red Army came into-- they separated Poland in two parts.",
      "word_count": 35
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And then, I went again to school.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Before the schooling, my mother send me to a special school to-- to learn how to sew-- how to sew, how to knit, everything.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "She says, you have to know everything.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "It's very-- very important for a woman to know everything.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "You don't have to do it everything, but you-- it's important to know.",
      "word_count": 13
    }
  ],
