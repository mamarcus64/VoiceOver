{
  "stem": "2906.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They find out that we were-- we were taking babies to sleep, they chase us out.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, one time we stayed and the soldiers came in there, and they took my brother, and they took young men.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I saw that my brother's going.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I said that I want to go with him.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So they took me too.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And they took some more, not too many girls, but you had a brother or fiance went with them.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And we were going.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They took us in a-- never tell us where we were going.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And we walked, walked, then we came to a desert.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "In the desert, there's nothing, you know, it's desert.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And they gave us shovels and said at night, and it was very windy there.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "He said, you have to dig holes.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "You stay in the holes for the wind.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "The wind will protect you.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "The holes will protect you.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "Food, they brought us the other day in the morning, something to eat, but it wasn't much.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a lot of-- there was a lot, maybe 50, 60, and everybody digged a-- a hole to stay there.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, they left.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They left.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They thought we-- where were we able to go.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "We don't have anything to go.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And there was no water.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We had to dig for-- for water.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And the-- so when-- when we got a full, I don't know how much water I get, there came out a little bit like this water.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It was very bad there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And we stayed there maybe for two days and all of a sudden, it start raining.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And it start raining.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Where will you go?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And we-- we didn't have what to protect ourselves.",
      "word_count": 9
    }
  ],
