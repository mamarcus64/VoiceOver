{
  "stem": "543.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "It was a small-- a very small-- they had no place for all those people who came from Auschwitz, from Gliwice, from Birkenau.",
      "word_count": 23
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "They had no place to sleep for those people.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "They took 'em, but they have nothing to do for them.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "They didn't know what to do with them.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "So when we came in-- in-- in Ravensbruck, Lillian weigh only 64 pounds.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And she was just a skeleton.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Her head, you know, and her-- and her bones, it was just a-- a breathing skeleton.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "So she couldn't walk anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "We had-- I had to-- to-- to carry  her.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "But I told you I was always stronger than her.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "And they picked me all the time to-- to-- to go somewhere.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "I had to work.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "So when I came back-- Because you looked healthy--",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I came-- I came--",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "--healthier.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Back and I now I had to only pray that she was still there.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Now one time, she-- they-- they-- I came back.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And she wasn't there.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "So they picked her up, the SS.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And she was like in a Muselmann, you know, so, so skinny.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And they took her to-- to the [NON-ENGLISH] to-- to-- to be gassed.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "So Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Slavkov was there.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "Lillian-- her mind was still good.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "And she was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "She wants to go to me.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "She wants to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "She wants to go.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "So Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Slavkov was looking for me.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "She came to the-- to the-- I was-- I was laying out.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "So I said get.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "You know what, maybe I have-- Elizabeth, she go, I have Lillian here.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Said she cries.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "She cries.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "She cries.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "She-- she doesn't make it.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "But you take her.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "I rather have she-- she dies with you.",
      "word_count": 8
    }
  ],
