  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 55,
      "text": "He went up to them, grabbed them both, and started to scream, police, police, police.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 56,
      "text": "Police came.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 57,
      "text": "He said, these two brothers killed the Jews, helped the Germans to kill the Jews in Grodek.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 58,
      "text": "They're from Grodek.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 59,
      "text": "With documents, he showed them.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 60,
      "text": "That's true.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 61,
      "text": "He had them.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 62,
      "text": "And he said, these two brothers killed, murdered themselves a Jew-- that means my uncle.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 63,
      "text": "And they helped the Nazis to kill, to round up all the Jews in Grodek [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 64,
      "text": "Went to court with them.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 65,
      "text": "What money he had, he spent on it.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 66,
      "text": "Said, I don't want to be left with a penny.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 67,
      "text": "Spent all of them.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 68,
      "text": "He said, I have to bring them to court.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 69,
      "text": "Brought them to the court in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 70,
      "text": "And they sent-- I don't know where they are.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 71,
      "text": "And they sentenced them in Germany for that.",
      "word_count": 8
    }
  ],
