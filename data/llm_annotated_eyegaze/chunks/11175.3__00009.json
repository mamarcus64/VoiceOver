{
  "stem": "11175.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "What did you have with you?",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We have a shirt, you know, some-- some-- something to change it with.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Where we going?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] You will see.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "You will-- you're gonna go.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You're going to work somewhere else.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But this was our place.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And they put us together, and they took us into the-- to the-- to bahnhof, to the-- the station and, they start to put us into the-- to the trains.",
      "word_count": 30
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Oh, [?",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I said, ?] everybody start, oh.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Who knows where they're sending us?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I think this is how it end already.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "This is-- this is-- it was [? warm, ?] hot outside, Warsaw, September, and we were there about-- a few hours.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And they put-- little-- not just our group.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "They brought groups from [?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Vilanov ?] and-- and some other places.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And there was-- they put together I would say it was 1,200, 1,500 people.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "How many people in each cattle car?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In the car, as many-- as many as they could.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "There was no counting how many.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "As many they could push in, they pushed it in.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My estimation is about 60 people. 55, 60 people.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "It was crowded.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You can't-- you have to-- very crowded.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And without the toilet.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "There was no toilet.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "No water.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We were standing.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I-- somebody, you know, pushed himself.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He sat down in a corner, and he was sitting.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He was afraid they gonna step on him.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "They put us in the-- in the trains, and you were waiting a few hours, and the train start to move.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "We said, where are we going?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We don't know where we going.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "One said, we're going to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "One said we're going to some other place.",
      "word_count": 8
    }
  ],
