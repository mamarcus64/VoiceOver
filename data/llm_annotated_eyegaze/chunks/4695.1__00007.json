  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "This is hard.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "[SOBBING] I was very hard in my life.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Then, then when I start working as a [NON-ENGLISH], my trade, I make a good living.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No, I work also mostly the-- only from the-- from the-- was Jewish owners.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Only was-- the workers was German and Polish, and part Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But-- but mostly the owners was-- was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I think my father died at 1933, I think, if I am sure.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "He died because he comes back from the war sick.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He will eat only when he was 100% sure that everything is kosher.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "When he was not sure, than he was eat bread and water.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "He went-- for that, his brother couldn't, you see, recognize him.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And for that he comes back so sick nothing can help him.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "He was only-- he comes-- he passed-- He comes back 1921 or '21 or '22, and he passed away 1933.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "So, very young.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "He was 58 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And-- Now it's-- that-- then I was working-- I went to the-- make a living, OK-- to support my mother and the two children who were younger for me.",
      "word_count": 29
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "One sister was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "The other was Cela.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "My older sister, Nadja, she has married to Weizman.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "My brother was married.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "Also then Yehuda was married, and my sister, Fela, was married.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "So till I went to the service-- meantime before I went to the service, OK-- I was come in connect with-- I was going out with a girlfriend.",
      "word_count": 28
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "But in fact she is here.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Lanya. ?] And she was 17 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Milsztjan.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "She was 17 years old, and I 18 years old, and we started to chat, and we start going out steady this time.",
      "word_count": 23
    }
  ],
