  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "The parents were begging him if he could take some packages to them, because the boys were starving.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "So he said yes.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Evidently, he got permission from the Judenrat to take packages.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "He was such a gallant man.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "Such a brave person.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "He wasn't afraid of anything.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "Anyway, he went away right after Yom Kippor.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "He must have been delayed to deliver those packages, because first day of Sukkot, early in the morning, we were sleeping by my grandmother in the house.",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "My grandmother would stand watch like a watchman.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "She wouldn't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "What happened was she would took out a small pane from one of the windows, and she would listen what was going on on the street.",
      "word_count": 26
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "If you--",
      "word_count": 2
    }
  ],
