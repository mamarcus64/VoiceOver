{
  "stem": "3659.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I instilled that into my children, and they live by that too.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So now we are in the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And there were some of our relatives had already arrived here, and we went to their house.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There was about 10 or 12 living there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "It was like Gorky's Everybody was on the floor with the mattresses.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "But we were breathing.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "How big a group were you now?",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "There was--",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We had-- we brought my aunt, my grandmother that was blind, that we also had to pay additional funds so that she would-- she will never be part, you know, will never take from the government, and there was another uncle, three cousins.",
      "word_count": 43
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I say we were about 12 or 14 people in a two-bedroom apartment-- excuse me-- stepping over each other, but being as happy as you can imagine.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Nobody had any money, but somehow we all pooled our few shekels that we had, and bread, at that time, was 10 cents a loaf.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And so became very entrepreneurial.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I remember my mother had some jewelry that she smuggled out somehow, and we hocked it.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We went to the pawn shop.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And so at least we had a couple of dollars.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So then I started to knit.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "That's where my handiwork came in.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I knitted little sweaters that they paid me like $1.40 for a back of a big sweater.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And we started to be very entrepreneurial.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "My sister went as a nursemaid.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in a little apartment in New York.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "My mother was able to find a little apartment, and so we lived there.",
      "word_count": 14
    }
  ],
