{
  "stem": "13395.8",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "We established a Holocaust Education and Memorial Center.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "The opening was September 15, 1985.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "Right after our first gathering of Holocaust survivors in Canada, which took place in April of 1985, in Ottawa, which I was a member of the steering committee and Chair of the Cultural Evening.",
      "word_count": 34
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "The Holocaust Center has been now in existence for 10 years.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "We had hundreds of thousands of students coming through that center, adults, church groups, synagogue groups, Jewish organizations.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "It is a place where you can, in the Hall of Memories, read on ceramic tiles names of families, victims, of the Holocaust, where our children can come and find the names of their grandparents they never knew.",
      "word_count": 38
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "They can say a prayer.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "That's the place, the only place, they can visit and see their names, their family names.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "These are their roots.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "They have nothing else.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "I am glad that we have established a Holocaust Center.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "It was my life's work.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "I was involved in the Holocaust Memorial in the Earl Bales Park, in planning it.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "And I am very proud of that accomplishment as well.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 36,
      "text": "It is my life's work.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 37,
      "text": "Having been elected of Canadian Jewish Congress, Ontario Region, after many presidencies that I held in many organizations, I had the opportunity not only to continue to speak about the Holocaust, and making a living memorial for of our victims.",
      "word_count": 40
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 38,
      "text": "I also had the opportunity to fight the neo-Nazis and the deniers in the position that I was holding as Chair of Canadian Jewish Congress, Ontario Region.",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 39,
      "text": "I also was appointed by the Premier of Ontario, to the cabinet roundtable on anti-racism.",
      "word_count": 15
    }
  ],
