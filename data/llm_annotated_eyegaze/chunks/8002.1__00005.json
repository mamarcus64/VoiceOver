{
  "stem": "8002.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "And they moved-- moved them.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "I didn't even know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't want-- I was afraid to go back home.",
      "word_count": 11
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "So the first thing I thought about it, I'm going to run away.",
      "word_count": 13
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "But I didn't know where to run.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "So not too far from us was the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "That was happened when the German moved in.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "They moved in in June.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Beginning of June they moved in in 1941.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "So I didn't know where to hide.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "So I figured the safest place would be in cemetery.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "So I went in the cemetery.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "And I slept over there.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 6,
      "text": "But at night, the wind was blowing.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 7,
      "text": "And the trees moved.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 8,
      "text": "And it start to make a noise like woo, woo.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 9,
      "text": "And when I saw it, I thought that people were dancing in front of me.",
      "word_count": 15
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 10,
      "text": "And I got scared and tried to sleep, but I couldn't sleep.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 11,
      "text": "And then for a couple of days, I didn't eat nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 12,
      "text": "And I was starving.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 13,
      "text": "I didn't have nothing to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "So I started to dig the grave.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And as I dug with my hand, I find a bone.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "And I was so hungry, I started chew on the bone.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And then I realized it was from the dead people.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "But at that time I didn't even think about, because they say hunger breaks iron.",
      "word_count": 15
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And I chewed on the bone.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "And that was in [PAUSES FOR 3 SECONDS] [INAUDIBLE] middle of June.",
      "word_count": 12
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] I tried to go in the farm to find if I can find a raw potato or a carrot.",
      "word_count": 23
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 4,
      "text": "And somebody saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 5,
      "text": "And they must have told the Latvian police.",
      "word_count": 8
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 6,
      "text": "So I ran back to the cemetery.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 7,
      "text": "And I was there about six months.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yes, by myself.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
