  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I was-- the day they entered Amsterdam, I was standing at the corner of the road where we lived with the doctor that birthed my two children and saw them march in.",
      "word_count": 37
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "You can imagine how I felt.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "You can imagine how we all felt.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "This doctor was a young Jewish doctor who went underground.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "They changed his name and sent him in another hospital a long way away.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "So he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "I saw him after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I went back to where we lived, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "The children were there.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We lived.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And then my husband, being one of the diamond workers in Amsterdam, they were essential to the Germans because they needed the Germans to buy munitions.",
      "word_count": 26
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "So we had a special-- what did they call it?",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "A spare?",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "That if we were picked up, if I was picked up with the children, or my husband, they wouldn't take us.",
      "word_count": 21
    }
  ],
