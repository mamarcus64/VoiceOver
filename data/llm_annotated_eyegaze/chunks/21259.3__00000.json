{
  "stem": "21259.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, no.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I've got a lot of friends where they was in concentration camp.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't there in, in Zawichost.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But the teacher, Sabatowski, they told me.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "They took-- they took out from the Zawichost all Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And they came then in [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "This is [INAUDIBLE], you know?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And after, a lot what they-- was a concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And they find out to the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "From, from my city, the most of my city, you know, they killed them.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "They never was in concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "A lot, they run away before.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "They took the concentration.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "Now, a lot, what they lived there.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And they not run away, none.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "They took them.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And they killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "They shot them out there.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "This I know of sure.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And, and after, you know, I would go see there, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE], a lot they told me.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "It was so many years, there was, you know, in 1946, there was September '39.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "A lot they went there and they saw the, the, the graves, the all graves there.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So I, I, I couldn't go there.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Well, I was a-- the teacher told me, go away, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I never went there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "It's not far from Zawichost, 8, 8 kilometers.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I will see the graves there where they do-- in this-- in this-- when they come in the city for-- and [INAUDIBLE] You know, [INAUDIBLE], where the buried the old Jewish people, you know?",
      "word_count": 34
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "There is a road, Ozarow, Ozarow [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "They took from all the stones.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They took the stones away, and they make a road, a road to, to Ozarow, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "This was the [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "They took all the-- all the-- all the graves and stones.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "This I won't see.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "But they told me this.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "This, I never was there.",
      "word_count": 5
    }
  ],
