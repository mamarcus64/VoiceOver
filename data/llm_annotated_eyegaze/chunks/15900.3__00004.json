{
  "stem": "15900.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "I went back and I told them, I'm sorry.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "With my brother's work.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "In [INAUDIBLE] supplying food to the army and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "My brother was afraid for anything.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He worked in a meat-- he was a-- he was a butcher at home.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "He worked by cutting meat.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And there in Russia, you cannot live.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "You have to steal anything.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "But when you steal something, they arrest you and they put you in jail.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And I got contact with the police right away.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "I got contact with the police and with the judges and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And I said, you want to make money, to the police.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I-- look, two people together.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He can do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And later on I-- I had a girlfriend there, I was going out and I-- and the judge, we were going out dancing and everything.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I used to take out whole cows.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I took it out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "The guy who stayed in the factory, he-- he was paid, too-- everything.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Later on, I was working in the meat in the black market.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] people came to the house and bought the meat and everything from black market.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And I took the money and I split it with the judge, with the--",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "--police with the guy who was the guard and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We were [? getting ?] 100 rubles for a pound of meat.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'm gonna quit this.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I used to be delivering the-- the-- the food to the army and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I'm gonna go to a tea factory.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "A tea-- [INAUDIBLE] the [INAUDIBLE] the tea-- they-- they-- they take tea, the Arabs and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And the tea was 1,000 rubles a packet.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I said, I'm gonna go there, take a job in the tea factory.",
      "word_count": 13
    }
  ],
