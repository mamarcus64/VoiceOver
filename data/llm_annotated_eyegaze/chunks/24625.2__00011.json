{
  "stem": "24625.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "He got remarried in the meantime, and she had children there, so she couldn't go.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And he didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And then my sister came, and then the-- this aunt in New York didn't want my brother anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "So she moved to California, and took her brother-- the brother with her and lived in Los Angeles.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And then she made the papers for us, and then we came to Los Angeles in 1956.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And at that time, we had already a little girl too.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "We had a child that was born in '54.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "And we came to America, and then that's another story.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In '56.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My daughter was born in '54, and then we came in January of 1956.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We came to Los Angeles.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And we're here ever since.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, to begin with, I worked for Desmond's when I came to Los Angeles.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I was an alteration man.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I know-- I know about tailoring, so I was working in the shop there.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And then I was a fitter for them.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And then I got on my own, and I worked for an upholster part time.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I was sewing cushions at night.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And then the guy sold the business, so I bought it without any money.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have any money yet.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "But I found a guy that wanted to go partners with me that had the money.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "He put up the money, and I put up the knowledge.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And we were together for about seven years, and then I bought him out.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "He went on his own, and I went on my own.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "And I'm ever since, I'm in the upholstering.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "And I took-- I bought the shop.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And all the children got born, and we stayed here.",
      "word_count": 10
    }
  ],
