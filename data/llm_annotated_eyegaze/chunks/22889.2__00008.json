{
  "stem": "22889.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "Don't forget, our town was 11,000 population, there were 3,000 Jews-- 30%-- and were a lot of Hasidim.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "Was the majority of our town were Hasidim really.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't too bad, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "There was always anti-semitism.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They used to call you names and oh, and that.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "You know, they used to break the windows.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "They used to beat you up.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Was worse.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Was worse because the German did it, the same thing and worse.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And they would use a lot of the Pollacks.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "If they were looking for somebody, they would use a lot of the Pollack.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "They give them extra ration so forth on.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't pleasant.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "My father was in First World War.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He was soldier First World War.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "He wasn't drafted when the Second World War broke out.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They-- they-- they draft some Polish people before the war, see the sign was there.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They mobilized, but they mobilized about two, three days before the German occupy our town.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So my father didn't go to the army because he had a family at home.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Austro-Hungary.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "It didn't make any different at all.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "My father as a matter of fact had a-- he was in the cavalry in the horses, and he used to-- I remember we had a picture of him.",
      "word_count": 29
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He used to have a big saber, and he had a scar here on his face.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He was-- when he fought in the First World War he was hit with a saber on his cheek.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 3 SECONDS] we always had pictures hanging on the wall.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "But didn't mean anything to them.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He had decoration from the war, from bravery.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Didn't mean a thing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "He walk, [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He walk.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Just took away with nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Whatever-- food, stuff like that.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Nothing else.",
      "word_count": 2
    }
  ],
