  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "You know, the Jewish people got the real one.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I can't tell you because I don't remember him.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I remember when the war time.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, he walked through the train.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He not say nothing, no, no.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He talk a little, and after this, he's go, take the car.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He go home.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I know of his wife too.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "His wife is still alive.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "She's in Argentina.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I remember her.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the train was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And he after that, after the train.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We get off on the train.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We go to make a ready for the beds.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Then we go  and eat.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In Plaszow, we never got food.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Over here, we got food.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "What kind of soup [INAUDIBLE]?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Why would they cook over there?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "That's a long time, 50 years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, eat.",
