{
  "stem": "1249.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "We had a little tag, KUKA Factory.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "That's what it said in Augsburg.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "We were there seven months, as I understood.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And we-- our shoes was not the best shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And sometimes, it was snowing.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And that's when I think I got my sickness, when I became sick.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "And I was sick or not, I had to go to work.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "We had a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "The doctor was a medical student, really.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "That what-- they made out of her a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "And we were-- we were working in-- over there.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 17,
      "text": "And one day-- one, one night, first of all when we get there-- maybe a couple nights after.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 18,
      "text": "We were still on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 19,
      "text": "And I get up.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 20,
      "text": "We were sleeping.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 21,
      "text": "That's my sister said.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 22,
      "text": "We were sleeping.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 23,
      "text": "But I thought I was up.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 24,
      "text": "And I heard a voice.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 25,
      "text": "Sarele-- that's my name, my Jewish name-- Sarele, come with me.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 26,
      "text": "Come with me.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 27,
      "text": "Sara, come with me, come.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 28,
      "text": "I said, grandma, grandfather, [NON-ENGLISH SPEECH].",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 29,
      "text": "[PAUSES FOR 3 SECONDS] I'm coming.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 30,
      "text": "I'm coming.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 31,
      "text": "I get up.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 32,
      "text": "And I started to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And my sister said, where are you going?",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He was-- she was sleeping.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'm going with grandfather.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "He's here.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "He's asking me to go.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "She said, nobody's here.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "Very, very dark-- very dark, was no light, nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "And then I lay down again.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "And I could swear he was there.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "And what does it mean?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "Maybe someday I will ask a, a rabbi.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] I know--",
      "word_count": 6
    }
  ],
