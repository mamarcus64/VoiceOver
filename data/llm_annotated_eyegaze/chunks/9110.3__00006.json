{
  "stem": "9110.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "But in the States, we-- I changed it.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And my nephew, my brother's child, after a few-- he was a year and a half.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "He was so smart.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "We locked ourself up-- this is just a funny story.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And we didn't have-- we locked the door.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "We couldn't get in.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "And he was by himself.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "He was a year and a half.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "And we start talking to him-- Aaron, Aaron, take a little chair, a step stool.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "Go to the window.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "Look for the keys.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "He was so smart.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "And he-- and he will throw it out through the window.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "It took a while.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "But he did it.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "But later, he got sick.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Because he caught the-- from a cousin-- how do you call it?",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I forgot how you call it-- pneumonia, he had.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And they took him to Switzerland to cure him.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And he was there four years.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "While you were in Bergen-Belsen, and after you had gotten married, did you and your husband discuss where you wanted to go eventually?",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "First, we wanted to go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My hus-- we had a friend in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He went before us.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He-- we-- he had sent away a factory for makes those blocks, to build homes.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "He went to a town in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And A bought, for $48,000-- we had money at that time, already-- those machineries what makes the cent and everything.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And he-- he took some lessons.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And we sent it away to Germany-- to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And I sent away clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And I sent away a lot of stuff to Ger-- to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Because we wanted to go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So this guy, [?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Zilberschwartz, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Haim ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Zilberschwartz, ?] with his wife, [?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Thela, ?] she wrote us a letter.",
      "word_count": 7
    }
  ],
