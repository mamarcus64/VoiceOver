{
  "stem": "6523.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "She got three, three sisters and a brother from a second marriage, for which, after the war, I went to Canada to find it as what has happened to them.",
      "word_count": 30
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Some of them.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "One was-- the sister was Tila.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how to spell it.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Tila, Tila.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Because I saw them a short time.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It was a few days in Canada.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The brother was Jechel.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Jechel in Hebrew, I wouldn't know how to spell it.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Oh, Jechel, let's say in Polish would be J-E-C-H-E-L, or something like this.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, this-- if some of them survived the war-- I find it as mine aunt's son.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He was a officer in the Russian army.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I don't-- I never have a chance to meet him because we left Poland because I hate-- I got the feeling always, I-- [PAUSES FOR 7 SECONDS] [INAUDIBLE].",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "This is the reason, right in-- after I got back, my son-- we left.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "He hated Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Father's family-- [PAUSES FOR 5 SECONDS] I find nobody.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Before the war my father got a brother, with three nephews.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The-- all of them was killed in the-- they was injected in the Polish army, and they all of them was killed.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, I come from parents for this-- you can call this in, in Polish [POLISH] middle class. 90% Jewish was very poor.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Was 10%, 15% were the-- could afford what you call this middle class.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My father, we been in, they all of them been in business, china business.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "They most imported china from Czechoslovakia, from lot of factories in Poland, like, like Olkusz, [POLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He tried to educate the, the children.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We been-- 11 children.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It was six brothers and five sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Oh, some of them died very young.",
      "word_count": 7
    }
  ],
