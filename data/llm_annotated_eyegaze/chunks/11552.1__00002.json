{
  "stem": "11552.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I want you to show me how you wash your underwear?",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And I said, grandpa, how can you say something.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I say, I want you to do that.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Because one day you're going to be in charge of a big estate.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And I want you to know how to do everything as well as the people who will been working for you.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Now, he was a very lovely man.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And of course, Grandma was a wonderfully lady.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I loved Grandma too.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother's My mother is from the house of Kurtz.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "There were two things I remember very well about my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "When I was about seven years old-- actually, from the age of five, in our tradition for Shabbat you bring food to the needy people.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We didn't use the expression poor people, needy people.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We shared.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We didn't give.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And since I was the daughter of the house, it was my honor to bring the food to the needy people.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And I started on Wednesday after Hebrew school.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And one day my friend Rachel came to me.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "She was all excited.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "She says, Alicia, I have a secret to tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Could your maid bring the food in for this one Friday, this one-- it was on Thursday-- this one afternoon?",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Please, could you ask your mother?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "So I came to my mother all excited.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Who doesn't want to hear a secret?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And my mother sat me down and says, Alicia, darling, I would like to share something with you.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "She says, you know, God gave you the greatest of gifts.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And that's the ability to make a decision.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Now, you're going to make a decision today.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You can go and bring the food to the people or you can go and have your secret with Rachel.",
      "word_count": 20
    }
  ],
