  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "Kremenets is a very well-known town in Poland from universities, a kind of small Oxford, something like this, you know, rather a university city with colleges-- different colleges, different schools.",
      "word_count": 30
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And one of the teachers' colleges was a new building, a new established teachers' college.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And we decided to enroll.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And we were accepted.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "We were give a scholarship off 180 ruble, which was good enough to keep us going.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "The teachers' college-- we specialize in physics and mathematics.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "Many of us had some previous university experience.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "Some of them were from Manchester, from Lwow University, from Warsaw University.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "And the one from Manchester lives here in Melbourne.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And I met him by chance somewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "And I didn't know who he was.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "Then, then we talked together.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "And then we realized that we went to the same college.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "His name is [?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Salig ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Zilberstein. ?]",
      "word_count": 2
    }
  ],
