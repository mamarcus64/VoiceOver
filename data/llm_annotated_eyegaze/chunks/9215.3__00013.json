{
  "stem": "9215.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "He said, if you'll make so much and so much over the monat, we'll pay you 1,200 ruble.",
      "word_count": 18
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "You know what this mean, ruble?",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "Russian.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "I said, all right.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "After the monat, he came.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And I show him how much I made.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "He said, OK, you made good.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "And he gave me a piece of paper to go there and there, and they'll pay you.",
      "word_count": 17
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 8,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 9,
      "text": "I went and show them the paper and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 10,
      "text": "He gave me 180 ruble.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 11,
      "text": "I said, they told me you had to give me 1,200.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 12,
      "text": "Why do you give me 180-- 80 ruble?",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 13,
      "text": "He said, do you know it's a war?",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 14,
      "text": "It's a war.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 15,
      "text": "We got to give food for the soldiers, dressing, ammunition, and this and that.",
      "word_count": 14
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 16,
      "text": "I can't give 12.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 17,
      "text": "You got to pay for it.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 18,
      "text": "And he gave me 180 ruble.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 19,
      "text": "I said, what shall I do for 180 ruble?",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 20,
      "text": "Give me a place where to-- OK?",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 21,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 22,
      "text": "Should I finish?",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 23,
      "text": "Go ahead, go ahead.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Give me a place where to buy a bread.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "You can buy-- if Russia [NON-ENGLISH]-- matches-- matches, kerosene.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "I said, I don't need matches and kerosene!",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "I need bread, butter, something!",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "No, he said.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "They say to end it.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "I'll tell you later.",
      "word_count": 4
    }
  ],
