{
  "stem": "21004.10",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And now it's my children, grandchildren.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I got 7-- How many grandchildren do you have?",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "7 grandchildren.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "My oldest son has four, three boys, two lawyers, computer one-- one, and one girl.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "She is a master of psychology.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "So is my younger son, master of psychology.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Now he's doing in aviation something else.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And my grandchildren-- he got three children, one from his second wife.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "She is in college.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And two kids, Amy and David.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "One is-- he is 15 and the girl is 17.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Nice children, nice family.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Used to visit every year almost, come to California and visit and go out and-- with the children.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "I have-- I have also five great-grandchildren, my older son.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So have a nice family, that's for sure.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And the two brothers live like really two brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They love each other.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "If one needs help, is there.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] Thank God I'm healthy.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "How-- how did the Holocaust affect you?",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "For a while, you know, it affect very much.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I missed-- I miss my-- my sisters and my brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I miss them.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And my mother especially, she suffered without a father so many years.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "She never want to remarry, my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And the time when it start getting good, they moved to-- she moved to Krakow, then the war broke out.",
      "word_count": 20
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "But the war was a disaster for a lot of people.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "I saw a lot of things.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "Kids starving for food, typhus.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "I didn't even go-- they didn't let me in even the temple in Jaworow to see my cousin.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "She was 13 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "I used to teach her also Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "I was older from her.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "And I couldn't go and see her.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 15,
      "text": "They say, can't go in there.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 16,
      "text": "It's all typhus people.",
      "word_count": 4
    }
  ],
