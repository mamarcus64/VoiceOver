{
  "stem": "22836.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 10,
      "text": "And I was getting there, getting some in change for bread.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 11,
      "text": "Change for bread-- I got some clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 12,
      "text": "I give away shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 13,
      "text": "I got other things give away.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 14,
      "text": "And I get, always, bread from the people.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 15,
      "text": "And I get flour from the people-- I always, to-- to bake bread.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I got a good-- no, I got a woman, too.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "She bake-- she bake me the bread.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "She bake me-- even put in potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "There was more bread with potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And it was taste good.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "Later, she don't want to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "She was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "She said, Louis, I can't do it.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "I'm afraid they're-- they're gonna kill me if they find out.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "Then-- then we don't-- we don't bake bread, because we don't have where to bake.",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "That was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And then, we see if he stay-- if he stay by a good friend, a Ukrainitz, are there, right?",
      "word_count": 19
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "OK, he help us.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Then he say, Louis, we can't.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "The police goes right there.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "He's was in-- on the road, and the police was right away driving.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "I mean it, he came in to kill him, and he kill us, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "That's what they're saying.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 8,
      "text": "Then we say, we don't have other choice, what to do.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Then we find out we gonna do two bunkers in a wood-- in the woods.",
      "word_count": 15
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "This was between Matejko and Kolki.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "We find out a very, very tight woods with a lot of woods.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And we make two bunkers.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "Six-- six people was in one bunker, and six people was in the other bunker.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Underground, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Just, we dig it up, and cover up.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And we were staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "And-- and me and mine brother, we was-- the smaller brother was like the strongest.",
      "word_count": 15
    }
  ],
