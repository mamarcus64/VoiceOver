  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And the language was such a strange Austrian language from the time of the First World War.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Words which I never knew or heard before.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "[GERMAN SPEECH], which means rooms or--",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Toilets.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "All kinds of strange names and things which we were not used to.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Or suddenly we saw German Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Blind people who had a yellow kind of strip with three black circles, which was a sign for a blind people.",
      "word_count": 21
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't in Czechoslovakia.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And for a child of just bar mitzvah, everything was new.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And also that people around-- overcrowded, terribly overcrowded, and shouting, and screaming.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And everyone wanted to find his place.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "All of this was new.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "By the way-- sorry-- I arrived just after my bar mitzvah.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And maybe I may go for a minute back.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Bar mitzvah was something very unusual-- oh, it's red.",
      "word_count": 9
    }
  ],
