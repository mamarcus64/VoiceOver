{
  "stem": "9245.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "So we picked a-- a-- a mission to go and damage two kilometers of railway.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I served as a nurse.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And they gave each soldier-- they gave each partisan, they gave a piece of dynamite, which was like a piece of soap, a bar of soap, with a wick inside.",
      "word_count": 30
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And they took matches.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And we had a-- a guard that what lived in the area, and he knew the area very well.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So at night, he took us.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And we took out-- we went out to like about 15 kilometers to the railway.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "It was a very, very damp night.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans were working on the railways.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "They were constantly fixing it.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "So they had-- and they had barracks that they lived, not far.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "So they had bonfires, that they were warming up.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And as the guys were dispersed on the railways, and they were going to light the wicks and put the dynamite under the rails, the-- the matches wouldn't work.",
      "word_count": 29
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "They were damp.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So they ran to the coals, and they grabbed the coals.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they were lighting the wick.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "This created a little bit of a commotion.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans woke up, and they started chasing us.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And I was sitting, with a guard, in one corner.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he became very-- I-- I was told that this is my punkt, my point, where they will come, and they were-- we will reunite and run back.",
      "word_count": 28
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But he became panicky.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And he said, I'm not staying to get killed.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "He started running.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And I ran after him.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And Germans were chasing me.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And I could see them, practically.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "They were pointing the gun.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And they were shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And the bullets were flying by my side.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And I came to a-- a ditch.",
      "word_count": 7
    }
  ],
