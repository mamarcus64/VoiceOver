{
  "stem": "22889.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "And I start to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "Settled.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "I worked for about a year.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "Bought myself a car.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "And I start to travel to Pittsburgh, start to date some girls in the-- just a little bit.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "I date them all, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I'm sure.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] Every week, I have three dates, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "The girl fixed me up with some other girl.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "It was-- was that.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "You know, we had a good time.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "It was very good.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And finally, I met my wife on a blind date.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And, as soon as I met her, I thought to myself, well, she's different.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I think she's-- she's going to be my wife.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And she fall in love with me, too.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "She was young.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "She's younger than me, a good bit.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "So when I married her, she was only 19 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "Her mother had to go sign the paper for me-- for her.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "I was a little bit older.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "I was 25.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We got married March the 7th, 1954.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And I got married at Rodef Shalom Temple.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Freehof married us, a nice wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't too happy with the wedding, this-- a marriage in a-- in a [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Because I wasn't brought up as a Reform Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I was brought up as Orthodox Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And this was a little bit different for me, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The Rabbi Freehof said, I know where you come from.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I know who you are.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "If you want me to, I do anything you want me to do.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You want to be like yourself.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "You want me to wear yarmulke, I'll be happy to.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I said, yes, I want you to wear yarmulke.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I'm not used-- I-- maybe I'm not doing it for myself.",
      "word_count": 11
    }
  ],
