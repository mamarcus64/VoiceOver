  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "But some of them were collaborators, but many of them were not.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "But in any event, we were assigned-- I was assigned to a room with many other people.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "It is kind of difficult to remember how many because it was an apartment in the ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Now each apartment had a room.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And each room was-- we must have been to an apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I would say there must've been maybe as many as 15 or 20 people in one apartment.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Some of them were with families, but many of them were not with families.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Many of them were just single men who managed to, so far, survive.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Their wives and children were taken away in one form or another.",
      "word_count": 12
    }
  ],
