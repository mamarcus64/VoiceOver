{
  "stem": "11067.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I mean, she was going to put her daughter onto that train.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And of course, all the usual admonitions.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "But the last thing that she said to me was-- one of the last, I guess, things was, be a good girl.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Whoever you're going to go to, help in the household.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And just be a good girl.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Nothing really saying to me, I'll see you again soon or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "It was my behavior, that I do things that are right.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "This is the way that I was brought up.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "You do the proper thing all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And so I got onto the train all by myself with a big suitcase-- she couldn't even help me get that up-- and sat in a compartment with probably nine others.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "We were probably about five people, you know, facing one another, five and five.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And that's the way I sat and remained.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "It was a terrifying experience.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "I just don't remember a thing about it.",
      "word_count": 8
    }
  ],
