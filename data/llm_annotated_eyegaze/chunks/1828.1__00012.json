{
  "stem": "1828.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "That means a protective list-- as-- you were their relatives.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And there was a-- a man by the name of the Jakob Edelstein, who was a-- a great Zionist and who did tremendous work.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He even had the opportunity to get out of Theresienstadt.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "The Jewish agency offered him escape.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And he said, a captain does not leave his ship.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And he stayed behind.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "He had a-- an only child, Ariah, and his wife, and his mother-in-law.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And he said to us he was going to protect us as long as he's there.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And we didn't know why.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "Because we really had very little contact with him.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And he said the-- this [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "It's the respect of-- that he had for my father.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "And when we were called to go, the-- we were not on his list yet, somehow.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "We were called to go, and-- and my mother told Jakob Edelstein that we are going on the transport-- that we are called.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "We had received our slip.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 17,
      "text": "And he said, no, that has to be corrected.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 18,
      "text": "And he came to tell us.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 19,
      "text": "So my father said the children should stay behind.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 20,
      "text": "But he wants to-- he's not going to let another Jew take his place, because each day was important.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 21,
      "text": "Maybe next week it will be over and--",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
