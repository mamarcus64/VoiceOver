{
  "stem": "182.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 188.3,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "That was the-- our president was Masaryk.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He was a wonderful president.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And he saw to it-- it was compulsory that every child, rich or poor, they had to go to school, at least six elementary classes he had to take.",
      "word_count": 29
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "There was no such thing that a boy has to work on the farm and he doesn't go to school.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "They were forced to go to school.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I went to six elementary schools in my town.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And then I took a test, and I went to a gymnasium in another town about 60 kilometers from where I lived.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I took the train every morning.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And every evening I came home.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was 11.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And when the disturbances started I was only 13.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Between 13 and 14 I stopped going to this gymnasium, and I continued in our town.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I don't know what is the-- how would your call it?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "A middle school or a--",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't a high school, because the high school was where I had to take a test to go to the high school.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But this was a school that offered general education for four years, and then you graduated.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "From there you could go to a business college, or you could then take a test and go to the high school also.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Now, after I finished the four years-- I mean, competed the four years, I went to a business school.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In my town.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I only finished one year.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Then they deported us-- my family and I were deported to Galicia.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, on my life actually it was in '41.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Because until then, a child feels protected when you are with your mother and father, no matter what goes on in the world.",
      "word_count": 23
    }
  ],
