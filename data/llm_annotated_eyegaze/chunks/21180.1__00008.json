  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "But she lived over in Israel, and my brother saw her after the war.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And we as religious people, we didn't-- the family-- didn't thought-- it was not enough kosher.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "This what I understand.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I should say in '38, '38.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Hitler came in '33.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So I should say four years later, we find out this in-- we knew it, what happened.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "But we didn't believe it till around in '37, '38.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "The-- the communication also was not like now.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have the television at home.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 5 SECONDS] We didn't have the television at home.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Religious people didn't have in this time televisions.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "So we had-- the communication between outside the country was not like today.",
      "word_count": 13
    }
  ],
