{
  "stem": "22047.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 44,
      "text": "And we had been dating 'cause I had-- my wife-- former wife had been-- and I had divorced.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 45,
      "text": "And so here I am, working in Pasadena, and she's up here now in Monterey.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 46,
      "text": "And I'm commuting every weekend, living in an apartment down there.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 47,
      "text": "And that was getting kind of dumb.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 48,
      "text": "So we decided that I was going to leave JPL.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 49,
      "text": "And so I did in 1978 and went to work for Lockheed in Sunnyvale.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 50,
      "text": "That was another commute.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 51,
      "text": "And that got, [PAUSES FOR 3 SECONDS] got poor after a while.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 52,
      "text": "This, this commute was getting to me.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 53,
      "text": "I was a basket case by Friday.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So I told Lockheed I was gonna leave.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And they said, but you can't.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We're working on an important program.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It was called HOE, Homing Overlay Experiment, which was an interceptor that was supposed to knock down a reentry vehicle from a Russian ICBM up above the atmosphere.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And so I worked on that program on the propulsion system again.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And, but I said, I, I, I can't do this anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So they offered me a consulting contract, which allowed me to stay up there in a hotel.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And, and they paid for my food and transportation.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I'd come home a couple times a week versus every day.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And I worked there as a-- as a consultant for two years.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And then, then I started branching out to other pursuits in the-- in the consulting business.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I went to-- got a consulting contract from Ford Aerospace in Palo Alto.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Same situation there, where I worked on the propulsion system for satellites-- communications satellites.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "One for NOAA, National Oceanographic and Atmospheric Association, which was one of the weather satellites that we see on TV now.",
      "word_count": 21
    }
  ],
