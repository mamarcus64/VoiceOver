  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The first two years we had communications with families.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "We, for instance, knew that some of our relatives made it in '41 out to America.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't know-- we didn't know about the others.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And I had a correspondence with a good friend of mine.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "He sat for years next to me in school, in the Jewish school.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "So we were good friends.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "His mother was still in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "His father had passed away.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And he was in England, then he was taken prisoner of war.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Then he joined the army.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "They sent him to Australia, and then to Canada finally.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And he wrote me to write his mother, because I still had- I could write still to Germany-- [PAUSES FOR 4 SECONDS] before the war broke out in the Pacific.",
      "word_count": 30
    }
  ],
