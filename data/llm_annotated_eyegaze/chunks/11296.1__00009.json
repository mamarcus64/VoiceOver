{
  "stem": "11296.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And there was a policeman standing, a Jewish policeman.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And you had-- you could go in.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Oh, there was-- like my case, I wanted to go out from the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "I knew the-- the roads from the other side through the fields.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "The fields was not closed up.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And I ran through the fields.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And I went on the Polish-- on the Polish side.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "So there is where I was always in contact.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "A few times I was lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "I went out, and I came back.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "And I brought the food.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "So the--",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "There was no name.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "There was Plonsk, you know, Plonsk ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And through the ghetto, they're starting-- you know, this was 1940.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They closed up the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And they start bringing from little towns.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "There was-- we were surrounded by very little towns.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "So they had to close up completely the towns, and they brought in the people to us-- to us.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And between-- and this was-- now I'm going to go to 1941. 1941, they had made-- the Germans came in with big machines.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They said all the ghetto is going to get [NON-ENGLISH]-- how you say-- clean up, you know, disinfected.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They're going to disinfect.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They took to one shul.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "We had a big shul.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "We had a small shul.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And they converted the shul to a-- to a bath.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "They brought the machines.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And they brought, you know, the-- they took people from the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "I was working there, so-- so I-- so I know what was going on.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "Everybody by-- by the house.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "They brought in.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "They shaved them, They disinfected them, you know, because they said, oh, everybody had lice.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "This is 100% sure.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And-- and they was afraid, because typhus started, you know, the epidemics that came out.",
      "word_count": 15
    }
  ],
