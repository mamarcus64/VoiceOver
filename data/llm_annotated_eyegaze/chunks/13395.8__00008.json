{
  "stem": "13395.8",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Jewish organization, spoke to the Senate, members of the Senate, in Berlin.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Members of the German government in Bonn.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Members of the clergy in Bonn.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I spoke to students in high schools in Munich.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I spoke to people in [NON-ENGLISH], [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I will speak wherever there is anyone with ears, whether he wants to hear the story or not.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "For many years, Jewish mothers were not receptive to the idea that survivors would speak to their children in schools.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They did not want the children to go through the trauma.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It was all right for the children that were murdered to go through the trauma, to be torn away from their parents, and pushed into the gas chamber by themselves.",
      "word_count": 30
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But it was not OK for the Canadian Jewish children to hear the story.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "This is unforgivable.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I don't accept it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I always had the dream of building a Holocaust memorial in this community, to leave something behind when survivors are gone.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "We won't live forever.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And the clock is ticking.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "My opportunity came.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "I thought, ?] I have done a lot of work speaking at different functions, at schools.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "It wasn't enough for me.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "I wanted a memorial where people can come and learn, an educational facility and a memorial at the same time.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "The opportunity came in 1983, when I was asked to join a committee, a building committee.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "It took three years to finish the project.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I was chair of a small committee of survivors.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "We raised the money necessary.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "We did not go to any organization to finance us.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "We raised it among survivors, and Canadian Jews of Goodwill.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "And the Ontario government was very generous.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "We also got a bit of funding from the Canadian government.",
      "word_count": 11
    }
  ],
