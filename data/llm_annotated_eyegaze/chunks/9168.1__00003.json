{
  "stem": "9168.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And then there was a fire in the town somewhere, and they all had to go to take care of this fire problem and put him back in his cell until they returned, at which time they were going to continue the card game.",
      "word_count": 44
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And it was during the time they were gone that he used his belt to hang himself in the cell.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "It-- well, I-- I was really-- I felt very glad, if you will, because I had spent 17 years of a young life with the-- he was very, very brutal.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I know that the three of us children, did not-- we really did not have any kind of love for a father because of the brutality which was visited upon our mother, predominantly.",
      "word_count": 34
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And as much as I wanted her to just leave him and get us out of this situation, she was not really able to do it.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And she just went to work to provide income in the Woodstock typewriter factory.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And it-- it-- it just seemed as though after his death, our life started-- literally.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I had-- I was just graduating from high school.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And we did not have the money.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I did not have the money.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Nor did my mother, from the-- the limited income that she received from her father's wheat farm in Kansas.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She had a tenant farmer there.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "But there was not money for me to go to college.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I lived this far out from Chicago.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And she borrowed enough money on her wheat farm for me to-- to go into Chicago, to Gregg Reporting College.",
      "word_count": 20
    }
  ],
