{
  "stem": "598.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And I save myself this way.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And my father at that time was saved in a bush.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "He came in a bush and nobody saw him.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "And that's the way we survived that day.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "That day they collect 450 people in a day.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "That time, I didn't know about they kill him.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They say they're taking a camp.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They take them away for working.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have no mail.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have no letters.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have no organization.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And we thought that maybe it's true.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "They take them away somewhere to work.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "That's the way they said he was taken away.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, '41-- that was they took away Leo.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] was-- [NON-ENGLISH] were '42.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH] was, at 4 o'clock in the morning, I hear someone's knocking in the walls.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I waked up, and I go down to the halls and looked to the-- to the wall.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I see SS knocking neighbor's door to open up.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I jumped into my house.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I says, SS is looking for Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And I barefooted, only a pair of pants and a shirt, I run into the garden and try to run to the river.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "In the garden stays police-- Germans and with guns.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And he shoot.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And don't ask questions.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Shoot straight at me-- one time, twice.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "See, he didn't say a word to me, just start shooting.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "So I fall down.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And he thought that I was killed.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "And he came  near to me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And I looked around.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And he says to me, what?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Are you not dead yet?",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Then came a younger guy-- a German guy, too.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And he start beating me up.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And they find my father, too, and another guy.",
      "word_count": 9
    }
  ],
