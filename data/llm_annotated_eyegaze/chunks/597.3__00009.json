{
  "stem": "597.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "She looked up, and over there it was dark.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They don't have lights.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "They don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So we-- this way, we find our way to go to that village.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And we came in on a Sunday morning in that village.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And my mother knew-- she was born there.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "She knew all the houses there and all the people-- all the people.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "She went on the end of the village there and ran into a woman.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She knew the people there where they lived.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And that was a-- already a daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "That was not the older people.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Her daughter was there.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And she was asking for bread.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We was hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "People be hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "You need to eat!",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "You're a human being.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "You have to eat something-- asking for bread and water.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "Then a woman-- and she told her who she are-- is.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "The little guys already knew that this is-- this is already a [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "[NON-ENGLISH], this is in Russian-- in Ukrainian.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "It means Jew.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "The little-- little-- little kids, they put in in their eyes that Jews are not people.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And the little kids went away right away-- the little kids, like a 10-year-old, or 9, 10, 11-year-old kids.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "They went right away to the [NON-ENGLISH] over there to the city village.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And they said that the Jews are in the village.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "And there was Germans there collecting some duties-- were about three, four Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "And that woman-- girl-- was there in the village-- the girl, Nadia Storazuk.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "I told you about it.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "And she ran back.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "They knew where my mother and we were stationed there, by that woman.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "And she ran down barefooted.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "She was my age-- about 18-years-old-- 17-- about that.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "And she came here-- there, and she says, listen!",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "Germans are looking already for you.",
      "word_count": 6
    }
  ],
