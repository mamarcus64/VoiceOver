  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 5 SECONDS] Most of the time they were sure speaking German.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had the daily paper, and several magazines.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "My sister [INAUDIBLE] separate magazine.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "My brother had and I had a magazine.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I tell you, we didn't have much time to read, because early in the morning till late night, we all, the whole family, we were working in the store.",
      "word_count": 29
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Shabbos we come together with friends and we had fun.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "So we didn't have reading much time.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Well, it was-- [PAUSES FOR 5 SECONDS] I don't see any magazines like that here.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "It was many [PAUSES FOR 9 SECONDS] [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And the funny pages of the day.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "The comic section was there.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And little stories, little stories from-- every day stories.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "It was very-- I remember I liked very much.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "It was very interesting.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH], that was the name.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I don't really know.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Well, I think I was--",
      "word_count": 5
    }
