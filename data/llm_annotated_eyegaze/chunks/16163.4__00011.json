{
  "stem": "16163.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "They put food and stuff into baskets, and we had to march in the ghetto-- into the ghetto and were filmed in ghetto from-- what was his name?",
      "word_count": 28
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "A-- a Jewish film [INAUDIBLE] who came from Berlin.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Gavon, ?] and he took the films from Theresienstadt.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "He didn't make [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "After that he went to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "This is right after that every-- all the transports started.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Were you allowed to eat that food?",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "We were allowed to eat that food, and [INAUDIBLE], you know, they-- they taught us what to say.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "They said, oh, don't we have anything else to eat?",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We always have to eat the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "Don't we have something this time?",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Couldn't you bring in, let's say, for instance, strawberries instead of apples, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "I don't know exactly the words anymore more, but that's what they taught us.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Didn't help much for the one day, two days.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No, I just remember that we walked in there with the things in there, and they took that film.",
      "word_count": 19
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, we had usually in the summer times, we had like a-- we made from-- mostly from bedsheets and stuff, we made our own clothes.",
      "word_count": 25
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And some people who could sew.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "We had like slacks and shorts.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And in the winter time, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "We-- we had very little clothes, but we made the best out of it.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "That was still the ghetto life.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "But when they were trying to fix the place up to make everything look very nice--",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Oh, they made like a children pavilion where the kids could play and all kinds of things.",
      "word_count": 17
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Nothing like that.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Not that I remember.",
      "word_count": 4
    }
  ],
