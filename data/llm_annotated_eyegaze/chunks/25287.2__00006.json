  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "These two German soldiers was a decent man.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Next door had two old girls.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "They get also, too, but they was terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "They don't-- they-- I don't even want to tell you what the horrible things-- you know-- did for them.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "You know, to don't go to the bedroom, but in the front of the window.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "Ours was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "He-- they even came to the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "My mother used to bake some squash.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "You know, we don't have too many things to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "And we asked them if you want to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And somehow, they respect us.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And they moved on, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "They stay, I don't know, months or a couple of weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "I cannot remember.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "But that's also happened.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Because we talked to them.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And they was crying, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And they needed to clean their dirty boots.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "For us, doesn't.",
      "word_count": 3
    },
    {
