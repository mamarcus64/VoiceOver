{
  "stem": "131.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But when my sister and I supposed to put potatoes in those barrels and put it-- take it together on a-- to put away for the Germans for the winter in the ground.",
      "word_count": 33
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And [PAUSES FOR 3 SECONDS] we stopped, because I said to my sister, I can carry no more.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Let them kill us.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "So they let the dogs on us [PAUSES FOR 3 SECONDS] when we stopped.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And the dogs [PAUSES FOR 4 SECONDS] were jumping on our faces and scratching us all over.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "My legs and my sisters' legs were bleeding, but that's nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] And from the dirt, we didn't get no [PAUSES FOR 3 SECONDS] infection there.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They don't let you standing there.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "From that.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I prayed to-- for dying all the time, because I heard what happened to my family, that they told us next that-- don't you see the chimney?",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They are burned?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They told us what happened to them.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Don't look for them, because they are not alive anymore, whoever was-- you are alive, and that's it.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] We couldn't believe it, but those girls who came from Poland who were there already two years, they used to tell us that you were still sitting by a table and eating normal food.",
      "word_count": 38
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We are here already three or four years.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "We build all the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "You have it very good now.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "They said that we had it good now.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "I says, you're talking like it was our fault that we remain until now.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "She says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "But you don't know what we went through here [PAUSES FOR 3 SECONDS] to build all the barracks.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They had to do that.",
      "word_count": 5
    }
  ],
