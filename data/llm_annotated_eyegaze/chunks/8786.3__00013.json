      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "He gave me a bang with a huge-- it was-- it was like a bamboo stick about two yard long.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Gave me-- I fall down, big bang bump here, bleeding, bleeding.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know where I was.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I lost my hat.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I put on my snow hat.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I lost-- I don't know whether-- no, I picked up my package.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "But when I got up, I was-- I was-- I was totally dizzy.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I didn't know which way to go, because the screaming and I didn't see any group to go.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "There was no marchers anymore.",
      "word_count": 5
    }
