{
  "stem": "17044.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 177.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And my father had also sisters [BACKGROUND NOISE] and brothers, but two of them immigrate to United States, lived here in United States.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we was-- with the little brothers, we were fighting.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "With the older brothers, we-- we-- we had fun, go and play soccer, climb in trees, and going to some organizations for a picnic.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And it was a very close family.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes, we shared mostly three or four were in one room.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And the sister had her own room.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And the parents had a separate room.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And my grandma-- and my grandmother had a separate room.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And she like was the princess in the family.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We were a religious family, a Orthodox family, observed holy day, holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And even my father, oh, God, three times a day, praying.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But [BACKGROUND NOISE] modern way, already, you know, not special dresses, modern clothes, modern-- like in the [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And-- but the observant was strict and respectable [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Like-- and my mother want to punish me, she sort of mention that, that your father come home, I'll tell him.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "This was punishment.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "So I mean-- but he never laid a hand on us.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "But for a-- so just for respect, so.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My father had a shoe store.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He-- they used to tell us stories, how [PAUSES FOR 3 SECONDS] he survived a orphanage.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And he had to support-- by 12 years old, he supports the-- he support the family.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They lived in a village and when-- and bring in, to the market, straw and hay and other product to sell and everything.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And also, his family background was a big family of six children.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And then he became a businessman.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And then he went to United States.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And my father was there.",
      "word_count": 5
    }
  ],
