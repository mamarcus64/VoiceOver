  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "So after this moment when he ask about the mother, we were two brothers again.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Nobody know.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "After '68 when I was British citizen, I was many times in Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "In the marriage, we was together-- I don't-- three or four times in [?",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Eilat. ?] We fly London to Tel Aviv.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I stay with my brother a few days.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And I-- with a coach, we go to [?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Eilat. ?] And from [?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Eilat, ?] direct to London.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "My wife, she have a-- she had a cousin in [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "So I see my brother and this.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And she contacted her cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In London.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was three years alone.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Again, [? sad ?] story.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I go-- when my wife died, I asked my children what we do-- what I do.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Bury or cremation?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Said, no.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We like mother to be buried.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "It was difficult.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I was in [INAUDIBLE] house to get the permission to bury my wife in [?",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Bushey. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Said, ?] why will bury your wife in a Jewish cemetery?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Tell ?] [? you ?] what I can answer you.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "She is a Jewish, and the children like bury her in a Jewish cemetery.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Though I wasn't a member of a synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "So I must pay a lot of money backwards to be a member of a synagogue.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And I must bring a witness that my wife is a Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "So my sister, my niece, her husband is the-- was the son from Rabbi Schonfield.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "So I phoned my wife, he died in between.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "My sister, she can give me the phone number from Rabbi Schonfield.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So I give them [? and ?] [?",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I ?] phone him on the phone and ask about my wife.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And Rabbi Schonfield tell Mrs.",
      "word_count": 5
    }
