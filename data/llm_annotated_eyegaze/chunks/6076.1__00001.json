{
  "stem": "6076.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We didn't have-- we only had elementary school.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And we had a Hebrew school.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "We had all the convenience in our shtetl, all the convenience I will say.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I went to a public school.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was also half and half-- elementary, I would say, and Catholic.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "The priest will come in.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We, Jewish students, would walk out while he was teaching the Christian kids you know, The Bible.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We respect them.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "He would take them twice a week.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And he will teach one hour.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "Then we will come back like nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And that was respect.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "In the winter time, I remember, it was too cold to go out in the backyard, the school backyard.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "So we would stood up and respect them.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And I would listen, like make believe I don't listen, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "But that was a part we had to attend that Catholic school.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "Because Poland is mostly, in the smaller cities, Catholic schools.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "In the big cities, the Jewish people could attend private schools, Jewish schools, universities.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "But we didn't have that.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "But it was a must.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "Everybody had to go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I went to Hebrew school which was called [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They were only for girls.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We learned the Hebrew history.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We learned the history, the folk-dancing for two hours every day.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "After we came home 12 o'clock from school, we ate lunch, and I prepared my work to go to Hebrew school. 3 o'clock, I came back.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I did my homework from my public school, then for my Hebrew school.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And then the evening fell.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And it was a custom to be home, you know, not to play around late in the evening.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And that's the life in the shtetl, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I used to help my mother.",
      "word_count": 6
    }
  ],
