{
  "stem": "365.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "So I was-- remember tearing off a small piece of bread, the inside, stuffing it into my mouth and just sucking on it till it dissolved in my mouth to swallow it.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I was lying there for several days.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "Finally, they take me off, send me back to my room upstairs where we slept on the shelf.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "My friends see me.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "They claim the next day, there is a selection that all healthy ones go to a work camp.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Roman, you better come with us, because there are rumors that they are going to blow up that camp, to put dynamite under and then pour some petrol over and burn it down.",
      "word_count": 33
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "Blow it up and burn it down with all the sick ones, to stop the epidemic.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "I says, no way.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I'm not going with you.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "If they blow up the camp, I will go fast.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "I'll be killed.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "If I go back with you to a forced labor camp, it will be a slow death.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "I will live-- last a week.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "It will take me a week to die.",
      "word_count": 8
    }
  ],
