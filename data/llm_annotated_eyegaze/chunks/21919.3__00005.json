{
  "stem": "21919.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I could never ask anybody for advice.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid to be sick, because in case I have fever, and I-- and I say things I'm not supposed to.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I was always aware that I might do something that isn't right, especially working on a farm which I wasn't used to.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Every time I've done something wrong, I was terrified if they ask me, how come you didn't know how to do it the right way?",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I constantly observe people, and I was constantly aware of pleasing everybody around me and not getting into any problems with anybody.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Not to talk too much, or say too much, and remembering what I said when I said it so I would repeat the same thing.",
      "word_count": 25
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I was liberated in that place [PAUSES FOR 3 SECONDS] where I met my husband.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No, I went to the Jewish people, and there I met him.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I was working-- Kaza took me to work in that city I was working, then I went to the Jewish people.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And there I met the two partisans, they took me to-- to Kiwerce.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No, I was liberated when I was at Kaza's.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, to me it was no liberation.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I mean, the Russians came and--",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, didn't change my life.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, this was in Kiwerce already, where I met my husband.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And when my husband-- I met my husband after a while.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He proposed, and we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "In 1944.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we stayed for a while in that town.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Then when our city was liberated, Wlodzimierz, we went there.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No, he was from Zamosc, but he went through the-- he went through the occupation in my city, and he lost his family there.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Nothing very much.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We continued because--",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
