{
  "stem": "25114.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I went under a cart, and somebody took me into this zemilyanka.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It was already built-- not all of them were built yet.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It was just the beginning of the-- of the base, which was the last till the end.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It was a a very-- as it turned out, It was like a-- turned out into something else.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "A little genuine little town.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "What was-- in eight months what was built there, what was going on was just indescribable, unbelievable.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Anyway, I went to this zemilyankas.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "There was not a door yet.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Was just a rough sort of door.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "There was no-- so they put in a stove because of me, and they tried to find a door because of me.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And I went to the other side of where the-- the-- the straw was, and brought my own straw and put it on the-- sort of the bank, which was from one end of the zemilyanka to the other.",
      "word_count": 39
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Everybody slept next-- next to each other.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "There was no divisions.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And I put-- made myself a bed of straw-- talking about Jesus-- [LAUGHS] and a peasant's rag.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And that was my bed for having my baby.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "No-- no curtains, no doors, no windows in cold zemilyankian winter.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And I was covered in shingles on top of it.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, my husband stayed still on the other base, because he had to look after the provisions.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And it took a few days.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "The baby didn't come before-- think about a week I was there, and didn't-- didn't get my real labor pains then.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Then all of a sudden I got my labor pains.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And I was sent to the doctor, and the doctor wasn't there.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The doctor was called out on an emergency.",
      "word_count": 8
    }
  ],
