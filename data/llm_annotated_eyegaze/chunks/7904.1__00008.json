  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I-- I had-- yeah, so from there, I went to-- by train, I think by train, I went to Lemberg.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "This was a big city.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Galicia. ?] Very beautiful city, a Pole-- a Jewish-- I mean, a large percent of Jewish people lived in Lemberg, a fine-- a big city, a nice city, a historical city.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And over there-- over there I met a friend of mine.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "He looked at me like I would come back from the [NON-ENGLISH], from the other world.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "He said, what are you doing here?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They say-- at home, they think-- no, this was-- no, this was later on.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "We decided-- this was later on.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We decided to go from Lemberg to go to Romania.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So by train, we went from Lemberg, Stanislavov, [?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Kolomyja, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Sniatyn. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Sniatyn ?] was the border of the Polish-- Polish-- Polish-Romanian border.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "On the other side, there was the city of Cernovic.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And we heard that the Polish army crossed the border-- the Polish army crossed the border to Romania, to Cernovic.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I thought-- we thought maybe we're going to be lucky.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "We're-- and from there, we had a mind to go to Palestine.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "But in Sniatyn-- we saw Cernovic.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Sniatyn-- excuse me.",
      "word_count": 3
    }
  ],
