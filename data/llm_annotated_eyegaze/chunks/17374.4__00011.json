{
  "stem": "17374.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "When she sent us the letter with the photos, in beginning, they live in boarding house somewhere.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "About six months they'd been here, before we arrive.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But my brother-in-law started to work.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And he got, somehow, enough money to put deposit on the house.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And the letter was, my house is your house.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And we lived together for-- in the same house [INAUDIBLE] for six years, one kitchen.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "We started to buy furniture, a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I started to work.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "Oh, it was-- well, it was hard.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "I was working in a-- without English, again, I start with the people who are only English, in a small-- small, few machine.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Want year?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "What year?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I think was '49? '49, I think we arrived to Melbourne.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to [INAUDIBLE] manufactory, a good, big factory here in Richmond, and I was strong.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I was working all day.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I came home by train.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I went back to the city for English, to that adult education.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And I have time from [INAUDIBLE]-- well, I was young and stronger, and I have time for everything.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "I was cooking, and baking, and scrubbing, and washing.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "But my sister didn't work, and that was good, because she looks after Anna.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And she take her to kindergarten, she comb her hair, and she was-- my husband wasn't working during the day.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "It was my husband and my sister together.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "Sometimes was fun, when they went to shop.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They said, funny that the girls look completely like father and the boys like mother.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS] Because [?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "Louie ?] was always with us.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "He was like-- my sister didn't have enough milk.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "I have to feed [?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Louie. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I have Frances, younger one, born in Australia, in Melbourne-- was six years after.",
      "word_count": 14
    }
  ],
