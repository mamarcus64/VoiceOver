  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He knew that they were being taken away from Tarnow-- her parents and the older sister.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And he brought this little girl to stay with us.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "She was five years old.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "So when my father left-- my father was taken away, my mother and I, we still had this little girl that we, you know, tried to save, tried to hide, tried to feed.",
      "word_count": 33
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father was able to-- had a little, probably, money.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And they were just buying food on the black market.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "You did get a five.",
      "word_count": 5
    }
  ],
