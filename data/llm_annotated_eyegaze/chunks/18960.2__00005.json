{
  "stem": "18960.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 377.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "That was a known family in all of Poland, of Galicia, especially.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "The name Backenroth was very known.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It was synonymous with-- with wealth, with charity, and with [PAUSES FOR 4 SECONDS] education, and so forth.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Correct.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "it-- it affected us morally and materially.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Morally, because we became like paupers overnight.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Everything was taken away from us.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "It was nationalized.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Including-- including the fields and everything else.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "We-- we had a right to work in the fields, but it didn't belong to us anymore.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Also there was a shortage of everything, include-- food in particular.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Bread lines.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I remember I used to get up at 4 o'clock in the morning to stay in bread lines to get a loaf of bread, and usually by the time I got to the end of the line, the-- the bread was gone already.",
      "word_count": 43
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "There was no more bread.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "It was pretty-- pretty bad times.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "With starvation, with hunger.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And did-- they were not happy memories for me.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "This-- this lasted for--",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "--from September, 1939 till the-- the outbreak of the Russo-German war was in June, 1941.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I remember it was a Sunday morning when the first German Luftwaffe planes were bombarding already.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I was in Drohobycz at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They were bombarding the oil field-- the oil refineries.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They were very important.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And they wanted to destroy them.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And the-- and this was a terrible, terrible experience to me.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I might to-- I might want to mention that when I was accepted in medical school in Lwow, there was a-- a few days before the war broke out.",
      "word_count": 29
    }
  ],
