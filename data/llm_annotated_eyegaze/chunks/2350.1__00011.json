{
  "stem": "2350.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "Through a little hole, we peeked, and we saw the Germans coming into our house, looking for somebody to take if-- whoever they will catch, they will take.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed there with the rats, with whatever noise there was there, because it was dark and dirty.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We stayed there for two days and two nights, hidden, because my brother built this-- this was a cement door, you know, from bricks, and a double wall to hide us.",
      "word_count": 31
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "There was always something that you had to escape.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid-- I wasn't ready, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I was not, they say, [GERMAN], candidate, because I was young.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Because they took like from 14, 15, and I was 12.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "So if my sister wouldn't be there, they would take me.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "So I had to hide.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Every time something was going on, I had to hide.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was sitting once in a basement by a friend.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "She was married to a Polack.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And he was a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So she put me in the basement in the carpet that was on top.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And she locked the outside door, like nobody's home.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I was sitting there so scared that I heard like the feet of the Germans were walking over my head.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I heard their voices and the stamping of the feet.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And they were saying, no Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "No Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "No Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "They were looking around.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And after a few hours, it got quiet.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I came out, and I looked.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I says the door was locked.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "How did I hear them?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I was so scared that I heard them over my head.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "That's how it went out, till we went into the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "There was no peace, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And all my brother, my brother-in-law, everybody, was already in camp, except one of my brothers.",
      "word_count": 16
    }
  ],
