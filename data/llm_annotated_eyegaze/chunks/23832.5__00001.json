{
  "stem": "23832.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I think, I think I came to this door-- [WHISPERS]-- [PAUSES FOR 9 SECONDS] Well, I came to where I work with Mimi.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I was breathing very hard because I was running.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I made believe that nothing happened.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I had to hide my face.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 8 SECONDS] Now, I forgot to tell you when I was with this woman there, with the baby Anthony, in that estate.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I always watched through the window, because I expected to have new if my sister is alive or not.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And I was waiting for the mailman.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And I saw the head of the-- of the village, whatever you called him.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I saw him come with the German, like this, and said, I got news that you have Jews hidden here.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And if I find out, that what you'll get.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "No, I don't have Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "We better find out.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And he came to the estate And it was March 19, I think.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "And I was called.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "And I was standing near the door by the wall.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And the door opened.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "And the Germans came in.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And he said, you have Jews hidden here.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "And I heard what's going on.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "I quickly-- and that was in the dining room.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "I quickly went into the baby's room-- meaning the grandmother's bedroom-- bedroom.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "And I took this baby and I put it across.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "He was sleeping, as if I take care of the baby.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And I felt hot and cold.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "Hot and cold, the blood was coming into the face in a way, like this.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And he came, the father of the baby, opened the door and said, somebody's accusing that I have Jews here.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Do you have a Kenncarte?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    }
  ],
