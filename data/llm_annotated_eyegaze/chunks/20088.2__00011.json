  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 31,
      "text": "And they worked till 10 o'clock at night.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 32,
      "text": "And we were quite happy.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 33,
      "text": "We went to bed in the evening.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 34,
      "text": "And about 2 o'clock, we heard lorries outside and shouting.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 35,
      "text": "And then we heard the banging on the door.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 36,
      "text": "And we quickly got out of bed and jumped into this-- like a rehearsal, it was, and put the trap door on.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 37,
      "text": "And waited.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 38,
      "text": "And we heard the Germans come in with their heavy boots on the stairs.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 39,
      "text": "And it was the same partition.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 40,
      "text": "And my heart-- I felt my heart beating.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 41,
      "text": "And I thought, well, I'm sure they must hear my heart beat.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 42,
      "text": "But of course, they couldn't.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 43,
      "text": "We heard them opening and-- the door, and they must have looked in and saw everything was all right, and left again.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 44,
      "text": "So--",
      "word_count": 1
    }
  ],
