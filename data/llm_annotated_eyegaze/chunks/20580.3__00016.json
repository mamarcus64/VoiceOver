  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "A guy came last year [BACKROUND NOISE] to the factory from leather, he should bring wood.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "He didn't bring the wood.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "He says, I cannot bring the wood by my horse-- cannot walk.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And he bring the-- and I sign it.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "I have 20, 20 wagons.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And he's the 20th.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "I'll sign it.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "He says, I'll bring you a chicken.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "I'll bring you butter.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "I'll bring you everything there.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "Next day, he bring me butter.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "He bring me chicken.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "But the next course, my name is Josef.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And I don't remember the name.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    }
  ],
