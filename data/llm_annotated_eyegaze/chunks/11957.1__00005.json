{
  "stem": "11957.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We had to wear a star.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it did make me angry.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Worse, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had to take our prized possessions and trade them for some food.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "The farmers used to come to the-- to the ghetto, not inside the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "We used to trade them.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "They were on the outside of the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "We were on the inside of the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "We used to trade our prized possessions for some food.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Like a gold watch and a gold ring.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "They-- [PAUSES FOR 3 SECONDS] they took the-- all able-bodied to work.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "We had to go to a certain designated area.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And they came and they picked out 10 or 20 people.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And they took them to work.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "They were too young.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "When the Germans first came, they had me working making roads, asphalt.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We had to make better roads for them that they could advance faster.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "We had cobblestones and that wasn't good enough for them.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "They had to have a smooth road so they can advance faster.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "So they took us out.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And we worked on the roads until later on, when the Gendarmerie came.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Gendamerie was a police.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "They were sent to take care of law and order in our town.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "When they came in, they needed people to work for them.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "So they sent me over to the Gendamerie there-- myself and my cousin, were-- we were using wood for cooking and for heating.",
      "word_count": 23
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We had to sew it and cut it to a certain size, so it would fit in the ovens and the stoves.",
      "word_count": 22
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "So my cousin and I were sent to work for the Gendarmerie.",
      "word_count": 12
    }
  ],
