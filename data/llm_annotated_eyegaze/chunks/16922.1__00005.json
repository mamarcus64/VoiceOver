{
  "stem": "16922.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "To a forest near, near some boy, who bring us milk, and a girl came-- came just in the same day.",
      "word_count": 21
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "She came, and she said to my mother, you can come in my house.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I live alone.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "So my mother came in her house, with my sister, and the, the youngest, Hilda, came her house.",
      "word_count": 18
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "So, [PAUSES FOR 4 SECONDS] she said that she can stay in her house.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And later, she throw away-- throw out my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Because she find out they are going to kill her, if she's going to keep Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "So she throw my mother out.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And I make up with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "I have to pick, I'm going to pick her up, and we're going to go to where all, all the Jews are going.",
      "word_count": 23
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "I wanted to go to Cracow.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Then I'm not-- I didn't know where to look for her.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Since she throw away, she said, she's gone somewhere else.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't know where to look for her.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And I didn't see her till then, till today.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "I know they-- a woman came.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "I went to my woman, what she-- I was working for her.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And she was a very good-- a good friend.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And she said, I know your mother was killed.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "In the same day, she tell me, your mother was-- your sister was killed, and your mother was killed.",
      "word_count": 19
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "A Polish woman, a good woman.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "She came to my house, and she said, Sally, you can stay at my house.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And she keep me in the-- in the attic.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "A couple days.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Later I went from her house, I went to Cracow",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "To Sosnowiec.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Because I have a friend in Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And she said when something happen, come to Sosnowiec.",
      "word_count": 9
    }
  ],
