{
  "stem": "24651.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It's Janet Applefield, J-A-N-E-T A-P-P-L-E-F-I-E-L-D.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Gustawa Singer, G-U-S-T-A-W-A, Singer, S-I-N-G-E-R.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My nickname was Dzidzia, D-Z-I-D-Z-I-A.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Just it means baby.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I had other names during the war.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "My name was Krystina Antoszkiewicz, K-R-Y-S-T-I-N-A A-N-T-O-S-Z-K-I-E-W-I-C-Z.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, I think that's all.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "June 4th, 1935.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm 61.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Krakow, Poland, C-R-A-C-OW, Poland, P-O-L-A-N-D.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, I lived in a little town, Nowy Targ, outside of Krakow, with a large extended family.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I had a baby sister.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I was the first grandchild in the family.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And my father was one of six brothers.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And my mother was one of three sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And one set of grandparents, the Singers, lived in Nowy Targ.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My other grandparents lived in Wadowice, a little village-- same place where the current Pope is from.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And I remember a lot of fun things.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I remember my uncles doing a lot of fun things with me in particular.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "My uncle Arthur used to take me out on his motorcycle, and we would go to the candy store, and he would buy me things.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "I remember preparation for the holidays when my mother and my grandmother used to cook and bake.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I remember making challah, braiding challah with them, and making noodles.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Everything was made from scratch, so it took a long time to prepare.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And I remember the house being cleaned and-- but in particular, I recall the gypsy woman used to come.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And she used to scrub-- you know, scrub the floors and get the whole house ready.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "For the holi-- like for Friday night, for every Friday night when, you know, we'd have our Shabbos supper.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We had chicken soup, of course-- chicken, fish, cold fish.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I think it was carp.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And it was cooked with raisins.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I remember the gelatin from the fish.",
      "word_count": 8
    }
  ],
