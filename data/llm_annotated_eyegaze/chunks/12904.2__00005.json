{
  "stem": "12904.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And we did that for that whole year, and then we went back and my cousin decided, as a Mischling, a mixture, she came from a mixed marriage, that she would be able to stay in Germany.",
      "word_count": 37
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "She felt she was not in imminent danger.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And I knew I couldn't, and I went back to another school in England, in Haslemere.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It's a sort of-- well, it's not London anymore, it's-- I don't-- I can't tell you what direction it was from London.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And this was a school that was established by two German Jewish women teachers so that people could finish their education there.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And then I don't remember what happened in 1935, '36-- end of '35.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I had to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I think it was the English home office didn't give me permission to stay longer.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "You have to get permission for some reason.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And I went home again, and then later attended-- beginning of '36-- attended school in Switzerland.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Her name as Edith.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I call her Doris in the story I wrote about her.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Edith.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Coming from a mixed marriage and having been brought up Protestant.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I think that really saved her from being-- towards the end of the war, all the-- they started picking up all the people from mixed marriages, too.",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And what saved her was that she had developed TB, tuberculosis, and had to go to a sanatorium.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And she was sort of protected there.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how many knew that she had a Jewish mother, whatever, or how much she talked about it since she didn't want to talk about it when she was younger.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So that protected her.",
      "word_count": 4
    }
  ],
