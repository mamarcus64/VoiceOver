  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And you know, I wish sometimes that we would have had a background, that we would have had a religious background and we would have been-- we would have celebrated the holidays and somehow maybe even be closer than we were.",
      "word_count": 41
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "But I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "But it would give you some-- some solidity, which I never had.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I would like my children and grandchildren to hear my story one day, if they're so interested.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And that's the reason I decided to go along with it and have it done.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Just hoping and wishing that my family can have an easier life than I did and more chances, which I know educationally they've had.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I'm very grateful for that and that my grandchildren will equally have the same opportunities, and hopefully take them.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "OK, you're welcome.",
      "word_count": 3
    }
  ],
