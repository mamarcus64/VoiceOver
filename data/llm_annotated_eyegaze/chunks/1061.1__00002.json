{
  "stem": "1061.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "She also had a nickname, [?",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "Hanya. ?] The second sister, the middle one, Rosalie [?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "Kristine ?] Lerman, also known as [?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "Krisha. ?] And I am the third one.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 32,
      "text": "And we all attended school.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 33,
      "text": "We attended Polish schools, not Jewish schools, because our town also had a very sizable Jewish population.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 34,
      "text": "And the religious part of the Jewish population preferred their own schools.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 35,
      "text": "And they had religious schools for girls.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 36,
      "text": "And they had religious schools for boys.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 37,
      "text": "We did not attend any of those schools.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 38,
      "text": "We went to the regular Polish school.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 39,
      "text": "And the language spoken at home was Polish.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "This was just a public school.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You know, this was just a regular public school in town.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It had no name.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "When-- when the war broke out, I was 10 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I never, of course, never finished elementary school before the war.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "My oldest sister, Anna, she was already in gymnasium, which is high school, which was a higher level in Poland than it is here.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And my second sister of-- the middle sister, of course, had more education than I.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "But my education was cut off right in the middle of-- of elementary school.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, I adored it, because we were very much in tune with our surroundings.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We did not live a-- a-- a ghetto-ized type of existence.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We mingled with the Christians.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We attended their Christmas dinners and-- and went to look at their Christmas trees.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And they would come for Passovers to our home.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we just felt ourselves part of the community, even though we were Jewish and participated in the Jewish community.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "But not-- my parents were only religious to an extent that, you know, they attended synagogue and such.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "But they were not-- we were not kosher, you see.",
      "word_count": 10
    }
  ],
