{
  "stem": "10397.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I want to go on your garret and sleep overnight, and early in the morning I go away.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So she says, I would like to have you but I'm afraid because you know what happens.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They'll kill me, my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "If you want to stay here, we will go away.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "We'll leave the building all together.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You know, I said, where are you going to go?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "We know a lot of people in the villages.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "They went and I went on the garret.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And I slept there.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "I slept I don't know how long.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Maybe half a day.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Next to the school there was two sisters, seamstresses.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Also patients.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "One was a patient coming into my-- I didn't do very much for them, but they wanted, what's the matter with me?",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I done this, it hurts.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "I say, OK, you will be all right.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "Do this.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Village medicine, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "Hot compresses.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "So I say, it was already two days.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Because one night I spent in the forest.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "One night I spent on the garret in the school.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "So that's the third day.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And I don't know if the Germans are there or if the Germans are not there.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "So I told the sister, the seamstress, some people were talking in the village that she was a prostitute.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "To that's an additional profession but it doesn't bother me.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "So I say, you go.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "Now I didn't have to.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "So are the Germans in the village?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "I didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "I was cut off.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "She says, they're gone.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "They're gone.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "Who is in the village?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "I say, do me a favor.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "You go to the Huzar house.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "Tell theme to come and get me.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "Want to go back to my home.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "That's my home.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "Pretty soon Huzar come in.",
      "word_count": 5
    }
  ],
