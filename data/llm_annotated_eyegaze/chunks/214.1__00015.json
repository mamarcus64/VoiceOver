  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "So this [? all ?] came in meters.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And so, let's say if you managed to cut 20 meters, you grab it, you know, and you were fortunate nobody caught you, because it was the middle of the night, and you brought it down.",
      "word_count": 36
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And then, this Pole would take it to Skierniewice-- and that actually, the first-- was the first year for sure.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "Maybe even more.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We lived on it, because my cousins and my sister and myself, they knew all those Polish peasants because they were customers of my aunt's.",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My aunt-- my aunt, again, was a retailer-- she was one of my father's customers.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "She was-- you know, she was in retail, and my father was this wholesaler, [? jobber ?] or whatever you call it.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Oh, fine.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I think I'm talking too--",
      "word_count": 5
    }
  ],
