{
  "stem": "27747.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And no way did we want to stay any longer, waiting for papers from-- from-- from America, which my husband had a lot of family and I had an uncle here.",
      "word_count": 31
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Czechoslovakian government did not-- did not think that the passports are legitimate, and this is why we were jailed.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We got them to-- my cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You know, whether he knew that they are legitimate or not we don't know.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We paid-- whatever money we had we paid for them, and he made them for us, the cousin the pharmacist.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Heading towards-- thinking that maybe-- we really didn't know where we were heading.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There was no plans.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "No plans.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But we knew that if we come to Germany, there are displaced person camps there.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We figured that maybe from there would either we go to America or we go to Palestine when the time is right and when the immigration is open.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And so we met the head of the Brigade.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "My husband knew him from Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "He knew him from Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And he said to follow him to Austria.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "There were-- there were borders, and we did that at night.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we came--",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and he-- not just us, many other Jewish people-- young, mainly.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And we came to the town of Linz that was on the Danube.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "That's where we had our honeymoon because he gave us a special room, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed there, and later traveled to Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And we settled in Ulm.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Ulm on the Danube was a camp, a displaced person camp.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It was '46 already. 1946.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We married in February 3rd of 1946, and at that same time, we traveled and arrived-- still '46, we arrived into the town of Ulm.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "There were two camps in Ulm.",
      "word_count": 6
    }
  ],
