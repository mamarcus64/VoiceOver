{
  "stem": "21978.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- we-- we have been given a room in a-- of a apartment of Jewish people who had to take tenants, because Jews were not allowed to live in an apartment on their own.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So there, one room of their apartment was given to us.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "There was even a maid of those people who was very kind to us.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "She taught me how to do something, how to make a cake or something, because I wasn't really taught to cook.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "But it was not for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "It was-- we were married in March.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In '42.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I was very sad, because my parents didn't know that I'm married.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And his parents were sent to Theresienstadt soon after we were married.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And so I didn't have really mother-in-law for long.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And they were-- were not able to be with us anyway.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We visited them once or twice.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "The thing is that in May '42, my sister who was single at that time-- I don't know what the kind of system was taking people into transport was-- told that she has to go to Theresienstadt ghetto.",
      "word_count": 38
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And of course, I didn't want to be separated from her.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "So Egon and I, we volunteered to come just as well.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And we were allowed to assemble in the exhibition building.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "We were taken in.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "We were registered as for the transport.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And after one night spent on the floors there and being taken-- even our wedding ring was taken away from us-- my husband's hair was shorn-- or cut short.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And the next day, in the morning, Egon and I, we have been told we are not allowed to accompany my sister on the transport, because are saboteurs.",
      "word_count": 28
    }
  ],
