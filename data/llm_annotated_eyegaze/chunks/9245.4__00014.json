{
  "stem": "9245.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And now-- well, that's the end of this story.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "Many of us are not among the living anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And [CRYING] this story has to be told, definitely.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] [SOBBING] It's a-- it's a-- it's an obligation.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "I-- I get into discussions, very heated discussions, urging them, that they must come out and tell this story.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "[SOB]",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "This is Sonia Barman, my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "You know, as-- as--",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "--as you can-- the-- this photo was taken when she was very young, before she got married.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "But there's a very interesting story attached to it.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "As I told you, I-- when we escaped, we didn't have no pictures.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I salvaged this picture-- picture from my uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "You see, my father was an invalid, when he came from-- Before the First World War, he had a-- a girlfriend, who was-- whom he was supposed to marry.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "But when he came back, and he lost his four fingers, she didn't want him.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And she went to America.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So he went, and he found my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And he married her.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And when he married her, he sent a picture to this girlfriend.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And she lived in Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "My uncle, who lived in Washington, when I survived and I came to America, he said, you know, I have a picture of your mother.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And this is how I got this picture.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I also have a picture of my-- of my uncle and my grandmother.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Mm hm.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "This was taken in David Grudek, two names, D-A-V-I-D G-R-U-D-E-K.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And that would be in--",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That's in Poland, yeah.",
      "word_count": 4
    }
  ],
