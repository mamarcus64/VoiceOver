  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And then they-- the offensive started, and they were pushing back the Nazis.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "My father hid, and behind the Russian lines came back to Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And that's when he got my letter what I wrote in Auschwitz.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I forgot to mention.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "On second week I was in Auschwitz, they ordered us to write a letter to somebody who is home.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "Because the Budapest ghetto basically was there.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "So I didn't write.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "Didn't have nobody else.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "But in Csepel, in the town where we lived the last time, we had a gentile friend.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And I addressed this postcard to this gentile friend.",
      "word_count": 9
    }
  ],
