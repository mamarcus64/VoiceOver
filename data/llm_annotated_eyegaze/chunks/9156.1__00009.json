{
  "stem": "9156.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 39,
      "text": "The person who got me into it, who later became a very prominent person in Israel, was Rosa Baline.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 40,
      "text": "She wasn't called that in Israel, so I don't know any more.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 41,
      "text": "But the Balines were rich Jews in Berlin.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 42,
      "text": "But Rosa was very much for the poor, for everything.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 43,
      "text": "But she got me into that, a wonderful, gentle person.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 44,
      "text": "The youth movement at that time was, to me, the most important thing.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 45,
      "text": "You-- there were all friends.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 46,
      "text": "We were very close.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 47,
      "text": "We believed in beauty.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 48,
      "text": "We believed in justice.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 49,
      "text": "We believed that poor people shouldn't be treated differently than rich people.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 50,
      "text": "Everything that I stand for still, even today, it was there.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 51,
      "text": "And we also were angry at some of the adults that would treat us like nothing.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 52,
      "text": "And you know, many people know that all my life has been speaking up for young people.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 53,
      "text": "You know, once somebody called me the mother of all delinquents.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 54,
      "text": "And maybe that's what I am.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 55,
      "text": "But it starts at that time.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 56,
      "text": "I can tell for hours stories that I always say the dumb adults never remember, but I remember them.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 57,
      "text": "We were not-- we were idealistic.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 58,
      "text": "We wanted the world to be better.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 59,
      "text": "We were not violent, but we wanted to be that we were recognized.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 60,
      "text": "Part of the Kameraden became a split off.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 61,
      "text": "It was called the Schwarzer Haufen, Schwarzer, black.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 62,
      "text": "Whatever Haufen is.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 63,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 64,
      "text": "H-A-U-F-E-N.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 65,
      "text": "They were the radical part, the real radicals.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 66,
      "text": "And we did question a lot of things that were taught in the synagogues.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 67,
      "text": "And I myself at that-- now, I will tell something else in a minute, but I finish about the Schwarzer Haufen.",
      "word_count": 21
    }
  ],
