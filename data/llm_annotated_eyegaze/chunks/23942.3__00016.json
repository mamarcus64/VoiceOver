  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Because that brook was my guide how to-- to get my bearings.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I knew by that brook, that that brook leads to where I'm familiar.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And at first, I didn't realize I was going in the direction of where I could be identified because that was towards closer to where people lived.",
      "word_count": 27
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And I-- and those were my enemies.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "They-- they were my potential enemies.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Any person that saw me could-- knew that I-- Anyway, I went with that brook.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I ran to the closest barn where my grandmother once slept.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "We slept one night.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "So I knew that that man-- that non-Jew-- that man owned that barn, that he was not an unfriendly person.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "Because she-- by showing me that she slept in that barn, I went there that night.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "That first night, I let-- that-- the end-- when I recognized the barn.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And I let myself in.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "I opened up the latch and I let myself in.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "And I slept on the straw.",
      "word_count": 6
    }
  ],
