{
  "stem": "3933.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 59,
      "text": "I-- there is another thing, I was going to get married, and I run away from the ceremony, at the last minute.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 60,
      "text": "A nice Jewish, American young man.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 61,
      "text": "That was a very big mistake.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 62,
      "text": "I have pictures.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 63,
      "text": "A very big mistake.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 64,
      "text": "I didn't love him, but he as a very decent, nice-- he was a supervisor in a post office, an American.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 65,
      "text": "And he was 35, and I was 40.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 66,
      "text": "To the last minute.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 67,
      "text": "I was engaged first, buy furniture-- he bought furniture and an apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 68,
      "text": "They started the ceremony with the rabbi-- I ran away.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My life is a hell, Jackie.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "It's a hell, it's a hell, it's a hell.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Do I have to tell you about my health?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I worked in an office.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "A friend of mine.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "A friend of mine said, Mary, there is a woman giving birth to a-- to a baby.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We're going to need somebody in the office.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I said, me in the office?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "My-- my English is still not this, my spelling.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And she said, oh Mary, I know you, you will manage.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And then I went for an interview, and they hired me.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And I worked there 10 long years, doing-- writing distributions.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "It was frankly-- a corporation.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "They are closed up.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "They were sold about 10, 15 years ago.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They closed it up and they sold it.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "It was in 1960.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "I worked-- [PAUSES FOR 3 SECONDS] I was-- then I emigrated back to-- well, anyway-- then I-- I worked there, and I met this Harry, whatever.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "My life was going on.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "I was going to work, eight hours a day.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "I moved to Flushing in Queens, got a nice apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "I used to go to Roseland dancing, because dance  was my-- I wanted to be a dancer.",
      "word_count": 17
    }
  ],
