{
  "stem": "1684.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 375.5,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And this was going on-- [PAUSES FOR 3 SECONDS] June the 11th was the first day.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I stayed with my parents, and nothing happened, thank God, because we were not taken.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "We were not on the list.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "The second deportation, when they said it will be the second day, it was the 15th, my mother had some earrings, some diamond earrings.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And she had some brooches, some valuables.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And she said to me-- we had friends which were a friend of my husband too.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "So she said, maybe you can go to the suburbs and-- and hide them there.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And the next morning, I came back, and my husband has already going-- he wanted to help me a little bit.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "So he went and he made a paper, marriage paper.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "Just a little piece of paper which said that I belong to him.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And I came back, and our apartment was sealed.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 13,
      "text": "What they did is they took my parents out.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 14,
      "text": "They were shooting 10,000 people.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 15,
      "text": "I am sure they were shot at the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 16,
      "text": "And 10,000 people were sent to [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So when I came back, I had no place to go.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "The apartment was sealed, and I had nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So my husband offered me to come to his house.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "He lived with his brother further out.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "So I went to the house where my-- where my husband-- at that time, he was a friend of mine only.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And we-- I stayed there for a while.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Then they opened up our apartment again.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And it became, actually, they made a ghetto out of it later on.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So my husband had to move in then to my apartment, because it became the ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1943, after the first deportation.",
      "word_count": 8
    }
  ],
