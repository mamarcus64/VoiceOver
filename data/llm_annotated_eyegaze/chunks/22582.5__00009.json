{
  "stem": "22582.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "They told me how they got to my uncles, because my brother was in Europe and was in the army.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And so he was not-- they couldn't locate him.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And somehow, they found out that he had a family in Staten Island.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "And-- and they sent me affidavit.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "I met somebody that they sent where-- and he wrote them.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "Where-- I mean-- I met-- he was a captain in the army from Staten Island, and we had the address.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "And they send me the affidavit.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "And meanwhile, my brother, they told me, he wrote me a letter from Italy.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "That-- they wrote him, to my brother, that I am in Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And he was at Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "And so-- and he got my address.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "I don't remember if he sent me a letter or not.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "If I got the letter or he didn't have time to.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "But he asked for furlough to be able to come and see me.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "But meanwhile, there was still war going on in the far east, and he was sent in to Japan.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So by the time when he got the answer that he can't, be on account of the condition in Europe and in the far east that he can't get the furlough, he was in Japan anyway already by that time.",
      "word_count": 40
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So I got the affidavit from my uncles.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And then one month before I arrived to United States, I got the affidavit from my-- my brother, who came back already.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "He came one month before I arrived to United States.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So I came actually on his affidavit.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I got the-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Through Bremerhaven.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I had to go to consulate in Munich at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And then they send-- I was actually in second transport to United States on a small boat.",
      "word_count": 17
    }
  ],
