  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "At another time and another place, the answer to the same question was because Poland had the largest concentration of Jews and also the Germans built the death factories also for the Poles.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Not too convincing for me.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Our companion on the train bid us goodbye, wished us well, and gave us some good advice how to move in and around Katowice.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Very friendly.'",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "K-A-T-O-W-I-C-E. 'Katowice, which is in [? older ?] Silesia, which is only a couple of kilometers from our hometown.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "This was the place where we actually stayed in a hotel.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We checked into our hotel not far from the railroad station in Katowice and proceeded by cab to Bendin.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "On the way, we passed a football field.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "The sign outside reads, [POLISH] football field.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "That is the former [POLISH] soccer field where the first punkt, where the first selection, started, where all the torture and all the terror started.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "The mood is depressing.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Your heart is pounding and racing as we disembark at the railroad station in Bendin, Bendzin, [INAUDIBLE] the city of Bendin.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We start walking on the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "Everything looks like miniature replicas.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Incredible.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "Everything looks so small, so dirty.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "All the facades of the buildings are covered with soot and crumbling plastic exposes the original bricks.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "The windows are broken and the pavements are unrepaired.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "Not too many people in the streets.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "It looks like the new owners of these buildings have not spent a nickel's worth of paint or repair since they took them over from the former Jewish owners.",
      "word_count": 29
    }
  ],
