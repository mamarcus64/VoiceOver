  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "He was also looking-- it wouldn't be-- later on when the-- when we went on the two death march, I said something, which is unbelievable.",
      "word_count": 25
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "When I saw-- when the people were killed, and I saw all shot.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And I saw all the brains, the gray brain on the street.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I said, thank god that my father went to the gas chamber.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "He surely wouldn't be able to--",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "--to survive this terrible thing which I had.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And he would be shot.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "My mother passed the selection.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And I know that she came later on to Stutthof, where she--",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "With my sister, both got [NON-ENGLISH], typhoid.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And two or three weeks, they came in the block from typhoid, they survived the typhoid.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't have anymore food.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "It was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "So they were--",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "They starved to death just these two weeks before the liberation.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Why?",
      "word_count": 1
    }
  ],
