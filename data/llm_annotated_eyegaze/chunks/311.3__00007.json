{
  "stem": "311.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't an airport like here.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "There was airport for the-- for the soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "This was the type of actions there was.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "You know, when they-- when they needed, they took 1,000 people, 2,000 people.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And they took them-- that time, that did not-- They killed.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "But, you know, you stay home.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You don't want to look.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "You don't go look for it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "You heard, OK, that four people got killed, six people.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "This, they took to Montelupich, this there.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "They start-- we start hearing about Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They were giving soap, who was very, you know, like Lava soap, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Very rough.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "It was kind of rough.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And they would say, they're going to make soap from you, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "The guys between themselves, the kids, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We're going-- we-- we're going to become soap, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "It's-- you-- you-- you talk.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "You're kids.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "You don't-- I mean, reality is reality.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It start hitting.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "No, it's all dated.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I don't keep a-- a-- a diary.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Do you remember how the people were assembled for the deportations?",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "How they were assembled?",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "But they-- they went house by house, with a list, from beginning.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And at the end, when they took, you know, three-quarters of the people, when my mother went, and my aunt--",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I never mentioned this.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "My mother's sister-- it was her stupidity, but she got pregnant.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And she had a baby.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And this was the date of the bris.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No, that was a week after-- the-- the baby was born on Saturday.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "The bris was on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And on the same-- and next week, Saturday, it was the big thing, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "So I remember-- The big what?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "The big?",
      "word_count": 2
    }
  ],
