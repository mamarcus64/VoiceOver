{
  "stem": "3103.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "So we used to go to Grandma Ziesl, to the parents of my father's and that was a completely different situation.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "That was-- that-- you couldn't move by grandma.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I mean, you couldn't ask for anything.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She put on the table, and you could eat.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You had a choice, yes or no.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I used to [INAUDIBLE], but she was very strict.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't come with her with a short sleeve.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't come to her visit with no stockings on.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "She was very religious and I resented this.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Because I wanted comfort as a child.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "The Tarbut, the religious school that I went, we came.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "We could go with no hose, we could go with short sleeves, and that's what I wanted to do.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So she really wasn't pleased with me because I knew when I have to go and visit, I have to change.",
      "word_count": 21
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "So I try to avoid this as much as I could.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I believe there was not a technique.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "She knew it, what the problem is, so she didn't ask as much.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And I was happy about it, and I didn't go as much.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I think my mother basically made clothes all-- you know, it wasn't just new year.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "She made basically-- we had a seamstress.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I remember very well, her, because I was never good with it.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I could never stand still or listen to her.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But we used to go quite a few times during the year because she had so many customers, and she couldn't produce as much.",
      "word_count": 24
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I really don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Sweet lady, but I don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I think maybe I don't remember it was a piece of chocolate, it was a cookie, or maybe a hard candy.",
      "word_count": 21
    }
  ],
