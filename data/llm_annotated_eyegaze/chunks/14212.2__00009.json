{
  "stem": "14212.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "I was the last one out.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "And my wife was the last one out because she was the director of the old shul there.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "And we had the pleasure of liquidating all of it.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Went-- they went to Israel, from Stuttgart to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "After the erection of the state of Israel, they went to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "On the exodus.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It was the leading kibbutz on the exodus, the real exodus, not the picture.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I came to the United States 1950-- February 1, 1950.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I came.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't do anything else.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I was everything.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I was offered a job by the American Jewish Joint to go to Africa to connect with-- I didn't want to go.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I traveled enough in my lifetime.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I wanted to settle, to make a family, things like this.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "My wife was pregnant at the time with my son.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So I decided to settle in the States and take it easy a little bit.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was a little bit tired.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I joined the painters union.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I worked as a painter.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "In 1959, I was elected to a secretary-- it's a golden secretary of the Painters Local Union 1011, which was a Jewish [? chartered ?] local.",
      "word_count": 26
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And the minutes were written in Yiddish and English.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I have a book which was given by the local to me as a present for remembrance.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And I carried it till 1988.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And-- and even so, after the merger, a number of locals in the ranks, I remained a secretary until 1984.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "I retired at the age of 80.",
      "word_count": 7
    }
  ],
