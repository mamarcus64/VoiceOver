{
  "stem": "16887.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "We went to the streetcar, took a streetcar and were going to Praga, which is on the other side of Vistula.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I ask her, [NON-ENGLISH], where did you leave her?",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I don't know the street.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I don't know the address.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But as soon as I see a red wall, I know that's-- the next street, I left her.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It took probably about 3/4 of an hour.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Finally, I look through the window and I see a red wall.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And she says, that's where we have to get off.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't think.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I had eyes red.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "My hair were not combed.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I looked like a mental patient.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "When we start walking, my feet became paralyzed.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "She said she left them in a little house that was on the next street.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "She knocked at the door.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Somebody came out.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "She-- her name was Jasia Dobrowolska.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "She ask if she lives there.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And the lady said, no.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Where does she live?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "She says, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We were standing and I was crying.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We were-- my neighbor, her husband, and another neighbor, and myself-- we were crying.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Everything-- in just a split of a second, a little girl passed by.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "She stopped by and she says, what are you doing here, lady?",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Who are you looking for?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But my neighbor said, we're looking for Jasia Dobrowolska that used to live here.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "She says, I know where she lives.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "She lives with the principal from the school.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And she took us there.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "When she brought us there, when they knocked at the door-- I was immobile-- they knocked at the door.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "The lady opened the door.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "She looked at me.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "She says, you don't have to tell me.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I look at you.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I could see you her sister.",
      "word_count": 6
    }
  ],
