{
  "stem": "8947.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And they-- you know, Israel knew-- I mean, the Jewish people knew, if the English goes out from there, the British, there's going to be war with the Arabs.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So they wanted to organize aliyahs, you know, immigrations.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And those were illegal, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "We went through illegal immigration.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And two of my mother's cousin came.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "There are very strange things in my life.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And I said, you want to stay here for your children?",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "We didn't like it anymore, because it was-- you-- you were whispering.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You didn't know who's lea-- who is going to say that you are an enemy of the state.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And at 2:00 in the-- at night, you are going to be taken and nobody will know where you are.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So do you-- you don't want to-- now we are robbed of our spiritual freedom.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "How much do we do we take?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Still was antisemitist to a great extent.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They were still didn't like the Jews, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And we said, well, why should we-- I mean-- so we went with these two ships, and",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And we were 16,000 Jewish people immigrating in December, 1947.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And naturally, it was an illegal thing.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And the British got word, and we were intercepted in the Mediterranean by two British warships.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And they say it's going to be war.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Either you go to the Island of Cyprus, and you agree.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Or we are going to fight you, and you're not going to be able to get Israel ever.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And our captain felt-- there were many children and people, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He felt that we should-- I mean, we-- we were forced.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It was not voluntary.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We were forced-- accompanied by the battleship to the Island of Cyprus.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we-- we were put on the sea shore.",
      "word_count": 9
    }
  ],
