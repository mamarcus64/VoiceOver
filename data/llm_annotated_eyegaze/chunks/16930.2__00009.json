{
  "stem": "16930.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 304.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Were you in touch with your sister at this time?",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "My sister and I always were in touch.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My sister and I-- because we lived a few miles apart.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they let us get together, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And as a matter of fact, we got together in a church.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "They took this kid-- they took-- my-- these people, they took the people to the church.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And they took me to the church also.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We got together there, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And-- and I subsequently always was in touch with my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I used to visit her.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "A couple of times, they took her to visit me.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And we're still in touch to this day.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "We're very close.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And my sister's people-- people where she lived with were more dogmatic, especially the-- the woman.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And she sort of wanted to make sure this-- this kid belonged to her.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "Well, no one-- no one-- no one gave kid to her.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "It was only like foster care.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "It was not an adoption.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "None of these people would have-- you know, these people, my sister especially, would not have been suitable as adoptive parents here in America.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "They were old, first of all.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "They were about 10, 15 years older than the people I went to.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "They were old-- maybe in their late 50's or 60's already.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Maybe in their late 50's.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "They would normally not have qualified to get a child into their home.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "But because of the-- the pressure of the moment, the-- the-- the Jewish committee for the children, their-- their priority was save Jews.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "They weren't asking are these qualified people, are these not-qualified people.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "Their-- their goal had to be to put children into homes to save lives.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "That was a priority goal.",
      "word_count": 5
    }
  ],
