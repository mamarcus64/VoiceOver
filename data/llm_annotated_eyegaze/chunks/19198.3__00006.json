{
  "stem": "19198.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 236.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We watched ship schedules to make sure that we would get a-- our letters in to New York at the time when a fast ship would leave that would cross the ocean in five or six days, rather than on a steamer that took six or even eight or nine days.",
      "word_count": 51
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So the-- the letters went very regularly, even though we had no immediate information on anything.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "From time to time, there was the chance of sending a-- a letter by Zeppelin.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The Hindenburg hadn't crashed yet, and it and one other ship would cross maybe once a month or something like that, at which time with-- for extra-- with extra pay, we could send a-- a faster letter.",
      "word_count": 37
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "How often did the Hindenburg cross?",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I think about once a month, but I'm not sure.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, but I saw one of its sister ships, which came over Eberbach, because one of the-- the-- one of Zeppelin's coworkers in-- had been from Eberbach, and so the-- the ship came, flew over the city, and then went its way.",
      "word_count": 42
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "What were the news from overseas?",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Of course, the hard news we got-- had to get from the paper, because the-- all-- all letters were-- were examined.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The-- the letters arrived, having been opened by the-- by the authorities, and resealed.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So all they could write was personal things, and about the-- those events happened to them that had nothing to do with the government.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "You-- how long did you stay in Cincinnati?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Six years.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I came to Cincinnati in 1935, spent two school years, '35-'36, '36-'37, during which time I not only attended the Hebrew Union College but also the University of Cincinnati.",
      "word_count": 29
    }
  ],
