  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 39,
      "text": "I had to run around both crematoriums, because being so young and servicing them, they had-- in each crematorium, they had offices.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 40,
      "text": "And in the one place, there was a laboratory.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So I had a red bandanna on my arm that I could cross the street.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "This was the camp street.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But nobody could cross that street.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "But fortunately, I had seen more things than some of the other-- my other friends-- did.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And this only lasted until October, 1944.",
      "word_count": 7
    }
  ],
