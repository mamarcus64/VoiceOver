{
  "stem": "5188.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I remember one incident where I had a little friend that I played with.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And his parents were talking one day.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And I just stood there and stared and listened.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And they told me, you know, go, go play.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And that was the kind of kid I was.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And I would take it all in and then build my own world based on what I heard.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And that is sometimes good and sometimes not so good.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "But I always had a vivid imagination.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And what I wasn't sure of, I'd construct.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was going to be, you know, like Alice's adventures going through the looking-glass.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We were just going to leave all this and another world was going to open up for us.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And then we went home.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very busy time.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I mean, selling the house, selling the business, going out buying, buying, buying, buying.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I think, every day, my mother went shopping to take things, because we knew we weren't going to have anything when we got here.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I remember getting clothes that were in graduated sizes bigger than I was.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Oh, how I hated those clothes after I got here, because, in those days, kids didn't wear the same thing all over the world.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And it identified me as a refugee for years.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't wait to outgrow them.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And, you know, I had shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I had everything.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "She bought all this stuff, because we couldn't take any money out.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "But we were sending this lift, so she was going to have clothes for us, and she was going to have linens to last forever, you know, bed linens, table linens.",
      "word_count": 31
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "She just bought, bought, and bought.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And so we packed up.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "And then we left the house.",
      "word_count": 6
    }
  ],
