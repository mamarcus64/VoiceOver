  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "All of a sudden, the head of the Gestapo-- that Graf-- saw me, and he put his finger-- he was holding a-- like, you know, they give you a--",
      "word_count": 29
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "A machete, right, And he said, [GERMAN].",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "On this side.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Come here.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And as I came close, he gave me a hit.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And he told me to go on this side.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, I would've gone away with the rest.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "That was 1941.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I was 11-- between 10 and 11.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "As I came to the side where my mother was standing.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "My sisters and I saw a couple-- a husband and wife.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "This woman was a beautiful woman, and he was a tailor.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "But somehow the Germans did not like him.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And they grabbed him, and he was begging.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They took him, but with the rest.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "That's it.",
      "word_count": 2
    }
  ],
