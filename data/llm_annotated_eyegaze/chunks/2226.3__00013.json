  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "But that-- that-- that was the talking.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 11,
      "text": "[TEARFUL] But that Wermacht knew what was going to happen.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "He come back, and he started to scream.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Listen, you want that I should kill you?",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "After all, I am the general.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "You better take them to the next little village and let them stay over there.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "And that's where we got liberated by the Americans-- come in-- [TEARFUL] Can you remember that moment?",
      "word_count": 17
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "American Jew.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "He asked us a few words.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "What's happening?",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "How many people got killed?",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "So we told him.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "We said, a few hundred, but there was no Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "They took [INAUDIBLE] that commandant he shouldn't take us.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "He should give the-- wait another-- he shouldn't be scared for the Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "The Jews know we're never going to revolt [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "And the American Army [? lost a friend. ?] Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "And we're going to help him.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "It happened like that, he didn't-- so anyway, I didn't trust him then.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "I didn't trust him.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 12,
      "text": "I didn't-- I didn't trust him.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 13,
      "text": "There was--",
      "word_count": 2
    }
  ],
