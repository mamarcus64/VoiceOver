  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 59,
      "text": "And the Nazis came, and they killed him-- [?",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 60,
      "text": "Adem. ?] They killed him.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 61,
      "text": "I, I, I walked by myself.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 62,
      "text": "And I had that hole over here in the back.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 63,
      "text": "It was terrible pain.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 64,
      "text": "Me-- and my brother had the, the bullets over here, pain.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 65,
      "text": "And the pain is only-- with warm, steady temperature, that heals, heals.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 66,
      "text": "But at night, you go out in the warm-- and during-- gets-- be cold.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 67,
      "text": "It's terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 68,
      "text": "It's pain.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 69,
      "text": "It doesn't heal.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 70,
      "text": "And over here, a little thing didn't heal.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I went in a house-- Chelbourg.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And I asked the guy, give me a little rag.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Could you get a rag, everything?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They give me a rag.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "They clean me up.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "But they put me a little-- a little alcohol.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And the alcohol is brilliant for that one.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I feel better.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And the same thing with him.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And suddenly, we want to go out-- stays two guys.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "The name I remember if you need a name-- [NON-ENGLISH] and Chelbourg.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Because they told me name later.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "He says, halt, stay!",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "You've got bullets.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "You've got this.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And they checked me.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "I had that, that dowry which my-- $500 which my, my-- they gave me dowry, you know that.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "Then I had $200 for my brother over here and $300 over here.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "It was only $50 bill, $20 bills.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "American money was long-- very long.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "You don't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "It was before you were born-- longer, a lot longer.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "They call it macaroni [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "And they started to, to count the, the-- they are five people already.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "And the guy hit me over here-- over here, with the stick-- with the potatoes, over here hit me.",
      "word_count": 19
    },
    {
