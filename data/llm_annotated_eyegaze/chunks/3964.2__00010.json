    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And the first-- to my-- best to my-- best of my recollection-- first place we knew, or I knew, we were told, or seemingly, we looked out of the window.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It was early in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if it was the second or first day-- second or the first day it was of our trip.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We were in Pilsen.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And everybody said we were going east.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Nobody knew before if we were going east, west, south, or north.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
