{
  "stem": "18575.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It was a small burner which had a kerosene tank and you, and a little cup on the top where you put alcohol to start the heating up the burner, the, the end burner and then pumped up the kerosene, and was acting like a gas burner.",
      "word_count": 47
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "In fact, there millions of them were sold.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was famous in Europe, the primus burner.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Primus is P as Peter, R-I-M-U, S as Sam.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Up to the war, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We, we were, of course, in Europe and Poland specifically, there were only orthodox synagogues and what they called shtiebel, small praying rooms.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Our home was kosher, kept kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Although I was very thin and anemic, supposedly, and one of the doctors prescribed that I should have red meat, and said ham.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So my mother used to get me when I went to school dry roll.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I used to stop at a Polish delicatessen and buy 10 decagrams of ham.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "But never at home, never had anything non-kosher.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "We kept all the holidays at home.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "My father always, no matter how far he traveled, I always make sure to be home for holidays and also for all the occasions, such as wedding, bar mitzvahs, et cetera.",
      "word_count": 31
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "We also attended, in the same building that we lived in, was a shtiebel, as they called a three- or four-room apartment converted to a praying rooms with a rabbi.",
      "word_count": 30
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And it was in orthodox tradition.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We had at Sabbath, of course, my mother lit the candles.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "When my father was there, excuse me, he would perform the Sabbath service.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "But if he wasn't, we just had a dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "My mother would light the candles.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We had just a dinner.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I would say two of them.",
      "word_count": 6
    }
  ],
