  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Dolf Ringel.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I live in Kew Gardens, New York since 1949 when I came here with Dottie from Amsterdam, Holland.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Western Germany in the city called Mainz on the 23rd of December, 1910, the third child and first son of Max and Toni Ringel.",
      "word_count": 28
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "My parents at that time had a business of importing eggs from different parts of Europe, mainly Holland and Belgium.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "During World War One, my mother and her four children-- my brother was born in 1913-- left Mainz and went to Berlin to escape the first bombardments of Mainz during World War One.",
      "word_count": 33
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "After the war-- I think it was 1922 or 1923-- my father and mother returned with the four children to Frankfurt, which was a much larger and more metropolitan city than Mainz.",
      "word_count": 32
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "He continued doing the same business as before, importing eggs from mainly Western Europe, but also Eastern Europe.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "The business was flourishing.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And my two sisters got married, in 1925 my eldest sister, and in 1929 my younger sister, both in Berlin.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "My brother and I went to a what is called gymnasium in Frankfurt, meaning that it taught the Latin and was a preparatory school for college.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I was a very good student.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And when I made my abiturium-- that means the high school-- when I got my high school diploma-- I decided to go study medicine.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And I went to the medical college in Frankfurt, of the Frankfurt University.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "I had-- I made my, what is called physical, or translated, it may mean pre-clinical exam.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "But when I reached the time to start with my clinical studies, it was March 1933 and Hitler had just come to power.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "My father-- my father's business was not going well.",
      "word_count": 9
    }
  ],
