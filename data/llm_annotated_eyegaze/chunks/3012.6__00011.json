      "sentence_idx_in_seg": 6,
      "text": "And then we went out to sea, a good number of miles from the shore.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I buried mother, in this blue suit with my two hands.",
