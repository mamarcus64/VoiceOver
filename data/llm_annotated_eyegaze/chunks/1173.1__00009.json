    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I don't know what happened, but something clicked.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER] And that's it.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And now we are just celebrated our 45th wedding anniversary.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Met my wife.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "My father, 1948, he moved to Israel with, with his-- with his wife, second wife.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "They married 1947.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They went to Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And in 1949, end of '49, we decided to visit them with my fiancee.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And when we were in Israel, my father had said, OK, I don't know if you are going to come to Israel or go maybe to America, and get married, and--",
      "word_count": 31
    }
