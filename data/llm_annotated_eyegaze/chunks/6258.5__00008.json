  "sentences_input": [
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "I was when the moment I went there with the-- with these wires, with-- with that electric wires, with the terrible noises, with that terrible language being used there.",
      "word_count": 29
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Noise.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Everybody-- well, you see, a sign of power it was that people were not talking, but yelling.",
      "word_count": 17
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And everybody was yelling.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "This was when you have power in camp, well, then you yell.",
      "word_count": 12
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "From everybody who wanted to be a powerful person.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "From the [NON-ENGLISH], from the [NON-ENGLISH], from every block [NON-ENGLISH], from every Jewish policeman, from every couple, from everyone there, there was-- there was noise.",
      "word_count": 25
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And there was the most dirty language possible.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "By trucks.",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "Maybe there were four trucks for all of us--",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "--big trucks.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Ah, well, 3/4 of an hour, half an hour.",
      "word_count": 9
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "I have to tell--",
      "word_count": 4
    }
  ],
