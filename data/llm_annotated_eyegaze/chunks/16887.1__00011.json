  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So we-- I remember we ran to another house which was already bombed out.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "My husband said that that will be safer, because they're not going to bomb again.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And your father was also with you?",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "My father, everybody, ran.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Once we got to that house, my-- I remember my mother and my younger sister, with Regina, she stood someplace on the steps.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "My father somehow-- my father somehow got in-- in the yard, in the middle of the yard.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I was standing by the entrance with my husband and my middle sister next to me.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "All of a sudden, a bomb fell in the courtyard.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
