  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "They didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Some people-- it was different people.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "To older people, young people.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "From where it was the energy in-- by myself, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I jumped from the truck.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And I jumped through-- it was a fence.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "One fence and the second fence.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And I jumped.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And to-- and it was like field, nothing-- no houses.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And I begin to run.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "They-- the day was a sunny day.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "When I jumped, they was killing the other people.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And the Ukraine-- it was people-- they begin to-- to-- to the policemen.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And they said, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "That mean that you see one Jew is running.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "They-- the policeman comes to the-- to the corner, begin to shot after me.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "What luck I got, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "He didn't shot me.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "I come to a place that's all-- that's minutes and seconds.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "It's not what you can-- you can something thinks what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "I come to a barn.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "And the barn stay-- it's in the city.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "It's in the side city.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "And it was a pig in the small barn.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "I think fast.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "Open the door.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "And I get up on the top.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "In the top.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "And it was straw.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "When I come in the top, when no-- I feel what my-- my-- I'm shaking.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I-- I don't know what I'm doing, no?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It's something-- something slipped something.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "My brain was working a little.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I put on myself the straw.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was straw and they put in the corner.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I feel with my hand what enough.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It's a pain.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I see it's blood in my nose.",
