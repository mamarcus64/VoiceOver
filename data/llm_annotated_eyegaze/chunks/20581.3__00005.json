{
  "stem": "20581.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "You were really free.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "But now, you don't know what tomorrow brings.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We coming in to one little village.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "It's called-- I remember the name-- it was called [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And we going in.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "The Russian command was right across the street.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And we start to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "People going to take bed.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "We're going to sleep in this house where there's a farmer, a Ukrainian.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "We had some food in the night time.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "You know, and the guy put-- you know, we had no mattresses sort of, but just straw on the floor.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "So we were laying down, falling asleep.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "In the meantime, some of the Russian soldiers, they get drunk.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And they starting to go in, and they want to have a good time.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "They're looking for women.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "And they're looking for more vodka.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "Sure enough, two Russians coming in to the place where we sleep.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And we're sleeping on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And they're waking us up.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And they say, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Ah, we tell them.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We-- no, no, no good, no good, you German spies.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "We're going to shoot you.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "What do you mean you're going to shoot me?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "For what?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Let's go outside.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "We're going to line you up.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We're going to shoot you, you German spies.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They take-- I was hiding in there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I was looking in there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they took the other three people-- [INAUDIBLE], with [INAUDIBLE], with Parness, [INAUDIBLE] Parness.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I remember that's the name.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "They took them outside.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "They lined them up against the wall.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And they Were turning their machine guns.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "They were going to shoot.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "When I saw this, I jumped out.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And I went to-- to the headquarters, the Russian headquarters.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "It was like across the street.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "So I went in there.",
      "word_count": 5
    }
  ],
