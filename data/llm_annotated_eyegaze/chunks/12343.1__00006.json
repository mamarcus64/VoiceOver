  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Oh, there-- I saw-- a lot of Polish used to stand by the Jewish stores and never intending to buy something against the Jews.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Oh, that's [? terrible. ?] [INAUDIBLE] don't go to the Jews, don't go to the Jews, don't go to the Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "It's just terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "What I remember?",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Is how right away, they run to every house and look for boys, for men, for men, for men-- go to work.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Take me to work.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "All the time, right away.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You never can sleep any more.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "I was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "After-- after-- a while, [INAUDIBLE], they started curfew time.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Then it was worse then.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "You cannot go out.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "After 6:00, you have to stay in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "That was worst thing for them to catch us.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "You cannot go out.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "It's just trouble.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "[INAUDIBLE] [? think. ?]",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Beginning, yes, [? off that bat. ?] Oh, then they started.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "The [INAUDIBLE] the Polish [INAUDIBLE] do the thing.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Then they started to put on a band with a-- with a Jewish star.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And I used to go-- I used to take the shirts and cover this.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Then the Polish said, he's a juden.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "He's a juden.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "He's Jewish, Jew.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "That was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "Nothing to hide, no place.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Worse.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "For everybody.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Not just for me, everybody.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "What way?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "What they-- then the Germans try to make a-- call up all the Jews, the richer Jews, and they make them to be the leaders.",
      "word_count": 25
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "If they need something, they have to-- they have to get it from the others.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Oh, then it's trouble.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Then it started trouble.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "All those names-- I-- I remember the names.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Because mostly they take the richer people.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I remember some names.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE], other names, oh, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    }
