  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "It was a-- it was a rainy, October night, and everybody had to get off the train.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "And they said, keep on.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 28,
      "text": "March on.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 29,
      "text": "And all of a sudden, we found out that we were in no man's land.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 30,
      "text": "The Germans had withdrawn.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 31,
      "text": "And some young fellows in our group, they marched on to find out where we were.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 32,
      "text": "And they came against-- across some Polish border patrols, and they didn't know what to do with us.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 33,
      "text": "And we had to stay there until next morning.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 34,
      "text": "And then finally, they got orders to let us in, and they took us to the nearest town.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 35,
      "text": "And from there, we were put on trains to different parts in-- in Poland.",
      "word_count": 14
    }
  ],
