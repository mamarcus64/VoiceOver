{
  "stem": "20684.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So he got me with a knife-- with a razor.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He was a much taller boy than me.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And while he was trying to get the razor out, it got stuck.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He put it in pretty deep.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I got my knife out and did my first bit of surgery.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I cut in a circle and was taken to hospital.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I don't know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I-- came back.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "That's the life that you live in-- scars here, that was another knife.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Cuts across there.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "That was a tough life for four and a half years.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "If-- if the war was hard, four and a half years in French orphanages with delinquents, that was bad news.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Shit, that was bad news.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "That was a hard landing.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "So you win some, you lose some.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "If I hadn't sat so close to the roast, I probably would have had a different life altogether.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "But that was hard in France, that was hard.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "My uncle and auntie, who came from Poland to Russia to Germany from France to Australia found out about our plight and they got-- they got my mother and I out of the France and we finished up in Australia.",
      "word_count": 40
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "She couldn't speak French, she couldn't work.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It was the best thing for me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But I was a-- I was a typical case for a-- for the orphanage.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I was wild, I didn't have any type of manners.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I had never used a knife or a fork for six years or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I was bored.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I was bored.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And they never gave me a chance.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "One night.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I guess [INAUDIBLE] a little lot of meat out of it.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "[DRINKS]",
      "word_count": 1
    }
  ],
