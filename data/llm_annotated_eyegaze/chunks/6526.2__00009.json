{
  "stem": "6526.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And then we noticed that one of the Germans had a Pole on his neck and taking him to this, putting him against the wall-- we were inside-- and shot him, because he had some things.",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He robbed a house, and they wanted to-- they weren't allowed to.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "We were survived.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I mean, it came evening.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We ran away to one of the labor camps that were still there.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And then I've been there.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I found out that my brother also ran away to another camp, to a camp 33 kilometers, Siedlce, that they worked on the road, a German company called the Wolfer and Gobel.",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Wolfer and Gobel.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Wolfer.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "W-O-L-F-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And Gobel.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Gobel is G-O- umlaut G-O with two dots B-E-L.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Wolfer and Gobel.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They were engineers or a road company.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They were fixing the roads, making roads.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And they used us Jews as workers.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "That's all the time, the Jews worked during the occupation.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Occasionally, they allowed the Jews to work at the sheep factory, made the coats-- sheep coat factory.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Made them to work, because they were using this for them.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And all the others had to go to work on the roads or similar hard work.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, not Wolfer and Gobel.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "They were not organized by the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Wolfer and Gobel used to take people to work and they used to pay.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "But they paid so much money that people didn't want to go to work.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So the-- and the Judenrat was forced to give the people-- to send the people to work.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So in this case, the Judenrat was also the bad guy, because they told them to go to work.",
      "word_count": 19
    }
  ],
