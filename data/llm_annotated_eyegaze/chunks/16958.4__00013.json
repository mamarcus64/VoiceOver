{
  "stem": "16958.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I remember it well.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "With my brother and [INAUDIBLE], we walk first.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And we came in to the city.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Most of houses were, were demolished.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "You see a chimney sticks out here.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "We go to see where is house?",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Oh, here are the steps.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "I recognize that.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "No houses, no barns, no nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "So we came out.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "He says, we're going to have to find a house.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "So we find a house, a Jewish house, a good house.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "And we set up there.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "This was April.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "And, and we didn't know what danger it was there.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "It was very danger.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "We were there.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And once a Red Army went through.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And my sister and another girl there, they was standing there.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he says, we are stationed at this place.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Come at night.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Take your brother and bring her back.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I have to give you something.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "We gone there.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "He takes out a, a semi-automatic rifle with a gun.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "He says, now, take this here.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "Put this in the bag.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "You are still in danger.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "You-- when you sleep at night, somebody should stay by the window with this here.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "We didn't even realize that this is-- that we are liberated.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "Because there was still Nazis here.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "There was still Ukrainian police hiding here and there.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "So we did this here.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And we were there for about four weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "Because on the-- on April-- on, on May the 20th, the Russian, the Russians, all the young people had to go to the army.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "I, I had time to go.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "My brother had a rifle already.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "He was working for the police when they tried to [INAUDIBLE] for the police in order not to go in the army.",
      "word_count": 22
    }
  ],
