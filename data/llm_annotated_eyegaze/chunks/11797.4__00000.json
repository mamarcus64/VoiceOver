{
  "stem": "11797.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "There was over there-- we were very-- my brother and I were only together.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We-- I slept on the bottom bunk.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He slept on the upper bunk.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We had three bunks there.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Three row bunks.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "No mattresses-- straw.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "No pillows.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Just lay on the straw like an animal.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "One time the kapo-- which in the concentration camp police mostly consisting of Jews and sometimes maybe a German.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "He picked me for a very-- for a job.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "OK, we need six Jews not working.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "You're going to be called the Iron Brigade.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The job consisted to go to the factory-- we were in a camp.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We were in the concentration already.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They took us out under guard, you know-- under machine gun, under short guns, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "The SS.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "They took us to this particular factory where there was already people-- of non-Jews-- worked there, too, before the war.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And they're still working.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "They were manufacturing revolvers, manufacturing bicycles, motorcycles, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Something that the Germans can use.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It was a huge factory.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Before the war, no Jews worked there.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They wouldn't allow Jews to work there.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] My job consisted-- if somebody-- if somebody's machine breaks down, I had a dolly.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "They taught me how to get a dolly, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And bolt-- take off the bolts from the bottom from the floor, put the small machine on the dolly, take the dolly down, and the machine, to the warehouse.",
      "word_count": 29
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 6 SECONDS] And exchange the machine, put it back, and fasten it on the floor and all.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And let the new people work on the-- this particular machine.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "This factory was one of the worst factories you can imagine.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "There were three shifts.",
      "word_count": 4
    }
  ],
