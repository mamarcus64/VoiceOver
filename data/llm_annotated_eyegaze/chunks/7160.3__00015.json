{
  "stem": "7160.3",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "I figure, you know, better than nothing, I work 10 days around the ship.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "But in the meantime I had an upset stomach, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "The food did not agree with me and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "And the ship was up and down, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "So the following morning they call me on the loud speaker, Albert Rosa report to the office.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "Ah, screw them.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "So the next day again, Albert Rosa.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "When they arrive in New Orleans, the guy was looking for me around.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I saw him, was hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "The big British guy.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You got to think-- I mean, because I got away with that.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "So he was looking for me, I was hiding.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So when I went come over there to-- and he was holding my papers to come down from the ship to land in the United States legal.",
      "word_count": 27
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "When I went-- everybody was a few tables over there, and they ask you-- ask for your name and they gave you the paper.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "So and so gave you the paper.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "That way the guy on the front that looks, you know, some-- how you call those people?",
      "word_count": 17
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Somebody legal was sneak in the United States, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They check-- they wanted the paper.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Then the one on the door, they check you again, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "Say your wife or daughter, whatever you have.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "When I went over there he says-- the captain-- the transport [INAUDIBLE] got the papers.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I went to him and I say, how come you're holding my papers?",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "Don't you remember?",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "We told you have to work on the ship or else you're not coming to the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "We're going to take you back with us to Europe.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "I say, you're kidding.",
      "word_count": 4
    }
  ],
