{
  "stem": "11499.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 416.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So when the Russian army came in Poland, we were near Chelm.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And one day, one morning, I was going out with the-- to see what's happening.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We met the Russian forward troops.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And they start.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "They were, who you are and all this.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They were afraid, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So we told them we are the partisans and I spoke Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And, all right.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So they were fighting for Janow Lubelski, a town.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So we mined the roads there.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The Germans couldn't run away.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And took Janow Lubelski.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Then we went into Chelm.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Chelm was liberated already.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And we established our group.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Our partisan group, [NON-ENGLISH] became the police.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "The first Polish police after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "The first Polish liberated city.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Chelm was the city.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I had very close friends who were with me during the war in the partisans.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "After few weeks, one of my friends was killed in the street.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Few weeks later, another friend of mine was killed.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Chelm in 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Then, anyway, I lost four friends after the--",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "After liberation.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We buried them in the main street of the city, Ulica Lubelska.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Must be Ukrainian or the AK.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "One day, I walked out of the movie and they were shooting after me.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So I used to go to Lublin every week.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "So I asked my commander officer that he should transfer me.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I said, look what's happened.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "They're going to kill me here.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "So he said, no, I cannot do it.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "You have to stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Were there Jews in Chelm after the war?",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "A few.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "A few.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "A few.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "They were liberated. 16 Jews were liberated in town and they were in jail.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "The Germans put them in jail.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And then the Germans couldn't have time to do anything with them.",
      "word_count": 12
    }
  ],
