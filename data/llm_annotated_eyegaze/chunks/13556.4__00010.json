  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 18,
      "text": "We gone to him to live-- which I lived in Seven Oaks for two years.",
      "word_count": 15
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And I feel-- [PAUSES FOR 3 SECONDS] you see, with a older man-- my wife was washing up the floor, dirtied the floor, is coming in with his shoes not so clean.",
      "word_count": 36
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 20,
      "text": "And I don't want my wife to be a housekeeper for him.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 21,
      "text": "And we decided to move to Perth apartments, which I received a raise.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 22,
      "text": "And I quit.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 23,
      "text": "And I start to work as salesman for [?",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 24,
      "text": "Steiman. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was a salesman.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And I moved to Perth apartments, in which-- the old [?",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "Steiman ?] tried to take me without money, nothing to pay.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "He told me he'll take me and my wife, the family, to live with him when the wife died.",
      "word_count": 19
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And I [LAUGHS] have a bad experience to live with the old man.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I told my wife no, no.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "We're going to cut down on food.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I don't want it-- to be a housekeeper for somebody.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And we was living in Perth apartments.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And-- [PAUSES FOR 3 SECONDS] can I continue?",
      "word_count": 8
    }
  ],
