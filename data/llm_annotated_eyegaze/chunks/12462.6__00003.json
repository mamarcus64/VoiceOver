{
  "stem": "12462.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Now, one of the exceptions is in the case of-- the ministry's case.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "A friend of mine in the French delegation, Charles Gertoffer, G-E-R-T-H-O-F-F-E-R, who had worked in the first case, he and I became quite friendly.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And he was brought in to present some part of one of the cases, partly because Telford Taylor just wanted to be able to say we used someone beside Americans.",
      "word_count": 30
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "In that case, we used Charles Gerthoffer.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "A case that-- it was the 11th of the 12 cases.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It was the last in which there was a judgment.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It was the longest case in Nuremberg.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "It was longer than the first trial of the-- before the International Military Tribunal.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And it had in it 24, or 23, or 22 defendants, most of whom were high officials in the Nazi government.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Colonel and then General Telford Taylor.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He was the successor to Justice Jackson, and hence was called, US Chief of Council for War Crimes.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He was a remarkable man.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Justice Jackson had picked him out long before the war as a very able writer of briefs and a very able assistant.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he'd gotten him into the Department of Justice, when he was Attorney General, and so on.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And during the war, Telford Taylor had gotten into intelligence at a very high rank.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he'd become a full colonel.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And he was in Bletchley, England, where the intelligence staff that intercepted the German broadcasts and the German code-- coded messages, they broke the code and so on.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "So he was working with intelligence over there.",
      "word_count": 8
    }
  ],
