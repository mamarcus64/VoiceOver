{
  "stem": "19923.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 126.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "First time I [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "At birth, it was Siegfried Findling.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "S-I-E-G-F-R-I-E-D.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Cologne, Germany.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "C-O-L-O-G-N-E, Germany-- G-E-R-M-A-N-Y.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "December 4, 1930.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I'll be 66 on December 4th.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "David Wolfe Findling.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "David, D-A-V-I-D, and Wolf, W-O-L-F, and Findling, F-I-N-D-L-I-N-G.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In Fryzstag.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "F-R-Y-Z-S-T-A-G.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And that's-- we used to say near Jaslov in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It's a small village in the western part of Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I would say there is another name called [INAUDIBLE], but I would say Jaslov is what I'm familiar with.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "J-A-S-L-O-V.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "That's probably the German spelling.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Etla, E-T-L-A, Gottesdiener, G-O-T-T-E-S-D-I-E-N-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "July 22, 1905.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And did you ask my father's date of birth?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "David Wolf Findling was born March 6, 1901.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw, Poland, W-A-R-S-A-W.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "My father's grandparents I never knew.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I understand that they also lived in Fryzstag.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And my father came from a large family and my grandfather is supposed to have been a redhead and there were a lot of redheads in the Findling family in Fryzstag.",
      "word_count": 31
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And I never met any of my father's family.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "When he came to Germany, he communicated to his family in Fryzstag, but nobody ever came from Fryzstag to visit us.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So I never met any of my uncles or aunts or my grandfather on my father's side.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My maternal grandparents, we do have more of a history.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I have a family tree that goes back a number of years.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And in Cologne, Germany, my father's-- my mother's younger brother lived with us and his name was at that time Herman Gottesdiener.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And Herman, H-E-R-M-A-N, Gottesdiener, the same spelling as my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He later changed his name in life to Charles Gordon, C-H-A-R-L-E-S, Gordon, G-O-R-D-O-N.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "That's a far cry from Herman Gottesdiener, but that's a long story.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "In any event, he was single and lived with us in Cologne, Germany.",
      "word_count": 13
    }
  ],
