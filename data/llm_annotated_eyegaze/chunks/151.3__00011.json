{
  "stem": "151.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I want you to understand that when we came here and I started my business and I realized that I have to really concentrate on a family, that we were a very unique little group of people from the age of 15 to the age of 40 maybe that we had no children and no elders.",
      "word_count": 56
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "That we have to recreate a new nation.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "So that's what we concentrated on and that's what I did.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And I didn't talk about the Holocaust, not even to my own child.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "Until she came later and asked me.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And then of course she got very much involved in the subject and when she was I think 19 years old or so, she organized the first second generation group in Los Angeles.",
      "word_count": 33
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "This is my only daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She has a daughter, Johanna.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Was named after my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And she's now in Israel at Bar-Ilan University becoming religious, which I never dreamt will happen.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But we are delighted about it.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And myself got involved at the time with the Simon Wiesenthal Center and I became a public speaker for the Simon Wiesenthal Center.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Soon after that, I had a conflict with the fashion industry and me talking about the Holocaust and I quit my business.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And--",
      "word_count": 1
    }
  ],
