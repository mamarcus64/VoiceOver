{
  "stem": "748.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Henry and Barbara.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But Barbara was nine months old when-- [SIGHS] yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "When I married?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "No, but the-- the child was there.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "My mother didn't give me the child.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "She didn't trust me.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The child is hers, she said.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And he called her mother.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "This is--",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "There was three-- I think, three bedrooms, a dining room, living room, and a kitchen.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "It was one story.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "A separate house.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And plumbing and everything.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "It's my father.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So too, with everything, should be ready.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "One, I got before, and one later.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "This, I got between high school.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "I took nursing school.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I graduated nursing school.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Then I got a lot easier-- a lots thing they teach about nursing there, in the beginning.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And then, it was very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I worked day and night.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Ah, it was wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I don't think, if you find parents like this was-- I was the only child.",
      "word_count": 15
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "My mother couldn't have more children, so I was their whole life for them.",
      "word_count": 14
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "In-- in-- my mother, around the house, like a-- a religious person do it, because she was from a very religious family, rabbis.",
      "word_count": 23
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Mostly, they graduated the-- the Jewish University, the cousins.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "The family was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And so my mother tried to keep the-- her religious very strictly.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "No, I got in my-- I was in my home.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "But it was close, so the child was mostly with the mother.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Barbara-- Barbara got nine months, when I put her in the church, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Henry?",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "A friend my mother's, a Christian woman, she got a-- a son in Henry's age.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And this child died, hers.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "And she got the-- how should I say?",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "The papers, this [NON-ENGLISH], they call.",
      "word_count": 6
    }
  ],
