{
  "stem": "3835.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And we saw the fire of every building in the-- in the-- in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "But this was a side story.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "This wasn't my main story.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I got to this Mickiewicza 34 in Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they were very elegant people.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Like, she had to have a, a, a girl-- a cleaning girl in the house-- a living-up maid, she had to have.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Because this is how she was used.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "But since her husband couldn't afford it, they could-- they took in a Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And the Jew paid.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And they could have a maid, too.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "At 5 o'clock was tea. 12 o'clock to the second was lunch. 9 o'clock was breakfast. 6 o'clock was-- I think, 7 o'clock was dinner, to the minute.",
      "word_count": 28
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "It was a very elegant house.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "This was the Polish aristocracy.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "In the afternoon, once a week, he went to play bridge.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "He went to play bridge-- very elegant people.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "They had a daughter and a son-in-law, which lost a leg, which was in the hospital-- an officer, a doctor, which was still in the hospital.",
      "word_count": 26
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "And his uniforms were hanging in my bedroom.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Hmm?",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "--I'll tell you the story.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And during the day, I, I put on my uniform, walking around in a Polish officer's uniform.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So whoever-- the, the girl who was working for us-- saw that I am a part of the family, a cousin with the uniform.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I was a-- and one day, they went away the-- to play bridge.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And this girl was alone.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And she came into my room and told me-- this woman, not a girl, a woman, middle-aged woman.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And she saw-- oh, I didn't go out.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- she asked, why doesn't he go out in the street?",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Oh, because he has TB.",
      "word_count": 5
    }
  ],
