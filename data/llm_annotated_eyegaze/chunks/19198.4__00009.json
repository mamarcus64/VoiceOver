  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "After five years in Dothan, I was asked to become the regional director, opening the first regional office of the Union of American Hebrew Congregations, which is the headquarters of Reform Judaism for the United States and Canada.",
      "word_count": 38
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The-- for the entire West Coast, with a seat in Los Angeles.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And just as I was the first to hold that kind of position as a rabbi in the isolated South, so I was the first to hold that position of regional director in the Far West.",
      "word_count": 36
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And again, I had to construct an office and establish the lines of communication.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "This time not to individual families scattered over the area of the state of-- size of the state of-- of New Jersey, but over the six states closest to the Pacific Ocean.",
      "word_count": 32
    }
  ],
