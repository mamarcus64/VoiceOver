{
  "stem": "4695.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And I was working there till the time comes in, in June, I think.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "At the end of May, 1946, I go back to Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "As soon as we come back to Poland, I see we met the Polish people already what-- yes.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "Show us, we will kill you.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "After this, everything-- and I told my wife, I don't like to be in Poland [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "Like to go out.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "It was two months.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Really, I make-- when I talk with you, I make a mistake.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Because we were more than seven children.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "My father has a stepson.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And, and he adopted him.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He was the first [?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Gemir ?] Feldman.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Then he has two children his own-- Nadja and Berek.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And then with my mother because my mother was the first marriage, but my father the second marriage, he has Yehuda, Fela, I, [INAUDIBLE] and Cela, five.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And it was together eight.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And we've [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Gemir ?] was a soldier [INAUDIBLE] a very religious man.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "He has four sons.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "He-- nobody survived from the family-- not he, not his wife, not the four sons.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Nobody survive.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "My sister, Nadja, she married Abe Laib Weizman.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "Then she have a beautiful daughter, Anja.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] I don't know which year they took her out from the Lodz ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] Nobody survived.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 4 SECONDS] Then there is my brother, [?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "Dov ?] Feldman.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "He was in the Lodz ghetto with his wife with two children.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "And thanks God, he survive.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "He bring the children from one place to the other.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "He hides them.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "And he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "Then Yehuda, he is-- he was married to [?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "Lola Siegelthorpe-- ?] a very beautiful girl with red hair.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 29,
      "text": "And they-- all the time, they had no children.",
      "word_count": 9
    }
  ],
