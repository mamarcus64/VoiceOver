{
  "stem": "14687.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I was doing the-- after it-- I was doing-- after, I tell you I went to the factories.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I'm--",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Now, I'm talking about the Auschwitz, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz, we were in August 16.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They took us on the 20 of July.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "We arrived on the 16 of August into--",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "On the 20th of July.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And we arrived on the 16th of August--",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And we cry and crying all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "We see.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And then they used to say, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "No, you are not Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I say, yes, we're Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "We used to say, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "They say, you don't speak Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "You look Italian.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "Mussolini la macaroni, they used to tell us, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "The other prisoners.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And the morning, they used to give you coffee, black coffee, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes they used to throw you the coffee.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Eat-- the Jewish people.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "The [NON-ENGLISH], you know.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "They used to give you--",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "They used to give us.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "They throw it on top of you.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "So I became friends with one girl.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "She was from Budapest.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And she used to say, sing, sing.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "So I used to sing to her.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "She used to give me something to eat, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And after when we were so hungry, we used to go to the dirty place to take the peeps, even the potato skin.",
      "word_count": 23
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "We used to eat them after, you know, from the hunger.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "We were so hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "After we saw, we were thin, thin, thin.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And every week, we used to have selection.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "We used to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "How are we-- we are going to come out from here?",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "We say, eh, we're not going to come.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "We're not coming.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "One night, I-- I-- I dream, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "There were horses running.",
      "word_count": 4
    }
  ],
