{
  "stem": "11589.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 335.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "The English worked together with the Americans, you know, and other free countries.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And after the war, they were so rude, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Very rude.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Then later, they checked everything and every little thing.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "There was a time we tried to escape.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "There wasn't.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They caught us, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So nowhere near.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They never helped.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "How we came to the camp?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Finally?",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Officially, because Israel-- we heard that night-- was a rainy night, terrible night.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "You know, we were outside, you know, talking to each other.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I mean, near the tents.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And, all of a sudden, we heard the news.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Somebody came over and broke the news to us that Israel became a state, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "That's how.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "You can't imagine what a night it was, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "Everybody was dancing in the street.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Everybody was wet.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "Water was running all over.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Who care?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "After going through all those things.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "You know, losing your family, sisters, and parents, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You come over, you say, I've got my own country.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I can start a new living over there, a new family.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "You know what it is?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "People didn't sleep all night.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "We were dancing, I remember, all night.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "At that point, had you found out what happened to your family?",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I found a girl-- the children-- one of the families from out town, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "But she was in camp.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "A while, she was in camp.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And then, she-- somehow, one of the Christians got in touch with her and took her away.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how in our-- it wasn't a camp.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "It was in our town, you know, where they kept them together in one place.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Then they dig the-- you know, diggings.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "They kill them over there, all together.",
      "word_count": 7
    }
  ],
