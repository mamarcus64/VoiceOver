{
  "stem": "10010.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "She lived there a short while-- I don't know how long-- at this [NON-ENGLISH]-- is Aunt [NON-ENGLISH]-- in her house, because they were well-off people.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "They had a factory of-- of-- [LAUGHS] --of combs.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "But the combs were made of galalith.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "It's a form of plastic.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I want to say also about my father's family.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My father's family, there was my grandfather.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My grandfather, he was born in Staszow, and he came from Staszow here.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He had four children-- no-- four-- four son and a daughter-- five children.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "The youngest was a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "My grandmother died.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Her name was Tama, the same like mine.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And he remarried and had with this other woman-- her name was [NON-ENGLISH]-- his name was Chaim-- Chaim Buchman-- and he had another four children-- two boys and two girls.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "The boys' name was Itzhak and Mendel, and the girls who were younger, [NON-ENGLISH] and [NON-ENGLISH], who was in my-- my age.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Now, my grandfather was also a carpenter, and he worked very hard.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And he had a place on a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It was an apartment-- 1/2 was apartment where he lived-- a room-- a one room, really, with a kitchen.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And he lives there.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And the other part, another big room is his place where he work on carpentry.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "My father helped a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "After he got married, he was helping this grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "He was bringing us very often there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Now, my father had four brothers from his-- like, his-- my grandfather's first wife.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "He had four brothers, and the brother's name was Joseph, who later on lived in Belgium, and married, and had a son, Uri, who lives now in Israel.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "He had another brother, Hersch, another brother Ephraim, and a sister, Shosha.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And this sister's daughter lives in Rishon, in Israel.",
      "word_count": 9
    }
  ],
