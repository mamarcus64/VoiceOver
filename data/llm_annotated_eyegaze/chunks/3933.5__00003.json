{
  "stem": "3933.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "He was very-- he said, I wouldn't believe it.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "That you wouldn't-- I wouldn't believe my people did those things.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Well, whatever.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I stayed in this Gliwice.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "The name of the city was Gliwice.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "In German, Gleiwitz.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "In Polish-- the Poles named it Gliwice.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I stayed there in this beautiful apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And-- people said in Walbrzych, which is Waldenburg-- there's another city called Walbrzych.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "In German, Waldenburg.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "This is more Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "More-- many Jewish are there.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "It's a different atmosphere.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "I travel to Walbrzych.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I left-- I left the apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "I went to Walbrzych.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "They gave me also another apartment after Germans left it over, the ones that were evacuated.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And this animal, Kola, traveled there, too.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "[PAUSES FOR 3 SECONDS] And he was still after me.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "This is absolutely unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "People say, no, no, no, I didn't do the right thing.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "I begged, we were hidden from him, drunk, and it came.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "And I went to the police finally at once, and they told him never to come over, never, never, never.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "But he came after a little while.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "He came.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My friend said, you know what you should have done?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Like he was saying-- because I was living the second floor-- I should have pushed with my foot, and being an invalid, I should pushed him, and he would drop dead from over staircase.",
      "word_count": 34
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "But finally, I was rid-- his sister, Lucia, didn't agree with him.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And she said, Mary, believe me, he takes-- he calls me terrible names, blah blah, whatever.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "While I was in Walbrzych, I met this-- well, I don't want to.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was in Walbrzych.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The emigration started to go to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Yes, when I was in Walbrzych, people from Rovno-- I met some people that said, did you hear about your husband, Mary?",
      "word_count": 22
    }
  ],
