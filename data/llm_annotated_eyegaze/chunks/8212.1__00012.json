  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "So my mother ran every single day to a different part of Vienna to get papers that would clear us, that we don't owe Austria money, that we don't, we don't have anything wrong with us, that, that we were never in prison, so that we would get the possibility to leave Austria if we get a passport, and visa for any, anywhere.",
      "word_count": 63
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "Because you had to clear everything also from Austria if you wanted to leave.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "But we didn't get any visa.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "So my mother also ran all over the place to liberate my father, which she finally succeeded with a lawyer.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "After six weeks, he came out of prison.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "And he was told that unless he leaves in the next two weeks, they would send him to Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "At this point, my mother said, leave.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 20,
      "text": "Go, go anywhere.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 21,
      "text": "Go to Belgium.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 22,
      "text": "Go over the border and leave us, because the children and I, nothing will happen.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 23,
      "text": "And my father just didn't want to do that.",
      "word_count": 9
    }
  ],
