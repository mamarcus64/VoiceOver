{
  "stem": "20609.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I says, no, I-- when I make up my mind, I'm leaving.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So I go home and was-- it was in walking distance, like, two or three blocks.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I go home and, you know, you lay in the bathtub for-- in those years you didn't have that cleaning, the soap you have today where you can get-- I-- I scrubbed my fingers.",
      "word_count": 34
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I said, I never want to be dirty again, right.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So this guy comes knocking on my door and I-- I finally get out of the bathtub.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He says, I will go as high as $50.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Then he comes back and says, I'll give you $75.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I says, I wouldn't work for you if you give me $200 a week.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And I-- that-- that's all-- that's all I said.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He gave me his $20-- the $15 I had coming-- and I left.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I went to work for a brake outfit for-- and I did-- all of a sudden, I was making $150 because it was a court job, you now, for the peacemen.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And-- and that's all we did-- brakes, brakes.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I was making like $120, $110.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "One week I had $170.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "This was a lot of money then, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "So I was paying off my cousin for the ticket and she charged me $10 a month for a room or something like that, which was-- oh, $10.",
      "word_count": 28
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I paid her every-- every-- no.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I paid her every-- something like I paid off the ticket real fast.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "The ticket was $180, she sent me $20 which I didn't get, it was screwed up.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I had to borrowed $10 from a guy on the boat.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "He lent me-- and he never thought I was going to send-- I sent him the $10.",
      "word_count": 17
    }
  ],
