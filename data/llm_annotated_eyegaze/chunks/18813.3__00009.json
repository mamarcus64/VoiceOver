{
  "stem": "18813.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] Because then they came, the-- some news from Schindler not to kill us, not to do nothing.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He, he needs us.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And he really didn't need us.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "He was-- just wanted to save us.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "That's it-- unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "I would never see-- I will never forget him.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we-- you know, he, he looked different.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I looked different already because that was quite a few years after.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "We kiss each other.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We made pictures.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "We said goodbye.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Thanked-- that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "What could I say?",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it took me quite a few years.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "The first time what I really said the story was after the Schindler-- my husband made tapes, because he lived through the same thing what I did, with that university in Cracow.",
      "word_count": 32
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "In Cracow-- I said in Vancouver in my-- the tape.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "But I couldn't do it.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I'm surprised how I'm making now.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And-- but when Schindler's movie came out, we went to see it.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I watched the movie, and I didn't see nothing, OK?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I was just crying, and that's it.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "But I seen young people sitting and crying.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And I was thinking to myself, can I keep the story in me about that guy who saved us in the pictures there?",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "I said, that's it.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "I'm starting to talk.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't shut up till now.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "It's true.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Do you have any last messages that you would leave-- like to leave to your grandchildren, that you would like to leave to future generations?",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Just be good to other people.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "People are good all over the world.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And hopefully, we will never have to go through that [SOBBING] and they don't have to go through that what I went.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And what I am alive, I was just lucky.",
      "word_count": 9
    }
  ],
