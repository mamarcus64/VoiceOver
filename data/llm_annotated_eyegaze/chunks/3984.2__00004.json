{
  "stem": "3984.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And I cannot go.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I cannot go, because-- and the people was free in this time, in '43.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "You know, without ghetto yet.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "But I was in ghetto, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "I was not-- I was a prisoner-- of like a [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And before that, almost in the-- when we moved to the ghetto, the old man tried to be very sick.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "The [? gentle, ?] the [? gentle ?] where I was over there, he was very sick.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And the woman was afraid that what can happen to me.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "So when, when they moved to the ghetto, to Hajdunanas, my mother took me with them.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "So this is my story, a very short story.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "So this story is very long for me.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "And I remember for all my life, that I was alone, and alone.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And later, when I finish, I tell you that I never live alone.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "I never-- I cannot be in-- I cannot be in the elevator.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "I cannot be alone.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "And if somebody close me, I cannot be alone.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "I never sleeped without light.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "I can be five minute or 10 minute in home, but if somebody's not here, I open the door and I going out.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And if I-- if I-- you know, sometimes I am very tired.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I sleep five minute on the sofa, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I don't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I sleep like this.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "After five minute, I all time-- where is my sister?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Where are my husband?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Where is my children?",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I looking for them, all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "If my children going somewhere, and they don't come in the time, I am nervous.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Or my, my husband is going somewhere, I am nervous right away.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "If I am going to doctor or somewhere, I never go alone.",
      "word_count": 12
    }
  ],
