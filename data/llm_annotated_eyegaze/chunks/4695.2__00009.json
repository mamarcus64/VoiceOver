  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But in the side roads, they was afraid still to come in.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Then I meet a man.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I saw was very nice dress, a cultured man.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And we start talking before.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "We go to a farmer.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "He give us something to take off at least a half uniform and to be half in civil and half in uniform.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And I talk with him.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "And he tell me he run [INAUDIBLE] city.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "He is professor [NON-ENGLISH] from [NON-ENGLISH] university-- from historical Krakow University, not-- a Christian.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And we were talking.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We are talking.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Then he ask me, tell me, who are you?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Be honest with me.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I tell him, I am Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Then he tell me, you know, the best way go on the path with the Russian occupied, because you know what the German are doing every day, if you are Jewish.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "OK, I didn't know till you tell me.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Save your life.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Go there.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And then you will see what is what.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I'm rector of a university from historical university from Krakow.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "But this is the true safe.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Then we decided where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Dimenstein tell me like that-- his wife is supposed to give birth in this time.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Then he will go back.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "What will be happen this happen to him?",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He will go back.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The other, Polivoda, and tell me, you know, Ignac, I believe in you, what you will do, I will do it.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "OK, let's go.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And decide to east Poland toward the Russian occupied.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Now it's take time to walk.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "You see, we walk only-- we was hiding from the-- not go on the highways, but only on the side roads by the farmers.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And then I come to a place.",
      "word_count": 7
