{
  "stem": "15900.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He was working.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "He was working, he made a salary, but he would not take anything--",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "--out from the factory.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "But-- oh, his money that he made wasn't enough to--",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "He made-- he made for a month's money he could spend for a day on food and [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I stayed with my brother there till the-- till the-- the war was almost over.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I-- and I went back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I went back to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "The first thing I-- I landed in Lwow.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No, no, 1944, the end of '44, I went back from Samarkand to Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I had a ticket.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I had money.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I bought a ticket and I went back to Blonie.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I came back there from the border.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I took a train and I went to Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And the Polacks saw me in Warsaw, they saw a ghost.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "You're alive?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "How'd you survive?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I know them--",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "--my friends.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They-- they were thinking I went to the oven with my brother from the Warsaw ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They don't know I was a prisoner in Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And they said, hey, you're alive?",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And-- and I meant to my town, to Blonie.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Poles, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I went to-- to-- to-- to my city, and I-- and I got the news of what they did to the family, what they-- how they took them to the ghetto in Warsaw and how they died and everything.",
      "word_count": 39
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The house where I used to live, was somebody else there.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But I was friendly with the priest in Poland, where family was very, very-- I used to-- we are like my friends.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And I said, I'm going to the church and see the priest, talk to him what happened to my family, [? your ?] family.",
      "word_count": 24
    }
  ],
