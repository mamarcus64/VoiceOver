  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The people who were accused were found guilty to hang.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "But most of them were not hanged.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And then very-- I mean, huge number of those who were involved directly in the killing were not accused.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And on the ally's side, people who-- who should have stood, too, [? there, ?] [? too, ?] Mr.-- [PAUSES FOR 5 SECONDS] what's his name?",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "In the state department.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I can't recall the name right now.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And the whole state department organized-- organized-- they were responsible, together with the Germans, who were responsible.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "The Germans put the house afire, and the state department organized the blockade of Europe.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "The conference in-- in Evian, which was hold supposedly in order to help the-- the poor people-- this is--",
      "word_count": 19
    }
  ],
