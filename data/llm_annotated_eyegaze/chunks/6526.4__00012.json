{
  "stem": "6526.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 35,
      "text": "[PAUSES FOR 5 SECONDS] It was a new life.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 36,
      "text": "We came to-- we were hungry.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 37,
      "text": "We, we had a pail.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 38,
      "text": "We went into German houses.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 39,
      "text": "I had the uniform, the striped uniform I want to get rid of.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 40,
      "text": "I went into a German house because the Germans run away because the Russians came forward.",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 41,
      "text": "They were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 42,
      "text": "And I got a jacket from a German organization.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 43,
      "text": "It's called TOD.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 44,
      "text": "T-O-D.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 45,
      "text": "The TOD Organization, they were supplying labor.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 46,
      "text": "They were a labor organization supplying the Germans with technical things.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 47,
      "text": "And they had a special uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 48,
      "text": "As a matter of fact, the picture that I made, my first picture on the liberation, I have-- had that in the-- in that jacket.",
      "word_count": 25
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 49,
      "text": "And I went into the house.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 50,
      "text": "I got myself a towel, one or two shirts, some underwear, whatever they had leftover because whether it fit or didn't fit, it [INAUDIBLE] fit me right.",
      "word_count": 27
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 51,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And we started to go-- to go home, to go to Poland, to Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And there, there was a train.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "We asked where the train was going.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "The train was going towards Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "The train was going to Warsaw, and we went in-- went into the train, and they took us up to Warsaw.",
      "word_count": 21
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "The train.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, but who?",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Who?",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "The Russians?",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No, it was already-- the Poles were already-- the Russians and the Poles.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And we came with the train towards Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Warsaw was bombed.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't, couldn't go-- [INAUDIBLE] was one, one-- the west side of Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "I knew Warsaw well, like I know New York because from before the war.",
      "word_count": 14
    }
  ],
