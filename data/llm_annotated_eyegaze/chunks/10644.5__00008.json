  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Now, the new devil is not the devil.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "It's the doctor.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "When every woman delivers an abnormal child, the doctor's responsible.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "And I said when I saw this, and I was hit with this, I said, that's enough.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "This nonsense I don't want to put up with anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "And I'm sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "It was on my 80th birthday on November 1, 1887--",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "1987.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I retired.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In New York.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "It is not-- 50 years.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "My second wife.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "My second wife, shortly, will say, in '67, she was officially 49, but I know that she made herself younger, because after liberation she didn't have any papers.",
      "word_count": 28
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "She could say, I'm born on this day and this day.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And she's 53-- got a severe heart attack.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "In 10 minutes.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "In New York, on West End Avenue.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Two-- two sons.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Andrew Mark Klebanow.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "He was born in America at Mt.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Sinai where I work.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "That was a very, very big problem.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I was having-- I had at that time an excellent practice.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I had to bring-- you know, I had to-- it was a problem.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "One son was 17 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "The other was 13 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "So it was not babies.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "They were already grown up, that to manage them, yes, it was a hard time.",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "One was a failed help, that was the sister of my late wife.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And then, you know, simply-- simply I had the women, you know, working at home [PAUSES FOR 4 SECONDS] every day.",
      "word_count": 21
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "So [? dishonest, ?] they would go to school, and from school, you know, I am still keeping an eye on them.",
      "word_count": 22
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "They didn't need another.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And in 1970, I married my second wife-- my third wife.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Sophie.",
      "word_count": 1
    }
