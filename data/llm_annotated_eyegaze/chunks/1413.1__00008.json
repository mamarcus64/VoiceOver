{
  "stem": "1413.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And as you well know, you might know, that they even became Dutch citizens, because the Netherlands is well known for taking in people who are looking for exile.",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My sister was a men's tie maker.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And one of her bosses-- one-- a German guy-- a German-- I think it was a German guy who-- he had a factory.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And my-- my-- my wife-- my sister worked for him.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "You know, he made-- she made the ties for him.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I, for one, when my sister got sick, I was 11, 12 years old, when I was sitting off the sewing machine.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, but I was too young at the time to get into politics. 16 years, was more thinking about girls than politics.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I had a job.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And when I was taken to the camp, I had no choice.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I was not taken to the camps-- I was sent to the camp, because I did-- I went to the Dutch camp.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I had to go on my own to the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They told me I had to report April the 1st.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I had to leave Amsterdam to go to north of the Netherlands.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And I had to take a train.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "I'll never forget the time.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "The train I needed was April 2.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "And the train left 10 minutes after 7:00 in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Kremboong.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "This was only for men.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Only men.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "All ages.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "All ages, because we had to work there.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And there was only one man named by the same family name, and even though he was not related to me.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "What I did in Kremboong?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "There was so much land there, we had to dig in it and to make it fruitful that it can make seeds, some whatever, corn, potatoes.",
      "word_count": 26
    }
  ],
