{
  "stem": "7781.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So by living in the city, you knew what street to go to school and the time-- the time-- and they let out the schools at a certain time.",
      "word_count": 29
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They let us out at a different time so we should not, you know, meet or something.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "You should not-- you should separate them.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "We always tried to separate ourselves from-- from-- from the Polish kids.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "You mean that the different schools let the children out at different times?",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "When I was in school, we-- we let us out at the different time, because if they-- sometimes same time, there was always a danger of them ganging up and beating up the Jewish kids.",
      "word_count": 35
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "All Jewish kids.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Home.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We strictly-- home, we spoke Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And between our friends, we spoke Yiddish too.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Yiddish was the main language, I would say.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And Polish, too, but we used Yiddish a lot.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Everybody spoke Yiddish.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In the street, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "With friends, relatives, everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "In the marketplace.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "At the workplace.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "You mean in the store, in the shop, in our work?",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we spoke Yiddish among ourselves.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "There was a woodworking shop.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We used to build kitchen cabinets mostly, and-- and all my brothers worked for them.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And then he had some other additional, you know, people, painters and so forth.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Before me, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They all-- yeah, they all went to school.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I don't know exactly, but all went to school.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And then in order to become a journeyman, you had to have so many years technical school.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "So, but I was the youngest, but they were already-- they were journeymen.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "They were craftsmen, which I was not.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Were cabinetmakers.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Five.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Together, with me, five.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "With you, five.",
      "word_count": 3
    }
  ],
