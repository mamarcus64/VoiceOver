  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "On the-- between 19th-- the 19th and 23rd or 25th-- I don't know the date exactly. 19-- [PAUSES FOR 4 SECONDS] in August 1942, between 19th, 19th and 25th, could be 26th, they gathered 17,000 Jews-- one, seven-- [PAUSES FOR 4 SECONDS] at the place called Polonka on the outer periphery of Lutsk and shot them there.",
      "word_count": 57
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They murdered them there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "It's very strange that I can talk about it in 1997, be alive, [PAUSES FOR 3 SECONDS] and I have seen it all, because they came to the, to our ghetto dwelling [PAUSES FOR 5 SECONDS] and they were- they collected all female members.",
      "word_count": 44
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "There were 13 of us-- amongst them, three children, two younger than myself.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I told you before that Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Lampert was not there, because he was initially taken as part of the intelligentsia hostages.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Sorry.",
      "word_count": 5
    }
  ],
