  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And then I went up to the road, and I pointed my friends with the horse and wagon, and we came in.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And they already had dinner on the table.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "That was the big mistake we made, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And we sat down and we ate.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "It was meat and other things.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And most of us got sick after that dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And then Russians came in already.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "I remember one Russian came in with a-- with a-- not an accordion, but those small things that they have, like a [RUSSIAN] they call.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "And he brought in a bottle of vodka, you know, and we were not used to-- to-- to drink that stuff and eat that stuff, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "But they stayed with us there.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "They stayed with us.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "They stayed with us for a few minutes and then they left.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was near Lowenburg.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In East Prussia, in the area of Konigsberg",
      "word_count": 8
    }
  ],
