{
  "stem": "16106.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 342.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He just didn't move.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "[POINTING] And he foamed at his mouth and his eyes were bulging.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And we were standing there-- his daughters, his grandchildren-- helpless, looking at, at-- it was incredible!",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And Mom said, the third time she's calling Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Kroneberg, she is still out for lunch.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "So we had to line up with the others in the yard and waited to be transported wherever they transported us.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "We didn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "They transported us in those days, and I remember, on trucks.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There-- we were over-- listen, we were 11,000, 12,000 Jews. 4,000 they killed in July.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "The rest they collected, more or less.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Exceptions the one which had passes, which were so important for the war.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Like my Tante Minna who, who, who did clothes for Mrs.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Kroneberg.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And by the way, the German lady's name helped us was Miss Kroneberg.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Oh, we got the same name.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "She was a good one, that was a mean one.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "All right, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Kroneberg had lunch-- the Latvian Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Kroneberg-- and didn't give a damn about us.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And we had to line up with the others.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And I remember my teacher, Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Friedlander-- [POINTING] my English teacher Miss Friedlander-- Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Friedler.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "Then she was married to Professor [?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "Lang-- ?] was standing in front of me.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And I said to her, do you know what, Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Friedlander?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "When we are going where we are going, let's talk only English.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "By that time we're out of there, I will speak English beautifully and go straight to America, have a house with a, with a white picket fence and marry Mickey Rooney, probably.",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Possibly.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] She said, ja, my child.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Yes, my child.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Yes, my child.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "She knew.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And then it happened.",
      "word_count": 4
    }
  ],
