{
  "stem": "10359.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Mark Grinims.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I'm from the town called Ostrog, Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My name of father is Zev.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "My mother's name was Eska.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I had one brother and one sister.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My sister was murdered in 1942 in the town Rovno.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And my brother died in the United States of natural causes.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My sister's name was Sonia, and my brother's name was Henry.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, I-- Ostrog in gen-- in general was a very beautiful city, full of meadows, full of lilac trees and apple trees, a lot of grass and rivers.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And it was an idyllic place with no pollution, no noise.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And the people used to come from all over for vacation to Ostrog.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I used to live in a fairly comfortable house, but a big house.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And that's about all I can remember.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "My childhood is uneventful per se because I lived very comfortable.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And I attended private public school.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And I attend private high school.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I had friends from different religion, Jewish and non-Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I got along very well within the community.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I also belonged to the Betar organization, which was a Zionist organization, when I was a teenager up till the age of-- up to the year 1939 until the Soviets came into our town, where all the temples and all the organizations were disband, especially the Jewish ones.",
      "word_count": 48
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And that's about all I can remember of my childhood.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "My, my sister lived at home.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "She went to private high school.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "My brother was studying abroad in Austria, medicine, and then in Sorbonne in Paris.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "To a point, yes-- not orthodox religious, but religious to a point.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I want a temple only on, on major holidays.",
      "word_count": 9
    }
  ],
