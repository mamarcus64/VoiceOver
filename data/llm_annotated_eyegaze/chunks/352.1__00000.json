{
  "stem": "352.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "They spit in my face.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I am not going to say it's raining, ever.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "You call a spade a spade.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "[SPEAKING YIDDISH] Look at you.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name is-- I was born June 1, 1933, in Wloclawek on the Wisla in Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "When I was three months old, I, my family moved to Lodz.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And there I lived till we left Lodz.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Before the war, my name was [?",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Bronja ?] Kenig.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We, I lived with my mother and father and a sister.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "My father's family, they were 10 brothers and two sisters.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Only one, only one brothers, two brothers survived.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They are very old.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "They are now in New York.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "The eight brothers, including my, my father, and the two sisters, and the entire family was wiped out.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "They all lived in Kutno and in Lodz.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "My mother's family, they were three sisters and four brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "My mother's maiden name was [?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "Eiche ?].",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Nobody survived.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "The entire family was wiped out.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "There were the-- my mom was born in [POLISH], next, not too far from Lodz.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "Her brothers and sisters lived in Lodz.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "Nobody survived.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "There's nobody.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "We were a big family.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "And I don't remember too much from before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "It's just, I really don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "I know that we lived in, in the center of Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "And my mom was a designer.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "Here, she would be called a designer.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And she was an excellent seamstress.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "My dad was a businessman.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "And I guess that we had a factory on, in Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "There is not too much that I remember right before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "But when, when the war started in September, 1939, I know-- I remember that they were talking there is a war.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "And the Germans are coming.",
      "word_count": 5
    }
  ],
