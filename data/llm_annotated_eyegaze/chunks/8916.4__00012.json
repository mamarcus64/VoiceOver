  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 13,
      "text": "But in the end, they didn't win the war that they wanted to win.",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 14,
      "text": "They actually lost that, the spiritual, the-- the people's spirit.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 15,
      "text": "As hard as it was in-- in ghetto, I used to be able to-- there was a little yard and they'd put some chairs up there and tables.",
      "word_count": 28
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 16,
      "text": "And they had a cabaret, a stage production.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 17,
      "text": "You know, people were doing stage work.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 18,
      "text": "And I used to chin myself up on the back of the wall to see what they were doing.",
      "word_count": 19
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 19,
      "text": "And there'd be a stand up comedian telling jokes, sad jokes, you know, kind of gallows type, but nevertheless, it was-- it was going on all the time.",
      "word_count": 28
    }
