  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "Then they told me that the Jewish agency in Rome, from Palestine, where they were fighting alongside the British, I should go there, because they're making Aliyah Bet transports, you know, illegally to Palestine.",
      "word_count": 34
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "There I was seven weeks, and nothing doing.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was looking for her.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I went to the Jewish agency, to the headquarters.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And they asked me right away, what is her name?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I told her her maiden name, but how should I know?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She's supposed to be married to a Greek druggist, Jewish druggist, also a former inmate in the concentration camp.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So I lost track.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I never found her.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I wrote to the Red Cross in Switzerland, and nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Ghiselle.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The end of the-- you're finished?",
      "word_count": 6
    }
  ],
