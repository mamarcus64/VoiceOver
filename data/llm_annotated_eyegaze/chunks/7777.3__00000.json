{
  "stem": "7777.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "When we saw the door open up, and the gate-- this was over there a gate-- and this coming in a Ger-- a Gestapo, and some Ukrainian police.",
      "word_count": 28
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I said to the-- my friend, maybe we will run away.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They said there's no time to run away.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "They was over there.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And I ran to a-- in a little wood.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "It was over there, not far.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- I was over there about two, three hours.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "This was about 12 o'clock.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "Well, I walked back where the place is-- but-- but this place was over there a home, not far, some private people was it.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I went in this place.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And they have over there-- they bring in wood from the-- with the horses and the wagons.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "I help this to take out the wood, to put it together, to take it apart.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "It was over there a Gentile-- a Gentile what he worked over there, a carpenter.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "He tell me-- he told me, hide it.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "If not, you get killed.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "Because he saw the Gestapo with this-- they come over there to look again for people.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "Maybe somebody saw me over there-- they come.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I went in, in a shed.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "There was a couple cars over there.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I was hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I was over there sitting till it gets dark.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "When it get dark, I come out and I sit down over there, over at the bench.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And the lady come out.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I ask her, maybe you can give me a little bit water?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I don't have water.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I don't eat a whole day.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "She bring me out a little bit water and a piece of bread.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I ate it up.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And I'm sitting on the bench.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Her husband was working in the city hall, the [NON-ENGLISH].",
      "word_count": 10
    }
  ],
