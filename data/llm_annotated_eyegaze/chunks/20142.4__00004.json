  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And October, end of October they sent us to Lublin.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "They ran out of material, so they didn't have any work for us in a camp.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they took these people who they considered a qualified workforce, and they sent us to the munition factory in Lublin and-- and in the aircraft factory in Lublin.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Very in the initial stages.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They were already experimenting with the crematoriums, and many of the Russian soldiers, were-- the POWs were dying of malnutrition, but they were trying to cremate them.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And that's where the crematorium started to function.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "There was a very specific smell when they were using a crematorium that can't be described by a human being.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The smell of burning flesh [PAUSES FOR 5 SECONDS] that could cause many unpleasant feelings of nausea and [PAUSES FOR 3 SECONDS] causing a trauma.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] We knew what was going on, because where we were coming to receive the food in line, the kapos would say, if you won't behave, you will go like them, and pointing out with their face to-- to the chimneys of the crematorium.",
      "word_count": 47
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And we knew that they meant what they said.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "There were no-- a kapo was actually [INAUDIBLE] police, but this was people who were chosen by the Germans to conduct certain functions for administrative purposes of controlling people and, if necessary, beating them up to a point of no return.",
      "word_count": 41
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Then we-- while I was working in the [INAUDIBLE] group that I went to work with in Lublin was coming daily back and forth.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Working with other groups.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And there were German [PAUSES FOR 3 SECONDS] in uniform who were erecting this barrack.",
      "word_count": 15
    }
  ],
