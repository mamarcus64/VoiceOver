{
  "stem": "17515.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.1,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "He was-- before the war he was a guard in a prison, in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "When I get into Poland, he speak beautiful German.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "Very tall man, young man.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "He work the-- with the officers-- [PAUSES FOR 3 SECONDS] --pants, officer's boots.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Because I know why.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "He-- he-- he killed so many Polish people.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "He was nice to us.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I believe Kowiecko, Kowiecko.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I have to-- to-- I'm going to speak to a friend of mine.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "He knew about it.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And he tried-- he tried to run away.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "That was after liberation.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And we caught him on the highway.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And we kill him.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "Not me, my-- a friend of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Also that was, I believe, early springtime.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "A couple days.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Because there had been-- there had been-- there had been plenty [INAUDIBLE] at Gusen I, Gusen II.",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I stayed to Gusen I, Gusen II till liberation night in '45, 5:00-- 5:00 PM.",
      "word_count": 15
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "That was, I believe, May 5, exactly, three 5's, 1945. 5:00 PM.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I been-- I been all kind of work.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "We pick up the dead people, deliver on the-- on the roll.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And-- and they call them Wasserwaage, pick up the dead and bring them to crematorium.",
      "word_count": 15
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "So you carried these people--",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Wasserleitung, [GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Barrack-- building the barracks.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Wasserleitung I made there-- [PAUSES FOR 3 SECONDS] --like a fresh water canal.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Wasserleitung.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I work on all kind of jobs.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Physical labor, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "First, the-- the army.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "There was army, you know, Eisenhower.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] very short.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And now army, US Army pulled out.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "Russian Army come in.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "There was another shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "A Russian-- a Russian officer shooting a prisoner.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "A Russian prisoner told them and then that prisoner also with him, this and that, and get shot on the spot.",
      "word_count": 21
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
