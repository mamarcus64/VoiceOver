  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "I asked my friend, kill it and cook it that I should give for Hannah to eat some soup.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Look how sick she is.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And the Germans said to me that I stole from them the chicken.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "I wasn't afraid from them that time at all, because the Americans were there.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So-- and I fed my sister, spoon by spoon, she should eat something.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And when I met my sister, she was, her hair was all full of-- not lice, not living lice, the dead lice.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And I said, Hannah, how come?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "What happened to you that you look like that?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "She says to me, they put on me lice to see how much they can [INAUDIBLE] more.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "How many lice would be born on me.",
      "word_count": 8
    }
  ],
