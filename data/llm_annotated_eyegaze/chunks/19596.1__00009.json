{
  "stem": "19596.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 119.3,
  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "They gave us sandwiches and coffee in the nighttime, and blankets.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "And they comfort us.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "There were about 200, 300 [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "Families.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "And then children who had no families, they were adopted to other Jewish families.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "Took them in the cars and took them home.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "My-- my uncle was there.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "He took me home.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "It was a bit strange.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "I hardly know my uncle.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Almost like a stranger.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "He knew me when I was little [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "It's my uncle and my auntie.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Not at that stage.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And he had his own house there and his own office.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "He was well off.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "He was in-- in electrical and electronic, you know, import.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "And it was a nice house.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "And I had a room on the top, on the rooftop.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "And I started to go to school.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I went to a technical school, a purely technical school.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "But I couldn't speak French.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So I had to learn very fast French, and I learned it fast.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And I was going to school then.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "And I-- again, I had a school cap on and things like that.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "I started all over again.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "I made a few good friends.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "One was very, very wealthy.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "He called himself Bernard.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 9,
      "text": "And he was one of the wealthy Jews in-- in Brussels.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 10,
      "text": "And I went to jazz bands and things like that.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 11,
      "text": "You know, I started to get interested in this, and start to get interested in girls, and dancing, and things like that.",
      "word_count": 22
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 12,
      "text": "And I missed my parents terribly.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they wrote.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "They wrote.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they were writing every week.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, yeah.",
      "word_count": 3
    }
  ],
