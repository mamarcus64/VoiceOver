{
  "stem": "8947.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "She said, Magda-- and you know she survived?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "And my mother, when I-- we lived in Israel for nine years, and my mother was living in Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "At that time, we were all to United States.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And she said, you know, [PAUSES FOR 3 SECONDS] this girl-- you know, my mother was at the shopping window, you know, and we knew this girl for many years.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And suddenly she said, Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Moses, Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Moses.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And she was the one.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And she told my mother about that.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "But she-- I have some-- this is just a few incidents.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I have [INAUDIBLE] the way I found my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "You know, there are things in my life that I truly believe that you have to have hope and faith.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And you have-- you can-- you should never give up.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "In the most adverse situation, you should say, somehow, I am going to make it, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "You have to be a fighter, in other words.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You have to be a fighter in adverse situations.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "You have to be a fighter in your normal life.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And you have to fight for the things that are important for you.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "My life was important for me.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And my father told me, when I was a little girl, you have to fight for the things and make sacrifices for the things that are important for you.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I was liberated on April 15th, 1945.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was in-- see, it took me three-- three months to be able to walk.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And they were wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They erected hospitals.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They accommodated us in the SS quarters and they became our living quarters.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It's a long story.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It took me three months to wobble.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And then we were disinfected.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "We-- we were quarantined because the typhus was raging.",
      "word_count": 9
    }
  ],
