{
  "stem": "21978.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And because of student of engineering, he has been given a job, a extra job, to work on washing machines, automatic-- not automatic-- big washing machines in the-- industrial washing machine in the orphanage.",
      "word_count": 34
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And that was my first husband.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "We met, there.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "We didn't work together, because we have been in the orphanage itself with the children, and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "But he was working in the Waschraum, it was called.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And we met.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "We fell in love.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "And his friends-- his friend-- he had a friend.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "And he-- she was sent also to Litzmannstadt with the same transport as my parents were.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "And that started our friendship.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And then we fell in love.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "And we didn't want to be separated.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "So if we got married.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "We were-- I was only 18 then.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Egon.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Egon, E-G-O-N, Kunwalder, K-U-N-W-A-L-D-E-R-- Kunwalder.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I was not able to get married without a permission of parents.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But at that time, my uncle was living still in Prague.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "So he gave the permission that I can marry.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I was not of age.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And Egon's parents, they also were living in Prague.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And we were married at a registry.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "The problem was that it was not a real marriage-- not as such, as you would think now.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I didn't have a white dress.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I didn't have flowers.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "I had a black dress-- black suit-- which was made out of a dinner suit of somebody-- and no flowers and no photographer.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "My sister even wasn't allowed to come to the wedding, because she has been working.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And it was no fuss wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And-- but I was married.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And we were not separated afterwards.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "We were staying together.",
      "word_count": 4
    }
  ],
