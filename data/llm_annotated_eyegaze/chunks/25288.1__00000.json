{
  "stem": "25288.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good morning.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "name is Morton Fuchs.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "F-U-C-H-S.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name was Miksa, M-I-K-S-A.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't have.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is in June 30, 1911.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, 85 and a half.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In June I'm going to be 86.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Tokaj, a little town in the Hungary.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It's 250 kilometer from Budapest to east.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "T-O-K-A-J.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, in my family, I'm the only one who survived.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, my brother, well, he was born in 1901.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And with wife and two children, he was deported and he didn't survive, none of them.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My father was Hinrik.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He was Hungarian.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "H-I-N-R-I-K.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, with the whole family it was kind of warm family.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "We had a good relationship with our parents, with my brother and sister.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We had a good, warm relationship.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, he had a general store for 47 years, and the whole family worked in the store.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And after 47 years, he retired.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And my brother and myself, we will continue during the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was a very religious man.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 5 SECONDS] he was very friendly to everybody.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And he tried to help everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Many people came to him for advice or for help.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And he was available to everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "He was a very good man.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Brought ?] [? respect ?] all over in the city.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And my mother was Ida, I-D-A.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Last name?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Last name was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "She was a daughter of a rabbi.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, she was a fine person, nice person.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And friendly all the time, smiled all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And helped the children and everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So it's a very, very friendly good person, my mother.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "We were four, two girl and two boy.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My older sister was Ilona.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Then my brother, Vilmos-- William.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "My younger sister was Miriam.",
      "word_count": 5
    }
  ],
