{
  "stem": "979.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "How much energy are you going to use in your body when this came, and there was no food in your stomach?",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They-- my sister went out of her mind.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "She was-- what she did-- the British had  come in.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They were so confused at what they saw.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "They then came in.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They gave other people to give us the food.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They didn't know where to go, where to start first with what they  saw.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So they brought us little cans of food inside.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They started giving it to the block leaders and give them-- before, they didn't come into the block because they had a lot of other work to do.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And inside the cans, there were different things.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "In one can, it was, like, dry coffee, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And so you put water, and you make it, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "She, [PAUSES FOR 3 SECONDS] she-- my sister, who was so smart, she said, what am I going to do?",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "So she took a piece-- a little of the coffee-- she put in one teaspoon coffee.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And then she took a piece of wood.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "She made the charcoal.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And she put it next to the-- to the stove.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And she, she made it like charcoal.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And she put a little of the coffee in there.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And she says to me-- she says to me-- I wasn't even aware of what was going on.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "She says, open your mouth.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So I didn't-- not because I didn't want to.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "She says, open your mouth, or I'll kill you.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "She says, you're not going to leave me alone in this  world.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "She says, you wanted me to leave.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Now you are going to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And she starts screaming at me.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "The girl say, she was going to kill you.",
      "word_count": 9
    }
  ],
