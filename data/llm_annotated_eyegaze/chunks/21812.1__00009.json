  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "My birthday was late November, but I-- so I was younger than a lot of the kids in my class and almost a year ahead.",
      "word_count": 25
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "And to have that education, which, which was wonderful and I-- was such a big help when I came to this country because it was a foundation that had been laid, which allowed you to, to learn a lot afterwards, and no matter in what language or what.",
      "word_count": 48
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "French, a little bit of French.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "We were beginning to learn French.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And then, of course, Hebrew, which I, you know, knew fairly well.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "You mentioned earlier that one of your teachers was a Nazi, was wearing a swastika.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "For Instance, the doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "There was a doctor in my grandmother's house who we knew was a Nazi, even when it was illegal to be a Nazi.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "He, after the war, committed suicide, from what I  had heard.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And there were other people, yes, whom you knew who were Nazis.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Austria was social democracy at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Until about '37, maybe. '36 or '37.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "And then, fascist-- sort of a semo-fascist government came in.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "But yes, there were a lot of Nazis around.",
      "word_count": 9
    }
  ],
