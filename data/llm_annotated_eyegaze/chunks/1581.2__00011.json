  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "It was very crowded and uncomfortable.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And we were in this train for three days.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And then we arrived in Theresienstadt.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Theresienstadt was-- that was on the 4th of April, 1942.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Theresienstadt was a fortress that Maria Theresa, the empress, Maria Theresa built, with the idea to become a fortress for the weapons that were known in the 18th century.",
      "word_count": 29
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "There were huge, massive walls all around the town.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "There were water-filled moats on the outside.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And there were just three or four gates where you could enter the town.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Of course, all this was wide open before we got in there.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Then it was closed up and became one large jail or, if you want to call, a concentration camp.",
      "word_count": 19
    }
  ],
