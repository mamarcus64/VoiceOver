{
  "stem": "58.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He went and sold it for 5 zlotys-- 5 zlotys was the equivalent to $1.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And he gave it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "He said, you want to go, go.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I took this money, and the next morning I jumped over the fence.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "It was on [NON-ENGLISH]-- if somebody will ever see it, maybe he'll know where it was.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "The city-- the street was-- was-- [PAUSES FOR 4 SECONDS] what was the street?",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH]-- it was separated.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "In the middle of the street, one was the ghetto on one side.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And the other half was on the Polish side.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And I jumped over the fence.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was lucky that there was nobody around, because there was an order, if you deliver a Jew, you're going to get a kilo of sugar-- two and a half pounds of sugar.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "There was nobody there, and-- and another boy talked down, and he said he also wants to go from the same city.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He wants to go, so, OK, we both went.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And we marched close to the road, we shouldn't get lost, to the main road.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And we walked in one day-- actually, two days, we made it to Grojec.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We slept over-- I don't remember where we slept over the night.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "We came to Grojec.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He lived in a-- in a street that there were two brothers-- blacksmiths.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And they were communists.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "When we came there, they saw us.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "They said, look-- you know me.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I'm not going to take you to the Germans, but if anybody else sees you here, it wouldn't take them even two seconds to take you to the Germans.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "They gave us some bread and tell us, march on.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We marched on.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It took us another day to get to Bialobrzegi.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I had a-- two cousins in Bialobrzegi.",
      "word_count": 7
    }
  ],
