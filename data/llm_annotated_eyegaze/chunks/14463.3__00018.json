  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 18,
      "text": "And I-- by chance, I grabbed a half a brick and I threw it to one, and I hit the one in the head.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 19,
      "text": "And they run away.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 20,
      "text": "And after that night, next day, I went and bought myself a flick knife.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 21,
      "text": "And I had that flick knife, with my father's letters in here, and the flick knife in here, right through the war, even in Australia, until my uncle found it and threw it out.",
      "word_count": 34
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 22,
      "text": "Pity-- my wife says a pity.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 23,
      "text": "It would have been a terrific memorabilia.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 24,
      "text": "But I had a knife in my pocket all through the war, right, from that point on.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 25,
      "text": "And they run away.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 26,
      "text": "And then, soon after, we found that place in the city.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 27,
      "text": "You know, my uncle found it and we moved to the city.",
      "word_count": 12
    }
  ],
