  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And he was driving.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And pamphlets had been thrown from the planes.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "It was the Americans saying, if you put a flag on your-- on the top of your truck that the-- you will not be bombed.",
      "word_count": 25
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "We'll try and avoid bombing you.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "But obviously, it didn't work because he was bombed.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "We were not bombed on the building itself.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "But while he was on the road, he was-- he, he barely survived.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he did, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "So I remember bombings around us and leaflets being dropped.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And at some point in time, we started seeing the Germans retreating.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And I assume at that point, it was when it was getting near the end of the war.",
      "word_count": 22
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And the-- it lasted for seven days and seven nights.",
      "word_count": 10
    }
  ],
