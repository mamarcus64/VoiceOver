{
  "stem": "6076.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "When I remember-- when I was a little girl, so many people fainted with all the good foods on Yom Kippur.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They couldn't stand a day to fast.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Here with one slice of bread, you know, I ate the night before, and I fasted for so many hours.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "It didn't bother me.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "It bothered me.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "But somehow, I survived.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And I didn't faint.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And I worked the whole day.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I just envy my own strength.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I-- on Simchat Torah day, my meister walked over to me.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And he says, Miss Warszauer, Skarzysko was evacuated. 11 o'clock, 11 o'clock, 11 o'clock they came in to our [INAUDIBLE], 11 o'clock on Simchat Torah, [INAUDIBLE] Skarzysko was evacuated again.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "These numbers, these dates, always, you now, the same time.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "I cried.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "I didn't want to show him that I'm crying.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "I, I felt that I have temperature.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "I felt my head is coming off.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "I felt like the same feeling like I had typhus.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "My whole body shook up.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "I'm walking.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "We walk.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "We walk in five in a row.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "We walk, you know, few hundred girls walking from the fac-- from the work, go back to the, to the camp.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "While I walk in, I says, now, it's my last chance.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "I don't have anymore food sending from my home.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "I lost my parents.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And perhaps [?",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "Moishele ?] and Shmulek is gone with my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "I am going to be alone in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "I have no money like parents gave them to trade with the Poles to bring me a piece of bread or two.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "I have no possibility to survive.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And I says, I didn't think about surviving anymore, tell you the truth.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "I'm walking.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "I'm walking with the girls.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "I'm thinking.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "I'm thinking.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "I'm thinking.",
      "word_count": 2
    }
  ],
