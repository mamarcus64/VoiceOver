{
  "stem": "9702.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "It took a few hours, and they left.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "They left.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "My father was up in hiding there in the straw.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "And I was-- and he didn't know what's happening to me.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "Anyhow, I survived that too.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "Then, while we were at that last place where my husband met us, it was-- we had to find a new place.",
      "word_count": 22
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "My father went to look for a place.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "And I'm sitting.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "There is no place to hide.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "Only on the attic I'm sitting.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Meantime, I hear the Ukrainian Banderovcis are coming in.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And a lot downstairs-- and I hear them talking.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I hear one of them is trying to go up to the barn, to the attics.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And she says to, where are you going?",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "We don't have no [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Don't go.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "When I heard that, the roof was from straw.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I don't know where I got the [NON-ENGLISH], the strength.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I pushed up straws.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And I jumped down from the roof.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And it was, like, in the back fields.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] I went back where the school, and that was-- and the cemetery.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And I laid on that cemetery for hours.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Then, then I heard it was quiet.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "So I-- Moshe told me, my late husband told me, where he's in hiding, by whom.",
      "word_count": 16
    }
  ],
