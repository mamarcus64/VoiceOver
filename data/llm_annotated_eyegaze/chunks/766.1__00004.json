{
  "stem": "766.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "The teacher, I think, was more afraid of us than we of her.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That time wasn't so much importance, in our school, at least, because this wasn't especially-- they didn't brainwash us, but the atmosphere was they didn't pay so much attention to that.",
      "word_count": 31
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "No prayer, no nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No religious.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, it wasn't by selections.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Was people who could pay, and there were-- I think there were a few who got some scholarship paid less if they showed that they can't afford it.",
      "word_count": 28
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But I wasn't in this category.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "My parents never asked for a reduction in the fee.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Until I finished.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I entered at the age of eight, and I finished at the age of 17, the gymnasium.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And this what we call to get a Matura, yeah.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I graduated, I always knew that I want to do more education.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So I wanted to study medicine, but as my parents were of Russian origin, they themselves were not Polish citizens.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't yet, and 17, I was considered a minor.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Of course, I was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "The street?",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I-- I was a boarder with another classmate of mine.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Together, we went.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Classmate from school.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "She went-- she remained and finished over there in Krakow.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I stayed only one year, and I didn't want to go back, by no means, for many reasons.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I wasn't so mature that I knew exact.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I didn't want to be-- they-- they-- the Poles, they were too blonde for me and too non-Jewish, and I-- they didn't do to me anything wrong.",
      "word_count": 27
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "No, actually, excuse me, they did a lot of wrong.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "Not to me, personally.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I didn't want to stay anymore in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "I wanted to go.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    }
  ],
