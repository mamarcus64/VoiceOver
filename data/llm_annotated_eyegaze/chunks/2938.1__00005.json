{
  "stem": "2938.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "After a concert, they used to attack us.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "Where the wave of anti-Semite started up.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "A wave, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "Used to come and used to go.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "We-- we had feeling when starts, when ends.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No, mostly in the city section.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "In the park of the city.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Going out from a movie.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "Going home from a soccer game.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "Going home from a parade.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't too happy.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "But what can you do?",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "You have to take the way it came.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Certainly.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "There is no other way.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Certainly, we used to win.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We never gave up.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "We were strong, united.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "We fought back as much as we could.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Certainly we've been trying.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Sure, we've been trying, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "Usually, people in the city used to get along fine-- Jews, Gentile used to get very fine.",
      "word_count": 17
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "But used to the anti-Semitic groups, who used to stir up the trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "But the government didn't support it.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "The government always was neutral.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "The government never support.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Well, a little bit, the church used to add a little, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "The church bear the most responsibility of the anti-Semitic outbreaks.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Because the church used to spread rumors before every holiday.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "They used to spread out rumors against the Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "And the ignorant Pollacks used to take it to their heart, and used to attack the Jews.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Mostly before Easter, came out rumors that the Jews kidnap a Christian child, and killed it, and used the blood to bake matzohs for Easter, for Pesach.",
      "word_count": 27
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And this lead to pogroms.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "Every Easter, we used to have a pogrom.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "The Pollacks used to tell us.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "The Polish people were afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "They used to tell us, why did you kidnap the Christian child to use the blood?",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "They were not ashamed.",
      "word_count": 4
    }
  ],
