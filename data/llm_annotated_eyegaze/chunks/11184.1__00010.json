  "sentences_input": [
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 1,
      "text": "People were dying.",
      "word_count": 3
    },
    {
      "segment_idx": 212,
      "sentence_idx_in_seg": 2,
      "text": "Whole families were dying out.",
      "word_count": 5
    },
    {
      "segment_idx": 213,
      "sentence_idx_in_seg": 0,
      "text": "Malnutrition, right.",
      "word_count": 2
    },
    {
      "segment_idx": 214,
      "sentence_idx_in_seg": 0,
      "text": "The cards-- in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 214,
      "sentence_idx_in_seg": 1,
      "text": "In the ghetto-- we're in the ghetto, we got cards.",
      "word_count": 10
    },
    {
      "segment_idx": 214,
      "sentence_idx_in_seg": 2,
      "text": "And we could only--",
      "word_count": 4
    },
    {
      "segment_idx": 215,
      "sentence_idx_in_seg": 0,
      "text": "Committee would assign-- they were assigned, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 215,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, the-- I don't remember who brought it in, but I know through--",
      "word_count": 13
    },
    {
      "segment_idx": 216,
      "sentence_idx_in_seg": 0,
      "text": "My mother was doing all that, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 216,
      "sentence_idx_in_seg": 1,
      "text": "So I, I am not so familiar with.",
      "word_count": 8
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 0,
      "text": "I know there was the card, you know, that we could get a bread or half a bread or, or some potatoes or horse meat.",
      "word_count": 25
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 1,
      "text": "At that time-- was still horse meat.",
      "word_count": 7
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 2,
      "text": "And later on, there was no horse meat.",
      "word_count": 8
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 3,
      "text": "And there was nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 217,
      "sentence_idx_in_seg": 4,
      "text": "And there were peelings--",
      "word_count": 4
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 0,
      "text": "--peelings, potato peelings.",
      "word_count": 3
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 1,
      "text": "Now, who was going to eat potato peelings?",
      "word_count": 8
    },
    {
      "segment_idx": 218,
      "sentence_idx_in_seg": 2,
      "text": "But later on, we're waiting for the potato peelings.",
      "word_count": 9
    },
    {
      "segment_idx": 219,
      "sentence_idx_in_seg": 0,
      "text": "I think a family.",
      "word_count": 4
    },
    {
      "segment_idx": 220,
      "sentence_idx_in_seg": 0,
      "text": "I think a family, yeah.",
      "word_count": 5
    }
  ],
