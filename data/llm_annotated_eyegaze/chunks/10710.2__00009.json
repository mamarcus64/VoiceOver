{
  "stem": "10710.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "And they had loudspeakers.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "You know what a loudspeaker is.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "And they, they was playing songs.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "They played German songs, [GERMAN] It's all over.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "Everything is finished.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "That's how the Jews had to go to their graves.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "They were standing in front of the graves.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "And each one was shot.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And they fall, one after the other.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "And then we had to come back, and we put-- to cover them up.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "And sometimes the ground was still moving.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "Because the people were not completely dead.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "This, this was the first camp that we were.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "It was the most horrible camp that I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "They took from our people, they took about-- from the 100 people, about 30 people.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "They shot them.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 31,
      "text": "And at home, we did-- they didn't know who was alive, who was not alive.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 32,
      "text": "So We had to make a list of the people who are alive.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 33,
      "text": "And then the family, they saw who was-- and there were women with five, six children when their husbands died.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 34,
      "text": "And then they shot them for-- just because they didn't like their faces or something.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "There were-- almost every week, there were [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "They were shooting people.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They brought people from other towns.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And they had fun.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They told them to get undressed, the women.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "When they found somebody on, on-- hidden, Jews were hidden, they put them in, in the basement in the-- in the-- it was like a jail.",
      "word_count": 26
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they kept them there for a day or two.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And then they, they shoot them all.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "They put them all in the, in the, in the graves.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "There are-- there are graves in Rabka.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "A friend of mine was just there two years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "He brought me pictures.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "They have some kind of monuments.",
      "word_count": 6
    }
  ],
