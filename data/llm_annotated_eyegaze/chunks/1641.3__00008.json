{
  "stem": "1641.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "You are due to go out to work next week when your leg will get a bit better.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "With the bandage on it's all right.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "They want you to go back to work, but I won't let you go back to work.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I'll see to it that you get a job right here in this building-- in this building.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And the next morning he says, your job will be with a different uniform.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "You get a-- a thing on your-- insignia.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "You are going to be Leichentrager and in charge of the [GERMAN], which is the morgue-- the-- the morgue.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And if anybody is beaten to death or collapses, dies, you and three others, you have to run there with your stretcher, pick up the dead body, bring it here.",
      "word_count": 30
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Take off their clothing, put their clothing into the clothing pool, and put chlorine on them and wash them every two hours so the smell is not too bad.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I got busy with three of my friends.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And on an average day-- that was the basement of the hospital on the concrete floor-- we had maybe 160 men, maybe 70, 80, 90, up to 100 women.",
      "word_count": 29
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We had to put them in alphabetic-- in numerical order.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "The highest number on the right, the lowest number on the left.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Then by 6 o'clock, we close the shop.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "No more admitted that night.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And we had to prepare the typed lists of men-- the following numbers from-- from 1 up to 200,000, and the A category, then the B category, all the numbers for the bookkeeping.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Because they had to book all these people.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "They-- they are out of stock, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "They died.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "So we had to put them in order.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "The-- the reason of death?",
      "word_count": 5
    }
  ],
