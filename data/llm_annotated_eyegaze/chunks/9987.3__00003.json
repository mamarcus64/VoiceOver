{
  "stem": "9987.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They put up a gate on the other side.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And that was supposed to be our place to live.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Now we didn't know anything about what's happening over there.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "We worked all day at that airport.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "At night time, we didn't go back anymore to our house.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And they took us to this ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And there were approximately-- I don't know-- 500, 600 people.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "To-- to put them in-- in five, six houses, 10, 15 in a room.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "People were laying on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "People were laying on boxes, one on top of each other.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "But that was supposed to be our place to live.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "The next day, in the morning, they came.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "They took us to our shop, our former father's shop.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "But we didn't own the shop anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "A Pole that used to work for us, he was given over the shop.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And he became the boss.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "And we had to go to work over there, for the-- to work for the Organisation Todt, not getting paid.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "Brought us in the morning, took us back at nighttime to sleep in-- in-- in the-- in the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Now what happened with the rest of the people that they are standing there?",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Now they were standing there all day.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "August was a very hot day, no food, no water.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "According to what I-- what I heard-- because I was not present at it-- by nighttime, they took them to the railroad station, they loaded them into cattle-- cattle-- the cars.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Train took off to the next station.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They brought other transports, from other little towns all the way around.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "They loaded up the train.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And the train went east.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Now somebody hired a Pole to follow the train, to find out where they are going.",
      "word_count": 16
    }
  ],
