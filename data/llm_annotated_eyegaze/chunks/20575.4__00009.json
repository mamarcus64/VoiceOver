{
  "stem": "20575.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And there he fed us with the pork they were making for the soldiers there, all kinds of, of, of mishmash there.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "But we ate it, you know-- anything we could.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I mean, meanwhile, we had terrible diarrhea.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And we ate this and ate this.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "We were-- we were terrible sick.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "But we had to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "We felt we had to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And then one morning, he, he put us on a-- on a-- what do you call it?",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Again, a, a wagon-- not a car, a truck.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was a truck.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And he put us on a truck with Russian soldiers, women soldiers.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they drove us to some kind of a station.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And from there, we got a train to go to Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And we arrived in Vienna early in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And where the railroad station-- I know the street very well.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "We have been back since.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Now it's a beautiful shopping street.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "But everything was bombed out-- bombed out.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Everything was, like, flattened.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And we walked, and we walked.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And we set into the open store just to rest up.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I had a little bread and things in that satchel that I made in, in, in, in Mauthausen.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And we walked all the way down.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I remember we met somebody that we knew.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And we ask him.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "He said, oh my god.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "Gutie, ?] you and Thea, you came back, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "Where's [?",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Jule? ?] Well, he's not here.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And George?",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where my brother was.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know that he survived.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we went straight in a Jewish hospital on the Malzgasse.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And there we stayed for weeks until we-- me, I recuperated much faster.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And that was the end of our trip from, from Mauthausen.",
      "word_count": 11
    }
  ],
