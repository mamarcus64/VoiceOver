{
  "stem": "15017.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "If this has gone another six months, you would have had to have a colostomy.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But as it is, they operated on me and said, you've got to be very, very clean at any time you have to go to the-- and if you go to my bathroom, you see I have a special rag, because I don't have a bidet.",
      "word_count": 46
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "You came to America when?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "As, as, as soon as I, as soon as I let Henry know-- Henry Abrams was this man's name.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "He was back in America.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "As soon as I let him know that I wanted to come to America, he stood up for me.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And the papers came in for me, bang, bang, bang, even when I was in hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I came out of hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Then I applied for-- to come to America.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I arrived in America September the 10th, 1958, the day before my birthday.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Went to Detroit immediately.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Wait a minute.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "When I went to Detroit, I took a look at this city, me being a big city working-- I thought, where have I come to?",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Oye, no.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I didn't like at all, because it was a big factory town.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I have to get a job.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So Henry says, I'm working at a discount store.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was working for $1.25 an hour.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Because when you're not working, you're spending.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And when you're working, you're earning, never mind what.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I go to work in this place, Halls Discount Store, it was called.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And then I went downtown looking for a job.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And a guy told me that there was a man who sold Selmer instruments-- that he was looking for a salesman.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "The one he got, he didn't like.",
      "word_count": 7
    }
  ],
