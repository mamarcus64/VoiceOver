  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And when I was back in Heidelberg, I sent the money, and-- [PAUSES FOR 6 SECONDS] the first days of '39-- with other words, about four weeks later-- I got my permit to Holland and left in January, five, six, seven, eight, nine-- forgot-- for Holland.",
      "word_count": 46
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I came into a camp by the name [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And that was a camp [PAUSES FOR 3 SECONDS] basically for young scientists from Germany and from Austria who were learning a trade there-- agriculture, gardening, cabinet making, and stuff like that.",
      "word_count": 32
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I did not belong there because I was not a scientist, and I was not preparing to go in an Aliyah-- [INAUDIBLE] to Israel, but they let me in.",
      "word_count": 30
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And that's where I was.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Till [PAUSES FOR 3 SECONDS] May '41.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "With other words, about two years and two months.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "It was actually my college education.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I did not want to do any gardening or any agriculture or any cabinet making.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "I became a night watchman.",
      "word_count": 5
    }
  ],
