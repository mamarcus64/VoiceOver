  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "It was punished to death.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Young.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I was courageous then.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "That took courage, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "Of course, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "I didn't even think that I'm risking something.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "I risked not my life-- [INAUDIBLE] tortured.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "Worse than die-- to die.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "They tortured you to death.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "About six months there.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Work.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "All kind of work, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Remember used to carry cement or something.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Labor, hard labor, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "But we were glad to do-- I didn't [INAUDIBLE] any beatings, you know what I mean?",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "More than Auschwitz because I remember [INAUDIBLE] six months [INAUDIBLE], we didn't have any other income.",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "In Auschwitz we had income.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "My brother used to trade these things.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Somehow he managed.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "But we survived with a portion.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "As I said, we were young.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "Later, elderly people wouldn't be able to survive on this portion.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We had meetings and they told us about the partisans, about the people--",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "With the Underground people.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I think with that men that-- I think [?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Munk. ?] No, in Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "In Dachau we didn't know anything.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know about anything.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "We just knew the war is ending, that the war is-- because their regime was [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We don't know about that.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "You don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Was there a name to that-- [?",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "LB: Munk ?] criticized me.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "He criticized me.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "In that uprising [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "He says why didn't I die with those who were shot?",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] He was a fanatic, you see.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "Why didn't you die?",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "That was revolution-- calls you to die.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "You had to die.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 10,
      "text": "But he didn't die.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I should have told him, why didn't you?",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Why did you survive?",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, then-- no one-- see, everything was changed.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "There was no more sending to the crematoriums.",
      "word_count": 8
    }
  ],
