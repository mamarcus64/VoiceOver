{
  "stem": "21008.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I was considered, according to the Nuremberg laws-- I was called a Geltungsjude.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That means I am considered a Jew because I was brought up in the Jewish religion, of course.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Oh, of--",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "If I-- if my mother wouldn't have been Jewish, and I wouldn't have been brought up Jewish, then I would have been a-- a Mischling first grade, they called this.",
      "word_count": 30
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "What's a Mischling?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I don't even know how to translate it.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But I would not have to wear a star.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I did not want to have to do forced labor.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I would not have to quit school and all this, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And that I was Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "That was more-- that was more--",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "More Jewish than if she hadn't.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "--that-- that-- that her being Jewish did not count.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Only her blood counted.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Her blood was Aryan.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But I was brought up Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And that, of course, brought the hardship onto me.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "A category for everything.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "My father didn't-- wouldn't even have to wear the star then if I would have not been brought up Jewish.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, as I said, my father did all kinds of odd jobs as a salesman.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And his brother had a little business-- a-- a paper-- paper-- how do you call this?",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Oh, god.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Retail-- there is retail and there is--",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Wholesale.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "A little wholesale paper business.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "My father helped there.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And we-- we helped at home.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "He-- he-- he was selling napkins to restaurants.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And-- and they had to be folded.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And my-- and they-- my father brought home packs and packs of unfolded napkins.",
      "word_count": 14
    }
  ],
