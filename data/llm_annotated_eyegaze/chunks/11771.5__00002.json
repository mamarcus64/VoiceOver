  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "Eventually, after half a mile, I came out to a dry field, coming out when I saw in front of me this house that I show you.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "And then, I sleep over [PAUSES FOR 3 SECONDS] in this place.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] In the early morning, I hear people coming closer-- the voice of people coming closer, and closer, and closer towards me.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And that's I find out looking out from the wall that was from the building itself, that was a distance.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "And I could look out.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "The sun [? kind of ?] shining.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "I look out.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "There's two peasants, two farmers, coming with a wagon and a horse, coming towards me.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "And when they coming closing to me, they turning away.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "When I watched him, I observe what they were doing.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "I heard them talking.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "But I find out they came in to catch the fish that was at the man-made [PAUSES FOR 3 SECONDS] water where they used to feed fish.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "And they would then catch them up, put them in the wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "This was a barrel on the wagon where they put the-- catch  of the fish.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 3 SECONDS] After they finished their work, they went away.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "I came-- I go out to the place where the fish are, and I find a sack, an empty sack.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "I put myself-- the sack on myself.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "I make a hole.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "And it was like a-- a dress on me, around my neck, not to be naked.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "But that was so rough, [PAUSES FOR 3 SECONDS] the sack on me, it was bothering me.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "My body was full with wounds.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "It would make me uncomfortable.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "I took them off again.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "I figure I'll wait till the evening.",
      "word_count": 7
    }
  ],
