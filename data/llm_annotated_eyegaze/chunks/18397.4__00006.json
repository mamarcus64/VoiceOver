{
  "stem": "18397.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "He was escaping to-- to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And they catched him.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And they brought him over there, and they hanged him by the feet.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "No, not in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, not in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I think I saw it, when they're they hang the people in-- in Vilna in a place, in the-- not in [?",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Kylis, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "HKP. ?] It was where they fixed-- used to fix the cars.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They used to hang people over there, Jewish, they used to hang, I think.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But I didn't live there.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You know, I went in, maybe [INAUDIBLE], maybe they shoot at me?",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] You got--",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Eight years.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I didn't-- I didn't want to go to America.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "You know, I didn't want to.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Because I had a good business, and I got married.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But I had a-- a letter from my uncle.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I wear [NON-ENGLISH] to me, he looked, you know what [NON-ENGLISH]?",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] He-- he used to-- used to say, I had letters from from my aunt.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "They sent me papers, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I-- maybe at the same time, anyway.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Don't ask me.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was have-- was-- when I-- when I was the leader of the kibbutz, I was thinking of to go to Palestine, you know.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "This was the-- my mission.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We had a big kibbutz.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I was the leader for over there.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And my-- [PAUSES FOR 3 SECONDS] then they liked it.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And all of a sudden, I had a kibbutz, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Everything was all right.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "So these-- these Israelis, you know, the Bricha, send over a guy, he should take it over.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And he start giving orders, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And I wasn't used to it.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Nobody gave me orders before.",
      "word_count": 5
    }
  ],
