  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "By that time, the Russians were pushing them back from the east.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "The Allies were about to land from the west.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "They have been pushed out from North America.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "They have been pushed through Italy, you know, the, the Patton Army has been-- pushed the Germans out of Italy.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "By that time--",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "By that time, Italy, as the major supporter of the Axis, has been-- has opted out, right?",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "So things have changed.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "But we realized that Hitler has got enough stranglehold on, on, on satellite countries like Hungary that we are far from being out of danger.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "OK, Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Angles, just leave it there for the moment.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "We'll change--",
      "word_count": 2
    }
  ],
