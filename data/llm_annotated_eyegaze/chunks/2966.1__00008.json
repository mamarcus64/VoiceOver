  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] After a few days of the Germans in 1939, the Russian army came in and the Germans withdrew to their part of Poland.",
      "word_count": 27
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And we were on the eastern part of Poland, which is actually now Ukraine.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And-- [PAUSES FOR 3 SECONDS] and we were under Russian occupation or whatever you want to call it.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "We were liberated by the Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] When the Russians came in, we had-- [PAUSES FOR 3 SECONDS] actually things improved greatly.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "Because no one was afraid of his life.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] The Jews stayed in their homes.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 3 SECONDS] Things economically were not as good as they should be.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "But if you had enough food-- was nothing the best food-- but you had enough bread, you had enough potatoes.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "You were not hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "And they took away all the big stores, the factories, the shops.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "They-- they requisitioned everything.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "But a few people, very rich ones, or political, were sent to Siberia.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "[PAUSES FOR 3 SECONDS] But the majority of people were left alone.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "Whoever had a business, like my father, they took away his business, and he had to go to work with his hands.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "Which wasn't a tragedy in a way.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "But nobody threatened your life.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "And-- and there was no fear of being killed or beaten or shot.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "If you didn't mix into any politics, they left you alone.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 33,
      "text": "And there was no problem of anything.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 34,
      "text": "We continued school.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 35,
      "text": "[PAUSES FOR 5 SECONDS] And life was going on at a pace that [PAUSES FOR 3 SECONDS] wasn't very, [PAUSES FOR 5 SECONDS] very quick, or-- or-- or we just lived from day to day.",
      "word_count": 35
    }
  ],
