{
  "stem": "22944.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Edith, who was taken to Auschwitz, [PAUSES FOR 3 SECONDS] was caught very quickly after the second day, when we separated.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "You remember, the beginning, we separated.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We went to look for our father, and she was looking to find out information-- what is going on.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And then we got lost, and she probably did not know where we were.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And she went in hiding in a haystack.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "It was summer season.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And she was caught very quickly, I think within 24 hours.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "She had to go out.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And she was taken to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But she herself happened to be-- probably the only one who looked much more older than she was.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Well, how old could she have been?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "She was five years-- she must have been about 14 or 15.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I don't exactly know.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Probably less.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "But she was developed.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And when she was taken to Auschwitz, they were selecting people to go to the right and people going to the left.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And she was very intuitive or very aware.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "When she looked on the left, they all looked a bit older people, with glasses and-- she managed to slip, or somebody gave her a tip.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "It looks like those that are going to the right side look younger and healthier.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I mean, you did not know what it meant, anyway.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Could be that they went to [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "You did not know they're going to go to gas chamber.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "But she went to escape to the other side.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And she was in a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And, unfortunately, Mengele did experiment on her.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And she was very fat, because they put all kind of hormones.",
      "word_count": 12
    }
  ],
