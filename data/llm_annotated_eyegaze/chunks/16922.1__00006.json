{
  "stem": "16922.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "I take you to Warsaw, a Polish girl.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Well, from Rabka, a run by legs through forest.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I came to-- [PAUSES FOR 4 SECONDS] to Cracow, I didn't go.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I went to the train.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Now I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I went to the train.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "And I don't know how they didn't see me.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "But they have black uniforms, the Ukrainians.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I make believe I sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "It was a sitting car, old women around me.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "So I beg her she let me sleep on their arm.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "They didn't wake me.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I didn't speak with no one on the train.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "To Sosnowiec.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "By train.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And when I came to Sosnowiec, they-- I was very dizzy.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I went to a cafeteria there by the train, and I did wrong.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And the man was nice, and said, go out.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "I should go out.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "He said, look out.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "They hang-- I don't know how many-- I don't remember how many.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "They hang the Jew's head there.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "You don't want to hang there.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I went to cafeteria.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't wear a star.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "But my face said.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "In Sosnowiec, I stay mine girlfriend's friends overnight, and I left.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't wait.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And she had broken her wrist.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "She was in Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "She was not in Sosnowiec.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "This was her friends.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "They tell me, look.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "You have to wait maybe a couple weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "Said I couldn't do that.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "Because I didn't know them.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I went to-- back to Cracow to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "By train.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I say whatever will be will be.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I came to Cracow to ghetto, to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "And there was standing a friend, what used to live in our building.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And he said, you're going to sister?",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "I said, where are my sisters?",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "Rega was in Cracow.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "So perfect.",
      "word_count": 2
    }
  ],
