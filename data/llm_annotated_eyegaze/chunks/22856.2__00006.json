{
  "stem": "22856.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And it was a ritual, Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I have still a certificate, a copy of the certificate of marriage, which I arranged after we were repatriated to Poland.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Which means not in the same barrack.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Men were separated, women separated.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "But we had a chance to see each other, especially that my wife was chosen to work in the kitchen, in the administration.",
      "word_count": 23
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "She was accepting the numbers from every barrack, how many soups we are receiving for each barrack.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "So we had a contact to see her.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "When my wife was not called when the 300 women were assembled to go, she decided to keep with her brother, with her sister, and sister-in-law, together, up to the end of existing, until the 15th of January, 1945.",
      "word_count": 39
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "She was there up to the liquidation with her brother, sister, sister-in-law.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "In Plaszow.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And they went, on foot, to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "From Gross Rosen, directly, we went to Brinnlitz, Bratislava, in Moravia.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "It's part of the Czechoslovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was several days.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Only with the same wagons which we received in Cracow-Plaszow.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Very bad.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "It's hard to describe this.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Because we were nearly 50 people or more sometimes, in the wagons.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "You couldn't always sit.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't always lie.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "You couldn't always stay.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "But we survived.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "There was a dish where everybody was using for that sort of purpose.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And when there were stoppages, they were emptying the dish.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Not to my knowledge during the travel from Gross Rosen.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Only, we received some food in Gross Rosen, because it was anticipated that it will take longer.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "But I don't remember that somebody starved because of that, no.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember any outsiders.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Maybe they were not born in Cracow.",
      "word_count": 7
    }
  ],
