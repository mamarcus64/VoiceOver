{
  "stem": "16106.1",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "In those days, they had only the room heated we were in.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "And I was quite sure that the Eliyahu Hanavi was, was lurking in the shadows and ready to pounce on me.",
      "word_count": 21
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "I was very scary.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "Besides our Hagganah had on the back the pictures of the Marranos.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 19,
      "text": "I mean, the Jews sitting-- [INAUDIBLE] sitting, having Seder in-- in a cellar, someone in hiding.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 20,
      "text": "And you see those guys coming in with spears and taking them away.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 21,
      "text": "And I had this terrible sense of fore-- premonition that something evil is going to happen.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So the whole Seder thing was not very pleasurable for me.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I mean, they killed little firstborns.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I was the firstborn.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Although it said it's boys, I wasn't quite sure they will not make a mistake.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Eliyahu Hanavi was lurking in the shadows.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And then we had mead to drink, which bubbled.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And I saw him drinking.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And he wore a toga.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "The [INAUDIBLE] Eliyahu Hanavi.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "I saw him in a white toga.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And there's a picture of the Marranos being, being arrested.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "It was very scary.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "It was a scary occasion to me.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "I was a probably very sensitive child.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHS] Yes.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "I had this feeling that it's no, it's no good.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    }
  ],
