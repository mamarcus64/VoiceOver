{
  "stem": "15396.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I knew they were going to ask me, are you taking any papers out of the country or any secret messages or anything.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I knew I would blush.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And because, you know, in school we were taught not to lie.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "When you lie, you have to cross your fingers, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And I lost courage.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I went to a bar to have a little courage.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And I saw this lady sitting over there with her legs crossed and all.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "She wasn't good looking or anything, but I started thinking, everybody is distracted by anything sexual.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So I got some of these papers that they have and tore the top off and all, and made three or four the most pornographic drawings I could think of.",
      "word_count": 30
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I knew that this would give me a reason to be confused.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "So I hid them where I knew they would find them, of course.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And went back and, of course, sir-- boy, how they hated to say sir-- are you taking any-- especially to some dumb kid, you know-- are you taking any secret messages or any-- oh, no.",
      "word_count": 35
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And well, would you mind opening this?",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Well, I seem to-- oh, its doesn't matter.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Opened it.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And of course they found them.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "He said, oh, you know, you can't take-- this is a Catholic country.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "You can't take this into Spain.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we'll have to confiscate them.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "So they closed the bags, and I-- I went out.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I think that was my first real acting.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I started method acting.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I started saying, what am I supposed to be, a dog with his tail between his legs.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So I slunk out like this.",
      "word_count": 6
    }
  ],
