{
  "stem": "20084.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "So she was taking care of his wife and helping and taking care of the cattle [PAUSES FOR 3 SECONDS] and working on the farm.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "And he was telling everybody that this is a niece of his, that she came from, from Poznan, from some, some other, other area of the-- a refugee.",
      "word_count": 28
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "And Helen went-- she was blonde and light skin and blue eyes.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "And she went to learn a little bit about the church.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "She went to church and sang Christmas carols.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "And, and there was one of the-- of the sons was a tailor.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "And the Germans used to come to have their uniforms fixed.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "And, and this was destroyed.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "That's how she lived through-- the war ended already.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 35,
      "text": "I'm going-- the war ended already.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 36,
      "text": "It was a year maybe after the war or so.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 37,
      "text": "And she had a dream.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 38,
      "text": "She told-- she's telling me that.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 39,
      "text": "Her mother came through and told her that she should go to the village.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 40,
      "text": "She knew that the war was over, because the Russians were there already.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 41,
      "text": "And she should go to the village and find out what's cooking.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 42,
      "text": "So she goes to the village.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 43,
      "text": "She found one of her cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 44,
      "text": "And he told her that there is a doctor a rabbi from England, taking all the orphans kids to London, that she could go with him.",
      "word_count": 26
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So-- where was I?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, oh, so she went to, to-- so she went-- so she wind up in England.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So she wind up in England.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And that's where I met her, in-- and she had, she had cousins in England.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "She, she had family in England, aunts and uncles in England, Helen.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So she stayed with them.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And she went to school at night.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "That's how I met her.",
      "word_count": 5
    }
  ],
