{
  "stem": "14737.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And so when you want to come to live anyplace, you have to go to the police, and the police ask you, what's your military status?",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "You have to write that you are drafted.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "You have to prove.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "So I figure, myself, so I'm going to take chances.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I want to stay in Budapest, so I'm going to go over to that office and draft.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I see there are many drafted.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "What's drafting?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "They put a line, maybe 100.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "Not everyone went, but I went, because I was a stranger and I couldn't stay.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "I couldn't go to live no place else without having this-- this status might clarify.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And I come there.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "There's a line.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "You undress yourself. 100, maybe 200, going one, two, three.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "A doctor or an officer comes there.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Well, anyone who's a cripple doesn't have-- there's no food.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He's taken out and the rest are all drafted.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And they give you a paper, drafted.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Now, drafted doesn't mean nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "You can work.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "So I'm drafted there.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Already I can go anyplace I want.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "I have my status.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "I can register.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "Forgot to tell you about, I couldn't get my domicile in Dovhoje, my-- because I came late, so I'm not-- I'm not a citizen according to their interpretation.",
      "word_count": 28
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And so I'm struggling in Budapest.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And every day is a different story.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "Still working on emigration, but still I cannot emigrate.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "There's no place.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "I Didn't give up.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "I'm going to Jewish organization, I'm going to other organization, but so are thousands and thousands.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "There is a newspaper-- I forgot the name I put on-- where there is matrimony going on.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "So every ad is there is a girl wants a boy, a boy wants a girl, but mostly it's written like this.",
      "word_count": 22
    }
  ],
