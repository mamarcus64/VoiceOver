{
  "stem": "393.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And the sister, she-- a 20-year-old robust, healthy country girl-- she went with her.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "She went with her.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I can't believe that.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I can't believe that she went with her.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And she died with her.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "She knew what's going to happen.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "She was so brave.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "You see what people did?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It's-- it's really unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Somehow, I always went through all the-- I-- I told you before.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But even in Auschwitz, I looked good.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I-- I I was with a friend, which we called-- like a sister.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I had with me three cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We were a group of 10.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We kept together all the time, all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "We managed to-- to live in such terrible circumstances, but we lived through in Auschwitz til September.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] We were very skinny, and we were always hungry, but we didn't work there somehow.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "Because this was just a-- a changing place.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "So that was actually called Birkenau.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "I find that out just a couple of years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I was there.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I went back there.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And I don't know if-- if I can remember.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "That little girl, yes, she slept near me, you know, we-- if-- if one had to turn, everybody had to turn.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "When she couldn't sleep, she couldn't sleep.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She was a very young.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And-- and I ask her, why are you moving so much?",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I can't sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "What's the matter with you?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "She says, you see, when I went to sleep at home, I always used to play with my hair-- to twist my hair like this.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I don't have hair now.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So she couldn't sleep, poor girl.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And that was the other girl.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Oh, I have to remember things.",
      "word_count": 6
    }
  ],
