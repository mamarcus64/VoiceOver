{
  "stem": "7832.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "When we got closer to him, he told my mother to put the children down on the floor, and she wouldn't-- she wouldn't do it, so she hung on to-- so he took this little thing and he split me away from my sister.",
      "word_count": 44
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And he pushed me over to the side, and my mother and the children to the other side.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I looked back, and I said I want to go with my mother, and I screamed.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And then the guard took me, and he was pushing me in this direction.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And my mother was hollering at me, don't worry.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I'll see you tomorrow.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Just don't-- just don't cry.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Everything'll be OK.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I'll see you tomorrow.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "[CRYING] And then she-- she just went away.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING] And-- and I was taken to these-- a whole bunch of people that I didn't know.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "We were marched.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "We were walking, another way.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "On the way, I saw wires on each side of us.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And there were people behind the wires with shaved heads and one piece of clothing on their body.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And-- and I said, what is this?",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Where are we going?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And everybody said, it's an insane asylum.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "This is not for us.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We're going somewhere.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "These people are insane.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "This is a hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And we kept going.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And then we saw these black trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They were lined up on a road just-- the train was on this side that we came off, and these black trucks were lined up on this side.",
      "word_count": 28
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And as we were going, see, my mother and the children went that away, and I went that away.",
      "word_count": 19
    }
  ],
