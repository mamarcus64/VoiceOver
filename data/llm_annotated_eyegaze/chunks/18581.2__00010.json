{
  "stem": "18581.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "You see, I was in Vilna, studying.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And all of a sudden, I received a-- a letter from my father, that he-- he has to talk to me about a very important subject.",
      "word_count": 26
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "The subject was that he was contacted in our-- our hometown, Mazeikiai, by a [?",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Lithuanized ?] Russian, Tominov, the son of the letter carrier.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "And the man said, Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "Trigubov, you have family in Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "I know, because you receive letters.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "His father was the letter carrier.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Said, why don't you take your family and go to Russia?",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Because this is dangerous, to stay here.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "So my father said, why should I go from my home, again, back to Russia?",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And he said, because we are very well organized here, the Lithuanians.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And war is imminent.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And when the war starts, many people will suffer-- the innocent together with those that worked against us.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "My father said, why should it be?",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Lithuania was always a country of law and order.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "There was a court.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "There were lawyers.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "He says, oh, no.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "This is a different time.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "It's time of war.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And those who sinned against us will definitely suffer, and maybe, many who did not do anything wrong may also suffer.",
      "word_count": 21
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "So I-- I suggest that you take your family and try to get to Russia.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "My father said, it's so simple.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "It's not so simple.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "You can't get out.",
      "word_count": 4
    }
  ],
