{
  "stem": "942.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "And his business was taken away without any compensation.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And Jewish people could not sell any tobacco products.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And Jewish people could not employ any Gentiles.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So this nanny, she had to leave after 11 years of being-- living with us.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I remember we were very upset, and she was really upset.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She had to go back to her home.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And we had to hand in this crystal radio.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We were not allowed to have a radio.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And we had to have papers in our pockets when you went from one town to the next, this type of thing.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And the whole atmosphere changed in the school.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "When we went to school, you know, there were fights with other kids, and Jewish kids had to sit in the back of the class.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Our teachers changed.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We had new teachers that came from Hungary.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I remember one particular teacher.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "He was quite cruel.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "We wore little side-- it's called payot, peyas, you know, like a sideburn-- not the one, you known that is curled, but just a small sideburn about an inch long.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And he used to pick us up, Jewish kids, by the sideburn, and he said, just sit.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And he used to pull us up from the chair.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And sometimes, I thought that my scalp will come off.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "So these were these subtle things that were happening to us in school.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And-- excuse me.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So by 1941, the next things that came into-- the Hungarians brought in, they took away all the able-bodied young men from the age of 20 or 21 to 55 to forced labor camps.",
      "word_count": 34
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And my father and my uncle were taken away as well.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And they were away for almost two years, on and off.",
      "word_count": 11
    }
  ],
