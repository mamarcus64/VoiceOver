{
  "stem": "1917.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.2,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I said, I'll tell  you what.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Let's get engaged, and you write to me letters, and I'll write you letters.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "He said, no, [{PAUSES] or now or never.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "My sister was already married.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And she just had a baby.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And my aunt who raised us said, in our family, there are no old maids.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "[{PAUSES] She said, get married and then if you don't like it, get divorced.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "That's better.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "There was a lot of pressure put by many people on me, get married, get married, get married.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "And I broke up already three engagements.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "That was not-- [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "If there was nothing to go, and I really wasn't feeling like I wanted to get married.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "I enjoyed being single.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "And I didn't need to get married.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "But after I think the fourth-- fourth or fifth time, I said, OK, let's get married.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And it wasn't really me.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And I was not crazy in love with him.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "It was the circumstances that I wanted to get away from Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "I wanted to get away from that old boyfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "And I wanted everybody to stop, leave me alone.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "And I said, well, you know, it will be exciting to go to America.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "So I got married.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "He came back to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "I worked in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "I still was a sergeant major in  the Israeli Army and I needed to get my release from the army-- which took me quite a while-- as well as a visa, entry visa in United States.",
      "word_count": 36
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "And there was one other problem, that my poor sister was married, but she was having a very difficult time.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "While I lived in Israel, I helped them financially a great deal.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "I was almost like a mother to her.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "I mothered her very much.",
      "word_count": 5
    }
  ],
