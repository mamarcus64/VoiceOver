{
  "stem": "25835.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "The people brought to Warsaw many food.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "But it was very difficult to, to get that.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "All-- yeah, I remember that this was time when I was growing fast.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "Between 11 and 16, I was in Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "Communication was not safe.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "Because always, you can suspect something.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "I saw a couple times going on the street, and immediately, two or three gendarmerie came to one person, took them to the big car.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "And he disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And later, many people were shot on the street in special place on spot.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "Next day, the same places was covered with lights and flowers.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "We have still the same now in Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "In a couple places where Polish-- it was not soldier.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "Because of people, they shot them.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "Therefore, each day, mother was praying, oh, God, let me see my children.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "Seven o'clock was time where nobody should be on the street.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "And she was waiting till seven o'clock.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "Oh, God, let me be with my children-- hard time.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My brother, George, was much earlier as I was in underground army, he had-- he passed special preparation for, to, for shooting and everything.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He was in underground army, I think, since 1942.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Also, going to this underground ar-- underground school, where he was very active in preparing [PAUSES FOR 3 SECONDS] theater, school theater.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He was very, very dedicated to painting.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But you see, in this time nobody knows what you doing.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Because it was secret.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I remember when I gave my oath, I said, never tell about where I am, what I'm doing, what I have to do.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "It was secret.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was 15 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My girlfriend, very close friend from school, Mischka, she has connection with officer from underground army.",
      "word_count": 16
    }
  ],
