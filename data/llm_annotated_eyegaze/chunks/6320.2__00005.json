{
  "stem": "6320.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And there was also, which I forgot to mention that I met one boy, Schlomka.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And he was with my father at the time.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And he was killed also and my father.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "Then I was all alone.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And I went-- my journey began all by myself.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "And I didn't even know where they were-- where they were buried.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "I could never find it.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "And I worked for this-- at this-- evangelist.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "I don't know if you call him a preacher, or-- I guess.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "I was working then.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "They said that I-- I told them that I was Czechoslovakian, an orphan.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "And-- but I was work-- the-- the wife recognized that.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "She said that I don't work like a Czechoslovakian.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "I work like a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 33,
      "text": "And she told me that I should go to another-- that he send me to another place.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 34,
      "text": "Because they were afraid that they-- you know, that they going to-- that they find out.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Because they knew that Jewish people didn't work on farms.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "That's how she said it.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I went to-- they send me to another.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I became really Evangelist with them.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I used to sing when they had the prayers.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "These were people who spoke with different-- with different languages.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So one day they started to-- you know, they scream.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And so I started to talk loud.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I said, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I said, mother, father, please, help me to survive.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And you know, they all started to scream that I am talking in different languages.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I actually-- they went and throw me in the water.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And they baptized me.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Because they said that I was speaking in their different languages.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I-- then I already found out how they real believers.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "But they were very nice to me.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "They gave me papers.",
      "word_count": 4
    }
  ],
