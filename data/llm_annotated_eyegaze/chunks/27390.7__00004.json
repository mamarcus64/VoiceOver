{
  "stem": "27390.7",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So every day this, this, this soup wagon traveled backwards and forwards.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So these two people went with the wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And there were two SS guards with them on the wagon.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And they-- on the way they were stopped by an-- a car came, drove up and high ranking officers, German officers, went out of this car.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And they asked, who are these two people?",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They asked the guards who are these people.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And he told them they're two prisoners that they're taking to the main camp to have their teeth seen to.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "So they said, these high rank officers, they said, we want these two people.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We have to interview them.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And they took them away into the car.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And they drove away.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And when these guards got to the camp, they realized this was a plot.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They were, they were partisans.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And these two, they took away these two prisoners.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "But later on the block fuhrer, he told us that they were caught, and they were hanged.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "The partisans?",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Whether it's true or not--",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But the partisans killed the kapos",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "They were trying to save these two kapos.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "One of them was a Pole.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And one of them was a Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But they were both kapos.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They-- kapos had more contact with the outside world somehow.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "They-- they had, as I said, more privileges.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They came in contact with other prisoners from other camps.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "So maybe--",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "One was called Yanek.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "The Pole was called Yanek.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "The Jew, I can't remember his name.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But we were told by this block fuhrer.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He came, the next day he came-- or it wasn't the next day after.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "About a week he came and he said, mm, you think they got away.",
      "word_count": 14
    }
  ],
