  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "This few Polish fascists, while I was hiding, they already [INAUDIBLE] because they [INAUDIBLE] already, the Germans will come to [? meet ?] [? them. ?] You understand?",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I [? find ?] [?",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "God, ?] I come not far from my place where I used to live was a place they used to call the [? bazaar. ?] You know [? bazaar? ?] [?",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Bazaar. ?] In this place, we used to meet each other, Polish people-- Yiddish people.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "If I want to meet you on the [? bazaar, ?] you be there on the [? bazaar. ?] I come there, my girlfriend is there standing and talking with other-- two boys, with a girl talk.",
      "word_count": 37
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They ask, Mojsze, did you hear the news?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Of course I hear the news.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "My boss had a radio, I heard the news.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "What are you going to do it?",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I'm going home, pack-- take a pair of trousers, a shirt, a pair of shoes and this and that-- and tomorrow six o'clock, I'm going to Russia.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I ask you to do the same thing if you want to be alive; otherwise, you will be finished.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Hitler will not let you alive.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "One boy said, I just started to do a partnership with another man in a business.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I cannot leave this one.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And the girl, we known each other because we were friends, they girl was [INAUDIBLE] I know-- my friends, we knew each other.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I already make arrangement to get married.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I cannot go.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Do what you like it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "I going.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "Tomorrow morning, six o'clock in the morning, I'm going to Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I took my girlfriend home-- I took her home.",
      "word_count": 9
    }
  ],
