{
  "stem": "18520.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 843.0,
  "sentences_input": [
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "This is already the later years, late, I started.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "They accept me already, you know, to continue.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Completely excellent.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Completely, no complaints.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "They didn't complain, the other side didn't complain.",
      "word_count": 8
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "They just don't join the same group as you.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "You know, he sits all day and [PAUSES FOR 4 SECONDS] My father had to go to work.",
      "word_count": 18
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "So it's a-- it was a different-- today is the same thing here.",
      "word_count": 13
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "You know, I helped out a few years ago, when I came.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "I was working on my own.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "You know, I was building, and I was fixing anything to houses.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "In Monticello area.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "I, I build a few bungalows, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "So I, I made-- I made-- I made a good living.",
      "word_count": 11
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "I made money.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "I came here as a professional.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "I didn't try this to do.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "I didn't want it.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "I knew this to do too, you know, woodwork.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "A matter of fact, I have a lot of the stuff from wood homemade.",
      "word_count": 14
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "For Hasidim too, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "I built for [NON-ENGLISH], and it changed.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "You want to an addition or something, I did.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "It's OK people.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "I have never had any problem--",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Not in Lodz.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "Not in towns.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have a bar mitzvah.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Because the war broke out at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "They have a person.",
      "word_count": 4
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "He's a rabbi-like.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "He's the rabbi.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "He sits all the time in the kehillah, in the shul.",
      "word_count": 11
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "And people coming, and he takes a, a, a, a, a, a [NON-ENGLISH] or takes a gemara out.",
      "word_count": 18
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "And he explains this to people sitting around.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "And he translates from the Hebrew, whatever it's written in the Bible, the way it's written, he translates this in Yiddish.",
      "word_count": 21
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "The kehillah.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "The rabbonim are poor.",
      "word_count": 4
    }
  ],
