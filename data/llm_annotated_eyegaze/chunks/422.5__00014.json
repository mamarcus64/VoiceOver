  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Just they don't want more than the tickets.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "They want to move over to California.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Four people, two teenagers and the parents.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I have to give them $100 a piece for the ticket to go to California.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't have money.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "But my uncle helped me with this.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "So I got the apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And over there, I lived-- it was a cold apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "The landlord didn't give us steam.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "We froze every winter.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "I had to dress the children to go to sleep in winter coats.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "That's how cold it was.",
      "word_count": 5
    }
  ],
