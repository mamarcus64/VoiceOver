{
  "stem": "17299.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And then when we marched back in the ghetto in the evening, we had to line up-- all male had to line up, and everyone over 50 years of age got told he can step out of line.",
      "word_count": 38
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we were selected.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "We were told we all would go to Salaspils.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We are building a camp for the Jews because the ghetto is too small, that we will have proper living quarters, and things like that.",
      "word_count": 25
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "On the next morning, we were marched out there.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But the selection was done in such a manner that Nussbaum selected more people to go to Salaspils than the SS wanted.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "He was very obedient to the SS.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, the SS left some people behind.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "See, they wanted only 500 Jews that were from the transport-- Hanover, Dusseldorf, and Cassel.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Each transport had 1,000 Jews when they came in, but they wanted only 500 males of the-- of the 3,000.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And they didn't want any children, and they didn't want any older people.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We knew that Leiser was the alteste of the Jews, but that's all we knew, because the minute we walked in the ghetto we were in the houses.",
      "word_count": 28
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "There was a curfew.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You could not go out.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You could not talk to anyone.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And it was too cold, and snow and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "You were glad to be in warmth, because all day long we were out in the cold working for the army.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Not during that time.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "They were to stay in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They stay in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And my brother-in-law had an accident.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He fell in-- in the harbor.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "He stayed behind.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "He was not selected.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "My oldest and my youngest brother.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Kurt and Herbert.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
