{
  "stem": "293.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Leopold-- original name is Leopold Pfefferberg.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born on March the 20th, 1913, in Cracow Podgorze, the most beautiful town in in the whole Poland, old over 1,000 years old.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was born to a beautiful, middle class Jewish family, religious.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "My grandparents were very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "My parents were religious too.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Not orthodox, but conservative.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I have a beautiful youth.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I was the first in the family of my grandfather's family, where there was 11 brother and sister.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I was the oldest grandson, and I was like a treasure for my grandfather.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Three years later, my sister was born on February 9, 1916.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "This time, my father was not present during the birth of my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "He was already drafted to the Austrian Army during the First World War.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we didn't know in this time where he was located.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "We found a few months later, after my sister was born, that he was wounded in the western-- northwestern part of Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My father-- first, my father's name was David Pfefferberg.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My father was a representative of company from Germany in this particular time, has a [INAUDIBLE] office in city of Cracow, and represent [INAUDIBLE] company was importing goods from South America, like coffee, tea, and nuts, and raisins, and other types of normal imports from this part of the world and was doing very well.",
      "word_count": 55
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But the war started in 1914, and he was drafted.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And he got wounded in 1916, and then he was released.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "My father-- The family on my father was a very well-known Jewish family of city of Cracow for centuries.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "His family was consistent about nine sister and brother.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He was the oldest one.",
      "word_count": 5
    }
  ],
