{
  "stem": "1677.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I had to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And my mother was leaning against me, in that awful, stinking, terrible, cattle train, which was 80 people were in one, instead of 40, 80.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't move.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Two died, fortunately, so there was a bit more room.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "People are people.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Throw them out on the next station.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes, many times.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and I know that there were 21 cars.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And there were over 2,100 people.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I think they were also from Novaky, from Zilina, from other camps.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They just cleaned up.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They made a big clean up.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And if you escaped this big cleanup, on the 2nd of October, 1944, Auschwitz stopped gassing.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "That's a fact.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "If you would have made it, then you would have come to Theresienstadt.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Theresienstadt was survivable, because there was no gas anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I mean if you survived, if you didn't get typhoid fever, if you didn't get all sorts of terrible diseases, cholera.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "So--",
      "word_count": 1
    }
  ],
