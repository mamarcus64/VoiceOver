{
  "stem": "8234.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I says, what kind of people is that?",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Who are they?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "This is what I think-- this is what I think was the biggest shock of my life.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't sleep for nights.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "OK, [PAUSES FOR 3 SECONDS] Auschwitz was finished.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "This was already '43.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I didn't get a tattoo, because I-- I didn't suppose to be in Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I was a [NON-ENGLISH]-- in transit.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I was still not named about 11 months.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And they put us on trains.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And we traveled quite a few days.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And we came to a camp called Mauthausen in Austria, up in the Alps.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "By train.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it was OK.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have any-- any-- any wagon-lits, you know, but it was OK.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "At that time, I had the [NON-ENGLISH], you know, the striped, like the zebra has.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Shoes?",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "There were shoes.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Usually there was shoes with wooden soles.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "But you can have your own shoes.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I bought some shoes in Auschwitz for bread.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "So I had good shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And we came to Mauthausen.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "That was a long-established camp.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Like the sardines-- they push-- this was early in our-- I think Russia was attacking the Germans, and pushing down.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And that-- that felt really uncomfortable.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So there was a lot of people coming from-- from some camps.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "We slept like the sardines.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And the morning-- We have to stop now.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "OK, fine.",
      "word_count": 2
    }
  ],
