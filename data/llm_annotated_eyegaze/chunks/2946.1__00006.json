{
  "stem": "2946.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So I decided, just for the sake of the girl, to start university.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "But a year later, she married somebody else, and the whole thing fell apart.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "But I continued in my studies at the university.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I was in Prague.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I was studying-- studying accountancy commercial and leading me towards an engineering degree in commerce.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "That's how I came to Canada with the engineer of commerce.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was teaching.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Beg your pardon-- I was teaching in Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "When I graduated, I was teaching high school.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I graduated in 1938.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And then the Germans marched in March 15, 1939.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And I had to leave school-- this high school-- because the Jewish teachers and Jewish children or students were not allowed to continue their studies.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And in this situation in Prague was there was 80,000 Jews lived in Prague.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And the lawyers were not allowed to continue their practice.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And the Jewish kids had no education, were excluded from studies-- studying in public schools.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And the Jewish Congress-- the Jewish-- they would call it-- well, the offices of the Jewish Congress, I guess, they would call it here-- they needed Jewish teachers to teach these students privately in homes, 10 kids in one home.",
      "word_count": 40
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "So they asked me, since I was a teacher.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "Not too many Jewish teachers were around.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "They asked me to lead one of these groups.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And they assigned three lawyers, Jewish lawyers, who couldn't practice to me as assistants.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "And we had every day school in a Jewish home-- 10 kids, one lawyer with one kid-- with a group of 10 kids.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "I was with the others.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "The other lawyer was with another group of 10 kids in the home.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "This went on until the-- the transportation or deportation of Jews started.",
      "word_count": 12
    }
  ],
