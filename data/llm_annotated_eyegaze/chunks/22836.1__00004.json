  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "I had a sister, and an older brother, and a younger brother.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And she have, in the meantime, she got a boyfriend.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Lehke, Lehke.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Lea, Lea.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And a brother, Mayer, the younger than me.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And an older brother, [INAUDIBLE], Isaac.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And she have to get married.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And we don't have much money to give.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Then she wanted me just sign-- the, the son-in-law.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "My son-in-law, well, you have to be the son-in-law, he wanted me to sign him, I'm going to give him $50, like you say, and-- what do you say.",
      "word_count": 29
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He was going to be your brother-in-law.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, brother-in-law, right.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "A dowry.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Then I have to sign myself.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Sign him I'm going to pay him off $50. $50.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "That time, $50 in Europe was a lot of money.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And the time to pay him off, because I was going in the business, too.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "In the grocery.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And I signed.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "Then we give him away the house.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "We give him away the house, some of the house with the business.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "And I went with my father and mother, with my younger son went to a smaller town.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "A smaller dorf, like same thing.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "He was there, Ukrainians.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "The younger brother, younger brother, right.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No, Isaac is the older brother.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Mayer, Mayer.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Mayer and my father and mother.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And we open up a grocery in Matejka.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "They call it Matejka.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "That's another small town.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Matejka.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Matejka-- M-A--",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "A-- Matejka, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Is-- and the older brother of mine was married there in Kolki.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Isaac was married there in Kolki.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Not too far.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And he opened a grocery, too.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Is-- I forgot what I want to say.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Then-- OK.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Then we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "When they [INAUDIBLE], and we give away my sister, the house, and everything.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "We went there.",
