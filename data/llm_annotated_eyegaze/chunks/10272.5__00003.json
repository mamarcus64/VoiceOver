{
  "stem": "10272.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So we start to run up the staircase fast they shouldn't be able to hit us, but he was running after us up to the top floor.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And there we-- we run inside a big hall.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We saw behind a big desk, one Gestapo in a white-- in a white-- A shirt?",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In a white-- no.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "In a white-- like-- like a doctor, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "A white-- yes.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "A white coat.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So-- a robe, a white robe, looked like a doctor.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And on the floor, there were things laying [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "The shoes were separate.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "There was a stack of shoes, stack of underwear, and stack of pants and-- and jackets.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So when we came in, he said right away to undress, everything undress, and put there on the stair.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So we put everything there.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And then came out, these two Nilosh which they were-- were chasing us up the floor, the two.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Another two were in there, inside.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And-- no, another one inside.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And each of them grabbed us by the hair like that.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I had hair short like this.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And started to pull our hair out and all kind of-- each of them grabbed the hair of somebody-- of one of the guys.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And the doctor said, [PAUSES FOR 3 SECONDS] name?",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Each of us has to give the name.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Name, I gave my name.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He give the name.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Third give the name.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And then he said, where are you from?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I said, [HUNGARIAN].",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "In Hungarian, [HUNGARIAN] is [HUNGARIAN].",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "When I said, [HUNGARIAN] and he was holding me by the head, he give me a punch me up, that I was-- my head was swinging around.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You are from-- listen!",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "He was from [HUNGARIAN], he says.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "You are from [HUNGARIAN]?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Another punch.",
      "word_count": 2
    }
  ],
