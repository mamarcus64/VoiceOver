{
  "stem": "7302.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Hanna, ?] from the first marriage-- she was then about 15, 16 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Maybe a bit older, maybe 18.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And she was a beautiful girl.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "You have seen her in-- on the picture.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And she met a boy, and he fell in love with her.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he was a rich man.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was buying cattle and selling it to the, to the army, to the butchers, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So thanks to her-- he married her.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And thanks to her, he took in all the family in the business.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So my three brothers worked with him-- for him, worked with him-- you know?",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So the oldest was Moshe.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And then-- and he got married from a girl not from our town, to a shadchan, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "She was a poor girl, but from a very religious family.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Her father was a soifer.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Her brother-- one was a rabbi, and the other one was a shochet.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "But she was poor, and she was looking for, for a husband who will take her without-- how would you say-- nothing?",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Without a dowry.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Dowry.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a soifer, who writes the--",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The Torah.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "The Torah.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "A shochet is who kills the--",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The ritual slaughterer.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "--Who--",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "A ritual slaughterer.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Checks it.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We haven't got--",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Is a matchmaker.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "A shadchan is a matchmaker.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So it's clear now?",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So my oldest brother got married, and they went to live with us in this house.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "So we gave her-- we was having one room extra-- this was the second house, not the first house.",
      "word_count": 19
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We gave them a, a little room for-- just for sleeping.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And the rest, it was altogether.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "They lived with us about two years till they got born, the first child.",
      "word_count": 14
    }
  ],
