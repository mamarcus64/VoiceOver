{
  "stem": "22047.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "No, I-- I didn't think that she'd understand.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Or-- or-- It turned out that-- that she wasn't particularly interested in-- in what I was interested in.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And that's why she is my former wife, God rest her soul.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "She passed away.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And that's another story.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS] So no, I didn't talk about it.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Married in Tacoma.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Moved into my mother's house in North Hollywood, and that's where we lived from July-- well, we went on a honeymoon up in Northern California, and then drove-- my mother had given us their car.",
      "word_count": 35
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It was-- which was a '36 Dodge.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "That was a wedding present.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "So we drove that '36 Dodge around and drove to North Hollywood and lived in my mother's house.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And then my sister and her husband, who had been married two months earlier, asked if they couldn't come and live in that same house-- asked my mother.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And that turned out to be a terrible plan.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We were at each other's throats all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "And my wife, Sally, didn't help the situation any.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "She was a self-centered person.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Anyway, we decided we've got to get out of there.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "So I applied at UCLA, because I was-- I was going to UCLA then, applied at UCLA for an apartment on the campus.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "There were a number of buildings that had been moved from Vanport near Portland and rebuilt on the campus of UCLA.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And we were able to get an apartment in-- that would have been '46.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I think it was about November of '46 we were able to get that apartment.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "So we only lived there in North Hollywood for a few months, a couple of months.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I remained in the Reserve.",
      "word_count": 5
    }
  ],
