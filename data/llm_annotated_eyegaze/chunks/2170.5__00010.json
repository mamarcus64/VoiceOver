{
  "stem": "2170.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "I can't believe it that he let you out.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "You are lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "You are lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "You have to go back to the Ukraine.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "So I said to her, how am I gonna leave?",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "They got all my documents.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "How I'm gonna go back?",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "And then comes after the rest-- the rest of the story.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "And she went to the typewriter.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 30,
      "text": "I said, I cannot back-- go back to Ukraine only if I have a permit from you.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 31,
      "text": "Otherwise, I will not get no ticket on the station because there's thousands of soldiers.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 32,
      "text": "How I'm gonna get into the train?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "She sat down.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She wrote a letter.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "That letter was to the [? nachalnik, ?] to the chief of the station, to get me into the train as soon as possible to go back to Zhmerinka.",
      "word_count": 29
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I said goodbye, but she said to me, you are a lucky man.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I never saw over here in this room walks out-- out like you.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "She spoke very low, you are gonna go to America.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I said, what about my documents?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "My passport?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "This will be sent back to you in Vinnitsa, to the headquarters of the KGB.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Over there, you'll go to the KGB, and Kiev is capital of the Ukraine, is there own international foreign affairs.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And from there you'll get the visa and go back as soon as possible.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I run back, and I came into the house.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The mother and the daughter could not believe.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Same day I was running, they-- I said, somebody has to take me to the station, I don't know where.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So the daughter took me to the station.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "This girl, supposed to be a doctor later on.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I said goodbye to the mother.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They were-- they were a mother to me.",
      "word_count": 8
    }
  ],
