{
  "stem": "11167.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And we went-- we went the second day to the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We went to the factory.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "They asked me, what you going to do?",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I want first to  write home to hear if maybe somebody is left.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Then I want to see what everybody will do.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "The Polish people-- I had my passport till '39-- the Polish passport.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "I belonged to Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "It was still '39.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "They said till '39 who belonged to Poland will be able to go back to Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "You had to know your language back.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "I did speak four solid years Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "I had all forgot.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "Then once they think-- think hard will come the language back to you.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "I couldn't-- they asked me to speak something, I speak in Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 16,
      "text": "I couldn't speak.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, I-- after four or five days, I started thinking and how did go to school.",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And what I did right in school.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And it came to me slowly, surely, came to me back the language.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I had to register.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And then I received a letter from my brother as he was--",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "He say it's very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "He didn't want to tell me, as everybody was killed.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "But I did write then to my girlfriend-- this-- [INAUDIBLE] this Luba.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "To my-- and she-- she sent me a telegram.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "My friends from school.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Czech girl.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "She-- she-- she did in telegram, tell me is-- is not-- you haven't got nobody.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS] [DRINKS] She asked me to come to her.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And she said was a very honest person.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Very honest.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "She said Freda, if you can help yourself, not to come up to see what's going on.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "It's bad.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 7 SECONDS] Then I registered.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Nobody.",
      "word_count": 1
    }
  ],
