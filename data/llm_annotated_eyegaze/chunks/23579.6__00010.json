{
  "stem": "23579.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, when I was pregnant-- and six months-- six months-- five months-- I wrote to my mother in Paris-- she was in Paris, then, by the family-- that I am pregnant.",
      "word_count": 31
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "She asked me, listen, I know you love him and he loves you.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "But I would like for the children you should be married now.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "So we went to a rabbi, and he married me off, me and Zus.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "When we came here, to the United States, he said-- the justice-- he send out my son-- my oldest, Jay-- does your son knows that you marry-- you marry your husband when you were pregnant?",
      "word_count": 35
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "This was a war.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, this is it.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "So Jay was born in 1963.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "David was born in-- David was-- no, [NON-ENGLISH]-- Jay was born in 1969-- Jay.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "David was born in-- something wrong with me.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Jay's birthday is December 9, and we were in Israel in '45, and he was born in '49.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "David was born in '50-- '51.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And Zvika was born in '53.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "All of them, they're born in Israel-- in Assuta.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I decided I couldn't take the Arabs.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Whatever you're closing a window, what-- I was thinking that the Arabs are coming to knock me in the window.",
      "word_count": 20
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "This was my-- my-- I was afraid of the children, of the boys.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I had so much afraid of that.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I had-- I felt it-- the knocking from the German, from everybody.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And I said, I cannot take it.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "What will be when the children will go to the army?",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "So my brother, my kibbutzim said, Sonia, I don't care.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "You can go to the United States, but don't take away your children from here.",
      "word_count": 15
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "But my children went anyway to the army there.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "When did you come here?",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Hmm?",
      "word_count": 1
    }
  ],
