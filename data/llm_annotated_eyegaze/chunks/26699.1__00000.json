{
  "stem": "26699.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Lyonell Fliss.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "L-Y-O-N-E-L-L F-L-I-S-S.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "This was my name at birth.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents and my friends gave me nicknames, like Nelu.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Nelu is one of the most common names in Romania, as nicknames.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "It's a shortening of Lyonell.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It's N-E-L-U.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But for my parents and for my closest friends, I was Nelutzu, N-E-L-U-T-Z-U, which means little Nelu.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My birthdate was 1st of April, 1935.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My age now is 61.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I'll turn in April 62.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The city was Iasi.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It is spelled in the Romanian I-S-- I-A-S-I, with a certain accent.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "In French or German, it's called Jassy, J-A-S-S-Y.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The country, Romania.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I can.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Iasi was called the sweet town of Iasi, because it was a dormant town, an old town, a cultural town.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "It was the center of Romanian culture, where the roots of the Romanian culture took place.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Iasi is the provincial capital of Moldavia, one of the three provinces which form Romania today.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It is located on the hills of Moldavia, close to the Carpathian mountains, in an area which is famous for its wines and vineyards.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Actually, my first memories go to the farm of one of my uncles.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "Actually, he was an uncle of my father.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "He had a vineyard, and every Sunday the whole family was traveling from Iasi to the vineyard in a cart with two horses called dokar, and we are spending there a wonderful time.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I can remember that my father had a shop.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "He was a shopkeeper.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "Fabrics, he was selling, particularly to the peasants of the area.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And I was playing in the shop, as a little kid, sometimes upsetting my father's business.",
      "word_count": 16
    }
  ],
