{
  "stem": "19895.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And we were forced into living in Jewish houses, which meant that certain buildings in each neighborhood were selected, having a big Jewish star on the entrance of the apartment building, that everybody who would walk by the street would know that this is where Jews live.",
      "word_count": 47
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We had to leave our apartment and move into apartments in the building where some of the original people who lived there were Jewish.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And some who were non-Jewish were given better apartments and moved out.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And some of them stayed in the same building even so if they were non-Jewish.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "But we were forced into those buildings and very cramped and very over populated in an apartment with two bedrooms.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "We had the one in which we lived in some 16 people were living in that.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "We were sleeping on mattresses on the floor and shared living quarters.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And that time came those curtailments.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "The Jews couldn't go on the street, only between the hours of 11 till 5 o'clock.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And we had to wear Jewish stars on our clothes, which were sewn on.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And the star of David was to be worn by anybody who went on the street.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And you had to be identified that you were Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And-- and that was obviously extremely humiliating.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "It also led to more and more atrocities.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And when 11 o'clock came in the morning, people wanted to go out of their building to try to get to the neighborhood grocery stores or markets to-- to purchase with whatever money they had left and had without having jobs.",
      "word_count": 41
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "Because many people by then were not able to hold and go to their jobs or to your stores.",
      "word_count": 19
    }
  ],
