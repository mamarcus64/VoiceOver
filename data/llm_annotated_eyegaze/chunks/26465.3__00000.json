{
  "stem": "26465.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, I told him I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was repeating that several times.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And I even told him that, being a Christian I don't ever lie.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So he started beating me on the head.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And he tore my right ear slightly off, here.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And kicked me, finally, so hard that the whole chair with me went on the floor.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And I tried to get up.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He came again and kicked me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And he got so mad, he started swearing.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "[SPEAKING GERMAN], and so on.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And finally he went to the table and motioned for some other guy to pick me up and take me away.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And this other guy took me away.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "But he locked me in some sort of a-- um-- looked like it was a utility place-- a small-- very small place.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And he locked me in there and said goodbye, with a last kick.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I don't know how long, because I was so half-- I was not quite conscious, then.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "When I came to, there was another guy who opened the door.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And he took me outside.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And he was-- He was a Polish-- uh-- some sort of a Polish collaborator.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And he led me-- I was asking him-- because I have a loaf of bread with me, that I was carrying, that my aunt gave me, on my-- and I carried that as something very dear-- the last time remnant of my life.",
      "word_count": 43
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And he said, you don't need it, and you will never need any bread.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "You will never need anything now.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "You're finished.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And I asked him whether I could still go to the washroom and wash up myself-- wash my blood off.",
      "word_count": 20
    }
  ],
