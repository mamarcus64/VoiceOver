{
  "stem": "1511.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And one day, the Russian decide to see if we are communists or we are, we are-- [PAUSES FOR 3 SECONDS] what do you call it when you betray the country--",
      "word_count": 31
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Spy.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Spies.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They didn't trust us.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Because people were doing business, going still to Germany, and still go to buy in Russia and bring into Germany.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They risk their lives, because they want to see their families.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "The meantime, they bought gold, and, you know, it was going on something like that.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So one day, they let out papers in the streets that they want all this [NON-ENGLISH]-- they called us [NON-ENGLISH]-- where we came-- to register, if we want to go back to see our family.",
      "word_count": 35
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know that they taking already people in the concentrations.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what's doing in the other side at all.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So everybody had to register where he lives and give the address and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I said like that-- if I have to die, I want to die with my family.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "What, I'm alone, I'm 14 years old, what am I gonna do here in that life?",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "What's doing in this side, it's terrible too.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And I left them all-- I want to go back.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Anyways, I registered.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "But when I came to Bialystok, I start to singing in a big choir.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It was a big conductor, Sneerson from Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "He was a very famous guy.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We organized for boys and girls.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And we used to sing in the streets for the Russians on the-- all over, we went to perform.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I met that girl Baltscha.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And one night, we had the performance.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And it was I think on a Friday.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Friday night she says to me, I don't want you to go home by yourself.",
      "word_count": 15
    }
  ],
