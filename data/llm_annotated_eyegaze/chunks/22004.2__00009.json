{
  "stem": "22004.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "In that time, I marked it there in Hebrew in [NON-ENGLISH]-- 12 days in hell.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "This is-- this-- in this-- I have to check in the Jewish calendar there, what is the-- the month.",
      "word_count": 19
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No, then we went-- they-- the-- the Russian arrest us, and they said they're going to send us in the Russian army.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I said, I got a paper for the Polish army.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "So we went to Lublin by train, ourselves.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And we came there and we went in the Polish army.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "We got in at [NON-ENGLISH], this is in Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], and that group, we went to the farmers collecting food for the army to go on the front line army.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Uniform-- sure.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "First, we got in-- my younger brother wants to go to what he thinks to go.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And I don't want to go there, because I know this is suicide right away.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "So I told him to go, when I go, to stay next to me.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "So finally, we see they picked out all the people, not young.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "So we-- we have-- first, we want to shave.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "We didn't shave.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "We got a little beard, so we look a little bit older.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "So when I see speaking only these guys, and they came to me, and he asked me how I feel-- if I'm strong enough.",
      "word_count": 24
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "So they took us both in that group.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And when they-- and then-- in an hour later, they took us in a big-- big magazine.",
      "word_count": 17
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "You know, this-- in a big place.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And they put us in a little new, brand new Polish clothes.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And they gave us grenades with machine guns.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "My brother said to me, here, you pick the right thing.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "You're going to get killed-- in a day or two.",
      "word_count": 10
    }
  ],
