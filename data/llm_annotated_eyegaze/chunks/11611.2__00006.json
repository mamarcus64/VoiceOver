{
  "stem": "11611.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "The effect of that was some court martials were still going on, and I stayed in Hawaii probably an extra three months, because they wouldn't release me from my duties as a prosecutor.",
      "word_count": 33
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "In those days, you got dismissed from the military by points.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I think it took something like 130 points, which were measured in various ways, mostly overseas service, to get out.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I had something over 200 points, but I was stuck in Hawaii.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I also applied for a regular Marine Corps commission, which looked better to me than going back to law school.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And on conditions, I wanted to be an intelligence officer and study Russian and Chinese.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "The Marine Corps said they'd be happy to accept my application as a regular officer, no conditions.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And I wrote back and said, thank you.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I have no greater interest.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "The result of that was they put me on the rolls of a potential regular officer, and that cost me another couple of months.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "So I didn't get out of Marine Corps service until well into '46 and just barely made the due date for my last year in law school.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "I was assigned for almost two months to a Naval ammunition base at Crane, Indiana near Bloomington, which was another experience.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "There I polished my shoes all day and rode in the jeep around to the guard posts.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And I was desperate to get out.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "I mean, I didn't-- in some ways I liked the Marine Corps, but I had no great future in the Marine Corps.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "January or February '46.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "First Lieutenant.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I think Crane, Indiana.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She was working.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She was a psychiatric social worker by profession.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "She was working for the American Red Cross at an Army base in Utah.",
      "word_count": 14
    }
  ],
