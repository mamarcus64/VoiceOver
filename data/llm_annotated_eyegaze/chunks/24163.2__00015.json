{
  "stem": "24163.2",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 27,
      "text": "I went up to the second headquarter-- second floor.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 28,
      "text": "And there was a big steel door at the Gestapo headquarters.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "And when that door shut after me, I thought I would never, ever come out alive.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "He stood me in the corner, facing the wall.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "And he told-- there was-- there was an office with at least a half a dozen-- all SS men in this Gestapo, all in SS uniform, except this guy, who was wearing civilian clothes.",
      "word_count": 34
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "And he said something to them.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "I don't-- I was in a state of shock.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "I don't know what-- what he said to them.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "And I stood in that corner, maybe, for 45 minutes to an hour.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "And they all took turns coming by with these heavy black boots, and they kicked me and beat me.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "And I kept sagging down.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 38,
      "text": "And-- and they just beat the hell out of me, so to say.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And all the time, when it-- every time somebody came by, they would say to me in German, [SPEAKING GERMAN], which means where is-- where is your father hiding his money?",
      "word_count": 31
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "That's all they wanted to know.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And they kept on beating me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And then, one of them came over, and he looked at my hands, and he said, oh, you've never worked a day in your life.",
      "word_count": 25
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I can see that by your hands.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "We're going to teach you how to dig coal, how to carry bricks.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And all of this, you will learn at Dachau.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "In those days, they were primarily deporting prisoners to Dachau.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He said, you are going to learn how to work, he said.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And all this went on, and they kept on beating me.",
      "word_count": 11
    }
  ],
