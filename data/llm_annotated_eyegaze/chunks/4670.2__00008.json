{
  "stem": "4670.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if it was per person.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I just remember the sum of 1,500 guilder.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They announced to us that we could stay for one month and then make sure that we have papers to go elsewhere because we couldn't stay.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And where to go, they said, well, you'll have to go back to Germany then.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "They said they might-- father was extremely upset because he had no idea what he was going to do-- so they explained that we might get a grace period of another month, but that was it.",
      "word_count": 36
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "In the meanwhile, they gave us the first month, and we settled into an apartment in Amsterdam.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And then my father could not get a work permit.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "There was no-- no way we could make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So the three of us girls went to work.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And my older sister went-- this is very interesting-- she worked for the Frank family, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Anne Frank, and-- with that family when they were in the grain business.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "I mean, it was long before we ever knew about that story.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Otto Frank had hired my sister, and she worked in their household.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My middle sister, Margot, worked for another family.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I have no idea who they were.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I worked for a physician.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Her name was Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Riesenfeld, ?] who had also come from Germany but had settled in Holland.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "She really didn't need me.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I was only 14 years old, and she didn't need a kid in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And she did it because she felt she could help us.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "She knew we needed money.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "She had a housekeeper already, and all I did really was keep the housekeeper company and she taught me to do some tests that she was doing in her laboratory.",
      "word_count": 30
    }
  ],
