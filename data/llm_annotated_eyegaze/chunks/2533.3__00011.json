{
  "stem": "2533.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I have to walk quite a distance.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "The railway station was there.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I walked to them.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And when they saw me, they nearly couldn't believe that I was alive.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And they want to keep me there.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And I said, I can't, because I don't want to endanger you.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "They had two young children, maybe eight or nine years old.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And I said, if only you could help me in any other way.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "Before even he said that, I would like to get away to Germany, because in Germany, I won't be responsible for anybody, only for myself.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "And he said, yes, that's a good idea, because they have a niece already in Germany, in Frankfurt.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "And I knew her.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "She was a few years older.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "She was already married.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "I knew her from-- from home.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "And I got the address from them to Frankfurt.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "And they went to the-- he went to the station.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "He bought me a ticket to Lublin.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And he said, there you are.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "He gave me 200 zloty and gave me something else to wear so I will have something to change.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "And-- But don't get off in Lublin.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "Get off one station before.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "That was Majdanek.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 25,
      "text": "That was the camp.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 26,
      "text": "But the camp was on a different-- not where the station was.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 27,
      "text": "But that day, my luck, the train didn't stop at Majdanek.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 28,
      "text": "It went right to Lublin, because in Lublin they had at every gate of the station-- it was a very big city and a very big station-- they had the Germans were standing there, and everybody had to show papers.",
      "word_count": 40
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 29,
      "text": "In that particular time, we were not allowed to travel without special passes more than 30 kilometers.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 30,
      "text": "But from where I was coming to Lublin was 50 kilometers.",
      "word_count": 11
    }
  ],
