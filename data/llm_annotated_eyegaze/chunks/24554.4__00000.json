{
  "stem": "24554.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Where I learn?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "There in the camp.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "You know, in the evening, we go together, you know, and some, uh, volunteer teacher from the camp, you know, they teach us Russian.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, only these immigrants, nothing, uh, different, not a Russian.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The Russian people, the local people, they distance from us, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "You know, they was very afraid to make friendship with foreigners, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "They're Russian.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They don't-- was very afraid to come in contact with foreigners, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In the authority?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "They were not actually difficult.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "It's why we have the documents.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We are-- permission.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It was-- different was when we work, you know, as help worker, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "On the farm, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "They took-- talk with us-- no, not when there was the other one, only when he was alone.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "No weakness, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "There were always this, you know, from the interior police, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "There was--",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So what I said in 1942, I got the permission, go to the army.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I don't show him the documents.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I-- I tell I am from Czechoslovakia, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "The documents, I show only the interior police, not the private people.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In a-- Jewish [INAUDIBLE], started in--",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "--Tajikistan.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "There was a lot Polish people, Polish Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And there was a lot people that throw away from the Baltic states, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "When the Soviets occupied the Baltic states, Litwa, Latvia, you know, they threw away first the Jewish all in Asia, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, not so.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They-- they came to work hard, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't remember to.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "No, in this-- I must tell, in this, I speak about the Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I never-- nobody hit me, all the time, no different.",
      "word_count": 10
    }
  ],
