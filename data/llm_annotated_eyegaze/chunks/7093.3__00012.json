  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 50,
      "text": "And we-- and after-- I mean, at the end of the war, quite a few of these girls who managed to survive were then lynched by Jewish Jews who suffered under them.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 51,
      "text": "I actually met one who was one of the women who looked after us.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 52,
      "text": "And I  met one, and I-- well, I certainly didn't take part in any lynching.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 53,
      "text": "And I met one after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 54,
      "text": "I don't know whether she recognized me, but it was-- but perhaps I come do that a little bit later.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 55,
      "text": "I met her in Paris after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 56,
      "text": "We didn't really speak.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 57,
      "text": "We just were introduced to each other.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 58,
      "text": "And I didn't tell anyone that she was one of these women.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 59,
      "text": "[PAUSES FOR 3 SECONDS] We-- sorry, I must take a-- [DRINKS]",
      "word_count": 11
    }
  ],
