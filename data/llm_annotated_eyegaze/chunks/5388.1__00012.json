  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I mean, people that remembered the Germans from the First World War, people that dealt with Germany before Hitler, it was-- was such a nice country, you know?",
      "word_count": 28
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "But my parents must have known about it because they knew about the refugees that were dumped on Poland on the borders in 1938.",
      "word_count": 24
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And that they dumped prior citizen or something of-- of Poland, who didn't have German citizenship, and let them sit there.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And finally-- so that was a question of raising money.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "But I didn't know about it.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "I just learned it later, after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Or during the war from stories.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "At that time, I didn't know that.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Nine.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Not even 10.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "The war started, I was nine.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "I was just about 10.",
      "word_count": 5
    }
  ],
