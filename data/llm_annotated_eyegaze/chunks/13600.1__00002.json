{
  "stem": "13600.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "But you have to realize that Jewish people in Poland were so oppressed that to be leftist was very easy, you know, just to look for something that-- for redemption, so to say.",
      "word_count": 33
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "So she was politically minded, and I would say leftist, at least.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Both sisters.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Both were, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Both were like this, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, none whatsoever.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "No, of course not.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- not secular books, but books for school, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "In Poland, you didn't get, like here in school, you got all the books.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "In the shop, you sold the books that were required for school opening during the year.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "So these were the books.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if you can call it secular-- for school, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Textbooks, that is correct, and writing materials as well.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "No, both.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Other--",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Other than that, other than that were Hebrew books.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "They-- when I was born, I don't think they were alive anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, yes, yes, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "No, none of them, none of them.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "From my mother's side, some were living in Warsaw proper.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And some were living in a city called Opoczno in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "That would be about two hours, I would say, travel by train-- two to three hours travel by train from Warsaw.",
      "word_count": 21
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No, not frequently, only on occasions.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "In Warsaw, where I learned, where I studied from the age of 12 till 14, I was a boarder in the school.",
      "word_count": 22
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So I used to go to my mother's sister.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes, a Saturday afternoon, you know, for a visit-- or i used to go to my father's brother, who lived in the center of Warsaw as well.",
      "word_count": 27
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Other family lived further away with no money to go.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No, wasn't--",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Very limited.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Unfortunate, not secular whatsoever.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No, no, none whatsoever.",
      "word_count": 4
    }
  ],
