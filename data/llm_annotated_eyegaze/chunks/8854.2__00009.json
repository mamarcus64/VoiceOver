{
  "stem": "8854.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So they had-- they knew how many people has to be there.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Every day was Mengele, there.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Every day he was going around with the sticks, [? drawn, ?] like that.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Like that.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And-- and beating.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And-- and-- and-- [SIGHS] Oy, God.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And after five weeks living like that, in Auschwitz, not-- very little food.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "You know, they put in the-- in the soups medication, that we should lose the menstruation.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "We-- and a lot of people had very much cramps.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "A lot of girls, young girls they had pain and cramps.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "But they wasn't allowed to tell.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "If they would tell they have cramps, they don't feel good.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "They pick them out, and go.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "Go to death.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] One day-- hmm-- I was very sick.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "I had a [NON-ENGLISH] on my breast.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "A-- something very big, full with pus.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "And it hurt.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And I had 104 fever.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know that it's 104.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "That doctor-- the book.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I have the book.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "You want to take the book?",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I'll show you.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "We'll look at it later.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "That was Perl, Gisella.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "She is born in Sighet, where Elie Wiesel is born.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "In fact, they had a relationship.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And her name was Perl, Gisella.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "She was the Auschwitz doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And she was in our barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And I went to her.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And I cried to her, how can I go out?",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I'm so sick.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I'm falling apart.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Look.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "She says-- and she took the-- she took the-- the fever, how much I have.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Oh, she says, you are very sick.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "You cannot go out.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "But if I don't go out, they will kill the other people.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Whoever was missing, the other people was responsible for each one.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "She was living in our barrack.",
      "word_count": 6
    }
  ],
