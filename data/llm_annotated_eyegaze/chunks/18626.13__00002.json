{
  "stem": "18626.13",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 398.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I see people walking around in shorts, with the palm trees, with oranges, with bananas growing.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I said, what is it, a paradise country?",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I've never seen it in wintertime in my life, oranges growing, with all kind of things.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And my Uncle Frank with short pants, you know, with the open here.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And his son came in a taxi.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They took me-- they took me home.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he says, Morris, we are going to find you a job in Miami.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You're not going back in the cold, freezing place.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I says, I cannot.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "I must go back and tell my boss.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "He's a very nice gentleman and very nice person.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Give him at least notice two weeks, at least that I'm quitting.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He says, OK, Mo, don't make it seem as-- you're in America.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Don't make it seem as-- don't be a gentleman too much.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I cannot do that.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "I went back.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "I says, Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "Morris, I have a uncle in Florida, and he wants me to stay.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "He's a older man.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "You know, old people, you know, they want to be around young people.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "Made up, you know, a little [INAUDIBLE], a little truth, too.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And he wants me to be near his side.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "I want to leave for Florida.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "He says, OK, Morris.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "I'm glad you gave me two weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I'm going to advertise in the newspapers.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "After the two weeks, I took my couple little things I had there and came to Florida.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "Came to Florida.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "Florida was a place only for tourists, not for woodturners.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Everybody promised me, they have so much.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "Every little cabinet shop who had a-- to fix a leg once in a year says, ooh, we have so much work.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "We don't know what to do.",
      "word_count": 6
    }
  ],
