  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Then in Salzburg, we decide to pick up the kids not to let them go nowhere.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "So I went looking for the kids.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And I go in one town-- I forgot the name-- I go on the street and I see Dave walking.",
      "word_count": 20
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And then somebody told me they saw Maria.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "So I got Dave, and we go look for Maria.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "There was a crematorium there by the forest at the end.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "And I go out and holler, Maria, Maria!",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "And she heard me.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] She came out.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "They were sleeping in a-- it was a crematorium.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "There was a lot of boys and girls there.",
      "word_count": 9
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "So I got Maria, too.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And a lot of boys and girls-- were their parents was with me in-- in Salzburg.",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I went to all of them and went to Salzburg and brought them.",
      "word_count": 13
    }
  ],
