{
  "stem": "13655.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 133.2,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Some of them, we sent a Polish man after them to find out where-- where they took them.",
      "word_count": 18
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Very few came back.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "The other ones, they got killed there-- hard labor, no food.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "The labor was unbelievable-- bad.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "They're digging-- digging ditches.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "They got killed there, that's all.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They took [INAUDIBLE], so they didn't take nothing with them.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My father was-- he took sick.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't take in a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't get medicine.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "He passed away.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "He's [INAUDIBLE] man, but he passed away, normal.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "The normal time, he would be alive, if we had a doctor or medicine.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "But that time was nothing, no doctor, no medicine, and he died six days before Purim, 1942.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "He had pneumonia.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "My mother, when we was already out-- they sent us out.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] We have to come later to it, because my mother-- we went from in our town-- [PAUSES FOR 3 SECONDS] --a day-- after Yom Kippur, 1942.",
      "word_count": 30
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "There was an order-- no, I'm mixing up.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "The 6th of June, 1942, was an order from the capital.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] Like every one Jew has to come into Biala Podlaska.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "There is going to be a Judenstaat.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And we was thinking, this is the biggest lie in the world.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "The Germans, they know how to frame up these things.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "We start to run away.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "We went to Sarnaki.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "It was a different district.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "To [INAUDIBLE], we went in the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Just a very few.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Around the town, was all kind of names in the forest.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Was terrible to go away, to send the people to that.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "We sent it with Polish people, with horse and wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "At night, we used to sneak out from the town.",
      "word_count": 10
    }
  ],
