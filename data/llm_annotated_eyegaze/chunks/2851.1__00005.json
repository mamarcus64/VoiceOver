{
  "stem": "2851.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "He came into the ghetto, but the people, which they took him out for work, he went in with them and and he took out my sister with a man who should bring the bread, what the Germans-- they gave him the bread for the people.",
      "word_count": 46
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "He went-- they went with him out of-- of the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Of the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And they went--",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "He knew they're going to kill us too.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We paid him.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I had my-- my-- my Singer machine, so I gave him the Singer machine away and he did it for us.",
      "word_count": 21
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "We had it in the room.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "We brought this when we went to-- to the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "We took just the head from the machine, and the other left-- and the other half we left.",
      "word_count": 18
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "We couldn't.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Just clothes.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't took too much.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "They didn't let us.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "He took away my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "It was very, very-- it was very [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "It was very hard to go out, but we sur-- we survived.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I remember the man, but I don't remember the name.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "They take-- they took her to the Koszary.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "A man was waiting with a-- with a-- [PAUSES FOR 7 SECONDS] it was a man who was waiting, and he took us.",
      "word_count": 23
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Not a Jewish man.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Took them-- my brother-in-law and my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And I was-- and I stayed in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And the other day, my brother-in-law came to me to take me out.",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "One day.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "The ne-- the next day he came to me.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we went out with the people, we sneak in with the people they took to the work.",
      "word_count": 18
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And the people, they-- they-- they went to-- with a-- with a train, they went to work.",
      "word_count": 17
    }
  ],
