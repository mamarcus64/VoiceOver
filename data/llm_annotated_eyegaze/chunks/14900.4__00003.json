{
  "stem": "14900.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 79,
      "text": "It turned out it was an SS kitchen in a factory-- at least I believe it was a factory.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 80,
      "text": "She marched us in past all these security doors, took us to a closet-like room-- no windows.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 81,
      "text": "There were buckets of potatoes and water, peeling knives, and little, tiny, like, milking stools.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 82,
      "text": "We were told that was our job.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 83,
      "text": "We were to peel potatoes for the SS kitchen.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 84,
      "text": "She looked-- I mean, I was terrified of her.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 85,
      "text": "We all were.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 86,
      "text": "We were sure she was taking us to an extermination camp-- locked the door behind her.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 87,
      "text": "A few hours later, she came back, and she said, shh.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 88,
      "text": "She had a  big bowl of hot soup for us.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 89,
      "text": "She told us not to eat the potato peels, because they really watched closely as to how much was missing.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 90,
      "text": "She could have been killed for that.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 91,
      "text": "Eventually, as she sternly marched us back and forth to our labor camp, she proceeded to tell us the reason she selected us-- because we looked so young, and we were the ones in need of saving more than the others.",
      "word_count": 41
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 92,
      "text": "She wanted to give us a chance.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 93,
      "text": "One day, as we are marching-- hup 2, 3, 4 [NON-ENGLISH]-- she isn't taking us to our camp.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 94,
      "text": "She took us to her apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 95,
      "text": "She decided we needed a warm shower or bath.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 96,
      "text": "She even bought us raincoats-- little-- nothing-- little plastic, vinyl-- whatever.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 97,
      "text": "Well, my utopia lasted three weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 98,
      "text": "They had taken chest x-rays, because we were working for the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 99,
      "text": "Mine came back TB.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 100,
      "text": "So I was told I was going to the hospital.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 101,
      "text": "Well, I knew what that meant.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 102,
      "text": "I was taken to a hospital-- kept in isolation with five other women.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 103,
      "text": "I don't know who they were-- a Hungarian, a gypsy, a Russian, me.",
      "word_count": 13
    }
  ],
