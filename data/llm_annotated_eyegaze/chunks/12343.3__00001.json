  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And I said, you know, [GERMAN] in Deutch, and I told him.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "You told me to go in the barrack.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish officer send me back.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Go back.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Then he lost me there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Then I was out, back alive.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I fight.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You never going to believe it.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "That's the truth, that sometime I've met the Jewish-- because they send me out back?",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "For what?",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "Let me ask you something.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "You said that the girls called you [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they call me [NON-ENGLISH] they call me [NON-ENGLISH] It's easy for them to call me [NON-ENGLISH], Schulum Moishe.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In the shul they now say that they call me [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "In the lager, they used to call me [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "What a difference.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Both names is my name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I took over [INAUDIBLE], well, they're both my name.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I show, I got the-- the man in Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, jumped off the line, then they send me back to the beginning of the line, to save life, and then left over.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I stay alive.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "After all, they looked for the clothes later on.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Later on.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And took me away from over there, and took her from this place.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "It's [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Sulejow [NON-ENGLISH] They make it over there, pentagram.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You know, the German calls pentagram.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They built big ditches against the [INAUDIBLE] go through this.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And this, over there, I work.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And they saw me.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They told me for me to work, is work.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "They said, you know that if you want, you tell them to make it smooth, this and this good.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He told them about me.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You know, [INAUDIBLE], they took me away from the work.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And I sitting and work.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And work, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Rather than dig the ditches.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And he helped me out.",
      "word_count": 5
    }
