{
  "stem": "6076.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Before Shabbat was a big, big job at home, especially in our home.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "As we were all orthodox, we all took pride on Shabbas.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Sabbath was the most wonderful day that we could enjoy-- all day long, all week we went to school.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We hustled.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "My father worked.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My mother was busy crocheting, and cooking, and washing, and mending, and this, and this, you know, cleaning the clothes with benzene those years.",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have cleaning stores.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Everything had to be made by hand.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So preparing for that Sabbath-- the cleaning my father's hat-- velvet hat and cleaning his-- his wardrobe and this and that, and preparing that velvet yarmulke you had to clean with that benzene.",
      "word_count": 33
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And it took place on a Thursday.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We prepared the shopping on a Thursday.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "We had a-- a market.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "What do you call it?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "This was every Thursday.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH] lasted for a few hours, from morning to 1 o'clock.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Most of the people, most of these handlers, they came from the farms.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They brought eggs, chickens, live fish, sour pickles, apples, onions, [NON-ENGLISH], potatoes, carrots, whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was everything you could buy.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "The only thing you needed is money in any place.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In Poland before the war, there wasn't such a-- you know, you could buy everything.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "You could buy chocolate, and halvah, and oranges from everything, whatever you want.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But the only thing that you needed is money.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "The people who had money lived beautiful, lived relatively the same like in America, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And for us, it was a little difficult.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "My father-- you know, it was very difficult for us to-- because we were a household of-- without my sisters, they were married-- they [INAUDIBLE] six of us ate together.",
      "word_count": 30
    }
  ],
