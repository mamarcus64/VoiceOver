{
  "stem": "393.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We lost weight.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "When I saw-- you see, we saw ourselves in the other one.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Because there wasn't a glass or a mirror.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "When I saw a friend of mine with whom I was in Guben, after just three, four weeks, I couldn't recognize her-- just the two big bones-- bones all over-- bones over-- bones here-- just bones, just bones.",
      "word_count": 38
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I got scared.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "That's how we looked.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "You know, I became flat completely-- flat-- flat like a table.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I always thought-- ah, as was a woman, after all-- I always thought, would I ever have breasts again?",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "What's-- what's going to-- till nothing, nothing, nothing-- flat-- although, I am bony, anyway.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I had big bones.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Everybody was like that.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "Bergen-Belsen-- there, it was dirt, and louse, and sickness, and no food-- nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "It was-- it was worse than-- than Dante's-- what is it called?",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "I don't know that.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "It's-- it's a famous-- it's a very famous-- anyway-- purgatory-- Dante's purgatory.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "But you-- you--",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was with 10 people always together.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "They were my cousins, and they were my closest friends.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "One of them-- we became so close-- Elizabeth [NON-ENGLISH]-- so close, that we were like a-- like a role model to everybody, because it was so harmonious our-- our being together-- and so close.",
      "word_count": 34
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And-- but she said, I'm not going to survive that.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "She told me everything you-- my husband is-- I'm sure he's surviving.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And you tell him that this is there.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And that is there, and where we hide certain things, and so.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I laugh at him.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Look.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "I tried to-- to-- to put-- I was the strongest, somehow.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "But she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "But other ones-- I had a cousin, a very close cousin.",
      "word_count": 11
    }
  ],
