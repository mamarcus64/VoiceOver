{
  "stem": "5644.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "On the spot.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "We been telling the people, from the very beginning, what we-- when we knew about Treblinka, end of 1941, beginning '42.",
      "word_count": 21
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "But the, the older people, and the religious people, said to us, that we are bandits, not liberators.",
      "word_count": 18
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 3,
      "text": "You are bandits, and this is a sin to kill, and to go around killing.",
      "word_count": 15
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 4,
      "text": "We shouldn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "Because we are only making the Germans nervous.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "They kill all of us.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 7,
      "text": "We tried to explain.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 8,
      "text": "We tried to say we've been bandits and murderers in the eyes of the older Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 9,
      "text": "Older Jews, I say from 47, 48.",
      "word_count": 7
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 10,
      "text": "That's to me old at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 11,
      "text": "They didn't let us do--",
      "word_count": 5
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "From 45, 47 years age.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Age, up.",
      "word_count": 2
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "They didn't let us do anything.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want us to do anything.",
      "word_count": 7
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "We did have in our-- first of all, we did have, in mine opinion, what I got from some books, and from a little bit of knowledge from inside, I think we been about 400 plus.",
      "word_count": 36
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "The ZOB was about 800 plus.",
      "word_count": 6
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "Double.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "The ZOB was the strongest organization in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Cleaning up with the people which are working for the Gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Cleaning up.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "Do you mean?",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Cleaning, that's mean killing the people work with the Gestapo.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "Taking notes, and preparing ourself for a final, for a final fight with the Germans.",
      "word_count": 15
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "When that will come, we didn't know at the beginning.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "But we are prepared of anything it will take the Germans with their connection to clean up the ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "That mean we got to get out.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "We got to get out.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "We've been training always in the cellars.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "We never used real bullets, never.",
      "word_count": 6
    }
  ],
