{
  "stem": "25423.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I left Katowice when I was about three years old.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "So my memories are rather vague.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I moved with my parents to Lwow.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I pronounce the name of the city in Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It would be, probably, useful if I will indicate that the city in Polish is Lwow.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "In German, it is [?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Numberg. ?] In Russian, it is [?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Lviv. ?] In Ukrainian, it is Lviw.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Lviw would be spelled L-V, like in Victor, I-W.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "That's the way it's spelled and pronounced, but in Ukrainian.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Well, I have very few recollections from Katowice as a child.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "But I distinctly remember my father being greeted by the community in Katowice.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And quite a number of people came to the railroad station to say goodbye to my parents.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Lwow on a street called [INAUDIBLE], 3rd of May, number 7.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "It is the day where the Polish [INAUDIBLE], an equivalent of Congress, has accepted, a-- formally, a constitution-- a new constitution which is called the Constitution of 3rd of May.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And it is modeled, somewhat, on the American Constitution, or related.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "You got me, but I would assume it's 1796 or '95.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I lived in a apartment house which was built, probably, at the turn of the century-- as Lwow was an administrative center of Austro-Hungary, of southern Poland.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It was a house quite similar to the ones you find in Vienna, or equivalent of Park Avenue, in New York.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My father had his office there, his library.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And there were living quarters.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "To my recollection, there were about seven rooms.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My father, my mother, [PAUSES FOR 5 SECONDS] my younger brother was born there, at the time when we lived in Lwow, and shortly after we arrived.",
      "word_count": 27
    }
  ],
