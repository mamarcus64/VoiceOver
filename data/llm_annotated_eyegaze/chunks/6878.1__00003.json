{
  "stem": "6878.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Our home, we had quite a nice house.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Our house was the only house in the shtetl with an iron roof.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "The other houses were thatched roofs.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And we then opened a bakery, and my sisters and brother-- one brother, especially-- and myself, we used to work in the bakery and help in the bakery as much as possible.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But most of it was my older brother, Simon, which he is not alive anymore, and the two sisters, Faga and Tybie.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "These two, They were the main bakers from the family.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And we had a big garden.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "My mother used to work in the garden most of the days, and we grew quite a lot of cucumbers and fruit, and this and that, and we used to sell them and make a living off, out of that.",
      "word_count": 40
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "That was the living.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "We had a cow, and milk and cheese and everything was there.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And we lived quite-- until--",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Chava.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Chava.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Also Chava but Pogir was afterward, Chava Pogir.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Friedman.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Friedman, sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Friedman.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And in 1935, I went into Lithuanian army.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was in Lithuanian army for a year and a half in the cavalry.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I was the only Jewish boy amongst 180 Christian guys.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And nobody knew that I'm Jewish, because I looked blond.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "My language was good.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I used to speak Lithuanian, Polish, Russian, German.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "We had some, all these people in the army.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And after I finished the army, I came back home, but I didn't stay long.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And I went to Kovna for a job.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I got myself a job in Kovna.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I walked to Kovna, 105 kilometers, me and a friend of mine by the name [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "We walked it real fast.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "It took us two days, 105 kilometers.",
      "word_count": 7
    }
  ],
