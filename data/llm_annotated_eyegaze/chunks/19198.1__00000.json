  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I am Alfred Wolf, A-L-F-R-E-D W-O-L-F.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born and Eberbach, E-B-E-R-B-A-C-H, in the state of Baden in Germany on October 7th, 1915.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father is Herman Wolf, who at the time was in the trenches of World War I.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He was a co-owner of a-- of a clothing and-- and dry goods store which had been founded by my grandfather, Benjamin Levy.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So the name of the firm was Levy and Wolf, and they were a major part of the commercial life of the great city of Eberbach, which at that time had a population of about 7,000.",
      "word_count": 36
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "The [BACKROUND NOISE] Jewish population, about 10, 12 families, maybe 30, 40 people.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I am-- I'm not sure of the exact number.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name-- maiden name-- was Regina Levy and she worked with my father and my grandparents in the dry goods store.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I remember fairly well back to the early '20s.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "There's one memory which probably is induced, rather than really remembered, namely that when my father came back at the end of the war in a dirty uniform and a beard, I said, I want this man to go away.",
      "word_count": 40
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Then I was four years old.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I'm the only child.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I think my grandmother and my-- my maternal aunt, Aunt Jenny, were the always available babysitters.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I also spent a good deal of time with my grandfather, who probably influenced my life as much as any other member of the family, including my parents.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My grandfather's name was Benjamin Levy, called Benny by his friends and by the-- by his wife.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And he, apart from being the founder and the-- and still the joint owner of the dry goods store, he also could do just about anything that he wanted with his hands.",
      "word_count": 32
    }
  ],
