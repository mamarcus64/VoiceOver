  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Because I was ashamed, because I was afraid that it will be happen the same situation like in the other prison, that they will treat me in the same way if I say so.",
      "word_count": 34
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And he said, oh, don't worry, don't worry.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But you are young.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "You'll stay alive.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "The war will be not forever.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Oh, I like it very much that somebody said me in this way, especially when I was completely strange at these cells.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Later, at the same, I met from Torun two gays.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "One is [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Janusz ?] M, and the other was [?",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Zbigniew ?] Z.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "Probably-- I know that [?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Janusz ?] M Probably is no more alive, because when I went to Torun.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I visited my parents, unfortunately, in the same old flat.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Because even after the war, they never received again our nice flat.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "First took German, our flat, and then took Russian soldiers, the flat.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And my poor parents, they had to stay to the end of their life in this very bad house.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So when I visited them during the Christmas or all the holidays, I went also to th-- and I met once this [?",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Janusz ?] M.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "He was working in a house-- oh, [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But it was no more [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It was Polish government stock store, and he was working there.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And once, I went also with my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I told him, come on, I will introduce [?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "Janusz, ?] when you would be in demand.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Because in Poland, material was always very bad.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Maybe he gives you something as we call [NON-ENGLISH SPEECH].",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "It means only as a connection for somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And he used of this very often.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "He told me [?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Janusz ?] was very kind.",
      "word_count": 5
    }
  ],
