  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 9,
      "text": "There was plenty time-- plenty problem before I get a room, before I get what-- it was very hard to get a-- a place to live.",
      "word_count": 26
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 10,
      "text": "Then I find a place that was like a grocery, a front-- a front room and a little room on the side, in the back, a little kitchen.",
      "word_count": 28
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 11,
      "text": "And I was lucky I get that room.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 12,
      "text": "I put me in a little Frigidaire.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 13,
      "text": "And I was looking for a job.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 14,
      "text": "I find a job right on Watkins Street, right there next door with that man with the pickles.",
      "word_count": 18
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 15,
      "text": "They want to kill me.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 16,
      "text": "They-- they-- they-- they-- I worked with black people.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 17,
      "text": "And I would have to carry barrels to give him.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 18,
      "text": "And he took a barrel, he jumped on me.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 19,
      "text": "That guy, the black man, and I was-- get very mad.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 20,
      "text": "And I jump out from that hole.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 21,
      "text": "And I took him.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 22,
      "text": "I want to kill him.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 23,
      "text": "I want to kill him.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 24,
      "text": "I was choking him.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 25,
      "text": "He was black [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 26,
      "text": "And everybody comes to me to hold me up.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 27,
      "text": "And I explain him why.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 28,
      "text": "He took a barrel, want to kill me.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 29,
      "text": "Then after that, nobody was touching me.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 30,
      "text": "They was talking, don't you  touch that refugee, that one.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 31,
      "text": "After that, I was looking for another job.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 32,
      "text": "I find-- I find a job, a butcher.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 33,
      "text": "And a butcher couldn't make a living, then three days a week.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 34,
      "text": "Then I find [INAUDIBLE] veal market.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 35,
      "text": "I was making out good.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] veal market, they call it.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Calfs.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "They're boiling calfs.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "And I was making $190 a week there.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "It was a very good job, very-- I was working hard.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "I not afraid from working hard.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "And I was making some time, with overtime-- I don't work Saturdays, Sundays, sometime.",
      "word_count": 14
    }
  ],
