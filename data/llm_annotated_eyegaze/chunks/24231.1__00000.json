{
  "stem": "24231.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Sidney Taussig.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "T-A-U-S-S-I-G.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name was Zeenek, Z-E-E-N-E-K.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The last name was Taussig, again.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I am 67 years old now.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "October 17, 1929.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Prague, Czechoslovakia",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My-- I lived with my grandparents originally, and my grandfather was a very orthodox man.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He was a, a butcher, a kosher butcher.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And-- --my father also was a butcher by trade.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "At the time, people with trades were professionals.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So he had to take four years of apprenticeship to become a butcher.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "When he married my, my mother, he still stayed with the-- helped my grandfather.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "But later he started to do contracting.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He bought himself a couple horses and then another pair of horses.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "He had four pair of horses, and then he started with trucks.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And he developed full-- became a full contractor.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And he bought out the house from my-- from my grandfather.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And we stayed in the house, and my grandparents lived across the yard in a-- in a small apartment.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "In 1935, I, I was just about to start school.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "My grandfather died.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And-- --because my grandmother was alone, I used to sleep over with her so-- because she was afraid.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "So I used to sleep with her.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "Then I attended-- I attended grammar school, which is five year in, in Prague.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "This, the area where we lived was outside-- on the outskirts of Prague.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "It still was Prague but it wasn't center off Prague.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "And there were-- it was a mostly Christian area.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "There were-- there weren't any, any Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "So I was brought up in a non-Jewish environment really.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "And I went to a public school.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "My-- most of my friends were Christians.",
      "word_count": 7
    }
  ],
