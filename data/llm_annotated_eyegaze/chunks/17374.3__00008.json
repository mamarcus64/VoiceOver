{
  "stem": "17374.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "But it was.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And we knew that there wasn't an danger of life danger.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And in the beginning, we have bread.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "It was cut in eight pieces.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "Eight of a the lot of bread for each of one.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And soup.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And coffee in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "[PAUSES FOR 3 SECONDS] And-- when-- it-- after this Birkenau, and after-- it was good comparatively.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "Later on in Brunnlitz, it was less and less food.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "Much less food.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "I know that I didn't know what to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "Whole portion at once or-- I start to keep it for later on, but I never have enough time, enough will power.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "I ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "And my husband started to play again.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "He got his accordion in Brunnlitz.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "And he play for Schindler, for his party.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "I didn't know about that, but I knew that he'd played.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And he gets sometimes sausage and sometimes piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And he brought to me these things.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "And it was funny, that Regina-- that was my husband's sister-- he didn't [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "She didn't get used to that I'm his wife.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "That I'm the one who's supposed to get this, and then I share it between my other sister-in-law, Niusia, [NON-ENGLISH], all of them.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "I have to share it, that piece of sausage between us.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I know it was Pesach once.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And some of the Jews, I heard of this.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I knew they got some even matzoh that Schindler give-- find somewhere for them.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "He was-- Schindler was coming on-- I never knew-- Emilie Schindler was there as well.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Schindler's wife-- but we haven't seen her much.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "She was behind.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "She was in the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "She was helping.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And he was a smoker.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And he smoked cigarettes.",
      "word_count": 4
    }
  ],
