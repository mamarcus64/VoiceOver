{
  "stem": "4272.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And as a matter of fact, my-- my husband as a young man, we had a place in Plozk what they called [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "It was on a high mountain overlooking the Vistula River.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And we were walking back and forth or sitting on the benches and talking, and somebody stabbed him with a knife inside, through his winter coat.",
      "word_count": 26
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "He carried a scar for the rest of his life on his back.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Was anything said?",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And we-- we felt it.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We really felt it all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Did they say anything when this happened?",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No, they just did it and ran.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Was your family aware of what was going on in Germany in the '30s?",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah-- oh, after Hitler came to power?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I'll never forget my mother reading-- reading the morning papers and crying her eyes out because of what went on, especially when the Jews, when they started transporting them into Poland.",
      "word_count": 31
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "The-- the Polish citizens, so to speak, the ones what were not born in Germany, and they-- and they brought them by train to [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And-- and I'll never forget my mother's-- constant.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Every morning, she opened the paper and she was crying.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "We were quite aware of what's going on.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "What happened to these Jews that came from Germany?",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Did any come to your town?",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, not to my town.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "My town, we didn't have any.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "What were your activities when you were a school girl?",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Did you join any organizations?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I belonged to [NON-ENGLISH] and-- and to [INAUDIBLE], which was a social group.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And that's about it.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And schoolwork.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Are these Zionist groups?",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The-- the [INAUDIBLE]?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "That was a Zionist group.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Were you interested in going to Palestine?",
      "word_count": 7
    }
  ],
