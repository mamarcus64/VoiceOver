{
  "stem": "22750.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "In the worst time, even in war time or something, in any worse time, yes.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And like I will tell you, it came to mind.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "You don't ask me.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Maybe it's not necessary.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "When I went for to pick up something in a bigger city, the city was Dubno.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And I went there, and I came to the city.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "It was already, they called in that time, in their language, Aktion.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "Aktion means they kill Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "And I left the horse and wagon and went.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "I was walking home because I find out in the beginning from the city.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And this is not stories.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "This was the life, this happened in life.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I find-- when I came to the city to pick up something, to find somebody, I came on the beginning.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "There's something-- and find the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They called it at the time, razia.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Then I went.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see nothing because my eyes, in that time, even didn't look right.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Scared dead.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "This is not a good, you know, way of thinking.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Like I told you, and I want to also mention-- but it's necessary to mention the name.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I was always talking, at that time, not like today, in my life and in my mind.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And I was a little bit organized.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I thought at the end is waiting.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "Bad.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And I was also-- I don't want to take the credit, between myself and other people, we're going to go out in the woods to be a partisan.",
      "word_count": 28
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "You know, like the partisan came after.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "To go to the wood.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And they asked me, you have a wife, the other young-- I was young at the time.",
      "word_count": 17
    }
  ],
