{
  "stem": "2074.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "But nobody told me for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "So they kept the secret.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "So I went with the baby one time to the-- to the German leader.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Somehow, I got through everybody to the biggest leaders of the war with a question.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to know in which prison my husband is going to be.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So they look at me, look at the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And they were laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They said to me in German, in German, don't worry, honey, you're gonna go real soon the same way with your baby.",
      "word_count": 22
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "Don't look for your husband.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "You're going to do for you-- showed like that-- you're going to have it just like that.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He thought I don't understand.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "You're going to have the same.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So I didn't know that he was already killed until one time, a friend of mine comes in, a non-Jew.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "She looks at the baby, starts to cry in the beginning.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And she said, the baby already doesn't have her father.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Her father was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I say, what?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Wow.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So she said to me, go to the rabbi.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "So she stayed with the baby.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And I'm walking.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I'll never forget that drops of rain right on my-- I come in.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And the rabbi sits down and tells me the story from beginning to the end.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "The rabbi's wife came in and yelling, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "This is the wife.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Why did you tell her?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I said to her, don't worry.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I do wanna know.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So my mother tried for months to bring my husband out from that grave and bring him to a Jewish cemetery.",
      "word_count": 21
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know what she was coming for.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "But she was all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "But they lived in the suburb, you know.",
      "word_count": 8
    }
  ],
