{
  "stem": "1918.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "It was 4 and 1/2 weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And we arrived on the very day the war ended, on May 8, 1945, making us a very historic presence.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We came here, and we had a very-- we had to be housed.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We arrived on a Thursday afternoon.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We arrived originally on May 8 in Newport News, Virginia on a beautiful day, then it started to rain.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we arrived in-- the boat continued on to Baltimore, Maryland, and we arrived near the end of the day, which was Thursday.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And we were taken off by an organization called-- whatever, some women.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "So the FBI took us off and took  us to the home of the most prominent citizen, who later became the Solicitor General of the United States, Simon E.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Sobeloff.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And he guaranteed-- you know, he took responsibility for us, and we were housed in his magnificent home.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And he got on the telephone, and he tried to find a man named Menyhert Katz in New York, and he couldn't find him.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "He was a judge then, and he  had influence.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And there was no way of finding a man listed Menyhert Katz in 166 Ross Street, Brooklyn.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "That's all we remembered, because that was my aunt's address, and he was living with his sister.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And he couldn't find him.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And finally, he got tired of the whole thing.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And he told the operator, operator, you don't understand this.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "These three kids survived Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "You know what Auschwitz was?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "You know what Auschwitz is?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And they're here in America, and they're trying to find their father.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And you've got to find a phone number at that address.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And he says-- she said, there's no such listing.",
      "word_count": 9
    }
  ],
