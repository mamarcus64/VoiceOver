{
  "stem": "7832.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 38,
      "text": "It was so horrible.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 39,
      "text": "At that time, we were still able to distinguish how bad or good it was, because we weren't-- we-- we weren't that hungry yet.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 40,
      "text": "And we had-- they gave us a bowl, a little bowl.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 41,
      "text": "If you lost your bowl, you didn't have any food.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 42,
      "text": "So if people didn't have a bowl, because some people didn't get to get a bowl, what they did is that they gave us a bucket of soup that was for the 10 people that were in the-- in the bunk.",
      "word_count": 41
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 43,
      "text": "And we each had to share that, so everybody took a sip and passed it to the other one.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 44,
      "text": "And we sipped and we passed it around.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 45,
      "text": "And God forbid somebody took a bigger sip.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So, my cousin, she didn't want to live.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "So her sister-- her name was Faigy and my father's cousin's name was [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We used to call her, you know, [NON-ENGLISH], 0 like an aunt, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And she-- we used to give up our sip and give it to her so she can live.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So we-- we were-- we were hungry most of the time, trying to keep her alive.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "But she died.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "She died in a very short time.",
      "word_count": 7
    }
  ],
