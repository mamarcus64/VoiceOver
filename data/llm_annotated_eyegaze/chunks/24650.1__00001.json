{
  "stem": "24650.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And they would get food Friday night, Saturday in the morning, Saturday in the middle of the day, and Saturday at night.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And Hachnosas Kallah, this was for helping young people to get married, to get them work, to get them where to live.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Then he was the vice president of a-- a hospital called-- [PAUSES FOR 4 SECONDS] [SIGHS] [PAUSES FOR 3 SECONDS] not the Jewish-- I forgot the name.",
      "word_count": 27
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Vilna.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We had two Jewish hospitals, the Jewish Hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And the other one, I don't remember the name.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "There were he was vice president.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "So he helped out for the poor people, through the Kehillah.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Kehillah was the place where all the rich people sit together and think how to help the people who don't have nothing.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So my father belonged to them.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And my mother helped out, too.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "When it was a concert, in the city, she would sit and sell the tickets.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "What was her name?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Sonia Kuricki.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "When she was younger, she was the director of all homes for the children who don't have parents, after the First War.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And then she got married.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And she didn't work anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She came from a very rich family. 99% of the family were doctors.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] That's all.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We had actors, painters, writers, poets.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We had everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And everybody would come to see my father's pictures.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Not what he did for people, just what he did for people to sell.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He sold.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But not too-- very much, because Vilna was a very poor city.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have an industrial city.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We had a couple of factories.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "That-- they had over 600,000 people, from them, 86,000 Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I know we had a couple of leather factories.",
      "word_count": 9
    }
  ],
