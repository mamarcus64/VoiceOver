{
  "stem": "294.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I was married to Poldek already, so I could stay, but my mother-- they-- in those days, they left-- they let the people to choose the city or town where they wanted to go.",
      "word_count": 34
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And my mother chose Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "This was all within the-- the so-called Generalgouvernement.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "You couldn't go to the city of Lodz, because this was this Deutsches Reich proper.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "This was Germany proper already.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "And Generalgouvernement was the occupied territory.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "So she could choose, and she chose to go to--",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "--Warsaw.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "My mother was born in 1889.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "So in 19-- when she died, when she was killed, she was 51.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "She went to Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "She had no one in Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "She made some friends, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And twice we were able, on a special permit, to visit her.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And going there, it was absolutely evident to us that this is a death place.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "You know, the-- the ghetto was not even close.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "This was the area on which they made the ghetto, later on.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto wasn't even close, but death was lurking from every corner.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "People were already hungry, because there were thousands of people that the Germans threw out of the smaller towns, villages, cities.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And they all brought them to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And the people were already hungry.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "They were not dressed.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "The-- the-- the living conditions were terribly crowded.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "The conditions were much worse than in Krakow, in that-- at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    }
  ],
