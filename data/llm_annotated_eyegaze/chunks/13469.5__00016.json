    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And there was no-- there wre hospitals, but there was no doctors, or medicines, or-- or anything like that.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So people didn't really get better.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And-- and it was really later in 1944 when things really began to get worse, when all these people from the east-- from the camps that were being overrun by the Russians-- came to Belsen, including the commandant, Josef Kramer, SS captain Josef Kramer.",
      "word_count": 44
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "He had been the commandant at Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And all this team of SS people-- Irma Grese, the woman-- they all came to Belsen in December, 1944, and Belsen became a real concentration camp, and things really got worse.",
      "word_count": 31
    }
