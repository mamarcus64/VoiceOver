{
  "stem": "16792.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 446.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And in the morning, I was going to the Polish school, 8 o'clock.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "I came home 1 o'clock.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And I was going to the Jewish school, and I came home at 5 o'clock, and sometimes, 6:00.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "And after that-- after that, I have got a special teacher, which I was going everyday for an hour, hour and a half.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "Not too far, but-- but it was two-- two streets from our house.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "And my father paid for it, and she teach me I should pick up more from the Polish school.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "You know, because I got two schools, a little bit too much for a child like I am.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "But my-- I got a good head, very good-- I used to have.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "Now, I-- I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "But I still have.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 29,
      "text": "And, uh, we was doing all the time like that, until I was going-- until I finished the school until I was 13 years old.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 30,
      "text": "And I was going two schools everyday.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 31,
      "text": "Normally, Friday night, I meet my friends, and Saturday, I meet my friends.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 32,
      "text": "But during the week, I have not got time even to play, because when I go from one school to the other one.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 33,
      "text": "And after I come home, I eat something.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 34,
      "text": "And I must go-- I must go to the preparation teacher which prepare for me for the next day all kinds of questions, and was-- was busy all the time.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 35,
      "text": "And when I come home, even I also read a lot.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 36,
      "text": "I was reading very good Polish, very good.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 37,
      "text": "And then in the house, we speak several languages already.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 38,
      "text": "In the house.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "We speak Polish, Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We speak German.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You see, we-- we speak a lot, you know.",
      "word_count": 9
    }
  ],
