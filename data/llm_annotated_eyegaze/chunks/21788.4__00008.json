{
  "stem": "21788.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Into 53 [NON-ENGLISH] Road and lived in that one room for, for all that time.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We continued with schooling.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Shanghai was also a haven for a lot of what was called the White Russians and some of the Jews that were wealthy enough not to be communist during the take over from the czarist period.",
      "word_count": 36
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of them fled into Shanghai.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And some of them were-- had, had large holdings.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And one of the richer Jews of Shanghai was named [?",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "Kadori. ?] I don't remember his first name.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And he opened up a school for Jewish refugees in our district.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "The school was all in English.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "My sister had absolutely no trouble whatsoever in the school learning the language real fast and keeping up with the curriculum.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Not me.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I was not able to keep up with the curriculum and learn English at the same time.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So my parents took me to another school, the ORT school.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Which the ORT organization is famous all around the world of helping Jews who were lawyers, doctors, and dentists to immigrate to Palestine at that time and learn the trade that is used to more advantage in Israel, farming, carpentry, locksmithing.",
      "word_count": 41
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And that's what I did in Shanghai.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I went to school in the morning, and I learned carpentry, electricity, and locksmithing, and spray painting in the afternoon.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The language was partially in, in German and partially in English.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So I eased into this much, much better.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "That was the school I went to.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And after the war was over and Shanghai became liberated, I actually used my, my skills and became a carpenter for the American forces.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I also did some spray painting.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And that was my first job that I had when I came to Denver.",
      "word_count": 14
    }
  ],
