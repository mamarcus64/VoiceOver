  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And they were already they knew they were losing the war.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They were very frightened.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And they were very weak.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And half of the army perished in Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And they were-- still they held a grip on Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "But the Polish underground under the command of Bor Komorowski, General Bor Komorowski and other Polish high officers, who were constantly working in the underground.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "They decided because the Germans are weakening, and because the Russians are on the march to Vistula.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "Poland was divided into a suburb, Warsaw and Prague.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "That they are going-- they are absolutely on a march to Warsaw and to Berlin.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And the Germans would be running away, and they are very much weakened.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "So the Polish people, in their pride, wanted to liberate Warsaw.",
      "word_count": 11
    }
  ],
