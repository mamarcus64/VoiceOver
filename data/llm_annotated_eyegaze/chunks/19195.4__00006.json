{
  "stem": "19195.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And they desperately need me to come there because I'm the only one who has proof to prove that what happened.",
      "word_count": 21
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And I said, but I don't want to go.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "But you-- you better think about it.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I said, what are you, warning me?",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I say, you don't need to warn me.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And-- so one day, I'm just leaving the house, locking it up.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And I heard the phone ring.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "So I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And he says to me, Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "Zelmanovic.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "I says, what can I do for you?",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "He said, I want you to come to a trial.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "You're the one who has all the potent evidence.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "You want-- you don't want to help us out?",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "I said, I don't have for strength to go through anymore what I went through.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "Well, he says, we'll try to spare you.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "But please come.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "They all say that the witnesses are crazy.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 17,
      "text": "They don't know what they're talking.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 18,
      "text": "They might be lying.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 19,
      "text": "And here you're walking around with something, and you don't want to come?",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 20,
      "text": "So I called him nasty names.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 21,
      "text": "And I was really, you know, all worked up.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 22,
      "text": "And he asked to speak to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 23,
      "text": "I said, my mother is not alive, and you know that.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "How dare you hurt me after so many years.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And he started apologizing.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Please forgive me.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Please find room in your heart to forgive me.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I didn't mean to, he says.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "But people are coming, you know, to testify, and you're refusing.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "And then I start breathing in a little air.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'll tell you what.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you make all the arrangements?",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to make myself a passport, and I'm coming.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "He says, you mean it?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "I says, yes, I'm coming.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "I called my husband at work.",
      "word_count": 6
    }
  ],
