  "elapsed_s": 247.2,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "And we were taken on this train.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "We traveled about 14 hours.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "Because they were-- had to stop a lot of times because of the bombings from the British and Americans on.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "In fact, once when we arrived in Hanover, everybody out.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "And we went in-- into bunkers.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "And we held on to the greatcoats of the soldiers.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "We didn't want to get lost.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "We didn't know what was happening.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "We didn't know what-- what's going on.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "And we were holding on to them, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "You would think we would-- great.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 32,
      "text": "We can escape.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 33,
      "text": "There's bombing going on.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 34,
      "text": "We were too young to know what was going on.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 35,
      "text": "We was too young to know what's happening.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 36,
      "text": "We going back to this.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 37,
      "text": "Well we was in this train, we were fed food which I hadn't seen for donkey's years.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 38,
      "text": "Like white bread and salamis and butter, if they-- or marg, or whatever it was.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 39,
      "text": "And just had no idea what was happening, what was going on.",
      "word_count": 12
    }
  ],
