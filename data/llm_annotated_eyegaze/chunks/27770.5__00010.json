{
  "stem": "27770.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 36,
      "text": "I didn't see nobody to sneeze there.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 37,
      "text": "Maybe we didn't have even [INAUDIBLE] to sneeze. 6 o'clock in the morning comes the kapo.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 38,
      "text": "Over there there were Spanish kapos.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 39,
      "text": "If they were Jews or non-Jews, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 40,
      "text": "They was hitting and beating without the-- nervous, and screaming, Du bist nicht in Auschwitz!",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 41,
      "text": "Du bist in Mauthausen!",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 42,
      "text": "It means, you are not anymore in Auschwitz!",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 43,
      "text": "You are in Mauthausen!",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "What the different where I am?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Here is a hell and over there is a hell.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Beating for no reason whatsoever.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And taking us to a big barrack, a barrack what is, like, half a block, a big barrack.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And puts everything had to lay, everybody had to lay down on a floor.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Head, feet, head, feet, head, feet.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And came the kapo.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And covering us up, all of them, with a blanket.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And he was walking on us.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Walking!",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "One guy, he broke the nose, and one guy, he took out the eyes, and was terrible.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And you couldn't see nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "If you [INAUDIBLE], he came, he was dancing on you.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "So whatever happened to you, be quiet.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "That's how it is.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "That's your life, and that's how you have to take it.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So next day, they gave us a soup.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And came Sunday, louse controller.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Louse controller means, you have to check.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "You have to be undressed.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Just take with you your shirt, and see if you haven't got lice in your shirt.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "But he didn't look the lice if you have it here or here.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "That's how he looked.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And if he find a little, in the side, an egg from a lice, they was beating you.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "This pains what you had, you just couldn't take it anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "This was his pleasure.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So I figured, oh, no.",
      "word_count": 5
    }
  ],
