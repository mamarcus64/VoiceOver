{
  "stem": "9113.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "I'm gonna go-- first I went to Prague, to Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "Over there was a Jewish community.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "I went there to the Jewish community, didn't find nobody.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "I went-- I went to Berlin, was also Jewish community.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "I didn't find nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "There was people, but not my people.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "I was looking for my brothers and sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "I went to Bergen-Belsen.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "I found, not-- not relatives, just friends, which I used to know them.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "And I communicate from Berlin to Bergen-Belsen.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "Because officially, I used to live in Berlin with my brother.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And later, my brother find his wife-- his wife, and he married her.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "He married her in Lodz, in 1945, May the 12th.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And I used to live out there with my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "And he married my-- my-- he married his wife, and so I start off my life.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Perished?",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I did-- to be honest with you, I don't know till now.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But they told us that our-- this-- this transport went to-- to Treblinka.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They always guessed.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "To say exactly when and what, no.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I made myself a [INAUDIBLE] like [INAUDIBLE] days in HaShem, I have my [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But to be-- I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I don't know if anybody is out here.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I don't know if they're all dead.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "Till now I am sure they're dead.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Berlin, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS]",
      "word_count": 1
    }
  ],
