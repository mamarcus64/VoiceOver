{
  "stem": "18294.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 500.2,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And my father was very sick, and then they come to take the whole hospital, and shot him, all of them.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Because my husband come two days later.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "If he would come two days earlier, they would run away with him together.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And when he come, he ask, have you hear something about Kaplan?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So they told him.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "This was in Estonia.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly the name from the-- from the concentration camp.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I went from there.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "They took us to Riga.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Over there, there was a big concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "But there was-- there-- from there, they used to take the-- the what was more healthy one, and send it to work.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Like I went from Riga to Strasdenhof.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Over there we went in 2,000 young woman in this camp.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And we was staying there about nearly-- nearly a year.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And there they put us to work.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "I had a very good job from the start.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "I was working in-- in the houses-- like they're putting under the glass, these [NON-ENGLISH] they call.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "They used to have tomatoes, and cucumber, grapes-- everything in the warm houses.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And then I was working two-- two [INAUDIBLE] woman, they used to bring me every morning a sandwich.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I said to them, look, can I have a half, and half I bring for my cousin to the camp?",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You don't take nothing from here.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Because if they catch you, they catch me.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And we both lost.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "So I couldn't bring my cousin nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Then we had a-- a kapo.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She was provided with our camp in Strasdenhof.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And she said to me, look.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH], then they called, [NON-ENGLISH], if you can't bring any cucumber and tomatoes and everything was there, I take you off from the job.",
      "word_count": 24
    }
  ],
