{
  "stem": "12756.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Then, when the Germans came in and start fighting, take over Berezne, then we decided-- we used to have a big house, a two story-- to go over to my brother across the road.",
      "word_count": 34
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "He got a small house.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "Everybody's going to sit with my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Kieva.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "There was a Kieva.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Then-- OK, go on?",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Then, soon everybody left to my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And maybe two hours later, they were shooting-- the Germans was fighting together.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And they put in a bomb right in this house what I was, the whole family.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "They was killing a few friends of my family.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And I was crippled too, then.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "They couldn't find me.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "After, they-- this one's crippled.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "They took him out.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And they couldn't find-- they didn't know where I am.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And they start looking for me.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And they find that I was under the gravel when the house-- then they looking.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "They find some-- I used to wear boots, leather boots.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "And they see the boots, and they pulled me out.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "And they brought me over.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "Then about 10 miles from [INAUDIBLE], there was a village.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 10,
      "text": "And I was there for three, four days and don't know what goes on with me.",
      "word_count": 16
    }
  ],
