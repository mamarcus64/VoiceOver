{
  "stem": "3685.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Max Sitzer, M-A-X, S-I-T-Z-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born May the 25th, 1925, in a little village called Stremilcze, S-T-R-E-M-I-L-C-Z-E, and that's in the eastern-- in the-- in the Ukraine.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK. it's a village.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It-- it's got 180 families, mostly Ukrainian.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Nine-- among the 180 were 9 Jewish families in that little town-- in that little village.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we had a shul.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "My father was one of the organizers.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "He build the shul.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And every Saturday, we used have a-- a service, and holidays, too.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Every day, the shul was-- by the ways, the shul was closed during the week.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "Now we are-- my father was actually a farm.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "We have-- we had a farm of 20 acres.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "My mother-- we had a general store, which my mother looked after it.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And my father was heavy involved in real estate-- buying and selling real estate.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "I was-- before the war, I was 14.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "I was going to a Hebrew school called Tarbut.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And that was 5 kilometers from my town.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "And on the weekend, I used to come home.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "In the summer, I used to help out on the farm.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And that's how I was till 1939, till the war broke out.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "OK, I had four-- I had four sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Actually, till '39, I had only three sisters, because the fourth was born in 1941 during the-- already during the Holocaust when the Germans were there.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So I had two older sisters and one younger sister at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And then I had another sister born in '41.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "My oldest sister was born 1920.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "My second oldest was born in '22, I was born in '25, and my younger sister was born in '29.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And the fourth sister was born 1941.",
      "word_count": 7
    }
  ],
