{
  "stem": "7904.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "The [GERMAN] wasn't bad.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "We still could have packages from home.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And 1941, like I said before, my youngest sister got married.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And I still got a piece of cake.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "They sent me still a piece of cake from-- from the wedding.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And they-- from there, they sent us to [INAUDIBLE], not a camp.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "I wasn't in [INAUDIBLE] too long.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "They needed 300 young men for the Austrian [GERMAN], for the-- because the Russian-- the Russian railroad is 9 centimeter wider than the European.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "And they needed the-- the railroad for-- for the army.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So they-- they selected 300 [NON-ENGLISH], 300 boys.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Each one of us-- I was at that time about 18-- 18 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Young.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And they sent us to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We didn't go as Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We went there as [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Well, they gave us to understand that we are [GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "That means that we-- we are good.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "We are better than the other-- than the other Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "And we-- they sent us to Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "We went from Breslau, from Gross Masselwitz, from our camp, by Breslau-- Gross Masselwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "We went by-- by train, cattle-- cattle-- you know?",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And we went to-- through-- we went through Germany, through [?",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Vindler. ?] You heard about [?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Vindler? ?] Who didn't?",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "We saw the-- we saw Jews over there with big, big [NON-ENGLISH] on the back.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "They work on the railroad too.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We came-- we came to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They put us in, in a army camp.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It was not a wooden army camp.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It was from-- from blocks, from-- [LAUGHS] we're up.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We went in there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We felt a smell, a horrible, horrible smell, a dead-- dead smell, of dead people, flesh.",
      "word_count": 16
    }
  ],
