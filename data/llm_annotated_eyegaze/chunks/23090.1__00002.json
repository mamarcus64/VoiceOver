{
  "stem": "23090.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And-- my mother was one of those mothers, if I may say so, one of those Jewish mothers, who did the cooking, who did the loving, who did the caring, who did the protecting, and who did what every other good mother will do in any society.",
      "word_count": 47
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And my sister was a year older, and she was already becoming-- or starting to be a ham, as we call it today.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "She was singing and performing.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And we-- we always argued, and-- like the normal two-- competition between two young kids.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And we just had a very normal, regular existence.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And my dad was, as I indicated, a concert pianist.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "He traveled quite a bit.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And he was very, very close and was a wonderful-- is a wonderful father.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And I can have nothing but wonderful memories as a child of my childhood years.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "We had a fairly good sized family.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "My dad had brothers and sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "My mother had brothers and sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "So consequently, we had many cousins who we were able to chase around, run around, and get in trouble.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, the normal way.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "You broke somebody's window and-- playing football or-- did the very-- we got into mischief just like I can't specifically say, but the normal things that children will get in trouble, coming home late and tearing your clothes and bumps on your head and bumps on your-- where did you get that?",
      "word_count": 52
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And how did you get that?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And come home dirty with the good clothes that was just minutes before we were going out.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We're supposed to be dressed and clean.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And I managed to get into a-- into some sort of a game and got myself all dirty.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And of course, it didn't go over too well with my parents.",
      "word_count": 12
    }
  ],
