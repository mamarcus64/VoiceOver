{
  "stem": "598.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Me and a few other guys get horse and wagon.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Getting a-- a guy in his-- wherever we are belonging.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "We have to walk 40 miles to our town.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "We're going back to our town.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "So they get us [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I was and young guy, I never sit down.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "There's a few other guys there who was sitting down, they work a couple days.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And they came into our town.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Back, the Russian was there in February month.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And I came in, where are we gonna sleep?",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "So a Jewish guy says to me, [INAUDIBLE] all the-- the houses are taken by Poles, because the Ukrainian killed the Poles.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "So the Poles, the farmers, run away from the-- from the farms, and they're sitting in the city.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "You going into that house, it's a [INAUDIBLE] home.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Tell that your house, that's your uncle's house, and she will let you in.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "That's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "I came in there, and I says, I-- this is my uncle's house, and she let us in-- me and Bill, the-- the house.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "So I shared to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "What do you do?",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "He didn't have anywhere to sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "So I met another guy.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "He gave me a-- a bed.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "So I brought the bed in and me and Bill stayed in the bed.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "All the guy says, you have to register.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "They're going in the army.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "I says, I'm not going in the army.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "I'm not registering.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "The guys that registered, they calling them into the army.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "It was on Friday, they have to go in the army.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Thursday night, in the evening, I'm going in market buy a piece of bread.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "They caught me over there-- the police.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they took me to the-- to the place.",
      "word_count": 9
    }
  ],
