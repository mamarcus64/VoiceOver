{
  "stem": "20711.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "This priest made the only smart move he could make, and I'm very happy he thought of it.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He called a family friend, a Catholic family friend, who lived in another town who did have transportation.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "He had a car and he had a motorcycle.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "But the car happened to be broke down.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "But he did have his motorcycle.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And he called him during the night.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "He excused himself from the gang, and he made that call in the middle of the night to this guy and told him, could you please jump on your motorcycle and go into Miskolc and find me.",
      "word_count": 37
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "He just vaguely knew the address, but he knew something about my grand-uncle and -aunt.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And he was able to describe where I am and pick her out immediately before dawn, because they're supposed to come and get her.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So he agreed he will do that.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "He got on his motorcycle.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And he arrived.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I was already asleep naturally.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "It was around 2 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I was woken up, and it didn't surprise me because those days, so often we had to get up in the middle of the night and go to the bombing shelter.",
      "word_count": 31
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I thought it is an air raid.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "So automatically I got into my dress, and everybody's very quiet and subdued, but I thought because of the air raid.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And when we were going down, I was curving toward the shelter.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they told me, no, you have to go outside.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Somebody's waiting for you.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "But please be very quiet and don't ask nothing, no questions, just go.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I sensed the danger.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I had no more questions.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I just followed the instruction.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I recognized this guy.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He was familiar for me.",
      "word_count": 5
    }
  ],
