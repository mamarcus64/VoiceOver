{
  "stem": "2851.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And then the war break out with Hitler.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "So it was very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I went to Kowel.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "My sister lived in Kowel and we had my sister's child.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So we took him there and my sister didn't let us go to-- back home.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "With my sister.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, me and my sister, my younger sister.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And my mother and father were in Luboml.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Later the German took away my father, so my mother came to us.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, it wasn't a ghetto then when my mother came.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Later, in-- three months later, it was a-- they-- we had a ghetto, Kowel.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't go back.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "We stayed in Kowel.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Me and my sister, my mother, stayed together with my sister-- my older sister, Hinda.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The family-- the-- we-- they took out the people sometimes.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "We-- they made a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "One ghetto was in-- in old-- in the old city Kowel, and one ghetto was in the new city Kowel.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "One ghetto was on the [NON-ENGLISH] Street.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And the other ghetto was on-- [PAUSES FOR 3 SECONDS] it was-- it said in-- on [INAUDIBLE].",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They called the other side the-- the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We all-- we all-- we all have to move.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They-- I-- I used to work.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I work with the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] We worked.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They took us to work every day.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I worked in a-- [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "It was on the-- where the trains are-- on the-- oh, what do you call it?",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "The railway, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "We worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They took us to the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't go by themself.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Like, 50 people.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "They came in and they took us, and they bri-- brought us back.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "There was a fence.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And the police was watching.",
      "word_count": 5
    }
  ],
