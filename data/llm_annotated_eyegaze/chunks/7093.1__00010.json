{
  "stem": "7093.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "Buda ?] instituted a training college for girls who wanted to do nursery nurse and nursery school teachers training.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "It was a one-year incredibly intensive and absolutely wonderful training course, quite, quite exciting.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "It was really one of my best years in my life, certainly in my youth my best year.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "My father didn't want me to go.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "Now, I from quite early times, I-- from quite early on, I always earned some money.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "I made things.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "I made flowers.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "I made lamp shades.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "I made belts.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 39,
      "text": "I taught children.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 40,
      "text": "But from age of 14, I was earning.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 41,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to have some money.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And I was kept very, very low.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I was kept very low partly from-- because of my parents, my father's principles.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But I also was kept very low, because I didn't have the money.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And my father has-- had-- was very popular.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "He had lots and lots of clients.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "But most of them didn't pay.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And-- so we had-- and if there was money in the house, then it went for books and music, but not for-- not for-- for other things.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Also, for the tuition, by that time, my brother went up to Budapest to study to the music academy.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And so he needed-- they needed to support him.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And-- and I had very little money.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And so I-- and I wanted money to do things.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And I also was putting aside money for later on.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Because I wanted to go up to Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "I was not happy at home.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "My parents' home wasn't a very, very nice home.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "They fought a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And they were so very, very-- it was a highly interesting home, but not a very happy home.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "That was all the way through my childhood.",
      "word_count": 8
    }
  ],
