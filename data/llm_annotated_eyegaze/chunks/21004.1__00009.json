{
  "stem": "21004.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "We were davened by my grandma.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "And also on the holidays, because to the city was like five, six kilometers to the city, so we didn't go to the city.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "So we had our own.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "And some people came from other religious-- from other villages to us, to my grandma to daven.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "So we had sometime me and 40, 50 people, they come for our [INAUDIBLE], especially for the big holidays, Rosh Hashanah, Yom Kippur and all the other holidays, Sukkot, Shavuot, Pesach.",
      "word_count": 31
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "A [NON-ENGLISH] had to come from the city.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We had a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And whatever-- we needed chickens, so my mother took some chickens in a basket and brought it to the city.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We had-- twice a week, they had the people come from the villages, brought out food to the city.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "It was a Monday and a Thursday, especially on Thursday.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So we brought some chickens.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "My mother came to the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And sometimes when we'd have-- I used to buy little calves.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I used to deal with that too.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So brought in the [NON-ENGLISH], brought it in.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And he came and he [INAUDIBLE] me and by other family.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And I used to take the skin off and do the whole thing, you know, pulling down with the arm, the skin goes off.",
      "word_count": 24
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And then we had all kinds of food.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We had meat and everything, and with meat, other meat, like roasts and all of this.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So we had a little far distance family, he had butcher store in the city.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "So he know-- when he was giving to my mother so she don't have to watch him.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He always treat her good, but she knows every piece of meat to tell him what she wants and that's what he had to give her.",
      "word_count": 26
    }
  ],
