    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Lokshn [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Chicken noodles, that's what-- every Friday night.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And my father would get the fat, you know.",
