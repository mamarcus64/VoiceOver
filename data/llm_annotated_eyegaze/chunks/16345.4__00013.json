  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "So I learned some of this, so I went to work as a fur nailer in Kansas City for the Alaskan Fur Company.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I think I was making $27 a week, which was good money in those days.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And then I decided I needed more education, so I-- I started going to junior college nights.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I learned some typing, and I learned some other things.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And all this time, I-- I always read a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I'm a prolific reader.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "In Kansas City, I-- I discovered comic magazines.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I was 18 year-- 18 years old, and I-- and I was reading all the comics I could get a hold of.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And then several of survivors, we got together-- five of us-- and we rented an apartment, and we were doing our own cooking.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And they were always making fun of me because I was always reading-- comic books, books, you name it.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "I started in one library.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I would read my way through the stacks.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I started with westerns and-- and then started with mysteries.",
      "word_count": 10
    }
  ],
