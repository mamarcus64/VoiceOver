  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Right after-- right after the liberation, you were so weak, you couldn't do a lot.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "For instance, we was sleeping-- we was sleeping in the same place where we was working, where we was during the Germans.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So we was sleeping.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "They gave us more to eat already.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "But I was so weak that I had, for instance, I want to go out at night.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "When I want to go at night, so it was a little step.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't walk to that step.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I went on my knees.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I was so weak.",
      "word_count": 4
    }
