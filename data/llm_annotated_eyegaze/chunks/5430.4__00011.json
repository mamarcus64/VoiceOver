{
  "stem": "5430.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I guess things weren't so good, but I wanted to be with my brother, Sam.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And so I smuggled across the border myself.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "The American army was over there.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I tried once, and they stopped me.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Go back.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So I went around the other way, and I managed to get across.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And I came to my brother's place.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "He was in the U-N-R-A, UNRA camp.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And-- Want to stop?",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And they--",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He was surprised to see me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I was all by myself.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And he was a little bit of a [INAUDIBLE] there, because he was one of the earlier groups.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And he says, how do you like to go to America?",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I said, I'd like to.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So he was able to change my papers.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "He heard that the United States Committee for Children was taking children to the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And you had to be under 18, and--",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So he managed to change my age, because I was over 18, and declare me as an orphan.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And that's how I came to United States on the earliest part of 1946, in December 1946.",
      "word_count": 17
    }
  ],
