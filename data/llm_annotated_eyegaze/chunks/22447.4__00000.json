{
  "stem": "22447.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, so I told corporal to take two of our men, take the jeep, bring her in, and we'll see.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "So I check the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "She showed me a pass, which the camp commander had signed, given her, giving her permission to go to [INAUDIBLE].",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "No, I don't want that one.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I want to SS Auschweiss, which was a little bit bigger than a credit card.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They're all [INAUDIBLE] or whatever, or 1923.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] So I said, well, we better-- we'll detain her for 48 hours.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Maybe someone will come forward.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So she said, can she go home to collect some personal belongings like brush, a comb, toothbrush?",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "She wasn't short of anything.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So I said, we'll take an armed guard.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "I gave strict instructions, an armed guard.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I said, you take her to home.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "If she tries to make a run for it, you shoot to kill.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "Because we had all this.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "If you was escorting soldiers, and they tried to make a run for it during transit, you shoot to wound them, like in the leg or something.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I said, you shoot to kill.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Don't hesitate.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I'll take full responsibility for it.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "She went home.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "She didn't give us any trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "So we brought her back.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I went through the case.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "She had a case.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "She had a neatly-- she's got a black skirt from the SS uniform.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "She had all cosmetics, hairbrush, not short of anything.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I said, take her back into the, into the cells.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And tell the cook, tell the cook to give her a tin of corned beef.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "That's got  to last her 48 hours.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "Now that-- and I said to the [? woman, ?] now go back.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "If you find any friends, anyone, stand on the rooftops.",
      "word_count": 10
    }
  ],
