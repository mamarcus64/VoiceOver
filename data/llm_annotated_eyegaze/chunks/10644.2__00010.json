{
  "stem": "10644.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And here starts, you know, we-- [PAUSES FOR 3 SECONDS] I could be killed, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 7 SECONDS] The first days-- first days, it was for the Germans, you know, go against the Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "There was-- Kaunas was surrounded with forts, 10 forts.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "Seven forts was the place where they would bring the Jews what they catch on the streets.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "And every soldier-- German soldier, who wanted to excel would come to kill the Jews, for the sake, for the glory of the Fuhrer.",
      "word_count": 24
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "And they caught me.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 10,
      "text": "They bring me to the-- to the police precinct.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 11,
      "text": "And it is just an old [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 12,
      "text": "And comes a, a, a probably a higher.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 13,
      "text": "And I told, told him, the only word what I knew how in Lithuanian, a doctor, [LITHUANIAN].",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 14,
      "text": "He looked at me, made a hand.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 15,
      "text": "And I-- he let me go.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "It is one of the miracles, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I know if, if I-- if he asked me something, I wouldn't be able to answer.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I just say to him, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Believed me.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I was, you know, fine, you know, dressed nicely, et cetera.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I went to, to where I lived with my wife.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We were living in the apartment of her relatives who fled to Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "In Kaunas.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "But we--",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "But we have to go-- we have to go to the already announcement that the Jews had to go to this, this area.",
      "word_count": 23
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And on the-- until 15th of July, all Jews have to be concentrated in this area.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Bialystok was already occupied, too.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I-- it was in-- no communication.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "On the first day, they recognized I am a Jew.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I didn't had to walk on the sidewalk.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I have to walk-- next--",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "--on the street.",
      "word_count": 3
    }
  ],
