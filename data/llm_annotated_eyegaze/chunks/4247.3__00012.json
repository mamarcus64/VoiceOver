  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I received news from that, but in an unreliable manner.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "We didn't receive news immediately.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "You must understand that Hitler managed to keep things so much confused, by which I understand-- by, by which I mean that my parents, by that time, had been moved two or three times, right?",
      "word_count": 35
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Whether this last deportation move was the last one, we didn't know, right?",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "We knew that they had been moved in a major way because it involved the railway, right, not just moving from one part of the city to another part of the city.",
      "word_count": 32
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But, but whether was a major move and whether that was to Auschwitz, this we didn't know-- Mhm.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "--because, because, because they made sure that nobody was informed, right?",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So you understand, therefore, when I say that to say at this stage that, yes, I knew that my parents have been deported on the 2nd of July to Auschwitz--",
      "word_count": 30
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "--that is not a true statement.",
      "word_count": 6
    }
  ],
