  "sentences_input": [
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "We stayed with that family for a week.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "The five of you?",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 7,
      "text": "The other five?",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "The five of us.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "And he fed us.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "He hid us in his timber yard.",
      "word_count": 7
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 3,
      "text": "And when the time went on and there was no sight of anybody coming to pick us up, he said, look, I'm in danger myself.",
      "word_count": 25
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 4,
      "text": "We can't go on like this.",
      "word_count": 6
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 5,
      "text": "We have to do something.",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "What are we going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "He said, look, I suggest I'm going to buy train tickets for you.",
      "word_count": 13
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "And so he did.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "He got five tickets, and-- We'll have a tape change and we'll--",
      "word_count": 12
    }
  ],
