{
  "stem": "5516.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Somebody else was sleeping there.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no food.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how I survived.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I had food-- when I was in ghetto, I had food because on my own, I organized.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "When I worked on the airfield, I had food.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Over in Germany, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They used to give us a piece of bread for all day long.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And the bread, when they run away from the Germans, they took the bread with them back that they came over.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "The bread used to come in green, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "They used to blow.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "They used to go out the green powder like--",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Mold.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "At first they used to give, I think, allow for bread for the German-- for the soldiers got like a little loaf of bread for three people or four people.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "After this, they gave you for six people, the same.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Ah, it's no good.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how I survived.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "No-- no food, nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And after this they had typhus epidemic and dysentery.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "They used to-- near me, they used to die.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "They used to close up the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "They didn't go in.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "They didn't let us out because of typhus.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "They were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And people died like flies there, and I don't know how I survived.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I had pneumonia one time.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They had me in a little place like a hut, I think, for a few days and they just beat me up there.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They used to beat me, instead of to heal me.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And, ah.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It's-- it's a lot of trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] But I don't know, so I have to survive, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I told you before, when I started, [PAUSES FOR 3 SECONDS] the news man started talking to him and I say to this secretary from our lodge.",
      "word_count": 27
    }
  ],
