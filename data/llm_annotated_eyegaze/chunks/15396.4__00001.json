{
  "stem": "15396.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "A lot of people thought it was the Virgin Islands, but it was-- and when I was in the Foreign Legion, [INAUDIBLE] was a 12-year-old sister of my closest friend, Phillip [INAUDIBLE], and she used to wear my [FRENCH], you know, from the Legion.",
      "word_count": 44
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They would say, what is that?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And she'd say, oh, it's a secret society I belong to.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "But this doctor-- naturally, I was the only person who had Virginia on it because you weren't supposed to have.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I'd had it embroidered, and he reported it and found out where I was, and they said that I was contagious.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And our commanding officer took me to dinner, and he sat there, and he said, what the hell were you trying to do, infect everybody here?",
      "word_count": 26
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "So how long were you in the RAF for?",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I guess eight months.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Seven or eight months, something like that.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Flying, but then I-- then when I broke down-- I broke down and all-- they sent me to-- first to a hospital in England, and then eventually to Canada.",
      "word_count": 29
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And then I faked my way back into America.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I crossed-- I bet you I'm the only person who ever crossed into America without one paper, without-- only with a bus ticket.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But I did it exactly-- I knew exactly how to do it because of the experiences.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I bet I'm the only one who ever did.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I just didn't, because I left the hospital without permission.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I sneaked out one night, and I tell you, after I got about 25 meters away, I was wishing I was back in that bed, I can tell you.",
      "word_count": 29
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, about a year all together.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he came up to see me.",
      "word_count": 7
    }
  ],
