{
  "stem": "25591.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I served eight years on that school board and poured my heart into that.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I certainly don't claim credit, but by the time I finished my service as president of the school board, that school district had the highest scores of its children in the whole state of California.",
      "word_count": 35
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We paid the highest salaries to teachers.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "We had the smallest class size.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "We had a marvelous program for gifted children with a marvelous program for mentally and physically retarded children.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And in some ways, those eight years were unbelievably satisfying.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I really learned firsthand that nobody will come to you and ask you to get into public service.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "You throw your hat in the ring.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And-- and that's what I did.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "My-- my Hungarian friends, when I was first elected to Congress, asked me, quite a few of them, how did the people in your district-- and I have, you know, about 600,000 people in the district-- select you, with-- an immigrant, a Jew with an accent?",
      "word_count": 46
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I said, nobody selected me.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I selected myself.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I stepped forward, I organized my campaign, I raised the money, I ran my campaign, and I was elected.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And that's one of the reasons why I love this country.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "I mean, nowhere else can this happen.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We're gonna stop again for a minute.",
      "word_count": 7
    }
  ],
