{
  "stem": "10394.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Geinia Weinstein-- G-E-I-N-E-I-A.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I probably should have said on-- they thought that.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Geineia.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Nornberg.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "N-O-R-N-B-E-R-G.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "This is a Yiddish name.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "1st-- 9, 1st, 1914.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Now 81-- my, God!",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "This is Brzesko Nove.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You want that I spell?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "B-R-Z-E-S-K-O, N-O-V-E.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Poland.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "This was, before the war, a very small town.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And over there, I went in the school not too long.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Then we moved to Przoszece.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "P-R-Z-O-S-Z-E-C-E, Przoszece.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "How?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Over there I went into school.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Once a week I worked in store.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "You know, because it wasn't so good.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I have to make a living.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "I go in the school and once a week in the store.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I sell it-- sales.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My father was a special from the men-- the shoes-- not the boots.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "He was a special.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Not orthodox, but we keep kosher, strictly kosher.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My mother was very kosher.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And everyone go in the shul and davened every day.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It's not strictly like now the Orthodox.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And Shabbes is Shabbes.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "You make Shabbes and light the candles, you know, and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And they go in the shul, the men.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "It was like this in our small town.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, it's like this.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We work.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I worked in a house then in-- in-- then in Krakow, not in-- and it was before Shabbes, everything is cleaned; make challahs, wine, fish has to be every week-- fish-- no, and chicken soup, and the like, you know.",
      "word_count": 40
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Everything is like this in our small town.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And when they came from the shul, then we eat.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My father, my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And I wasn't married this time.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And this was in next day Shabbes, they went to the shul.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "We didn't work.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And we didn't cook in Shabbes-- no.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Oh, it's like this.",
      "word_count": 4
    }
  ],
