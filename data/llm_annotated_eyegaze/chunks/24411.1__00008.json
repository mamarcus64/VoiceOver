{
  "stem": "24411.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "They have machine-- you know, the trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "Then, another place was men.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "We weren't together.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "The men with the woman, they wasn't together.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "They just-- they just, you know, walk around.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And they picked up 10 girls, and I was with them together.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "And they put us near the wall, and big, big dogs-- very big dogs that was standing near us.",
      "word_count": 19
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "And there was the Germans standing at the other side.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 6,
      "text": "And they said, the Jews, you people, you gotta die.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "And we were standing, and they start to shoot.",
      "word_count": 9
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 8,
      "text": "We all fell down, and we was laying.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 9,
      "text": "Then I felt something like my heart start to pump.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 10,
      "text": "And I moved and I moved and I was full of blood.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 11,
      "text": "And I see that all nine of them were dead.",
      "word_count": 10
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 12,
      "text": "I touched them, and I start to run.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 13,
      "text": "I run home.",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 14,
      "text": "And I came home.",
      "word_count": 4
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 15,
      "text": "Everybody was crying, and my mother start to wash me up and to change my clothes.",
      "word_count": 16
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if I hurt.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Emotionally, I didn't know what to say and I couldn't talk for a little while.",
      "word_count": 15
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "Then I told her what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "Then the sec-- the following day, I went down and I saw my friend.",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "She was a Polish girl, and she said, you know, it happened just to you.",
      "word_count": 15
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Why don't you come and I put you in the basement?",
      "word_count": 11
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "You're going to stay there.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to hide you.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "I went down.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "And she'd been upstairs to my-- my parents' house every day.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "She brought me some food.",
      "word_count": 5
    }
  ],
