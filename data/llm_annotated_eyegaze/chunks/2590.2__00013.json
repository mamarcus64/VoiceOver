{
  "stem": "2590.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "Maybe I'll find out if my sister is alive.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "Maybe I would find out.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "And the next day, I met her.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "And she was with my husband, my current husband.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "And, you know, I felt very uncomfortable, because my husband started to ask me questions.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He became very interested in me-- not in me as a person, I assume-- in my story, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And she got very jealous.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And I wanted to go home.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Home was where that friend, Drucker, you know, by my-- my girlfriend's father.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And, she said that she has a headache.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "She wants to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And later on, he took her home.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And we became acquainted.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I met a girl, you know, people started to come from old villages, from hiding, from churches.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I met a girlfriend who survived, came back from Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "She was with her-- with her parents in Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "She came back.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And her parent and her aunt and uncle-- she was with an uncle and aunt, not her parents.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And she said, you'll stay with us.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And whatever will happen to Cilla, and my friend, it will happen to you too.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And it happened that my-- Cilla, my friend, started to-- I kept company with this fellow, Nathan.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And I kept company with Phillip.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "And we wanted to leave Russia and to go to Poland and from Poland to Palestine.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "But this-- this woman, the aunt of my-- my friend-- Levino is their name-- he said, if you want to go, you-- we'll marry you off, and you'll go.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "And sure enough, we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I was really reluctant.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "My husband, was a nice guy, but I knew him only six weeks.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And my parents had a doctor, Dr.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Ehrlich, who survived.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I came to him.",
      "word_count": 5
    }
  ],
