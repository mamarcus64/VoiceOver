{
  "stem": "9110.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And when my mother went, my sister didn't wait.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "They should call her.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "She went right away with her.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "And I went in another line.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "And my sister-in-law, my brother's wife, went with me in that line.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "We didn't know if we're going to be alive or not.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "And he went to say goodbye to our father.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "So my father said, remember.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "I leave just one child.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "Be a father and a brother to her.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "But it didn't take long.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "He was working with the [NON-ENGLISH] in the town.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "You know what's a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "And they were shot-- both of them-- nice, tall.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "My father was very smart-- very smart man.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "If they needed-- some people had some misunderstanding, they called my father.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "He should straighten them out.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "He was so good.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "He was on a [? payroll. ?] Every Sunday, he lent some people, like, 30 zlotys, 40 zlotys.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "And Wednesday, they brought it back without anything.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "He did a lot of good stuff.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 3 SECONDS] And we were 10 women. 10 women were staying.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "And men, was a lot.",
      "word_count": 5
    }
  ],
