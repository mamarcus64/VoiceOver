{
  "stem": "25773.7",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And I lived with him and his mother about one year.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And then his brothers came from Russia, told us all kinds of stories.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And then, my sister obtained a visa for me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Very-- she went through a terrific strain, and had to travel to Delhi and had to convince the high commissioner-- the English High Commissioner then.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And then-- and then the Indian High Commission, because the English were living already in India-- and obtained a visa for me to go to India.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I went to India in '94, May '94.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Said goodbye to my friends, goodbye to my cousins, who were very kind to me and very nice.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I went on my new life to meet my-- to-- to-- to start a new life with my sister in Bombay.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "It was in May '46.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I went through-- through Sweden.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I was in Sweden for a few months.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And I was in Amsterdam.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Then I had boarded a KLM plane, traveled for three days to-- we passed Rome and Cairo.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "At the famous Shepherd hotel we were.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Then we went to Basra, Karachi, and then to India, and met my sister in Bombay.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And my husband-- you see, that was like that-- she lived in Warsaw, of course.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Then when the war started, the Polish authorities over the radio said, every young person who can possibly should run away to the Eastern part.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "The Eastern part was already occupied, as you remember.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "The Russians had taken away a chunk of--",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "--by agreement with German.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "The Germans took the-- the-- the-- the-- the Western side of Poland, chunk of Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And the Russians took the big side of-- with Lviv, which has become now Ukrainian capital.",
      "word_count": 16
    }
  ],
