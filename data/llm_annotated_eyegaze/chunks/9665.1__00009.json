  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We still, even if I was born in Holland, [PAUSES FOR 3 SECONDS] I still felt not-- at that particular time, later it was different-- that I was still a foreigner.",
      "word_count": 31
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "They didn't treat the foreign Jews, or who came over illegal, the way they should have been treated.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "They should have been treated as being [PAUSES FOR 4 SECONDS] you know, refuges, people which haven't got a home.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And Holland could afford to look after them, right?",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] We were very wealthy.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Holland was very wealthy.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "We didn't have a deficit.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "We had a colony.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "You know, the Indonesia was our colony.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "At that time, they called it Nederlands West India.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "We were wealthy.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "So, but somehow along the line, there wasn't even that standing up of the Dutch Jews to help those people.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "It wasn't there.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "Thank you, Paul.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "We're going to change the tape now.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
  ],
