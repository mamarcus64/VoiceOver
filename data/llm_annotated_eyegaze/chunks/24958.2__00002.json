{
  "stem": "24958.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My son found himself always something to play with, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "This time [PAUSES FOR 3 SECONDS] a box, you know, anything, a stick, a box-- from old stockings, you make a ball.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] It's different.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It's very, very different.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "1940 Until about 1942, two years, until about 1942-- 1941, 1942, when we came to Plazsow.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I personally-- I-- my-- my husband got up there earlier [PAUSES FOR 3 SECONDS] with my boy.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I was in the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I was pregnant, and I had a-- a abortion.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "So I was in a hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I got up there.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Luckily, I went out in time, before they liquidated.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "They killed everybody in the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "They liquidated the hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Luckily, I got out of it.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I had to go.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Those were in ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to have the abortion.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I-- I didn't want to give-- bear a child in these conditions.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] So that's-- I had to go.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "There was a doctor there, Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Sternberg, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And he examined me.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And this is-- said-- and that's what's happen.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "This was for me also an accident.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We didn't-- it was an accident, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I didn't want to become in this situation.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't want to give birth either.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I probably would have never lived through anyway.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My son-- [PAUSES FOR 3 SECONDS] my husband had some connection.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "While he was in the ghetto, there was some some [NON-ENGLISH], you know?",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "You had to work for the Germans, and he was in a-- in a-- he worked for the-- for the air force, for the German air force, for an office.",
      "word_count": 30
    }
  ],
