{
  "stem": "1413.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And she was a single maiden.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And she went from sister to brother, because she had no family.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then one day, it was my father's turn to take his sister in for a while.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And that while was till she passed away.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And there's a story to that, the way she passed away also.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I mean, she passed away-- passed away-- she was killed in Auschwitz, or whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I might have it on paper where she was-- yeah, I have it on paper where she was killed.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother died in 1939 around Purim.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And she's buried in the Netherlands.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I know exactly.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "She was a sick person.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "She was in the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And she always came home.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "After one week when she was home, she died while I was laying in bed.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "She fell off-- she was sitting on the side of the bed, and I heard her fall off the bed.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "My father and me were the only ones in the house.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "[CRYING] And I heard her fall, and fell dead.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I was at the time 15 years of age.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I think it was '39.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I was born in-- I was about a month before I would turn 16.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I was still 15 at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't want to put my sisters and brothers down.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But I was the only one who mourned for a whole year.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "[CRYING] And I was a soccer player.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't do without it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So I went-- that is customary in the Netherlands, if you want to do something that you're not supposed to do while you were mourning, I went to the-- to the-- to the rabbi-- the highest in the-- in the city.",
      "word_count": 41
    }
  ],
