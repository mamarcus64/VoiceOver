{
  "stem": "5516.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "And with the money he used to send over in Panevezys in the city to hold on the-- all the Jewish institutions-- a hospital and old-age homes and orphans' homes-- to supply money to cover the expense, you know.",
      "word_count": 39
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "For holiday, they used to just come in back to the city, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "Oh, but this was good for the city.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "Well, one time-- and in Lithuania, it's like this.",
      "word_count": 9
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "A rabbi is not like here.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "Each synagogue got a rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "Each temple got a rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "He was the rabbi of all the city.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "There was 16 synagogues there.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "And he was the rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "And he was in his synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 4,
      "text": "He didn't go all of them, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 5,
      "text": "But one time when he come over, and they'd made the bases there--",
      "word_count": 13
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "--the Russian.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "So he made a speech in, in synagogue to the people.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And he say, today, he say, Russia gave Vilna to Lithuania.",
      "word_count": 11
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "But in a few days later, in a short while, for interest, United States will have to pay with the whole country.",
      "word_count": 22
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "They will take the whole country.",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "So he--",
      "word_count": 2
    }
  ],
