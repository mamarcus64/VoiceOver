{
  "stem": "14387.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "She had lived in Poland and emigrated about 1900s-- emigrate-- emigrated to Norway because of persecution.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Now she says, I'm not going a second time.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "She says, this is my home, this is where I'm going to stay.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "She said she's going to stay.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And then her daughter says, well, I'm staying with my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And I was pregnant, and I didn't want to go without my husband.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "No-- my husband, he was young, and he was brave and he said, I'm not going either.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "I'm going to go join the army and I'm going to fight for Norway.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So I said, well, I'm not going without my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "So the mother-- the married brothers all left with their families and their children.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They took the train to Orland, which is on the border of Sweden.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And Sweden, you know, allows-- Sweden and Denmark and Norway, they allow the citizens to travel, so you don't have to have visas or passports.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Well, my mother-in-law and my sister-in-law and I stayed there three days.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The husbands, they went off to try and join the army.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And after three days, we realized this was impossible.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I was afraid to open my mouth because I was British-- British and Jewish, what a terrible combination in Norway.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And they were scared to walk out of the house, so we decided we'd better go.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "We'd better follow the rest of the family.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Soldiers, that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There was no fighting.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "There was no fighting, and there was no mention of touching the Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "No, there was nothing going on.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "It's just that people were scared.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So, we got on the train-- my mother-in-law, my sister-in-law, and I left the men behind, the single men and my husband.",
      "word_count": 22
    }
  ],
