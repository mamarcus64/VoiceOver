{
  "stem": "628.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So I went through life in England.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And also, in England itself, the boys Maccabee Club didn't ask me to come.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I was a weight-lifter.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I was a bit-- I did a bit sport, but they didn't mix with me.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to mix.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So I was like a lone goy.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Even my mother being there-- I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I looked-- I looked-- I was lost.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Just I was lost.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I-- I didn't know where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Left, right, went to cinema, went this.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "My life was empty after the-- until, when I got 18, 19 years, I said, I'm not going to stand it here.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I'm going to go in the merchant navy.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I want to see the world.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So I went into the merchant navy.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I saw the world.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I went to America.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "But in America, they didn't let me in there.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I had a stateless passport.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "I had a lot of difficulties.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "In England, the English were very bad for the stateless people, with us.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "The Germans, when they had the passports, they could come back and forth.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "I used to say to the home office, I said, they killed your soldiers.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "They killed you.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And us, stateless people, you treat like this?",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "But they didn't listen.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Young boy, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "When I had-- you know, people said to me in England, Yiddish people, [NON-ENGLISH]-- don't go to Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Don't do that.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "In '56, I did-- they all have been there before me.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "When I went there, they said to me, you're much too young.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], you're much too young.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I said, too young?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "In German, I said, what are you talking about?",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "When they used to hit us in Birkenau, the death march.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "You think we didn't feel nothing?",
      "word_count": 6
    }
  ],
