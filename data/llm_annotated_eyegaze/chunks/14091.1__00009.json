  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 42,
      "text": "[SOBS] And when the house was empty and the people were out, he put the house on fire.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 43,
      "text": "[PAUSES FOR 3 SECONDS] And I presume he perish within.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 44,
      "text": "[PAUSES FOR 3 SECONDS] We start running.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 45,
      "text": "It was summer.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 46,
      "text": "It was warm.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 47,
      "text": "Somehow, I was holding my sister's hand.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 48,
      "text": "Her name is Celia.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 49,
      "text": "We ran, we ran, we ran.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 50,
      "text": "And of course, people were falling like flies.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 51,
      "text": "So many people.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 52,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] We ran.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 53,
      "text": "I didn't see my mother or my sisters or anybody.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 54,
      "text": "Somehow, I caught her hand, and I didn't let go.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 55,
      "text": "And we ran.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 56,
      "text": "We ran.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 57,
      "text": "We came to a very thick, wooded area.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 58,
      "text": "And we recognize it, because sometimes we would go with my parents, we would drive to visit certain Gentile people because of my father's involvement with buying up flax and other commodities.",
      "word_count": 32
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 59,
      "text": "When we stopped running, we were in a-- it was-- you could fall into it.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 60,
      "text": "It was water, and you had to be frightened.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 61,
      "text": "Because it was sink.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 62,
      "text": "You would sink into it.",
      "word_count": 5
    }
  ],
