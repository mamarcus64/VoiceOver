{
  "stem": "13584.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My name is Jacob Szczupak.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "J-A-C-O-B.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And last name, S-Z-C-Z-U-P-A-K.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Jakub or Yankev.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yankev in Yiddish, and Jakub in Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Jakub spelling is J-A-K-U-B.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Family nickname is Kuba.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "K-U-B-A.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I am right now 60.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was born January the 1st, 1936.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Warsaw, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The room we lived in Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The first memories I remember--",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "--was--",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Oh, here, that's why.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw, my earliest memories are the room we lived in.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The room, I remember, was divided, divided sort of a half.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "In one half was a little, little iron stove where my mother used to cook something.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I remember the earliest remember-- memories are when my mother used to knee in front of the bed and I was standing in the bed before going to sleep.",
      "word_count": 30
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I used to repeat after my mother the prayer before to go to sleep-- [NON-ENGLISH]-- and I was repeating this.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "This is my earliest memories is the apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I remember some singers used to-- beggar-singers used to come to the yard and sing.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And my mother used to wrap up some money and ask me to throw it to the person who was singing.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "The room was rented from an old Jewish couple.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They were living in a very small place, in a small room.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "They were renting the bigger room for us.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "No, they were all walks of-- I mean, Jewish, non-Jewish, it doesn't matter.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Jewish, Jewish background.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My grandparents, if I can recall, were, were Orthodox religious.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My parents were not Orthodox religious, were not.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember for them to go to synagogue, but I know they used to-- they attended.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I remember my father's family came from a little village in East Poland.",
      "word_count": 13
    }
  ],
