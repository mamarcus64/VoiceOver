{
  "stem": "8703.7",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "I would go because I had a large family here.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "My father had five brothers and sisters here in the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And I had many first cousins in the United States that I never met them.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And they never met me either.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And at that time-- and I agreed.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And it took me a long time until I got permission to come to the United States, not like today.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And, and in 19-- in the beginning of 1954, I came to United States.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "My brother was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "He felt-- he felt lonely in a sense.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "He got married.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I came to visit my brother just for three months.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I came to visit, and I was planning to go back.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "But my brother and my cousins had different plans.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They said, we-- Israel-- they called me Israel, of course-- is single.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "If we will find him a girl, then he wouldn't go back.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They wanted very badly I should stay here with them in the United States, and my brother, including my brother.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I was very, you know, close.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We were very close.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Even in the concentration camp, he was my big brother, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "He always took care of me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And he wanted I should stay here.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "Anyway, the introduced me to a girl.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And the girl was a nice girl.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And after a year-- now before when I decided that I-- that I liked the girl.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And the girl was to-- wanted to get married, me too.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And we decided I'm not going to go back to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "We applied for permanent resident in the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "It took a while, you know, through a lawyer.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "And he made legal-- legally the papers for me.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "And I became a legal resident of the United States.",
      "word_count": 10
    }
  ],
