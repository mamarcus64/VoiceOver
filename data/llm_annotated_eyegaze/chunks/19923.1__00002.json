  "model": "openai/gpt-oss-120b",
  "elapsed_s": 60.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "It was an apartment, old apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have any public toilet.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We had to go in a separate area for public toilets.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "It was a-- [PAUSES FOR 3 SECONDS] --a small apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And we call it-- all four of us, there were four at that time before my younger sister, Reggie, was born-- we all slept in one bed, two facing one way and two facing the other way.",
      "word_count": 37
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And of course, if anyone wet to bed, there would be accusatory fingers as to who was responsible.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And-- but that was our life and we were accustomed to that.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And my father and mother had their own bedroom.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "So we had two bedrooms, one for all four children and one for my mother and father.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "The stove that we had was one of those old fashioned kind, where they're lit by coal or wood.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And they had these metal circular rings that were on top of the stove and you would remove as many as you'd need in order to make the fire hotter.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "If you wanted to make the fire low, you would just add on more of these rings around the circle until it was completely closed.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "That was the way we did our cooking.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "As far as food is concerned, my understanding was my parents were kosher so that he-- my father would go out and buy live chickens and we'd keep it in the house under the bed until they could be taken to a-- a [INAUDIBLE], I think it's called, who would slaughter the chicken and we would have kosher meat.",
      "word_count": 59
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "But that was the way we ate.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "That was my recollection of Hosengasse.",
      "word_count": 6
    }
  ],
