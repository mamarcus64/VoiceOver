  "elapsed_s": 14.7,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "It was something.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "I arrived two days later on a Sunday, early morning.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "In, in Tyrol.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Yes, yes-- February 6.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "'44.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We arrived.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "You know, was tired, somehow completely washed out.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I mean, this goes without saying.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "We came into the railroad station in Imst.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "We were like 60 kilometers from Innsbruck-- I-M-S-T.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "From there, there was a 12 kilometer route-- valley-- that was leading to his, to his home.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Usually, there were buses, again, going from like this, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "So I want to say that I came.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And this is the first time that I saw these mountains with the first snow.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "It was late snow.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I thought that I am dead and I'm in heaven.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "That was this-- no other place in the world will make this impression on me.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So there were no buses.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We came.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "He brought me to his house, to his wife, right?",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And she was this German something, prepared a good dinner.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I was supposed to work with her.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "But she called me with this-- not you, but the third person, like in German [INAUDIBLE], right?",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "She didn't look at me.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "She didn't something.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And he was there on, on vacation, right, to doing work in home.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "Well, she-- I told him, listen, she doesn't give me anything to do.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I tried whatever.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "It was winter.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "And she probably thought that I was the girlfriend, right?",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And so he said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "You will go to work for my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And the-- he was near the church.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "His father came.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "They liked me.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They took me to, to t other place in the mountains something.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I worked all this time for his parents.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "In that part, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "There was one incident just the fear.",
      "word_count": 7
    }
