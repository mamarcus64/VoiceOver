{
  "stem": "16792.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I became-- I became a citizen when I came-- when I came to Voroshilovgrad.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I received papers to-- the drafting papers.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I go down there, and they draft me to the army.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I was drafted in 1941, and they send me to our group, to a city, the name is Frunze.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Frunze is a city with very warm climate in Russia.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And, um, in this city, they register me in the-- with knowledge which I have, that I speak German and different languages.",
      "word_count": 22
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "Then they put me in reconnaissance.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "Reconnaissance means not FBI, but, uh-- reconnaissance is like, um--",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In English, is reconnaissance?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "In English, is reconnaissance.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "OK, they put me in reconnaissance.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Down there, it is different.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "It is [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "In Russia, it is [NON-ENGLISH], they calling it.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And, uh, I study that.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I, uh, was attached to a certain group, and they send me to the 385th Division.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Was organizing division, these people in this particular time.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "The 385th Division, and they put me in a [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "A [NON-ENGLISH] is a regiment, regiment.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "The 1266 regiment-- 1266.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "Each division has three regiments.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "It was 1266, 1268, and 1270.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "And they put me in the 1266 regiment, and I was like a soldier from the reconnaissance group.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] After that, [PAUSES FOR 3 SECONDS] the-- when we finished studying everything, they put us to the front.",
      "word_count": 22
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "They give us uniforms, I am very good in shooting before that.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I learn-- I learn from-- from when I was a kid, I learn shooting.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "When I was in-- in school about 11-- 10, 11 years old, [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We-- we was going for sport, we was going to shooting [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And I was shooting.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I was good, very good.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "I'm good today, too.",
      "word_count": 4
    }
  ],
