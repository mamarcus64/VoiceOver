{
  "stem": "9230.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And they-- and she-- and they need somebody to guarantee for us, that we-- you're not going to fall for the government.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "The government should support us.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "She says to her cousin-- he was Canadian.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "She says, listen, you have to do it.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "That's my best friend.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "When I was sick, and I was laying with hay fever-- with high fever, high, high, in the [NON-ENGLISH], in-- in the sick room, and she gave her bread.",
      "word_count": 29
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "People stole the bread from me.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "I got under my pillow.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And she brought bread, what she got.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And she give me in-- in her-- in my mouth.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "And thanks to her, I am alive.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "They came to my daughter's wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "I went to her daughter's wedding.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "We are very close.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "And you have to do for her, and you have to guarantee.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "And they guarantee.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "I never met the people.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 15,
      "text": "Because we came to Montreal, because my cousin was in Montreal.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 16,
      "text": "And it was four weeks before the-- before Pesach.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 17,
      "text": "And we got tickets to go to Toronto.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 18,
      "text": "And I says to my husband, you know, over there, it's very close friends-- very good.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 19,
      "text": "You know, that's my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 20,
      "text": "And with her, I was in concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 21,
      "text": "And we slept one bed up on the other.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 22,
      "text": "And we are very close.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 23,
      "text": "And we live in Israel four years in the same apartment-- same rooms.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 24,
      "text": "She got one bedroom.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 25,
      "text": "I got one bedroom.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 26,
      "text": "And we got a little dining room, the same kitchen, the same bathroom.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 27,
      "text": "And we very close.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 28,
      "text": "And I says, I didn't want to move to Toronto.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 29,
      "text": "I want to stay with them.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 30,
      "text": "And now, she was mad.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 31,
      "text": "When they-- when they came out, the whole trouble, she says, you see, when you go to Toronto, we will run after you.",
      "word_count": 23
    }
  ],
