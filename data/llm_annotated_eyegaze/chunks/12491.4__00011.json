  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "To us, he was a criminal.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "When the Russian came in-- not the first Russian, but eventually a few days later came a Russian colonel-- who was actually Jewish, spoke Yiddish, spoke Yiddish, very few of us spoke Russian-- and we told him the story about who the man is.",
      "word_count": 44
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And this colonel told us look, in a few days in our administration, a group will come in and will register you.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "Whoever will be in camp will be registered.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And whoever will not be here anymore, who will die, won't be registered.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "So you know what they're going to do with him.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "And they hung him.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] Before that administration came they hung him, right in the factory.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "The people from [?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "Golashov ?] who came frozen in the car with him, they hung him.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "[PAUSES FOR 3 SECONDS] Now, we were liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "How many tapes you want?",
      "word_count": 5
    }
  ],
