  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "So we had to be very deep in that hole.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "It was a time, it was very hard.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "But the main thing was, and it happened which we find many people that couldn't breathe, or the bundle just gots from one place to the other place.",
      "word_count": 28
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And to go out, was impossible.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "You understand what I said?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "It was very horrible.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "In that same barrack, in the time I worked, we took out over 30 people killed.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They died in the bundles?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "They died.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "From they had no air to breathe, because the bundles [PAUSES FOR 3 SECONDS] moved from place-- while they went down, they moved from one place to the other, and they covered them.",
      "word_count": 33
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Nobody could do for us.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Once you went out in hiding, you couldn't go back to the barrack.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They was all, you dead or you disappear.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Go back to the barrack?",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "That was no way to do it.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And nobody did it.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We decided after they killed those five people, and they let me off.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And I know they will-- eventually, they will take me too, and those two others.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Because we were in the group.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And we were sleeping together.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 5 SECONDS] At that time, I decided that I have to do something, something to do was to escape.",
      "word_count": 21
    }
  ],
