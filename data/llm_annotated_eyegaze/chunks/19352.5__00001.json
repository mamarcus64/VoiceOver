{
  "stem": "19352.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 24.4,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "It was a booth like that.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And my eyes was terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "No doctors, no anything.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "At the beginning, I put some water in it.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And-- and the-- and then they gave me a guard from the camp-- [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And he went with me to a doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And the doctor said, no, I am not-- for free, I'm not going to do it.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And the guard said, if you're not going to do it, I'm going to kill you.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "So he took out with a magnet my metals from my eye.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "When he turned back with his hand, he touched my eye, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And they-- he had something there, because the whole time he works there.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Did it, and he let me go.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He took me home, back home, back.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "No, it was these two places there.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The third one, Czestochowa--",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "--evacuation.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It was in September of 1944.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We were going to Czestochowa.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And the Red Army was on the Vistula.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "They select us to go.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We go-- around with machine guns, and the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And they took some to Germany and some to Czestochowa.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "The rest of the inmates.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "About 7,000 went to Czestochowa.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "By train, 120 people in a boxcar.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] This was the worst kind transportation we had.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But the SS-- it was in Kielce.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I think it was Kielce town where we needed water.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "We-- we receive only yellow cheese, salted cheese, yellow.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "You know that I didn't eat cheese after the war?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I didn't touch it until here.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I came to the United States.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I start tasting it.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And it's good.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't eat those things.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And so we needed water.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So I went out.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "We-- we were very lucky.",
      "word_count": 5
    }
  ],
