  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "I came back-- one piece of hair here, piece of hair there.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And they decided I must eat pork.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "The doctor-- I went to a doctor, he said I must eat, for a few weeks, pork.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "So I went-- my father went to a new rabbi, who was also a survivor.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "He said, yes, I'm allowed to.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "It was the doctor says.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "But we decided not.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "It will take a little bit longer, but I will survive.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "The hair came back to me.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And that's how it was when I came home.",
      "word_count": 9
    }
  ],
