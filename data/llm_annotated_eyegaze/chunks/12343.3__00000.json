  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Then, in Skarzysko, they make, a long time to call up, everybody going to come in the lot.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And they said, everything, to try again.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Some to leave a while and some to take out to Skarzysko.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was on the lot.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "A day before, two days before, I find out as they come, and they said, [PAUSES FOR 5 SECONDS] also come women, to work with the team.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I did, I know this.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I took the lining from [INAUDIBLE] jacket.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I make me a blouse.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I took [INAUDIBLE] from a light, make me a collar, to look young.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And I come.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "They said, everybody out.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Everybody out.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I was dressed, then the Gestapo men, the oberscharfuhrer there, he said, oh, you're woman.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "You go back.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "See?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "That's that.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "No, that's not happened.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Still happened, something else.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Going back over there, comes around a Jewish policeman, comes in a policeman.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Go out!",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I said, why you sent me out, back?",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "The Gestapo sends me in.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And you send me out?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Why you send me out, to go to hell?",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "To go into death?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "He said, go out!",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "The Jewish policeman.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I did it.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I cannot do nothing with him.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "You see, police is police.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "The same that is going on every place.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Now I got a mistake.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "See, it was already two lines.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "One to death, one stays.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "One to death, one stays.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I was a fool.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I go to the death.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "You know, they're bombing [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] you, that place!",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "What you going to do?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "What you doing?",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I said, what I'm going to do?",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "Then I went to go out.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "The Gestapo said, stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I watch him.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "When he  turns his head, I jump out.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Go back to the officer.",
      "word_count": 5
    }
  ],
