{
  "stem": "26609.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And you see, it was oral and practical.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "We had to-- as we studied, we had to work straightaway.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And it's every shift for the work night duty.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "So I work night time.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "In day, I didn't have time when to sleep, because we had-- had the lectures.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I think it's much easier here now.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "But it was hard, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "There were only Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We were only-- it was at the Jewish hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And that Jewish hospital is famous.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "It was on the-- oh, I knew the street and I forgot it, the street.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Not [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I will call it.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "It's on the tip of my tongue, but I can't say it.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And it was a big Jewish hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "There was a Jewish hospital and mostly Jewish doctors and professors, and you know.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "One we had, he was Professor [?",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "Pesik ?].",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "He was-- he was Jewish but from Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And I remember, there was a charge sister.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "It was very clean.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "And the patient had to be-- the bed changed every day.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "And Professor [?",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "Pesik ?] was very particular, very clean.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And I remember the charge sister.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "Each charge sister had under her wings a few students, about four or five, in-- in one ward.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "You know, they were like here, wards, a hospital like here.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "It's the same.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "And she fed-- that sister herself fed a patient in bed, lying.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "And she had to feed her with a egg, soft egg.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And she dropped and-- there was-- it dropped from the spoon.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "She fed her, and she dropped a drop of yellow egg yolk on the cover.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And it was there.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Pesik ?] came in.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He said, who did that?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And she showed to me.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "She did it.",
      "word_count": 3
    }
  ],
