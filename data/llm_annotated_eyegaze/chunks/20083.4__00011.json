{
  "stem": "20083.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And Fritz Lang said, will you please come up to my office?",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHTER] I thought, gladly.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I had no idea what he wanted.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I thought he wanted to give me a job.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "But he changed his mind.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He screamed at me.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "He said, do you know what you're doing to me personally?",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You are my guest, and you're shouting at one of the world's top stars.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I don't want to see you again ever.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And he literally kicked me out.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And that was the end of my experiences in Hollywood.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I interviewed a few stars for a magazine called I got this job before I left London and interviewed movie stars like Spencer Tracy, who gave me a-- a signed autograph, which I still have.",
      "word_count": 35
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, absolutely not.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "No, Louis B.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Mayer simply said, there's just nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Our studios are virtually at a standstill right now.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, I hoped-- I said, well, what can I do?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Maybe I'll wait a little bit longer.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And I started as a dishwasher for a catering establishment in Beverly Hills, which was lovely.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "The food was tremendous.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We prepared meals-- and later on, I always had to wash the dishes.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "But we prepared meals for movie star parties.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So I did-- then we went with our finished meals, per truck, to a movie star's home.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Delivered them, delivered the food.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And I met a few movie stars that way, including Groucho Marx.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Only a few weeks, maybe five or six weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I realized there was nothing for me to do in Hollywood.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I would come back later one day.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But it just was hopeless.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And I went back to New York.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In New York, first, I worked for a displaced persons organization.",
      "word_count": 11
    }
  ],
