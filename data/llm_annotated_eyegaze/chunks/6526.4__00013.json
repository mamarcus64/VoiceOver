{
  "stem": "6526.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "So I started walking from one end of Warsaw to the other end of Warsaw to cross the Vistula in a-- in a boat, and came to a train station, which takes me east, because I was east of Warsaw.",
      "word_count": 40
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "I came to there to get a train, and the train is leaving for-- from another place.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "The other place is about 10, 15 kilometers away.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "Well, I walked so much, I'll walk 15 kilometers more.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "I came there.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "The only place that I could reserve was on the roof.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Because my, my-- I was east of Warsaw, my [NON-ENGLISH] My town was east of Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I want to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 9 SECONDS] I, I, I drag myself up on the roof, and I had a little suitcase, because I took the towels, a shirt, a pair of pants.",
      "word_count": 30
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "And I had it.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And there was a conductor, a woman, a Russian woman.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "She was conducting.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And she says-- she saw me.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "Well, this is all right.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "When came to the station, I had to, to get off.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "The train didn't stop.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "So I says, I'll jump.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "She says, go ahead, jump.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "I'll throw the suitcase in.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "I said, I'm not that dumb.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "I threw the suitcase first.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 14,
      "text": "[SOBBING] And I jumped out.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 15,
      "text": "Nothing happened to me.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 16,
      "text": "I had had experience.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 17,
      "text": "And I walked 5 kilometers to town.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 18,
      "text": "And I see, as he approaches me, a young men that I know.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 19,
      "text": "When he noticed me, he was afraid, because I looked like a dead man.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I don't know who I am.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS] And he said, my brother's home.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "He told me that my brother came home.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "[CRYING] That's all I needed.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "So we were there for a month or two.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "We went to Warsaw.",
      "word_count": 4
    }
  ],
