  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "In Jewish, it's Hannah Pesha, and he is Avraham Yisrael.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "This is it.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Belong to Young Israel Hillcrest.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Let me tell you something.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "This is deep and rooted.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You cannot-- you cannot take it out.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "You cannot take it out.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I'll tell you the truth now, something else.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Today, this morning, I had a [YIDDISH].",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "You know what's a [YIDDISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Learning.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Everyday in the morning.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Saturday.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "So-- but I don't have a rabbi.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "We two, another companion of mine from Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "We study together.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He's my age.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And he was from Krakow.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I was from Chrzanow.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "But I know-- I knew him from here.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Of course I have.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I had a book there.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I have a society, the Chrzanow Society--",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "We meet.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We have anniversaries.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And we have [PAUSES FOR 3 SECONDS] every-- once a year, a party.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "We meet.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "All the Chrzanow [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "If you want to-- if you want to-- if you want to come there sometimes, you're welcome.",
      "word_count": 17
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "At that time, I didn't go just to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "But I-- I had a trip, a big trip.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "On the way back, my son [PAUSES FOR 3 SECONDS] has the young son, has a publishing-- had a publishing.",
      "word_count": 20
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Now he has also a partner in something else, also Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And he dealt with Lufthansa.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And he accumulated a travel mileage.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "So he gave me mileage.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "He gave me mileage, a lot of mileage.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "I was-- I was in a lot of countries.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "So I went to-- to Spain.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "And I went to Morocco.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "And I went to Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 13,
      "text": "I went to-- I went to France.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 14,
      "text": "And I went to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 15,
      "text": "And then I came back.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 16,
      "text": "Everything was Lufthansa.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Poland, I want-- I want to see [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I want to see [POLISH].",
      "word_count": 5
    }
