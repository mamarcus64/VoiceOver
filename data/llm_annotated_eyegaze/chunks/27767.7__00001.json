{
  "stem": "27767.7",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And I was lucky it wasn't on my name, because under the communists, I would be persecuted if you had something before.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "So-- and then we had it for about from '46 to '48, because in '48 they nationalized everything, the communists that took over.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And I went out from that store.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I let-- my partner was still there for a year or two.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And then he had to close the store.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And then I went to work for the government.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "As-- I was working in the forest industry as a technician, and a clerk, in a government job, because everything was government, and-- down in Baia-Sprie.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was also studying.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Try to-- to go back-- to go to the university and do the studies.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But I worked in the meantime.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I worked in Baia-Sprie for about two years until 1950.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And then in 1950, they moved us to [INAUDIBLE], which is Baia-Mare.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And then I went to the center of the company, which I worked there.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I had a hired position already there.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And I was already a chief of department there in organization and planning.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "So I worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And then I moved.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "I wasn't married yet.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "So I rented a room there in-- a place there in-- because there was-- under the communists, it was very hard.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "You know, they didn't let you have more than one room or so.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "If you had two rooms, then one of you had to rent it out.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "So I rented out one room from another family.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And I was there for a-- in that town in Baia-Mare, for about six years.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "In this time, my brother got married in '48.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "And he lived in Baia-Sprie, still there in my parents' house.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "That was where I was born.",
      "word_count": 6
    }
  ],
