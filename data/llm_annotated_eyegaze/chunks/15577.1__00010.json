  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Maybe he spoke too much.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "He was talking too much, or maybe he was even discussing the Jewish problems when he was where he worked, or-- at the end, he was taken to the-- to the army and-- as a punishment-- and sent to the Russian front.",
      "word_count": 42
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And he was killed, and we know that he was killed.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Before he-- before he-- they left, his wife went back to Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And he was sent to-- to the army.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Before they left, they said, we will say-- we will settle another couple, which is at least as good as we are.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And it was really so.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "They sent us a-- somebody who was a very nice person.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "He came, not with his wife, with his mistress, but--",
      "word_count": 10
    }
  ],
