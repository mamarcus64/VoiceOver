  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "So-- but then I-- so that was during the school year, really, because then we were-- my mother always went to the country with some relative or other.",
      "word_count": 28
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I think so, from the-- to the best of my recollection.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Other than-- but there's the other side.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Because on the way to school from, from this Othmargasse to-- I had to cross a, a main street.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And then there was a shortcut to school through the yard of a church.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "It was a big, beautiful church.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And it was a pretty park all around it.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "I could not do that.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I could never cross that park.",
      "word_count": 6
    }
  ],
