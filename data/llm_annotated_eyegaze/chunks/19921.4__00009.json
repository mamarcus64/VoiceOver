{
  "stem": "19921.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And by the way, this is that name which I have here.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I have to look at that name to give you the name of the rabbi.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We had only one rabbi there, the unit.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Unfortunately, this rabbi did not make it.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "He was a young rabbi, and his name was Hirsz Zawada.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And he fell in the battle for Lenin, October 12, 1943, including, including 56 of other Jewish soldiers.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I'm going to tell you the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Absolutely none whatsoever.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Honest to God.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "There was no discrimination there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "The reason for it, I don't know what's the reason for it.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "First, we were in the same shoe, in the same boat, let's put it this way.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "All of us-- now, in my unit, I was the youngest in my unit, and I had a very responsible position because I was the gunner in that unit, which, you know, I'm talking about [? buddy ?] unit there.",
      "word_count": 40
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "But in any event, there was no discrimination for one reason.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I guess all of us were there in Siberia.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "All of us suffered the same hunger and the same sorrows.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I guess that's the only reason which, which there was no discrimination.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "There was no discrimination.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "If there was, maybe it was hidden.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Maybe it was not shown.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I personally did not came across.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Some-- nobody called me a dirty Jew or whatever it is.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "No, nobody did.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Very strange because I was lecturing in one of the-- I'm thinking in Kingston.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I was invited the last year.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I had-- you know, there was a question and answer there at the end of the lecture.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And one of the gentlemen is there.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I have it, as a matter of fact, on the tape.",
      "word_count": 11
    }
  ],
