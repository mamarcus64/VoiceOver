{
  "stem": "935.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "And it took a very, very long time before she got back to Earth.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "And then she tried-- she never told us.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "She never told us that we had no money any more.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "You didn't do this.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "She said that, let's say, you're temporarily out of funds.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "You don't say you're poor.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "And she kept the housekeeper.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "Well, the governess went, because we were too wild.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "They couldn't handle us.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "So I think they retired at an early age or something like that.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "But she kept up the expensive apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "She kept up the front, all of these things, got involved in most incredible schemes.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 32,
      "text": "She got involved in selling ice cream.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 33,
      "text": "She got involved in-- oh, yes-- marriage counseling.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 34,
      "text": "That's right, marriage for-- for for-- with honorable intentions.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 35,
      "text": "And it was in our dining room.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 36,
      "text": "I remember the very first guy.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 37,
      "text": "He was also a red head and very pale and watery eyes.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 38,
      "text": "I was 15.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 39,
      "text": "And he was very rich.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 40,
      "text": "He had inherited coal mines, didn't know what to do with them.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 41,
      "text": "He wanted to marry me.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 42,
      "text": "I was 15.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 43,
      "text": "I told him to come back when I was 21.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 44,
      "text": "He didn't come back at all.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 45,
      "text": "Terrible schemes, the marriage counseling.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 46,
      "text": "And there was the ice cream factory.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 47,
      "text": "And then there were a few other things.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 48,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 49,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 50,
      "text": "I just know that that was a struggle, a great struggle.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 51,
      "text": "But she kept up the front.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I was in the theater constantly.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I was under contract to a very, very good theater.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I played beautiful parts.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "At 11, I had my first solo part.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Well, not solo part-- I mean the lead.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I played the lead in a play.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Ah, it was wonderful.",
      "word_count": 4
    }
  ],
