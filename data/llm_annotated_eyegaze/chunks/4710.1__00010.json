  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "In fact, my father served in the-- in the Austro-Hungarian army in the First World War, and many other adults.",
      "word_count": 20
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "They were good soldiers and good Hungarians and good citizens, as far as being citizens of Hungary.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The school it was-- itself was mixed.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "The girls, they usually stayed at home.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Usually, they learned up to-- up to 14.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I think the girls, there was more girls there in the class.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "So it was really with the boys who were the problem.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "But the girls, they learned up to the age of 14.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And then I think just--",
      "word_count": 5
    }
  ],
