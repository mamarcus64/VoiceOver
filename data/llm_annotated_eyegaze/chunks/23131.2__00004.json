{
  "stem": "23131.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "That he-- he used to come home and say, I feel something in the air.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "It's not what it used to be.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Especially many years to come from Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "He was very depressed.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He said, I'm always afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Or he used to say, I'm afraid something shouldn't come.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "This was already in '39. '38, '39, right?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Us kids?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We didn't want to know.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "It's the same thing like the Germans came to us and they were our friends in the beginning.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "We didn't want to know.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't imagine that what would happen with us.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Not in-- not in Horodok, but in Lida already before-- before the Germans came into our region, already had a lot of refugee coming from the-- from Poland, from the back Poland, you know, like close to the borders of Germany and close to that borders.",
      "word_count": 46
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "A lot of refugees started to come in.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The same stories that we experienced, but we didn't believe them.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't imagine that this could happen.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "That the killing, the anti-- the antisemitism, and all-- all what-- what they-- that here was burned, this boy was hurt, this one they throw a rock at, or this one, they took away the bike.",
      "word_count": 36
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "You know, it's always something.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In the schools, it was terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Especially in the schools-- in the public schools where they were mixed, Jews and Poles.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But who wanted to believe?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "When you are young, you don't want to know from nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "You just want to live and live up.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "What are these stories are they telling you?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "But when they came in one shirt and one pair of pants, and you had to take them in and to feed them, you saw that's not the story.",
      "word_count": 29
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "You saw that they're not making it up.",
      "word_count": 8
    }
  ],
