  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "People lost weight within two months, 15, 20, 25 kilos.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "They couldn't let you sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They beat you up with no reason whatsoever.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Sundays, where we didn't work, and we walked around outside, the went around with whips, and they whip up, just walking there.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Must have-- maybe the instruction was to make our life as miserable as possible.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Now, lice were eating us by the millions.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And when we worked outside the quarry, where they built a railroad, and they had cement sacks, paper.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And because we were freezing, we put paper bags underneath.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "If they find you with paper bags, you get 25 on your ass with a stick, because they said you will get lice.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "But we had already so many lice, when we walked, we didn't have to walk.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "The lice was carrying us.",
      "word_count": 5
    }
  ],
