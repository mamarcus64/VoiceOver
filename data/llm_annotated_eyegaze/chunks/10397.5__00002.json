{
  "stem": "10397.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 3 SECONDS] Incidentally, I worked in the hospital, and I worked in a clinic, have a outpatient, three hours.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "Six hours in the hospital, three hours in the clinic.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And they paid me 902 rubles, all together.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "That would be two pounds of butter a month. 600 pounds-- 600 rubles was a pound of butter.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "And I got 900 rubles.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "I couldn't make a living.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "But the thing is, in the clinic, people came in with fake diseases and needed a certificate to get off work.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "A shoemaker comes in.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "He has to steal something from there, where he worked, because there was no private enterprise.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "But it was a cooperative.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "He steal.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "There was a lot of American stuff.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "American stuff, you know, shoe leather, canned foods, you have no idea, everything American.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "Anybody, he says-- and I see he wants a-- a-- a fake certificate.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "It's faked.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "So I say, you come to see me in my home.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And I show him the holes in my shoes.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "What are you, a shoemaker?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Well, give me a pair of.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So I-- I could give him up to 10 days off.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And so forth and so forth.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, when they-- the-- after typhus fever, I couldn't work.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I found a good-- a good, nice lady, a young-- not very young lady, who lost her husband.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And she took me to the hospital, a German hospital in-- in-- in-- in-- in-- in Augsburg, in Augsburg, yeah.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was already in Germany.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Because I had my-- I had my-- I-- I was in Germany, yeah, yeah, in Germany.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I came to Munich.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "From Munich, I went to Augsburg.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And I developed this heart disease.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Before I-- before I-- before I-- oh, yeah!",
      "word_count": 8
    }
  ],
