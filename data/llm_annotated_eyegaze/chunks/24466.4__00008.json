  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "They were different.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I don't blame the whole police.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Because people that they were working with us in the underground-- they were working with us in-- by the partisan.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They have been by the partisan-- commandants.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But they have been lower persons like him leaving the-- no-- [PAUSES FOR 4 SECONDS]",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I gave him the money.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "The rabbi?",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "The money was given to him.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "When I told him that he is getting the $300, he was sure that he will get the $300.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "He brought back the rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And a 1/2 an hour, the rabbi was back with the wife-- was back.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
