{
  "stem": "9987.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I told them to notify that man that his daughter was arrested, and if they have anything still in their house, they should clear it up.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "But the German, they never went to their house.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They wanted the money.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So they took the money away from the girl, and they let her go.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They never came to search to their house.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] I stayed in that place over there for about four weeks, dressed in--",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In Tarnow, dressed in women clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I notified through somebody-- I don't know how.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And I notified to my parents that where I-- that I am in Tarnow, not-- I did not give them no address where I am, but that I was arrested and escaped, and I'm hiding.",
      "word_count": 35
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "My mother was very resourceful, so she found a guy over there that had connections with the Gestapo, paid off some money to him.",
      "word_count": 24
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And he went to the Gestapo, and he was supposed to arrange that they shouldn't be looking for me.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And after she was told that everything is arranged, about four weeks later, I came back home to Krosno.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "When I came back to Krosno, the Gestapo was waiting for me.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] They was-- they were waiting for me, and they re-arrested me.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In 1940.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They re-arrested me.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "All they knew that they had an order to-- that I was arrested and escaped.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They didn't know why, where, and when.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "The Gestapo people knew me because their-- their office was two houses away from our shop.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And they used to come into our shop all the time.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "My father used to do some-- some repairs for them and some-- some uniform helping for them.",
      "word_count": 17
    }
  ],
