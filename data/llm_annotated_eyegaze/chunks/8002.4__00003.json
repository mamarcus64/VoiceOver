{
  "stem": "8002.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "It was the Wehrmacht.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And they gave us good food there.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, they give us bread.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They gave us bread.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They gave us soup.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They fed us pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They didn't hit us.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "We had to dig ditches, so a tank would fall in.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "We had big ditches we had to dig.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And my adopted brother, my friend, he started to dig the ditches, and he got sick.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "So I pushed him away.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I says, I'm going to do it.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "But that was not the Wehrmacht-- the prisoner that was in charge of prisoners.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So he came over, and he hit me.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He says, why you doing his work?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "This was a German prisoner?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "He was a Ukranian.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Ukranian.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He was in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "He was like a foreman, a kapo.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And he says, why are you doing his work?",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "I says, he don't feel good.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "I have to do it.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "He says, I'm going to hit you and he started hitting me.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Then I says, I'm still going to do it.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "He kept on hitting me more.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And blood came out all over my face, out from my nose.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And I smeared my face with the blood all over.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "So he says, wash up after you finish work.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "I says, no, I'm not going to wash up.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "He says, if you don't wash up, I'll hit you more.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "I says, I don't care if you kill me.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "I'm not going to wash.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And I went to the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They took us with trucks to dig the ditches.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And they took us back with the trucks to camp.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And when I came and the commander, he says, what happened to you?",
      "word_count": 13
    }
  ],
