  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And they rounded up my mother's cousins and all those people, put them on trucks, loaded them on trucks to take them to Siberia.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "My mother cried, ran with bread and fruit to hand over to the boys.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And the Russian chased her away.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Get away from the prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "She went home heartbroken.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And she kept saying, why did we let them register?",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Why did they register?",
      "word_count": 4
    },
    {
      "segment_idx": 16,
