{
  "stem": "26609.17",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I know what happened in Poland when the Russians came, because they took away the-- the mill from my in-laws, my grandfather of my late husband.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They took away everything.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And they took away from her.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And from [NON-ENGLISH], he was a big, fat man, very good-- a good man, a jolly man.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But I'm sure that they killed him.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I'm quite sure.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I know what the Russians are.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "We have had them.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "So I lived through the Russians.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And I lived through the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And now I left her.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I was halfway to [NON-ENGLISH], and I ran back.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And they said, wonder where you're going?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We won't wait for you.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "You won't find your way.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We could still hear shootings in the forests around.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The Americans were there first at the beginning.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "We could hear around.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And there were always soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "But we walked through a main street to [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I had those documents that I showed you, the torn ones, the old ones, from [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And I was halfway.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And I ran back.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And I said, wait for me.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "I have to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I didn't-- she didn't open the door.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And I wanted to say goodbye.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "I just felt it, that I should do something about it.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "I couldn't go away without seeing her, because I don't think that she lives after what happened there later with the Russians with the two children alone.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "Not that I got used to her.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I knew all the time that I am different from them.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And I-- and I-- and I have to go back home.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "But she saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "I wouldn't be here today.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "My daughter wouldn't have a mother if she wouldn't have saved me.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "Nothing helped.",
      "word_count": 2
    }
  ],
