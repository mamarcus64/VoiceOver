{
  "stem": "14463.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "The whole train goes to Silesia, to the part of Poland where Poland-- past Krakow, past Krapkowice, into the German part where the Poles-- You see, the Russians took a part of Poland from one side, and the Poles took a part of Germany from the other side.",
      "word_count": 48
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "So that's where you're going to go because that's where we need the people.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "We don't need you in any others city.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Again, I was very clever, right?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And we arrive in Plaszow, in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "You know, that's a Sabbot from Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I said, ah, you know my uncle died, right?",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "So I was the man of the family.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "I was the one who made all the decisions.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "I was 19.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Made all the decisions.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "I said, we're going to try to get out here.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "Because what are we going to do in Silesia?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "There's nobody there.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And here there could be some Jews in the area.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "It's a big city.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "We want to go from here, want to go to either Palestine or we want to go to Israel, we want to go to Australia, you know?",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "What are we going to do here?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, the train stopped and I jumped down from the train, down, and there was sort of a bridge, and under the bridge a Polish fellow with a horse and a cart.",
      "word_count": 32
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And I said to him, I've got two women and two children and a little bit of luggage, and I'll pay anything you want to take us to Krakow.",
      "word_count": 29
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Well, fellow had to use money, you know, so yes.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I went up to the train, and I-- can you imagine what hardship I had to get the two women down, and the two boys?",
      "word_count": 25
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Two boys was no problem.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And that bit of luggage.",
      "word_count": 5
    }
  ],
