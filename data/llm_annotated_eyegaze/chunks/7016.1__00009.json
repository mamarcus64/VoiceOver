  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 22,
      "text": "And-- and she took me to the-- to the block, and it was inside.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 23,
      "text": "This was the middle the night.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 24,
      "text": "They waked her up, and she said that I wanted-- I was thinking she gonna kill me, that-- that kapo.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 25,
      "text": "This was a Jewish kapo, and they live in a little room.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And she-- she start to holler [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I said, you see, all we-- we came all died already, and I'm not gonna live either.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And then she-- I was thinking, is she gonna kill me?",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "She said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "She was nice.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "She gave me a glass of milk.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "She gave me a blanket.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I laid down.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I should go lay down.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And after this, I start-- I started to get better in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "I start to feel better.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So-- and then debating, debate for a while, and they said-- she came to me, that kapo, all the time, to see how I am.",
      "word_count": 25
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And  she see that I start to feel better.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And she said, the SS will come, probably, in a week.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And they're gonna-- not just me, the other people too, they're gonna check you out.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And they're gonna send you to the-- to the working camp.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "Now I was in the quarantine.",
      "word_count": 6
    }
  ],
