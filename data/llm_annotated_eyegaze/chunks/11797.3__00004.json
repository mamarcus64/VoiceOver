{
  "stem": "11797.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "They shot them in the air like a practice shooting.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "I saw-- and they-- we all went out on the street.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "We stayed from 4:30 in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "Our street was a very huge street, because on Thursdays we used to have, like, a flea market, in that street, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "So it was very large.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "Very, very wide.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "And there was-- they had all the Jews, you know, who were in the ghetto was in that street, in that particular-- but when it got lighter, we heard-- that's all we heard is shouting, shooting, you know.",
      "word_count": 38
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 39,
      "text": "Screaming, hollering, whipping, beating, people falling down.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 40,
      "text": "The-- I remembered the chief rabbi was shot then.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 41,
      "text": "The chief cantor was shot there.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- that's-- I think it's Keslenberg or somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "No, I can't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's been a long time, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I remember these details.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I remember and-- and the-- I know the Rabbi [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "They used to call him [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "He lived on [INAUDIBLE], which means the new-- the new world, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "He was a very pious person.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "When people were sick, they used to go to him for help.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "He was very, very most-- I used to-- when I used to go by from school-- you know, I was a young kid and all-- and I used to go by and near his house, you know, I felt I'm going through, like, a god.",
      "word_count": 45
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I felt very, very emotional when I used to go by there.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "I felt this is-- this must be something.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "God is there.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Because he knew how to help people.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "He used to-- knew how to-- how to-- [PAUSES FOR 3 SECONDS] he was give-- like, he knew how to help the sickness-- the sick people.",
      "word_count": 26
    }
  ],
