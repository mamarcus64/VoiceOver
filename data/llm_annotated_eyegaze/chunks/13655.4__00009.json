{
  "stem": "13655.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 463.4,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Tomorrow, you're going to work.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "You get $3 a day.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And I know this is the biggest lie.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "They were gelt, gold division.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "That was zlotys.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Gold-- gelt-- gelt is the zlotys in division-- dollars.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Everybody would give away.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "He start to shoot them right away.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "He recognized one guy.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "Oh, you're still alive, you [? runt? ?] Right away, he shot him.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] boy [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And you know what happened?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "He told me-- they ordered me to get naked.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "He was checking I had money here in the [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "I was shaking.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Me and my sister-in-law was there, and I didn't want to be killed.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "She should see.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Maybe she would survive [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "Not to-- [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I just-- you start a second, a second.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] I threw it into the desk.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The money.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And they checked.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "They see us from a lighting--",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I had a stone from a lighter.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Oh, a diamond.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "No, this is in the lighter, [NON-ENGLISH] They brought us into the shul-- to the synagogue.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "In the synagogue, [NON-ENGLISH] was up to here in [INAUDIBLE] boots.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Was crying, cursing.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And this was-- the shul was the nicest in the area from 100 miles around.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And they took me.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "And I was-- and I went upstairs in the women's section.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "This was maybe about 35 feet.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "And my sister-in-law, she started to complain.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "She has a gallstone attack.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "I took off my jacket and I put her away.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "And I was sitting-- and I was trying to-- and I told her.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "If I'll jump out, try to jump.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "Don't wait.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 15,
      "text": "Go there and there and there and there, and maybe we will see each other.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "From the shul.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I was going around, and we cannot go out.",
      "word_count": 9
    }
  ],
