{
  "stem": "2097.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "I don't know now, already, German.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "And I rinsed my mouth.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "And I got a little bit better.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "But my mouth was constantly bleeding.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "And the cough finally got so severe that I had fever.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "I felt chilly-- a chill over my body.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "And whoever got sick on that place was taken away, and no one ever heard of it.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "I got very, very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "I had fever.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "I had-- we had a tech-- dental technician.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "And she told me I have 38 1/2, she measured.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "But I had to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "But sometimes, just I couldn't anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "Because I was so shivering, and trembling, and coughing so terribly, that no one was able to sleep in the whole room.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "Because I was coughing.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "I kept my head on the side of the bed.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "I was sleeping on the top of the bed, because it was easier for me to cough.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "And no one was allowed to work with a blanket or to get sick.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "As I said, the sick person was taken away.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 38,
      "text": "And I put a blanket on me.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 39,
      "text": "And I went to the lady.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 40,
      "text": "And I said, I cannot go to work.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 41,
      "text": "I was working, I don't know, somehow-- never changed.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 42,
      "text": "I have to work always, at night, 12 hours.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 43,
      "text": "I was on that shift.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 44,
      "text": "And during the day, was always a air raid.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 45,
      "text": "We had to go to the bunker.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 46,
      "text": "So even if I would be able to sleep, I never was able to sleep.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 47,
      "text": "Because I was just coughing.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 48,
      "text": "When on the weekend we didn't work, I woke up everybody, because I was coughing so horribly.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 49,
      "text": "Or sometimes I think was changed, the shift.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 50,
      "text": "Because sometimes I slept-- I would have slept all night if I would-- if I wouldn't cough.",
      "word_count": 17
    }
  ],
