  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Three other girls, which we met and became friendly-- [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "They were also mostly from Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "So it was a good thing, because we had a lot in common.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And we were there, I don't know how long, a few months.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And all of a sudden, they said, they are taking people out to a different camp.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "I said, Rosie, you know something-- and the three girls-- no matter where we go out of a death camp, there is a gas chamber.",
      "word_count": 25
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "There is a-- there is a ovens.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "Let's see what we wind up with.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Majdanek, we were working mostly in the fields, on all four.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Weeding.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Because you know, when you put somebody in you-- and try to-- I have to close the door.",
      "word_count": 18
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Because I can hear his-- does it bother?",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "So this-- so the weeding-- just to torture us.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing, really.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Carrying all kinds of heavy, heavy boulders from one place to the other, and the next day, from there to another place.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Please, let me--",
      "word_count": 3
    }
  ],
