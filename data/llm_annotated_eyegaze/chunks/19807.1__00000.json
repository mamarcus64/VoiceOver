  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Cohen.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Aaron Moses Cohen.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "A-A-R-O-N, initial M, C-O-H-E-N.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My given name in birth was Aaron [NON-ENGLISH] Cohen.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is December 18, 1929.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "66.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a city called Gorna Dzhumaya.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Shall I spell it for you?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Gorna Dzhumaya, in the country of Bulgaria.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] To tell you about my childhood, I have to briefly tell you about Bulgaria and the Jews that lived in Bulgaria.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I can remember as a child-- and I would say that that was a childhood of innocence-- I remember four years old, I was.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "That's the first recollection.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "In fact, I have a recollection of me sitting on a high chair, and having my great-grandfather visit me, very, very vaguely.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I was shaking very hard on the-- on the high chair.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "I was a year and a half, two years.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "That was my first recollection.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Then I blank out until I am about four.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And I remember my mother taking me for a walk and-- in-- in the city, lovely city.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "The Jews enjoyed very, very fine reputation.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "My-- my family on my father's side, which were residing at that time in Gorna Dzhumaya, enjoyed excellent reputation.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "They were merchants.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And primarily, they dealt in furs, tobacco, and jewelry.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "That was their-- their primary occupation.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And to give you the difference between my family, on my father's side, they were real strong, tough individuals.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "It was-- the-- the town was bordering Macedonia.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And one of the reasons my father had to leave Gorna Dzhumaya, because the Macedonians wanted him to become their secretary-treasurer of that party.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And they were very tough.",
      "word_count": 5
    }
  ],
