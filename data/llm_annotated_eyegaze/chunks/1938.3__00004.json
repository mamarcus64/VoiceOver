  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He became-- go through this school, and he became in New York-- he lives in New York-- and he became an editor.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He's very popular, a good reputation, and a lot [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "He's going to write up the whole Czechoslovakia trip-- the Jewish life there.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, but I like to finish with my daughter and then go to the end.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And then in '53-- in '53, my daughter was born, and then-- and my son took care of her, because I had to go to work, and their father never felt too good.",
      "word_count": 33
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "But anyway, this is the story that she also push herself.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And she became a body improvement exercise teacher, which she's teaching in Beverly Hills school for many years.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She's very loved, and I'm her student, too.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, she said that this is not a profession forever, when you get a little older.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She got into photography.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We give you this-- and she is now going for extra courses to UCLA, behind those machine-- expensive machine-- and she's a very good mother, has three beautiful children, and-- and a good marriage.",
      "word_count": 34
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "What else?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And my son has a good marriage.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "He married a girl from Vancouver, British Columbia, and-- and the father is a psychiatrist.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "They have three children, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So when they-- when I heard from the mayor from Prague, a letter which I have, that the ghettos what was liberated in his city, he would like to make a ceremony for three days to take from Prague to Volary and to meet them all.",
      "word_count": 46
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "My children--",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So my children decided to leave everything, the kids, the home-- we're never together.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They are busy.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "My son lives in Connecticut and works in New York.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Five hours every day to travel.",
      "word_count": 6
    }
  ],
