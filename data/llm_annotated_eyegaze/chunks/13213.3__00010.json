{
  "stem": "13213.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And we met some Jewish people and they told us there was a Jewish organization in Lwow that would maybe help us.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "We went to the Jewish organization, and I met there, standing outside, a Jewish man who was in the Communist party, and he invited us into his house.",
      "word_count": 28
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "When we were in his house, he said, this is a secret.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "I'm in the Communist party, but you kids have no future here.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "A lot of Jewish people that go to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And there, they are sent to America or other countries that they can go to school and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "We decided to go to Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "In order to go to Poland, we had to go to a Polish ambassador in Lwow.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "We went over to see the Polish ambassador.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "They asked us for some documents.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "I went and I got some-- my birth certificate.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "When we came there, we were all nervous and upset because they were drilling us and questioning us.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "We didn't speak such a good Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "And they only let people go that were Polish born or Polish citizens.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "So they didn't believe we were really born in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "And finally, there was another man that came in and-- I was all upset.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "I started to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "And they said, let the kids go to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "Let them go.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "So they gave us a visa.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "And then-- I think it was in the spring of 1947-- we left from Poland to-- from Lwow to Poland, and we were taken off in Cracow.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "In Krakow, we were met by Jewish organizations, all kinds of Zionist and religious-- it was a religious group that approached me.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "They asked if my parents were religious.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "I said yes, so they took me right into a religious orphanage.",
      "word_count": 12
    }
  ],
