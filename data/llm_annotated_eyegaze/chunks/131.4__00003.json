{
  "stem": "131.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "That's the way he was escaping.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "My nephew.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And my brother [PAUSES FOR 3 SECONDS] died.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "His wife became very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She had a heart condition, and she got the-- [PAUSES FOR 9 SECONDS] how you-- how you say?",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, she got the heart attack.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And my brother went for the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And by the time he came, she was dead.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my brother didn't want to live after that, because they were a couple who loved each other very, very much.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And he didn't want to see nobody.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And a year after my sister-in-law's death-- it wasn't quite a year-- he passed away from sadness.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He didn't see nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "He didn't go out even from the house.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Just the maids were there.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "That was in Mexico City.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He was living in Mexico City.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He was building there.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And we went there lots of time from this country.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] I want to tell you, my children went 10 months schooling to three different countries.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Not for pleasure.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] We started in California, school for the kids.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] And things were very bad for us here.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And we went to Mexico City to my brother, and they went in English school there.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And then we went to Canada, where my husband's family was, to finish one term of schooling.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I don't even know exactly how old they were.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I met my husband through some friends of my parents.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "When I came to United States, right away they tried to introduce me to acquaintances.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Always that I should meet somebody.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I met that- that family was my father's friends and some distant relatives.",
      "word_count": 13
    }
  ],
