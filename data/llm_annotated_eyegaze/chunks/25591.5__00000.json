{
  "stem": "25591.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, [PAUSES FOR 3 SECONDS] the-- the first part of the question is very easy to answer.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "She came a year after I did, in '48.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "When we decided to get married is a-- is a subject of great contention between the two of us because I think it was in the early '30s, and she thinks it was in the mid-'30s.",
      "word_count": 36
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But we knew each other in Budapest.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And-- and we knew we would get married.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was born in '28.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So in the mid '30s, I was seven, which, you know, you grow up fast in that [LAUGHS] old country world.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And-- and-- we grew up together, but, of course, I grew old and she grew young.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "So now there's a huge time difference between us, a gigantic age gap.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But it's-- we have been married now almost 47 years.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And the first 47 years is quite good.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So we are looking forward to the next 47.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We have two daughters and we have 17 grandchildren. 17.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And the reason is that our two daughters decided that since our families were basically killed in the Holocaust, they wanted to create a new family for us.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And they have.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And it's clearly our [PAUSES FOR 3 SECONDS] greatest joy and the focus of our-- of our lives.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Annette was instrumental in my becoming involved with human rights.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "She really is the person who did 99% of the work, for instance, on Raoul Wallenberg.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "The Raoul Wallenberg project began on the kitchen table in our kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And Annette gave years of her life to it.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "She then suggested when I was elected to Congress that I introduce legislation making him an honorary citizen.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I got the credit, but she did the work.",
      "word_count": 9
    }
  ],
