  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "You have responsibility to 650,000 people.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 46,
      "text": "Because if they would have said, go and find a rat hole to disappear to, people-- more people would have had the opportunity partially or maybe totally to survive.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 47,
      "text": "Look, there were people who lived on the southern part of Hungary, which was near to Yugoslavia, where, where already in 1944, a lot of partisan action was going on.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 48,
      "text": "It would have been-- young men of military age-- would've easily infiltrated.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 49,
      "text": "So they may have shot 75 of 100.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 50,
      "text": "Then 25 would have survived.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 51,
      "text": "And this is my point on that.",
      "word_count": 7
    }
  ],
