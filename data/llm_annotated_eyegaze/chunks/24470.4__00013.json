  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "I was so passive and so closed.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I feel that everything was flowing over me on the outside, but inside was locked.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And still, some period of my time is locked.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "So it's hard to say what kept me alive, maybe.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "Is there anything-- [INTERPOSING VOICES]",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I did not.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I did not do much.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I said it before-- uh, uproot the prejudice and the hatred.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Learn to know people for what they are.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Do not des-- despair when something terrible happens, because there is always change.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    }
  ],
