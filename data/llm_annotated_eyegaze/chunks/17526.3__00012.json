{
  "stem": "17526.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "A Muselmann was a skeleton of a person who was like a walking dead, covered with a blanket over his head, his eyes sockets suck-- sinken in, and who could hardly walk.",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "Of course, a man like this, he was very quickly done away with.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "He was put on a-- put on a transport with others, and he was shipped to wherever they were shipped.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "I was one of them and my brother, I was picked up, and I was put on a train.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "And instead of-- these were the last days already and I have a document here from Dachau.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "I was shipped to Dachau.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And not until this morning, I didn't pay attention, this was April the 13th, 1943 from Spaichingen, I was shipped to Dachau.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "And at Dachau, I was put in in a barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "There were hundreds naked people in this one-- a lot of Russians, a lot of Russians prisoners-- a lot of Russian prisoners of war.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "The lice were eating us up alive.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "It was like everything was moving and everybody was covered with lice.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "And they left some warts, like-- not warts, open pockmarks.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "And this was like hell-- hell on Earth.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "I remember there was one window that the sun was shining and there were hundreds of prisoners like wild beasts running around.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "The Russians were very boisterous.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "There must have been new prisoners of war.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "And we were destined to be gassed, but for some reason or another, they put us on trains.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "The Americans started encircling this whole area.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "Dachau was not far from Munich.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And they put us on trains and we were on trains for eight days.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "There were five long trains with thousands of prisoners.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "There were specific orders by Himmler, later on it was documented.",
      "word_count": 11
    }
  ],
