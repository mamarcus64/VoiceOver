  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "And they-- just because that's true, they go to 10, 15 houses and pull all the men and shot them.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And that--",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Polish men now.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Helen was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But she's a-- [PAUSES FOR 3 SECONDS] she said that, you know, her father was pulled with other men and killed because the partisans did something to the German.",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So they took it full out and were killing people.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she did see.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The mother-- now, was-- she was only with mother together.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And she did not-- [PAUSES FOR 4 SECONDS] she was very poor.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "She did not-- but she trusted me now and say that she is married to a Jewish man.",
      "word_count": 18
    }
  ],
