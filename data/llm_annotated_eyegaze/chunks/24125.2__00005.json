{
  "stem": "24125.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They killed them.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And they left them in that ditch.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "All the Ukrainian were afraid to bury them.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "But that friend of mine, like I told you, that [?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Kola, ?] risk his life, and he gave them a burial there.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "After that, our life was completely broken.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "My mother was hiding on a roof in one house.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "My brother with his family, to the neighbor home-- neighborhood village.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "My brother was on the roof-- on the attic, and his wife was working in the fields.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "My sisters-- one went to Shepetovka.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "The other one went, again, to these people in the scattered houses.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And they were taking care of cows, whatever, and the family.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "So we were completely out of Stadniki.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "I went to a neighborhood-- it's not a village, again.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "It's like scattered houses.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "I took care of a little child and was there till they found out that I was there.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "Then it came my turn.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "They decided it's time for me to be killed.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "Then again, there was-- they called him Plenick.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "The-- the-- Russian soldier that decided to leave, he lived there, also, with me, with these people.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "He found out that there is orders that I should be killed in the last minute.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "I had only time to take a little cover, whatever I wore, and I started to run at night.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "I ran to my father and my mother, which were hiding not far away.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "But as I was walking towards my father and mother-- and there were woods, and I heard talking, which is unusual at night.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "I figured that these are the people that came to look for me and kill me.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "They did pass by me very close.",
      "word_count": 7
    }
  ],
