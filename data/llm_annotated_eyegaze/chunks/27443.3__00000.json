{
  "stem": "27443.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "When they unloaded us from the trucks, we were marched in and separated, men from women.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we had a selection by Bartenschlager, he was the leader from Majdanek.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "He came with a white coat, with a whip, and transferred us into lines, and directed us from right to left, to lines we didn't where we were going.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "But I wound up in the line that I was transferred into camp.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Marching into camp, we observed the big chimneys, the terrible stench, the odor.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We couldn't define at that time what the odor was.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "But we later found out that the rest of the people were led [PAUSES FOR 3 SECONDS] into the ovens, into the crematoria.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And then they were burned in the crematoriums.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We were led into barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I was in field five, with rows and rows of barracks.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "The barrack consisted of bunks.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "There were three and four layers of bunks.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And each one of us was given a bunk with a few more girls.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And they were completely empty planks, no bedding or whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And that's the way we slept on these bunks.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "To keep warm, we huddled, one into another, to keep warm at night.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And just like any other camps, were surrounded by lice, a lot of rats.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "We were terribly hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "Every morning, if it was cold or whatever, we were marched outside.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "It was still dark, it was appel.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "It was appel to be counted.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Nobody was allowed to be missing.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "There was no escape, because the camp was surrounded with electric wires.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "Not just one, but between electric wires was a big lake, not to be able to escape.",
      "word_count": 17
    }
  ],
