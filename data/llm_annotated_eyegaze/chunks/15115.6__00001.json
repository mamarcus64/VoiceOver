{
  "stem": "15115.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "And sure enough, a bunch of Jewish kids, Canadian Jewish kids, came in with their parents, with their cars.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "And they took us, and they brought us into what you call on Markham Street.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "There used to be the Jewish center on Markham Street.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And then-- the-- there was a lot of rooms down there which, today, is a library.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And-- but there was no room for me at the-- what do you call?",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "At the center there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They put me in the Beverley Hotel on Spadina for a few nights, till a few other kids moved out of the center.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Then I moved-- I moved back into the-- into the center, from the hotel.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In the mean time, I stayed about four or five nights in the Beverley Hotel on Spadina and College.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "From there, they were trying to find homes for us to live on, because the center-- more kids were coming in, bi-weekly or bi-monthly.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "You know, they were coming, a lot of kids from all over, all over the world, actually-- from England, from many places.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And they found me-- I found a house by the name-- [INAUDIBLE] used to be-- on College Street, they used to have-- [PAUSES FOR 5 SECONDS] what do you call-- making suits.",
      "word_count": 32
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, a tailor.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Tailors-- [INAUDIBLE] tailor on College Street.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very nice family, and I-- and the Congress was giving me $18 a week to live on, in those days.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And I used to pay $14 for room and board for the lady.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And $4, I used to have for spare money.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "But in the meantime, I had quite a few dollars when I came over.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I was the richest kid of all the 70, you know?",
      "word_count": 11
    }
  ],
