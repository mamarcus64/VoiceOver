  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 37,
      "text": "So he found out where I worked.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 38,
      "text": "And he tried to prove how nice the Germans were because in the train I said, no, I-- you know, the Germans aren't so nice.",
      "word_count": 25
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 39,
      "text": "Also I have German blood, and-- you know, I am half Polish.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 40,
      "text": "And so-- [SIGHS] so he took the train very early in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 41,
      "text": "And he would leave smoked fish or-- or some kielbasa or something in my drawer, to prove he was nice.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 42,
      "text": "And it stank there [LAUGHTER] and I would come in and I have a smoked fish in my desk.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 43,
      "text": "So-- there's-- there's more to this story.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 44,
      "text": "But I know you probably have to change the--",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Well, that's a long story-- not a long story.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So anyway, I-- I knew him.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And he gave me his phone number.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "He was an instructor in some officers' school and said if I ever need him, to call him.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I-- I needed him.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
