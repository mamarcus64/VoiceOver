{
  "stem": "4226.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.1,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I actually [PAUSES FOR 3 SECONDS] volunteered [LAUGHS] to cut some timber for the-- for the kitchen, which supplied the food for the-- for the guards, the gendarmes.",
      "word_count": 28
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "We got some extra food for cutting the timber.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, they were in a different ghetto in the same town where the school was.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "It was a much bigger center.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "But when I cut wood, these two people who survived with me-- they're in Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "The three of us--",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Not school friends, only school friends from primary school.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They didn't come in town.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "One is deaf and dumb now.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And I visited him three years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And the other one-- the three of us, we cut wood.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "So we saw what's going on there.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "They did a lot of-- they try to force all sorts of things out of different people.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "They thought they can-- they can get their jewelry.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "Some have.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "Some didn't even have it where they hid it.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "And they were beating them up there.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "The Hungarian, Hungarian gendarmes.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Hungarian.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And they had all sorts of ways of making them talk.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Well, I, I saw a young woman, probably in her early 20s.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "They, they put under her knee a broom stick.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "At the back of her knees...",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Yes..",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "In the back of her knees, which went through her two arms cross, like this.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "So it went-- her arms had to go--",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "The arms had to go--",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "--the knees up, and the stick through here.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And then your hands were tied up with string.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And you actually, if they hit her, she were moving like a ball.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "She couldn't stretch, not foot, not, not hands.",
      "word_count": 8
    }
  ],
