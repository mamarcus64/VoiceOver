  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Karkur. ?] This was the border, Jordan border.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "We have to sleep on the floor on account-- we got beautiful furniture-- on account the Arabs every night invading the station.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But, you know, the terrorists.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have water.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have hydro.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "We survive.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "We liked it.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And my daughter-- our daughter was born.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have water to bathe here.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So the kibbutzim, I went into the kibbutzim, and they gave me jugs of milk.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And we bathe our daughter and ourselves in milk.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And we didn't have hydro, just a [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "Until our daughter got two years old, and she was [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "She want to speak French, English.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "She got nobody to play with, nobody [? to that. ?] So I ask for a transfer.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So they transfer me to Haifa.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And they-- I worked in Haifa in, what do call them, special units and [? cruisers-- ?] special units.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Beautiful apartment too they give us.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "But the only thing trouble was the utilities was with another police family.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "This was not comfortable, but we survived till I got healed.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I says I have to, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Not enough ?] dead, they want to send me to the Negev, while they start to develop Negev police stations, you know, to build up new development.",
      "word_count": 27
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And my wife's family was against this.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I could give you a beautiful job, she could, in the city, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Kindergarten.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And-- [PAUSES FOR 3 SECONDS] and I got healed.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And the doctor told me-- I start to suffer there in the knee and here in the back.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And I went every day for treatment.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And that was no good for me.",
      "word_count": 7
    }
  ],
