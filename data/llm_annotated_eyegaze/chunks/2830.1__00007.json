{
  "stem": "2830.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 7,
      "text": "So did they take money from you, or they just let you go?",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "She gave them--",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "She gave them money.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "But never mind the money.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I thought out of the goodness of their heart--",
      "word_count": 9
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "--they let you go.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "So they opened the door.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "Don't ever look back.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "Just keep going-- running-- not going, but run.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "And we walked out.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "Like this--",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "First miracle-- that's true.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "So we walked.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "It was all night.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know which way we walked.",
      "word_count": 7
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 4,
      "text": "Apparently, it was-- it led us to a big forest.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "They call them Black Forest.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "We walked in this-- that forest.",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 7,
      "text": "We breathed a little easier, because there were no people.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 8,
      "text": "We're gonna be, you know, only us and that-- those-- that forest.",
      "word_count": 12
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 9,
      "text": "But we walked into deep.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 10,
      "text": "It was so dark that we haven't seen any sky.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 11,
      "text": "And then we heard-- we walked a couple of hours.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 12,
      "text": "We heard crying-- a baby crying so loud and woman's-- a woman's voice.",
      "word_count": 13
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 13,
      "text": "And we followed that, you know, sound from where it came.",
      "word_count": 11
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "And my sister walked in, and my sister recognized.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "She knew the woman.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "She had about a nine-month-old baby in her arms.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "So she dried up.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "She hadn't fed the baby for a couple of days maybe.",
      "word_count": 11
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "She said she was tearing her hair out.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "And she was screaming.",
      "word_count": 4
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 4,
      "text": "My sister said to her, you want to join us?",
      "word_count": 10
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 5,
      "text": "She said, to leave the baby?",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 6,
      "text": "No, I want to die with the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 7,
      "text": "I can never do that-- leave the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 8,
      "text": "And we couldn't, you know, stay there, because she was screaming.",
      "word_count": 11
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "We were afraid that they-- somebody is gonna hear.",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "And we started to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "We walked-- it was already noon.",
      "word_count": 6
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "And there was no end to this forest.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 4,
      "text": "Finally, we saw a little light.",
      "word_count": 6
    }
  ],
