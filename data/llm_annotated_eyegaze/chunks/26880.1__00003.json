  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Matzah, all kind they eat-- like the women, make good cooks.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "That's a [NON-ENGLISH], and a holiday, [NON-ENGLISH], that says [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "This day, when God gave the Torah for the Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And that's [NON-ENGLISH], and they did things they you can cook-- milk, and things.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "The same as Sukkot.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "Sukkot is a-- Sukkot is not such such a proclaimed holiday, but the orthodox people, you have to eat at Sukkot.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "Sometimes, it got real [INAUDIBLE], you must run in the house.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "Those are they-- anyway, happy holiday.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And after this, we finish [NON-ENGLISH]-- it's the biggest holiday what can be, by the Jewish people.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "No, [NON-ENGLISH] supposed-- Jewish people supposed to keep the [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "Oh, but you see, in America, not like this.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "Everyone, everyone, is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Even we, in [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "At least he's doing that to God.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "Remember, today is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "God gave the Torah to the Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "At least he have this [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My father, I remember that he-- like I say, he was an honest man, an orthodox man. a man of [NON-ENGLISH].",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I can say [NON-ENGLISH]-- between-- between smart people, learned people, he was-- I was growing up.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I was grown up in a house between [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My mother was the same, like father-- my father was orthodox as she was.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The same, no question.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They was orthodox, 100%.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No, she was-- she was learning the children.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I tried to be a Jew-- I have a [INAUDIBLE] to say pray [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She was orthodox, 100%.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And she was learning the children-- my brothers and sisters-- the same as she was.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And we were the same.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Not the same, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "From generation to generation, not the most, even my brothers-- we till the end, we was-- till Hitler came, we was orthodox, 100%.",
      "word_count": 23
    }
  ],
