{
  "stem": "15943.1",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "I remember my uncle-- the one that became a teacher. when he went to the university and he was heartbroken because he had to sit on the left side of the room-- in the back on the left side.",
      "word_count": 39
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Jewish students were not allowed to certain-- in certain seats.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And that kind of bothered him, that's why he didn't continue because medical schools, it will be even worse if you get in as a Jew.",
      "word_count": 26
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "So that's why he went to a Jewish teacher seminary and became, became a teacher.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "But we knew that if you go to college, you feel the anti-Semitism every day because you have to sit in the back of the room on the left side.",
      "word_count": 30
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Harry, my best friend.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We lived-- the area that we lived, though it was mostly Jewish, Mrs.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Gruber, the landlady, we knew that she wasn't Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "The only time we knew, when it came Christmas.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "When we had-- Harry had a Christmas tree, and I didn't.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "But otherwise, you know, she was so involved in our holidays-- her daughter Olga and her grandson.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Olga was divorced and grandson Harry.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He was same age as I was, and he was my best friend.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And we would-- they always celebrated the holidays with us.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And she acted like our grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "If you run in the hallway, don't run too fast.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "You're going to break your foot.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Your mother is a widow.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And she-- it was reinforcing.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "Like, you know, she really took care on us.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "So we knew-- we knew that she-- they weren't Jewish, but it didn't-- they spoke Yiddish.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "In fact, Harry used to go with me to Jewish school.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "On Sunday-- because school is six days a week.",
      "word_count": 9
    }
  ],
