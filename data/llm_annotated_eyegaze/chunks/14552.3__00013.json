  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And it doesn't seem logical, why would they have wires, electric fences, and count the people so carefully when no one would be able to-- sharpshooters on the-- on the fences.",
      "word_count": 31
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And it was very illogical, but that's what they were told to do.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And that was-- at night I would go out to use the facilities.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And the very bright lights-- and there was somebody-- every night there was at least one person stuck to the fence.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And in the morning, they would shut off the-- the electricity and they would remove the body.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "They would shoot people.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Of course, they shot people for this or-- this-- doing the-- the-- something they were not pleased with, subordination.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "They would-- the gun was there and it was used.",
      "word_count": 10
    }
  ],
