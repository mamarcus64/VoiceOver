{
  "stem": "11797.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "If we went to the Germans-- the SS-- to work, no, you knew for sure you were going to come back beaten up.",
      "word_count": 23
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Because this was the-- they'd take us and beat the heck out of us, no.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "If we went to the other, to the wehrmacht to work, no, or the other soldiers, no, somebody else, maybe to civilian people, we were able to ask to help us, no.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "So they used to give a piece of bread, the non-Jewish people, or the-- or the Germans, no.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "They give us bread, no, maybe some piece of [INAUDIBLE], no, sugar, no.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "We used to steal it and smuggle it into the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Well, I didn't get the-- I didn't get-- only one incident I had one time with a non-Polish Polish person.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I asked, one time, a Polish fella-- help me, give me some bread to my father and my brothers, please give me some bread, no.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Bring me something.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So he said, bring me your silver, and I'll give it to you.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Bring me your gold that your mother had.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He never knew me before.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I said, I haven't got any.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He felt all Jews are wealthy, all Jews are very rich, no, and they contain these items, no.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I had a silver spoon or-- or something, no.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Because, you know my father was not a materialistic person to believe in all these silver or gold.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He was a working man, no, and we didn't believe in those kinds of things, no.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We were very-- we lived from day to day.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in the ghetto until 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was formed right after the-- after the Germans came in.",
      "word_count": 11
    }
  ],
