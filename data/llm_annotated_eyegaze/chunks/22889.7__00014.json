  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "My uncle wrote me, right away.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "I want you to come to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "I don't have children.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "I want you to come over here.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "I want you to live with me.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "You're going to have a job.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "You're going to have living quarters, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 12,
      "text": "I want you to come over here.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 13,
      "text": "Of course, I didn't want to part with my friends.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 14,
      "text": "My friends, they were all going to Palestine.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 15,
      "text": "There was no Israel, then.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 16,
      "text": "My-- my best friend, he lives in Antwerp.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 17,
      "text": "I said to my uncle, I wrote him, if he's not going to come with me, I'm not coming.",
      "word_count": 19
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 18,
      "text": "So my uncle had to send him affidavit, also.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "But I tell you the story, what happened.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
  ],
