{
  "stem": "9898.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "On 35,000, one was missing.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "Now, the SS soldiers, they went completely wild, beating and screaming.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "They couldn't find that one guy.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "So they said, perhaps they miscounted the dead ones.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "Because every day, 30, 40, 50 people were dying in the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So they put all the corpses out on a-- in a-- in a-- in a-- square there.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Over a thousand in three-- over thousand of them, we saw it.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And it was-- it is known because it was written up in the book, Over a thousand-- and the guy was missing.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was a young boy who overslept.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "He was in one of the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And they found him.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "He overslept.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And he came out.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And they shot him right away.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Now, as I said, they had to-- hundreds were coming every few weeks, new.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And new guys were coming to the camp because they were dying out.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And I was in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And I, I was not doing-- I was in the barrack, not doing too, too bad.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And it came fall of 1944.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And one day, Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "Goldberg, the chief doctor, comes to me and said, David, you are my best friend in this camp.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "I don't have anybody else.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "Americans are approaching.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "We heard even artillery fire.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "And we were digging, you know, against the tanks-- holes against tanks, something.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "I don't know what you called it, outside-- the work.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "He said, he came to me, he said, David, you're the only friend I have here.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "I'm going to send you to Hersbruck to organize a hospital there.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "Because here, when the-- before the Americans came, over 35,000-- the whole camp-- will be finished.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "And they did kill them all off.",
      "word_count": 7
    }
  ],
