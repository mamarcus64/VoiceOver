  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "The guy who captured them was gonna drive-- he was gonna ride the horses and drive my parents by [? wood ?] to the-- running by foot to the city to be killed.",
      "word_count": 33
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So he did my parents a favor, [?",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Safka. ?] He ordered the horse and buggy they should take him to the cemetery where they're supposed to be killed.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They told me that now when I was there.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "It was two years ago.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "That [?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Safka ?] was-- felt bad that my parents were captured.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I mean, that was his daughter that was hiding me.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "See, so they brought them there to-- to be killed.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So they did the favor.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So that was the story from-- from before.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Now we'll go back to me sitting at that Nazis area.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It was a good place away from the city.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "But the war with the Ukrainians.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "The Ukrainian burning, burning day and night.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "The whole Ukrainian, by the end of '43, was black.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So many killed.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So many burned.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And they were killing each other.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "One-- the one of the Ukrainians who-- who was telling my sister who the girl captured to-- I'm going back.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He told my sister the plans that that lady made.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He was one of the four so to kill us and bury us on the farm.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "He was one of them to capture us.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "So then when she let my sister go, he told her her plans, that she had their graves ready on the farm to capture us both and kill us.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "When I went back at night, remember this story?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "So the-- the-- this guy killed his brother to take his boots away.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So this is how they were going killing each other, the Ukrainians, like-- like-- like animals.",
      "word_count": 16
    }
  ],
