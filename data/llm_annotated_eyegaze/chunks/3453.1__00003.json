  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I told them that I am [NON-ENGLISH], that means Samuel's daughter, they used to cry over me, and give me food.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And he was-- he was helping people.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was a student.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I went to a Tarbut gymnasium they call it.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It's a Hebrew-- and it was acknowledged by the government, of course.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And we were checked, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Like inspectors used to come and check out if we have the curriculum and everything is there.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And it was a Hebrew gymnasium.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Predominately Hebrew [? it was. ?] If they were-- if they were Orthodox, my mother was more so than my father.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "My father was a very modern, very updated.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He was--",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "He was very modern.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Not regularly, but to we used to go to shul, especially on the holidays.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In Sarny, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We-- I remember my father-- and I remember [NON-ENGLISH], you know.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Especially when the kids used to come, I remember going with my father.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And they called it this-- this-- this synagogue [NON-ENGLISH] Shul.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "You know, this is a commerce.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "All people who were in commerce or something, they belonged under or something, I don't know.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "But this was the shul.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And I liked-- I remember liked very much to go with my father whenever.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The name of the rabbi, no.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "But the name of the second shul, I remember, Rabbi [?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Karlinkski, ?] I think-- Kunda, I'm sorry, Rabbi Kunda.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And a few times I was dragged to go to-- to-- with-- with my friends to come with them, and this was like a [?",
      "word_count": 25
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Gordonia ?] or something.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We used to dance and this, and horahs.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And-- and that was appealing for a certain time.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And then I did not proceed.",
      "word_count": 6
    }
  ],
