  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So I got to be a pen pal with a girl for three years.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And I said, gee, I would like to meet this girl one time.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "So I decided to go to France.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "But I said to myself, I've been to France.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "It would be a mitzvah to bring her over here.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "So I sent her a ticket, and she came here to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "And that was Vera.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "That's my wife.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "That's the way we met, after-- she was also in a children home from there.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "She was in a children's home in-- in France?",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In France, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But she was born in France, in Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "She was born in 1938.",
      "word_count": 5
    }
  ],
