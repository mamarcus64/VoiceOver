  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 9,
      "text": "In, in the Ukraine, it's-- the Ukraine and the Polish people can do nothing to you.",
      "word_count": 16
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 10,
      "text": "I remember I was in a meeting, and we say, when we can get something like clothes, or material from the Jewish-- from the Jewish people.",
      "word_count": 26
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 11,
      "text": "And they called them [NON-ENGLISH], they call.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Jew.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "And the man where he was working with the Russian.",
      "word_count": 10
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "He says, we don't have [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "We have [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 4,
      "text": "It's nicer.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Hebrew, Hebrew, right.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "And they shut up him.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "And he couldn't talk.",
      "word_count": 4
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 3,
      "text": "And the Russian, at least they didn't kill nobody.",
      "word_count": 9
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 4,
      "text": "It was everything fine.",
      "word_count": 4
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 5,
      "text": "We even managed-- we, we don't-- we don't-- it was not so great a war, but at least not killing.",
      "word_count": 20
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 6,
      "text": "It was a lot of refugees coming in to us.",
      "word_count": 10
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 7,
      "text": "There was a lot of refugees from Germany come in in Kolki.",
      "word_count": 12
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "From Germany.",
      "word_count": 2
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "When Germany come in, they were very, very intelligent people.",
      "word_count": 10
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "Very intelligent.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "German Jews, yeah, They have right away jobs with the Russians.",
      "word_count": 11
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "They give them jobs and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 2,
      "text": "And it was good.",
      "word_count": 4
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 3,
      "text": "Even, even--",
      "word_count": 2
    }
  ],
