{
  "stem": "7238.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "My mother kept us calm with her constant assurance that the great commotion is only a military exercise of the Polish Air Force.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "She was so brave, a real heroine.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "After a few days, the constant bombardment came to a stop.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "The Polish army, defeated, was fleeing to the east, and with them, thousands of helpless civilians.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "My sister, Lucy, and her family were on vacation when the war broke out.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "They joined the other civilians fleeing behind the army.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Only after weeks, we found out that they are in the east, Baranowicze, safe, but without any means of survival.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She was there with her little girl of two and her husband.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "We heard already about families who came from Germany because it was an expulsion of Jews from Germany.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "They came in their nightgowns, in their robes, chased out by Hitler.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It was already since 1933.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We tried to accept those people and hope that this happened only where Hitler is, but he will not be able to come where we are.",
      "word_count": 26
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My first encounter with reality was the day I saw German soldiers seeking for water.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "They ordered me to drink first to make sure it's not poisoned.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "On the street, I saw dead bodies, rows of rows of captured prisoners and mighty tanks.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I was scared and ran home.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Here, I was safe.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I ha-- I had my parents, my loving home.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "Food was scarce, but we managed.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And now, gray days followed with no hope for the better.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And then the first order of the day-- Jews must wear the yellow sign, register for work, give away fur-- furs and jewelry.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "A couple of months.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish committee was responsible for supplying enough workers.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My father was too fragile for hard labor.",
      "word_count": 8
    }
  ],
