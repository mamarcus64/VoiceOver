{
  "stem": "10710.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "He later became-- he went to Bielsko, where my sisters lived.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And he became working in a printing office-- printing factory, whatever it is.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "They used to make all kinds of letters, headings.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And my third brother was-- was name was Benek.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "He was like three years older than me.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "So we use to fight a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And he also wound up in Bielsko, working for another company there.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And what was left in our house was my mother, my father, my sister, the youngest Mala, and me.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "The rest of the family were away.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Well, before the war, there were about 500 Jewish families.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I mean, 500 people-- Jewish people, excuse me.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "There were about 150 families, right.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And see, there was a small town.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "So it was like a family.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Everybody knew everything was going on in somebody else's house.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "My neighbor knew what my mother was cooking for lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Everybody lived together.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And when we came together in shul, it was-- I still remember, that it's-- it was-- you know, everybody was together.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And it was a very nice life.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Because it was a small town.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And we live-- we lived together in the neighborhood from other people.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And one had the store with the grocery, one had the fish store.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "So we had to support everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "My-- my mother used to shop for Shabbos-- she used to buy flour in this store, and she used to buy sugar in the other store.",
      "word_count": 26
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "And she bought other things, challahs, somewhere else.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "Everybody should be able to make a living.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "We were supporting each other, because it was a small town and everybody depended on the other guy.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "There were very few rich people in our hometown.",
      "word_count": 9
    }
  ],
