{
  "stem": "17301.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "Next morning, that was that day.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "I came back and naturally, I found my mother and my sister in the same condition as-- as much as-- as I left them, very, very poor.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "My sister didn't stop crying.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "She was-- she says, I'm going to die here.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "I'm going to die here, because they weren't-- they didn't really pay any attention to her.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "They didn't give her any food.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "I mean, she was really starving.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And I kept on telling her, you're going to see.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "We're going to be liberated.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "I-- I-- I can hear from a distance.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "I hear something that is-- I bet you, that's the bombs.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "I said they're bombing some place around here.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "She says, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "I said they're bombing, because I can hear it.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "I can hear it.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I found a girl, a Polish girl, who befriended-- who was befriended by a German soldier.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I said to her, did you hear anything, any news at all?",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "She says, not really.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "But I can tell you something.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Says they're bombing all over the place here.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "She says, I bet you anything, she says, I heard the radio, because he let me listen to a radio.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "We will be out of here in about two days.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "So I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And I said to my mother, and I swore.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I said please, believe me, because I heard it, my own ears.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I say, I heard it.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "We're going to be liberated.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Next morning, [INAUDIBLE] it was like about 4 o'clock in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "The barrack where we were, we had windows.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "But, of course, they had the bars on-- on all the windows.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I looked out the window, and I saw a very familiar face that was one of the SS men.",
      "word_count": 19
    }
  ],
