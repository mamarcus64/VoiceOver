{
  "stem": "4289.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I did not realize how hard it was, because I was a child.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But when I look back, there were no notebooks.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "There were pieces of paper or brown paper that we used.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember using a toothbrush.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember of smelling nice soap.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "The dishes were washed with ashes left from the oven.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And that's how we heated our apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "My stepmother was unfortunately, a real stepmother.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "She did not like me, because she lost her own children in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I don't know why.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "In a way I do know.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "She was bitter that her children did not survive.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And sometimes when I was bad, she blamed me for her children not surviving.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And she got the habit of hiding food.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "So I was always hungry because she hid the food.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "If she made something, she would hide part of it.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "Then, you know, when it was rotten, I would find it on top of the credenza.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I cried.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I wanted to leave.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I told my father, why did you take me out from Transtahova, where there they loved me?",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "They were good to me.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And my father said, because you don't belong there.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "What will you be if you be in Transtahova?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You'll be a drunk, he told me.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "That's the family you grew up with.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Which was true.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Everybody there was drunk.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "So I stayed on.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And then I made a lot of friends in school, to which homes I used to go.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "On weekends I used to sleep over.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And it took me forever to go home from school.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "I took the longest route to get home late, so I won't be with my stepmother.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Did you enjoy school?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I enjoyed it very much.",
      "word_count": 5
    }
  ],
