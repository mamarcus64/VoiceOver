{
  "stem": "27390.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And-- [PAUSES FOR 5 SECONDS] In the country, on-- on Saturday night, we used to have, I remember-- we used to have a gramophone with a handle that you had to turn up with, with records.",
      "word_count": 36
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And we used to play a lot of Jewish records, Hazzanut records, all kinds of classical music.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "That was the entertainment.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "In-- at home, in town, we did have a radio.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "In those days, a radio was really considered a luxury.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "We also had a telephone, which was very unusual in those days in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "So in other words, we were quite-- we were not-- I wouldn't say we were very rich, but we were comfortable.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "My father made a very good living.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "We had a textile shop in, in, in, in the center of Lodz.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 23,
      "text": "And we lived in a good area where the rents were very expensive.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "We had two rooms and a kitchen, which was already considered a good-- a good size-- a good size apartment in that area.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "The rents were very expensive.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "We had my-- two bedrooms and a kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "And then we had another room next to it, sort of a living room.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "My parents slept in one bedroom.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "And me and my brother slept in the other bedroom.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And my sister slept in the kitchen on the put-you-up bed, which was put together for the day and they brought out-- was bought out for the night for her to sleep.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Shabbat was celebrated Friday night.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Everybody had put on their, like you say in English, their Sunday best.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And Friday night we went to synagogue, which wasn't very far from us.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Talking about synagogues, Lodz had many synagogues, as you can imagine.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And-- but three of them were very beautiful synagogues.",
      "word_count": 9
    }
  ],
