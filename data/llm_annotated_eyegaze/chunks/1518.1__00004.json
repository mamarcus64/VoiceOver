{
  "stem": "1518.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "They were about a-- a mile from us.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They took my two year older brother.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "They took my oldest brother to the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I was too young.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Simcha.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He was two years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And Abi was my half-brother.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Those two were in the labor camp in Sasow, not far.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And us they took to-- to the ghettos, Zolochiv.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They took me, my mother, and my father.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Golda, Leah Golda.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Sandel.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That-- that's the name-- when I escaped from the ghetto, that's the name I used right through the war, Sandel.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Instead of Janek-- Jacob-- I was called Janek.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "That was it, till-- till-- till right after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The Gentiles took us with sleds.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It was in wintertime, very cold.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We almost froze to death.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Was an announcement.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Was an announcement, this and this day, and everybody had to move.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they took-- took about, I don't know, a few hours, and we came to Zolochiv.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "At Zolochiv, they gave us one little room, a cubicle.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And that was-- that was it.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "It was like a concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "It was-- then they-- they put up the barbed like the wires, you know, like closing off the streets.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't get out.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "But I lived right by the-- my house, where I stayed in the ghetto--",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "It was an apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It was right near the wires, by the fence, so I used to stay there and watch.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I used to go out every day-- used to go to the villages, for food.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "If I didn't bring food, we-- we would have starved.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "People used to die like flies in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "They used to-- there was a Judenrat.",
      "word_count": 7
    }
  ],
