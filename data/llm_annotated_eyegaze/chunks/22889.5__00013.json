  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 25,
      "text": "You had your own particular place with the groups then.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 26,
      "text": "We stay like that from about 6 o'clock in the morning till around 7:30, 8 o'clock, rain or shine, stay like that like a soldier.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 27,
      "text": "An SS trooper used to walk around.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 28,
      "text": "Then we start to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 29,
      "text": "[PAUSES FOR 3 SECONDS] At the gates, orchestra play marches.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 30,
      "text": "We used to march to work.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 31,
      "text": "The kapo, the, the commander of our camp, stay outside every day.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 32,
      "text": "And the kapo had to stand, took off his, his hat and report to the commander that his group number is 48, so many, so many men.",
      "word_count": 27
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 33,
      "text": "We marched 10 in a row.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 34,
      "text": "Count us out.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 35,
      "text": "We march to work.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I can't think.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "They hang him after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I know that.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I can't think of it.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "My mind, my memory's forgetful already.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
