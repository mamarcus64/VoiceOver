{
  "stem": "16930.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Henry Kreisel, K-R-E-I-S-E-L.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Vienna, Austria in 1929.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "April 26th, 1929.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I'm the oldest.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "There's two of us.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I have a younger sister named Gerda.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "She was born in 1930.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "She is a year and a half younger.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My parents-- I left there when I was 10 years old or 10 and 1/2 years old.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And I do remember my parents.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They were good people.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Names were-- my father's name was Michael.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was [?",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Minah. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The Hebrew-- the Hebrew name is Mickha'el, the Hebrew name.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And the-- and the name of my mother was Myshka.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I think it's a Polish name, Polish name.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father was born in-- in 1886.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was born in 1895.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My parents had a-- a grocery store at one time.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Then they had a haberdashery store.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And then I guess a result of the depression, they-- the store went under.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And my father worked for my uncle in a-- in my uncle's haberdashery store.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My-- my parents were Orthodox, 'cause I remember going to shul with my father.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, I can't describe in terms of community, 'cause I wasn't thinking in terms of community.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My schedule was I went to a regular public school in the daytime and I went to a cheder, a Jewish school, after-- after the regular public school.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So that, in addition to playing with other kids, took care of my-- my social life, and going to shul with my father.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I experienced quite a bit of anti-Semitism.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "There was in Vienna-- there was various-- a lot of anti-Semitism before Hitler.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Hitler didn't create anti-Semitism either in Germany or Austria or any other part of the world.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He only took advantage of it.",
      "word_count": 6
    }
  ],
