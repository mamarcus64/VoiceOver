{
  "stem": "26609.12",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And I was afraid to go home, because if I go home, they will find out there is a child, and whose child is it?",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "They'll start asking.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I didn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "There was a bench.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "On the street, as you go there, there are a few trees and a bench there.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And every Sunday-- it was a small place-- the soldiers-- that was in Poland-- the Polish soldiers used to dance with the peasant girls.",
      "word_count": 24
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I sat on the bench there, and I sat on the bench.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You know who came back?",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "These two men-- it was night time-- one is this, and one here, both sat there.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "They sat down near me, these two men that went after me, the police, and said, why are you sitting here?",
      "word_count": 21
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They didn't say, we remember you, that you went out of the prison.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Just like that, why are you sitting here?",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Why don't you go home?",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I said, because I have no home.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "My home is in Brody, and I haven't got money to go for a train.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "Could you, could you help me out?",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Could you give me something, some money, then I will go home?",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "They said, no, we have no money to give.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "We can't give you any money.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "Then I said, all right, so why-- why do you sit here?",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "Leave me here.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In the morning-- it was late in the evening-- in the morning, I'll go.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Maybe I'll find someone who will help me out.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "I want to go to Brody.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Brody was a city further.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So one started-- he thought that I would tell him to come nearer to me, you know, and advancing.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I said, aren't you police?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I know you are police people, aren't you?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He said, yes.",
      "word_count": 3
    }
  ],
