  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "You knew that a Jew doesn't go drunk in the street.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "A Jew takes care of another Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Make sure that you help, that you give the ones that don't have, even if you have less, that you do not hurt other person's feeling, that you not embarrass another person, that you show respect to authority, that you show respect for elders.",
      "word_count": 44
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "All these things-- they were not taught in the way that the Torah is taught.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "But they were taught as a way of life.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "This was a way of life.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "You don't do that.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "You know the law.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "And if you ask why, he says, don't ask.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "The way of teaching in the [INAUDIBLE] in Europe was not the way the young people would expect--",
      "word_count": 18
    }
  ],
