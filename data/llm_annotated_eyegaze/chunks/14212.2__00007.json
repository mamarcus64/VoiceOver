{
  "stem": "14212.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 572.3,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "Rochele. ?] She had a husband, three sons, and two daughters, all married with children.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "One daughter left Poland before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "She lives in Paris.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "And one son survived, hidden all the time by a Pole, who didn't know them, and he didn't know them.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "They-- he survived there and married the daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "And he lives in Red Bank, New Jersey, now.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "And another aunt, my father's sister, lived in Kozienice, Kuzma--",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Kozienice.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Had a husband and four kids, all vanished.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And the uncle must have passed away last year at the age of 87.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "This is from my father's side.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "My mother had [PAUSES FOR 4 SECONDS] Fraidle, a sister, an older sister, a husband.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "She had three sons and a daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "The oldest son and the youngest son was murdered during the war.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And the daughter had three kids with the husband.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They all vanished.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "One son, he had a wife and two kids from Kielce.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "They vanished.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "He survived, and he died in-- in '89 in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Another sister, she lived in Lodz.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "She had six children.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "Two sons survived, but one was killed in Lodz after the war.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And one died in Israel, Tel Aviv.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And the rest, one daughter left Poland before the war to Argentina.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "She's alive with her kids there.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "On that end, my mother's younger sister, which photo of their wedding is here.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "She had eight children.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "None survived.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 6 SECONDS] I have one aunt, who went in 1938, in December of 1938, to Argentina to Buenos Aires.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "The uncle and aunt died.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "Two cousins died there already.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "And I still have a cousin and a sister there, two sisters still living.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "This is more or less the first immediate family.",
      "word_count": 9
    }
  ],
