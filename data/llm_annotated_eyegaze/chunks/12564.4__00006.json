{
  "stem": "12564.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "At that time, we had no money to buy food for the-- to start to grow a chicken again, when they mostly died.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "There was no insurance.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Now they do have insurance in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "At that time there was no insurance.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I understand you have to go to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "But you have to cover somebody what has such a losses.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And you have to start building, again, the same thing.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "But I went to a supplier, to Rehovot.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "His name was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I got back from the army.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I said, [?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Zwe, ?] could you help me?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He said, what do you need?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I said, I want to start again.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He said, you really want to start?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "The price is so low.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I said, you don't start when the price is high.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I will start when the price is low.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But I don't have money.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And if I don't succeed with the chicken, I will not have money to pay you until a year, I still have 10 calves, until they grow up.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And they will be one-year-old.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I think they will cover the foot.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "He said, anything you want, you have it.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "When the first chicken were ready, it took three months.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "The price tripled.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And I started making plenty money at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "This was 1956, '57.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And I decide to build a big house for ourself.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Leave the house as it is and start building.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So I had grape trees all around the house.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "So one place, I decided to cut out the trees.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And as I was standing and cutting the trees, came the mailman with a letter from the US Embassy.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "If I don't pick up the visa, I will lose my term.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I got registered about five years earlier.",
      "word_count": 7
    }
  ],
