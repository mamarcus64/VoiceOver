{
  "stem": "18397.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "But they didn't tell me about it.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "And I didn't ask him, what-- you know, is there such a bunker, then we'll come.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "Anyway, we came into-- to [?",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "Kylis, ?] where we used to make the fur, used for the soldiers.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "And we were there, and I find out from this girl.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "Her-- her-- her father was a [NON-ENGLISH] in Vilna, a big deal, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "And he was there with-- with my parents, together with maybe a hundred people in the bunker.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "This was a bunker between-- between the ghetto and the outside.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "You should be able to get in through the-- through the sewers, you know, sewers over there.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "You had to go and walk over there in the sewers.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "But you couldn't walk straight.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "You know, you had to-- And my father and mother was there, and his mother went away with the other people from-- from a town, you know.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So he didn't have to go.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I had to go myself.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So I find the-- the girl.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "She was the-- the [NON-ENGLISH] daughter.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And she knew them.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "She was a brave girl.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And she knew everything.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "But she-- but she belonged to the organization.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And then she had some--",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, we went to go over there.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "She didn't have to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Because she had papers, you know, a girl could have papers.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "If she had papers, good papers, she didn't have to.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But a guy couldn't, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "But [INAUDIBLE] you're Jewish or not.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "So I went with her in the streets.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "We got into the bunker, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And we came-- came into the bunker, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Nobody was there.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "A woman that got left over with a baby, she couldn't-- she didn't have no place to go.",
      "word_count": 18
    }
  ],
