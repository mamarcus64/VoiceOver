{
  "stem": "3022.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we-- my-- no-- the family got together, my father, I, and my uncle.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We decided that we should volunteer.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And about 100 men, two truckloads were loaded up.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And we went to the labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "When were leaving, the families were lined up on the streets saying goodbye.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And the last picture, the last vision that I have of my mother, is her standing there with her arms on the shoulders of my little brother.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "My little brother crying, and my mother saying to me, saying goodbye to me, and telling me, I shall never see you again.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "This is the end.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "That was her premonition.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "[COUGHS] We went to this place that-- called-- a labor camp, [NON-ENGLISH], which was a labor camp attached to an airplane factory, to airplane manufacturing, the Heinkelwerke.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "About five weeks later, in July, the village was rounded up and all its inhabitants, contrary to the promises that the Germans made, were marched on foot to the town of Debica.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And the next day, put on the train and taken to the Belzec extermination camp. - Now this is your mother, your brother-- My mother-- - And many other relatives.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "My brother, my grandparents, my uncles, my aunts, my cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Total, about 56 members of my father's family in one day.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "We-- I found out later on, about four weeks later, when they brought people from the town of Debica to our camp, and the conversation was a fellow who was a druggist.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "He was telling me about this-- about a transport from Wielpole, having brought to Debica.",
      "word_count": 15
    }
  ],
