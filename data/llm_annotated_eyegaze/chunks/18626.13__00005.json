{
  "stem": "18626.13",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "I walked in a bowling alley.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "The man says-- I said to the man, do you have old bowling pins you want to get rid of that?",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "He says, yeah, about-- we were going about to throw them out, because the fire department is on my neck already all week.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "It's a fire hazard.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "Take all of them.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "So I took the bowling pins.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "And I had a old jalopy station wagon, a broken one.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "I loaded up it was-- [INAUDIBLE] all the pins.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "I brought the pins to my shop, to the little shop I had.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "I cut away the neck from the pin.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "And the heavy ball-- the heavy belly on the pin, I turned out the lawn mower roller, the wooden roller.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "So it didn't cost me no money.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And I start to supply all the lawn mower repair people.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And then I found a store where they sell lawn mower supply for the lawn mower shops.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I came in.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I said to the man-- his name was Walter, a nice person.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And they had [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And they saw my roller.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "After I turned them, I took machine oil from the cars, you know, what you use the oil, and I dipped in machine oil, and I wiped them out, and they came out like a piece of amber.",
      "word_count": 38
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I brought them.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He says, wow.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "How much you going to charge it?",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I said, $0.50.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "How many you got?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I says, just a sample.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "He says, make me 50 right away. 50 pins is $50.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "It's $25, $0.50 apiece.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I made it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I brought it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "He says, make me a hundred.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And that man-- I was about to leave already Miami, because I couldn't make a living.",
      "word_count": 16
    }
  ],
