{
  "stem": "27543.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.3,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "One day, a lady brings-- at that time you couldn't bring in bacon or this or that.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And she says, I got here 10 pounds of bacon. 10 kilo bacon.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Can you sell it?",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And then the little store start open.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "There was a butcher named Schwartz.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And I know the guy a long time ago.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "I go to him.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "I says, [INAUDIBLE], can you use 10 kilo bacon?",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "So yeah, he says, sure.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "How much you give it to-- how much you pay me?",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "He said, how much you got?",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "I says, about 10 kilo.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 12,
      "text": "He said, I'll give you 80 cents for a kilo.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I said, I just got 60 cents.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "That's good.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "So I made $2 on it.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "She said, but if you want I can bring you a whole hog in.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "A whole hog in.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "Brought in the hog.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "I made 50 bucks on it.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "Then I heard that they bring bacon and eggs.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "You get-- you can get a permit to bring for the English, American, French, and the Russian embassy, all these chickens, eggs, no bacon and no fat.",
      "word_count": 27
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "No nothing of these kinds of things.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "So I got in touch there with a Russian, who know how to do it.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "So what did we do?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "We went out in the farm.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "In the farm we bought salt.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And we went to Romania to buy salt for two cents a kilo that time.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Went to the farmers.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "We give them four-- four kilo salt for a kilo bacon.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And for a kilo bacon, we got a gram gold.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So our money got 40 times.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We doubled our money in a day.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "In two days.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "So end of it, business was so-- but easy.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] told me, forget it.",
      "word_count": 5
    }
  ],
