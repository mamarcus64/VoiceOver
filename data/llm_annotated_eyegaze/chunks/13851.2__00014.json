{
  "stem": "13851.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "My brother saw me next day I was out, after a few days out, so I bandaged.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "I told him what happened to me.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "So and then I was assigned to the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "We didn't go back to the same murder company that I worked for.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "I was assigned to a different company.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "I got [? helped ?] to work with some other people.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't so hard work.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "What-- what kind of work were you doing then?",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "The other one was like mechanical and something with metal, keys or something-- like, something like metal things to do.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "It was not hard.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No, he was in separate barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He was a tailor, and so he was sewing things for those kapos, for the German kapos.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "They were, as I told you, criminals.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "But-- so he had a little bit more food.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And one time, I remember, I was-- in-- one of the kapos knew that I'm his brother.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And he put me to work to put-- load something those wagons, the little wagons.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And I know, he came to me, the kapo, and he hit me with a shovel in face.",
      "word_count": 18
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "I was bleeding.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "I said what the heck.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "He-- he knows I'm a brother to Sol, and he sews for him things.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "But that was a little bit crazy.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 11,
      "text": "I was bleeding.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 12,
      "text": "He hit me with a shovel.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE] So true.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 14,
      "text": "Excuse me.",
      "word_count": 2
    }
  ],
