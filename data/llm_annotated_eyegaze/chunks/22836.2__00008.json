{
  "stem": "22836.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "We always have empty bottles with-- with us for water, sometime milk, we get in.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "We get it.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "And was the runners and the bringers.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "We was the-- everything for survive for the other-- for mine other brother, the older one, and my wife, and-- and-- us-- in-- and the brother-in-law.",
      "word_count": 26
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "They was like more-- more religious, and more-- not active, like we was active.",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 9,
      "text": "And we was active.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 10,
      "text": "We was active.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 11,
      "text": "We were surviving and helping.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "We don't get no kosher.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Everything was kosher.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "You don't get nothing not kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "They gonna give you-- they give you-- what they gonna give you a pig or something?",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "Nobody will give you nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "You're lucky you get a-- sometime a bottle of milk or a piece of bread.",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Into the woods, because we see--",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, you have to go only to good people where you know them.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Not-- you can't go to everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Because if they go to everybody, they say right away, I saw Louis.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I saw him with-- I see with Mayer, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "Then they start looking for you.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "This way, you try to hide.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And we was going only in the days when the moon was not the moon.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "Once a month, when-- when everything is dark.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "When it's light, I never go with Mayer.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "Always we go when it's dark.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "And then nobody see you.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "And you-- you can get through.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "That's when we was going.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "And we survive.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "And we don't-- when we get up-- pulled up-- I get like 60 pounds.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "They call them a pit in Europe-- a flour-- not flour-- it's a wheat-- wheat-- wheat where you can cook them and eat them.",
      "word_count": 24
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 14,
      "text": "And I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 15,
      "text": "We were strong.",
      "word_count": 3
    }
  ],
