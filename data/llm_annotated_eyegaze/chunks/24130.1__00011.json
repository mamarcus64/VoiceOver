{
  "stem": "24130.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "And they says, no, she can't do it.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "She's a child.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "She-- she can't do it.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "My father put a little box for me, because I couldn't reach a table.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "He says, my Chavalah could do it.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And they watched the matzoh till it came out from the oven-- because if it was thinner or heavier, it would burn.",
      "word_count": 22
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "So my father was so proud of me, that I could do it.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So we used to go to bake-- we got paid for it, and we had to pay for the-- for the-- that they bake.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Let's say, we had 25 kilo flour, so we paid, let's say, two pengo a kilo.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So they paid me 10 pengos a day, so, you know, it evened out.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "So my sisters and my brothers were worked already, and my father.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "So it gave us a little work, because there was very little work there.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "We had to make a living, so before Pesach we used to bake our own matzoh.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "We're going to stop here to change tapes.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
