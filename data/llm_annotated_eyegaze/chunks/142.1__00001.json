{
  "stem": "142.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "But unfortunately at that time in 1938, Hitler and Mussolini got together and they didn't let anymore Jewish Italians go to the Italian universities.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "We live in-- mostly in a Jewish neighborhood.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The-- we lived in a quarter called 151 in Salonika.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Actually, the Jewish community bought all that section from-- actually, they were barracks of the Italian army from the First World War.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And when the-- when the First World War finished in 1919, that was left over, and the Jewish community bought it and we were living there practically for very little money, you know.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, the-- my grandparents on my-- on my mother's side living-- were living with us, in the same-- in the same-- actually in the same house.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Their names were-- her name was Allegra, you know, and his name was Bohor.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Their last name were Beraha.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had a lot on activities in the Italian school, actually a lot of athletic activities there.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And we-- I was also going every year-- the school took us for two, three months in the summer to Italy, free you know.",
      "word_count": 24
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, I used to play in a band with a clarinet.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was very much.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "It was beautiful.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "We used to go to-- they used to take us to Como, di Lago Como, and then to Cortina d'Ampezzo, you know, and then the last month we used to be in Rome.",
      "word_count": 33
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We used to go about for seven days by boat from-- from Salonika to Italy.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And from there, it was a beautiful three months during the summer, because it didn't cost us anything.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "We have-- you know, we're enough Jewish Italians-- a Jewish Italian colony in Salonika.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And lots of them were well-to-do people.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And I had quite a few friends.",
      "word_count": 7
    }
  ],
