  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And the other gate was in-- Hmm, in [NON-ENGLISH], [NON-ENGLISH] on the-- on the-- the-- on the [NON-ENGLISH], [NON-ENGLISH], [NON-ENGLISH], which I couldn't remember it.",
      "word_count": 25
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Near [INAUDIBLE] [NON-ENGLISH] Going to the square of [? what ?] [? was ?] [? this ?] creek.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "German.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "By this time, I was going-- I have the-- the paper from-- [INAUDIBLE], I don't know what it's called-- [PAUSES FOR 6 SECONDS]",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And I am allowed to go to the work at seven o'clock in the morning.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And I have to come back whenever I were ready.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "But before nine o'clock.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "The same job.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was-- [PAUSES FOR 3 SECONDS] --officially, I was a worker for-- for car repair, in workshop.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But I-- I know these people from-- from the-- before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And we make an-- an arrangement that he will take all of my wages.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And so it was not a big deal.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "But you know, when the Germans, they have five people.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Give me give Jewish people.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't care less.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "They said that's what they get, the same a [? privatization ?] with the Polish people.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "So he took-- took the-- the-- spirits, what I get twice a year, and working, clothing, and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "He-- [? anyway ?] I-- I was from very short distance from him.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "When he expected somebody is coming, he give me a ring.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "And I jump on my bike and wait in place, waiting for the-- this coming back into my work.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "In a-- in a soda water factory.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "To make a living.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Oskar Schindler, I meet-- I met him-- met him later.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "But before I met him, after the [INAUDIBLE] in '42, I find out that I was without place to work.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Because I was one worker.",
      "word_count": 5
    }
  ],
