{
  "stem": "3928.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "You know, it's a-- in a family, when they have wealth in Europe-- and I don't know how is this here-- it's a jealousy, that since two boys in the family, if somebody dies, who will inherit, you know?",
      "word_count": 39
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And she felt threatened by me, since I was the eldest.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "But my brother and I, we did not felt this way at all, you know, whatsoever, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "His name was Pal.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Pal, P-A-apostrophe-L.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Now, I know there is a Jewish connection in your family.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my father was Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "My mother wasn't Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And when I was-- when my mother died, my family, non-Jewish family raised me.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And so I lost completely contact with any kind of a religion so to speak.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Because they weren't religious people, at all, you know, really.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So I used Sundays to go to amusement parks and movies.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And this was my church service.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You know, Hopalong Cassidy and-- and-- [LAUGHS] and-- and what they call or-- or the other American movies, they were my church service Sundays.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I spent sometimes five, six movies a day, because they were a part of the family outside of us.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "What they were in the entertainment business, so I had a press-- pass for all the movie theaters.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "So I just roamed around movie theaters watching movies.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "When Hitler came to power, I was very much, as a young man, you know, appalled, because of my friends, because I had a lot of Jewish friends, you know, whom they had no idea what my background was, because we were-- you know?",
      "word_count": 44
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I lived with my aunt and so on.",
      "word_count": 8
    }
  ],
