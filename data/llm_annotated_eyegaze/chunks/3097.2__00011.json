{
  "stem": "3097.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Ours was the first-- the first one.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And so they prepared this area.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "There was grass and something growing to cut it, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He was in charge of it-- to cut it and make it ready.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "So we knew that will happen-- something will happen.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Everybody had a bundle or something, to take with himself-- with him.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And when we went to the place there, it was real chaos.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "There was people laying already killed, and destroyed, and crying, and children lost, and then packages, and valises, and tanks around.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "It was really something tragic.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I didn't see my father anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was with my mother and my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And we worked, you know, around.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They worked in the-- in the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We worked together.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And I worked in the-- in the-- in the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So we had-- everybody had a special, [NON-ENGLISH] you see? that was a-- a document-- internal document, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And they started to make a-- they took us to the place by the central synagogue, OK?",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And there was the selection.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Geyer and Thomas were there.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And you had to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And they ask you to show the document-- where do you work, you see?",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "So my mother said, I am in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "My sister and I-- OK, you go there.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "Where do you work?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "I said, Ludvikov.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "Oh, go with them, right there, OK.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "If they-- older people, children, women, right away to the other side, OK?",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "So I was left with my mother and my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "My father was not there anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "So they went in the temple, in the synagogue, to rest.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "And I was still around, you see.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "And suddenly, they surrounded me.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "Some Ukrainians surrounded me by the temple there.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "And they said, you go to work.",
      "word_count": 7
    }
  ],
