{
  "stem": "11611.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I also participated in lots of commission hearings, I mean, I would say at least 12, 15 of those.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember the exact number.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They were mostly of defense witnesses.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Clumsy, but effective.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know anything about trial tactics or finesse or grace.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Rasche was a terrible liar.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "It was built into his soul.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Incidentally, I should say his defense counsel was an able lawyer who had defended von Papen in the big case and gotten von Papen off on multiple--",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "His name was Egon Kubuschok.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was the German defense counsel for Rasche.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Franz von Papen was the head of the Catholic Party in Germany, which, when Hitler became chancellor, had thrown in the Catholic Party vote to Hitler, and thereby became deputy chancellor when Hitler became chancellor in '33.",
      "word_count": 37
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "He fell out of favor a little bit later and wound up only as ambassador to Austria before the Germans grabbed Austria, and he contributed to the taking over of Austria.",
      "word_count": 31
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But he was acquitted in the major trial.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He was one of the three people who were acquitted.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Three people were acquitted before the IMT.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "One, of course, was Schacht, who was the president of the Reichsbank.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "The other was von Papen, who was deputy chancellor at one point under Hitler.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And the third was a operative in the ministry of propaganda in Goebbels's operation by the name of Fritzsche, Hans Fritzsche.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Don't ask me to spell Fritzsche.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "For Rasche and Dresdner Bank.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "He was a good lawyer and as far as I know was a pretty good man too.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No, and that was very unusual.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Kubuschok was a guy who had practiced law in Berlin before the Nazis.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "He was a rather competent, able trial lawyer.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "That was his business.",
      "word_count": 4
    }
  ],
