    },
    {
      "segment_idx": 244,
      "sentence_idx_in_seg": 0,
      "text": "In somebody's house.",
      "word_count": 3
    },
    {
      "segment_idx": 245,
      "sentence_idx_in_seg": 0,
      "text": "And I-- I'd-- I'd been starving from hunger.",
      "word_count": 8
    },
    {
      "segment_idx": 245,
      "sentence_idx_in_seg": 1,
      "text": "And my child starve from hunger.",
      "word_count": 6
    },
    {
      "segment_idx": 246,
      "sentence_idx_in_seg": 0,
      "text": "They didn't give me food, no.",
      "word_count": 6
    },
    {
      "segment_idx": 247,
      "sentence_idx_in_seg": 0,
      "text": "He was-- he's at the field, eating.",
      "word_count": 7
    },
    {
      "segment_idx": 247,
      "sentence_idx_in_seg": 1,
      "text": "And I had been starving with my child in there-- there, inside, in the house.",
