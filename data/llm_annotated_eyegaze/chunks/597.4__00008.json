{
  "stem": "597.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "So I made myself-- my-- a-- a mattress from-- from sacks.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "You put it in, sew together.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "You put in some straw.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "That was the mattress.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "No-- no sheets, no nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "No pillow.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And we-- and we-- we-- we-- we got some people to give us some blankets.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "Neighbors gave us some blankets.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "And we organized.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "We had no-- no table, no food, no nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And then we organized ourselves.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And we were starting-- and I start work for the Russians, the second time.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "I've worked in a office, as a bookkeeper-- [PAUSES FOR 4 SECONDS] --over there.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "And I worked in a office as a bookkeeper from-- from-- from a restaurant and from a dairy, different kind of offices.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "I worked in there because they mobilized people to-- to work.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "The Russians mobilized.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "They didn't have enough people to work in the-- in the coal mines.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "So they start mobilizing people to work in the coal mines.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "In the coal mines.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "See, I was a young girl.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "I didn't know what mean, coal mines.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "They want to take me to coal mines.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "If I'm working, they wouldn't take me out of work.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "My sister didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "At night, they used to come in and take people.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "They were then taking young people to the-- to the coal mines.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "So at night I didn't have to-- I couldn't sleep at home at that time, too.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "I used to go someplace in the attics to sleep, not in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "Because they-- they didn't-- they didn't ask you.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 37,
      "text": "They was looking for young people to-- to work.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 38,
      "text": "They didn't ask if you work, if you don't work.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 39,
      "text": "They take you.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 40,
      "text": "They grab you and they take you.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 41,
      "text": "The undercover, the KGB.",
      "word_count": 4
    }
  ],
