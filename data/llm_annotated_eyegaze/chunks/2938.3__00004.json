{
  "stem": "2938.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Certain people, they put to the right.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Certain people, they marched away.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And they start loading people to different camps, to labor camps.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "They had been shipping them, by truck, to Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "When I came to the segregation, he looked at me, he looked at me, and they put me into a barrack seven.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Others went to-- to-- to camps. 10 trucks to this camp, five truck to this camp, six truck to this camp.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I went into barrack seven.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "But when I went into barrack seven, somebody spotted me who was in Auschwitz already a long time.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "He says, Irving, Irving, this is you?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "He hugged me.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "He kissed me.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "He says, you are in a barrack that you will go to the crematorium tonight.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "In five hours from today, this barrack will be marched in the crematorium.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "I said, how do you know?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "You see, all those others on the trucks are going to the camps, to labor camps to work in Germany.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "And this barrack will go to the crematorium tonight.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "I say, what do you want me to do?",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "He says, you go in the back, is an open door.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "And stick out your head.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "If nobody's around there, when [? you look ?] around, when you trucks loading people, go in line.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "You will go to work in a camp.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Five minute later, I went to the back of the barrack-- my barrack seven was loaded.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "This barrack had room for 500 people.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We must have had 1,500 people in this barrack.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "So crowded, you couldn't breathe.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I went in the back, opened up the-- the door, gave a look, was quiet, I made 10 steps.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And they were loading a truck.",
      "word_count": 6
    }
  ],
