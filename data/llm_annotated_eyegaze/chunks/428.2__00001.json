{
  "stem": "428.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "So they took out the shoes from me in [NON-ENGLISH] and they told me to run in snow on the appellplatz.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Naked?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Naked. 10 times.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So I-- I figured out I was going to run the whole night, and I lived through that hell.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "But this was already-- yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And then the next day you're going to work again until they-- it was already close to the end the war because the Americans and the Russians, they used to bomb that camp.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So at night, when they-- we used to wait only, I was happy that they were bombing this camp.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So they used to take us to a tunnel at night when there-- when there-- when there was an alarm when they start to bomb that camp.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They take out all the people because they need us for work, to the-- to the tunnels.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "One time a bomb fell in the tunnel, the entrance and the exit from the tunnel was smashed completely.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't go out from the tunnel.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So we digged with hands and we made a hole smooth to go out from that camp-- from that camp.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So it was already bombing.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They bombing day and night-- the Russians and the Americans.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And they liquidated that camp, and they announced whoever no want to work, you should come out.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "They're going to take us by bus.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "They're going to take that people by bus.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "It was the opposite way.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "That people they registered that they can walk, they killed them all.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "The rest when they said they want to walk, they took us by bus.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "So-- and while-- while going by bus to that town, Ebensee, it was a camp in the mountains, in the woods.",
      "word_count": 21
    }
  ],
