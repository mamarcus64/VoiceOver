{
  "stem": "9665.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Are we going to Central America?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Are we going to South America?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "No, the furthest away is New Zealand.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We're going to New Zealand.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I said, Jan-- he was without a job.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I mean, they still paid him his salary, AKU, which was a large company.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But he went-- I said, you go to New Zealand.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "This is the furthest away from Europe.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Is so far away that, you know, whatever happen in the third world war, maybe we got a chance there.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Don't forget, we are talking about the atom bomb, which came down to Hiroshima.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "So he went to New Zealand.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He rang me.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I could hardly hear his voice because, at the time, the telephone wasn't working as well as it does now.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And we were screaming to each other.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And he said, this is the end of the world.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "This is not what you're going to like.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "But I came along a place called Sydney, which is very cosmopolitan.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "That would be for you.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Because he was a man from the country.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "That would be ideal for you.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And I said to him, fix up.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I had two children.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He had three children.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Go to Canberra-- that's the one thing I knew-- Canberra was the capital of Australia-- and fix up the papers.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And that's exactly what he did.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "He went from-- he fixed up the papers.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "He came back, and we went-- we left-- not Holland.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "We went from Italy.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "My brother was very upset.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Was [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "He was very upset, because we never had a fight.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "You know, once a year, we had a fight.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "He was pushing the money towards me.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "I mean, you know, visual-- not visual but, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And I was pushing, to him.",
      "word_count": 6
    }
  ],
