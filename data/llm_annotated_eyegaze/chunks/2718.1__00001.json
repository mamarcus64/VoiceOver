{
  "stem": "2718.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, the-- the two sets of grandparents, my grandmother and grandfather from my-- from my mother's side, and-- and also the same from my father's side.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My father's only brother died or fell-- fell in the First World-- First World War on the Italian front.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And my mother's two brothers, they both perished during the Holocaust.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "One-- one died in Auschwitz as one of the last people who dismantled the-- one of the factories in Auschwitz.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And it was too late to evacuate him.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans shot him, one of the last days before the Russians came.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And my other uncle, my mother's brother, was shot somewhere near Vienna on a march from [INAUDIBLE], from Yugoslavia, to somewhere, this unknown destination, in Austria.",
      "word_count": 26
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "He was one of the people who-- who couldn't walk any longer.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And he was one of those-- one of many thousands of people who was shot because he couldn't walk.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So-- my other immediate family-- family, of course my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "She was older?",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My sister was six years older, who came here to Australia with her husband and children in 1956.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And she just died in 1993 at the age if 70.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] My father died in-- in Muldorf.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "We were together in Muldorf, in the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And he died on the 29th of December, 1944, which happens to be my mother's birthday.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, had to tell you how religious.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Religious, naturally that any-- any-- anybody who says they're religious starts from-- from the-- from home.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Of course kosher, it was-- it was nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "There wasn't anything extra religious to have a kosher household.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "But on the other hand, none of my family has-- was one of those ultra-Orthodox people who had a beard.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Nobody had a beard in the family.",
      "word_count": 7
    }
  ],
