{
  "stem": "22959.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "We understood everything, but we made believe that we don't understand.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And they sent us back to Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "We tried for the second time.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And the second time we succeeded.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "We left the Czechoslovakian border.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "And we left the Polish border for Czechoslovakia, Prague.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "And then Prague for Austria.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In Prague, I would say that we were in Prague, [PAUSES FOR 6 SECONDS] I would say about three days, four days.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "In Prague?",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "In Prague we had our own place.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We dreaming about reaching the American zone.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We did not do too much in Prague.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We were making connections so we can reach the American zone.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "It means that we had rooms.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "So we had our room with my husband and other two people.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And we were dreaming about reaching the American zone.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 7 SECONDS] OK.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And we [PAUSES FOR 5 SECONDS] came to Austria.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "To Austria we were taken by machines, driven to Austria, to Bad Gastein.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And there we were placed in displaced persons camps.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "At that point, we were already-- things were a little bit better organized.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "The UNRRA took us from Prague to-- in Prague they had the American zone-- so from Prague, to Austria, to Bad Gastein.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "In Bad Gastein, we were placed in displaced person camps, in beautiful hotels.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "UNRRA.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "UNRRA is an organization.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "You spell it U-N-R-R-A.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They helped the survivors leave for America, mainly for America.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "UNRRA was not a Jewish organization.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "UNRRA was not a Jewish organization, but it helped the Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It helped the Yugoslavians.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "It helped the people who survived the war.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They placed them in separate camps.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And it helped them to move to America, or to-- but some of them, of the survivors, they left for Israel.",
      "word_count": 21
    }
  ],
