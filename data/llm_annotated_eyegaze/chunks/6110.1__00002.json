{
  "stem": "6110.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Delicious-- oh, it was beautiful.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was a family, family holiday.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I didn't have a big family besides my closest, because my mother run away from Russia with my father with the, with the seven kids.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "So she left all the relatives there.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So we did not have relatives in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I never had an aunt.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I never had a cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I never had no relatives.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "So I was only with my friends and with my family.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "But it was nice.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I used to go Yom Kippur, Rosh Hashanah, Pesach.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We used to go to the synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, they never-- nobody beat me up.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Nobody never touched me.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "But just the school days were very, very, very terrible to go to school every day knowing that I have enemies around and they do something bad to me.",
      "word_count": 29
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Because we used to wear uniforms, you know, all the girls the same-- navy skirts and red, red blouses, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "So every day, I, I used to come with spots.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't have too much clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "So it was not nice.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS] But it, it's all right.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I took everything, because I was always smiling.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I was always happy.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "No matter what happened, I was always happy.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "So I came home with a spot.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "My mother said, all right, I try take it out like this.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And that was-- but then my mother changed the schools.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "She went to the Jewish neighborhood.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "We had the Jewish neighborhood, the Jewish schools.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "So my mother registered me in a Jewish school, which was not so for me, because I had to walk, very far to walk.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "How far?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Sometimes, I used to take a trolley car.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "When I didn't take a trolley car, I used to walk a half an hour.",
      "word_count": 15
    }
  ],
