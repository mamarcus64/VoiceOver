  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "They don't have the time.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They are busy during the daytime.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "They are afraid that their cat or the dog might get into fights there.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So they-- he charges for coming there what a plumber would charge, he says, for coming.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And then he charges a little less than the others-- than you have to pay to others when you come to their office.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he keeps up very cleverly the contact there.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "He calls the next morning and says, this is Dr.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Perl.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I waned to enquire how Fifi is doing.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Do you have grandchildren?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes, four.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The older son, Rafael, has two, Gili, 6, and Ori, 4 years old.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They're both-- their native tongue is both of them is Hebrew, although they were born here.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "But they're-- they're bilingual.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They go twice a year to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "His wife is [INAUDIBLE] in [?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Israeli. ?] And she was correspondent of the [INAUDIBLE], which was one of the biggest Israeli newspapers for Washington until a year ago, when they were [? bought ?] [? folding ?] up.",
      "word_count": 33
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Now she's correspondent for the Tel Aviv radio, military radio.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "She's, everyday at least once on the radio there.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Well, ?] the Solomon has two children, one, Jonathon Elliott, who is the happiest child I ever saw.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And the daughter [INAUDIBLE], who is now about 2 months old, Juliana Rachel.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I didn't speak to him several time.",
      "word_count": 7
    }
  ],
