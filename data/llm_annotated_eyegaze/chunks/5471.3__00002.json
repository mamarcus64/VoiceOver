{
  "stem": "5471.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "This woman had a child what was hiding-- in hiding.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And she said, when my little boy comes in, please, can you take care that he stays here?",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Well, this woman went on transport.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And what we later learned, there were kids sent by themselves.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And there was a little girl crying.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And this woman said, oh, come on.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You stay with me.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "She was gassed with that little girl.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Her husband survived.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "So if she hadn't been so kind to that little girl, maybe she had still been-- be alive.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "But her son survived.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "He is here in Sydney.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He was in hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And he was in hiding till the end.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So when his father came back, he was looking for him, and found him.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He visited us several times till he died.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But the son is here.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I had several girls working for me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "That was a little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was a German girl.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And she was about eight years old when that Kristallnacht came.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "You might-- may have heard of it.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So her parents said, it's too dangerous for her here.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And he brought her to Amsterdam where a few aunts lived.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And she stayed with those old aunts.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And then they were all picked up, the aunts and she.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And she was in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And she was about 15 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And she came to work with me-- one lovely little kid.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And she would say, Mrs. van As, do you think my mother will still know me when she sees me?",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes, I did.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Your mother knows exactly who you are when she sees you.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "A mother forget-- never forgets.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And she said, oh, I am so glad.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "This child was sent on transport.",
      "word_count": 6
    }
  ],
