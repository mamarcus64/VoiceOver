{
  "stem": "11671.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And my older sister Yaffa and my Aunt Rosie kind of pushed the food into my mouth and said that it was a bigger sin to commit suicide from not eating than to eat non-kosher food.",
      "word_count": 36
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I start eating again.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "If not for being with them, I probably would have died because I refused to eat the food.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And there were other people who probably were religious and didn't eat the food or didn't-- needed some support and depressed.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And all you had to do was touch the electric wire and be killed.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So I, I had some girlfriends who did that.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They just could not stand the conditions.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So it was, you know, really hard and had to be brave to want to go on.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But we were-- you know, we were just generally, out of the six months we were there, I was the most sick, depressed, and weak.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I was the smallest in weight even though I was not the youngest among the three of us sisters.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "But I was very weak.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And my mother always gave me extra food.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Like at home, she always gave me the, the nice part of the milk, the fat part of the milk when you boiled it.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And she always kind of pampered me because I was smaller and weaker than my other two sisters.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "So if not for being with them, I probably would have perished.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "She ca-- she came to us because she knew that we were avoiding selections.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My sister did, and I was going to put it down, and I f-- I forgot the name.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "But she has it.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "She, she told us don't afraid to go to the selection.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So we, we went.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And they had many selections and, and just so many.",
      "word_count": 10
    }
  ],
