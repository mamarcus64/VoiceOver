  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "This is a very risky things, but we have to, because he asked-- not because he asked the [INAUDIBLE] against his own interests, against the interests of the German Reich.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "He doesn't understand it.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And [INAUDIBLE] understand it you'll tell this man.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "He said, you are crazy.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "You cannot complain about a German official to his superior.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "But what you can do is, you go, you need foreign currency.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "You go to the Ministry of Foreign-- to the Treasury.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And try to get foreign currency from them.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] So we-- I-- I went to a [GERMAN], an office where the secretaries type, because outside the building, a ministerium, and dictated there.",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I have the copy of what we had dictated to Eichmann, with a copy which I'll give you, and added to it that we need, for this purpose, money.",
      "word_count": 29
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
