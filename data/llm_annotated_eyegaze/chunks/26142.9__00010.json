  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "And while we heard the dogs, the dogs got scent of us, most likely, and they were wild.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "And we laid down, quiet as we were-- barely, barely breathing.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "And we hear the dogs louder and louder.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "And we hear already the patrol talking to themselves in Hungarian.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "That's how close we were.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "And the dogs.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "We were without breath, stopped breathing.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "But they passed.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 32,
      "text": "They passed, and the dogs did not stop barking.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 33,
      "text": "The fact that they didn't stop barking, we could ascertain how far they are away.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 34,
      "text": "And we waited maybe for another 10, 15 minutes, and the echo came in further-- weaker, weaker.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 35,
      "text": "And we realized that this patrol just passed by here and they are a whole distance away, and then we took a dash right across the. border.",
      "word_count": 27
    }
  ],
