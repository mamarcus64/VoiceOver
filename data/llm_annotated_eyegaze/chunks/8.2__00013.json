  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "She eventually got better, but she was able to work in the potato area where they peeled potatoes for the Germans.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I remember once I was able to get into the garbage.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And I, I got a lot of goodies out of there.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I almost got killed and suffocated because a truck brought more garbage on and poured it over me, and I was almost suffocated there.",
      "word_count": 25
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "After, I don't know, about two or three months when the ground froze and we could no longer work there, we were, again, loaded into wagons and taken to another camp.",
      "word_count": 31
    }
  ],
