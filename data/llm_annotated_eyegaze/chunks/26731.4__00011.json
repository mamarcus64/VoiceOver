  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 34,
      "text": "Bureaucracy dictated that children of some people, mixed marriage, either adults or their non-Jewish partner, or children from a mixed marriage, were not to be deported at the time.",
      "word_count": 29
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 35,
      "text": "Here I am.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 36,
      "text": "And very often in other countries, or away from Berlin, probably that wouldn't have happened.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 37,
      "text": "It was much too cumbersome.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 38,
      "text": "Take him.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Otherwise, I wouldn't be here.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "You must say German bureaucracy helped to save my life.",
      "word_count": 10
    }
