{
  "stem": "26142.12",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And-- and said-- people that walked out of the bus, he stopped a few people and for papers.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "And I showed them that I have the paper.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "But I was suspicious for him.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "And he said, come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "So he took me up-- he took me-- took me up into a building on the Main Street, not too far from where my uncle and my mother and father was there.",
      "word_count": 32
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "They lived in one room that they had there.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "It was a two-story building.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "They put me up on the second floor.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "And I took me into an office.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "And I sat down.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Said, sit down, in front of his desk.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And then he pulls out the paper from the desk.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he says, [PAUSES FOR 6 SECONDS] you know tell me the truth, he says.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "How did you get this citizenship paper?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "You were deported on the other side in-- in the Ukraine, in Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Of course, I started to deny.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I lived in Mariapocs.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And that's where I got my citizenship paper.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "What saved me that time, I think, was that he said to me-- he noticed that there were four tiny holes at each corner of the citizenship paper.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So he noticed that-- did you make a copy of that citizenship?",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He said, where is that copy?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I said, I left it in Mariapocs.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I left one with my brother, and with my-- anyway, they started to beat me up.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He called on another guy.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And he pulled out a rubber stick, made out of rubber.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And he started to hit me over the head that I became bloody all over the face.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I-- I fell off the chair.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And he called another detective in.",
      "word_count": 6
    }
  ],
