  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "They know that the woman that I am married now to, that they know she's single and nice looking.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And I was all alone, by myself, nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "That I should see something.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "So I went-- she was-- she was living at that time in Windsheim.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And I went and met her there.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "And I liked her.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "I don't know if she liked me, but somehow, we got engaged there.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "And then Windsheim was liquidated.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And then Windsheim was liquidated.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And Wasseralfingen was liquidated.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "They sent us  in to Lechfeld.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "They sent us into Lechfeld.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "In Lechfeld, we got married there.",
      "word_count": 6
    }
  ],
