{
  "stem": "22836.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 20,
      "text": "When I tell you, another day is not enough to tell the story, [INAUDIBLE] year even.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 21,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No eggs.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Men's clothing, basket, eggs, everything mixed up, and I start making money.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "When I finish the year, I make $7,000.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "When I saw $7,000, I'll prove next year I'll make double and double and double.",
      "word_count": 15
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And I came out very good.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "Then, after that, I went to Dover, Delaware.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 5,
      "text": "And I stayed 20 years in Dover, Delaware.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 6,
      "text": "I make out very good.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 7,
      "text": "Then-- then I bought-- then I went in the other business, the motel business.",
      "word_count": 14
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 8,
      "text": "And I left Dover, Delaware.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 9,
      "text": "Now I'm in the motel business.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 10,
      "text": "From the whole thing, I'll be glad now to get out from the motel business too.",
      "word_count": 16
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 11,
      "text": "That's enough.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 12,
      "text": "Work, work, work, work. 20 years in the [INAUDIBLE], 28 years in the motel business.",
      "word_count": 15
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 13,
      "text": "And I'm getting older.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 14,
      "text": "I'm not-- I'm not getting younger.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 15,
      "text": "But one man can get through.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 4 SECONDS] OK.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 17,
      "text": "Is-- the end is, I'm happy.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 18,
      "text": "I'm glad, everything.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 19,
      "text": "I pass-- My first wife passed away.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 20,
      "text": "Then I married my second wife in the same time.",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 21,
      "text": "I'm very happy with her too.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 22,
      "text": "I have nice three kids.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 23,
      "text": "They always care about me.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 24,
      "text": "They're calling me like every week.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 25,
      "text": "They are calling me.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 26,
      "text": "And Michael, the-- the smallest, it was a accident.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 27,
      "text": "It was a accident he was born.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 28,
      "text": "My first wife wants to get rid of him.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Then we went, I remember, to a doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "And the doctor says, why you want to get rid of him?",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Have me the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Give it to me.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "I'll take the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "There was a [NON-ENGLISH] man.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Then we come to-- to farmers market.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And there's a lady say, why do you want to get rid of him?",
      "word_count": 14
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "Give me the baby.",
      "word_count": 4
    }
  ],
