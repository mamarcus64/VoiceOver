{
  "stem": "7592.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I remember one thing.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "There's one thing with human people.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "If doesn't affect you, you don't care.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "You tell me what's go on in Africa, [INAUDIBLE], did we care?",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Because where we go leave?",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Where we going go?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I could go after graduation from this gymnasium to Israel, study, because we got the diploma, which a few guys went and became famous over there.",
      "word_count": 26
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I somehow-- never came to my mind to leave.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "What happened to Nazis?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Well, they occupied this.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "You know, they gave-- every few days, a few weeks, we got new orders.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "You have to wear the Star of David on your arm, register yourself.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And then they went by the profession.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And one day, they came.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "They said, listen, you have to leave Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Because the government, which was Frank, has to made capital city of Polish government, so you have to leave.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I tell you, there was a curfew , nine o'clock.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And I used to go over there after nine o'clock without the things.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "For the Jews was a curfew.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "The first thing I remember, I met on the corner a soldier who came to me.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "He was a little drunk.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he starts, Heil Hitler.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I looked at him and says, tell me, why we are fighting each other?",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I got nothing against you.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "You got nothing against me.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "So I says, listen, what are you asking me?",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "Ask the guy who running the war.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "Why don't you go with me to the casino, which is right on corner, we will drink.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And in the meantime, I see people from the other houses watching me who know me.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "They say, oh, he's finished because he hasn't got the armband on him.",
      "word_count": 13
    }
  ],
