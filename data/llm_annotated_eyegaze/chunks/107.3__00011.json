  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I said you just make yourself as tall as you can be and don't look at him, or she wouldn't even know that it was he or any of the-- just look into the emptiness.",
      "word_count": 35
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "Ignore, but don't face.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Don't confront.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "You look like any one looks.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "There's no reason why you should be more in danger than anybody else.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I lost contact.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She went with one of the work transports out of the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And there were a few other-- other things.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I also was in a little romantic contact with a woman who-- who was sitting and talked pretty well German, and I explained a little bit what was going on, and she was little old, maybe in her later 20s.",
      "word_count": 40
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I was just a teenager, and had understanding for the situation, and had a kind of philosophical outlook.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "There was one flower, I think, which I took out and showed her, so we had this kind of funny thing going, over the fence, and--",
      "word_count": 26
    }
  ],
