{
  "stem": "942.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I was in Melk [PAUSES FOR 3 SECONDS] February-- I arrived in Mauthausen probably around the 5th of-- 5th-- between the 5th and 10th of February, and I was there for four days, so let's say the 15th.",
      "word_count": 38
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I was there till end of March.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I was living in these barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] The barracks here were not bad, because this was an old barrack, you know, from the cavalry barrack.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't that bad.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We had bunk beds again.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "You know, the food was very scarce.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "It was the same old diet, you know, that we had everywhere else.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You know, that didn't change with the location.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "So the food was quite scarce.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I had-- all of my-- the people that I was sleeping with they were all Russian.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "These were all Russian prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And they were really nice to me, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "They were all mature men, and they were all military men.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And they really knew how to survive a lot better than I did, but I did survive til then, too, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I remember picking up a few Russian words, you know, because Russian was totally different to me.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And they were very good.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "What kind of things did they help you with?",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Well, they didn't give me any food, but they didn't bother me either and they didn't take anything away from me.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "You were sort of on your own.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "There was nothing, no help that you could get from anybody.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "If somebody who was stronger tolerated you, didn't lean on you, or didn't bother you, that was-- that was a big thing, you know?",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "So that was great.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- I don't know.",
      "word_count": 5
    }
  ],
