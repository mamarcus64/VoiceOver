{
  "stem": "11296.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And ten minutes later, from the other side-- there was probably two kilometers-- we heard silence.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And they blew it up, the other crematorium.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So there I didn't saw nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Here I saw.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The Germans came, the SS men came, and they started shooting.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "They start shooting, and all the people who was in the block.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "All the sonderkommando-- there was a night shift, there was a day shift, there was a middle day, there was three shifts going-- they killed them all.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "They killed them all.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "So afterwards when everything was quiet-- you know, many, many people got killed-- they start making inquiry for where the Jews, or the organization-- the underground had.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And they start looking until they came across a girl named Roza Robota.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "This Roza Robota was in contact with girls who worked in the ammunition.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "This-- Go ahead.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "These girls got-- she, Roza, brought-- she gave them bread, she gave them other things.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And they were stealing, you know, bullets.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "When they start making inquiries they came to her.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "She was the first in all the other girls.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "The other girls, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I don't know they was talking or not.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I know one thing.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Roza never-- they took her and it's called the political-- a special political prison.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And they did to her terrible things.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "She didn't want to say another word.",
      "word_count": 7
    }
  ],
