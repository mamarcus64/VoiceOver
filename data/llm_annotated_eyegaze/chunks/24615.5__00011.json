      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Then they sent me to a clinic and the clinic checked me, looked in the eyes, and sent me to the hospital.",
      "word_count": 22
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And I was there I don't know, a month or two months.",
