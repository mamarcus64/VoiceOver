  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My brother came, and I saw them, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "You know, it-- I was in the correspondence, but I had to be away.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And by the end of it-- shall I continue?",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] By the end of it, [SIGHS] I was tired.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] The reason I went to Cracow is because the way [PAUSES FOR 3 SECONDS] to, to, to over, over, overgo the draft was to look for a doctor wherever, whatever, you know, they-- they-- they smeared him to get free.",
      "word_count": 44
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I was there till-- from, from '30-- '37, from '38, till the beginning of '39.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And then I got tired.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And I came back.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I came back.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And somehow we-- we contacted somebody who wanted to take money.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "But they-- they-- they-- they took me to the army.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "It didn't help.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They paid.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "I got-- I-- I couldn't stay long in Cracow.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I-- I-- I-- I missed something at home.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And they-- they-- drafted me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And I was in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "From your hometown they drafted you?",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Or from--",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "From my hometown.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "From my hometown, they drafted me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "One was a physic, one was a doctor-- a military.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they gave me the qualification.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They-- they drafted me.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And they called me right away.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "The beginning of-- of-- of '39, when I came home, I stood to the-- to the-- to the draft.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And a month later, they called me in.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Usually, it takes-- takes a year, takes this year.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "But they called me right away.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "In March, I was already in the army.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And-- and-- and-- and November was the war.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "In September was the war.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "So I was-- I was in active duty when the war started.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "It's a joke-- in Auschwitz.",
      "word_count": 5
    }
