{
  "stem": "5799.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BEEP]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Wolozhinski.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name is Sulia Rubin.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "S-U-L-I-A.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "R-U-B-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "It's actually a Hebrew name.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It's Shulamit.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "In Polish, it's Sulamit.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And Sulia, is in English, because all of you pronounce the hard L.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I'm not [?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Sola, ?] I'm [?",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "Sula, ?] so I put the I in.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And my maiden name is Wolozhinky.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "W-O-L-O-Z-H-I-N-K-Y, I think.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yes, in school they called me Carioca.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Because I used to dance Carioca a long time ago.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "May the 24th, 1924-- May the 22nd, 1924.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "71, A big number.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Nowogrodek, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "This town is approximately 175 miles east-- kilometers east of the Russian border.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And this town is a historical town and changed hands approximately every 20 years.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So hence, when my mother and father were born in the same town, it was Russia.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I was born, it was Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Today, it's [?",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Belarus, ?] White Russia, since the revolution in Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "But it used to belong to the USSR.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The population of the whole town, it wasn't big.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was small, about approximately 15,000-- 7,000 Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My childhood, I left Nowogrodek when I was approximately six weeks old.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "My parents went to Wilno and opened their practice there.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And I guess I was the least likely person to survive, because I come from so-called intelligentsia.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I didn't know any roads except when I went to camp or to a school for girls.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And I was pretty assimilized, I'm ashamed to say.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And I was a privileged child and a spoiled child, I guess.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "But even our spoiled children aren't like the spoiled children nowadays.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Because you kind of were in awe of your parents.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't realize how unusual they were.",
      "word_count": 8
    }
  ],
