{
  "stem": "26792.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "She went down to get some potatoes, I believe, into the cellar and she saw Jewish people with the yellow patches working in the courtyard, because German officers lived upstairs and they were bringing wood for them and providing them with different things.",
      "word_count": 43
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "She, being a friend of the Jewish people, went up to the Jews and said, where are you from?",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We are from the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And she said, we are hiding a Jewish girl.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "This was-- I think she shouldn't have said, but the purpose was to do something good.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "So she wanted them to trust her that she wants to help them.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And she brought them to-- four or five people-- and she brought them upstairs and of course we fed.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I asked one of them, his name was [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I asked him to find out who is still alive of our mutual acquaintances.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Who was the man you asked for?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], I told you who's on television, you know, that is his uncle.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He survived the war.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And the next day, he brought me a note written on sport cigarette paper, cigarette package.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Liebe Zelma, Dear Zelma, I'm happy you are in town.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Your parents and your sister, along with my parents and my sister [BACKGROUND NOISE] , were lining up for Rumbula on the night of the seventh through the eighth and they were all shot dead.",
      "word_count": 35
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So I found-- and your mother, the last words I heard from her-- he was my boyfriend, so he knew my mother very well-- the last words I heard from your mother were, I'm happy Zelma is in town.",
      "word_count": 39
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So this is how I found out the terrible way.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Max Schwartz.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I have even his picture.",
      "word_count": 5
    }
  ],
