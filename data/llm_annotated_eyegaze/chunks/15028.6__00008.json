{
  "stem": "15028.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I came to a conclusion there's only way according to the Torah to go with religion-- being and bringing up a family was only way to go in life and to be happy.",
      "word_count": 34
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Well, my children had Yeshiva Shaar.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They went to for high school-- elementary school, Yeshiva.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And they went to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I got married, I lived in Queens.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Grew up in Monsey.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "The first grade-- my-- for-- for the daughter started-- Marilyn, first year I send her to [INAUDIBLE] in Queens.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Then we moved to Monsey.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "But it wasn't even first grade.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "It was only kindergarten or something like that.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And I remember I went to the rabbi, and I said, it's too much money.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "He said, you want a babysitter?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "You have to pay for it.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "There isn't a day.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I cannot go to sleep.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I never go to sleep before 1:00, 12:00.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I don't think so it has anything affecting the children.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I didn't talk to my kids too much.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Well, I didn't want to talk about it all through the years.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't even talk to my wife too much about it.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And she was understanding.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "She reads a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "She well aware and was not necessary my wife to talk about.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "And we accepted life and we went along with the way it is.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I didn't want to--",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Burden them with it.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "It's--",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Was my life.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "I mean, it's--",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Now I believe I should have talked more and maybe opened up more years ago, but I couldn't.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't go through what I went through today 40 years ago, 30 years ago.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
