{
  "stem": "3933.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 46,
      "text": "I learned to give the injection.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 47,
      "text": "A very diabetic lady who was a millionaire on Park Avenue-- she had got a housekeeper, and a cleaning woman.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 48,
      "text": "And I was the one that taught me how to put here, give her the insulin every morning.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 49,
      "text": "Then I stayed, she died.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 50,
      "text": "I worked with another one, and then I started to work with FEX-- Federal Employment, FEX, called in short.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 51,
      "text": "And they place elderly people.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 52,
      "text": "Started to receive my social security.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 53,
      "text": "And they place elderly people in jobs in clericals and factories.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 54,
      "text": "And I started to work.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 55,
      "text": "I worked in COJO in office, Consulate of Jewish Organization called.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 56,
      "text": "I translated the Russians, went with them to social offices to be a translator, with the Russian immigrants.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 57,
      "text": "Then they-- they finished the FEX-- out of the business partnership, copartnership took it over.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 58,
      "text": "They called themselves Partnership for the Homeless.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 59,
      "text": "This is an office in Seventh Avenue, located, and they are organized.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 60,
      "text": "They're helping placing elderly people in jobs.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 61,
      "text": "I am with this place, with the partnership from the very beginning, the supervisor Linda Nelson.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 62,
      "text": "They placed me in several organizations.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 63,
      "text": "I worked.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 64,
      "text": "Then I became ill.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 65,
      "text": "I stopped work after the surgery.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 66,
      "text": "In August it's going to be a year I've been back to work.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 67,
      "text": "My surgery was a year and a half ago.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 68,
      "text": "After about eight, nine months, I received chemotherapy.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 69,
      "text": "I found out what my nightmare-- I still don't believe it.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 70,
      "text": "It's absolutely unbelievable, not because I'm untouchable, but because it's the circumstance.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And I stay, I work with them at the-- school volunteers offices.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I work now with the organization-- with the organization.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It's not an organization, it's an office.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "This is a-- called-- didn't you hear the school volunteers offices?",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "They are a very prestigious office, I assume.",
      "word_count": 8
    }
  ],
