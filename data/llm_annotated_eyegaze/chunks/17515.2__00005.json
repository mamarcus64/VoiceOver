      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No, but my-- my parents was afraid to write to me at Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't know.",
