  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "But as-- as-- to German, I was as political, because I was very active when I been in the civil life, the German put me in a camp.",
      "word_count": 28
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They knew I was Polish student.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Then they knew everything about me.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I don't belong to any organization.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "No, impossible.",
      "word_count": 2
    },
