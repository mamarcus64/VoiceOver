    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "They knew-- they were scared.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Maybe-- they [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "That's why they were scared to contact me.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "From beginning, there was Polish Jewish and Polish.",
