      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "They separated-- in the beginning, there was nothing-- everybody went all through to-- to the Auschwitz.",
      "word_count": 16
    },
    {
