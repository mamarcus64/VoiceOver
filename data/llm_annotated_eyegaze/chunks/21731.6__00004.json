{
  "stem": "21731.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I was sure he will kill me and take those 10 pounds off me or 1 pound, and my sack.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I had this service-- I had no-- I had a sack, [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And he took me to Boiler Road 66.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "It was midnight, or even early morning.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Rung the bell, and Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Felix was the name of this-- a lawyer.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Opened the door, and saw me standing there, and didn't know who that is.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "So well, I say him, Marx's wife.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Oh!",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Marx doesn't know you're coming.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Well, I sent him a telegram.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "I got a bath, I got something to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "We went to bed.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "He phoned my-- phoned, I suppose.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "My husband couldn't come for one or two days, because he was-- he had patients in the hospital.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "He couldn't leave.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "There was only one X-ray specialist.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "If there would have been another, he could come.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So he came after two days.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And he had a room reserved with a friend.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He knew his wife will come, near Lancaster Gate.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "This house doesn't exist.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "It's only now where the big hotel is.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "So we stayed a few days in-- in London.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Yan got new glasses, also.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And went underground to escalator, up and down.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "He never, I never saw an escalator.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "But for him it was fun.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I don't think we went to the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I even don't know where it was, but my husband showed me.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We could go into-- to a restaurant, I think, you could get food only 2 pound-- 2 shillings and 6 pence, or I don't know what amount it was.",
      "word_count": 29
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Very little food.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And then we went to the hospital, which was fine.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Took [INAUDIBLE] from Euston to [INAUDIBLE] and from there, the ambulance was waiting.",
      "word_count": 13
    }
  ],
