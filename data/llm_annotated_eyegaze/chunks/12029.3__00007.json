{
  "stem": "12029.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And this cupboard was closed in.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "She said, what have you done here?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "This cupboard was fantastic.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We could put in-- I had such a-- it was so useful for me.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Why did you close it up?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Then the husband of the house, of that woman, came up, and he said, I'm sorry you've got to leave.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And he broke down this-- The back of the cupboard.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "--the back of the cupboard.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He said, it is not good.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And there was a very big oven, a [INAUDIBLE] oven, what they used to warm the room.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Then my husband said to him, you know what?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We will hide in that oven.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No, to the--",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "--to the Polish man.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He said, we will empty the oven, because there is a lot of rubbish in it.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We will put in two big [PAUSES FOR 8 SECONDS] cots.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And on the one cot, we will put on a little chair.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And on the top, we will make a metal frame, fill it up with-- [PAUSES FOR 7 SECONDS] with other [PAUSES FOR 3 SECONDS] tiles, with little tiles.",
      "word_count": 28
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And we will have it on hinges, and we will open and we will go in there with a ladder.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "You will take away the ladder, and there we will hide.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "One day, it happened again.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And their oven was connected to this oven where we were in hiding.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And all the flames were coming from us.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "We couldn't breathe when we went into hiding.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Then in that block was a big attic.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And on that attic, they used to keep, because they belonged to the [NON-ENGLISH], to the Polish organization, you know, the socialist organization.",
      "word_count": 23
    }
  ],
