{
  "stem": "15694.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Well, my name is Henry Wermuth, pronounced the German Vermut originally.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "W-E-R-M-U-T-H.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I see.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My passport name is actually Abram Heinriche, or Abram Heinrich, if you like.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "But it became Heinz for short, and later Henry for English.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "4/4/1923.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "73.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I don't think I have to spell Frankfurt for you.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Frankfurt am Main, and that's in Germany, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Well, I've told you the date of birth.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Early childhood memories.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We lived in a predominantly Christian area, and had predominantly-- predominantly Christian friends.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I did not experience a lot of anti-Semitism, and-- well, if I did at once, I-- once I sort of countered it, and it was quiet thereafter.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Of course--",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "--when I was getting a bit older, we moved away from that area into a more Jewish surrounding.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And when I was 10, Hitler came to power.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "It wouldn't have bothered me much, but I felt a bit of disquiet amongst the adults surrounding me.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Grandparents.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents came from Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And when my father was nine years old, they moved-- my father's parents-- to Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "He was just nine month old.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My mother's parents also came from Poland, and Gribow is the name I remember.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And my mother was about 14 when she left Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And 15 when she came to Frankfurt.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, I do remember my-- father's parents who lived in Frankfurt.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Mother's parents lived in Vienna.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my grandfather on my mother's side, he died two years before I was born.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, that's the story of my grandparents.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father had a business when I was very young.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "A shop, actually, in the main street in Frankfurt.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Later, he worked in textiles.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And later still when the Nazis ruined that trade for him, he was traveling.",
      "word_count": 14
    }
  ],
