{
  "stem": "1733.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 224.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I found out that they were in Budapest, and they got on the train, and they came to Loucky.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And then my beloved, Etta, came home one day with her two sisters.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "Her brother was home already.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "And it was a very happy reunion.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I never saw him.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "But somehow, I found out where he was living, either through correspondence or through somebody else that saw him knew that I was using-- I used his name by liberation.",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No, none at all.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They were not very receptive to our survival.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And they were afraid whatever they stole from the Jews, that somebody's going to ask back for it.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So they-- they wanted to know how come we were not killed, that's all.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And the life-- the life was going on in Czechoslovakia, in Loucky at that time, and we knew that this is only temporary, and that we have to move on from there.",
      "word_count": 32
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And my brother-in-law, who's my brother-in-law now, he was my friend, Etta's brother Joseph-- the two of us decided to go back to Czechoslovakia because we knew that we have somebody in the United States, in America.",
      "word_count": 37
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "My father was alive, and that we are going to hear from them, that they are going to want to take us out to the United States.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And we wanted to settle in Czechoslovakia, so my brother-in-law and I went back.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "We came to a town of Zatec.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Z-- Z with a [INAUDIBLE] A-T-E-C.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The local government assigned a beautiful home for us.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "It was a big villa.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "We found out later that it still belonged to a Jewish family by the name of Stern that were in New York.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Never was in touch with them.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I don't know what happened to them.",
      "word_count": 7
    }
  ],
