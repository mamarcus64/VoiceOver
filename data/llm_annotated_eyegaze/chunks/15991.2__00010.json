  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Uncertainty of the future.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "You know, dreams were very scarce at that time because everything was so uncertain.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "So I think my dreams had been to get married one day to a nice young man, and that's about it.",
      "word_count": 21
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Have a career, but I wasn't sure what kind of career.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I knew I wanted to work with children.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And that wish was fulfilled when I was-- at 18. 20, sorry-- at 20, I could leave the house.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Leave the household, finally, and start a career, and be trained as a nursery-- nurse's teacher, a nursery teacher.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And-- and-- [PAUSES FOR 8 SECONDS] it was a place where you stayed overnight.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "It was a residential place.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "And during the day, the children came.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "All, of course, from wartime mothers, who brought the children at 7:00 in the morning and picked them up at 7:00 at night because they did all work in factory work.",
      "word_count": 31
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And so it was a very good training.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "You have children from a few weeks old to five years, through five.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "And you know, so you got trained each stage of their lives, which was very wonderful.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "And you went to school at the same time.",
      "word_count": 9
    }
  ],
