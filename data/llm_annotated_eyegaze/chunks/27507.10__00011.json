{
  "stem": "27507.10",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And neither did anybody else, except for-- well, my mother used to come.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "She used to-- my mother was not in hiding.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Where was she?",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "She was in Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "She was still continuing in her existence of moving from one place to another.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But she had it easier without me.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So she managed to continue like that.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And we stayed with-- at Koper's.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But she was coming more or less regularly from every few weeks, every four weeks or five weeks.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And one other woman was-- this Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Miller was coming occasionally.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "So there was some contact with the outside world.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And we were well informed.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "We were well informed, because everything was excellently informed because Warsaw was absolutely full of underground organizations.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "There were-- there was a press.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "We go the underground press.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Copper was getting underground newspapers.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "He was getting, continuously, underground newspapers, which were giving you all the information concerning the progress of the war, and all was happening in the fronts, and so on.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "Moreover, we were having Polish language newspapers, German language newspapers.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "Earth the German Jew, was sitting always in the kitchen, and was reading the communique in the German newspapers, and was-- had a map, and was moving little pins on the map, to see where the Germans were and where the Soviets were.",
      "word_count": 43
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And from summer-- and it was getting more and more clear that there is-- really, that this time, the Russians are coming nearer.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "They were coming nearer.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "There were great battles in '43.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "And after that, in other Kursk area, still deep, deep in Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "But then they started coming nearer, and nearer, and nearer.",
      "word_count": 10
    }
  ],
