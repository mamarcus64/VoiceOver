{
  "stem": "1537.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 21.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "My father, my sister, who lives in [NON-ENGLISH], Zippora, my sister, Toby, my brothers, Betzalel, whose name is Joseph, me, and the little nephew, my sister's little boy, was two-and-a-half or three, something like this.",
      "word_count": 35
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] [DRINKS] Before going to the train station-- we're not supposed to leave the house.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So I ask my father, we have to tell my mother that we are leaving.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "If he would go out, they're going to kill him, the Gestapo.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "My sister-- you know, everybody's afraid.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I was always-- somehow, I was not afraid.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I look out through the window.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And I don't see the Gestapo on the street.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They were, I don't know, in the back, maybe 200 feet away or 200 yard.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And I run out from the house, and I run across the street.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And I run into the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "They didn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "So I'm in the hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "So now I have to look for my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "She's laying.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "There's no beds, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "They're laying on some kind of a mattress or something.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And I find my mother there.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "And I bend down to her.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "I said, mother, they're taking us, already, away.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "I came to say goodbye.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "[CRYING] And she's telling me, I have no more children.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "[CRYING] [SOBBING] I can't-- every time I think about it, even when I drive the cab in New York, and I'm embarrassed.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "People are coming into the cab.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 23,
      "text": "And I break down.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 24,
      "text": "I start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 25,
      "text": "To say I have no more children.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 26,
      "text": "And I'm kissing mother.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 27,
      "text": "I have to go because they're going to beat me up.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 28,
      "text": "And then she couldn't say nothing else.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "And I just kiss her and hug her.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "I couldn't leave her [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "And I left her there.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "And I run across the street.",
      "word_count": 6
    }
  ],
