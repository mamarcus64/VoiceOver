    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "She was in different camps.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "And my father was in camps, too.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "And it is a great miracle that they both survived, because my father was handicapped.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "His right hand was-- got caught in a wringer, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And so he-- he survived.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "It was a miracle.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And my mother survived thanks to the fact that she was a doctor, and they needed doctors, with all the diseases that they had there.",
      "word_count": 25
    }
  ],
