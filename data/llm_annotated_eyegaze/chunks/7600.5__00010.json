{
  "stem": "7600.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I found out that I could-- if I needed something, shoes, I could get for $2.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "Dress, I could get for $1 in Macy's, you know, when there was a sale.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I barely bought anything.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Once I bought a heavy coat or a jacket because I was cold.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't have anything that, you know-- so my aunt, she says, that's what you're spending your money on?",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You have no right to spend your money on this.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And the other thing I immediately told my uncle, I would like to meet my my-- the man that gave the affidavit.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I want to thank him.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I want to tell him that we need what we need.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "No, no, no, he said.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I will take care of everything.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And you-- he's a busy man.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He doesn't want to see you.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And I couldn't get him to take me there.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Then I got from this job, what did I do?",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "She said, why don't you try and get another job?",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I got a job selling things from house to house, like the Fuller Brush man [? is ?] [? stacked ?] with stuff.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Because I couldn't get a job-- she couldn't get me into the Bartlett's Candy thing.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Now, did you get-- did you meet anybody at this time?",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, if you get-- no, she said, if you get a job like that, we'll get a room together.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we'll live very cheaply, which we did.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "A room, a furnished room, [? you would get in a family ?] was $3 a week.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So we each paid $1.50.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Then she found one for $2.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And we each paid $1.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And what we ate, we bought a little-- food was very cheap.",
      "word_count": 12
    }
  ],
