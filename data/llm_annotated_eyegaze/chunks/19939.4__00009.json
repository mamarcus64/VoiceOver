{
  "stem": "19939.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And I work with the Polish people.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "I had no ID.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Anybody could look at me.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I lived in fear day and night, second by second, somebody will open the door.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "Somebody will come in.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "Somebody will expose me.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have the papers yet.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Not yet-- I only had to this for this, this transport, you know, name.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They didn't ask for my ID so far.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And the Jews were still coming and working.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They had a place where they had the coal.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And the-- a Jewish man was working in this coal, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And I had to identify myself.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And if he could, then he helped me.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I was getting-- Do you know his name?",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I know he was from [INAUDIBLE] from something.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I forgot his name, very nice--",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I-- one day, you know, already in July, I, I was always in.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I had this somehow that not to expose myself, not to walk as if I can help it.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And they were telling me, it was hot.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Why don't you go out?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And this [INAUDIBLE], you know my roommate, she had no idea.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "She said, let's go for a walk.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Let's go [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I just couldn't help it, always this kerchief, because my roots came back.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And they were asking me.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "I had something on my head, always in a kerchief because my roots.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And I had no way of, of bleaching or no way of nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Disappeared.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So I-- what's happened, right?",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And then with the black hair, you look more Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "So we walked to this railroad station, walking in there, you know, because this is where they were building this.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And there was, was already sabotage or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "There was a Ukrainian with the black uniform guarding this, right?",
      "word_count": 11
    }
  ],
