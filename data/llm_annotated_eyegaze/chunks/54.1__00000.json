{
  "stem": "54.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "She was actually-- we were liberated the same camp.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My name is Hela Shapow, and I was born November 5, 1925.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "What else?",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was in a city, Ozorkow, Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My name was Hela Storch.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "S-T-O-R-C-H.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Bella Storch, my father's was Moshe Storch, and I had a little brother, was Shlomo Storch.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father was a very good supporter.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He made a nice living for the whole family.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "He was a custom tailor.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We had a good life with my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We used to go-- summer-- every summer we used to go out for three months vacation time, when we were off school.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we lived in the country, which we loved it very much.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We had everything over there what we needed.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And when we came home from the country, fresh, relaxed, you know, children.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "My mother used to be with us.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "My father used to come only for the weekends.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And my childhood was a very good, and a very nice childhood way.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I had very lovely parents.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And my sister is, now-- she's alive.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "My brother's alive, too.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "My brother is in Los Angeles, my sister lives in Johannesburg, in South Africa.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Bluma Doman.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And what else can I tell you about my family?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My mother had a big family.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "She had three-- three sisters, and she was the fourth, and she had a brother.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And each of them had three, four children.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "So we had back there a very big family.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "When it came a holiday, we didn't have to have French people as guests in our house, but we had only our family.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "We had the sisters, the cousins, and the aunts and the uncles.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And life was very good until Hitler came into our life in 1939.",
      "word_count": 13
    }
  ],
