  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Everyone who was 19 years old during the regime of Czechoslovakia had to go before a draft board.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Before I graduated in 1936, I had to go before a draft board to be drafted in the army.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "However, all who were students and continued their education anyplace else, they were exempt from going to the army.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "A postponement was given to them.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "They were drafted.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And so I was nine-- approximately 1936, I was almost 19 years.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "I was also drafted to the Czech army, like everyone else.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "But I was given-- that I'm going to study further, I was given an exemption as long as I will study.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
