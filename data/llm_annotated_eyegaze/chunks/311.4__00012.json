  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "Another two, I think one of the Rosner kids, the one, he is very sick in cancer.",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "I saw him last week, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "I think he was with him.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "There was Schindler, his wife, his girlfriend, you know the one?",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "You know, she saved my-- my life once.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And Goeth, he was hidden.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "He was with us in-- in-- in-- in the quarters.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "But Schindler told him, hey, [NON-ENGLISH], like you.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Don't you ever show your face.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "I saw him only twice.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "So he like he live from 300 pounds, there was like left like 150.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "But he was arrested by the Germans, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, Amon.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, Amon, Amon, Amon, Amon Goeth.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "He must have be arrested.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "But they must have let him out when the Russians start coming.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Just-- yeah, a day before.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I think a day before.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "And I had a hard time, too, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "We made him-- a week before he made that Schindler's list or two weeks before, we all signed it, how good he was to us.",
      "word_count": 25
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "A thank you, whatever happens, happens.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "And this, somebody was hiding this-- that list.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "And then there was exact dates and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "So we knew something is coming.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "You know, in case, they stop him, whatever it is, that he was one of the people who really want to help us.",
      "word_count": 23
    }
  ],
