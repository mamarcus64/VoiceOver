{
  "stem": "15900.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "To me.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Don't talk to nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And the first thing he asked me, is my wife OK?",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "She's on the other side with the children.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "We got news that she passed.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "And this way-- and he said to me, I'm-- I'm being sent away for five years.",
      "word_count": 16
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "And I won't see you no more.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "A couple weeks later--",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I never saw him.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I never saw him.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "After the war I met people who was with him in a concentration.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And they say, everything he was there.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And I-- I was looking on every train going to the army.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "He's there.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And I didn't find him.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "But he was sent.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "When they came into me, I didn't see a trial.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "And they gave me five years hard slavery.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "It's a concentration.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I said, and the guard who gave the food, he said, you went to a trial?",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "They just gave me five years.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "They announced that they're gonna take me.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "He said, oh you.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "You're going to be forever.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "The people who get outside trial, they are [NON-ENGLISH], they call them.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "When your five years is over, they give another five, another five.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "You never get out.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 11,
      "text": "I said, that's good news.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And they sent me there.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And I was still not healed.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I was still not healed.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "They put me on a train.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "You ever see 'Doctor Zhivago'?",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "The train for the taking the-- the people like cattle into Siberia when they-- when the Russian took over, the-- the Communists took over.",
      "word_count": 24
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "They sent the people.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "When took me I have just a regular uniform, a-- a-- a prison uniform.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And we were in-- in-- in Novosibirsk, a prison, in Siberia.",
      "word_count": 11
    }
  ],
