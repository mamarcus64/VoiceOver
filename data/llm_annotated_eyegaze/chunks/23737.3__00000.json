{
  "stem": "23737.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was all right.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Listen, when one is 19 years old, or 20 years old, you recover from everything easier than when you are older.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "So I recovered quite well.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No, because they, they had no idea what was going on.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They knew very little about Wallenberg, and who he was, and what happened.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They only knew that they were taken from the ghetto to these safe houses.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And that's where they survived.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My mother and my grandmother.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My father was-- we had no idea where my father was.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And two weeks after I came home-- I remember on a Sunday morning-- we were in the flat at home where we lived, and the bell went.",
      "word_count": 27
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I went to the door.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And who was standing at the door, but my father and my uncle?",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "They just came back.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "We had no idea where he was.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And they didn't know when to expect him.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Two weeks after me, they arrived.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Buchenwald and Gelsenkirchen.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It was.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father actually went back to his old job after the war.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He was taken back to his old position and his old job.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And he was there.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I, I went back, and I was working for-- my mother had a-- no, no, that was before the war.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "After the war.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I went back, and I was speaking about my uncle, who lived in Scotland.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And he was writing letters, why don't you let-- I was called Katush in Hungary at home.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Why don't you let Katush come to stay with us?",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "I have got two little boys, and she can stay here and look after my children, and so on, and so forth.",
      "word_count": 22
    }
  ],
