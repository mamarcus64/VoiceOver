{
  "stem": "3100.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "And I'll be in this and this address.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "My wife came home.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "She said-- She said to me, you don't want to be a chazzan anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "I said, you're right.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "But a few minutes later, I said, maybe I should go in and find out.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "She said, you said you don't want.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "We made arrangement to go with the [INAUDIBLE] and blah, blah.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "I said, I wait another 20 minutes, and I said, you know what?",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "A cantor is like an etrog and a lulav.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "He's good till Erev Sukkot.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "If you don't sell the etrog and the lulav, Erev Sukkot, you could throw him out.",
      "word_count": 16
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I said-- she said, no, I see you want to go.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Go in.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So I called up the, the cantor, my colleague, and I said to him, when do you want me to come in?",
      "word_count": 22
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "He said, when could you come in?",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "I said I could take the latest plane, 6 o'clock in the evening.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "He said, good.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "I'll have some people--",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "--waiting for you.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I come in and there was a whole group sitting.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "I said, what are you doing in here?",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "Said we were interviewed.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "I said, he told me I'm the only one.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "I wouldn't have come.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "So I said, what are you doing?",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "He said, one says he's a, a salesman.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "The other one said he is a clerk in a-- in the bank.",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "The other one has a grocery store.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "I said, they're not hazzanim.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No, they just wanted the position for-- I came in, and there was the rabbi from Calgary.",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't know where Calgary is.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "The west coast.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Finally, from all the people, I got the shtele.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "And I came to Calgary.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And I was there for 16 years.",
      "word_count": 7
    }
  ],
