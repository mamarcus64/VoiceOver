  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "I-- I really don't very-- I haven't been close to those people making the list.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "Or I don't know much about it.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "But I was on the list.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Must-- somebody must have mentioned my name.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I-- because we was taking as one lot-- oh, actually not really.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "The list was really to-- to me, the list I heard about was in Birkenau.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "But people were saying there-- there was a list made, and Schindler is supposed to-- but it took quite a long time.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And this was the worst time, because I was really not well.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "I had a cold.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I was distressed.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "That when I was really very, very much down.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "So don't ask me even how long I was in Birkenau, 'cause I have to ask somebody else and rely on somebody else.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I told her to be here about 12:00.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "12:00?",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "--my son can still-- can I see him for a minute?",
      "word_count": 11
    }
  ],
