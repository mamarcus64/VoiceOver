  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "They all looked at us as if at least I was crazy, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "What was I doing with this German on the American bus?",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "So I became-- all of a sudden it occurred to me it might have been a defense witness.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "I did want to be accommodating defense witnesses.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "So I spent some time checking up on him.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "He was an extremely distinguished physicist by name Robert Havemann, who later was a director of the Kaiser Wilhelm Institute and may have along the line gotten a Nobel Prize.",
      "word_count": 30
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "He had been picked up by the-- he was-- he was a witness for the prosecution, which made me feel a little bit better.",
      "word_count": 24
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "He'd been picked up by the Nazis and stuck in a concentration camp towards the end of the war because he was a bonafide-- a spy for both the British and the Russians.",
      "word_count": 33
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "And the only reason the Nazis didn't kill him was they wanted him to conduct experiments on nuclear projects for them.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "That kept him alive.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "I never had any further contact with him, but I did put them up overnight.",
      "word_count": 15
    }
  ],
