  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "He said, what's your name?",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yes, when he found out that I live, lived in Lwow, he said, I'm from Lwow, too.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Before the war, he went.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And he worked, worked in the HIAS, an older man.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And when I told him my name, maiden name, but it was my brother's name, he said, it rings a bell.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So I thought maybe he knows about my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "It's your sister is alive.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "The first time after so many years, it was in '64, that I found out that my sister lives in France.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Now, why he knew about my sister, because a friend, her friend that they were together during the German occupation, somewhere there in Germany working.",
      "word_count": 25
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "She lived in Israel after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "She found her mother alive and her sister.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And she lived in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "In Israel.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "From my brother-in-law-- I don't know if he's alive now-- from him somehow, she found out that I am alive, But she didn't know it was in Australia.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "It was in Germany still when he found out.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "So she knew that I'm alive and that my daughter's alive in Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "She visited in France, my sister, and told her that I, I survived.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "My sister didn't know about it.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "But she knew.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "She found out in Israel from my brother-in-law, I wrote them, that I am alive and my daughter but not my husband.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "My sister is Ella, a Jewish name.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "She was [?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "Kristina ?] during the war, [?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "Kristina Pavlik. ?] I think I wrote it there, married to a Frenchman, non-Jewish man, who helped her, too.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And she got married to him.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "So she knew.",
      "word_count": 3
    }
  ],
