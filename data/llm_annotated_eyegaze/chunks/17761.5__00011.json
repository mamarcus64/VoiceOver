  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "What was it like dealing with the non-Jews of the area once you came back?",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I didn't deal anything with them.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] after them.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It was calm.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "They knew already that the Jews coming back.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "They knew that they are under Russian [PAUSES FOR 3 SECONDS] administration.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "The-- it was a democratic government, to some extent, at least.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "We weren't-- they didn't do anything, but they were no-- at least from my point of view, I don't remember of any special relations with non-Jewish at that time.",
      "word_count": 29
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In-- that was in the end of 19-- 1945.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I was appointed as a member of the National [PAUSES FOR 4 SECONDS] Di-- Direction of the [INAUDIBLE] Youth Movement.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "By the way, when I came back home, immediately we founded the [INAUDIBLE] Youth Movement.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "We organized Zionist youth movement.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "It was a very nice sniff, as we called it, branch and we had a lot of activities there.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So they probably, because they heard that there is such a guy in Dornavatra, Vatra Dornei.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So they invited me-- they elected me as a member of the-- and I went to Bucharest.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And there starts a-- another period of my life, which was one of the nicest periods of my life, and this is in the youth movement, [INAUDIBLE] Direction.",
      "word_count": 28
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And then I became, also, a member of the Haganah later, and I worked in organizing Chalutzim to go to Israel, and organizing illegal transports to Israel, what's called [NON-ENGLISH].",
      "word_count": 30
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And how I went to Israel, that's another story.",
      "word_count": 9
    }
  ],
