{
  "stem": "20580.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "It's a mother with two kids running away-- running away from me.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "He says-- stays with me.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "I was nice dressed-- beautiful [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Then says in Polish, come away, come back.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "I says, that's not where they live.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "I want to run away for the kids.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "They're staying.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "[NON-ENGLISH SPEECH], this is a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "I'll pass.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 26,
      "text": "We could make-- you better investigate.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 27,
      "text": "I says, come on over here, in Polish [SPEAKING POLISH], I'm a Jew.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "And she come back.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "She give me to eat, to drink.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 30,
      "text": "And she says, in the daytime, you work over here with the chicken, by the herds, by that.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 31,
      "text": "At night, we always sleeping over there.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 32,
      "text": "But, if you want to go, is over there-- go three blocks-- is there Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 33,
      "text": "We call it Ukrainish on the other side.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 34,
      "text": "And over here is Polacks.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 35,
      "text": "And over there is Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 36,
      "text": "[LAUGHS] I came back there.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 37,
      "text": "I see a family, Shreiber, which is supposed to be over here in America-- Shreiber-- and three, four people from my town which are-- some of them is in Israel.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 38,
      "text": "Some I know in the [INAUDIBLE]-- 24.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 39,
      "text": "And they have a gun.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 40,
      "text": "And they have two hand grenades, you know, not big with that.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 41,
      "text": "I says to my friend of mine, which was in Israel-- anyway, I like-- she's got a nice place.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 42,
      "text": "But I don't like to stay at night over here [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 43,
      "text": "Then we went to make a place to hide ourself at night.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 44,
      "text": "That's-- in the daytime, we had corn, wheat-- we're--",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "--grinding.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My brother-- we've been together till January 9, 1944, together with this guy over here--",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "--running away from the-- from the bandit-- from the Bandera with leather.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we're sitting together and talking about everything else-- 12 o'clock.",
      "word_count": 11
    }
  ],
