{
  "stem": "16922.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "She didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "She came to Brunnlitz, and she got scarlet fever.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Sick, She was sickly.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I went out, and I stole a-- a scarf, you know, I got hit from the sturmfuhrer.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "The girl what is taking care-- the German girl.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I had saw this-- I should put on some-- she should put on something, a scarf, woolen scarf I had.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And when you-- we didn't have [? where ?] to steal, only sometime when they are going to the kitchen I find out this-- find on the floor a cabbage.",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And when everybody was asleep, I-- I gave everyone, I gave a leaf of cabbage.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Not everyone.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "How many was in that neighborhood, how much I had.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Beaten by sturmbannfuhrer.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "On my head, on my back, with a [NON-ENGLISH]",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "A [NON-ENGLISH] a leather [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I don't know this has, you hit like this.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Schindler came and pick us up.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They were talking about he came, and he probably gave money.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And he took us to-- to the factory.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Brunnlitz.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Leaving Auschwitz, you went-- everybody, when we came to Auschwitz, we went-- went in-- like cows in a wagon.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "When we came to Auschwitz, and when we went.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "It doesn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We have to-- we went to Auschwitz or to Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We were very, very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "To the factory, to the barrack we got there, all of us.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We'd look for perches where we're going to sleep.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In a room, in a big room.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "We had showers.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She had scarlet fever.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And she was sick for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They took her to the hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They take of here, because she get well.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], this ammunition.",
      "word_count": 3
    }
