{
  "stem": "13690.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "I was representing, being in Switzerland in that Swiss bank, being on the board of the, of the bank corporation.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "In turn, being-- thank God, being to the gracious of God-- being successful, I shared my wealth.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We established an endowment.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "My children went to Queens College.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "We made an endowment to Queens College where lectures are being given in the name of Celina and Marvin Zborowski.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I also am part of the Yeshiva University [PAUSES FOR 3 SECONDS] Interdisciplinary chair of Holocaust studies under the name of Diana and Eli Zborowski.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I'm on the board of-- international board in Jerusalem of Yad Vashem.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I'm serving on the board of directors here in the United States of the Friends of the Yad Vashem.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "I'm involved politically, supporting both the Republican and the Democratic Party, whereby I have no personal gain, not from one, not from the other, which is not tax-deductible, not at all.",
      "word_count": 31
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I'm involved in communal life, belonging to the synagogue, to my local synagogue.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I lived in Jamaica.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "I'm living in Jamaica now for the last three and a half years.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "I lived before for 30 some odd years in Hillcrest, where I was an officer, a builder, a founder of one of the largest orthodox community-- modern orthodox communities-- in the United States.",
      "word_count": 33
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "We had over 500 vibrant families in our community.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I'm on the board of the Queens College.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "All, since the day, always involved in the commemoration of the Yom Hashoah.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I was the one who installed the first one in our community, in Hillcrest, and it's been perpetuated every year.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And also, it's being followed the same way here where I am now, in Jamaica Estates.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "My family is really a lovely family.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "We are very close.",
      "word_count": 4
    }
  ],
