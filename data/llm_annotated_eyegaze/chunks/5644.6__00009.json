{
  "stem": "5644.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] That means, I am a Pole from Baku, from Russia, but honest.",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "No ZZW.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "And to give him the names, which I knew a few, but [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "But I said, I am not a Pole, so I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "I am a Jew.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Luckily, he didn't find my photo as a German.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Because I had been dressed as a German--",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "--[INAUDIBLE] during mine uprising.",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "Don't you know that?",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "I'll show you in a minute in the museum.",
      "word_count": 9
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "In the Israeli museum is the photo, too.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "I'll show you when you start eating.",
      "word_count": 7
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't have the photo, because I did give it as a souvenir to my cousin--",
      "word_count": 17
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "--which came from Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "And he was forcing me to tell him something.",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "And I thought myself, all right.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "If I got to help him, I got to help him.",
      "word_count": 11
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "I said, let me out.",
      "word_count": 5
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "Let me relax a little bit, because it's after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "I been a Jew hidden in there.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 7,
      "text": "I told him.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "I'd been hiding.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Let me rest a little bit.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "I'll come back.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "And I will tell you everything, but let me rest.",
      "word_count": 10
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 4,
      "text": "But I give you at the moment all the most important people, the leaders.",
      "word_count": 14
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 5,
      "text": "I am Jan [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 6,
      "text": "He doesn't know Landau at all.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 7,
      "text": "So I said to him, one was Miriam Landau.",
      "word_count": 9
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 8,
      "text": "She was the leader, the partisan.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 9,
      "text": "Then was Israel Landau.",
      "word_count": 4
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "You knew they were both dead.",
      "word_count": 6
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "One of the leaders in the Polish partisans.",
      "word_count": 8
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Ludwig Landau was a leader in the young groups.",
      "word_count": 9
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "And then was [INAUDIBLE] and was [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "I knew that all are dead.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 3,
      "text": "No one is alive.",
      "word_count": 4
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "So I give him my family as the leaders of the Polish underground.",
      "word_count": 13
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "But I'll give him much more when I rest.",
      "word_count": 9
    }
  ],
