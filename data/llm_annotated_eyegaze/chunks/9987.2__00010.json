{
  "stem": "9987.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "I was in that prison approximately, I don't know, five, six months.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I don't remember exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "One day I'm being called to the office and here there is a German captain sitting there, not a Gestapo man.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "He was from-- from, I don't know, they called it a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "I don't know what that means, probably the people that they are involved in-- in-- in foreign moneys.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And he reads me a story.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "He reads me a story that I was buying American dollars in Tarnow.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "I was caught by the Gestapo.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "I was interviewed.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "I escaped, and I got re-arrested.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And he gives me to sign the paper.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "I said, that's not true.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "I never did that.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "I didn't have any American dollars.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "I had nothing to do with it.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "He says, you're lying.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "For every lie you're going to say, you're going to get 25 over the back with rubber stick.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "He put me down, counted out 25 over my back.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He says, well.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Are you going to sign that?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I says, no, that's not true.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He says you're going to get 25 for every lie.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And he counted out four times 25, and I still would not admit.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Finally, he says-- he sees that he got a tough customer here, and he wanted to release me, because he was bought off.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "So he says to me, if you're gonna sing-- if you're not going to sign, he says, I'm going to right put you back to the cell.",
      "word_count": 27
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I says what happens if I'm going to sign?",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He says, if I'm going to sign, he says, tomorrow I'm going to release you.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Your mother is waiting for you outside the prison.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, I believed him.",
      "word_count": 4
    }
  ],
