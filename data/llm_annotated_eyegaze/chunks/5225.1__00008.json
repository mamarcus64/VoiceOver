  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And he took the ink holder.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And he throw at him.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "And he cut him out an eye.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And he was blind all the way.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "The rabbi.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "What can you did to, to the boy?",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Oh, plenty times.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Plenty times.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "He smoked cigarettes.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "But he never got a match.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "So he said, take my cigarette.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Go out and to the neighbor over and lighted up the cigarette.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "So we go out.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "And we light it up.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "We bring him and say, rabbi, take fast, because it's burning already.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "[LAUGHS] And we smoked it out there.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Me?",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And how.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Everybody got hit.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, it was-- listen, we was no angels.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was observant.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Uh-huh.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Pesach.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "All holidays was very good observed.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "Because you see, we was not rich.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "But we could afford it.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "See, I don't remember when I was small.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "But when we working already, four people working-- you can say five people, when mother works too-- so we could afford it.",
      "word_count": 22
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "We have food-- enough food.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "We have every Saturday an apple, you know, for dessert.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "And you take a nap.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "Even the rabbi-- he comes-- he comes already Saturday.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "He wants to have a free meal.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "So he say to the father, I am going to show you what I teach your son today, this week.",
      "word_count": 20
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 13,
      "text": "And he takes out the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 14,
      "text": "And meanwhile, he wants to grab a free meal.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 15,
      "text": "And what--",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "You know, kids are stupid.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I was like soccer-- socking playing-- soccer.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "So Friday I told him, Sunday I'm going to be sick.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "Because I want to go to the game.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "But what a kid know?",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "He goes ahead and tells my father that I told him Sunday going to be sick.",
      "word_count": 16
    }
  ],
