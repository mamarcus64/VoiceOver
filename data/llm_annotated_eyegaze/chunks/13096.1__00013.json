  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "We think there were three other ones, Mussolini and three other ones.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "One of them was De Vecchi.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And De Vecchi, you know, when he come to Rhodes Island to-- to take, you know, the place of our old governor, which was Mario Lago, everything start changing because he was a maniac like all the-- the fascists were.",
      "word_count": 40
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And he start first of all, when he was going into the street, everybody has to stand wherever they are and salute him.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "When you pass an ambulance, for instance, and you have to remain where you are.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "He-- he wanted that from, and he start having all these laws, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "He was very happy about these things.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So that's why, that he was over in-- in Rhodes Island.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Did any non-Jews try to help the Jews in Rhodes Island?",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "When we were deported?",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "When-- when these bombs, then, started to-- to fall?",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, we were-- we didn't-- I mean, what can they help?",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "But they were just helping as you say, all the Greeks, they-- they offered their houses, though we were paying.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We were paying their rent but they-- they help us.",
      "word_count": 10
    }
  ],
