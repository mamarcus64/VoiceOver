  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 18,
      "text": "And I thought, my god, it's worthwhile just to see them and especially for my brothers, who were adults, to-- to meet with their friends once more.",
      "word_count": 27
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 19,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 20,
      "text": "The other thing is we had a mission to identify Dad's grave and get a new headstone on there for him.",
      "word_count": 21
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 21,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So my brother Alfred said, let's go.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Helmut's willing to come.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We'll have our own reunion.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "We can't afford to travel.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "They're inviting us, and they're paying for it.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "So we decided-- They-- they paid for your air travel?",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "They paid for the whole trip for one week.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And it was the best thing I could have done in retrospect because it gave me such closure.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And I learned so much more about myself that I could never identify.",
      "word_count": 13
    }
  ],
