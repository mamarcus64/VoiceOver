{
  "stem": "1062.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "So [INAUDIBLE], whoever wanted to go on the beam, sat on the beam.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It was like a beam across.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "An SS officer walks in.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He had a sub machine gun, shoots down everybody from the beam, just like this.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "When I saw him-- he started on this end.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I, I, I, I jumped off.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "You know, I fell down on the floor.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "In the morning, I got up and I knew people that were in main camp.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And I saw people standing outside.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I remember man with stubbles.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "The stubbles were white, like frozen.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "But the men was staying there.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "They looked like alive.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And there was one guy, his name was Pincus.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And I walked over to him.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "I said, Pincus, I said to him, and I just gave him a little push and he turned over.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "They froze to death standing up.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "They were-- they looked, they looked alive.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "Well, we stayed there over, over that night, and then they start pushing us.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And we went to a place called Gleiwitz.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Gleiwitz was the first German town, which was on the Polish-German border.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "We went through a town called Katowice.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "From Nikolaev, we went to a town called Kattowitz.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "Today, it's called Katowice.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Katowice today is the capital of Silesia, of lower Silesia.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "It's a big city today.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "There the coal mines are, the coal, the coal area.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "Very rich in minerals.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "And I went-- when I went through it, it was a small, a small little town.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "And I-- when I went through Katowice, we went through the, the center of town.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "And I see children and civilians inside the building, because nobody was on the streets, because when Jews-- when we arrived to a station, they would make an announcement.",
      "word_count": 29
    }
  ],
