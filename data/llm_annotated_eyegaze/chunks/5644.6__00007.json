{
  "stem": "5644.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "We hold them in the bunker.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "I said, you sleep in the bunker.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Because nowhere to stay.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Warsaw was burned out anyhow.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "So there we did have where to sleep, and we did what to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "So we-- we--",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Because we didn't have to lock the bunker at night.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "We are free.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "To Prague about a day or one-- no, not a day, a few hours.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And then I stay in Prague about two days in Prague, two days.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And then I came back and told them, all right, we can go.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "There's a committee.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "There's everything.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "Let's pack up.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "But in the meantime, we did have a few problems with the Russians.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "They did want vodka, we didn't have it.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "They said that they will shoot us, a few little things which are--",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "--we are being free.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "All the-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- no, I checked the committee there.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "That's a Jewish committee--",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--already formed for months.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And I took him away and said where the committee is, 47 [INAUDIBLE] or 49. 47 even [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "And I told them go there.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "And then I will settle you and tell you who is left, who is not left, and give you some money.",
      "word_count": 21
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "Because they got some money.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Because they've been just liberated.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Food, I bought food.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And the people will most probably wonder, how did we get food for three months and some days in the bunkers?",
      "word_count": 21
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "Very easy.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "Very easy.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "We did have tons of food.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "Because if every one of the Poles which left-- 800 people-- left 10--",
      "word_count": 13
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "--10 [INAUDIBLE]-- 800,000-- 10 [INAUDIBLE] of food buried in the cellars.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Because everybody was living the last three months in the cellars, because of the bombing.",
      "word_count": 15
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "We took the food downstairs.",
      "word_count": 5
    }
  ],
