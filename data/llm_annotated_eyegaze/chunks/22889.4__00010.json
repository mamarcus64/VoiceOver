{
  "stem": "22889.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I used to live on that too many times-- sometimes we pick out the gold teeth from the skeleton.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I used to trade it with the Ukrainians.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "They used to bring us bread.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "They was so corrupt.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "You could've buy them-- if you had money, or you had something gold, or something like used to-- they did you favor.",
      "word_count": 22
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "They used to come, they used to watch us.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And they were behind the fences.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "We used to get with each other, used to trade in the gold for a slice of bread, something like that.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So we used to build the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Who was in charge at Krakow-Plaszow?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "We were divided out into groups.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Are you talking about when we went to work or the camp?",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "The camp was Amon Goeth.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "He was the-- he was the camp-- commandant, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And the Jewish commandant in the camp was Cholovich.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "He was a Jewish policeman, OD men-- OD men-- OD men, they-- we used to call them.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "They wear uniforms-- like-- and with the yellow hair-- yellow mark around their heads.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "He was something else, too.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "When we arrived to Krakow-Plaszow, there was one OD man named Finkelstein.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "He came in with the whip.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Right away, start to call us name.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "He was worse than the Nazi.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "He was worse than the SS troopers.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "Start to call us name.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "I'm ashamed to say, what a name he called.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "[NON-ENGLISH], it's a Polish name.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "You son of a bitches, you come over here.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "Don't think you're on vacation.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And he used to beat on us.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "He used to whip us.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "We didn't get the-- when we were in Czarny Dunajec, nobody beat us.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Once we did-- we perform our work, and that's it.",
      "word_count": 10
    }
  ],
