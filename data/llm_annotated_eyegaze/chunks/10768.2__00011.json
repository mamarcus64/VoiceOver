{
  "stem": "10768.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "There were no beds or no place where to sleep.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "But to rest on the floor and put a little knapsack under our heads.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And then, two or three hours later, they made a meeting.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And they told us, look, we came here.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We thought that we could stop here and start working here.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But the Germans are going at a very fast pace.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "So we decided to go further.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "There are trains here in Sambor.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We will put you on the trains.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "When we asked them, where will we go, how far will we go, they said, we don't know ourselves.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Our wives and children left, and we also don't know if they arrived home or not.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "This was their answer.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "They gave everybody 50 ruble.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "We should have something, because we had absolutely no money.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "I was, at that time, hysterical.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Because I knew that this was like the end of seeing my family.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "I had a feeling.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "But my brother, who was very reluctant to go from home, here, since he saw some of his friends, he said no.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "Since we came already here, and they are-- they want to send us deeper, we should go already deeper.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "It makes no sense to remain here in a city that we don't know anybody.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "This Irene knew a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "He was the head of the clinic and the head of the hospital, since she was the head nurse.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "His name was Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "He is himself Ukrainian, but a very, very peculiar man, a man who devoted his entire life to humanity, to helping sick people, without taking money.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "He was able to go 30, 40 kilometers into the mountains to help a woman who give birth, because the birth was in danger.",
      "word_count": 24
    }
  ],
