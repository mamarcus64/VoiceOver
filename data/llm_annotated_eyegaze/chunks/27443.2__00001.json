  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And [?",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Krupp, ?] unfortunately, is a very sad chapter in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Because one of the days, [PAUSES FOR 4 SECONDS] I guess the [NON-ENGLISH] got a quarter to deliver the unwanted Jews, unable-- people that were unable to work, old people and children that were unable to contribute to work, or they were unable to work, they went into transport.",
      "word_count": 49
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "We didn't know about it, but one morning, they pulled up a truck in front of our home, where we lived.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] And they tried to take away the two children.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "They came to pick up the two small children, because they were unable to contribute to work.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "As I said, the baby was born May 1, 1938.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My younger brother from me was born April 18, 1930.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "So he was 9 years old or reaching 10 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And they were no good to work.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So they came to pick up the children into transport.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was at that time 37 years old, and she refused to give up the children.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So when she started to cry and refused to give up the children, the German grabbed her by the hair and threw her in the truck, together with the children.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And the last words that I remember my mother said to me; [NON-ENGLISH], take care of Daddy.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And when the trucks pulled away, we couldn't visualize that I would never see my mother again.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "That was the last time I saw my two younger brothers and my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] My older brother and I, we continued to work in the fields [PAUSES FOR 4 SECONDS] for quite a few months.",
      "word_count": 25
    }
  ],
