{
  "stem": "22959.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So I was afraid that if I go back to Vilna, I will never be able to return to my home.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "That was the summer of-- [PAUSES FOR 3 SECONDS] let's see.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I think it was the summer of '41, if I'm not mistaken.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "'41.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "In Vilna, we had a beautiful life there.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "First of all, we would go every month to the Jewish theater, see all kind of plays, all kind of performances.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I spent lots of time at the library, Strashun Bibliotheque, where I was reading Jewish books, studying-- it was nice and quiet.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "It felt good.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I visited the YIVO, the Jewish Scientific Institute, where they showed us around, where we were doing some research, preparing some papers.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "They recommended to us which books we can use, and YIVO was a beautiful, beautiful institution, organization.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And it was-- they were situated, I remember the street, on [?",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Vivulska, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Ulitsa ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Vivulska, ?] in-- in Vilna.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And it felt good to be there and to visit with different people.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "I had friends.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "We would go out to dances.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "We had a special cafeteria in Vilna, I remember, where we used to meet.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And they called us [POLISH], that means, in Polish, students.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "We would meet at this particular cafeteria, had meals there, danced, enjoyed it.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "So that was something very special.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "In Vilna, there was a beautiful main street, [POLISH], with all kinds of stores, all kind of beautiful offices.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "We would go and visit, and walk around, and enjoy, and laugh.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And it was something very special.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "My father would come to Vilna to buy some merchandise for the store that they had in Zdzieciol.",
      "word_count": 18
    }
  ],
