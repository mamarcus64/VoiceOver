{
  "stem": "2316.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And as I was going people were coming to the ghetto, and I was going the opposite way.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And you couldn't go through the back.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "You just had to go on the main street, was all.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "And in order for me to get out-- the crowd was coming towards me, and with, you know, the Nazis, and the shotguns in back of them.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "And I saw my cousins, and my aunts, and my uncles coming and carrying the babies and everybody.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And it was Germans with guns and Ukrainians, too.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "And I went-- one of the Germans was busy looking up, and I went through his legs at one point.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "Under his legs I crawled.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "He didn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "He happened to be standing that way.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "And I passed by, and I pushed myself.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "I was a little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "Maybe they didn't see me.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "They were like cattle.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "And I approached my house and I saw there were soldiers far away.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "And I crawled on the ground like there was a drive and I just crawled between the twigs and the bushes.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "And I got to the wall, and they wouldn't let me in.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "They were afraid that the Nazis, that the Nazis got me and they put me up to find out where the rest of the family is and that I would lead them to the family.",
      "word_count": 35
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "So they wouldn't let me in, and they didn't answer.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 36,
      "text": "I finally started crying and said, there's nobody with me.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 37,
      "text": "There's nobody with me.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 38,
      "text": "I'm just alone.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 39,
      "text": "I'm just alone.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 40,
      "text": "And I convinced them to open the secret door and they let me in.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 41,
      "text": "That was the last time we saw, at that time, the rest of the family.",
      "word_count": 15
    }
  ],
