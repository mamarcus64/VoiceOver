  "sentences_input": [
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "Not for Schindler.",
      "word_count": 3
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "Schindler come late.",
      "word_count": 3
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Same by the oven.",
      "word_count": 4
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "Take them out, put it in.",
      "word_count": 6
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 2,
      "text": "Like a bakery.",
      "word_count": 3
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "My brother.",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "The older brother.",
      "word_count": 3
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "We both were together from first until finished.",
      "word_count": 8
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "Cracow?",
      "word_count": 1
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "Plaszow.",
      "word_count": 1
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "In Plaszow?",
      "word_count": 2
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Ah, about two, three years.",
      "word_count": 5
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "And after this, Schindler had come-- he come.",
      "word_count": 8
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 2,
      "text": "Schindler had come, and had tell he wants some people.",
      "word_count": 10
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 1,
      "text": "No change.",
      "word_count": 2
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 2,
      "text": "Was the same.",
      "word_count": 3
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "Nothing you can do.",
      "word_count": 4
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "You have to do it what they say.",
      "word_count": 8
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 0,
      "text": "The same.",
      "word_count": 2
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 1,
      "text": "We go together.",
      "word_count": 3
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 2,
      "text": "When he-- we-- if he was going, I'll go with him.",
      "word_count": 11
    },
    {
      "segment_idx": 160,
      "sentence_idx_in_seg": 3,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 161,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 162,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 1,
      "text": "I tell you what.",
      "word_count": 4
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 2,
      "text": "What's happened like-- for Schindler, you see, Schindler come.",
      "word_count": 9
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 3,
      "text": "He go to the bus when it come from the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 4,
      "text": "He tell them, I want people.",
      "word_count": 6
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 5,
      "text": "And that way, a friend of mine, he called, come on, come on, come on.",
      "word_count": 15
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 6,
      "text": "Come on.",
      "word_count": 2
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 7,
      "text": "He took me, and after, he took my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 8,
      "text": "A lot of people took from the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 9,
      "text": "We need the people.",
      "word_count": 4
    },
    {
      "segment_idx": 163,
      "sentence_idx_in_seg": 10,
      "text": "Not [INAUDIBLE] [INAUDIBLE] we go to the [INAUDIBLE], to them.",
      "word_count": 10
    },
    {
      "segment_idx": 164,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Bombs?",
      "word_count": 1
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Ammunition.",
      "word_count": 1
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "You didn't do that in Plaszow.",
      "word_count": 6
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "No, Krakow, we didn't make ammunition.",
      "word_count": 6
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "All [INAUDIBLE] the dishes, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "He took about 2,000 people.",
      "word_count": 5
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 1,
      "text": "Man and woman.",
      "word_count": 3
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 2,
      "text": "The womans, too.",
      "word_count": 3
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] All of us.",
      "word_count": 4
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 0,
      "text": "He'd-- he come over there, and he'd tell that he wants the people.",
      "word_count": 13
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 1,
      "text": "He wants the people get to work.",
      "word_count": 7
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 0,
      "text": "He chose himself.",
      "word_count": 3
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] that the foreman was coming.",
      "word_count": 6
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 2,
      "text": "He'd tell ever-- come on let's go.",
      "word_count": 7
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 3,
      "text": "Go, go, go, go, go, go.",
      "word_count": 6
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 4,
      "text": "We need-- somebody looking for you.",
      "word_count": 6
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 5,
      "text": "I was this time.",
      "word_count": 4
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 6,
      "text": "My brother, together.",
      "word_count": 3
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 7,
      "text": "He push me.",
      "word_count": 3
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 8,
      "text": "I push him.",
      "word_count": 3
    }
  ],
