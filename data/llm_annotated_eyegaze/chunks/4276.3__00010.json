{
  "stem": "4276.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And he worked with the Jewish agency.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And then we decided to come or to-- legal-- to Israel or to America.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And we putted our names in both.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I told him I don't want to go to another camp.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I have to go legal.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "So whoever will be first, that's where we go.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And United States got out papers first, so there.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "This how we managed to go to United States.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I was married in 8th of September, exactly.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Which year?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was fun.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We had a restaurant in Innsbruck that would cater the wedding.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But my aunt-- the older aunt that was always around us-- I forgot to tell you.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Are you tired?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I'll stop talking.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I think that you all want to know my life till normal times.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So my aunt was in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And, of course, we eat different things, not to talk about kosher at that time, because it was not.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But on the day of our wedding, of course, the women were separate.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "The bride was separate from her groom.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "All of a sudden, somebody opens the door and brings a rabbi with his court.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "About four or five people walked in, very old man.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And my husband was in heaven.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "He was quite orthodox, OK?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And then he came to kiss me, normal, and to see if I am who I supposed to be.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I had lipstick on, and he gave me his handkerchief.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And he says this doesn't go with me.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "So I whispered to him, don't worry, you are going to buy me lipsticks.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "[LAUGHS] So then we had a chuppah.",
      "word_count": 7
    }
  ],
