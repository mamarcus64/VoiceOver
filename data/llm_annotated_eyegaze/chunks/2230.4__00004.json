  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "When the Polish army left Poland, under the [INAUDIBLE] army that ended up in England, they ended up in Egypt before they went to England.",
      "word_count": 25
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] And about 15,000 of them were Jews in the Polish army.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They decided to go to Palestine at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "The other army, the Poles, went to England.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "The Jews went to Palestine.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "After a while, the British formed-- now I know what they did, I didn't know then-- they formed what is called-- it was called the Jewish brigade.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "They fought in Germany under the British flag, but [PAUSES FOR 3 SECONDS] every Jewish soldier had a Star of David over here, with a signet saying Jewish Brigade.",
      "word_count": 29
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And I joined them in Belgium.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "They wouldn't take me, but I got a [PAUSES FOR 3 SECONDS] army pay book.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I was too young.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "What they were doing was sending people back to Palestine at that time.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I got a [PAUSES FOR 3 SECONDS] army pay book.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "This pay book was so that I can go to Israel, and the British would let me in, [PAUSES FOR 3 SECONDS] because I was a returning soldier.",
      "word_count": 28
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "But I was 16, 17.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Nah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We didn't think of girls.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Not yet.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was too young.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "The Jewish brigade was in Belgium, which I was with the one in Holland.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And [PAUSES FOR 4 SECONDS] one day I-- I decided to come to the United States.",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "This is what I told you, about those two-- two people.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Now, when I came to United States, I always knew I had an aunt over here, and I had an uncle.",
      "word_count": 25
    }
  ],
