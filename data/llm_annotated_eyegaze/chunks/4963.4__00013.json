  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And she heard that I had come to Germany, to Munich, so she immediately went-- there were no doors locked for her-- And she was actually a very reserved person.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "But when she heard that, you know, the remains of her family, she didn't have any children and she immediately got papers and a visa to come to Germany.",
      "word_count": 29
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And she came to Germany, to Munich, to [?",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Batels ?] and had a big fight with my uncle because my uncle wanted us to go to Palestine.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "But she said, no, they're coming to the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "So she immediately made out papers, went to see the Jewish organization, and through the-- through HIAS, we were on the list to come to the-- as foster children-- we were 15-- to come to the United States.",
      "word_count": 38
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So we had to wait a couple of months.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And then we went to-- we went to the pier-- the pier in Bremen, and from Bremen, my cousin Wolf and I, came with the ship with Bremen, I believe it was, what was name of the ship-- to the United States.",
      "word_count": 42
    }
  ],
