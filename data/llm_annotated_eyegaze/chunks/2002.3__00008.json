{
  "stem": "2002.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Verslev-- ?] no, not [?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "Verslevka-- ?] Brulevska, Wanta Brulevska was the girl's name.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "Everybody in the town kept saying that I should go because I slept with her.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "OK, I went back there for the medicine.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "She gave me the medicine.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "She went with me back.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "I gave the medicine back to the-- to the person who was sick.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "She asked me to go back with her to the village, and I say, I cannot go, because I am working in the government.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "She said, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "My-- my uncle is the one who has all this stuff sent from the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "And he would send from Siberia gold to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "United States would send products.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "And her father was the head-- uncle was the head of it.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "She kept writing me papers that I'm sick and I shouldn't work.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "I should be with her.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "Anyways, it got to a point I was very scared.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "I was scared, and I didn't want to go there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "But my brother kept after me.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "My brother said, if you're not gonna do what you have to do, we're gonna die here.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "There's no food.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "There's hardly very little food, and we're not gonna survive.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So I went along with it.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "One day, they come in, and they're telling me with a horse and wagon, and they're taking me-- me, my brother, and these two guys, which I got the picture, and a couple other guys, and they're taking us to that-- where she is.",
      "word_count": 44
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "You wouldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I get there.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "There's a long table in a room with food, all kind of food, and I'm getting married without me even knowing that I am getting married.",
      "word_count": 26
    }
  ],
