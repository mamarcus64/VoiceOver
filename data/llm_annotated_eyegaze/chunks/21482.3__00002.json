{
  "stem": "21482.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And so people-- we had to go and build roads.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "They broke-- we had to break up the tombstone and crush it.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I did that while I was in the ghetto towards the end, towards the end of it, what they were already liquidating the workshops in the ghetto, because there were a lot of workshops in the ghetto.",
      "word_count": 37
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "The workshops were being moved to the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "So while they were being moved, there was no place for us to work.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So we walked to Plaszow and we would sit and-- the women-- women, we used to build the roads.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We were sitting building the road, breaking up the tombstones.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I remember whole row of women breaking up the tombstone.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And the commander of the camp was Amon Goth.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He was the one who would be in charge of liquidation of the ghetto as soon as the camp was ready, the barracks.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The men build the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans came very early in the morning, about 4:30 in the morning, and they were running through the ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "The truck was driving through the ghetto with loud speakers, that everybody had to pack up and leave the ghetto by 6 o'clock at night.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Everybody had to go to their place of work.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And you would work with the, you know, it was the gemeinschaft, it was the workshop people.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And anybody under 12, children under 12, had to stay in the ghetto in the orphans' home and you couldn't take children.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And my mother and I, we pack a little suitcase for each one.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And I took my cousin and went to the corner to meet my workshop.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And, you know, they wouldn't let me.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "The Germans and the Jewish police, they says, you can't take her.",
      "word_count": 12
    }
  ],
