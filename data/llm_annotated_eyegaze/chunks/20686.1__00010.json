  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "There was a tremendous division between us and the Poles.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS] They-- they-- I can't understand.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "It's something which needs someone perhaps like a man like Freud to analyze collectively what took place.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "After all, Germany was a common enemy.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "How could they side with them against us?",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Of course, there were individuals.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But as a nation, as a collective, their-- their response to their Jewish brothers was miserable, morally degrading.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I think they-- they did not stood the test of time.",
      "word_count": 11
    }
  ],
