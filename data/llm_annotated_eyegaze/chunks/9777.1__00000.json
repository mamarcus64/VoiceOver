{
  "stem": "9777.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "This is my new neighbors.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I live here just a few weeks, but the people seem to be much more receptive than in the previous place.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I lived there for six years.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And to tell you the truth, very few I even know, not by name, but even by looks.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My next door neighbor, where I went this morning, she's a snowbird-- Italian people from New York.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They're very, very lovely.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And across the way from me, there is an older couple.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They are very, very nice too, but they live here all year round.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Quite of an older-- both of them are over the 80s.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "They live here already for 17, 18 years in the same condo.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, my name is Eva Hoffman.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name is Deutsch.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The Deutsch?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "D-E-U-T-S-C-H.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And Eva is E-V-A.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I have no nickname, or a second name.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I was born in Hungary, in Pecs, P-E-C-S, June the 5th, 1928.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well, I did grow up partially.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I-- as I remember myself, being a small child, we lived in a different town called Szombathely.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It's [PAUSES FOR 3 SECONDS] about 30, 40 miles from the Austrian border.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It's a small-- smallish town.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I went there in the first or second grade.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And we moved to Pecs when I was in the second grade, where I was born, and there where I finished my schooling.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Pecs, I would say about 60,000 people, and about 5,000 people of-- 5,000, 6,000 the people Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Well, there was-- the stores mostly belonged to the Jewish people in the community, and we had a lot of textile and grocery business and [INAUDIBLE] that goes with the small town living.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents I lived with, they were retired people.",
      "word_count": 9
    }
  ],
