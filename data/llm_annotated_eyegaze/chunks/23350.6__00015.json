  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Went to the Grand Hotel.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But it was nice.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Everything was so wonderful, and we had children, and everything was fine.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And then we went-- after 17 years, we went to live in Italy.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "That was the highlight of my life.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "In Italy, we had a good life, very nice life.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "But my husband got very ill.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And it didn't work out well.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And then-- that was, we came back to England first.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Business was also going down.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "He was ill.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "It was very difficult.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And then afterwards, I had my downfall again.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "I was somewhere up there, and then I went right down again.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "This is when I started learning it was useful for me to learn corsetry-- that I knew corsetry, because I started working in corsetry.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "That means I was mainly selling and doing.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "But it was good that it I knew it.",
      "word_count": 9
    }
  ],
