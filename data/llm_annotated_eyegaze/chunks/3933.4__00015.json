{
  "stem": "3933.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "This non-Jewish brother-- brother of mine took to Tsila in.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They discover, they find, Tsila's mother was hiding with a Polack-- the Polack was in love with her, kept her, and later he hadn't got a choice.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "He left her, and she was killed.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "The non-Jewish-- the non-Jewish brother's wife was killed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "She was-- she was walking around with a patch over one eye, you'll remember.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I was-- I was visiting-- I was sleeping a few nights there, a few nights there.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "When-- when this-- when Kola went to get rid of me, I slept in a friend's house, a girl, and she said, don't go out.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "Don't go out, Mary.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "I will not, I said.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And she find out and she visited me-- the non-Jewish brother's-- brother's wife, my husband's sister.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "She part-- and I said, Sonja, oh, my God-- why did you do it?",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Why did you walk around?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I came from the village.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "I came to straighten out.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And I says, why do you straighten out, when you have a village, you have a place for to stay?",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Stay.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "She's said, the placement there it's not bad, but she's with Tsila there.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "The she's come in.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "She-- oh, this is a very important part.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "She made a patch on her eye.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "She walked in, and we talked, and we talked.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And suddenly, somebody knocked on the door.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Go into door two men, Polacks.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He said to her, [NON-ENGLISH]-- Zbyshek was a little bit on the street for a change, this was when I stayed with my girlfriend for-- kind of a girlfriend-- for two days.",
      "word_count": 32
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And he said, documents.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Where is your documents?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "She said, oh, I don't have any.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Come.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He took her with the patch on her eye-- finished.",
      "word_count": 10
    }
  ],
