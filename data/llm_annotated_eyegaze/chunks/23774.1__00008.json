  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "But after 4 o'clock, they had cars with loud speakers.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Any Jew is hidden, any Jew is awake, you can come back to the city-- we won't kill you anymore-- and start your normal life again.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And that's what it was.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "We came back, got out from the hidings.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "People what they were in forest, they came back.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans said at that time, and the Ukrainian police, now, why don't you move over on one street so you'll be close all together?",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Because there was no family that was not affected by the killing-- a mother, a brother, a sister, a father.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "So we moved over on one street.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "Let's stop here.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "Goszer, you can drink.",
      "word_count": 4
    }
  ],
