  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Because he was the one-- he was-- he was an architect, but in the camp he worked like a glazier, and he worked in the outside kommandos a lot.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And when you worked on the outside kommandos, you could always smuggle in something here and there.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And when we smuggled out the [NON-ENGLISH], I had wooden shoes that had hollowed-out heels--",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Those pistol shells.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So I had wooden shoes that had thick wooden heels, and the thing opened up, and I could put in there-- with sawdust in between, it shouldn't rattle.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't smuggle out a lot. 10, 15 at a time.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "But those things counted, and they took it out the same way--",
      "word_count": 12
    }
  ],
