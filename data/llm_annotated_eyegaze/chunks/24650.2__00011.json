  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "First of all, a Polish Christian lady came to the people who stood there, and she did go straight to a man.",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And she said, here, you have the package.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And I'm going with you.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "So the Kittel come and said, who are you?",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "She said, I am his wife.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "He said, go away.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "He is going to be shot.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "She said, OK, so I'm going to be shot.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "He said, you don't have to wait long.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "He took them both to the wall, everybody of us have seen, and shot them both.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "This was the one.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "And now you have here the picture I showed you, from my girlfriend, who passed away this year.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
