  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.3,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "In [POLISH], when we lived, before he went to army, to join the army-- well, he-- maybe the reason, he was small like me.",
      "word_count": 24
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] little bit-- my sister was taller.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "He was red-head.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And he got all Polish friends, my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "And he, he had a complex that he was Jewish.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "And he did many wrong thing, want he shouldn't have done.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Kuba. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Jacob. ?] That-- [?",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Kuba, ?] we call him [?",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "Kuba. ?] Same as my uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "My sister, [?",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Yanka, ?] Joanna, Joanna-- my sister was everything to me, really.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "She brought me up, and, and when my mother died, it was such a tragedy for me.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "It was such a trauma.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "I was all by myself in [POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "And, and that was the time-- the worst time of my life, maybe, when my mother died.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "But that was before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "I didn't know how it looks, ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I know, in Tonie, that we are going to ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know what that mean.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "But when we arrive, I know that was a wall, brick wall.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And it was a entrance, like a big, big entrance there.",
      "word_count": 11
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "And were Germans standing on this entrance.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "And we were located in some [POLISH] Street, I think, in [POLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "It was huge, big, very big, big house.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "Many, many family lives up there.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] was already one couple with two girls.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 10,
      "text": "He was making chocolate, that man.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 11,
      "text": "And he was still doing this during the-- ghetto was like a little, little town in the beginning, in the beginning.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 12,
      "text": "The shops were open, and bakery was-- normal life, only very squeezed.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 13,
      "text": "We were very squeezed.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 14,
      "text": "We were very uncomfortable.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 15,
      "text": "But And it was hard to get food.",
      "word_count": 8
    }
  ],
