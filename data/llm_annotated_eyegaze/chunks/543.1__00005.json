{
  "stem": "543.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And they say, oh, better that way.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] You know, [INAUDIBLE] My mother said to me, do not talk to me you know.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "But I was so-- tell her stories and things-- we were very close and were very-- I had actually a very nice youth.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My mother had only two brothers, and I had also nephews-- two, three nephews, who were deaf, born deaf.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But my mother had four kids who could hear, but my mother was-- my father was not deaf born.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So the-- and my father had a big family.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My father had about five sisters, I think, and two brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But my father was the youngest of family.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "So I can remember my aunts and uncles that I had to go Friday night visit them, and they-- they were quite well-to-do people, my father's side.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They lived in Amsterdam?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "They lived in Amsterdam, in Antwerp, but mostly in Amsterdam.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My father had two sisters, and they were-- they had a big doll factory.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My father had porcelain and they did fairly young.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They had a big factory and were quite well-to-do.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So Fridays, we had some dinner, we had to visit them.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I remember things, that had to get a big [INAUDIBLE] before I-- you know, when we were small and very-- have to behave myself, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Things like this I remember from my father.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "They could hear.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They were not deaf.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] Can you tell me a little bit about going to school, growing up in Amsterdam?",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When I-- when I was, well, six years old, every kids go to school, and I went just to public school, six years, yeah, till I-- till I was-- that's only six years.",
      "word_count": 33
    }
  ],
