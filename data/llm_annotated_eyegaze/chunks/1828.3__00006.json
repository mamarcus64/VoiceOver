{
  "stem": "1828.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 24,
      "text": "I mean, I was-- I was on the top tier, because I was young and I was able to climb up.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 25,
      "text": "And they were going to find out who that is.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 26,
      "text": "And they told me to keep my mouth shut, that they were going to take care of it.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 27,
      "text": "And as everyone had settled down for the night, they switched on the light and said, everyone stand next to their bunk.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 28,
      "text": "And two of the women examined.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 29,
      "text": "Anything you owned was on your bed, or under it.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 30,
      "text": "And they found this extra bread in this one woman's, and they said we weren't-- we're going to punish you.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "They threw her out.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "They said, get out, find your way somewhere else, and don't ever come near us again.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "And that was very interesting.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "But you see, bread wasn't just a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "It was the difference between life and death.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "This-- this-- we were-- our health and our being was so finely balanced that this one bread ration may have you know, pushed somebody over the top.",
      "word_count": 27
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "And it could not be permitted.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 38,
      "text": "And there were always some rotten apples in every group.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 39,
      "text": "Springing back to Auschwitz, when I was thinking of bread, my father didn't eat bread in Auschwitz on Pesach.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 40,
      "text": "He had not [NON-ENGLISH] at that point anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 41,
      "text": "He had no [NON-ENGLISH] He knew a lot by heart.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 42,
      "text": "And he said, I forbid you to do the same thing.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 43,
      "text": "He told us what he was going to do.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 44,
      "text": "You had to find a gentile.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 45,
      "text": "You couldn't do it to a Jew, give bread to a Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Not to eat the bread.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "You must eat.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And must nourish yourself, and you must remember at the same time why you're doing it.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And he didn't eat bread.",
      "word_count": 5
    }
  ],
