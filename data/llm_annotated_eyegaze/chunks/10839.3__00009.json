  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "May-- [INAUDIBLE] in December, I went to--",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Markstadt.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "How long I was in Markstadt?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Oh, oh, oh.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "You see, they, [PAUSES FOR 3 SECONDS] they made, again, they took me-- no, they gave out the order.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Every, Everybody got to be by a building where the, the, Jewish [INAUDIBLE] was there, the committee.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And who, who will not be there, when we catch him, will be shot on the spot.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Then I went there on that place.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And this time from [INAUDIBLE], they took me on a [NON-ENGLISH SPEECH] to Sosnowiec.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "They called this in Jewish, [HEBREW SPEECH].",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Now we-- It was on the [NON-ENGLISH SPEECH].",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "We went there.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And over there was a lot of people arrested already, Jewish people, to send it away.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Then they send me away, because I was in good condition with the health.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They needed me to work.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Then they sent me away to Markstadt from that place.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Markstadt, when I came there, I just-- over there was watching the Wehrmacht.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Because the Wehrmacht is the regular German army.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And when I was a year there, they liquidated the, the Wehrmacht.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And what I went to Blechhammer.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And before I'm going to Blechhammer.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I want to mention something here, what-- not a fight-- what, what I got a struggle to stay alive in Markstadt.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "In Markstadt, [PAUSES FOR 3 SECONDS] I went on the [NON-ENGLISH SPEECH] where we worked-- worked a few thousand people there.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They, they used to make there, like-- it, it was hills there like, like-- it looked like snow.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And this was chemicals.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "They used-- they used to make there all kind of chemicals.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "I think ammunition, too.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "I didn't work ammunition there.",
      "word_count": 5
    }
  ],
