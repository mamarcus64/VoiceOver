  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And he was doing operation on Australian soldiers without any anesthetic.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And he suffered through similar things that I did.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "You know, he was a very big man.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "There is a stamp in his honor, too.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So we came to Australia.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I hated every minute of it.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And you had a second son.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was later, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "My second son, Leslie, was born in 1955.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I liked Australia better.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And-- but still, I felt very lonely here-- terribly lonely.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Because I wasn't used to houses.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We all lived in houses.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Before, we all lived in apartments.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And then my mother, of course, was married.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And she went her own way.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And I went my way.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And my husband was working very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And we got a flat.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And I took a lodger, because we couldn't afford to pay rent.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "And I felt very lonely.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "But I was starting to get acclimatized, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "It takes time.",
      "word_count": 3
    }
  ],
