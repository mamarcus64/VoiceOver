{
  "stem": "9168.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And they raised prize rabbits, which brought them not only three-foot high trophies, but additional income.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "They also raised-- we had a dog kennel of Boston Terrier-- the little Boston Terrier bulldogs.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And they were American Kennel Club registered, so this also brought an additional-- my mother was a rock who really held our family kind of steady for a-- a substantial period of time.",
      "word_count": 33
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother was the German in-- in my family.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And she was-- she was born in Beloit, Kansas, and educated at the college at Lawrence, Kansas.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She, in her pre-marriage years, was a medical records librarian at the Karl Menninger Institute and-- in Topeka, I believe that is-- and actually worked with the old, original of the old Dr.",
      "word_count": 33
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Karl Menninger, during those years.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Her grandparents were born in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Their name was Groeppengeizer, G-R-O-E-P-P-E-N-G-E-I-Z-E-R, or S-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember that.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And they settled in-- eventually-- early on in the German community, in Aurora, Illinois, and then on to Kansas, where her father had a-- a wheat farm in Kansas, until his death.",
      "word_count": 32
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My mother and father-- my my mother's father and mother separated at age 1 for her.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So she was actually raised in Kansas by her father.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And then they were reunited again when she was 21, with her mother.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "It was a--",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father's family came initially from England.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And his mother and father, in Hopkinsville, Kentucky, had a tobacco farm, a very large tobacco farm.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And his grandparents actually had slaves in the same town-- maybe about a dozen slaves.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And he had-- I-- I never really knew much of that family.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We visited early on, occasionally, but very infrequently, with that side of the family.",
      "word_count": 14
    }
  ],
