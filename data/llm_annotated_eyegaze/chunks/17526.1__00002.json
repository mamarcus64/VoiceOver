  "elapsed_s": 351.8,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "So also due to the fact that our town was not far from the German border, on certain market days, the Germans from the-- from the bordering towns and villages would come on-- on market days to town so German was also heard her and there.",
      "word_count": 46
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "So it was rather a multi-language area.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "After school-- after school activities were helping out my father in the workshop that we had and the living house in the house where we lived.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Coming home from school, I did my homework, and then I immediately joined my father and a few people my father employed in producing-- we produced the tops of the shoes.",
      "word_count": 31
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "That was such a-- this was a trade by itself, which today has naturally disappeared.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "But at that time, this was quite a known trade.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It's like a subcontrator.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "The shoe-- the shoe store owner would come to us.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We would produce the tops of the shoes, then he would take it to the shoemaker and the shoemaker would finish up the product so he can sell it in his store.",
      "word_count": 32
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "So it was quite a known profession, if I can call it as such.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "But there were busy times and there were slow times.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "I remember distinctly how much I worried when it was slow and I was wondering where are we going to get enough to sustain ourselves.",
      "word_count": 25
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The family consisted of three children and two parents.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "My father and my mother and I was the oldest and I had a brother that did survive, too, and I had a sister that never did survive.",
      "word_count": 28
    }
  ],
