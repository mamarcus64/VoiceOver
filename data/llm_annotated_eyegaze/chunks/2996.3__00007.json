{
  "stem": "2996.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "His job was to make Nazism accepted all over the world, to soften up the soft underbelly of what they considered to be the soft underbelly of the likely enemies of Nazi Germany.",
      "word_count": 33
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I'll show you one thing.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "You can read the headline.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "You can't see the picture very well.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "The picture shows what appears to be a rabbi killing a Christian child to use its blood in the matzos, which those horrible Jews are eating on Passover.",
      "word_count": 28
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "With this-- with this, you can about imagine how people reacted.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I'll show you another one.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I used to publish-- once I went to work for the Community Relations Committee, I thought, all of this information we have here.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "We've got to do something.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "We've got to do something.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "We've got to make the world know about it.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "Just the same thinking as I had when we started to print the anti-Nazi newspaper in Chicago.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And I started publishing, what was called, the We printed only 1,000 copies.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "But we reached millions because they went to all kinds of paper, the Washington paper, all of them.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "He used a lot of this stuff, exposes of the Nazi activities, primarily of this country.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "He out there had a story about-- one full issue on what the Nazis were doing in Mexico and South Africa and so forth.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Here's one that helped me really do about something.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It says, why do we fight Marxism?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You need to turn it this way a little bit.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Why do we fight Marxism?",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "This is the cover of a brochure that we picked up through our agents at the Nazi headquarters here.",
      "word_count": 19
    }
  ],
