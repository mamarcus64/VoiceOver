  "elapsed_s": 201.0,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I said nothing, because we weren't allowed to talk to them.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I was afraid to talk to them.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And then if I did, what was I going to tell him?",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "But he insisted.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And he said to me, are we going al Kiddush Hashem?",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] You understand what that means.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And [PAUSES FOR 3 SECONDS] I was afraid to answer and I couldn't say anything and I didn't want to tell him.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But I remember saying in Yiddish, it would be a good time, Rabbi, for the Messiah to come right now.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "This is what I said to him.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "They had the order to march on and he marched on [PAUSES FOR 5 SECONDS] to oblivion.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I thought we would do that--",
      "word_count": 6
    }
  ],
