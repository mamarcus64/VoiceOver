{
  "stem": "151.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 411.4,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "After that when I finally was able to obtain papers, affidavits for them, then they came out here.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And now luckily, fortunately, we are together.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I arrived to Allentown, Pennsylvania.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It's very interesting.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I want you to know that I'm going next week to Prague to my father's gravesite where I'm going to meet my brother who's going to be coming back from Israel where he is visiting now.",
      "word_count": 36
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I'm going to go from Prague to Israel, so we will meet in the middle.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And this is the first time that we're going to be back together and visit my father's gravesite on which, by the way, before we left we engraved my mother's and my sister's name since they didn't have a grave.",
      "word_count": 40
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I came to Allentown, Pennsylvania, on the 31st of October, 1948.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And it will be on 31st of October that I'm going to be returning this time from Israel.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And it was not planned.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I just when I saw it on paper, I realized.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And I remember my brother-in-law waited for us at the airport.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And I arrived-- I came with my daughter who was then 11 months old.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "My husband stayed back.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "He got his visa a little bit later and he wanted to go to England where he was a young brother in an orphanage.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "He was taken by the UNRRA by the way to an orphanage in England after the war.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And the plane landed in-- in New York in the LaGuardia-- we arrived at the LaGuardia Airport.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And everybody was getting off the plane and the captain came over to me and he said, you can't get off.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "You have to wait.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And I said, why?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I said, they're going to keep me here?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "What's the problem?",
      "word_count": 3
    }
  ],
