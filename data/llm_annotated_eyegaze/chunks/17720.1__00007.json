  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "Was a very [PAUSES FOR 3 SECONDS] complex situation, because Bulgarian people never stop to-- they are very warm and not only sympathetic, but a feeling of admiration for the Russian people.",
      "word_count": 32
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "Because were the Russian that saved them from the Turkish [PAUSES FOR 3 SECONDS] yoke that they were for almost 500 years.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "So this was also projected in, in the behave there in the capital during this period.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "From one side, one kind of silent sympathy, but outspoken, very hostile officially feeling, until we had really to leave our beautiful home and move to one of the [PAUSES FOR 4 SECONDS] apartments of the area where they were concentrating Jewish people.",
      "word_count": 43
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "Was kind of poor area of the city.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "This word ghetto, actually, I didn't hear there in, in-- but perhaps, this was the right word for.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Because there was only strictly Jewish people living there.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Was known-- this area was not very far from the synagogue, by the way.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And there was the-- they used to call the gypsy quarters, the quarters where the gypsy, gypsies were basically living.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Was only-- I was the, the youngest member and the only member, my, my mother and my father.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "This was somewhere [PAUSES FOR 3 SECONDS] in the early '40s.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I would like to say in early '40s-- '40, exactly '40, 1940-- not '40s-- actually '40.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Because we didn't stay there too long.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We stay there less than year.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In this place, yes, in these quarters.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "After that, we had to pack meager belongings and take the train for the location that was indicated, again via this mail that they receive to [INAUDIBLE].",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
