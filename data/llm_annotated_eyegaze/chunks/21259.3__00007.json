    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I, I went out a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Now, she-- I went out-- I, I went in the country with my [INAUDIBLE] cousin, [?",
