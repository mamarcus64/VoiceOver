  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He told me, but the pocketbooks.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I tell you, yeah, what's the difference, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And I start-- he is a-- the furman was by the pocketbooks, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And he give me the job.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Over time, I ask for that price, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I used to make $180.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I used to work for $52.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I started at $52 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And I was working there, you know, believe me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And I see who makes money there, pieceworker, cutters for the cut and framers.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "They made the money.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I went there, you know, I went there.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "In about six months, I tell you, I, I want be a framer.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And they raise me, and I start framing, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "I used to make, you know-- I never make so much money.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "I used to make over $300.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "I used to make tickets, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "I not give every-- I could make more.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "But the boss, when he sees the tickets, I make so much money, you understand?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "He cut the prices.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "I give every week, you know, I make the price $290, $300.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "And I was working 35 years of this job.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "Even they want business.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 23,
      "text": "I not want the business.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 24,
      "text": "And this was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 25,
      "text": "And I like it that this was mine did.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 26,
      "text": "Let me ask you, how did you meet your second wife?",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The second wife, I went out, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I went out a lot.",
