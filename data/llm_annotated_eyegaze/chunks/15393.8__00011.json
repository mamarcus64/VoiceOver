{
  "stem": "15393.8",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "We ran also at the same time.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "It was a travel office and not an agency.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But the state travel office for information and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And the observer to the United Nations.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And so I worked part-time, because the child was small.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But it was very interesting for me to do that at the Rockefeller Center and in New York.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And it was at the time when Khrushchev was banging his-- and the war was almost imminent.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And they were interesting times.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And in 1963, I came back to London with Karen.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Because my husband and I, unfortunately, we were divorced.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Which is very sad, but so it happened.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we are friendly.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We were good friends and so forth.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "But unfortunately not as husband and wife.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And he stayed in America, and I came back here.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I working here and so on.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And then years later, I was working constantly.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Karen was going to school.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "She was at Saint Paul's here, and then at Godolphin and [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And this is why I moved to this part of the world.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "Because we used to live in Hampstead, but I wanted her within a walking distance to school.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And that was good.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And afterwards, she went back to America-- to study there, to work there and so on, and came back afterwards.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "And I was remarried in 1974.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "Sorry, in 1975.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "Unfortunately, did not last very, very long.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "My husband-- my then husband, late husband, was an actor.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And his name was Eric Pohlmann, a rather well-known actor.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "People here will know-- know him well.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "And a most delightful man.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "Absolutely kind, wonderful, clever, wise, fun.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "Everything in one person.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "And it was very nice life, very interesting life.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "I mean, he played a lot abroad.",
      "word_count": 7
    }
  ],
