{
  "stem": "3933.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And we were [INAUDIBLE] to the Russians.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "The Communists marched, and not that it was so very, very pleasant.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "It was far from it, but there were-- we already heard about Hitler's philosophy with Jews, and we were on the Russian side.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "We are far from it.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "And-- and refugees started to come from central Poland-- the refugees, where Hitler took over the Poland-- the half of Poland come to other-- this other half.",
      "word_count": 27
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And we find out, and we started talking about concentration camps, but we were under the Communists.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, ho, ho.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Here, I have the article.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I-- here I have the article.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I just find it this week in I-- a horrible article about anti-Semitism, and I-- I made-- I sent it to my son in Israel.",
      "word_count": 25
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And when I spoke to him, he said, Mama, we have it here too.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I showed it to my co-workers over there.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I made a copy, and I have it here.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I'll show it to you.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Extremely discrimination.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Jews were-- I consider Poland worse than Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I know it's unusual.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "It's-- you have no idea.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I was kicked around in school.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "We were discriminated terribly.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "We were not second-class citizens.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "We were third-class citizens.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "I don't know if they don't-- they don't talk about it.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Well, they know it.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Well, I don't look Jewish, as you know.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And I would believe that.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I look Slavic more.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "My son, absolutely not-- blond, very blond, and very blue eyed.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "But in spite of everything, we've got neighbors, school people, and everybody knew I'm Jewish.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I mean, you can't hide it.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "You know, you live in places.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "They were discriminated.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "They were kicked around.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "They were calling us names.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "We killed the Jesus.",
      "word_count": 4
    }
  ],
