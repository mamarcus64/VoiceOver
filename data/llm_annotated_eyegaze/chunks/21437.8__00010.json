{
  "stem": "21437.8",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And this is where my grandparents had another business, as well.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So she was coming, once a year or twice a year.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And when she was coming, she was-- my father insisted.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "My father adored her, so she-- he insisted that she stayed with us.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And he was changing the clocks when she was ready to go.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He said, no, another hour, another two hours, you know, things like this, where I remember.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And her name was Eve-- Eva.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] he absolutely adored her.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And so I saw her.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "She was with me, two weeks, three weeks at a time, once a year.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We just talked about girl things, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I mean she was married.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We were just so overwhelmed that we found one-- one another.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I stayed there for a little while.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Because I-- later, I went to Stuttgart.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And if I want to think, now, she was at my-- she was at our wedding.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I got married in-- on the 14th of June, 1946.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "So with her, I met her before the-- all-- all together, the four cousins, we all met together.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Sort of, we took like two years, you know, to sort of establish this.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And in what city?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "In Stuttgart.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And we lived in-- we didn't live in the DP camps.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And we lived in the Hohenheim-Strasse, Hohenheim-Strasse number 46.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We stayed in Stuttgart.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We traveled around.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "We looked around.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "We-- my husband didn't find anybody else, but his sister was there.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "She lived in Stuttgart, later, as well.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "She lived in, not in Stuttgart, but, later on, when we got together, she met a boy.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "My sister-in-law met a boy in camp.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And they fell in love.",
      "word_count": 5
    }
  ],
