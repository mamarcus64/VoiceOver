{
  "stem": "8352.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 72,
      "text": "[PAUSES FOR 7 SECONDS] Next morning, I got up.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 73,
      "text": "I go outside.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 74,
      "text": "Then what's going on on the ground.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 75,
      "text": "We could walk around there in that area there.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 76,
      "text": "You could see the crematorium with the smoke coming out.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 77,
      "text": "It was maybe about two blocks away from us.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And we said, what is that smoke?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They told us, this is where they burn the women, the people, the children, the old people.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] How do they do it?",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They said that they told them that are going to take showers.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] The mothers with the children.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Instead of letting out water, they'll have gas.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "They gassed them.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] You could smell the air from burnt bodies.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "We could see those little [PAUSES FOR 3 SECONDS] wagons pushed by the people what they are in the camp.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Dead bodies.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Piles.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Pushing to the oven, to the crematorium there.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 6 SECONDS] Also they told us that we might all wind up being there.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "But who knows what is going to be.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The people what they were already in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Because they didn't know that they will take us and ship us to other camps, to working camps.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We thought first they would kill-- burn and gas the children.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "The mothers what they don't-- there was a lot of mothers that they ask if they want to leave the child go on to die, to the death, and the mother would go to the working camp.",
      "word_count": 37
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But no mother wanted to give up the children so they would just push them in there.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "The mothers with the children.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "We were scared.",
      "word_count": 3
    }
  ],
