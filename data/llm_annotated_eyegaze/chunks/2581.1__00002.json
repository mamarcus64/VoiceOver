{
  "stem": "2581.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And she would be very angry at those people that would, because she felt that that means you're committing a sin-- was heresy-- and she's going to suffer on account of that.",
      "word_count": 32
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "She was a righteous orthodox person.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "While she was very poor, she lived mostly from what my father used to help her.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "But her being on the marketplace gave her that feeling of independence that she is earning some money.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And she was shot on the way, when we were deported from our hometown.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "When we were chased from the houses to the church, she couldn't walk that fast.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "So a German pulled out a gun and shot her on the-- on the spot.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't see it.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see it.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But there were 65 people from my hometown that were shot by Germans, by the people that chased us out from our home.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And there was a common grave on the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "There were people that were right after the war, friends of my relatives-- one relative that was-- has a picture of the grave-- of the mass grave of the 65 people.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "While I was later on in Poland, there was no sign of that grave.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "No sign of it.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- it's funny that I very seldom talk about my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It's always my father.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "My mother was a real devoted mother, as mothers could be.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She was a quiet person, didn't talk much.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But during the war years, she gave me two deutsche mark in my pocket.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "At that time, I probably was 14 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "She knew I was going on a date to spend $2, 2 deutsche mark on the girl.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "There was no place to go-- you couldn't spend it anywhere.",
      "word_count": 11
    }
  ],
