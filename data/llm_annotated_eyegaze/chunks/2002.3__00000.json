{
  "stem": "2002.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We were on the train going to Saratov.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I woke up in the middle of the night, and I find in my jacket a lot of stuff, and I didn't know what it is.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "But I-- well, I didn't like it.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "So when the train started to go, I got off the train.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "My-- my friend shouldn't be able to get off the train.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I got off the train, and I went in on the train station.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They had a different toilet than we have in the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "It's built like a outhouse.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And I took stuff, all that stuff that I had, and I threw it in the in the outhouse.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I pushed it down with a piece of wood.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "Because I was scared the Russians would catch me like that.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "I could be killed.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I didn't-- I saw passports, different things.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I didn't-- I was shaking so much.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I didn't even want-- I know it was stuff stolen out from other peoples on the train while they were sleeping from the luggage or whatever.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "But it-- it shook me up.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "I didn't care even to look if it's their diamonds or gold, whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I just was interested to get rid of it.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And as I got rid of it, finally the KGB got me in the [INAUDIBLE], what is my doing there?",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I said I missed the train.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "They interrogated me quite a while, but finally I went back on the train, and I went further.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "As I got into Saratov, I got off the train in Saratov.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And the Russians appointed me to go to work in a collective called Iminia Krupskaya.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Iminia Krupskaya was Lenin's wife's name.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I was working there for a long time.",
      "word_count": 9
    }
  ],
