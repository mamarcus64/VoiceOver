{
  "stem": "15028.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "I was a very good worker.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "So he brought me a little package there from Christmas.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And he left it like a doggy bag in the side-- a piece of salami, cake, and some other little goodies.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "It was never-- like a million dollars.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I don't-- I don't-- I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "He was the foreman.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And he was killing people and he choose me.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He liked me.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Just-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I'm a good worker.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "He always used to say I'm the best worker.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I worked-- I worked very, very clean, but he-- particular I didn't try to hide or to not to work and so on-- not to get hurt.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I left from the hospital in Sweden-- they cleaned me-- soap me-- the nurse-- from top to bottom.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And then I had doctors, all-- all types of doctors.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they start give me vitamins and different medicine and very, very [INAUDIBLE] food.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They kept me in the hospital about four to six weeks I believe and-- and get to work.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And after that, they came in-- tailor took my measurement and I got-- suit of clothes.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I had two pairs of pants, a sport jacket, a couple of shirts, underwear, socks, shoes, everything-- even a little valise they gave me.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "This was the pre-- they told me-- from the-- present from the government of Sweden.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "They did that to a lot of people-- a lot of people-- from a-- a lot of people.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "They somehow-- well, the-- from the war, they didn't suffer anything in the war and they didn't go to-- their people didn't suffer.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And they won the war.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And they said what I did, whatever-- the government in Sweden.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Very beautiful country and beautiful people.",
      "word_count": 6
    }
  ],
