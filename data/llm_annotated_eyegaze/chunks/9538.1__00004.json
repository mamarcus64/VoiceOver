{
  "stem": "9538.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "They just-- And, as you see on one of those memorial stones in Lengerich, where my father came from, there were only Heilbronns since 1680.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The first sign was that in the gymnasium, we had a very nice headmistress.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She was disposed of by one of the teachers who was a very great Nazi, and she became the headmistress of the--",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No Jewish teachers.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "This was a German gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Because she didn't conform with the-- with the regime.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "She was anti-Nazi.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Not openly, but she didn't want to conform to their rules.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "So she was sacked.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And this Nazi teacher, she became the headmistress.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "She was, at the same, time my [? fore ?] mistress.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "She made me sit separately in the classroom.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "There were two rows of benches left vacant, and I was sitting against the wall.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I was the only Jewish girl at the gymnasium.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She forbade all the other girls-- who were friends up till then of mine-- to speak to me in the intervals, when we had--",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "--break.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Some of the teachers took pity on me, and they came over and talked to me, but the headmistress was not allowed to see it.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And then, in '37, I had to leave the school.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Like I said before, all Jewish scholars had to leave universities--",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Very isolated and very conscious.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Very self-conscious, what happened, sort of, to me overnight.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Friends that used to pick me up in the mornings, we used to go to school together, we would go home after school together, dropped me, not because it was their conviction, but they were afraid the teacher might see them, that they had any contact with me.",
      "word_count": 48
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I had to leave the school.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was law.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "There must've been a few months.",
      "word_count": 6
    }
  ],
