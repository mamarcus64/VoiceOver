{
  "stem": "22086.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 34,
      "text": "They could get up and walk.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 35,
      "text": "Myself and the cousin, Abraham Kershern, we couldn't walk.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 36,
      "text": "At that time, they wanted us to get out of there.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 37,
      "text": "They didn't know what's gonna happen, if the Germans push the Russians back.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 38,
      "text": "And so they wanted us to go to Rowne, to that place.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 39,
      "text": "That was the big city.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 40,
      "text": "And you had no way of going by car or by bus or by railroad.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 41,
      "text": "You had to walk.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 42,
      "text": "And myself and that cousin, we walked out.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 43,
      "text": "We couldn't hardly walk, and we were left in our town with non-Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 44,
      "text": "And we told them.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 45,
      "text": "We didn't tell them where we were or what we were.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 46,
      "text": "But we here, and that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 47,
      "text": "And everybody said that they knew that the Lippers have to be somewhere, that the Lippers weren't killed.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 48,
      "text": "They kept count of the people were killed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 49,
      "text": "They think that they knew.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 50,
      "text": "And they said that they knew that the Lippers have to be around.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 51,
      "text": "The four of them, six of them, I should say, my-- and at that time, that's the-- my sister-in-law went with them too.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Bella went with them to Rowne.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Myself and my cousin, my husband's cousin, we were left in Klevan, in that town because we couldn't go.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And they went.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We went to a non-Jewish family that agreed to take us in.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Yes, we-- we-- we were getting stronger.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And we were be able, but we stayed there, and they treated us very well.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And those are people that remembered us from before the war that--",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't remember their names.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed there for a couple weeks until the situation stabilized.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And the Russian were-- they already for all over the-- you know, they knew the little towns.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They took over and everything.",
      "word_count": 5
    }
  ],
