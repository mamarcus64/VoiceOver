{
  "stem": "14463.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.7,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "And I run home as quickly as possible, and I got my uncle and aunt.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "We had everything ready for that eventuality.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "The little [INAUDIBLE], whatever we had.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "And the-- everybody was at home.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "Everybody was there, and we went in front of that column and the same story.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "[SPEAKING GERMAN], and we crossed the bridge.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "We came on the other side.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We came on the other side.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Where do you go?",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So the Russians, you know, came-- a Russian officer, and a Russian soldier, and he said, what are you doing here?",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "You can't stay in here.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "It's the border, right?",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "You've got to move on to Lwow, which is the nearest city.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And we went-- part of the way, I think we would by foot and part of the way, we went by-- by a truck.",
      "word_count": 24
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "We landed in Lwow.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Mother, my uncle, auntie, the three boys-- and the two boys.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that must have been about two months after the war finished.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "'39. '39, the war started in-- in-- in the ninth month, in September.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That would have been November.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "In '39.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "In Lwow, we were-- I think we were there for nine months.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Nine months.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And life in Lwow was not too bad.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "We-- we managed to get a room, the whole family together, one room.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And we were all sleeping on the floor, right?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "There was a shortage of food.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "We were hungry, but it was bearable.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Nobody was killing us and there was no decrees, nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "You know, it was just plain sitting in there doing nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And I was running around the city.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "I knew every nook and cranny in Lwow from A to Z.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "I liked the place where our first president was shot.",
      "word_count": 10
    }
  ],
