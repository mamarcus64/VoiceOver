{
  "stem": "3085.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "In fact, when we first arrived back home, we were bombarded with questions by people who either survived or-- or who stayed behind for whatever reason.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And we were constantly bombarded.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I mean, for weeks, we-- at some point, we were really just-- just exhausted, because people wanted to know, did I meet this person, or did I meet that person, did I see him or her.",
      "word_count": 36
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And I mean, they were-- you know, they just wanted to know their own relatives.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And so there was a lot of-- it was really difficult for us.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "At some point, it was quite trying to-- to answer all the questions.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "We were-- we were interviewed left and right.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "We were interviewed by the police, by the government, by all sorts of people.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I think about-- I'm guessing, but I think about 600-- 400 to 600-- survived.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I don't have the exact numbers, but, you know, it was in the hundreds.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    }
  ],
