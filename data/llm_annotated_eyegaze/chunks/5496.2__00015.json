  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And they came in these awful, big-- they are not cans.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "I don't know, like a barrel with handles, something like that.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And my arm slipped out.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And obviously, I was skin and bones and the girls were able to push it in.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "But that was the beginning.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And it came out several times, after.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And each time it came, it was more difficult.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "And when I came to Canada, and I told Dr.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "Levine ?], and he said he will not let me do any work.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "He will let me-- get me the position in the hospital.",
      "word_count": 11
    }
  ],
