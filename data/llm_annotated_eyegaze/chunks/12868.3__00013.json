{
  "stem": "12868.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I never-- I never-- because I don't know how to-- how to spell milk, how to ask milk, and how to food, it was better I didn't buy nothing at all.",
      "word_count": 31
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But I came in Atlanta.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I came in Atlanta.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "The Federation in Atlanta picked me up too.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "When I came here, and they got to make up the papers in Federation.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "When they asked me questions, my name, if there are children.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They asked me everything.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "One a-- one secretary, [INAUDIBLE] she writing for me everything.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "She ?] [? say, ?] how many-- you got children?",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "She said, how many children you got?",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I said, 17.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Everybody start to laugh.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "And she fall down like this laughing on the chair.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "On the-- the-- the president from Federation was calm.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "He-- and he speak in perfect Yiddish.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "Only he hear everybody laughing here.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "What going on?",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "What you laugh in here.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "They say, Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "Kahn ?], that man came just down from Europe.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "But he left 17 children in New York.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "He said to me is Yiddish, [SPEAKING YIDDISH].",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I say, no.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "[SPEAKING YIDDISH] what the Federation give me.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And I put down the $17.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Well, I put on the table.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Well, everybody start to laugh.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "And the-- You see, this-- this means a lot when you don't know nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "I thought she asked me how much money I got.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "I say, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "I got 17.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "There she is.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "She's saying I got 17 children in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Oh, god.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Well, that's good.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Perfect, right?",
      "word_count": 2
    }
  ],
