  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And sometimes they let us off these cars on the field to do whatever we had to do, but there was no food around.",
      "word_count": 24
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Maybe we found something in the fields.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "You know, it was turnips or something.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "This I remember also that there were turnips around.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 4 SECONDS] this was very hard, because people went crazy because they were thirsty, for instance.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "I remember somebody completely crazed-- a crazed woman because of thirst.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "I think thirst is even worse than hunger.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "I also remember that the German wanted to give me some bread or something.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "On the way, we stopped on a stop, and everybody was already out of the car.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "But Laura and me somehow-- Laura jumped out because she didn't want to influence me.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "That's why I ask you.",
      "word_count": 5
    }
  ],
