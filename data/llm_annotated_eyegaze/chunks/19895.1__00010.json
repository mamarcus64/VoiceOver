  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And he was a rabbi outside of New York in New Haven.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And, and I also sent an invitation to another rabbi whom I treated in the emergency room of Coney Island City Hospital as a young intern.",
      "word_count": 26
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And we became quite close and, and friendly to each other.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And then the third rabbi showed up.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "That was before the wedding took place, the reception.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "And he says, I am your teacher's brother.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "I am Jeno Grunwald's brother.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "I am a rabbi here in New York, a very orthodox rabbi, who said, I just came to deliver the good wishes of my brother from Hungary.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 4 SECONDS] why do I have tears in my eye?",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "[SOBBING] I think at a wedding which has three rabbis is rather unusual.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And so were there my parents and my wife's parents.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So those of us who survive on their side of the family, on our side of the family, we were a wonderful, happy little small family.",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we loved every moment of it.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We'll take a minute to change the tape.",
      "word_count": 8
    }
  ],
