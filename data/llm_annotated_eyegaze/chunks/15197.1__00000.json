{
  "stem": "15197.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I am Vladka Meed.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My maiden name is Peltel.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Warsaw, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I was the oldest in my family-- mother, father, and three children.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And my name is spelt Vladka-- V-L-A-D-K-A, capital M-E-E-D.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "P-E-L-T-E-L is my maiden name.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "As far as I remember, my family lived for years in Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Warsaw and all my family, my siblings, were born in Warsaw.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I even remember the street-- [INAUDIBLE] 3.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Father's name was Shlomo and mother's name was Hanna.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Our family I will describe was lower middle class.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My father has a haberdash store.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And it was small business.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The practical person in the family was the mother.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Father was a little bit a dreamer, liked very much to read books.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And mother was the one who kept the house and helped out the father in this business too.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "But we were quite comfortable.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Our household was always, as far as I recall, full of people from the family.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "We didn't have telephone at that time in Warsaw, Poland, so but family used to drop in and all kind of problems to reveal to my father, to my mother.",
      "word_count": 30
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "So it was a noisy house, but also an outgoing and of interest what is going on in the family and what is going on with people.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I have a younger sister, two years younger, and a younger brother, four and a half years younger than me.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Henia was my sister and Chiam was my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I would say that I resembled a little bit my father, a little bit in character and also in looks.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The relation was quite close.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We sometimes used to talk about books and about problems in the world, as a child even.",
      "word_count": 17
    }
  ],
