{
  "stem": "4760.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "So she made-- she was strong and sustained the-- She overcame the debt of my father, and she kept the business going and-- and she took care of the father-in-law and us two children.",
      "word_count": 34
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We had a maid, and we had a-- like a butcher in the house to maintain the-- the butcher shop, because we also had a butcher shop in the-- in the family.",
      "word_count": 32
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Our house was very large.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "My mother had butcher shop, [PAUSES FOR 3 SECONDS] [INAUDIBLE], like people who would stay in town and want to stay overnight.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "We had several rooms to stay there.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And she had a-- a tavern--",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "--serving liquor and beer.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So my mother worked very hard to keep us children going.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "His name was Leopold Baum.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I-- Leopold Baum, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "My-- my mother met my father in Laufersweiler for one reason, because my-- the parents of my mother were French, and she, too, after the First World War.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And actually Vic-Sur-Seille was German before the First World War and became France after the First World War.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It was a borderline, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But my mother had to move to Laufersweiler.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents had-- was a family of five people, of five youngsters.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My mother was the oldest.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And my-- my grandma had a sister living in Laufersweiler, and she was a neighbor of the Baum family, where my father lived.",
      "word_count": 23
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So my mother had-- had to maintain the household for the older people.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And-- excuse me.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And do the-- the housework and keeping busy and taking care of them.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And naturally my mother had a friend, my sister-- my father's sister and her became very good friend.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So my father spent a lot of time in-- in the Baum's house, and that's how they met.",
      "word_count": 18
    }
  ],
