{
  "stem": "26880.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And he-- and he-- my wife had such a dream.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And only thing I say, now she's very, very, very sick, my my wife.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I could not [INAUDIBLE] it there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Wait till she get a little stronger.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Then every day was guy, coming as asking, you know, has she not died yet?",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "She not died yet?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "You know, he was-- I say, no, no, no.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Till one time, I was outside.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "You know, he saw me, [INAUDIBLE] boy, came and he was talking, my-- with him, how it is.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Say you know one thing we have to do.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He say, she's sick.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Let you go for himself.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And take in boy too.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Then we will kill you and then we-- And I told him-- I told him this-- when-- when he came and he told-- and I was hearing what he say, we will kill you, then I came in the hole and I told my wife, you know, something going here, very bad.",
      "word_count": 52
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I told her the story.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "You know, I said, I go waiting what is going to be, if he will come.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It's-- he came.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And he say, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "You take his boy.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And let she be.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "When she dies-- then I-- I told him, should you come-- and I say, now come at nighttime with people and we go bury her.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Like, OK, very good.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "What you doing now?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I went from my-- from one place.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And then I went-- to-- to another place.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And it was only myself.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And then I came back.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And he was-- knows-- he know when I'm gone.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "The-- the-- the dog was at the barn.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And he knows I-- I went and came back.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And he say, what-- you know, what-- why you still here?",
      "word_count": 11
    }
  ],
