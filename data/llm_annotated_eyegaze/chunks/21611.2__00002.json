{
  "stem": "21611.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "They took me out in a terrible, terrible storm, and they took me back to the little house and put me on the floor.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And they were sure that in the morning I'll be dead.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But before they took me, they took off the little earrings-- that I have the picture still with the earrings that my mother gave me.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They didn't want to bury me with the golden earrings.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "They took this I remember, because I couldn't hear, I couldn't move, but I could see.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And in the morning, they walked in.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They wanted to bury me.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And I looked at them, and they got very scared.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "They started like to-- you know they were really scared to see me alive.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And I survived.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "No matter-- no matter the worst circumstances, I survived.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And if people ask me how, I don't know, because I can't believe it myself-- that I could sit still and talk to you about it.",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "It's very hard to believe.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I was in Kudrinka.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Kudrinka.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Not Kudrinka, Stara Huta.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Stara Huta.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We ran from Kudrinka to Stara Huta.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I didn't tell you still-- I forgot to tell you-- that I have a friend that I was with in kindergarten.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Yetta Fingerhut.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "She ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She ran away with her mother.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "She was an only child, only girl.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "The mother and family, aunties, a few aunties and cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So one policeman shot all of them, but the bullet went through her neck, and it stuck in one place that you could survive.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we find her.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "She survived and the bullet was removed after in Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "This was really-- like-- talk about miracles.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And where were you liberated?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "When you were liberated, where were you liberated to?",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "In Stara Huta.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "The Russians.",
      "word_count": 2
    }
  ],
