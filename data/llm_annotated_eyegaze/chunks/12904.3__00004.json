{
  "stem": "12904.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "And so when he died and I felt I wanted to go to graduate school-- I had been taking courses actually, evening courses, late afternoon at University of Chicago, graduate courses.",
      "word_count": 31
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "And so I decided I could do my graduate studies as well in St.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "Louis, help my parents at the time, same time, since I was widowed then.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "And so I moved back in 1960, and went to for two years to Washington University graduate school, got a master's in psychology.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "And then we worked at Jewish Employment and Vocational Services-- it's now called Metropolitan Employment Services-- for five years as a senior counseling psychologist.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "I did a lot of testing and so on.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "And then that time, the Jewish employment-- Jewish agencies did not pay women as well as men, was still-- in the 60s, there's still stigma.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "And so I went to Malcolm Bliss Mental Health Center Bay Hospital as a rehabilitation specialist.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "And then I realized I can't leave after five years anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "I have to have retirement.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "So I stayed 10 years there until I took early retirement because I-- my bad back.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 46,
      "text": "I have an implant in my back.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 47,
      "text": "And so it was a long career but I also did a lot of other things.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 48,
      "text": "Since we mentioned ethical society earlier, I became very involved and created a committee of concern which concerned itself with older or sick members, people who were in need of some personal attention.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 49,
      "text": "I used to visit everybody in the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 50,
      "text": "We used to get groceries to people who came home from the hospitals or whatever was needed.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 51,
      "text": "And I established a taxi service for people who could no longer drive or were afraid to drive.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 52,
      "text": "It was also at night.",
      "word_count": 5
    }
  ],
