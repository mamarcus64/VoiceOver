  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And, and that is no-- it was a big, big for, for, for, for us-- for, for us in, in the America.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And the American Jews gave money.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And they build a beautiful hundred-bed hospital in--",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "In Mezritch.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And the-- there was a--",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It is-- oh, it was 118,000 Jews for this there.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It is very Jewish city.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Mezrich was very Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "There-- with a special industry in the-- in the-- in the-- oh, it was a-- they were the, the only who, who did it.",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Up to 1st of September, '39.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I was right away called into the army.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And on the 1st of September, I was already wearing the-- I was an officer, doctor in the Polish Army.",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Two days later, I was sent to the-- to the front.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Not-- to the west.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We, we didn't-- when they, they-- we waited for catastrophe, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We went, you know-- I was a doctor attached to a you call the-- we call it the division.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But you guys say battalion of artillery, just artillery.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Just disregard.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I was also trained as a-- as a doctor-- as a doctor-- military doctor, and a military doctor on their outpost.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "That is the-- it is basically evaluate, can you keep?",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "To send, where to send, to, to field hospital, maybe to, to field hospital?",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I-- I decided what to do-- what to do with this-- with this--",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Emergency medicine, correct.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Romantic life at that time-- at 30, it was basically better to say 30 years, 32, 31.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] A friend who was with me in medical school-- he was one year younger, Dereczinski-- asked me to come to Vienna.",
      "word_count": 25
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "He want to introduce me to his sister.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "She was already a doctor, graduated recently, recently in Italy.",
      "word_count": 10
    }
  ],
