{
  "stem": "21731.6",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So where we were now?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "What did I say?",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No I go to Bregenz.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I leave Yan and the [NON-ENGLISH] in [NON-ENGLISH] and go to Bregenz for a job.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I went to Bregenz, to the Polish Red Cross, looking for a job.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And was offered to take children, orphans, mainly orphans, to Italy, to a camp for displaced persons.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I was very happy about this job, because I was also told that there is a Polish school where Yan could go, a high school.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I was very keen of Yan having some education.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I still look for my husband, but after a week or two, the transport went off.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I don't know how many days we travelled, but it was not too bad.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "It was summer.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And we arrived in Barletta, where I left the children and Mr. and Mrs.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And I went on with Yan to Trani.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "He went to his boarding school.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And I went to the office in the Red Cross.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "The next day, I took Yan to the hospital, to the Polish hospital, because he was very short-sighted.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And during the war, he couldn't wear glasses.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "Because it made him looking more Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I met there a doctor, I knew from Lvov, a specialist, who looked at me like coming from the other world.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Asked, how did you survive?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And where is your husband?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I say, well, never, how I survived.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I don't know where my husband is.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I looked for him everywhere.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And I knew he was in England.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "This doctor knew that he was an X-ray specialist.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "So he said, well, we have here an X-ray specialist.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Corbin Koronowski, Corbin Koronowski And he came just back from England.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Perhaps he knows something about your husband.",
      "word_count": 7
    }
  ],
