{
  "stem": "5371.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I took a little bit and I threw it over the fence from the other side of the window into the snow.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And the guy, my guy went into the barrack, and we had to be very careful from our own people too.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So we buried it in a-- into a chimney, we like dug out the-- in between the bricks, the cement.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We took out a couple bricks and we put it into the-- into the chimney.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And the next morning they turned over the whole campus looking for the food, because they were so limited food already.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They were beating people [INAUDIBLE] but nobody knew.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "So anyway, we-- they put us up on a march.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "We were walking for a few days without any food.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Some people were dying, you know, because they were falling back and they were shooting [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "One man, I remember an older man I was carrying.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "We were like six guys which we were kept together.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "So we made up-- you know, we made up our mind, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Whoever's going to stay behind, we're going to bring them to the front, and we're going to go back and forth.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "But one man I remember was an older man.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "I carried him literally on my shoulder, because he couldn't walk anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "To the front a few times, but then at the end, he was shot.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "An old German SS shot him.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And they let him lay there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And then the same evening, we came to a farm.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And there were American prisoners of war in that farm already, too.",
      "word_count": 12
    }
  ],
