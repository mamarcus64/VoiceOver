  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 1,
      "text": "We don't know where they took them.",
      "word_count": 7
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 2,
      "text": "But all those people that run away from the place when they were taking them said they got killed.",
      "word_count": 19
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "During the Nazis.",
      "word_count": 3
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Not in particular, but she knew it's very bad.",
      "word_count": 9
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "I mean, people started to know that Hitler is killing Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "Well, [PAUSES FOR 3 SECONDS] I hoped to.",
      "word_count": 8
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Yes.",
      "word_count": 2
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 1,
      "text": "Not in particular, no.",
      "word_count": 4
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 0,
      "text": "Those songs didn't survive.",
      "word_count": 4
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 1,
      "text": "But then we came back from the woods, my diary was left in my house.",
      "word_count": 15
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I found my diary.",
      "word_count": 8
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't have it.",
      "word_count": 5
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 1,
      "text": "But I had it then.",
      "word_count": 5
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "Empty.",
      "word_count": 1
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "Everything was taken out of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "The Nazis.",
      "word_count": 2
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "Well, before we run away, we give a lot our goods to the-- to the farmers.",
      "word_count": 16
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 1,
      "text": "And later after the war, they gave us all back, all kinds of linen and clothes.",
      "word_count": 16
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
