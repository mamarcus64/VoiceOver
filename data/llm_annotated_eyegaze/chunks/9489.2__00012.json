  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 13,
      "text": "But he come.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 14,
      "text": "He Told me he's Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 15,
      "text": "Why are you new in the office, Eizenstein.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 16,
      "text": "And it was very good.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 17,
      "text": "But then I took in the paper one evening, and I saw they liberate my town.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 18,
      "text": "So I went into the army, and I says, I want to volunteer.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 19,
      "text": "And they say, first thing, you're too young, and second, we got passport-- our passport was with red-- not red, pink.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 20,
      "text": "Pink stripe, in the middle of the passport.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 21,
      "text": "All the pages.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 22,
      "text": "That mainly they can mobilize us.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 23,
      "text": "You know, if they catch us in the city or there, the-- you know, the police-- army police, you know-- I come [INAUDIBLE] you don't go.",
      "word_count": 26
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 24,
      "text": "That was our password, you know, with a pink slip-- pink.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "So on one day, another day they didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "So I says, you know what, excuse me, you know, I'm going myself.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "I took off.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And we'll continue.",
      "word_count": 3
    }
  ],
