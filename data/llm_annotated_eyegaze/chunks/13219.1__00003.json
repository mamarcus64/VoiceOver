{
  "stem": "13219.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Up to nine, 10 grades-- nine grades or 10 grades, I think.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We had, we had recess in school.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "We used to play football, whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And after school, we used to have get togethers with kids and play.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I didn't see anything between the children.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "But we were on guard always, special before Easter.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We had to be on guard.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Because they have the, the services.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And they take out all the-- they carry all the plaques from the, from the goddess, from them.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And, and they told us not to go out on the street at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "The icons, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "My parents, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Because it could be arrest.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You know, arrest some people.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "They, they tried to [PAUSES FOR 4 SECONDS] start fights.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "But as far as I know, we, we didn't go out.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And till 1939, we-- I don't think it was too much anti-Semitism.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "It was anti-Semitism [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "But I didn't know about it, because I was young.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yeah",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, my dad was religious.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "He wasn't pious.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "I mean, he didn't wear-- he wore tzitzits every day.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "I mean, I know.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "But there was more religious-- the rabbi and his, his followers were much more religious than my father.",
      "word_count": 18
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "My mother was religious, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "My mother came from a rabbinical family.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "She was from Sarny.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "I never met any grandparents.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "When I was born, my grandparents were already died.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "The only one we had is my mother's sister who lived in [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And I know that my. my father's sister lived with us.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And my father's brother and sister lived in America.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "They went, I think, in 1918.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Well, they went to America.",
      "word_count": 5
    }
  ],
