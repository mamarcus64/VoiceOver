{
  "stem": "19111.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, they knew quite a bit, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "But not-- we didn't communicate with them in Yiddish.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We usually spoke in Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But they understood quite a bit.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And they knew a lot of the language, especially when it came to holidays and cooking certain-- to prepare certain meals and all that.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "They knew all about the Yiddish traditions.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father, he was a-- he was not very Orthodox, although we had a kosher home.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And we had a-- we attended the synagogue many times on Saturdays.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And also on all the holidays, we always went to the synagogue.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "He belonged to a synagogue which was actually supported by all the furriers of the town.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And so not only was there a jovial time of celebrating the holiday, but it is also a-- a gathering place.",
      "word_count": 21
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And that they would see their friends from the fur industry and have discussions.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And it was a very nice way of seeing each other at holidays.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "My mother used to light the candles at Friday, Friday nights.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And even the housemaid also helped with it.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "She used to set it all up for us.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And we were all together, including the housemaid.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And many times the governess, she would join us and celebrate Friday nights and the special Friday night dinners.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Many times.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Many times.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "My mother especially enjoyed to entertain.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And they had friends, especially, also the relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "My mother had three sisters and my father had a brother and a sister.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And they all-- most of them had their own families.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And the intermingling and used to go to each other houses and spend many times together.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I loved my cousins.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "We used to play games together.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And it was one big, happy family.",
      "word_count": 7
    }
  ],
