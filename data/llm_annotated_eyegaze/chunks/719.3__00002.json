  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 47,
      "text": "Somebody left something for me to help.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 48,
      "text": "Now, every little bit helped later on, when the-- when times got worse.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 49,
      "text": "Because I wasn't as skinny yet.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 50,
      "text": "And I'm not being when they did check us.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 51,
      "text": "They checked.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 52,
      "text": "They disrobed the girls, stand in the line, and see how-- how you look.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 53,
      "text": "If you were able to exist, you weren't totally like a stick, like, then you were OK.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 54,
      "text": "And in our camp were a lot of young people.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 55,
      "text": "Lot of young women.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 56,
      "text": "The oldest maybe was in the late 20s, the oldest.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 57,
      "text": "And this was-- this production was very precise to them.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 58,
      "text": "Because nobody tried not to-- not to behave, just to survive.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 59,
      "text": "For the extended, I remember going to work.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 60,
      "text": "It was quite a ways.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 61,
      "text": "And we had to-- oh, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 62,
      "text": "Later on, somebody came up with an in their-- their-- they were worried how to make our life more miserable, or trying to.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Forget the shift.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We are not going to meet anyone.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We're going to work the worst shift in the world, from 3:00 PM till 3:00 AM, or from 3:00 AM to 3:00 PM.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Can you believe it?",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "That's not a day and it's not a night.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "That's the way they want work choice.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "So working pitch dark.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And this is in the mountains.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I have this postcard.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "It's in the mountains.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "It's cold.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "It's snowing in the winter.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Its in Czechoslovakia, and it's very-- it's beautiful there for vacation, but it's very, very cold.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "Very-- the air is very sharp there.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "So working, I remember behind me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "I wish I would know where these women are or who they are.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "Straighten up.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "Walk straight.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Walk straight.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "Don't give in.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "Don't give in.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Voices.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "It meant so much.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "You know, you just drop your bundle.",
      "word_count": 7
