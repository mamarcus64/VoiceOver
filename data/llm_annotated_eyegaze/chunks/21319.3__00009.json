{
  "stem": "21319.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "So she jumped ahead of me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And then I-- I threw my baby to that Nazi, to that guard.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "Like that.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And I jumped.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And he closed the door.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And I put my baby on my neck, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And the first thing he said, where's the money?",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So I gave him my money, and I left with me like 1,000 rubles or something.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "The rest, I gave him.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I gave everything.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And I put the baby on my neck, and I was crawling under the rails, you know, because there were like three, four rails, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And this was like Siberia.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "I called it Estonia Siberia.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "It was nothing, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "Open space.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "We crawled through like that.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And the woman was next to me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And it was pitch dark, OK?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And with the last train, we were hiding right under.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "All of a sudden, we-- we saw lights, lights, light.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "See, he got my money, and then he called his friends and they were planning to get us back and kill us, you see.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "He didn't want any witnesses.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "But he couldn't find me and the baby in that moment.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "They were looking all under the trains, you know, all over.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "But we on the last one with the four-- four rails, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They're looking, looking, looking.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't find it.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "It was pitch dark, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "It was like 2:00, probably, in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And-- and it was late in the fall because it was open space.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "So after they left, we crawled out and we start walking.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And it was start to get light.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Was probably 4, 5 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "And here were coming Nazis, generals, with-- with-- with Estonian officers, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "They were walking to their office.",
      "word_count": 6
    }
  ],
