  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know where she was.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "So a boy in the OSE, in the home, the youth home, he had an uncle in New York.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And he remembered the address-- not exactly the address, but he remembered that he is from the larger group in Paris-- in New York.",
      "word_count": 24
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Did I say Paris?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Not Paris, in New York, In New York, they have groups from society, from every city in Poland.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So he wrote to his uncle, he was from Lodz.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And he asked if they have an organization from [?",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Gradna, ?] and my name, and my uncle's name, and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And so a months passed by, and I get a phone call from a lady.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He said in Russian to me, [RUSSIAN] is that you?",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "I said, Mom?",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "How did you found me?",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "Oh, she said, somebody told your uncle in New York that you are in Paris.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And he wrote, telegraphed, to his brother in Leningrad.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And his brother in Leningrad had the address of grandma, of my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And my mother phoned me right away.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I phoned you.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "She was in Nancy, and she was married.",
      "word_count": 8
    }
  ],
