  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Before Passover, that week, they had to redo it all the kitchenwares.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] And to clean all the house nobody [INAUDIBLE] in the house.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Carry the matzohs in a special container.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And they used to do over there [PAUSES FOR 3 SECONDS] fish, the carp, at the time.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Because I think it was at the time the carp was big enough and very, very delicious.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And then they used to-- to do meatballs of spinach or [PAUSES FOR 4 SECONDS] some other kinds, many, many, many other kinds.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "But was everything else Passover-- kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "We were not kosher at home.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "But at that time, everything was kosher.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Everything my mother cooked I still remember.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Like I said before, there were poor people, very poor people.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Because they were living in their community, the Jewish community homes.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And they used to call them Baron Hirsch.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They were worse than the ghetto after that.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "The Germans made a gate over there.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "From there they were [INAUDIBLE], because was right at the train station, that neighborhood.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "But they had everybody-- they used to have a very good time, especially when the girls were getting married, big parties.",
      "word_count": 21
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] When the-- when the children was born, very good parties.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Poor, but a lot of fun.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "A large what?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Was a brand new, almost brand new.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "A very big one, that was in Baron Hirsch only.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Because we had some other synagogues all over Thessaloniki.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "The way I know is a kind of a Baron Hirsch.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Name was a person, a rich person, called him Baron Hirsch.",
      "word_count": 11
    }
  ],
