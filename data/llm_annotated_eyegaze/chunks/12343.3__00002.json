  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Men like this, on the fields.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "For them, for the Gestapo.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Not for the whole of them, just for the Gestapo and Poland men.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "He can help a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "One man can help you.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, Gestapo names.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Who'd name the name?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Well, I'll name the name, Ukrainian, Ukrainian.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He can talk Polish, everything.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Pole.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "To Sulejow?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They took us with the train.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I don't know, maybe a day.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how long.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember this very long.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "In summertime.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "It was summertime.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Before, when they close off the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "When they took us, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Before this must be maybe, in '44, beginning '44, maybe. '44.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no good.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "You used to sleep in a barn.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "That's total, a barn, is total.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "You sleep, that's it.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Oh, food, food, bad food.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The food they  give you, just so you can work.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Not you can work.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "You got no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "You work.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "You have to work.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Give me no food, that's it.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Don't ask questions with the food.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "They never give you enough.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "Never enough.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "This is the truth.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Everybody's going to tell you the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "They don't give you, never enough.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Until they finish this.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Than they send me from Sulejow.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "From Sulejow they went to Buchenwald.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "No, no, from Sulejow, to Tschenstochau.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "To Tschenstochau.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I didn't find out nothing until they took  me there.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I don't know where they send me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Every place they just put on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You never know where you go.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "With the train, they take me there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Oh no, I can never-- You think I pay attention, how long they take me?",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Other people, they tell you the date?",
      "word_count": 7
