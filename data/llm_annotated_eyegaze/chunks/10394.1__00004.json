{
  "stem": "10394.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I got my brother-- the oldest brother was in ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "This time, the ghetto was closed.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "You can't go-- not go-- not in, not out.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "All the Jewish people in one place-- it was a big place, you know, the-- not so big, but all the Jewish people was in the one place.",
      "word_count": 28
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I says-- and the guy says, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "If you give me 3,000 zloty-- not dollars-- 3,000 zloty, I take her to Krakow.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "When you got to Krakow with me, I don't know you-- nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "You-- you go first, or I go first, and you go behind.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "It was 40 kilometers to Krakow from this village.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "So my father says, I have $20 I can give you-- no more.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "I don't have any more.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "So he says, no.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "I wanted 3,000 zlotys.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "The $20 he doesn't want.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So my father gives him the 3,000 zloty, and he went with me.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "But I was afraid, you know, that the German they go in and back-- they recognize me or not.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "So I take something, a piece of bread, another [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how-- on the back-- and-- and milk.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I put a-- a scarf like this.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Nobody recognized me.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "But I couldn't walk so many kilometers.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "You know, I says, I got like this.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "I says, you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "Maybe we take the-- it was a tram by in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "He said-- I says, I can't walk anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "He says, what?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "You crazy?",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "If somebody recognize you-- and this was true.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "And I said, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "[NON-ENGLISH] was at the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 16,
      "text": "The [NON-ENGLISH] was like here, sometimes here.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 17,
      "text": "Sometime you need a [NON-ENGLISH] another wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 18,
      "text": "A [NON-ENGLISH] is a horse.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a horse.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And a carriage.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And a-- yeah.",
      "word_count": 3
    }
  ],
