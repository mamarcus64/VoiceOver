{
  "stem": "9908.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "They clothed us from head to toe, even a house coat.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "The Joint is one of the beautiful Jewish organization.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "They-- in Bamberg, they announced who wants tallis, who wants [? tefillin? ?]",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "My husband, I still got him here.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "My son brought it.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "A tallis-- I made them a tallis [INAUDIBLE] from-- from velvet of black.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We have it and the [? tefillin, ?] from-- they gave us.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "The Yiddish cart, you want to do whatever you want.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You want [NON-ENGLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We have [NON-ENGLISH] too.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH], you want everything.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Start-- a lot of Juden start going back to-- to that old life, to the religious life, to eat kosher.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We are [INAUDIBLE] when we arrived in-- in New York, and we called our uncle, we couldn't call him right away because we couldn't speak English.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So my husband-- [PAUSES FOR 4 SECONDS] my husband went down to the lobby in the hotel.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "He found a gentleman fellow, a rich fellow, and he called my uncle.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And Uncle right away replied to our hotel room.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And he said, I'm coming.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "He-- my husband said, we are going to Rochester, New York.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Just for New York.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And we come there and said OK.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And we said a little bit.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "So we came into Rochester, New York.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "The Joint Distribution, there's a place where to live.",
      "word_count": 9
    }
  ],
