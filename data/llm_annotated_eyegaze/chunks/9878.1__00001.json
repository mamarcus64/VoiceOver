{
  "stem": "9878.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "We even had beaches to go on the beach to go swimming summertime.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "The Jewish kids went swimming in a different section of the-- of the beach, and the Gentile kids went to swim in their own section of the beach.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "We were not segregated, but we kept to our-- to ourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And the life was very, very pleasant.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "Poor-- we were very poor.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "But when we were young, we did not know what-- how poor it was.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "But we were very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My family consists of father and mother.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And we had-- they have six children.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I was the third child.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The first was Ruchel.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She was born in, in 1920.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My, my older brother was Liezer, he was born in 1923 or '24, I don't-- I don't remember it now so well.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Maybe '24, because he was only-- nearly two years older than me.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And I was third child.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "Then was another girl, Maya.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "She was-- when the time when they were-- killed her, she was probably 12 years old.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "There was a little brother, Abraham.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "He was 10.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And there, a little, small brother-- blond little boy, David.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "He was five years old.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father worked in a brewery as electrical engineer, electrician.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Engineering-- he worked in the engineering department as electrician.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And he worked in the brewery many, many years.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He worked since the First World War, yet.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "There were two breweries.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "One was brewery by a Czech.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The name was a-- was a, a Czechish brewery.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And the brewery my father worked was a Jewish brewery by the [?",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Schneider ?] brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They were the owners of the brewery.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "They-- we lived in [NON-ENGLISH], in the part of the city which was adjacent, not far from the brewery.",
      "word_count": 19
    }
  ],
