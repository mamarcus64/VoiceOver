{
  "stem": "23579.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "So wherever they could find a place, he went to this.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "After when the German went further, going to Moscow, they went out.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "But they were already soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "They know how to fight.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "We didn't fight like soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't fight like soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have the education.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We were fighting from behind.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "We were fighting behind the trees.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't fight the army, the German.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "They could fight.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "They could fight.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "They were fighting.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "But we could not.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "We were staying in a place till here in puszta, in water and in [PAUSES FOR 4 SECONDS] [NON-ENGLISH].",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "What is [NON-ENGLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "Mud?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Mud!",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We were staying till here, a whole week.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And then we heard the German talking.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And they were shooting over us.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "They were so near us, over us, but they couldn't go into the mud.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That you weren't got out, to the mud.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Even didn't believe that we can stay in the mud.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "We stayed because all day to here to mud, hungry!",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "When they went away, the German, we went out from the mud.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "We tried to clean up.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And then Zusia by himself said, whoever wants to go out from here, come with me.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "I'm not staying.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "He couldn't take the hunger.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "I'm not staying here.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "I'm going out from the puszta.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "And who wants to go with me, let's go.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "And he took about 100 to 90 people, young.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And he took me.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "And we went after the German.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "And this was the beginning that we went out from the puszta.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "After the German went to the front.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They took off, but our yearn is to fight the partisans in the puszta,",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We went over the [NON-ENGLISH], from the puszta to our places in the forest near Novogrudok, Lida, and like that.",
      "word_count": 20
    }
  ],
