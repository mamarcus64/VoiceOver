  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And he saved many, many, many, many other lives.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And when we came to Warsaw, we found out that they lived in Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "They took us in.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "I mean, they, they were just so gracious.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And he had some very, very tight connections with the government.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And he says, well, if you want a job with the new government, Polish government, which was patronized by the communists-- he was a leftist.",
      "word_count": 25
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And sure enough, I got a job in the-- in the Department of Education.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "And I stayed there for a short time until I found a way to go to the Displaced Persons camp.",
      "word_count": 20
    }
  ],
