  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "And you see, now you can go and go to Australian customers, because we have to support people who can't speak English.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "And that was a very good tip.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "[LAUGHS] You see, and then I spent some nine years, and I bought-- that means paid key money for a bigger factory, and I employed 12 girls, and my wife was helping me, you see, in the checking up, and invoicing, and so on.",
      "word_count": 44
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "And then a lot of competition came, and we were sick of it, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "And I sold this, decided to sell the factory and go into sort of a business shop or something.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, In the meantime, I got-- I wrote to my brother, and he said, look, I didn't want to disturb you while you were making a living in Australia, but now when you sold one business and look for another, why don't you come to Brazil?",
      "word_count": 46
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So I packed up.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I went to Brazil, you know, with the little money I had.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I had a very bad impression.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I say, that means first of all, we had a very bad journey, because at that time, Lola, they had the baby.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Sorry, say that again.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "We already had a daughter, Ann.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Ann.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "She was born on the 15th of October in 1950.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And we packed up everything, and she was sick on board ship.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We took a ship to Naples, and she was sick on board, and then we had to stop in Italy to Genoa, [PAUSES FOR 3 SECONDS] and we went to [?",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Navi ?], you see, for her to have a rest.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And then Genoa, we boarded a ship, the Augustus, we boarded to go to Santos.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And you see, she was, again, sick, you see.",
      "word_count": 13
    }
  ],
