{
  "stem": "5644.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "And they been walking in the back of the, of the column and giving signals in the nighttime.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Because we been mostly walking in the night.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "In the day, we used to hide in some of the forest or something which you could hide the whole groups.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "Hundreds of people who marched-- and army, too, lot of the army, all in trucks or in train or just walking.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "So they caught them and they-- they caught them seeing that they're giving signals in the nighttime.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "Because always in the morning, we're being attacked by planes.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "You were strafed by planes.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Immediately in the morning-- 5:00, 6:00 in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Was a little bit light, immediately the planes came in very low over us and attacking with everything, even with bundles of grenades.",
      "word_count": 23
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "With bundles of grenades from the top, from the airplane.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that took me, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "It's hard to remember now-- quite a few days.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We been marching about 30 to 40 kilometers a day.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Once we got there, I got to Kowel.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I been there.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Then I went to Vilna and then back from Vilna to Kowel and back to Bialystock and home.",
      "word_count": 18
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Because I been told that my mother is very, very ill by some people which came later, friends of mine.",
      "word_count": 20
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And I'd been told [? that dying. ?] I went to a place which was called [INAUDIBLE] and Bartosze in Poland, not far from the border, which was then the border of the Russians with the Germans.",
      "word_count": 37
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "I found there some people which I been told about in Warsaw if I will pass through there to see them.",
      "word_count": 21
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "And so the people start to think of a little organization, of a little partisan organization.",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 7,
      "text": "But unfortunately, didn't work long.",
      "word_count": 5
    }
  ],
