{
  "stem": "25639.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, I had a beautiful doll, which I received from America.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And that was-- it had a porcelain face, and nobody saw a beautiful doll like that in our little town.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, from, from the United States, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "From my relatives.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "My mother's brother and two sisters, Bella?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Lena?",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Ah, two sisters came to the United States before World War I.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My-- the oldest sister was Berta, or we called her Bella and then Lena, and then came my mother's brother, Adolf, and my mother was the youngest.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So there were--",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I do.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My Aunt Bell was born Gelb, and she became Yagoda.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And her last married name was Smith.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And my aunt Lena, who lived in New York, was born Gelb, and she be-- I'm sorry.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "She was born Gelb.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And she became Parness when she married Uncle Louis.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And Uncle Adolf was born Gelb, and he changed his name to Gero.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "G-E-R-O.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "It's an O with two commas on top.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And he, he lived in Budapest, at first.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "He studied there, and then he came to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "He was an orthopedic shoe specialist, and he did work for disabled people throughout the country.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We corresponded through the mail.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I remembered their addresses by heart, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So, it, it-- later I would like to explain the connection, how important this became to me.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had a doll and a little carriage that they sent me.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And I remember so proudly pushing the little carriage around and sleeping with the doll and combing her hair.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I also joined a, a small group, and we put on little plays.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] It was nothing sophisticated, I assure you.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I can't even remember some of the plays.",
      "word_count": 8
    }
  ],
