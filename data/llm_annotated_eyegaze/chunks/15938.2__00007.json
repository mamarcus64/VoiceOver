{
  "stem": "15938.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "She was born in a place called Zenta.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "But when she was about two, her father died.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So my grandmother went back to Hungary to her original birth place.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And she-- she had a brother living there, my grandmother.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And they had three children.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So my grandmother moved-- moved in with this family, this is-- her brother.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was brought up with these three other children.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And that's where she got married from.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "She always-- my grandmother never remarried.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "That was the place where I used to go every summer for four or five weeks.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "She was a well-to-do lady.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "She had a lot of property and land and spoiled me rotten.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Used to have a private tutor for the summer, and all my clothes were made there.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "My mother was the only daughter, and I was the only granddaughter obviously because-- and she was a very, very, very loving grandmother.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Pearl Pollack, but her maiden name was Klein.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And she used to come to us, I think, three or four times a year.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And every week, I used to get the long letters.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Every Thursday there was a parcel from her because she lived in Hungary where food was in abundance.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And in our place in the winter, food wasn't-- it was shortage of-- because of the cold, the climate.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Every Thursday, we used to go to the station to get these big crate of food she used to send us.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "She used to write a letter for every Shabbos.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I never remember a letter ever-- there was a ribbon in it or a little handkerchief in it or, you know, a very, very sweet old-- old lady.",
      "word_count": 29
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "I mean, she was younger than me.",
      "word_count": 7
    }
  ],
