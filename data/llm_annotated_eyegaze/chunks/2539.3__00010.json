{
  "stem": "2539.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So we did-- not three semesters a year.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We did four or five semesters a year.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Because they need the doctors for the army.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So they were training us nonstop.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So in two years, two and a 1/2 years, I did three years of medicine.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "In two and a 1/2 years, I did three years of medicine, because I left in July-- in June '46.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And I started-- I finished school early '44.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "So I had two-- just over two years and did three years.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "But I had to-- three years of medicine in two and 1/2-- just over two years-- not only I, everybody else did too.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I have-- anyway, when I came to Vienna, I had to repeat all the exams.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "I remember I had to-- I came to Vienna with this cousin of mine, right?",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "We're on the train.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And some girls found out-- there were other people on the train.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We were walking through the border same-- in-officially, but in-officially.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But the fellow on the Czech/Polish border, Polish/Czech border, said to me, oh.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "You should stay in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "You're such a pretty girl.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "You should stay in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You shouldn't go away.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "You shouldn't leave Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "They knew.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "They was-- they were escorting us.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "It was approved by the government, that whoever wanted to leave can leave.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Anyway, we didn't stay in Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "We had to pass by train, Czechoslovakia-- finished up in Vienna.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And there were people on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "There were a few Jews on the train.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I don't know who they were.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I can't remember who they were.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I don't know who they were.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But they got in touch with some-- maybe I asked them?",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    }
  ],
