  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So I said to him, are you Jewish?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "So, with a nice way, not, are you Jewish?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Are you Jewish?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "So he, right away, understood that-- that-- I-- I'm part of him.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "So he said to me, I am not Jewish, and you are not Jewish.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And don't you ever talk to me again.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I-- I just-- because feeling this-- the closeness from-- from like, one of mine, and he had the same thing.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So every time I saw that the garbage man is coming over, I just didn't go down.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I just stayed away.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Exactly.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Exactly.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He understood right away that I am Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So he said, I am not Jewish, and you are not Jewish, he said.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And don't you see me anymore again.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I had-- I had food, I had a shelter, I had clean-- I was clean.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I was-- I lived a normal life.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I just knew that I am Jewish, and whatever I lost-- my family, my close family-- and-- and I knew where they are.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But the garbage man didn't have anything to do with it.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, I knew.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I knew.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My mother, my-- my sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But my father--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "--I just-- I had a hope that he is alive.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Because I left him alive.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So I had a hope that he's alive.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "But he was-- We just got to know how my father was killed a couple years ago.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Till now [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "We knew that he's not-- he's not there.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "We knew that if my father will be alive, he would get to know himself through my uncle in the United States.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "But we didn't know exact.",
      "word_count": 5
    }
  ],
