{
  "stem": "1249.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And I took-- I found her in the latrine.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "You know what is latrine.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And they were sitting in latrine-- is men and women next to each other.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And there was two side-- men, women, men, whichever, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And right behind them-- again, it was not separate for women and men.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And she came out.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I said, I brought you something.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "You have to eat.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "She said, I can't eat.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "I'm so sick.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I can't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I have diarrhea.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I said, this will help you.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "This will help you.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "You have to.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "You have to get well.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "We are going to see our mother and grandfather.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "We'll get out of here.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "She ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And somehow, God helped her and helped me.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "She get better.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So after four weeks, they took us to Augsburg-- no, excuse me.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We were with a couple people whom we knew from Hungary.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "In, in Auschwitz, in the barracks where you were, where there are other girls there from your hometown at that time?",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We-- the-- Auschwitz, from the beginning were two sisters who lived in Miskolc.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "They are not from the same city.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But they moved there and rented from my mother one room.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "We had two rooms.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And one room-- and we were-- they-- one room, four of us.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And other room, we rented for.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And they were very nice girls, and older than we were.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They were in their 20s.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And my mother said, [?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Doris-- ?] this was one of the girl name-- if something happen to, to me, please, take care of our-- take care of my children.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Take care of them.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And she was very nice, very good.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 12,
      "text": "We were together.",
      "word_count": 3
    }
  ],
