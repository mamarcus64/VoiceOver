{
  "stem": "3835.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I started to travel to Warsaw when I was 19 years.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "My father was happy to send me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He shouldn't travel.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "It was tiresome for him.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And he gave me a bundle of money.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I put it in my-- on my body, a bundle of money.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And he gave me notes.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And naturally, I made a list which manufactures to visit.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And I knew-- I started to know, almost better than him, the colors and qualities and styling of-- we carried sweaters.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "We carried men's shirts, very big neckties, socks.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "So I understood-- I understood the-- this line very well.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And he was happy to see that I am doing well.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And thanks to this, I did it till-- till today, till I came to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Number one, we had a Polish paper, which is called Nasz Przeglad.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "This was a beautiful Zionist paper-- very, very high level, like the Israeli-- Israel has an English paper, the Jerusalem Post.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "This is the type of paper.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We had the Polish, naturally.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Naturally, we took interest in the Sejm senate, which is congress and-- congress and senate, which we had in Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "We called Sejm.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "We had-- we saw to it we should have Zionist members, congressmen, which was a very famous Yitzhak Gruenbaum, one of the famous Zionist congress.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Naturally, the ultra religious had also their people in congress and in senate.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "They had a senator also, a Jewish senator.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "Very few, but we had some representation.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure we followed-- we followed the events in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We had already radio, before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "This was the last years before the war, radio came to Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And we had newspaper, Jewish newspapers, which my father had every day.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "It's called the Haynt, a Zionist newspaper.",
      "word_count": 7
    }
  ],
