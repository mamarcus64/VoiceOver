    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I already had a bra, which was a big deal.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "My hair grew back.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "You know, so we looked human.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And we stayed in Czechoslovakia a few days.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And then we smuggled into the-- ironically, into Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And the reason that we went to Germany was that the Americans were there.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And the Americans let us pass.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "They kind of pretended they did not see us.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And we went to a small town in Germany-- Hoff an der Saale.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And, uh--",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
  ],
