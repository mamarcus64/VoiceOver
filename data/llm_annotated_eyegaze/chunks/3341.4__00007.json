  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "It was maybe 5 o'clock in the afternoon, it was already dark.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And I-- there was a very small village.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And I found out that little house, there was the poorest house in the village, because they were very poor.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And I knocked on the door and collapsed.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I had the paper in my hand what he wrote.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I gave it to the man.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "And I can't remember, I was in a daze.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "They have seen and he read the message from his son.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "Because you know, the poor peasants, who have really nothing, and they have one son who lives in the big town and is educated and is a finance man, so they are very proud.",
      "word_count": 34
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "He's the god in the family.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "So they said, [?",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "Shanko-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "Shanko ?] is Alex.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "His name was Alex, the parents called him [?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "Shanko. ?] And they said, when Alex send him, when [SLOVAK] sends somebody here, of course we have to do the best.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "You see the primitive or simple people, peasants, they show a lot of love to somebody who needs it, especially if their family members sends him.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "So [?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "Shanko ?] sent me there.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "And the story was he, he rehearsed it with me.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 22,
      "text": "Tell them you are a student.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 23,
      "text": "You got very sick, I can't keep you here.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "How do you know me?",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He invented also that.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He said, you are a, a university student.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And you are very poor, because your parents are already in the occupied territory.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And I-- he was making it-- you know, the finance or gendarmes or-- they always have to, if they want to advance, they have to make a special exams, every half a year or maybe one.",
      "word_count": 36
    }
  ],
