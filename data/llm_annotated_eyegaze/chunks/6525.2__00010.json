  "sentences_input": [
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 5,
      "text": "And she said she needs 10 girls to take to another block to clean it up because a transport is just coming in in the morning, and she needs 10 girls to clean up this.",
      "word_count": 35
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 6,
      "text": "And the girls who were cleaning up, they were called [GERMAN].",
      "word_count": 11
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 7,
      "text": "And those [GERMAN] had a special treatment, but they were working.",
      "word_count": 11
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 8,
      "text": "They worked hard.",
      "word_count": 3
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 9,
      "text": "They cleaned up the block.",
      "word_count": 5
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 10,
      "text": "They brought the food from the kitchen, and they served the food.",
      "word_count": 12
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 11,
      "text": "So those girls had food.",
      "word_count": 5
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 12,
      "text": "And I told my friends, oh, we are going to be [GERMAN] now.",
      "word_count": 13
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 13,
      "text": "And we jumped down off the beds.",
      "word_count": 7
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 14,
      "text": "And the [GERMAN] came out, and she find us there.",
      "word_count": 10
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 15,
      "text": "And she took us over to this block, clean it up.",
      "word_count": 11
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 16,
      "text": "Because in a while, a transport-- a new transport is coming in with a few hundred girls.",
      "word_count": 17
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
