{
  "stem": "3757.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 28,
      "text": "I had a little-- a-- a little card, what let me use the sanatorium's vehicle to go to town.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 29,
      "text": "So they-- they don't know these Latin letters, so I showed sanatorium, and I am a nurse, I said.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 30,
      "text": "And the-- this was my-- Pass.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "--pass.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So, OK, they need somebody.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And they have a room.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And I have to hire some people who will clean the room.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And I have to serve them food.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I have to-- my job will be to sterilize little bottles, which I don't know what was in it.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "This I can do, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They told me, they have-- they have to put in it something and let it boil 10 minutes.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And this solved our whole family problem.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Because I told them, you will be the cleaning woman.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I-- [LAUGHS] I am the nurse.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And we will get food for it.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And we-- every day, we got a big-- a big pot of Russian soup, what is everything in it, cabbage and potato and onion and whatever you can image.",
      "word_count": 29
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And the evening, they had-- they call it cutlet, some-- like a hamburger kind of things.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "So they-- with a-- with a big-- big plate and some potato.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And they eat one.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And then they bite in another one.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "So what left, I put in a plate, and this was our dinner.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
