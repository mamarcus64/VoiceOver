{
  "stem": "740.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Put it in my pocket.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Went to another spot.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "There was somebody waiting there.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Picked it up, and that was it.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "No names.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "Basically, I found out it was the Belgian resistance.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "That's all I found out.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "Nothing else.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I knew that from the beginning.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Because he also mentioned, we work for the Belgian resistance.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "If you don't want to, you don't have to.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I said, no!",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Hey!",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "That's adventure!",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Little guy was-- adrenaline going.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And unfortunately, it didn't last too long.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I was so visible.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Every Tom, Dick, and Harry knew me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I was so blond.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "The SS-- the Flemish SS knew me from bars, from coffee houses and all that.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "In June of '42, I'm walking home, and I'm in the North Station.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "It's called the Gare du Nord.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And two Flemish SS men come toward me.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And I said to myself, uh-oh.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And one says, hi, little fella!",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I says, hi.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Aren't you Louis?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I mean, that wasn't my real name, but I'm using this name.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "He says, no?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Oh, come on, now.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Aren't you Jew?",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "I says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "We know your name is Posener.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And this went on for about two, three minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And then suddenly, I have a big fist on my nose.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And I'm starting to dribble blood out of my nose.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "I said, oh, Jesus.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "They will find out anyway.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "Why-- why kill me?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "So I agreed to whatever they said.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "They took me to what they call a hofbrauhaus-- one of their houses where all the military is-- into the basement.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I got a little solo box match, where they pummeled me up.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And they-- as a little guy.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "You know, I'm about five foot two.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "About 16.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I was just 16 two months.",
      "word_count": 6
    }
  ],
