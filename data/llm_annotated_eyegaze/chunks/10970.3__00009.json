  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Possibly, but the fact that they hadn't done a great impression in the beginning with him wasn't too convincing at the time.",
      "word_count": 22
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I was torn.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "But I really went along with him because I would-- probably had-- you know, I was just as insulted at the time.",
      "word_count": 22
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Happy.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "I was happy.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in control of my life, first time, [CRYING] where I could dictate how I want to live my life, yeah.",
      "word_count": 21
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And so in '57-- six months, I guess, later, until all the paperwork for the Army were completed for me-- we came to New York.",
      "word_count": 25
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Interesting experience.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, because it was the Hungarian Revolution.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And all the refugees were being flown to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "So we had to come by boat.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "And I crossed the ocean [PAUSES FOR 4 SECONDS] being seasick for 14 days.",
      "word_count": 14
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "You want to lose weight?",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "That's the way to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I do.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Yes, it was in April 7, 1957, Fort Hamilton, Brooklyn, New York.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] I think-- my first step into New York, and I'm in-- you know, in the United States-- and I land in Brooklyn.",
      "word_count": 23
    }
  ],
