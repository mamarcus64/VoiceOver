{
  "stem": "11723.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And the largest room downstairs, where we used to eat and where we had Christmas tree before, was totally emptied of furniture and everybody brought down their mattress and we were lying down on the floor with the mattresses on top of us so that if any of the bullets came through, it first had to go through a piece of furniture and then through the mattress.",
      "word_count": 67
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And my sister and I were under one mattress, and we were clutching one another.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And I was always afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I am such a chicken-hearted person.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I was always afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "My sister, she was too little to understand.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So this went on for many days, and we children were only allowed to go to the toilet.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Other than that, we were on the floor, under the mattress.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And of course nobody could go out shopping or anything, so we were running very low on food.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And by a certain time we only had flour left.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And at some point the women looked outside and she saw that the house was on fire.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And there we are, 100 kids inside the house.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "No sooner does she tell us, everybody up, the Nazis from to roof come downstairs and they are starved.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They are starved like animals.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And they tell the adults that nobody leaves here until we get food.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And we didn't have any.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So finally somehow one of the women negotiated with them that she will make from flour and water pancakes, but they have to let us go.",
      "word_count": 26
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And by that time the house was pretty much gone.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "The construction is different there.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "It was stone.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "It wasn't wood, but it was a horrible time.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "To this day I'm claustrophobic because of being trapped in a burning house.",
      "word_count": 13
    }
  ],
