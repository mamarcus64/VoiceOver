{
  "stem": "422.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Then my brothers-- they-- the one, they were very slim, skinny, from malnutrition.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They had to slip-- they slip through, children, fed the families.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Children slipped through opening in the-- in the wall and brought from the Aryan side a potato, some bread.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes they were shot by getting back.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Getting out or getting back.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Sometimes they managed, the ghetto people managed to bribe whatever they could.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "The-- the-- the gendarme, by the wall, who was watching-- they bribe him with money.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So he make believe that he don't see.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We couldn't buy outside the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The Polish people made a whole market, a whole business out of it.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They bribe the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They should let them bring in food to the ghetto, some food, for fantastic prices.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "They made a lot of money at this time.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Whoever could still afford to buy, bought.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Like a piece of bread for 100 zlotys, like a piece of butter for 100 zlotys.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "There were not many people that could afford these prices.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Who didn't have-- we died from malnutrition.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "In our-- in our backyard, where we lived, the-- the parents of three small children were caught in the street and sent away to Treblinka.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "In the house remained three little kids with no-- no care.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Three little children.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "We, the tenants, whatever we didn't have enough for us brought down something for these kids, too, that they should be able to survive.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "The children got left like this, yet we shared whatever we had, that little bit with them.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "Till they died, too.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "It was a time that people died, children and older people, like flies.",
      "word_count": 13
    }
  ],
