{
  "stem": "7781.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "So the other four brothers had all been trained as craftsmen.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, cabinetmakers.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And the girls.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "One was two years older, so she-- she was young, and-- but Chaya-- Helen-- she was a seamstress.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She was trained to be a seamstress.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My-- only my-- before the war, my sister got married, the older sister.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Helen got married.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And she had a boy.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yosel.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And she had a boy, I guess at the beginning of the war, or something like this.",
      "word_count": 17
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "He-- he-- the beginning of the war.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Right at the beginning, or the start of the war.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "In this period, I don't know exactly.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "She had a boy, that was the only nephew I had.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "Or grandchild.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "She had a child.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "She-- we all-- we all lived in Lodz.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "There were-- because-- you see, there was no-- very hard to get higher education for Jewish people in Poland.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "The schools-- the government schools-- they're limited, the amount of Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Very-- very limited.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "It was impossible to get into.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "So when a child-- we finished public school, which was seven years, you had to learn a trade.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "So you had lots of craftsmen.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So that was-- you had to go out in the world and learn so you would be able to sustain yourself.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "That's why you had-- you had lots of craftsmen, and very few people, none of my friends, went to-- to high school.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Because it was practically impossible.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "But you did go to Jewish school, you said.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "You want to cheder.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to cheder I went, which to learn about praying and, you know, learn the Jewish--",
      "word_count": 16
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "We learned how to-- it was one big room.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "It was mostly one-- all the Jewish men with the beard, traditional.",
      "word_count": 12
    }
  ],
