  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "And I try to [PAUSES FOR 3 SECONDS] explain to the people who listen to me what hatred, what prejudice, has done, when the whole world-- whole world stood by and did nothing and allowed innocent people to be slaughtered.",
      "word_count": 40
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "Nobody said anything.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "Everybody said there was nothing I could do.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "And that's a lie, because there is always something you can do.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I feel the survivors are all getting older.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And every day, there are fewer of us left.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Every day I hear of somebody who has passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "In a few more years, there'll be none of us left.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
