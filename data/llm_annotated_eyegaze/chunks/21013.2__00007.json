{
  "stem": "21013.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "But when we asked, would they bring my parents out?",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They didn't want to take the responsibility of older people, and they only wanted to do that for me.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, as it happened, I left for England in August '38.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My parents were left in Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "The visa to Cyprus never came through.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then I finally ended up in a foster home of people that were recommended by the Quakers.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And they eventually brought my parents out of Austria.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "They sent for them and they got them to be domestic servants in England.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "That was the only way that anybody could immigrate to England.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "You had to be a domestic servant.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't do any other kind of work.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And that's how my parents were saved.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And they came to England on the last train out of Austria.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Before the war, in 1939.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "August, August 15th.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Jaretzki.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Came to London.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And then I stayed in a boarding house where the Jewish Children's Refugee Committee paid for me to live in that boarding house, which was next door to where Sigmund Freud lived.",
      "word_count": 32
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I had a cousin who was born in England and lived in Austria and also fled.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "But because she was an British citizen, could get out right away.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And they lived in this part of London, in Swiss Cottage.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And her husband was a psychiatrist and had studied with Sigmund Freud and was a very close friend of Anna Freud.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So he introduced me.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And I saw him every day for the few weeks that I lived there when he took a walk on the arm of his daughter, Anna.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, he had a very bad problem with his tongue.",
      "word_count": 13
    }
  ],
