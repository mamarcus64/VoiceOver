{
  "stem": "182.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 207.7,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And she lives across the street from us.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Her name is Rosie Silverstein.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And her husband is Ron.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And they have-- Michal is the oldest-- Josh, Benjamin, and Joseph-- the four children.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And our son, if I may say-- and I don't know if it means a lot to somebody else, but to us it means a lot-- when he was a young man, it was the time of the-- of the Vietnam War.",
      "word_count": 42
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And he's a pacifist, a total pacifist.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And he opposed it.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And he was against it.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And he was rebelling against everything that had to do with the government.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "And he didn't live at home.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 14,
      "text": "And I worried.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "I worried only that he shouldn't be brainwashed and he shouldn't want to be something else than a Jew.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "And he was a very good boy.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 17,
      "text": "And he worried about everybody who didn't have-- or who had to go to war.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 18,
      "text": "And he lives in Santa Barbara.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 19,
      "text": "And there are not too many Jews there.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 20,
      "text": "And I worried.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 21,
      "text": "He's very handsome.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 22,
      "text": "And he's very good, that he should-- he should stay Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 23,
      "text": "And my mother passed away when she was 91.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 24,
      "text": "My mother and father, they both lived in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 25,
      "text": "She passed away when she was 91.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 26,
      "text": "And when I was sitting shiva, Allen our son, came home and was with me.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And before he went away-- went back to Santa Barbara, he says, what can I do?",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Can I do something for you, mother?",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I asked him, the only thing what I would ask you, that you should learn how to pray for an [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "You know, for-- the [NON-ENGLISH] is where a person stands when he prays with ten people.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And he went back to Santa Barbara.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And there is a Lubavitch rabbi.",
      "word_count": 6
    }
  ],
