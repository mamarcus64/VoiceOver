{
  "stem": "3804.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And she start also to laugh and said, what is all this stories about the Holocaust, about your sister, and all this?",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "What happened now?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "Where are you going?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I said, to Paris.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "She said, to Paris?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "You go to Paris?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "Never, never believed me.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I said, I tell you, I'm going to Paris.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I call you.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You know, I looked her in eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I said, you know, it's not easy to lie to a mother.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I said, but a Polish Jewish mother, forget it.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "You never lie to her.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "It's always-- they look at your eyes.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "You said, OK, OK, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "But remember, the refrigerator is full of food.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And don't go for long time and call me.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And every call I called her, she asked me, don't forget that the, the refrigerator is full of food.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I said, what do you think-- in, in Paris, they don't eat?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Oh, but like your food of your mother, you never can find.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So that's the story about recognizing better the Holocaust through my disguise to my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "You had, you had been in the, in the Mossad for quite a while.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "You were pretty much an operative.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "28 years.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "28 Years.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Operating, yes, most of my time.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I was-- in the end, I was the head of the operation, head of the operation in the Mossad.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, at the end, much more than the end-- a few years, about seven years.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Most of the time, I was only in operation.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I heard about it-- I would say I heard a lot of it, I think, even '45.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Because it was-- in our family, Eichmann wasn't known.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "This was not not a man that he was not known.",
      "word_count": 11
    }
  ],
