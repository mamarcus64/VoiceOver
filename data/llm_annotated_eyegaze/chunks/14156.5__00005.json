{
  "stem": "14156.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So they got me in.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They put me in.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And then they put me down in the-- in the cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And that's when they started to-- had-- they had a whole [INAUDIBLE] full of disinfectant-- some brown stuff-- I don't know-- whatever.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Everybody had to go in there.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And they scrubbed you here and there and out and gave you a towel.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Something you keep, you know, covered up.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And they put you on a-- on a stretcher.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And it took another day.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Finally, I ended up upstairs in a regular-- regular bedroom-- a regular room, with white pillows.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Never seen that-- I haven't seen that for, you know-- for years.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "White pillows, white sheets.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I said, oh my god.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And, as I turned around-- my hair was not cut, really.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "It was cut, but-- there was lice all over the pillow.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "So the doctor came, then, the next day and told me, listen to me.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "You're fine.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "You're OK.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "You only have diarrhea.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "But remember, everybody in this room has typhus.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "You better get out before you catch it.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So I did.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I walked away.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I walked in the street and had to go into a displaced-person camp.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't-- you know-- I was just not fit enough to say, now we are free!",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Let me go!",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Why do you have to be in a camp again?",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Enough camp!",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I ran away again.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Who-- who took you to the DP camp?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You walked to it?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I walked, and I think soldiers picked me up on the street--",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And took you to that--",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "--Americans, and put me there.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And then, and [INAUDIBLE] I was in there.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I-- I couldn't just-- I could not comprehend it.",
      "word_count": 9
    }
  ],
