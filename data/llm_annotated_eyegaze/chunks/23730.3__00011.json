  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "But it's so-- so typical how history is repeating itself.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We had another lageralteste, Moses from Warsaw, a fantastic man.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Fantastic man, also a Jewish prisoner.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "But somehow the Germans accepted him somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And he came warning us that we are going to leave from Wustegiersdorf shortly, save up a little food.",
      "word_count": 19
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We didn't believe him like Moshe Rabin when he went to [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They didn't believe [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They came.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And Moses, his name was Moses, he said save, and we didn't believe him, except my cousin Poshevy Lowy.",
      "word_count": 19
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "He saved up food.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And five minutes before he left, he put food in my pockets.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Hungarian.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I came with Poshevy Lowy from Budapest to Wustegiersdorf.",
      "word_count": 10
    }
  ],
