{
  "stem": "5740.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "There were-- they were knocking on every Jewish door, dragging out the Jews, putting them-- killing them on the street, or putting them in-- in some big orphanages, or some-- then from that, taking them to labor camp, to concentration camp.",
      "word_count": 41
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "There were thousands, thousands of them dying every-- every minute and every day.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "The Germans-- the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I was with my aunt.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And we were lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "They were knocking on our down.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And my aunt had a Ukrainian servant.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And the Ukrainian servant spoke Ukrainish to them.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "And they thought that they-- we don't-- nobody lives here-- of-- of Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "There's no Jews here.",
      "word_count": 4
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Antonia.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Antonia.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, at this-- at that particular-- because I got saved hundreds of times.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Then we had to move to the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "In Lwow.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember how.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "This is a blank, completely blank.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I know that I've been in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "How I got to the ghetto, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I was with my aunt, and with my uncle--",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--and with-- and with-- with her daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Her son got taken to the army by the Russian, you know, while we were under the Russian occupation.",
      "word_count": 19
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "He was at the right age to go to the army.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "We never heard from him anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have food to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have-- we had nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "My-- my uncle was quite well off.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "And he had some money-- some put away.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "And he could help a little bit of buying this and this.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "But I decided I go out of the ghetto looking for a-- for a job somewhere.",
      "word_count": 16
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "Maybe I can-- I can-- I didn't look Jewish.",
      "word_count": 9
    }
  ],
