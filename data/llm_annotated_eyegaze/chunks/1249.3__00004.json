{
  "stem": "1249.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "One man who was a older man-- older man, maybe 32 years old, I don't know.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "To me, then, was older.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And he grabbed me, and grabbed me up front.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "I didn't have nothing yet.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "I was flat.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Not even 15, no, 14 and a half or something, yeah.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And, and started to grab me.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I could not say anything, just [NON-ENGLISH SPEECH].",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "That's all I asked.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Please don't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, a German.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And, and look like he had a good time.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I hardly could get out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And you wouldn't believe it.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "My sister still doesn't know that either.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I'm still embarrassed to tell, like it would be my fault.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "That's why I was thinking about those people who are raped.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Some people may be asking for that.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "But believe me, I would not ask something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And I said again, dear God, just one more day.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "Maybe you can save me, save us one more day.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Maybe two more, we'll be-- we'll be free.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "That's how I, I went every day.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "Every day, I prayed.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And every day, I said, just one more day.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "Give us one more day.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And my sister was asking, what's happened?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I said, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I just went to the bathroom.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It's-- everything OK?",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Everything OK.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Now, he didn't actually rape you, did he?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He did not.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't, because it was in the open.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "If he did that, he would be in, in concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "When he saw somebody come-- coming, he had to let me go.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, he would be in trouble, because I was a Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And-- [PAUSES FOR 4 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "What else I wanted to ask about-- or tell about Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 7 SECONDS] I don't know.",
      "word_count": 7
    }
  ],
