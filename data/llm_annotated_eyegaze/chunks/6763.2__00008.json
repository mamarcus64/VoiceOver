{
  "stem": "6763.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And [PAUSES FOR 3 SECONDS] one of the-- a couple Ustases came and told us that there was a interesting incident going on and it would be very educational for all of us to see.",
      "word_count": 35
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And we witnessed a woman [PAUSES FOR 4 SECONDS] being gang-raped, [PAUSES FOR 6 SECONDS] the man watching and being beaten while he was watching.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] Men around laughing, and then being told, yelled at, something.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And they were digging a hole in the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "They were given shovels.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And [PAUSES FOR 4 SECONDS] when that task was completed, the man was shot in the head, and he was pushed into the hole.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And then the woman was pushed in the hole after him.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And the dirt was just covering her.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 6 SECONDS] We found out that this was a Serb partisan who was found and captured.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And that was his wife.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And if anybody wonders about the hatred between the Croatians and the-- and the Serbs, this is a small example of it.",
      "word_count": 22
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "It was absolutely one of the most atrocious experiences to watch.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "I had nightmares about this incident for I don't know how long.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "It was a horror, absolute horror.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "The inhumanity of-- [PAUSES FOR 5 SECONDS] it was so realistic.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "It was-- it was-- unreal.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "Being-- seeing people shot was bad enough.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "Seeing people being beaten to a pulp.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "But this was just-- [PAUSES FOR 5 SECONDS] it was just unbelievable.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "And then we went on.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "[SIGHS] Train went on.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "You heard-- you had your entertainment for the day.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "Now we go on.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "And we went to Sarajevo.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "In Sarajevo, the train stopped.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "And that went into a much more organized camp.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "And there must have been several thousands of people, all different kinds of people.",
      "word_count": 14
    }
  ],
