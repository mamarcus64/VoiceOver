{
  "stem": "22889.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Business was closed, no business.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "We observe very strict, in our home.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "For Shabbat, every Friday was cholent, because we weren't allowed to cook at home.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We did have two Gentile girls working for us.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So my mother prepared the cholent.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "She made her own challah, and all the trimmings.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We used to send the cholent to the baker.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "The oven was still hot from the bake-- when the bake was previously was done.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "So we kept them down there.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And Shabbat morning, we came from shul, the girl went, pick it up, brought home.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "To begin with, Friday night, I remember we had a-- the first course was gefilte fish.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "There was chicken soup, chicken noodle soup, and chicken, [PAUSES FOR 3 SECONDS] and all that goes with it.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "She was an excellent cook, my mother-- very good cook, baker and cook.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My, at dinner?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I like pulke-- you know what pulke is?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "From chicken, drumstick.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "This was my favorite.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I still like it today, too.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, maids-- two maids.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They lived with us, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We had, also, my father uncle.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He was a bachelor, and was older man.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He lived with us.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Then we had another boy, which we adopt.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "So there were three, five of us-- six, seven, eight, nine people.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "His parents-- there were three children in the family.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "The parents got into fight-- every Thursday, we had market in our hometown.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "The parents got into fight with each other, and they abandoned the children.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They left the children.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "There was a-- the older boy, he was then around eight years old.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "There was a sister.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "She must've been about six.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And the younger boy, five years old.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And the children start to cry.",
      "word_count": 6
    }
  ],
