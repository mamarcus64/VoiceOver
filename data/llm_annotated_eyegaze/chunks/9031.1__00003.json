{
  "stem": "9031.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And-- and we was-- stayed there, seven people-- six people-- four kids, my father, and my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We was stay there about three weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And later, the Germans-- they started to experience to killed Jewish people in the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "My father-- he was the first survivor.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Like, they was talking, they will-- they need men to go to work.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And my father-- he talked to my mother, you know, we need food for the kids.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I will go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "My mother-- she was not too happy.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "But she was, OK, you can go.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And in this day-- this was after [PAUSES FOR 3 SECONDS] we were stay in ghetto three, four months-- three, four weeks.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And they take 500 young men.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "And it was-- they can work.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "They looking nice.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "My father was 38.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And never we saw my father back.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "They killed him in this-- we didn't-- nobody knows in what place they killed him and what happened about these 500 men.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, I do not remember.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "This was in 1941, in the beginning, when we were say in ghetto, after three weeks.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "We was living with my mother and three brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "In October 28, the Germans-- they do a big-- execute for the Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "In this day, they killed 12,000 Jewish people-- women, kids, oldest men, and young men.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And in this action, my mother-- she was, and three brothers-- and two brothers-- they killed in this-- in this day, they killed my mother and two brothers, my two oldest brothers.",
      "word_count": 32
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "This was-- they have-- in Lithuania, they have special places before, with the jail, for people.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And this-- in these places, they do big [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "What is in-- in English [NON-ENGLISH]?",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Was a-- was a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Holes.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "They were digging holes.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Digging-- they digging holes.",
      "word_count": 4
    }
  ],
