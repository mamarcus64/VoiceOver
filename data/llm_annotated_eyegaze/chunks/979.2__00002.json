{
  "stem": "979.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And, you know, like I wanted to see what it's like other countries.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And I decided to go with my sister and her husband.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My mother says, why are you going with them?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you wait for us?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I said, but I'll meet you there.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I said, you know-- I-- but I didn't know it.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I didn't know this happen.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And this stayed with the rest of my life.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "You know, I felt so bad.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And-- and I left.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And-- and she was crying from-- when the day we left.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And she was standing there crying, you know, and that.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Because I don't know if she knew what's is gonna be pretty bad or not.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And-- and so--",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they went to the mountains.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "They didn't force.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I mean the-- they didn't have to force.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They took the names.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They knew where we were.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "It's not like all the countries.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "My cousin, they didn't get my cousin.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "They-- I have a friend, they took her mother, her brother, but she-- her piano teacher took her in her house.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And she-- she stayed there through the war.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And they took her parents.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So they didn't know every-- the-- her other aunt didn't make it-- made it.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And her mother went to the concentration camp, because this is how we went in France.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "They didn't have a special place.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They tried to find them.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "They were trying.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "So in other words, if your sister didn't want to go, she could have gone to the mountains?",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So she didn't want to go to Baron Hirsch?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "She-- she could-- she could run to the mountain-- hide.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Run to the mountain, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "But there they were hiding to other people's houses-- maybe Christian house?",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how they did it in France.",
      "word_count": 9
    }
  ],
