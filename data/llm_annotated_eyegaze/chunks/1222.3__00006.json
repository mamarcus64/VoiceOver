{
  "stem": "1222.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I went into a factory, and I worked as a foyer for eight years, [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "I start saving a little bit money.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I bought a truck, and I went to peddle fruit.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I used to peddle [INAUDIBLE] Italy, bring in batteries.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "I used to bring some scrap metal, sell it.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "After that, I was for a while going in.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Bought a truck with another fellow buying cattle.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "After that, I saved a little bit money.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "I bought a grocery store.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "I sold the grocery store.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "I bought another little store.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And then later on, in 1952, [SOBBING] I met my wife, Edith Lerner.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "She came from [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "I married her, a beautiful girl.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "Unfortunately, she didn't feel well.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "She had a lot of sugar, diabetes.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "She died in a heart attack.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "She give me three wonderful children.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "[SIGHS] I worked day and night, seven days a week, three jobs in the grocery stores, no help, no nothing.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "I made the best of it.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "Unfortunately, she got sick.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And the doctors kept on telling me, because my middle son had a brain tumor-- he was born.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "He was-- he was 11 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "So I had at the time my wife in the hospital, my son in the hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "And I had Two children-- Brenda and Archie Honigman.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "[SOBBING] And I used to diaper Brenda.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "She's right in here.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "The customers used to say like that, Sam, you make me the hamburger, I'll diaper Brenda.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "And up till today, there are some customers still remember me that way.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "After that, I was going on all the years like that.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "My wife died probably about six or seven-- about six years ago.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "She was very sick.",
      "word_count": 4
    }
  ],
