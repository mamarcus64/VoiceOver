  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And in-- in my stupid head, not thinking of any, you know, serious effects that that would have, I might have pointed out one or two, and maybe my uncle too.",
      "word_count": 31
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And she had that feeling that I was the one who pointed out where the uncle lives.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So she had a little ill feelings.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We were very close after the war until she died 10, 15 years ago.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "But that was-- that was when I-- when I came into the house, again, and I-- and I-- and I was back home whence I came from.",
      "word_count": 27
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And stayed there for a while.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "My-- my brother came home.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "My middle brother Joe came home a few weeks later.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he brought along a friend who was also saved in concentration camp to stay with us.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And then we heard some notice from people that my sister was alive and that she is in a certain city.",
      "word_count": 21
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "So I picked myself up, and I went [PAUSES FOR 3 SECONDS] traveling again.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Let's pause here.",
      "word_count": 3
    }
  ],
