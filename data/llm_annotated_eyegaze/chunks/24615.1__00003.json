{
  "stem": "24615.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It was in-- I think it was 1937 or 1938, you know, I believe [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No, I-- I was-- I was 13 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was a night-- right after my bar mitzvah he died, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It could be 1938, because next year, you know, the Russian came in, in 1939.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember it was real, real-- it was-- it was real bad fast, because we didn't have too much, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And my mother, she used-- she used to take stuff, you know, and take it to some farm, and she would trade it for food, you know?",
      "word_count": 27
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And she used to bring it back, and she used to sell it.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "You know, like eggs.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Or she used to get a chicken for the material, you know, for clothes, she used to take to the farmers.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Or like a blouse or pants or shoes, or what.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She used to trade.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Or sometimes they used to buy it for money.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "She would trade those clothings for food?",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, for-- for food.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "That's what she had to do.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "That's the way.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And it was-- it was bad, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have too much.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "But we managed, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And I still used to go to shul, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I used to go to shul every morning, you know, daven, you know, pray and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And after, you know, I didn't-- I didn't go to school.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "You know, I think I went to school, you know, up till I was 10, 11 years old.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was a cheder.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "It was-- you know, they-- they teach how to daven, our [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "You know, I just start on one [NON-ENGLISH], two [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And then I stopped, you know?",
      "word_count": 6
    }
  ],
