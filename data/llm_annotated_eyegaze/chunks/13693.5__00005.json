    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The doctor is my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And she was a big shot over there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "She said, you know my-- my father.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He had a-- [PAUSES FOR 3 SECONDS] a revolver in the place.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And she told me where I'd go.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And if maybe if you can find it, you can join the partisan.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "This was the original house that you lived in?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
