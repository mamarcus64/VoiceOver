    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "It's going to end here.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Finally, I found the same [NON-ENGLISH] which was before for years, but in our house.",
      "word_count": 15
    },
