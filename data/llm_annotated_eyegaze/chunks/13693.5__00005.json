    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Kallis. ?] And from over there they are planning to go.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I came in over there, and they told me, you cannot go, because you don't have the arms.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "You don't have arms.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So from over there I went to my-- the old building.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I knew it that I talked to a doctor.",
