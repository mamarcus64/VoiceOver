{
  "stem": "628.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "But these people-- these old people-- the three-- three days traveling.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "[NON-ENGLISH]!",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "Some of them licked on the ice, and they couldn't take their-- what's it called-- away from it.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "They stuck on it.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "The SS came with a knife, and they cut the tongue.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "The blood was running down, and these people also fell dead.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "There was a cemetery, already, on that platform-- from 20, 30 people.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "In the trains, the ones who died were already-- hell.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "Everybody went to the right.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "I-- I want to see my grandparents.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "I didn't see them.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "On the train, when I went these three days, I said, oye.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 36,
      "text": "Maybe I'm going to see my Gisala.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 37,
      "text": "And it's going to be-- everything OK.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 38,
      "text": "We're going to be together-- imagination in this three day-- I've only got.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 39,
      "text": "Hell.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 40,
      "text": "That platform was not where the platform is now.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 41,
      "text": "Because that platform has been made later, right into the crematoriums.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 42,
      "text": "This was about a kilometer or two before the gate.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 43,
      "text": "They didn't have the-- the-- in '43, then.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We went into the quarantines.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "There were all barracks there.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And people were, [NON-ENGLISH] are the people-- everybody shouting, water.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Everybody was looking like that.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Their eyes were glass, like, sometimes, in Mars afterwards for the-- the people you saw there.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "We were monsters!",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We had-- I don't know what it is.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Without water, you can't exist.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Without food, [INAUDIBLE], yeah, it-- it's possible.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "But the water-- so in the barracks, everything-- so, already, the kapos came in the barracks.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "A woman standing next to me with two children said, [SPEAKING NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I bring you directly a glass of water.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I was standing next to her.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "She got the water.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I said, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Give me also some water.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "No, my two children.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I-- it was already survival.",
      "word_count": 5
    }
  ],
