    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "I think that to me, the Jewish experience was an education experience.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And I'm very grateful that my parents pushed me into studying.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
