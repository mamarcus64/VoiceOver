    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 9,
      "text": "And my brother was separate, because-- so when we went to the camp where they put these [SPANISH]-- what you call?",
      "word_count": 21
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 10,
      "text": "The-- yes, the fence.",
      "word_count": 4
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 0,
      "text": "Fence.",
      "word_count": 1
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 1,
      "text": "And we saw my brother was in Lager B.",
      "word_count": 9
    },
    {
      "segment_idx": 176,
      "sentence_idx_in_seg": 2,
      "text": "We were in Lager A, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 1,
      "text": "And then when they start crying, we cry, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 2,
      "text": "Ay, ay!",
      "word_count": 2
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 3,
      "text": "The other people say, I want my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 4,
      "text": "I want my father.",
      "word_count": 4
    },
    {
      "segment_idx": 177,
      "sentence_idx_in_seg": 5,
      "text": "You know, I didn't have my father and mother, died in Rhodes, you see-- but the other people.",
      "word_count": 18
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 0,
      "text": "So the Salonika people, who knew, they took them two years before, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 1,
      "text": "And they say, oh, my-- my [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 2,
      "text": "Don't cry, because your mother and father, they're already in the crematorium.",
      "word_count": 12
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 3,
      "text": "And see, look there.",
      "word_count": 4
    },
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 4,
      "text": "This is smoke where is the people burn, you know?",
      "word_count": 10
    }
