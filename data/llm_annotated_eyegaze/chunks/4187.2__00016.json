  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "But she didn't, because she was picked out by a German.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "My sister said Zsuzsa is not her daughter.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Had she said yes-- which she might have, just to be sure that they're together-- she would have been sent to the gas chamber.",
      "word_count": 24
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Had I said I'm 13, I would have had a very fair chance to go straight to the gas chamber.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "My mother survived.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "My sister survived.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "I survived.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "So that was, what I call, the first incredible choice that we made, which was just a choice.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "Anyway--",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Oh, right.",
      "word_count": 2
    }
  ],
