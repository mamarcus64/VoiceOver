{
  "stem": "2391.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "And you know, according to the doctor, had something to do-- I mean, the stress of all these years, of course, took its toll.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And then my mother-- my brother get married.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And I lived with my mother until I came here in 1962.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "I had only planned to come here for a year.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Here, in this country.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So this is not connected with the Holocaust really, because Belgium is a nice country.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "It's very-- very pleasant to live there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I came here, and I met-- I met Bob, my husband, and we got married.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So that's how it happened.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I actually came to learn the language.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I wanted to add you know, English to my languages.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "So that's, in a nutshell, you know, what happened.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "First I was in New York for two months and worked there.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Then I came to Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I had a cousin here and I came to visit her, and she convinced me to stay.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I first worked here at the Heinemann Studios as an artist, fashion-- fashion Illustrator, doing fashion illustration, which was fun.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "But it's-- unfortunately, it's kind of a dying art.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "It's not much done anymore, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Photography has replaced it mostly.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Then I worked as a secretary at the University of Chicago for a professor, a theologian named Paul Tillich.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I mean, he's quite well known, still is, even though he died many years ago.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "He was from Germany originally.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Not Jewish. but he was against the Nazi government.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "He was almost killed.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "He was close to being killed as a result, and so he had emigrated to the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And he was the only professor at divinity school that was entitled to have a private secretary, and I was the one that was hired.",
      "word_count": 25
    }
  ],
