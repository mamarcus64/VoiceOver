{
  "stem": "8423.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "But the common people like ourselves, who just arrived, and they didn't decide what they do with us, this was our garment.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Nothing under it of course.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And a pair of wooden shoes-- and we each had like two wooden shoes thrown at us.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "It could have been two lefts two rights.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "We tried to straighten it out between ourselves.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And my sister was yelling my name again.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And I was always being called, it seems.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And I stuck so close to her in the shower, out of the shower.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "I didn't let her out of my sight, because having lost Mother, she was all I had.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "So I was right there, next to her, touching her.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And she's calling my name.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I said, I'm here, right here.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And she looked at me.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And it was obvious she didn't recognize me.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Without my hair, I had this-- all this dark long hair.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Then she realized that she must look the same.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "So she walked over to the bathhouse.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And it had tiny little windows.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And I see her in front of the window, making all these crazy motions.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I got scared.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And I said, what are you doing?",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "She says, I'm trying to figure out which one is me.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Because she's realized now, that we all look the same.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And she just wanted to which one was her.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Well, she looks really worse than I did, because I always had a full face.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And she had sort of a narrow face.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And without the hair, she really just didn't look like herself.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But I stuck so close that I knew it was her.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "But we could not recognize ourselves.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And then quickly, they had poured buckets full of liquids, and steaming liquids.",
      "word_count": 13
    }
  ],
