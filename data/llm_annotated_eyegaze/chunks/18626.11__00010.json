{
  "stem": "18626.11",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 337.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And they found the cement bags by seven boys.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And that's why the seven boys was hung.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And the whole camp had to stay on 'still stand' and look at the seven boys who were hung.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "And one of the boy's mother was fainting right near the kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "She had to see her boy being hung.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And it was all directed by that Johann Kirsch.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Only when I was pointing to make sure that the court sees that I know who I'm talking about.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Then he was sitting down.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "All the time.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They were all sitting like in Nuremberg, exactly the same thing.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "They were all sitting on tribunes.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And they all had numbers, 1, 2, 3, up to 40.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It was 40 criminals.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And 36 were hung by the neck until dead.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Only one-- as they all had a last word, and one-- a lot of people-- they ask if they are guilty.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Nicht schuldig, nicht schuldig, 'not guilty.' And one didn't say, not schuldig.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "That was Kramer.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Kramer was the man who was-- who liquidated the ghetto of Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "The Warsaw Ghetto, he was from the liquidators.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And when he was told, you know, his fate, he says-- he hollered, Heil Hitler!",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "I hated the Jews all the time!",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I hate them now!",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And I'll hate them until I go to my grave.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "He's the only one who made that speech.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "The other prosecutors-- the other defendants tried to say they had orders, like everybody.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "The man I was prosecuting, that Moll, who beat me almost to death, he came into my barrack where I was working.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "And I had a potato, a big potato, boiling in a pot of water.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And he saw that big potato.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He looked at it, says, whose potato is that?",
      "word_count": 9
    }
  ],
