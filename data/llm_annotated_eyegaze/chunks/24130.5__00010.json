{
  "stem": "24130.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "[SOB] And the soldiers shot them.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And they poured gasoline over them.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And they burned them.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "I'm sure some of them weren't even dead.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "[CRYING] I-- I can't begin to tell you how hysterical we were.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "I said to my sister, I don't care if they kill me.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "This is the end.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "I used to so afraid of a dead person.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Now, this-- to see somebody die, it was so horrible.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "So difficult.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "These people were-- they said they were Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "They were from Krakau.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "They lived in Krakau.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "We knew that there is no more Jewish people in Krakau.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "When he came home, when he told the Polish people that were working there that-- what kind of work we're doing, so they said they know, because they'd been working there, too.",
      "word_count": 32
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And he says, before they were shooting there Jewish people from the camp.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "Now, they don't shoot anymore Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "It became [INAUDIBLE] I don't know, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "It became [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "They're not shooting Jewish people there.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I says, my god.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "If this is-- I just don't want to live.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "My sisters said, you have to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "[SOB] I says, how can I eat?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "How can I-- I couldn't sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "[SOBBING]",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I just saw these people walking there and-- and burning them.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I-- I says-- I don't want to live.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "This is-- this is worse than dying.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I just pray to God I should die.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So the next day, we went to [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So the woman said-- one woman said, look.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know this kapo.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He's going to come tomorrow again for people.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Try to see if you could sneak away from this kapo.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I says, how can we sneak away?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "We're standing there.",
      "word_count": 3
    }
  ],
