  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "If you get it, you get it.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 7,
      "text": "If not, it's too bad.",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Nothing wrong.",
      "word_count": 2
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "They didn't do anything wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "Because at that time, you wouldn't hear anything.",
      "word_count": 8
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "In the Soviet Union you don't hear anything.",
      "word_count": 8
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] They don't talk and-- [PAUSES FOR 4 SECONDS] so we couldn't hear anything.",
      "word_count": 14
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Sure, it changed a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] But we were happy that they were there, that we had the Soviet Union.",
      "word_count": 18
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "At least our lives weren't threatened.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't know anything about Germany?",
      "word_count": 7
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "No, not while the Soviet Union was there.",
      "word_count": 8
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "You mean about the Soviet Union?",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "Nobody could help anything.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "What would you do?",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "Sure, a lot of people were unhappy.",
      "word_count": 7
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 4,
      "text": "But you couldn't help it.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 5,
      "text": "Nobody could do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 6,
      "text": "Because if they did something, they went to Siberia.",
      "word_count": 9
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
