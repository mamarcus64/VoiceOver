{
  "stem": "2916.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And we were marched up, and as we were marching--they didn't take time out to select us.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "But as we were marching, the selection was taking place.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Officers, SS officers in-- on motorcycles were passing us and pulling people out of the lines who were too weak to walk.",
      "word_count": 22
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And at this point, my mother almost not made it because she was very weak, and she was just dragging herself.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And this SS officer stopped the motorcycle, reached and stuck her, hit her on the head with a stick and said, hey, old lady.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "And he spoke Hungarian.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "He was a Hungarian volksdeutsche who had volunteered for the SS army.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And he says, hey, grandma, can you work?",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And my mother wanted to say, no because she couldn't barely walk.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I gave her a pull, and I said, say yes.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Say yes.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Say yes.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And she said, like a bird, she was screeching, and she said, well, if I have to-- that's how her voice came out-- I will.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And so he let her go, and we marched on.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And this is when we got our numbers tattooed on our arms.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We were lined up.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And then we were driven into barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And that day, an accident happened in the barracks.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "We were driven-- these were proper barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "This was Auschwitz, not Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "These were brick barracks, much taller than the ones we had in Birkenau.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "It had four-tiered beds.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "On every square, 12 women had to sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "There was no mattress.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "You slept on the wooden plank.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And you were given one blanket to cover yourself for 12.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And we were on the bottom tier.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "The-- I noticed that one plank above us was cracked.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And I came out and I told the women to please move off.",
      "word_count": 13
    }
  ],
