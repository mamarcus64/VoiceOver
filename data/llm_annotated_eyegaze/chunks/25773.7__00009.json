{
  "stem": "25773.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I went to Warsaw, because I was going to be in touch with some-- somebody in Warsaw that I knew.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And it was about seven kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] No, I remember it was something different.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "They was very anxious to go to our villa, which was in [POLISH], which was completely different part, because I thought maybe my brother, maybe my-- maybe Rosa, maybe my father, maybe somebody will be there, because the villa was rented during the war.",
      "word_count": 44
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Maybe somebody came.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "If anyplace, that should be there, because we're-- so we made the journey, I remember.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And also, they were going to Warsaw-- Stefan and other people.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And we went the journey to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And it-- it was-- it was unbelievable.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And we sat like people sit on the-- like they sit in the David's psalm and-- and weeping over the-- over the the devastation of Jerusalem.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "That was like that.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "It was completely annihilated, torn to pieces.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "We arrived.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "We came eventually to the villa after a few good weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Nobody there came.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "I looked and never-- then I found out about my aunt who survived.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And then I got in touch.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "She told me she got in touch--",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "She survived, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Eva.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Yes, she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "She survived there.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Then she joined another who came in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And she told me she wrote to my uncle in Palestine that out of the whole family, we two of us survived.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Because she knew already--",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I had a few uncles, and a few aunties and cousins.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And she wrote to him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And she give him the address.",
      "word_count": 6
    }
  ],
