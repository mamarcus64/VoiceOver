{
  "stem": "23942.6",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was more, more-- I don't know even how to describe because there was nobody more Orthodox than my grandfather.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But he was what called a [NON-ENGLISH] before.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And he-- I mean, it was like more than I could-- was normal for me.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And, and this man turned completely the other way.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He was-- from what I understand, he didn't even keep anything after-- when the war ended.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "That's how disappointed in life he-- but I don't know what happened to him.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And he went-- he eventually reached America.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And he went to live either Detroit or Chicago.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And I never-- I never met him again.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "But I didn't live with him.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "I went back to the home.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And I decided on my own that my way is back to Przemysl, back to Przemysl, back to Przemysl.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "That's when I caught my first cold, my very first cold in all the years since the war started.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And I had such a cold, I couldn't talk.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "I was-- I was hoarse.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And I thought I'm going to die from the-- from such a terrible cold.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "I think I had fever, whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, I got it-- I got it right as I was going to Przemysl by-- and I, on the-- that, I caught the worst cold I ever remember in the world.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I never had such cold.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I remember it clear.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I was so hoarse.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But you know, somehow, I was very strong.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "By the time I got to Przemysl, I was better-- fine.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have to have medicine, not antibiotic.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "I was-- I could fight it off.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "That's the only way you could say it.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Some people can fight it off.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "And that's-- must have happened.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "It-- I was so strong.",
      "word_count": 5
    }
  ],
