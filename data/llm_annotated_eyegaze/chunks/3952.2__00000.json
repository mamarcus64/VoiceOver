{
  "stem": "3952.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I came home.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And I was-- being the only boy in the house, I-- I was the one who-- who-- who ran errands.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "You know, sometimes-- sometimes we didn't have enough food to put on the table.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Really, I can remember, literally, there wasn't bread enough.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I recall one Pesach, one Easter holiday-- you know, the main meals for us on Pesach were potatoes, matzot, and eggs.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Eggs.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "There were Pesach night, the seder night would have been-- we would have been sitting down at Monday night.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "The week before, Friday, we had-- we didn't have any potatoes, any matzot.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have, you mean, the basics.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "We didn't have any eggs.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "We had nothing, absolutely.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "There wasn't any money to buy anything.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And being a proud family, my father was Hungarian born.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "He was an officer in the Austro-Hungarian army, very, very proud man.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "He would walk with his cylinder in the street, and everybody would bend, Mr.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Goldblatt, and would greet him.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "So he wouldn't go and tell anybody that he needs something.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "We were-- the motto was-- in Yiddish they would say, [SPEAKING YIDDISH].",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Pinch your cheeks so they be red.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "Nobody should know what is going on-- what's going on in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "Really, nobody knew.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "My best friends, they were just kids in Sighet.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "My closest friends, they never knew.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "They wanted to go eat ice cream, I say my throat hurts.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "If they wanted to go eat a [INAUDIBLE], I would say, no, I feel my stomach is not so well.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "If they wanted to go to a cinema, I say my eyes hurt.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "I would always have something that hurts to-- to get out of-- of going someplace with the-- with the boys.",
      "word_count": 20
    }
  ],
