{
  "stem": "11611.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "She had a sister who was married to Rommel's adjutant, a major in the German army, who was also a leader of the Bundesdeutsche Madchen, which was the Nazi girls organization, equivalent of the Girl Scouts here, except Nazi.",
      "word_count": 39
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "Her father was a German industrialist who was a Nazi.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "She was a great-granddaughter of a chancellor of Prussia, von Hardenberg, at the time of Napoleon.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And I was very leery of her because I figured, what the hell?",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I don't need anybody pilfering my papers in the evening.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "But I followed her reporting career with interest.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She was quite anti-Nazi, which was, given her family background, kind of unusual.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But she had another aspect to her background.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "She had been married to an Englishman who died in internment in the first year of the war.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "That did not contribute to making her Nazi.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "Now, did I hear you just say that Kuperschmidt's lack of affiliation with national socialism was unusual for defense council in the cases?",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I would say he felt it was unusual for any German lawyer.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "My guess is no more than 5% of the German bar stayed out of the Nazi Lawyers Guild, and as far as I know, Kubuschok was not a member of it.",
      "word_count": 31
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "As far as I know, he was also not a Nazi party member.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And of the defense counsel, I would say 99%-- in fact, he's the only one I know who wouldn't have been.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And I may be even wrong on that.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I may be giving him too much credit, but that's as much as I could ever find out about him.",
      "word_count": 20
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "He also had a very obscure career under the Nazis.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "He moved to East Germany, somewhere near Dresden.",
      "word_count": 8
    }
  ],
