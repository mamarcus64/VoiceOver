  "sentences_input": [
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "What was shown on, on the road, caravans and Jewish people--",
      "word_count": 11
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "'39.",
      "word_count": 1
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "I don't--",
      "word_count": 2
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "After this.",
      "word_count": 2
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "And after this, the Germans took us to work by the roads, to fix up the roads.",
      "word_count": 17
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "We worked.",
      "word_count": 2
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "And after this, took us from Padew to Baranow.",
      "word_count": 9
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 3,
      "text": "Baranow and that.",
      "word_count": 3
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 4,
      "text": "The Judenrat gave us rooms.",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 5,
      "text": "After this, the Judenrat took me to the lager.",
      "word_count": 9
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] Then-- [PAUSES FOR 3 SECONDS] I [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 7,
      "text": "And we was in lager.",
      "word_count": 5
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 8,
      "text": "And one time, for money, I went for Shabbos to the town.",
      "word_count": 12
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 9,
      "text": "We don't care [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 10,
      "text": "This time, was all the Jewish took to market.",
      "word_count": 9
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 11,
      "text": "And my mother took, took me and go back to the lager, to the lager.",
      "word_count": 15
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 12,
      "text": "He took me between the-- this was a small place.",
      "word_count": 10
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 13,
      "text": "And she went home to Baranow, and I went in the, the lager.",
      "word_count": 13
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "The mother want in this way.",
      "word_count": 6
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "Got the mind, maybe, there will be better.",
      "word_count": 8
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Must be [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 2,
      "text": "Maybe I got a piece of paper.",
      "word_count": 7
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 3,
      "text": "Maybe I got.",
      "word_count": 3
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Just, just-- [PAUSES FOR 4 SECONDS] no.",
      "word_count": 7
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "They took us '40-- must be on '42, 1942 when it started.",
      "word_count": 12
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 2,
      "text": "March 1942 I went to [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Was, in this time, you can find Polish people, they took us.",
      "word_count": 12
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "Polish people with the horses.",
      "word_count": 5
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 1,
      "text": "We were forced to go to Baranow.",
      "word_count": 7
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "What you can take on this?",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "Clothing.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "Maybe to eat, something.",
      "word_count": 4
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 1,
      "text": "After this I was not long in Baranow.",
      "word_count": 8
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 2,
      "text": "They took me to, to, to the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 3,
      "text": "The Judenrat sent, sent us.",
      "word_count": 5
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 10 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "I was in in [INAUDIBLE] this summer, 1943.",
      "word_count": 8
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "What-- can you tell me a little bit more about-- how long were you in Baranow?",
      "word_count": 16
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
