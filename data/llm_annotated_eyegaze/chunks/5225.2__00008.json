{
  "stem": "5225.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.6,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So they come in [NON-ENGLISH] this one from the-- from the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And they ask the doctor, what's the matter with him?",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "He say, show it to him.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "He give me [INAUDIBLE] food.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "He said to me, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "You want to eat?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "I said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "He said, go in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And the kitchen was outside the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And I barely go to the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And over there was a big, big-- David they called his name, a German.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And he gave me food.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I never ate so much in my life.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And he say, sit here.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "You're going to eat.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "And I ate.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "Three days later, I was on the job.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "But he give an idea.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "He said, you got to make yourself-- there was a [INAUDIBLE], you know, a plumber.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "Make yourself a bucket from aluminum.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "And you come every day here.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "And we going to fill it up for you with soup.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 14,
      "text": "So, you know, you got kapos.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "And they don't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "How come you got it, and I don't?",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "So I say, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "You're going to divide it.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Oh, no, I don't like it.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "What do you mean, you divide it?",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "What's the matter with him?",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "What's the matter with him?",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "You're going to go in.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "If you're going to divide it, every day five days you're going to get one.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I already give away everything.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "It comes the time they're saying, we going to evacuate.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "Where we going, we don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "'45.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And we evacuate.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "We was putting us on a wagon, sitting one on the other, one on the other, one on the other.",
      "word_count": 20
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And everybody got only a blanket.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "What clothes?",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Oh, you got the-- the jacket and a pair of pants.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And everybody sitting with this one.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Hirschberg.",
      "word_count": 1
    }
  ],
