{
  "stem": "9230.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The date-- on the-- January 6 is our anniversary.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "It's going to be--",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "It's going to be 47 years.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "My daughter is 46 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Look, I didn't-- I remembered--",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my husband, he didn't want to go no place.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Because he was before the war in Israel with his wife.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And his wife got sick.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And she went back to Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "That's why he run after her.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And he got in trouble.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And he loved Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "He was staying in Tel Aviv with the Byks, with the-- the-- the two-- because they were scared for the Arabs.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "He wouldn't go no place.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "My sister went to America because my brother-in-law, he got the whole family here.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And-- and he-- and after, in Israel was very bad.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "So I forced him to leave Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "It was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "For four years, and my daughter was born there.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Bad, you know-- it wasn't-- you got three eggs a week.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We give it to the child.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "You got one portion of chicken, one week.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "It was very, very little.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And the rest, you have to buy on black market.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And to get a job, you have to-- you have to know the president.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "If not, you couldn't get a job.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and so I decided, because we lived with my cousin together.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "There went away.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And I says-- and his third friend, one lives in Washington.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And my husband-- and the third one lives in Toronto.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And my friend with her daughter is in-- has a talk show, Shirley, she put-- they got relatives-- Canadian born.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "They was in cow business.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So his friend maked us the papers.",
      "word_count": 7
    }
  ],
