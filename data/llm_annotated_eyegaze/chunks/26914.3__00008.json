{
  "stem": "26914.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 15,
      "text": "She's the first fiddler in Moscow theater.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 16,
      "text": "And she said, Stella, you will go with me.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 17,
      "text": "And I was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "We went there in the middle of the night.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "She got a horse and a buggy.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "She said, your suitcase, put on the buggy.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And you and I, with Israel, will walk.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "It was a hill to walk there.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "The horse--",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Mine husband.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And the horse was skinny-- hungry.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I thought that the horse will die before everything.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "We came up.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "It was in the middle of the night.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "She knocks at the window.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Momichka, we have guests.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "A grey lady with beautiful eyes came out with a smile.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Yeah, come on.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "And she said, you take a shower.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "I'll give you the bed.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "You will sleep there.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "And I said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "We will sleep on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "We will not get to the bed.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "And they took marvelous care of us.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "It was just a dream.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 19,
      "text": "Who would think about a thing like this.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 20,
      "text": "You are going, not knowing where you are going, where you will stay.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And then, when I was there, the people which came there before us, they found mine brother on the way.",
      "word_count": 20
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Mine brother was running from one wagon to the other, asks, Stella?",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "You know Stella, my sister, Stella?",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I was known, famous, in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "He thought that I am-- I'm famous-- famous in Russia too.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "You were famous because of sport?",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Sam.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And the-- he finally got the-- the train, which people were with me, they said, oh yes, Stella will come to Birsk.",
      "word_count": 22
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "She's-- she will be here.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "He came there, and he had the laryngitis.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "He was sick, in hospital.",
      "word_count": 5
    }
  ],
