{
  "stem": "1511.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "It was a really nice apartment, also from the German, a little bit nicer, and we used to have already enjoyment, something like that.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And from there, we came.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "My husband was very ashamed that we should have gone to Israel, because he was the leader.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "He wouldn't want to think about something else, and now is the time.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "Oh, and while we were in Veksheit-- I have a picture-- that all the countries agreed that we should have Israel, and we almost got crazy from being happy that, you know, that everybody vote for them.",
      "word_count": 37
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But we went out, and we came March the 20, 1949.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We came to Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Now where else should I go?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I have to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "We have to go back about your family and what they went through.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I came to Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My sister-in-law [INAUDIBLE] was here.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They treat us very nice, and my husband went to work in a factory, and he was a very fast worker, and life was good.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And I rent two rooms.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I lived with an old lady.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I was like her daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "She was sick, and I helped her.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "It was Bellevue, 36 Bellevue here in Toronto.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And little by little, we saved up money, and I bought my first house on Markham Street.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And then we went to Indian Road.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "We had a little grocery, and the kids were growing.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "But I didn't want to be on Indian Road, because my daughters were going to a non- a Gentile school.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "And I was afraid she was going to fall in love.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "She was very-- played and singed, and I was afraid she'd fall in love with a shegetz.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I figure out, and we bought on Badgers a building, and we opened up our own business.",
      "word_count": 18
    }
  ],
