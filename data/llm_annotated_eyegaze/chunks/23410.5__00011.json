  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "Not he is a baby, but he does not know where he is.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And the father-- and this old man said to him, how can I leave him here?",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "He looks like a baby.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And while he spoke in Polish, everything in Polish, he used the word baby.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Only baby.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "It's English.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "You know, it's an international name.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And so they took us over to his place.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Not they took us over, but they took us between us two so that I don't get lost.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "We'll stop right here.",
      "word_count": 4
    }
  ],
