{
  "stem": "25938.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "So people didn't go out of the-- of the home.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "They used to cover the-- the-- the icons in the streets.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "So people used to stay home then.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "I used to lay out the ground sometimes.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "It was-- I-- I-- I-- I brought myself to do that.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "But we knew there was a limit.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "We can-- we didn't want to provoke them by-- by-- by being seen.",
      "word_count": 13
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "So that--",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "On the street, on the street.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no violence--",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "--in my little town.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "When I was in Poland, no, not officially.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "There was no violence.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No, peaceful.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I'd sit with a friend-- a friend, a non-Jewish friend, and the peasants used to buy in my mother's store.",
      "word_count": 20
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "But I didn't-- I didn't-- there was no violence.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "There was no crime, even.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "Not even-- I don't remember any crime in-- in my little town, even in the Polish population.",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "That-- that we felt in our bones.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Because we couldn't-- people couldn't have a job-- couldn't have government jobs.",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "The rabbi and the cantor lived from the-- made a living out of the Jewish people, from the Jewish people.",
      "word_count": 20
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "There were-- there were--",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "There were Jewish lawyers and doctors.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And in my little town, there was not even one Jewish lawyer or-- or-- or doctor.",
      "word_count": 16
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "There were doctors in Poland, lawyers.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "But it is known in the universities there was anti-Semitism.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "There used to be not Jews-- Jews used to sit on different-- on different benches.",
      "word_count": 15
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "It's almost like the black people in America.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 6,
      "text": "That was in the-- in the big town.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 7,
      "text": "But in little towns we didn't-- that's interesting people don't know that.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "My town was an exceptional little town.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "We were a minority.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "In my town, Porzecze, the Jewish people were a minority, a small minority.",
      "word_count": 13
    }
  ],
