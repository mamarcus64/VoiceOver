{
  "stem": "2590.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "And I was afraid to tell my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And I walked over to her and I said, gosh, if we would have to run from here, where would we go.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And she said, we will go to tonight to Nadia Honovska.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "She used to be a maid in our house.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And I remember they said she lives in Piekna.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "Still, the name of the street is Piekna.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And I did not remember the number.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "And my sister said Piekna 16.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And as she said that-- she said those words, we heard footsteps.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And Germans came up in the attic and they started to [GERMAN], you know?",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I yell-- I ran first.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I thought my sister ran after me.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, my sister, they kept.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Let me run because I looked like a misfit, you know, with a broken nose and without teeth.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And I went to the [NON-ENGLISH], to the-- who I thought my mother was there.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And he said, no, your mother's not here.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Then I went to a Czech woman, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And when I came in, the woman got-- she looked like a ghost and said, why did you come here.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "But my uncle was hiding, and my aunt were hiding in her apartment-- in this room.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And my uncle called out from underneath the bed.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And my aunt came out from a closet.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And they begged the lady to take me.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And she said-- I'll go out, my uncle said.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And keep my niece here.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And she said, no, I am afraid.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I don't know, maybe somebody from the neighbor's noticed.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And I had to leave.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And I left.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I left.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And I went.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And I thought, I am going to go to Nadia Honovska.",
      "word_count": 11
    }
  ],
