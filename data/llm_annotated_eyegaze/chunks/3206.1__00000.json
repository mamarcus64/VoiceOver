{
  "stem": "3206.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Max Rosenbloom.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "R-O-S-E-N-B-L-double-O-M.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name was Matys, M-A-T-Y-S.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Rosenblum.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "R-O-S-E-N-B-L-- double-- U-M.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born on December 12, 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Today, 68-- 69 and 1/2, exactly-- 69 and 1/2.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Bogoria.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "B-O-R-- B-O-R-G-O-R-I-A.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "This is in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "When I was born, [PAUSES FOR 3 SECONDS] in Poland, in Bogoria, I can recall as a child, my father and mother were separated.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And then I went-- my mother took me to a farm, which my mother's sisters and her mother was on this farm.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "They were farm [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Reisl.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Feinkuchen.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] If you want to-- to spell is a little bit-- I have to write it down.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And then my grandmother's name was also Sura-- a Jewish name, Sura.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And then I had aunts.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "One was Marmu, and one was Rifki-- two Ns.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The farm was also in Poland, not far from Bogoria-- about 20, 25 kilometers.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "This was the farm.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And then I was grown up in that farm.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I can recall when I was about three, four years old, you know, I was still growing up there.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And when I got to the age of seven, school age, I moved-- they took me-- my father took me back from that farm, and they took me to the city of Staszow.",
      "word_count": 33
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "In Staszow, I started school as a child.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to heder there.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And this was in 19-- I don't, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Who remembers the dates exactly?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Tell us about your schools.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The schooling-- you know, this was-- when I started school, I was very good in Polish, because I was growing up on a farm between Poles.",
      "word_count": 26
    }
  ],
