  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "They used to give me a bit of kashi and a bit-- and a bit of bread and sometimes a bit of meat, a piece of meat.",
      "word_count": 27
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "This was what our food, that's what I eat.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "What we should do?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "What we should do?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "What [? you ?] be?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "A lot of people decided to go back, go back to the Germans, go back to Poland where they come from.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I said, I am not going back.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I am not going back.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "I will be-- I don't want to get killed by the bloody Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "Something will come on.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "I must tell you, when my mother with my grandmother was talking about me to become apprentice, my grandmother was saying, God will help.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "You see, God will help.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "He will become apprentice, God will help.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "If you are religious or not religious, but still decide you were brought up in this-- this-- this-- this life, I thought to myself, maybe God will help.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Maybe something-- a miracle will happen if something will happen, [?",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I'll ?] [? change. ?] And we hear that in Brest-Litovsk, a town not far from there, the Russian government, two [? offices ?] [? paid ?] [? the ?] [?",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Yiddish ?] people to go to Russia to work, volunteer.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "We took our parcels, we went there to the station, we went to Brest off from the train straight into the office.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Was two offices.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "One office was to register people with families, with children, and the other office was to register single people.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Can be married, but not children.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "We register, we get half a bread.",
      "word_count": 7
    }
  ],
