  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I want your [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "You can ID the tape, if you want to.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Can I get a drink?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "You would call it an interesting story, huh?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He remained down there in the woods in Karasin with his son.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Bebik, ?] we called him.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Dave. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And fight with them.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I left behind everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I went with fight with them.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They were Russians.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They were Ukrainians.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They were Jewish like I told you, a [? potpourri ?], a mixture.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I told them.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Maybe some did not advertising, not going out with placards on the front of them.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But I tell them if they ask me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I was-- I was proud of myself, of my family.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "It--",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My name, Braniaslava they use to call me [RUSSIAN] You know you call, in the Russian version, you call it by your name and your father's name.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Braniaslava, [?",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Brania, ?] yes.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I left yes.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "In the woods, when I came back, I left my sister.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I told the woman, what I told her, she got my message straight.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "My sister survived.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "That's what I wanted to tell you, emphasize if you will forget some things.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And she survived.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And then I met her in my town later on.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "With the partisan, what the life, a day in the life, I'll give you some example.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We used to occupy a village.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We had our radio station with three people working.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We had receiving and transmitting telegrams with Moscow.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "We used to have assignment what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And we were a might, I don't know, 1,600, 1,000, I don't know.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But we were a might.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "The Germans were afraid of us.",
      "word_count": 6
    }
  ],
