{
  "stem": "21180.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "The rails.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I have friends what are still alive which worked with him together, and they didn't get food.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And working, you have to work 28 hour day.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Not-- when it got dark, they worked also.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And very little food.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "People, young people, they got sick.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "So what they do, they send the sick back to ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "This-- the Jews should feed them.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "They didn't kill them.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "But from ghetto, we have a-- a quantity, so many people to send to Auschwitz to crematorium.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "So those people were the-- the first to go Auschwitz to the crematorium.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "Because we know now.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "The time, I didn't know it.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "This-- all the-- where were Jews, they had to give so many of own people, they said for labor.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "But we know, they send them to Auschwitz, the crematorium should not stop.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "And this was for the whole time.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He was taken for labor, but he came back.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And we know it they going to send him to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And we have good connection ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And we took him out.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Connection.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We took him out, not legal.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Somebody came out with him, only going to bring him back for a minute.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "This, my mother should see him.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "So when we was outside, we took him home.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Next day, the police came look for him.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "So-- but he was not sleeping in our house.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We don't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So he lived over, and was quiet.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So he lived over.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "He didn't have a card to get food.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Live without a card.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So he was staying in our house.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And-- but he came back sick, without-- What was his name?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Shulom.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "We did the most of it.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We had a little more, I should say, than simple people.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We sold.",
      "word_count": 2
    }
  ],
