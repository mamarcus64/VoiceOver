  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They-- I must say my parents were very well-liked in the community, in the town.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I have a feeling that this is why they never came to our house either to destroy everything.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And many times I have heard that my grandparents were very honest and honorable people.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And it was I suppose the background and that-- and just luck.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And-- but they-- as I said, that one lady who always brought us fresh vegetables and fruit.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So we-- my parents and family were very well-liked in that area, in that small town.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I don't believe so.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Not that I remember.",
      "word_count": 4
    }
  ],
