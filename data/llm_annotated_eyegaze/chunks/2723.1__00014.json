  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And when Gustav became afraid that he might have some visitors, or whatever, he would carry us on his back, covered with a sack, or in a sack, into the cellar, where we were in a big crate of potatoes.",
      "word_count": 40
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "People hoarded vegetables for the winter months.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And we were put into that sort of situation for, on and off, I think 10, 12 days.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And I can-- I really can't tell how long we were in each situation.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "We almost preferred the cellar, because there was a piece of light there, and we could read and strain our eyes [? dually ?] during the day.",
      "word_count": 27
    }
