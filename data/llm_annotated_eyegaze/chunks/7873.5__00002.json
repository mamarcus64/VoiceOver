{
  "stem": "7873.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 42,
      "text": "They used to stick their heads out.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 43,
      "text": "They saw who-- who we are.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 44,
      "text": "Down there we hardly get any-- anything to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 45,
      "text": "Water was unbelievable scarce.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "In the last camp.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Ganacker.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] We stayed in a-- in a woods.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They dug us-- there are no beds.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They dug a hole in the ground and for our heads to make a little step to lay our heads down, and only one blanket we got.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "People turned into cannibals.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "We could find bodies cut up.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "People were eating bodies.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] The time came for the death march-- to march out of there.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And by the way, something else I got to mention it.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "A-- a group of SS came down in civilian clothes.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "They checked me out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I didn't know what's all about.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "They undressed me, took a sample of my hair from this part, because here there wasn't enough hair to for it, from here.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "They asked me if I-- if anybody did any experiment on me-- they measured my chest, the color of my eyes, and I didn't know what's all about.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "As we left the place, a kapo-- a kapo comes over to me.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "He says you're lucky, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Exactly.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I told you what they did.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They took our-- the-- the Star of David away, only red.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Red--",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Because Hitler said no Jew will ever step over the threshold of Germany.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So not to make himself out a liar, so he took us and we just had one, the red Politsch.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So nobody then didn't know that we are Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And we were supposed to-- I was among them to breed children.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "There were a lot of Gentile people with us, too-- Jews, Jewish young kids.",
      "word_count": 14
    }
  ],
