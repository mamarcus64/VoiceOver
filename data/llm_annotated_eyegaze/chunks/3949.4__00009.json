{
  "stem": "3949.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "So she said to me, she going to work, and I should go to school-- hairdressing school.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So that's what I did.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "I went to hairdressing school in Stockholm.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And I learned a trade over there.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And she was working.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And then after I got my diploma and a license, then I went to work in a beauty parlor.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "And we set up a home.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "We had a nice little apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "We shared-- three of us, three girls-- we shared one-- one big room.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "Then in the other room was a Polish couple-- survivors-- were living.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "But they were working in the same place where-- where my sister did.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "And we shared a kitchen and a bathroom.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "But was-- it was nice, a very nice place.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And the-- the Swedish people were so trusting, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I-- I learned how to ride a bicycle.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They would give me a bicycle to take to ride into to the city-- two years.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "You know, they didn't-- they know I'm going to bring it back.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Children were waiting for me when-- the time in the evening.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "You know, they were all front of the door to greet me when I was coming home from work.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And they were-- we made a lot of friends there in Sweden-- Swedish people and, of course, you know, other people.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "We were living there five years.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "We learned the language.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I spoke very well Swedish when I came over here to the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "But [PAUSES FOR 3 SECONDS] when I came here, you know, I wanted to learn the English language.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Actually, you see, my-- we find our younger brother through the Red Cross who survived.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Mayer.",
      "word_count": 1
    }
  ],
