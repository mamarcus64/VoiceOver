{
  "stem": "23942.6",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And I was singing.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "I was-- from a hundred children, I was chosen to sing the solo.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And I will never forget it, that-- I realized I have some, you know, some talent that not every child had.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "I felt worthy.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "In other words, you know, that I had something special.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "Not every child knew how to sing.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "I felt very proud that I could stand up and sing the solo for the-- for the Hanukkah.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "I got up on the very top, and they put on a show for other Jewish people that come to see these children that survive.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "They sing in a choir.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "And I was the soloist.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "And I felt very good.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "And then they put a-- made a play.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "And they start teaching us Jewish, you know, everything to do with-- slowly.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "They had to take it easy because some of the children who had survived in, in Polish homes.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "And they were not used to, you know, you had to take it slowly, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "Because some Jewish children didn't feel, you know, they were worthy to be Jewish, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "Studying-- you got to-- have to go very slow with some of the children.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 24,
      "text": "They were-- some of them were hidden in Polish homes.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 25,
      "text": "They don't even-- didn't remember any holidays.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 26,
      "text": "Some--",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I didn't feel very good.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I felt-- in fact, at one point, I was discussing with my friend from Przemysl.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And she was-- she was trying to convince me it's worthy to stay a Jew.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I explained to her it isn't.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I was so sure that it wasn't, that I didn't want to become-- stay a Jew.",
      "word_count": 17
    }
  ],
