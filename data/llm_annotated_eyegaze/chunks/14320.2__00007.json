  "sentences_input": [
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "He says, my plan's to go only to Palestine.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And ask him if he have any relatives in America.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "I have a brother in Chicago.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "He said, give me the name of your brother and your name and the city and-- and your brother will find you.",
      "word_count": 22
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "He said my-- his father-in-law works at the [?",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 10,
      "text": "Fulwitz ?] in New York, and I'll put us in the [?",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 11,
      "text": "Fulwitz. ?] It's a paper, [?",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 12,
      "text": "Fulwitz ?], a Yiddish, Jewish paper.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 13,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 14,
      "text": "And then it happened.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 15,
      "text": "And after two weeks, he sent in papers with the picture of my husband and-- and the baby and everything.",
      "word_count": 20
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 16,
      "text": "So his brother find us through the papers.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 17,
      "text": "Right away he send us papers to fill out and-- and we refused to-- to go-- to come to America.",
      "word_count": 20
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 18,
      "text": "Just into-- to go to Palestine, we didn't have the certificate.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 19,
      "text": "So the-- the brother-in-law says, come to America.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 20,
      "text": "From America, you can go to Palestine.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 21,
      "text": "So we listened to him, and we came to America.",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have passport.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no passport.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "Wait a minute.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "We have already Russian passport.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "We have already Russian passport.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "From Rowne, we went to Germany, Boynton.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "And Bindermichl we stayed--",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "--till I told you that the officer find my husband, and he connected to-- to-- you know, through the [?",
      "word_count": 20
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Fulwitz ?] to America.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't-- I didn't feel good.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I was laying more than-- it was-- I-- I got an-- a nervous heart, still up to date.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Before I didn't feel I want to call you not to come.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "I didn't feel good.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Right-- New York.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "Hyas ?] took us out.",
      "word_count": 5
    }
  ],
