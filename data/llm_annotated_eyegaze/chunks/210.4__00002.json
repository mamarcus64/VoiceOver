{
  "stem": "210.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And, you know, and he was so good to me.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "He bought me clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "He bought me this.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "And my-- at that-- by that time, my cousin-- my cousin, the one that was in the ghetto, she came back with her husband.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "They survived, and she came back.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "And my friend's house-- you know, we found out that when I went to look at the list, I found them, that they're alive.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And I left-- I left a-- you know, my name, where I am.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 27,
      "text": "So they came to my friend's house, so-- my cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 28,
      "text": "So-- and Mr-- at that time, was name was Mr.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 29,
      "text": "Symsnovich.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 30,
      "text": "He came.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "You know, he came and stayed at-- with-- in my friend's house all the time.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "I can't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And-- and he asked me to come with him to Opoczno, but I wouldn't go, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So my cousin, Judy, she says, I'll go with you, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'm not gonna go to a strange man's house, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "So she says, I'll go with you, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And he-- he lived in Opoczno.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And he was hidden with a gentile family.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And he was liberated in January.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And he came back to his city.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And his parents were very rich people.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And they were-- you know, when he got-- he was married before.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He lost his wife and two children.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And when he got married before, his parents gave him the-- there was a gas station-- the only gas station in town.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They gave him, as a wedding present.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And this is what he did-- had the gas station.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And apparently, when he came home, he sold some of the property that his parents had.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And he-- they also had a soap factory.",
      "word_count": 8
    }
  ],
