  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "He was hiding with us I guess close to a year.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We had no rules.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We have no life.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "We had nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "It was rules if you have what you eat.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "You ate if you have what to drink.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "You drink-- you didn't go nowhere.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "It was like-- like animals.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "We didn't do nothing in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] We were scared to death.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 10,
      "text": "It was a curfew.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 11,
      "text": "After 6 o'clock, you can't have lights on.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "What I did with my daughter?",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Day and night on my lap.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "I slept with her and ate with her what we had.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "And then and she [? used to carry on ?] why is the others gone.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "Why is this, why is that?",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And then they learn, they learn fast.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Well, we was in the-- in the ghetto you mean?",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "In the ghetto, yes, yeah, the children was gone outside in the daytime.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And it was a-- the first time they-- when they took out the first killing was the [INAUDIBLE].",
      "word_count": 18
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I [? can't-- ?] remember close to 90,000 Jews.",
      "word_count": 9
    }
  ],
