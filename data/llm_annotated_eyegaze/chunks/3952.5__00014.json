{
  "stem": "3952.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Isn't-- wasn't that enough that I had to be in Auschwitz?",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Now let me go with my brother.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "So the sergeant says to me, you see these three stripes?",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "I give you the three stripes if you let me go where you-- in your place, where you are sent to go.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Where am I sent to go?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "Headquarters.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "Headquarters, or something, in the city, in Ramat Gan.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "It still is in Ramat Gan, but a different location.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "They moved since.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And I would eat at home and sleep at home.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I had a sister there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "One of the sisters settled down in Jaffa, so I would go home to sleep, and I would come in the morning to work.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Just-- not like a soldier.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I wouldn't carry a weapon.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I never shot.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I never shot a shot.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Although--",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Israel from January 31st, 1949 till 30th of June, 1980.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I mean, off and on.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I went around, went all over the world.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I went to the Far East, et cetera, et cetera.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "But I was an Israeli-- Israeli citizen till then.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And since then, I'm living in the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And now I am a American-- an American citizen.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And we'll go back to Israel soon.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We are going back to Israel because our children are there, except for the one son.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We have-- I have two daughters and-- three daughters and seven grandchildren.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So we are going back to Israel now, on the 23rd of July, God willing.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And this is my story, more or less, if I haven't forgotten anything, which I probably did.",
      "word_count": 21
    }
  ],
