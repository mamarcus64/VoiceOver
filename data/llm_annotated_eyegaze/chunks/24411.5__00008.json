{
  "stem": "24411.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "And she works over there too, but I don't know in the office someplace.",
      "word_count": 14
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "And Irving has two daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "And she's married.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "And she has now two children.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Beth.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And the--",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Her last name?",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Jaramillo.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And her husband is Andy.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And she has two little girls.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "One's gonna be-- January is gonna be three years old.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "She-- her name is Deborah.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And the little one is Rachel.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "She's-- I don't know-- a month?",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Two?",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "Not even two.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "Now the whole family is together.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "Except he said, ma, Jennifer was there.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "He-- she-- they came for a week-- just missing you.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "And I said, all right.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "Soon I'm gonna see you.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "1973.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "He woked up in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "This was Labor Day weekend.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "I went to work, I went to work earlier than him.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "While I worked in Manhattan I have to take a bus and a train.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And he was working Canal Street.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "And I said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "I see you.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "I see you at night-- tonight.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "And my-- Irving had a bungalow in the mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "And the wife was standing there-- staying there with the two children.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "So, and for the weekend, he said he's gonna go up.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "About 2 o'clock a guy came over.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And he said, are you Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "Warman?",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "I said, what's the matter?",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "He said to me, your son is here.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "He wants to see you.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "I said, oh my God.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "Why did he came?",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "It's-- it's nice thing he came to mother to say goodbye.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 10,
      "text": "He's going to his family for the weekend.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 11,
      "text": "When I-- when I got up, I saw my boss standing near my son.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 12,
      "text": "And my boss is crying.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 13,
      "text": "And I saw my son.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 14,
      "text": "I said, what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 15,
      "text": "He-- he couldn't talk, but my-- my boss said it.",
      "word_count": 10
    }
  ],
