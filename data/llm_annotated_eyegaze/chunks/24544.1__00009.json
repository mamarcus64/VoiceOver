  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Do not forget the gendarme was very good friend with us.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "OK, I was 22 years almost, that-- 21 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "So came in, I was the so-called [NON-ENGLISH], which means a young lady.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "They were joking.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And even then they came, for some reason they told us before we are-- we will be here 10 o'clock for officially to see the-- the scale and everything.",
      "word_count": 29
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "That was the gendarme's job.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "The business scale in the butcher shop and the grocer.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "But they told us before.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes, and they came in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And they have breakfast everything.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "It was a good things to be good with them, you know, friendship.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And the four gendarme came.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "And they said everybody stay seated with one gendarme.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "We are going down in the basement because we know you are giving sign for the Russian airplanes from your home, from the attic.",
      "word_count": 24
    }
