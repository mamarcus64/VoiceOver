{
  "stem": "8212.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "My name is Lucie Porges.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "It used to be Eisenstab before I was married.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it's P-O-R-G-E-S.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "E-I-S-E-N-S-T-A-B.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Not really, no.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My Hebrew name is Leah.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is the 23rd of November, 1926.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My current age is 68.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The city of the birth is Vienna, Austria.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My grandparents-- I had one set of grandparents, my father's parents, in Vienna, who were quite Orthodox.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My grandmother wore a sheitel.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And my grandfather had a beard.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And they were very good people, not very worldly.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Well, I know my grandfather went to the synagogue every day.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And on Friday, he used to bring people home for dinner, always.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We didn't see them too much.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "We saw them maybe every two weeks or so.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "It was a whole trip.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "You took a street car.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And they lived in a different part of the city than we did.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "These were my father's parents.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And they came from Poland, from Galicia, from a little town called Drohobych, which apparently was next to Lemberg, which was the bigger one.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "Then I had a grandmother, my mother's mother.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I-- my grandfather died during the War of 1914.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "He had, I think, just a very bad cold.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And there was no penicillin.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And he just died.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "I mean, he had a very high fever and died.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "While they were leaving-- were going into exile-- they were somewhere in Czechoslovakia before reaching Vienna, and he died there.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I only knew my grandmother on my mother's side.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Now, she lived not too far away from us in the same part of Vienna, which means that I saw her much more often, practically every day.",
      "word_count": 27
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And she was more a part of my life.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And I loved her very much.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "She was a more worldly woman.",
      "word_count": 6
    }
  ],
