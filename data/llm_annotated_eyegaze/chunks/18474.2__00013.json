{
  "stem": "18474.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 483.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "They used to leave the farms alone overnight.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And they used to go to sleep in town where it was safer because the Ukrainians used to burn down their farms.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And my father went over to Jaska, or my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I can't recall, exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "He says, I'm in trouble.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I need a place.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "Jaska says-- he says, with the family.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "Jaska says, you come here.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "But you're on own your own risk because I'm not here at night.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "If they burn you down-- if they burn me down, they burn me down.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "He had horses and, you know, cows and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Sure enough, that night was the middle of winter.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "This was on second winter already.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "It was very, very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "The snow must have been 4, 5 feet high.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "And we knew our way, you know, how to-- all of a sudden, we hear shots.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "It was-- the moon was out, you know, and the snow was bright.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "We hear pow, pow, shooting at us.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "We fell into the snow, all of us.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "We lay there for about 5, 10 minutes.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "We start to crawl away, crawl away.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "And finally, we-- we got on the other side.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "And we got into Jaska's.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "Nobody there, so we crawled into the barn.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "It was snowing that night and covered all the tracks, couldn't see no tracks or nothing.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "We were always afraid of tracks from the snow.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "Fresh snow, if you walk, you shouldn't leave no track.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "We crawled into there.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "In the morning Jaska came in.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "Didn't know.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "And she was very-- make a pot of potatoes and all kind-- they didn't know what to do for us.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 39,
      "text": "And he says to us, look, he says.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 40,
      "text": "It's not safe where you're at.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 41,
      "text": "And it's not safe in the house.",
      "word_count": 7
    }
  ],
