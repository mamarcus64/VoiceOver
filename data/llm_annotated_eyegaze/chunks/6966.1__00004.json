{
  "stem": "6966.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 23.7,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I had to be there early in the morning to open the shop.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And-- and-- and in the evening, he closed up, and then I went home and [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I only had an hour and a half, or about an hour, for lunch.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "They used to call me the Flying Dutchman when I went through the streets from the saloon to my home and back again.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "There was not much time.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Anyhow, my sister, Dinah, had a job in London.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "She was serving in a chemistry shop in the East End of London.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And I wanted to get back to London.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I'm missing a lot of this story.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Anyhow, I'll come back to later on.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I'll go back there later on.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I said to the governor, I'm leaving next week.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You're not leaving.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "He said, I'm opening another saloon on the other side of Rotterdam, and I wanted you to be the manager.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I've had enough.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I'm going to England.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "So I went to England.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "I got a job in England, ladies' hairdressing.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And at 21, I had my own saloon in Bow, the East End of London.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And I had an assistant, a lady assistant, helping me out and an apprentice.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "But both the ladies were too lazy, shall I say, to sweep up the hair or to polish the instruments.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "So I had to do this as well.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And then I thought myself, well, this can't go on for a long time.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And I sold the business.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And I stuck the money into my father-- coming father-in-law, intended father-in-law, who was a bookseller.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I'm coming to that now.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Yes, if you want to.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I've got to go right back now to my hairdressing in Holland.",
      "word_count": 12
    }
  ],
