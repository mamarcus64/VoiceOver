{
  "stem": "8703.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "A friend of ours from our city-- he was a young man.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And he was in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And they sent him, the Russians-- and the-- and the Polish Army which was created in Russia-- they sent him to a school.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And he became a captain.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "He came straight out from school.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "He didn't have a single penny.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "I said, come on to my house and stay with me.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "Anybody who ever came, they stayed with us.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And I made already, like I said, a little money.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "And, and they had food until they helped themselves.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "They stayed with us.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "We were interested to find our sister.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "We couldn't find her.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "Once we were on the street, we found somebody from Work C, a woman.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "And she lived over there.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "How are you, and all these things.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "She says, how, how is every-- I said, we-- no good.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "We are here already.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "We are looking for sometimes we can't find our sister, Rachel.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "She said, you don't know where she is?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Of course I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, she found out that my sister is with another group of Jewish-- of Jewish women, girls, in a place where they can't leave.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "They are locked up-- not in a camp, but they are not allowed to leave.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "The Russians are over there.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "This is a factory of the vodka.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And they wouldn't let them go.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "They don't pay them, but they wouldn't let them go.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "We found out where it is.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And my brother took upon himself-- my brother, Harry, took some money, and he took also a golden ring in case if we have to bribe somebody.",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And that's what he did.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "He found the place where the woman told us to find my sister.",
      "word_count": 13
    }
  ],
