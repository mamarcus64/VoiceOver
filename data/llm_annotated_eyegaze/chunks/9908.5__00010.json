{
  "stem": "9908.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "I said, yes, that's my husband, in broken German.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "He said, I want to come to you for the [? late ?] Friday night, for the lights.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "You know, for the candles.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I said, with pleasure.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "One-- one Friday evening, we had lit the candle, I made a supper.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Willie ?] shows up with another [?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Willie, ?] a friend with the [INAUDIBLE] and the [INAUDIBLE] lady.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "When she saw this, she-- she got scared to death.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "So they came and every time [?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "Willie ?] adopted us, me and my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And they were recovering parcels from all over America.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Everyone-- then one day we were sitting in the park in Bamberg.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "We're sitting in the park, my husband, myself, a fellow comes down, an American soldier.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "He said, do you speak German?",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And I said, yes, we speak.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He said, I want to adopt you.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I want to send home and-- to-- to give you help.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Because his name was [?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Ralph, ?] a German too.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "So I'm telling you this guy, with every relative he had in America, everybody was loading us with parcels.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "That's the American way.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "They're wonderful people.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "America is a wonderful country.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "I'm just sorry because I had leave.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "Now we-- we are American ready.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "My husband got a nice job.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "We had a nice place we had to live.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "We had still the little boy.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "Did you have to get-- apply for any papers?",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Oh sure.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The Joint Distribution they made fiction contracts from anybody as long as we can get down to-- to America, see?",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "My husband said to them, I don't want any charity.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Give me a job.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Said, why you-- why you worried?",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Sit.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "They took us into a store.",
      "word_count": 6
    }
  ],
