{
  "stem": "131.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I came to New York.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "First I had-- [PAUSES FOR 3 SECONDS] I was-- thank you-- in Czechoslovakia, in Prague, and my uncle, they fought-- they find me.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They send, every week for the four of us, letters with money in it.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "For everybody, $5.00.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And packages.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "But we were so afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Cigarettes-- you could sell it for everything.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I wouldn't sell even one cigarette in my life.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Just we had money to buy-- and clothes they sent us.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And canned goods constantly.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Pam.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "I learned how to make from that Pam--",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Spam.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Spam.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "All kind of food.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I was in my uncle's house in-- in [PAUSES FOR 6 SECONDS] Long Beach.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He lived near New York, in Long Beach.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] He's a builder, too.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He was a builder too.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "He doesn't live any more.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My brother-- when my father died, he couldn't come from Spain [PAUSES FOR 3 SECONDS] because [PAUSES FOR 3 SECONDS] they said that they will-- [PAUSES FOR 3 SECONDS] the Hungarian people wouldn't let him go back there.",
      "word_count": 38
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "They were keep him already.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "It was too late for him.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "But my parents were visiting him, I don't know which year.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Then, my sister-in-law, and they had a son, a little boy.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "His name was Claude, because my sister-in-law spoke German or French.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "She didn't speak Hungarian.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And it was bad times then, and my father-- not my father.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "My mother.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Because my father passed away already.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "My mother asked that he-- if they would let him to come with my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And he was by us here.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And it was very hard for to take him out.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "A consul from Spain came and took him out like his son.",
      "word_count": 12
    }
  ],
