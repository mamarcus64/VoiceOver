{
  "stem": "543.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "We-- I was-- I was in block 10, and it was mostly men.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the whole plot, the whole of Auschwitz-- the hundreds, thousands.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Everyone.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "If you were staying behind, they shot you.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "It was all the time shooting people.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "They didn't want to go, they were shot.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "There were some people who-- I don't know what they did.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "They were hiding.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I know somebody who was in block 10 who was hidden.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And an hour later, they were free.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "But I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "Maybe she was somewhere I don't know-- in a ditch.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "We-- we were-- Lillian and me were not with that.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "We were in-- on the-- on the row-- on the walk.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "I didn't want to walk anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "I wanted to sit down.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "And everybody was laying on the road half shot-- [PAUSES FOR 3 SECONDS] oh, God-- [SIGHS] death, and brains, and oh, unbelievable.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "That is something you can't believe.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So we were walking and walking.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And then, you know, and I wanted to sit down all the time.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I was so tired.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I had to go, you know, I said, I don't want to walk anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "One time, they let us sit down in a field.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "It was all ice-- no food, no water.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We had to eat ice.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So we were sitting in the-- on the-- on the road, and I-- somebody who was beside me was dead.",
      "word_count": 20
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I took the shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "I had no shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "My feet, all my toes, the nails fell off.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And then, my-- my teeth were loose.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "It was-- anyway, we were walking and walking.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Then we came to an-- I think it's past Gliwice.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I don't know where it was.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "It was for days and days we were walking.",
      "word_count": 9
    }
  ],
