  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Because when I walked from Lublin to the border, the Germany killed the people in the-- in the-- in the roads.",
      "word_count": 21
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] And a little Polish boy about 12 years old comes over and said, I have a little boat. 5 zloty, that a $5-- and I had-- I take you over to the other side.",
      "word_count": 38
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Six-- six can go in.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I don't have, but the two brothers Torffman have the money.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "They pay the money.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] And I take them to the river.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And nobody's there, no soldiers.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Daytime.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Daytime.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And the river is a little frozen already.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "It's cold in November.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "There's very cold.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Before, got in 6.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And I'm all the time they [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "I tell maybe the brothers, maybe something happened.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] the families, go over.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 7,
      "text": "Go over there.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 8,
      "text": "Come back with the boat, the boy.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 9,
      "text": "You take the other five together with me.",
      "word_count": 8
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 10,
      "text": "In the middle of the river, the Germans start shoot.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I jump in the water.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "My luck, [INAUDIBLE] I'm not a swimmer.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I go like this in the water-- ice.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You have ice.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And thank God, I went over.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Was God--",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, the water it go to there.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "And there, I take my shoes off [INAUDIBLE] water.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And the stocking get frozen right away.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "And stayed maybe 10 minute.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Everybody got away from there already.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Everybody is.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Maybe 10, 15 minutes, a-- a soldier with horse, a Russian soldier, comes over, takes everybody [PAUSES FOR 3 SECONDS] to a-- a little house.",
      "word_count": 29
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "There are maybe 50 people in this house.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "A lot of communists escaped from the prisons, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "I see straw on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "And people sleep there over at night.",
      "word_count": 7
    }
  ],
