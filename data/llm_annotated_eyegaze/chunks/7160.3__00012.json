{
  "stem": "7160.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We used to-- about 100 people, they used to live in a thing, beds up and down, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "The women with children and the older senior citizens, they used to put them in a cabin, three or four people bunk beds.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "My oldest daughter, she was a colic baby.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "She used to cry a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I don't know what was wrong with her.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "She used to cry 24 hours a day.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So we went on the ship that-- inside the ship.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "After one or two days the women right there, they're all senior citizens, was screaming at my wife, says kill this little baby.",
      "word_count": 23
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We cannot sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Day and night, she cries, blah, blah, blah, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "My oldest daughter.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So my wife, she says to me, come out and says, Albert, she says, you know, I need a little sleep.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Why don't you take the baby once in a while?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "You know, to watch the baby?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I say, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I do that.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "So I'll go to your room.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And over there was a sign on the door. 'Not allowed' was written in English.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "None men allowed to go to where the females was.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "Because was a big ship, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Were about 2,000 people were inside the ship.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And all coming to America.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "They are from different nationalities.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 17,
      "text": "And the headmen, they want to transfer-- [INAUDIBLE] they call him, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 18,
      "text": "He was a British guy, and I know him from the camp before.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 19,
      "text": "In the same time [INAUDIBLE], before that, they hang a couple of British in Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 20,
      "text": "They hang a couple of British soldiers.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 21,
      "text": "And he was so much against the Jews, that guy, the headman.",
      "word_count": 12
    }
  ],
