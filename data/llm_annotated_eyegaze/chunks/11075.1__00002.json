{
  "stem": "11075.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And my other sister, she got married, and she moved to Stanislawow.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "That's in-- in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And then-- then-- then Hitler came in.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "They said, you know, that it's impossible, you know, that's-- right away they will take men.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So my-- my brother-in-law, he had a chance.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He-- he ran away to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "But-- and my sister was with a small baby, she was still in Stanislawow, because then we were in the ghetto, you know, when, you know-- My father tried to get somebody-- a Pollack-- a Polish man.",
      "word_count": 37
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And he brought her home, you know, to be with us.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Did you experience any anti-Semitism?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And-- when we had the store-- when he had the store, you know, I was at the time in a uniform-- in a Polish uniform.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They came-- one Pollack came at night, you know, and he broke the window from the-- from the-- from the basement.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And he went into the store, and he wanted to take out everything.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "But-- and this-- this night, you know, I was home.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I was home, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I went to him, you know, and I gave him a couple of times-- that he will remember forever.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "You know, I wanted to kill him, because, for sure, in the cold, I will win.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Because he tried, you know, to-- the uniform, the uniform to take it, you know, to rip off from me, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And that's not allowed.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And that's [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "The president, Marshal Pilsudski, was that time, and he was not an anti-Semite.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "When Hitler came to power in 1933--",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, yeah--",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "As long as he was in Germany, it was OK.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Because as long, you know, in Poland, it was OK.",
      "word_count": 10
    }
  ],
