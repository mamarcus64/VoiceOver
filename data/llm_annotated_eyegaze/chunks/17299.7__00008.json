{
  "stem": "17299.7",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 21,
      "text": "He is Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 22,
      "text": "You want to talk to him?",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 23,
      "text": "So you went to meet the prosecutor?",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So I meet the prosecutor.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Benjamin Ferencz.",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "What I knew about Jost.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "What I knew about Sandberger.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And what I knew about Strauch.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "All of the mass killings, what I have witnesses and what I know about.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "He said, are you sure?",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes, I am sure.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "So and so and so.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I worked in the motor pool for the Gestapo.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "In the [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "So he said, can you stay here for a few days?",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "We want to talk to you.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "I said, if I have to, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "Well, we can put you in a hotel if I have to.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And-- and the girl said, no.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "You don't have to put him in a hotel.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "I can take care of him and make sure he stays here.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The next-- the next day, we started already.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "But they-- it was not a deposition.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Let's say for the next two weeks I had an interrogation going on.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "In-- in a-- in a separate rooms where the prosecutor were.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Not in-- in the courtroom.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "What they wanted me to do, go in the courtroom, listen to it, and tell them where they makes mistakes or what I remember, and give them the information.",
      "word_count": 29
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I knew three of them.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Two-- let's say three of them.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Two of the defendants.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "One was Dr. iur.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Eduard Strauch.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "The other one was Dr. iur.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "Sandberger.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "From Riga was Dr. iur.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "Rudolf Lange.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 8,
      "text": "They were lawyers.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 9,
      "text": "And the-- one of the defendant, Heinz Jost, I only have seen once.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 10,
      "text": "He was a general.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 11,
      "text": "He came to Salaspils when we make the mass grave.",
      "word_count": 10
    }
  ],
