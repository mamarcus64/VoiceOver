  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "The 7th of May, we had to move in to the ghetto, which were two streets hermetically sealed off with barbed wire.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And we were, in a way, quite lucky because we were two and we were moved in with a family of four.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "So we're only six in the room.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "There was only one bed, but we slept on the floor.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well, that is a different story.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yes, fine.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Because I must then tell about what happened to the Hungarian Jews, Jewish men, which, which is a very important and interesting point.",
      "word_count": 23
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And we were in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We were women, children, and men over 50.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Now I, perhaps I come to that point about my brother.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I see.",
      "word_count": 3
    }
  ],
