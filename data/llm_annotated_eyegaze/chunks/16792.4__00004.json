  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I, I was crawling, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was crawling.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Not only crawling, I was-- it took me-- it took me a long time till I got to him.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And it took me a long time till I got him out.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I got him out.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And I received a big [RUSSIAN], a, a decoration.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "[RUSSIAN], one of the biggest [RUSSIAN], before [RUSSIAN].",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "[RUSSIAN].",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "It's a very big [RUSSIAN].",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "You don't have too many generals get this [RUSSIAN].",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I was already a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "That's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Major Kuznetsov, a major, a major.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He was [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He was a big, big officer.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "1943.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Was not in a battle at all, because we was on the front.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And we mined-- we put mines-- I didn't put it.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "But we have special people which belong to the mine group.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they put mines that the Germans, when they want to come over on this side, they blow up.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "That's all what we do.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "This the mine people especially.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, not hear.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "You see, we-- between-- the distance between the German line and, and the Russian line is different distances.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Some distance is 10 yards.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And some distance is 25 yards.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And, and in the line, in the line, the, the real soldiers, the regular soldiers, stay in this line.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And in the line is special bunkers on the side, which the soldiers, if he is not on patrol, he sleeps there.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And our people are behind the line.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Let me see, like we and [NON-ENGLISH] is, [NON-ENGLISH] is reconnaissance groups.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We stay normally with the [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "For [NON-ENGLISH] means-- [NON-ENGLISH] is a, a big office from the commander from the [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "From the-- a [NON-ENGLISH] is a, is a-- higher the battalion.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "Each [NON-ENGLISH] has three battalions.",
      "word_count": 5
    }
  ],
