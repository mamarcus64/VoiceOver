{
  "stem": "8233.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "His name was Simon Goodman.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "He recognized me from France.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "And he threw-- over the wires, he threw some shoes.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "Each day, he threw something else.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "And when my sister went to the hospital, she survived only four days.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "My sister went to that [NON-ENGLISH], this hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And I wanted very badly to see her.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "One day, I got somebody to take me there.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And I was free from work because they're kind of-- some of the people respected my mother and me, maybe because they didn't have a mother.",
      "word_count": 26
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "[SOBBING] So they kind of regarded us, you know, better.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I mean, they, they liked us.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "So they let me go to the other camp to see my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "When I arrived, the-- to the [NON-ENGLISH], they told me, well, your sister just died.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "[SOBBING] I, I couldn't forgive myself for not being there before.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And I ask, I want to see her, please.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And they said you cannot see her.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "She's better off.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "You know, they took-- the, the nurse took me around.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "She said, believe me, she's better off.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "You should be happy that she's gone.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "I said, but I want to see her.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "So they took me to a kind of a-- it was like a wooden shack or something.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] And they said, well, she's there.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I said, I would like you to open the door.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They said they don't have the key.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So I looked-- I said, can I look through?",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And I looked.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I see-- I thought I seen my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I see so many [SOBBING] women, so many people, one on top of the other, with their eyes open, [SOBBING] with their arms spread and leg one on-- I thought I saw my sister.",
      "word_count": 34
    }
  ],
