{
  "stem": "14463.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I had a bag of rice and a bag of salt.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Heavy like hell.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, we got it down and we got it all down quietly, and we started to move to the city.",
      "word_count": 20
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "He said, [POLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Where do you want to go?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "Give me the address.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "I said, let's go and I'll tell you.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "I said, to tell you the truth, I don't know where to go.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "I've got no place where to go.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "So he said, it's quite obvious to me, he said, you're Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "He said, there is a house in Krakow which looks after the refugees for a few days until he gets himself sorted out.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "I said, that's where I want to go.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "And as we are going like this, it was starting to drizzle.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "It was raining.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "And like this.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "And a woman was sliding up to me.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "She said are you going to Krakow?",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "Can I come with you?",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "Because it's too dangerous for women on their own to go, to walk to Krakow.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 24,
      "text": "I said, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 25,
      "text": "I look at her, and she looks at me, and she said to me-- and I look at her and I said, [NON-ENGLISH SPEECH]?",
      "word_count": 24
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 26,
      "text": "You Jewish?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 27,
      "text": "[NON-ENGLISH SPEECH] means my folk, my people.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 28,
      "text": "She said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I said, I'm going to ask you a very stupid question.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I said, I've got a cousin which I believe has lived through the war.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He was in the partisans.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "His name is Joseph Goldberger, and he's a dentist.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Said, I know him, and I know where he lives.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And she took us to my cousin's place, in the middle of the city, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I knock on the door and he looks at me and he comes out.",
      "word_count": 14
    }
  ],
