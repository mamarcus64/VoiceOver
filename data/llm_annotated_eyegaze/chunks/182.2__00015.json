  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "We never ate it.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Because we were-- we were keeping it, that when they were taking-- if they will take us, then we should have it for the trip.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "But the Russians came sooner.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And even though the-- the Germans told us that, don't be so happy because we have the possibility to kill you just like that in two minutes.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "And you're not going to survive.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "But by the time the bombs started to come real close, you know, they were so worried about themselves that they were running around like chickens without heads, trying to get little carts and push carts and go someplace.",
      "word_count": 39
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And they left us alone.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "And May, I think it was 15, or the fifth, I don't remember exactly, we were liberated by the Russians.",
      "word_count": 20
    }
  ],
