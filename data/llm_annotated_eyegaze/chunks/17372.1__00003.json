{
  "stem": "17372.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "See, the last time from the beginning of the war, I play in Cracow with my brother George in [?",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Wierzynek, ?] one of the best restaurant.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And German were already there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "One German in uniform-- Polish-- in German uniform, spoke to me perfect Polish to play Polish anthem.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I said, I've forgotten.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] Maybe when I play, he would shoot me.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I play piano, accordion, and bass, double bass.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I play a little piano, but I play piano, accordion mostly.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were, were liberal, but keeping the-- all holidays, Jewish holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I was going almost every Friday with my father to synagogue and Saturday.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And brother of my father was a gabbai in synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And we had separate pan-- pots for-- in place for meat and for milky products-- quite strict, but semi-religious.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "My grandfather was quite a religious man.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Sorry, how--",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we had the Pesach all together.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Or every Friday, we had a dinner-- family dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Always somebody was missing because brother were overseas.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "One played in Vienna.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "One played in Berlin before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Only in Poland-- only in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I had a-- I could have a contract with Josephine Baker in her band but-- didn't want to let me out because I was in the military age.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "So they didn't want to let me out of Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Before the war, I play in two films music and all kind of venues.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't remember how much.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was quite, quite a good payment.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I-- of course, I give everything to my parents.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "While we away-- was other state, I sent by post to my parents.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I play in Kyrnica very famous place of Jan Keipura, the Polish famous singer.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "I was five years ago in Poland to see the place.",
      "word_count": 11
    }
  ],
