{
  "stem": "17.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And everybody had to go run downstairs, down to the street.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "I tried to hide.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "And, and this SS man noticed me, so he hit me.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "I had to join the rest.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And we were chased straight to the [GERMAN], to the cars.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And this time, I was already inside.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "I was on my own, without anybody protecting me.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "I was inside, it was full, crowded with people screaming, crying.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "We knew that's already the final hours.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "That was nothing-- no appeal from it.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "People were squished, just like sardines in the box.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "And, and, and people were screaming, crying.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "Some, some were getting crazy completely.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "Some were vomiting.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "Some were-- already a smell of human bodies.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "And I knew one thing.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "I wanted to live.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "And there was my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "His name was Paul Haber.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "He liked us, we liked him.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "And I told him I will try to escape, to, to, run, run away.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "He said-- definitely he encouraged me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "He said he will help me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "He had a pocketknife.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "He said he will cut the barbwire, which was covering the, the small opening, the small window in this cart.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "And he said he will do anything and encouraged me absolutely to jump out.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 39,
      "text": "We were not too far away from the station, maybe an hour in the train, not too far away.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 40,
      "text": "But the train, nevertheless, train was moving.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 41,
      "text": "And he managed to, to, to move this wires, to cut it down.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 42,
      "text": "And he said, jump, put your feet first.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 43,
      "text": "And he pushed me out.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 44,
      "text": "And here, you know, the train was moving, probably was on the curve.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 45,
      "text": "It was November 11, [PAUSES FOR 3 SECONDS] 1942.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 46,
      "text": "It was 3 o'clock, maybe 3:30 in the afternoon.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 47,
      "text": "I jumped on my feet.",
      "word_count": 5
    }
  ],
