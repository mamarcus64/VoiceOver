{
  "stem": "16790.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "And within a very short time, we were in the car.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "And he was taking us home.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And when we got home, we had a Christmas tree waiting for us.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And my uncle's best friend, Sam [?",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "Reich, ?] was there acting as Santa Claus.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And we got presents.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "And we were really made to feel welcome that we, we were here.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And it was a joyous occasion.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "That is correct.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My family is not very emotional.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "The only time I really recall my mother being extremely emotional is when my father passed away in 1937 and then when her second husband died.",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Because she said it brought back so many memories of her first husband.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "But they weren't-- I don't recall them being very emotional, no.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Eight.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Eight and a 1/2.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "My mother gets a job in, in New York City, working in the garment industry, sewing collars on t-shirts for 25 cents an hour.",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "My grandmother becomes a cleaning lady.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I stay in Hackensack, New Jersey, with my uncle, who-- I become his ward.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "In other words, he becomes my guardian, adopts me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And I stayed in that household-- well, he left for World War II as soon as that broke out.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And I stayed in Hackensack and lived with my two cousins, Arthur and Steve Gould, and stayed there until after World War II.",
      "word_count": 23
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Went to high school in New York City.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "Live with my mother for four years.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And then my uncle got a hold of me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And he said, you have now finished.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "You've graduated high school.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "The day that I graduated high school, the Korean War broke out.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And he said to me, what are you going to do now?",
      "word_count": 12
    }
  ],
