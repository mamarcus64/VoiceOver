      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "He was the peer student selected from the senate of the students-- peer student of the year.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "He had so many-- he had so many degrees and so many awards.",
