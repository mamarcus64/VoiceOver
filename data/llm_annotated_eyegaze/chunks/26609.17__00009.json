{
  "stem": "26609.17",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Why she was there, that's a different story how I found her.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "That's a different story.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "But she was there.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And I didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And she didn't know that I-- I didn't know that she's alive at all.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And she didn't know that I am alive.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "But she was at that orphanage.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "How she-- later tell me how she came to that orphanage.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "She was not at all in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "She was by different people taken out from one place to another.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "She didn't want to go.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "She said, Jesus Mary, the Jews will kill me.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "That how she was brought up, that Polish family.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And she was in the churches every day for hours.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "Till now, she had on her knees, marks.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "She had sores from kneeling on the cold, stony floor in the churches.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "Till now, she showed me, Mom, that's from there.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "A mark, and it was whipping, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Never seen a doctor.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But fortunately enough, it's all right.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Nothing happened to the bones.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "So I couldn't find her, although she was not far from me.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And I went back to the Red Cross.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And I begged that maybe you can find-- no, impossible.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I tell you what, they say.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "We have here about 80 families, Jewish families, survivors, who want to cross the border.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "That was a border of Czechoslovakia, Kudowa.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I remember all the places.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Kudowa, I don't think anyone else could remember that all.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "It was named Kudowa.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And she said, Kudowa is a border Czechoslovakia and Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And that-- you know, the Transylvania is under eastern Polish border, southeastern.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "If you take those people through Kudowa, they want to immigrate to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "But Poland doesn't let them out.",
      "word_count": 6
    }
  ],
