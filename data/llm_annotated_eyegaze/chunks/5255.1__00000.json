{
  "stem": "5255.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Maurice Moore.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I was born in Warsaw July 15, 1923.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "M-A-U-R-I-C-E M-O-O-R-E.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name in Poland was Moniek Miodownik.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "That would be spelled M-O-N-I-E-K M-I-O-D-O-W-N-I-K.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Now I'm 72 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The slight confusion?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I-- for some reason-- I don't know if I am right of-- or the records of the camp that I received just a few months ago, while I was there in-- in Auschwitz.",
      "word_count": 33
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "To be honest with you, after the war I just ideally said, I was born July 15, 1923, and I kept it on.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "The record says that I was born in August of 1925.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I really-- I really don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I remember when I was a very little child, we used to live in Warsaw in a non-Jewish neighborhood.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "When I reached school age we-- my father and mother sent me to a religious school-- a religious day school-- where we learned half a day English and half a day Hebrew.",
      "word_count": 32
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "By 1936, the conditions-- political conditions-- and anti-Semitism was so pronounced.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And it was almost dangerous to live in a non-Jewish neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And we moved into a Jewish neighborhood, next to where my grandmother lived-- on Lewki 34.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember that age.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Most likely, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, every morning we used to fight.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The Polish boys used to tell me that the Jewish boys killed their god.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And that's what the priest told them.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And as a result they were angry, although we grew up together and we were friends.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And all of a sudden things changed.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "But they started going to school.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And we got stopped going to school.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Things changed entirely.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And we were no more close friends, although we were at times friends.",
      "word_count": 13
    }
  ],
