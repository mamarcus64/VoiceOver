{
  "stem": "8072.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "It was just maybe 8 kilometers, or something, 8, 10 kilometers outside of Krakow.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "It was a labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "In fact, we got there by train.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And from train-- from the train to the camp, I don't know, it was a forced marched.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how many kilometers, one or two or three.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "And I remember I tripped and I fell.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And my brother-- my brother grabbed me and picked me up.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "And when we got to that camp, you know, we had to line up, and line up fast and everything.",
      "word_count": 20
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "And somebody didn't line up.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And they wanted you to know that you're in a camp.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "And one man didn't line up so good, and he was shot right in front of us.",
      "word_count": 17
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "He was shot right in front of us, to make you think, I mean, you better watch out or you're going to be next.",
      "word_count": 24
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Mahel and Dovet.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "It was a short distance.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "It was just like a freight train, yeah, short distance.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "In camp?",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "On the train going--",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "On the train we were just herded in like cattle.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "They didn't want to leave any space, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "They didn't give me you a chair to sit on, no.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Nothing pleasant.",
      "word_count": 2
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Nothing pleasant, because I know one day, I was-- even myself at that age, I was caught-- and I was for labor and before they did that, I was in jail for a day.",
      "word_count": 34
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "You know-- the first time I was ever in jail, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "In Poland, you know like-- it was a regular jail.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "You know, I remember-- there for a day in jail, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Basically if we had any money, we took it with us.",
      "word_count": 11
    }
  ],
