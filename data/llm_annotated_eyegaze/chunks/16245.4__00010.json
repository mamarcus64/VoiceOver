  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "You went to a kibbutz and you the soil.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't my idea.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "There were other things that I objected to, such as the use of Hebrew, Hebrew writing in particular.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "To me, that was going back.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "I thought that Latin script was efficient enough.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "I didn't like this idea.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Ah, very happy that Israel is there.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "If I didn't live in Australia, I'd live in Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "But I live in Australia and it is my home.",
      "word_count": 10
    }
  ],
