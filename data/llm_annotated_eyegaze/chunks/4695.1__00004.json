{
  "stem": "4695.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Because I, I learned my trade also as a [NON-ENGLISH] and this was more in the hands from Germans and Polacks.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Like special finishing, special painting.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Furniture, anything, you see?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But this furniture was very, very dear, very high class, and this was more concentrated in German hands.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Because we have in our city-- our city was divided.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Was close to a million population density of Lodz before the war.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I like to note this.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Was 275,000 Jewish population, around 300,000 German population, and the rest Polacks.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So we have a balance in this city.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And the very, very-- the industry was--",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So I was-- by the work I was more with the-- with the [NON-ENGLISH], the non-Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Then as a young boy, I belong to a sport club, TUR, T-U-R.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And I must pronounce this in Polish [POLISH], U, [POLISH], R, [POLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "This mean that TUR, this was under the leadership from the Polish Socialist Party, but this is a separate thing.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "This is only for the-- for the youth, this sport club.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "But there was sort of hate between the socialists and the communists.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But this was special that the leadership from the socialism, the PPS, Polish Party Socialist.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I don't know because everybody if they are, they was figured out because the first name.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we was very pleased, because this was the avant-garde from Polish youth.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, the latest years, even my life was saved from people who belonged together with me to the TUR.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "A small group, but we don't know how the future can bring together us.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Till--",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- till my father notice that I go away Saturday that I belong to a Christian club.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Was a big scandal.",
      "word_count": 4
    }
  ],
