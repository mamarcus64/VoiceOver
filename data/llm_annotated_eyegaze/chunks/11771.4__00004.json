  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "They [PAUSES FOR 4 SECONDS] concentrated the all people who they catched who were not from Voranava in a movies-- in a-- in a movie hall, a cinema.",
      "word_count": 28
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "But on the way, they took us in into their Kommandatur.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And it wasn't a SS unit.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "It was a communication unit, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Translation, radio, because I saw on the-- on the signs of their-- of the cloth.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But from sadism, they helped the SS on that night in this action.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And from sadism on their own, they put in whoever they catch-- before they putting them in in the cinema, with, with the second-- with the-- with the rest of the catch, they put in in their headquarters.",
      "word_count": 38
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And they start to beat us.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They catch one guy from Ejszyszki, Teivele Blacher, who is also on the picture there in the [YIDDISH] with me.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And they undressed us.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And they put such a big-- a small table in the middle, such a little area table.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And they undressed us again.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And they saw I'm still, I'm still wounded.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And they started to ask me, Where are the scratches?",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Where is the wound under here?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I got still the wound on this little patch from [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Ah it happened in Ejszyszki.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Have to hide from them.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "So I am in the soup.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I can-- can I save myself?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And they undressed us and put us on the-- on a wall.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And one by one they're putting on the bent-- the bench.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And they start to beat with sticks, with whips, whatever everybody can catch.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Four people, 1-2-3-4, 1-2-3-4.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "They start beating everybody like.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And the skin became like a pipe, all colors.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The Germans.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They took first from the oldest one.",
