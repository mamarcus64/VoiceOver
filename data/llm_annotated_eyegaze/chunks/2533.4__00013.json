{
  "stem": "2533.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And she told her that I survived, and she had the address from Frankfurt.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So while she was coming to Germany from Poland away, she got to Frankfurt to the Hildemanns, and the Hildemanns told her that I am in Wetzlar, in that displaced persons camp.",
      "word_count": 32
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "So she came over and tried to find me there.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And she went to the administration office, but it was a Saturday again.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "But she had to go through I don't know what to tell her to look through-- she already knew, you know, not quite maybe the name or something.",
      "word_count": 28
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "But when she looked through and she said, Ordynazki, and she-- she-- that's her.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And then the way she came over, the cousin was with her.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Her cousin was with her.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They were-- he was in Warsaw, and he survived, too.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And he came in.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And it was maybe a day even before I married-- it was the day before I was going back to Poland to find somebody.",
      "word_count": 24
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "It was a Sunday.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And I was going on a Monday to Poland by train.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And he came in and he said, he's got greetings from Zelda, and all that.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "I didn't recognize him right away.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "He suddenly turned around in the profile.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "He was 14 years when I last saw him, and he was 19, nearly 20.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "And he had a big patch of gray hair because he was buried under rubbles in Warsaw, three or four, I don't know how many days.",
      "word_count": 26
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "And when he got out, his gray hair were there.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And when I recognized him, I said, Henry, it's you.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "And then Zelda was outside.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "She didn't want to come in to shock my straight away.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "And then he called her in.",
      "word_count": 6
    }
  ],
