{
  "stem": "15028.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I was smaller.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I was smaller, but I had-- I grew here, in the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Small and skinny, and whatnot.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And I had a broken teeth.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "They never-- OK, three teeth, and my teeth were knocked out.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "I selected.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And they were counting for the going out to work.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "And as they select us there, about 20, 30 people, what were already they selected to go-- well to-- for their death, I start screaming.",
      "word_count": 25
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "I saw the bathroom.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "Just screaming, like a wild Indian, I would say today, screaming.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "I had a bellyache.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 15,
      "text": "Ooh, ooh.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 16,
      "text": "So we couldn't-- you know, the SS man was there, the kapo.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 17,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 18,
      "text": "I should go into the bathroom.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 19,
      "text": "Bathroom, I went in.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 20,
      "text": "There was a barrack.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 21,
      "text": "And there were dead people.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 22,
      "text": "And they had my number taken already, 3642.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 23,
      "text": "Write that number down.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 24,
      "text": "There it is I changed the number.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 25,
      "text": "And I went into the bathroom.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 26,
      "text": "There was a window.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 27,
      "text": "Jumped out through the window.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 28,
      "text": "Nobody there.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 29,
      "text": "It's in the camp.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 30,
      "text": "And went over to one of the dead people, took off the my jacket, and just throw it down there, underneath and took his jacket, the number, and cleaned myself up and just mixed in to the-- with the-- with the people.",
      "word_count": 42
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 31,
      "text": "And right away, I somehow worked myself in and went to work that morning.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 32,
      "text": "Another way I stayed alive.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The number was written down. 3642.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "The 30 people what they selected for the-- for the crematorium or for the death-- death, they put on the numbers.",
      "word_count": 21
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So I know all this, you know, was going on.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So that's-- then I saved my life and I went into work.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And then it didn't take long from there.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "This was, already, late.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Late, late, late. in April, April, 19--5.",
      "word_count": 7
    }
  ],
