{
  "stem": "6076.8",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And of course, I took him home-- took him to [POLISH] five and Tobcha met him.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "It didn't take long.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "Even Tobcha promised me-- she told me she will never get married again.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "She didn't-- she was too injured.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But I told her, you're so young, and why not?",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "There are many young girls in your age survived.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "So whatever you lost, build a-- build a new life.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And she listened to me.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And Joel and Tobcha got married.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And the day when they took [HEBREW] just with a few people, we got engaged with the words what Herb told me.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And I told Tobcha, and she says, he's a wonderful man.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I-- his family is wonderful.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I got to know his family.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And she was very happy that he is brought up from a nice home, which she got to know him through the cousins, the background, which was very important to my sister.",
      "word_count": 32
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And, and then, we both two couples got married.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "Tobcha became pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Three months later, I became-- no, six-- two months later, I became pregnant.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "That means three months after I got married, I became pregnant.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I was married in January 1946-- January 2, 1946.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And I came to Augsburg, and we lived with the family, with his brother.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "With the aunt, we visited.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Of course, Tobcha got an apartment from the committee not far away.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I had one room apartment but very happy-- very happy as long as I had Herb, my husband, together and my sister.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And then, I heard from Sam.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "Of course, I started to find out from the committee, from the Jewish committee.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "They had all the listings that Sam survived, you know, and he's in England.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And he-- they took 500 youngsters, and he was among them.",
      "word_count": 11
    }
  ],
