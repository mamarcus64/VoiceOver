{
  "stem": "11472.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "My aunt Chana was the first one up there.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "They pushed me up, then my cousin Sharma went up, and my aunt Yetta.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they-- and-- and who remained?",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It took us a long time.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "She couldn't open up, and she's yelling for her brother.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And her brother is paralyzed-- he's in shock, can't move.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "All of the sudden, we hear my Uncle Sam is back and the veterinarian.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I hear my grandmother is alive, too.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "My aunts are excited.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Their mother is alive, and I'm still crying.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "My mother, they must have shot her.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, it went through a few hours until we got through.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And this was our lock because had we come out during the day, the Ukrainian police were watching the exit.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "The first entrance, they would have caught us.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "This was night already.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "We came out at night.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And my grandmother in order not to endanger our lives pulled out her sick-- [NON-ENGLISH] helped to lift [NON-ENGLISH] up, and she's carrying a man of 20 years old.",
      "word_count": 29
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "But he's paralyzed.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "He's in shock, and she's dragging him.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And she and her son-- she didn't want to endanger our life-- she told us to go one way, told my uncle Sam to go and tell my father and my grandfather and my uncle Nisel what's happened.",
      "word_count": 38
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "I and Chana and Yetta and Saul went in a different direction.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "My aunt Chana worked for a woman that she-- older woman, a peasant, she used to do knitting for her.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "And she said, she'll go.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "She'll take us to Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "Mierveldt.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "All of the sudden, we hear the Ukrainian police.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You're running like on an open field?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it's in the field.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "It's in the field.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "My aunt told us to lay down.",
      "word_count": 7
    }
  ],
