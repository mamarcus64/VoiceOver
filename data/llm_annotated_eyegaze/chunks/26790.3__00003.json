  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "I would like it if you will be-- take this photo from this little paper.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "Very interesting for me-- and I start to work.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "I was working in a factory. 15,000 people was work in the factory, [INAUDIBLE] factory. 15,000 people.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "And my Leja, she start to work in a little [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "I was such a good worker-- the factory was building flats-- they put me on after a few months, they put me on the list to the capital to get a, get a flat.",
      "word_count": 34
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 41,
      "text": "I was a good worker.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 42,
      "text": "And we start to build from nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 43,
      "text": "We see anything for sale in the shops, we bought it.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 44,
      "text": "Even if you don't need it, something for you, but in the Russia, bought something like that.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 45,
      "text": "If you don't, if you don't need it, you buy it.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 46,
      "text": "Because if you buy something like that, it's glass.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 47,
      "text": "You don't need it, the glass, but you keep it.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 48,
      "text": "When you're needing something else, you go at the bazaar or the market, Bob, I've got something which I wanted, and you wanted the glass, we changed it, or I [? pay ?] you something.",
      "word_count": 35
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 49,
      "text": "That would-- We have a big basket full of goods prepared to get the flat and to shift it in at the flat.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 50,
      "text": "[INAUDIBLE] we hear France are under occupation from Hitler without shot-- any shot.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 51,
      "text": "Romania, Bulgaria, Yugoslavia, all them, already German got up.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 52,
      "text": "My Leja said to me, Mojsze, look like the war will not be-- will not finish so fast.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 53,
      "text": "Let us got married.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 54,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 55,
      "text": "We got married.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 56,
      "text": "I went with my Leja to the register office.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 57,
      "text": "We pay two, two rubles.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 58,
      "text": "We got married already, like register office.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Next day, in the next day, my Leja told me, Mojsze, that's not a marriage.",
      "word_count": 15
    }
  ],
