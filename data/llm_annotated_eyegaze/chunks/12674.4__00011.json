{
  "stem": "12674.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And my father's sister managed to get out-- [BACKGROUND NOISE]",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "In 1938-- it's downstairs.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "That, that-- she got to Israel in 1938.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "She was on an illegal transport.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "She managed to get there.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "One of the, the-- my father's-- one of the brothers from, from Leipzig managed to get to England.",
      "word_count": 18
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And he was interned as a German national on the Isle of Man as a Jew in England during the war.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Speaks volumes for the state of the world.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And, and everybody else was sent away.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "One uncle managed to get to Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And, and he was in, in, in Lemberg, which was Lwow.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And then after the war, we found out Lwow was the Russian side.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "But he was-- did not survive.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "His wife and his son were sent-- were sent-- they were-- they were all sent away.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "Every week, a thousand people were sent away, week after week, after week, after week, after week for two years until nobody was left.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "And you had no recourse.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "And you had no opportunity.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And you had no anything.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Theresienstadt was a fortress that was built by the-- it was named in honor of Maria Theresa.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It had a garrison of horse soldiers in it.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It was about 40 kilometers outside-- northwest of Prague in-- very close to a place called Litomerice, which was on the other side of the Elbe.",
      "word_count": 26
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Theresienstadt was on a river called the Eger.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And the Elbe-- on the other side of the Elbe was the Sudetenland.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "It was, like, a 20-minute walk from Theresienstadt over the fields, which we did after the war when we could get out.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "But-- so that was in Theresienstadt.",
      "word_count": 6
    }
  ],
