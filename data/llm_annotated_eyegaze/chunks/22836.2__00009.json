{
  "stem": "22836.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 16,
      "text": "We still were strong from the air or something-- from the cold weather.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 17,
      "text": "That's what we eating.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 18,
      "text": "When we have our-- our 60 pounds, that wheat, then we surviving.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 19,
      "text": "We have something to eat.",
      "word_count": 5
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 20,
      "text": "Like, like, let's say China eat rice, and we eat the-- and we eat that wheat.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 21,
      "text": "And it was good.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "They don't ever to hide.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "We were staying on-- on the roof-- mostly on the roof.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "We can't get in.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "We stayed there on the roof.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And mostly, they have some shacks in the back, we were staying.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "They're afraid to keep us in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "That-- that was not keep on in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I heard some people, sometimes they hid in the barns with animals.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "That was good.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "That's where we went after that.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "After the woods.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "After the woods, we went there.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "In the woods, we was a long time in the woods.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "We was a long time.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I think we were holding up a good couple months.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "After that-- after that we hear shooting-- shooting.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "We shoot.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "And this is winter-- winter, and it was so strong, the snow, and the-- maybe below-- 10 below degree.",
      "word_count": 19
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "It was so cold.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "No, I used to have-- I always wear-- I wear a shoe-- Ukrainian shoe-- not-- not regular shoe, because regular shoes, they-- they find out you walking.",
      "word_count": 27
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "Then the Jew-- then a Jew was walking.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 10,
      "text": "They-- they go right to you.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 11,
      "text": "And I have-- and I have a cover, a-- a Ukrainian cover.",
      "word_count": 12
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 12,
      "text": "And on the bottom I have like from sheep, that skin.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 13,
      "text": "And that was warm for me.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 14,
      "text": "It was warm, and my wife, the same thing.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 15,
      "text": "And everybody, we survive.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 16,
      "text": "Oh, but this not-- when the point is, we hear shooting.",
      "word_count": 11
    }
  ],
