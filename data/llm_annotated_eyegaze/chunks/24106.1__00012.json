  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "And that's what we start our journey.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "My mother and my-- and my younger sister.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "My middle sister wasn't-- at that time when the war broke out, she wasn't in Rowne.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "She was working in a place.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "They used to ship in films from Russia, and she was examining those films.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Quite a few young girls worked there.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "So she worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And she was very good, so they gave her like to go to a-- in Russian you call this a [RUSSIAN].",
      "word_count": 21
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "Like in a hotel in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "That was near the-- the Romanian border.",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "She went away on the-- on June 14.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And on June 22, the war broke out.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "She couldn't come back, but she came back when the-- when the-- when the German was there.",
      "word_count": 17
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "Somehow she came back.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And a neighbor of ours-- she was hiding by-- by Christian people.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "So she told us the story.",
      "word_count": 6
    }
  ],
