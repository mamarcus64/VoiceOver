{
  "stem": "8753.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "And then she would make fish and chicken soup and so forth and cholent many times.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "That's the-- it's like a stew.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "You put it in the oven Friday.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And Saturday, for the noon meal it was ready.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "Now, for the holidays, there were more goodies.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "I remember for Rosh Hashanah she used to make some dough dipped in honey.",
      "word_count": 14
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "This was-- this was a delicacy.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "And she used to make a gefilte fish and bake all kind of sponge cake, a honey cake that was for the holiday.",
      "word_count": 23
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "And, of course, cooked the-- like a pot roast sometimes and chicken.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "We always were celebrating the our-- our own family.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We-- somehow we didn't have the style of inviting people for the holidays, especially the Seder.",
      "word_count": 16
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "We-- my father conducted the Seder just for our own family.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "That was the style.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "Somehow, at least in our town, we didn't invite family.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "We would give the donations.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "Would give money to the rabbi in order the poor people should be able to make their own Seder, to prepare their own food for the Seder.",
      "word_count": 27
    }
  ],
