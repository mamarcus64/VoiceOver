{
  "stem": "1929.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "I used to love-- my maid used to read-- I think we read, twin?",
      "word_count": 14
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "No?",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Sawyers?",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "No, that's not the name of it.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Sawyer.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "You know, about the Indians and Injuns.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Injuns.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And-- oh, I loved those stories.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "In the forest and carrying guns.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "We used to clip coupons off of coffee and things like that and send in for prizes and things like that.",
      "word_count": 21
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I Went to movies.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "I went-- I saw No, what's the-- they're playing it right now.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "The musical.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "What is the name of it?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "I saw I went to the circus.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "The thing that stands out in my mind is a guy with no arms being able to fire a rifle with-- with his feet.",
      "word_count": 24
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "That was in Piotrkow?",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "It was a town of roughly 60,000 people and about a third of the population was Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I think a little bit under a third.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "Maybe like 18,000.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "And for the most part, it-- well, I know about it now.",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know it then.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "But it was-- it had a lot of cultural things.",
      "word_count": 10
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "You know, we had all of the different clubs-- from chess club, to their own band.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "Lots of different famous rabbis, lots of learnings, their own school systems.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Lot of cultural thing.",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "And many different diverse organizations, you know, Jewish organizations-- from the Bund, who were socialists, to the ultra conservative, to-- There was lots.",
      "word_count": 23
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Jewish newspapers.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "I don't know that from then.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "I just know it from now.",
      "word_count": 6
    }
  ],
