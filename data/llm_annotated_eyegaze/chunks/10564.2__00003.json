{
  "stem": "10564.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No, this is in the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No, we couldn't go out.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "This is with the, not the Arbeits, the B, the B section.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And we crossed to the A section because they broke the wire already.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "We crossed through.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "We went to the building.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And when we walk up, we heard baby crying, crying, screaming.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And smell.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "When we went up, we saw hundreds of babies of the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And he told us to this, I want you to take two babies out and put it on the sidewalk, right by the house.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Put them separate.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So I said this is [NON-ENGLISH SPEECH].",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I said, this is impossible.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "He said, you dirty Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "You dirty Jew, you say something, I will kill you, and a gun right to my temple.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "But I didn't say nothing because I was more concerned about that looking on a dead body, you know, like somebody, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But what we found out later, that we will take the head from that side, and the head from that side.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So we can have it both head exposed later, both head exposed, or it was a little hard.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Supposed to go that just the head should be exposed from both baby, not the head together.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Carrying baby down, 3/4 finished.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "There was about 400 babies there, 300, 400.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Carried the baby down and put them right on the sidewalk, like the sidewalk, like this, sidewalk all the way lying this way, lying this way, lying this way, all the way down.",
      "word_count": 33
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And the building was over 100 feet long.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Everything was occupied.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "He took a gun out.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And he shot each baby in his head, killed them.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "Loaded magazine and killed them.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Loaded and killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And we saw it.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And we stopped and screamed.",
      "word_count": 5
    }
  ],
