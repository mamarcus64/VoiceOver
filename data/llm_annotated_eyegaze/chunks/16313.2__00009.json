{
  "stem": "16313.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Polish-- Polish soldier, [INAUDIBLE] find [? up and ?] got some papers.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I got this-- this-- this paper, I'm in the-- this-- from the-- some paper from Poland, [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They put the physical exam.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They don't care.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They put my physical.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "This by routine.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Just do the by routine.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And they ask you questions, and they all kind of things, take it-- talk about this and this.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And they putting a gun to the head, and you must talk about this.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "All kind-- and sign papers.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "You guilty for this?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "When you-- you must sign paper.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "You guilty for everything.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "You don't sign the paper, guilty, you kaput anyway, so anything what they tell me sign.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I don't know the Russian language good.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "I just understand a little bit.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "What they tell me sign?",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I-- I-- I sign it, I sign it, I sign it.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I'm guilty for everything.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] It's OK.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "So after this, when I'm guilty for everything, then they can take me out to the regular jail.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "The regular jail [INAUDIBLE] was half a room like this.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "It was-- 6 by--",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And down in the-- in corner there was a [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] is a-- a little like-- not a kettle.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "It's like-- you know, you can sit down on this.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "You can just do the-- you can just relieve yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Like a latrine, in the corner, so you can relieve yourself in this.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And for the big things, they opened the door.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "You go around, you go out, and they stay-- the guards stay.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And there was a-- a big-- some hole and a piece of wood.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "You stay on the wood and make the big things, and they give you one minute.",
      "word_count": 16
    }
  ],
