{
  "stem": "6736.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "They asked all the men to go to one side-- they knew they're going to be taken to a camp to work, [NON-ENGLISH] camp, arbeitslager-- and the woman and the children to the other side.",
      "word_count": 35
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And when they come for-- to take my family, two brothers, Chaim Yosef and Mordechai Yehuda, and a sister Esther ran away.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "They ran into the ghetto to Cracow.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And my father was left with my mother and two younger children.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "And when they asked my father to leave to the side to the men, he wouldn't leave.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "He said I'm not going to leave my wife and my two children.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "And of course, all the woman and the children, including my father, they shot on the spot.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "And the other ones, they bought in to Plaszow to the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "Because in the meantime, I was taken from the brick factory into Plaszow.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "And when I was taken to Plaszow, at that time Plaszow was only arbeitslager.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "And our commander was also Miller.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "And Miller liquidated gulag.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "And he brought in all, including my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "And we were both in Plaszow in 1942.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "And people came in who knew my father, said that they felt guilty that they left their wives and their wives were killed, and the children.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 29,
      "text": "And that my father did the right thing.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "And the irony is that we the ones who were prosecuted felt guilty.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "And the murders felt good.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "And this was my two brothers and my sister lived in the ghetto since November '42 till March 13, '43.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "And March in '43, they liquidated the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "My uncle made a hiding place for his wife and two children.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "And my older brother and my-- the younger sister was hidden there too with some other people.",
      "word_count": 17
    }
  ],
