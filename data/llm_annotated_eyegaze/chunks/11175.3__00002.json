{
  "stem": "11175.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We start to hear from Majdanek and from Lublin.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "We start to hear from some other camps, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "We know this-- that's not just talking, this-- this is a reality.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "You know, you see-- you-- you can see them.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Lublin-- Were you aware of other activity in the ghetto, resistance activity?",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we-- we knew there is.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And there was Jewish shows and was everything, you know, was schools for children.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "You know, but-- they had to do something.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "The Judenrat was-- tried to do something, and the Jewish-- Jewish organizations tried to do to organize the-- the parents.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They should send the kids to-- every-- every place had their group.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the fighting resistances, they started to organize.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Look, they-- it was the Zionist organizations and the Communist organizations and the Bund organizations.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "All the organizations they belong to-- Jews they belonged there.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "You see, they start to organize-- organized themselves, and say, what we gonna do?",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "You have to do something, you see.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "This January action, we didn't do anything.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We [? have-- ?] you heard rumors, you know, then something is cooking there.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They're organizing themselves.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "They would not let through that everything like this go out.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "That's all right.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "We have to get some resistance.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "Has to be some resistance.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "They-- everybody was afraid, you see, to talk even to somebody.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Or-- they did it.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They organized themselves.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Let's say I lived in Simonhof.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I moved to Miller 46, another place.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "The other side was young boys, [? halutism ?], and the Zionists.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And we knew-- we knew what they're doing.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "What they-- they're organizing themselves for some resistance against the German, against the Ukrainian.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Wait, were you part of that in any way?",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I'm not.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I was not belong to any.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
