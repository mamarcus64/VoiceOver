{
  "stem": "10394.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "What they did, they cut pieces from them.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother--",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "--was in Israel, but he passed away.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "That's how I know.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And they got killed by them.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah but then we left to the small town to my sister over there.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We-- we was thinking maybe they not coming over there.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "But they was over there-- all over.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was very hard-- not so easy.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how many-- two months.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And what I got everything-- and my brother, I give everything to one guy.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "He was the chief from the police.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And he tell us, this night, you have to go from the town.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Because they are going here.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And we left, and the small kids, my sister's three small kids, my mother, my father, and I.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "We didn't-- where are you gonna go?",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "No place.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "Who will let you in?",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "But one guy let us in where they caught the-- the horses, the cow-- one night.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And then in the night we hear what was going on-- the small town.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "This family was killed-- everybody.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "This was in our village-- in our village.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Next day, he says, you have to go.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Where we go?",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "No place to go.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "We go again to one.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I told you, my father got the money.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "He borrowed then the money.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And he let him in-- but not for long-- just the same place where the cow-- the cow, and the-- and the-- and the horses, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Then my mother says to me, you know what?",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Don't stay with us.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I say, where I go?",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "I don't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "It was one guy over there, Polish guy.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "He says, I take her to Krakow in ghetto.",
      "word_count": 9
    }
  ],
