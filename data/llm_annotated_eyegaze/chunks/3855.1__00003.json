{
  "stem": "3855.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Wilhelmina, maiden name Sabbath.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "S-A-B-B-A-T-H.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And, of course, her birth was July 1st, 1885.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Well, like it was done in those days.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "The aunt of my mother was living in Vienna and married to my father's brother.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "My mother came to visit her aunt, my father came to visit his brother, and they were introduced.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And that's the way it was done in those days.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And they married.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well, since I was born-- my brother was born in 1911.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It was before that.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "That's how it was done in those days.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My brother, Walter, four years older.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "My sister, Herta, who changed her name to Harriet, four years younger.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We had a wonderful home life, really.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "My father was a wonderful joke-teller, and I presume all three of us picked that up from him.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And we really had a very close home life, I must say.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Also conditioned by the fact that every summer, our parents would send us off to Bohemia to my grandfather's farm.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And there we met numerous cousins and aunts and uncles who came there.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "It was like a common meeting ground for the family.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And that, of course, made for a very closely woven, broader family than just our own family.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And many of my fondest memories go back to those times at my grandfather's farm.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "He was a wonderful man, in my opinion.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "I'm trying to do the same.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "He used to take me by the hand and take me through the fields and show me the corn and the potatoes that he was growing.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Various other experiences that I had with him.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "It was really pleasant.",
      "word_count": 4
    }
  ],
