  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I-- I was a bachelor, my brother was a bachelor.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I-- I went back to-- I went back to the same factory because they moved from-- from Milwaukee to Chicago.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "My brother, I think she worked in Chicago too, with me together.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Certain ?] [? time. ?] And he meant this-- he met a girl.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And-- and between I went-- I went to New York.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I just wanted to live in a big city.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Between-- between-- not friends, but I met many, many, many people in-- from camp.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And that time there was-- there was a different feeling, you know, that was together-- togetherness.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "This was in 1950.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Was that togetherness, each one try to help out the other one.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "I stayed in New York-- I stayed in New York about three months.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "I-- I got a job in a not very bad neighborhood.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "I had to travel about an hour and a half by the subway.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "I didn't like it.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "I went back to Chicago.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "In the meantime, I came home to Chicago.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "Went back to Chicago.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "My-- my [NON-ENGLISH], older lady, sub-- sub-- how you call the sub-- My brother found a girl already.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And I told him, listen, [?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "Avram, ?] no more cooking.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "I said, no-- I knew the language already a little bit.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 24,
      "text": "I had a-- I had a couple hundred dollars already.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 25,
      "text": "No more cooking, I said.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 26,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 27,
      "text": "I hated it.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 28,
      "text": "And he met this girl.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 29,
      "text": "And he went in a business, in a laundry business [PAUSES FOR 3 SECONDS] between-- in a-- in a colored neighborhood.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 30,
      "text": "He didn't-- you know.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 31,
      "text": "I-- and I was-- I-- I got laid off on the factory.",
      "word_count": 12
    }
  ],
