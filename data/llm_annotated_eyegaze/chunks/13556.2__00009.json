  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I was a [? child. ?] And we used to always scrub cattles with us.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And in daytime, we used to take cattles to go away a little bit far-- a couple miles away.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And was dressed like a little shepherd.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "And we used to watch where's the German army and what kind of movement-- what is going on-- and to bring the messages.",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Usually we was treated like adult.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We feel-- they give us to grow, in the army.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was-- was ready of his own to protect himself, to defend himself.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "I was treated like adult.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "We wouldn't-- was treat-- there was educated-- they tried to educate us not to look for protection.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "To be alone--",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Self-- yeah.",
      "word_count": 2
    }
  ],
