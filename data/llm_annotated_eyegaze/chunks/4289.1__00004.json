{
  "stem": "4289.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And they drove all over villages in the neighborhood of Czestochowa.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And one night we got a messenger coming to our house telling that all three of them were shot by Gestapo, that were caught with the merchandise they were selling.",
      "word_count": 30
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But lately, when I went back to Czestochowa, this year, I found out that my Polish father was, was a partisan.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And under the produce, he was carrying ammunition.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And that's why they were all killed in the village of Odusz.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And then I also found out through people who knew about this happening that the village was burned.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And some people were burned in the church-- alive.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "There was somebody coming to the house telling us that we better move out of there.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And overnight, we moved into the father-in-law and mother-in-law of my Polish mother where we stayed till about when we were freed from the Germans.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So we stayed in with grandpa and grandmother.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It looks like during the time when my mother took me into her house, she was pregnant.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And right after the death of her husband, a few months later, my mother had a baby which we named after our father, Wilhelm, Wilhelmina.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And we moved in all with the-- our grandparents.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The terrible thing was that the grandfather, Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Maj, he took his only son's death very hard to his heart.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And he started to drink alcohol.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And then he went almost crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He didn't stop drinking alcohol.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He used to come and demolish the apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "He used to kick everything, break everything.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "He took a credenza of dishes and threw it on the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "And in his anger, he used to kick us and beat us.",
      "word_count": 12
    }
  ],
