  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "And here, there is a roll of paper.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "Here is a roll of paper.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "That Molly, when they see a soldier with a roll of paper, she going to walk through, because she had to go through Gelsen ghetto.",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "You had to go through the-- the Bergen, where the soldiers stay.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 23,
      "text": "And you are the-- you see-- you see a person with a ball from the toilet, with a-- with a-- what do you call a one-piece suit?",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 24,
      "text": "A blue suit?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 25,
      "text": "A worker's suit?",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 26,
      "text": "What do you call that?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "A uniform?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Only has zipper.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "One piece.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "What do you call that?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "What do you call that?",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Overalls.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] Overall.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "You, Molly-- see, a woman is different.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "The back is different, entirely.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "You give a-- you give it in a dress, no good.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "A little high in a woman.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "A difference in the back, like a-- like a man.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "So she-- she go-- and the overall is loose.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And she took-- she took that ball on in her head, because you have to see the hair like that.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "She took-- and Edek saw-- and Edek saw-- and she saw Edek with a roll  of paper.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She had to walk to each other.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "It had to be exactly 12 o'clock, because they were hungry too-- the soldiers who stay on the first thing on the-- on the morning.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "So as soon as he come over there, he showed him-- he showed him the-- the piece of paper.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "He didn't want to even look.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "He was hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "He let him go.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "And he went away.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "For two weeks they didn't catch him.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "After two weeks, they catched him.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "And they hanged him.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Now, she-- she cut herself with a razor blade-- the veins.",
