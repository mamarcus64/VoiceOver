{
  "stem": "13600.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.8,
  "sentences_input": [
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "Kept it to myself.",
      "word_count": 4
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 2,
      "text": "Kept it to myself.",
      "word_count": 4
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 3,
      "text": "No jokes, no sayings, no criticisms, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "Joined me in Babruysk, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "By that time we got a little room.",
      "word_count": 8
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "It was a long corridor, you know, with single rooms.",
      "word_count": 10
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "They arrived much later.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't remember when.",
      "word_count": 4
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 2,
      "text": "But they arrived much later.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "From October '39 till June '41.",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "All the time working in the timber, yes.",
      "word_count": 8
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember having-- till I escaped, till the Nazis marched in and the beginning of the real war in '41-- having been out of this place.",
      "word_count": 27
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 2,
      "text": "A small, one room.",
      "word_count": 4
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "The war broke out in 1941, the 22nd of June.",
      "word_count": 10
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 1,
      "text": "And I left on 27th.",
      "word_count": 5
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "Five days later we heard that the Nazis are coming in.",
      "word_count": 11
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "And whoever can save, my mother told me, to leave.",
      "word_count": 10
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Yes, leave because you--",
      "word_count": 4
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Go away.",
      "word_count": 2
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "Maybe you will save yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "It was so sad.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 2,
      "text": "And we didn't believe that the Russians would be defeated so quickly.",
      "word_count": 12
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 3,
      "text": "They always presented themselves as a mighty power.",
      "word_count": 8
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 4,
      "text": "And suddenly the-- the Germans are coming close and closer.",
      "word_count": 10
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 5,
      "text": "So I ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 6,
      "text": "Actually I ran 120 kilometers.",
      "word_count": 5
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Run physically--",
      "word_count": 2
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "Yes, on foot.",
      "word_count": 3
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, of course, on foot.",
      "word_count": 5
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "To a city called Mogilev.",
      "word_count": 5
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "In Belarus.",
      "word_count": 2
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 0,
      "text": "Oh, gosh.",
      "word_count": 2
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 1,
      "text": "What can I to tell you?",
      "word_count": 6
    },
    {
      "segment_idx": 155,
      "sentence_idx_in_seg": 2,
      "text": "I remember only coming-- arriving with sores on my feet from running so much, and coming to the train, and pushing myself in the cattle trains, trying to escape.",
      "word_count": 29
    },
    {
      "segment_idx": 156,
      "sentence_idx_in_seg": 0,
      "text": "--taking out people who have wanted to escape further inside Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 157,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 1,
      "text": "On the whole there were more Jewish than non-Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 158,
      "sentence_idx_in_seg": 2,
      "text": "People who are political affiliated, non-Jews were running as well, because they were afraid more.",
      "word_count": 15
    },
    {
      "segment_idx": 159,
      "sentence_idx_in_seg": 0,
      "text": "That is correct.",
      "word_count": 3
    }
  ],
