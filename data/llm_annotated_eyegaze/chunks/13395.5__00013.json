  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "He left his mother behind and jumped with his wife to save his life, to maybe be together, reunited, with his children.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And so his mother went with the transport to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "That was the only destination at the time.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And he hid with his wife in the cemetery, only to be found two days later by the Jewish police.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "It was raining while they were out there.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And they were picked up by the police.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "They found them.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "They were searching all the homes and everywhere where Jews possibly could have hid.",
      "word_count": 14
    }
  ],
