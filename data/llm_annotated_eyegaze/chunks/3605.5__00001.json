{
  "stem": "3605.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I had a family picture-- a square inch-- the size-- that I cut out.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I put it in.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And the group picture from my [NON-ENGLISH] I rolled in.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I put in all in the tubes.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The-- the picture of my group there too.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I cut around the white-- just left the heads of my friends there.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And when I came through Bergen-Belsen, and they told us to disrobe, I put my picture tube in my rectum.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "This was a celluloid tube that I had the valuable things that my mother gave me when I left, with the poison pill from my brother, as I mentioned before.",
      "word_count": 30
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I took out the valuable stones.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I left the poison pill.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I put in the pictures that I cut out in the cattle train in the tube.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And when I arrived in Bergen-Belsen, and we had to disrobe ourselves, they even told us to keep the clothes right and keep it good.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And we are going to come back and put it on.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But I knew that this wasn't the case, because I was told about it in Buchenwald.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And I put the tube in my rectum when I had to pass the shower-- the disinfection shower.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And actually, when we came out from the shower, we got striped coats.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And I remember under the coat, they gave me a purple evening dress, and no underwear, and wooden shoes.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And this was the height of winter.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And I remember when we went out, my hair were wet.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And they stood up like ice.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And we stood there on long appells, which is counting sessions.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Many people got sick.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "Many people died.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "In Bergen-Belsen, our time was spent just carrying stones back and forth just to wear it out-- wear us out.",
      "word_count": 20
    }
  ],
