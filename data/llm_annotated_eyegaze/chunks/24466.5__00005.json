  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Do you know if-- or how many, or if any of these people survived the war?",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Was one, [?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Butkoff, ?] but he passed away here.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "The-- the father was-- was alive.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "He was living in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And he was killed from a-- he felled off from a truck, and killed himself.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Her father-- yes, where-- yes.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I would like to go back a little bit, because not mentioning a name with whom we-- I was in contact in-- and [?",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Hereshek ?] Riszfeld was in contact, not to mention the name of-- and not to talk about this would be not right.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "The family Riszfeld got a little son, just a newborn son.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Before the action of Jewish children, till 13 years, he was asleep from the Kailis.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And to a family on the name Ludwig Fronckiewicz.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "He was Commandant [NON-ENGLISH] from the [NON-ENGLISH] I'll say it in Polish, maybe it will be easier.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "[SPEAKING POLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And his name was Fronckiewicz.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Could you spell his name, please?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "F-R-O-N-- Fron-- N-C-K-E-K-A-E-W-I-C-Z.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And that child was in that flat.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 7 SECONDS] The daughter-- they got one daughter.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "She was the only one daughter and working as a secretary for the treuhander in the furrier factory.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "A treuhander?",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "That Is the-- the-- every factory has to have a-- a person what work and is responsible for the work what is the factory was doing.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Of course, that was a German.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Most of them, they were Germans, you know? a volksdeutche.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And that child, still alive now.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Is living in-- is not a-- is not a child anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Is living in America.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] And-- [POINTS] [SIGHS] I was in contact with them, because, on the factories where I was working, was also the underground.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "The Polish underground was there.",
      "word_count": 5
    }
  ],
