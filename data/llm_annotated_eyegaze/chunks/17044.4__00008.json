{
  "stem": "17044.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And then the-- we had already partisans coming in openly.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "We knew the front is closer to-- this, I'm talking, already, it was 19-- beginning 1944.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And, it was terrible thing.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "People dying from hunger and this.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And it's hard to describe.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And by March '44, the Russian army came in and liberate.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And I had the pleasure even, they gave me weapon to shoot on the Germans on the front across the street.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I showed them where they digged in, and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And I took off, and the way back was my march back to my town to see if everybody survived.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "So I came back to the-- to the Vinnitsa-- you know, the town where I was with the-- with the street gangs.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Where are you going first thing?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "You're going to the police to find [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to sleep someplace.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I come into police.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "The leaders from the police was those street gangs.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Before they gave me out, they kissed me and hugged me.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "They're friends.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I didn't want to make a deal from this.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "The others, they eat.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "They gave me food, eat, and drink.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I slept over, and I said goodbye the following day.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I went the way home, back.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "The way home back, I came to a town, [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "There in [NON-ENGLISH], they took me off.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "There was the Polish army.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "They took me off, they-- they figured me, no documents or anything, that I'm a spy.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "They took me to the KBG and to Berdychiv.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And-- and then they released me.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I was travelling-- because I was looking the way home, then I was travelling with another group, with girls in the train.",
      "word_count": 23
    }
  ],
