{
  "stem": "21004.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 30,
      "text": "I said you take off the shoes.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 31,
      "text": "You don't have no more money here.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 32,
      "text": "I bet you he gave you Polish zloties to put in here.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 33,
      "text": "That's what happened.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 34,
      "text": "He takes out the shoes, pick out the sole, there's six silver Polish zloties.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 35,
      "text": "He took out the other six from him, and he stacked them away.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 36,
      "text": "I say, here you don't have nowhere to go with them.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 37,
      "text": "So then there-- then my-- then my cousin starts screaming and screaming, what do you do?",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 38,
      "text": "Why you listen to such a crook?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 39,
      "text": "Why you listen?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 40,
      "text": "Anyway, what's happened?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 41,
      "text": "I called back to find my friend-- to find my friend.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 42,
      "text": "I say here, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 43,
      "text": "You have a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 44,
      "text": "You can-- you maybe know-- maybe somebody knows where Schmuckler is.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 45,
      "text": "Schmuckler was no more there.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 46,
      "text": "He was hiding already by a Gentile person, by a lady.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 47,
      "text": "She made an extra bunker from him in her house.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 48,
      "text": "She had a big house.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 49,
      "text": "And he must have promised or gave her a lot of his own money.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 50,
      "text": "So I say-- he say, I know where Schmuckler is hiding.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 51,
      "text": "I say, can you take somebody else with you and go?",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 52,
      "text": "I couldn't go there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 53,
      "text": "But you go with another person.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Go to there, tell the lady-- tell the Polish lady if she is not going to chase him out from there, you're going to call the Gestapo, and we're going to tell them not you and not me.",
      "word_count": 38
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "There's no such thing, couldn't happen.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "That's the way it happened.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And then they told the Polish lady what he did, she say what a terrible person he is.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "He shouldn't be alive even.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "He should-- he should have been killed, that he can do something like that.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "He has enough his own money.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "He was a watchmaker.",
      "word_count": 4
    }
  ],
