  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "If you want to have him-- wake him up at 3:00 in the morning, he'll sure appreciate it.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "He asked me, are-- are you intending to stay in the town, or are you going on?",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "I said, we are going on.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I went on and [INAUDIBLE] into the American territory.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That was the 22nd of June when we celebrated our wedding day.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Because we had married before, but we could never live together.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In the army?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Until I was discharged.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "My-- my points had come up earlier.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I could have earlier but I was [INAUDIBLE] the persecution until about September 1946.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't yet.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I went-- I went to the discharge paper.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "But I stayed [INAUDIBLE] has plenty of leave coming.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I was still on leave until November or December was the [INAUDIBLE] December and joined to [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And I sit in the reserves.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And when the Korean War started-- when the Korean War started, I-- I was to be called up-- that I was informed that you will be called up to-- to go to Eisenhower's headquarters in Versailles in Paris because I spoke very [INAUDIBLE] US intelligence.",
      "word_count": 45
    }
  ],
