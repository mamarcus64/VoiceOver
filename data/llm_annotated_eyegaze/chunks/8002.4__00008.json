{
  "stem": "8002.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I went to look for my relative.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I got held up with the Russians.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "They put me in the Russian army.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "I'm still going to be a policeman?",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "But then he says to me, they're looking who wants to go to the United States, to move to United States.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "I says, I would love to.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I wrote it on a piece of paper.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And I waited.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 4 SECONDS] before going to the United States, I belonged to the Haganah, that was an Israel organization.",
      "word_count": 21
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And they say, listen.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "You want to go to Israel?",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I want to go Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "But you've got to fight.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "I says, I'll go fight.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And they took us, we were a couple hundred people.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They took us with a truck to a ship.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And we went to a ship.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "We went to Bremerhaven.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And from Bermerhaven, we went to a ship to go to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Um.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] We called it Shalom, but it wasn't.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "It was a German name.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I-- I can't remember.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "I might have it in my transcript.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I'll remember.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "We went with the ship.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And just maybe about 50 miles from Israel, an English, big destroyer caught us.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "And they shot over the ship.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And they told us to stop, which the captain stopped the ship.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "And they came over with the boat.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "And they said, they can't go to Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So they took us to Cypress.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed there for about a month.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "It was a camp there.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And they sent us back to Germany again.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "They told them we can't go to Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "They sent us back to Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "And you went back to where?",
      "word_count": 6
    }
  ],
