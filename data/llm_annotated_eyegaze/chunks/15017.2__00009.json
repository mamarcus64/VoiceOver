{
  "stem": "15017.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "This was in 19-- but there was a lot happened during that time.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "Because after she had gone, then in 19-- I came back from South America in 1949.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "In 1949, I worked in England.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "On these passenger ships till 1949 from 1947.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "From 1949, I was working at the Savoy Hotel in London, the Barclay Hotel, and Claridges.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "That went on until I got the offer to go to Nairobi.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "In August-- I could show you it.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I've got it in print.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "On August, I left England.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I finished at the Barclay Hotel on Saturday the 27th of August and flew away from England to Nairobi on the 30th.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Two years and a quarter.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "And then, I came back and worked again at the hotels, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And an offer came for me to take the band to the Taj Mahal Hotel in Bombay, which was celebrating its golden anniversary.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And I went to the Taj Mahal Hotel in Bombay.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I was there from September-- yeah, we arrived-- from September through to the end of February.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I came back to England the end of March of 1954.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Then I worked once again in London.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And then, the time came when I joined an act on the stage, and we toured Europe, went on a tour to Europe.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But this is a thing I must tell you.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "In India, we were told not to eat out.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "It was dangerous.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "But I went into a cafe one night, and I saw something that I fancied very much.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And what happened to me shouldn't happen to a dog.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "It developed into an anal fissure.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And while I was on tour with the act that you see in the picture up there, we were befriended by a surgeon in Switzerland.",
      "word_count": 25
    }
  ],
