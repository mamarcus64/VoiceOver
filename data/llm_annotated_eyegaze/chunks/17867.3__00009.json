{
  "stem": "17867.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.2,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And just as proud as can be, I stood up and I said, Portland, Maine.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "You know like, this is it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And the guy looked at me and he said, Portland, Maine.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "You're going to schlep this kid all the way to Portland, Maine?",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And I was so insulted to think that, what does he mean saying such a thing.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Oh, he says, you don't want to go to Portland, Maine.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "But this is our home, this is where we're going.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And this is how it was.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "My uncle, my cousins, they all greeted us at the station",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Portland.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, we had-- we went from the station in New York by train to Maine.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "The trip was very exciting.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "One more train trip.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "But this was a happy train trip, a very happy one.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I couldn't wait, I couldn't wait.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I don't know how long it took, but it wasn't long, in my opinion.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't wait to get here.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And my mother seeing her brother for the first time was quite thrilling.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And, and then after a while, they got the brother from New Jersey.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And it was like a family reunion.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "She had somebody else that was a part of her family.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yiddish, we spoke Yiddish, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but they didn't speak Yiddish and I didn't speak English.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I was 12 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "That was another problem.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I was 12 years old and I didn't know how to read, write, or speak English.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And they wanted-- they had to start me in school.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Where do you put a 12-year-old who doesn't speak it, read it, write it, or anything?",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "You know, I was like a dummy.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So they took me into grade school.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I think it was the sixth grade.",
      "word_count": 7
    }
  ],
