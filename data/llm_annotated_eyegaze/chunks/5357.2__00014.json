{
  "stem": "5357.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "So I had to brainwash myself-- I didn't have a pencil and paper-- the name of the child, the date-- the month that was born, and the year.",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "So I walked around and walked back and walked around again, until I brainwashed myself.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "I knew for sure that this I'll remember.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "I went and asked for where the church is.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "And I came in.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "There were two older women.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 15,
      "text": "I shouldn't say old, because now I'm getting old.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 16,
      "text": "They had white hair.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 17,
      "text": "And I told them, I said I need a birth certificate.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 18,
      "text": "Somebody asked me to get them.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 19,
      "text": "I am from Lublin.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 20,
      "text": "And they looked at each other.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 21,
      "text": "They said, I can't give it to you.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 22,
      "text": "My husband isn't here.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 23,
      "text": "I said, but my train is going to go away.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 24,
      "text": "And I promised the people.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 25,
      "text": "You see for me, I will start at home.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 26,
      "text": "A promise is holy.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 27,
      "text": "I promised the people that I would get it.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 28,
      "text": "And the train will go away and I don't have where to be.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 29,
      "text": "I have to go back.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So they again looked at each other, and they think, oh, well.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "It was like either 50 cents or a zloty, that time, the birth certificate.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And they finally gave it to me.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I took it.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And now that I had the birth certificate and a new name-- What was the--",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And I had an idea, Zofia Lesczinka.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "It was March, the 8th, 1931.",
      "word_count": 6
    }
  ],
