{
  "stem": "6076.7",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "The war was coming, you know-- it was-- rumors were going around.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "The Russians are, you know, fighting back.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And soon the war will be over.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "But they still-- the fight was still going on.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "The fight of survival was still going on, how to survive, or how to sneak away, or to hide.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "But there was no opportunity for us.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "They took us to Leipzig.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "Over there in Leipzig, we had the same ammunition factory like we had in Skarzysko.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "We did the same work with the same routine, the barracks, and the appeals, and sending away people.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And then everybody was afraid to mention that they feel bad over the little temperature.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "A new hassle again started.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "But the new hassle, of course, wasn't too long.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "It lasted only nine months.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "And the reading-- somehow we sneaked some old paper by the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "We had the German meisters.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "Instead of Polish meisters, we had German meisters working on the machines.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "Shmulek was sent to Buchenwald.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "And me and Tobcha slept together and marched with other three girls together and did the same work for nine months.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "Over there, over there we became-- on the bottom, we had also three stages.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "On the bottom, one, was one pregnant woman.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "And the other one was also pregnant.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "They came from Skarzysko.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "They had eventually-- Herlig-- Mrs.-- her name was Mrs.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "Herlig.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "She was a friend of ours.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 32,
      "text": "And the woman was from [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 33,
      "text": "She was pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 34,
      "text": "The woman was pregnant.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 35,
      "text": "Of course she was from her husband.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 36,
      "text": "The other women, I really don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 37,
      "text": "She just-- she was pregnant, but it wasn't-- she was from the beginning, her months, we didn't see it.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She was from Cracow, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But she came from our camp.",
      "word_count": 6
    }
  ],
