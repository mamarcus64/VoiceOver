{
  "stem": "13655.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.2,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And all night, we was with the Gestapo, with the Ukrainians, [INAUDIBLE], they was murdering us.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "They wouldn't let us rest a little bit, or what.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "They had a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "It was a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Not all.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Some of them they sent to [INAUDIBLE], near Brest-Litovsk, and some of them other places.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "With me, maybe it was about-- [PAUSES FOR 3 SECONDS] --150 people, something like that.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "One was a rabbi from the next neighbor, neighbor with [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "He knew very well me, my father, because he was a [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Then he said, please don't call me Rabbi.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And then I took away.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Still go.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, all right.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Ask.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "The next day, we find out there were horse and wagons.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "They took the rest of the people, women and children, to Miedzyrzec, 26 kilometers.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "It was a ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Miedzyrzec was a ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "From that town, they sent to Treblinka 50,000 people, 10,000 children.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I didn't arrive to Miedzyrzec.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They took me to work.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Airport.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "The next day, I see it's impossible to work here, to stay here.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Then I went, found a place where there's another group of Jewish people working, maybe a mile away.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Then I went there, and I saw a few people that I know them.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They said, come here.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] will be with us, and we'll be with you.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "I went back, and I took my two brothers and a few friends.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "We went there to them.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And we went at night in a different barrack from the soldiers.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They didn't-- I was afraid they're going to come to pick us up, but they didn't come.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And the beating was terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what happened there.",
      "word_count": 6
    }
  ],
