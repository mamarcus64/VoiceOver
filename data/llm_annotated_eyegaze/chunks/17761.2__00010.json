{
  "stem": "17761.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I would like to mention one name in this respect.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And that is the name-- a man by the name of Maurice Rath, M-A-U-R-I-C-E Rath R-A-T-H.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He somehow came to our city from Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "He didn't have any relatives wherever that I-- we know of.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "We don't know who was his family.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "But he rented in a little apartment in-- in the courtyard of our-- where we were living.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And so he was invited to our house.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "He became a guest, and then he became a good friend, and then he became a part of our family.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And when we were deported to the concentration camps, he came with us, lived with us until the winter of 1942.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And he died on a typhus in Mogilev-Podol'skii in that concentration camp that we were.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "He died almost on my hands.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "He asked for a glass of water.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "They brought him.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "They wanted to give him to drink.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "He just passed out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Our area was not occupied by the Russians.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Therefore, we-- when the-- when the Germans invaded Russia, we still-- that was in June, 1941.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We still lived in our place until October.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Because those-- those parts which were occupied by the Russian before the invasion, the great majority of them were just exterminated.",
      "word_count": 21
    }
  ],
