{
  "stem": "11167.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "My one sister-- this man what he did work by us in the-- for the oil factory-- she had a very, very big about eight-room house, and business, and everything.",
      "word_count": 30
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And she ask him, I give you everything.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I write it down and sign.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Spare me.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Let me be in the-- somewhere in this-- in the house, too.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "He agreed to everything.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And on the-- after four days, he came with the Gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And they was killed in their house-- she and the-- her husband and the daughter.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I will tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I-- we was living in a street where it was only eight families-- Jewish families.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Because our business couldn't be in center town.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "You had to go a little bit further, you see?",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So we-- we was like one family there.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "It was only eight families.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And it's the same business-- any-- of all of-- of the eight people who hadn't have-- more or less the same business-- not a oil factory, but wheat, and a little bit of shop, and that.",
      "word_count": 36
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I feel-- we feel it afterwards.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "You know, not in-- still-- still I was in school.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Still the-- but when I finished school, and I couldn't go to high school, then that I feel that I don't belong to them.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, I-- I want to tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I had the most-- I had non-Jewish-- in the movements, yes, the Jewish-- friends and everything.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "But at school and at home, then I had Czechish, two Czechish-- Czechish girls.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Because they-- there's a lot of Czechish people.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Even we had a colony of German people behind us.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Behind our garden was already built in German people-- where they did live over the years.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And I was friends with them, with these two girls.",
      "word_count": 10
    }
  ],
