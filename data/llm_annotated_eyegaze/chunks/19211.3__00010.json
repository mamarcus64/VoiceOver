{
  "stem": "19211.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 504.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "There was-- there was a couple, they are a Polish couple.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in one section of the house, the Polish couple, and then his parents lived in another section of the house.",
      "word_count": 23
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "It was divided.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "It was not like a duplex here, it was divided house.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "So we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "One-- [PAUSES FOR 3 SECONDS] --evening, or in the daytime, my mom heard screaming, and a woman screaming next door.",
      "word_count": 20
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "It was like the way that by 10 doors, that you heard scream.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And she ran over there.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And she says, my son is dying.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "He's dying.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "Son was my age.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "You know, there was no taxis, there was no nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "My mom ran to the hospital and brought a doctor by force, I don't know for what.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "And he came, and he came with a horse and buggy and took the boy to the hospital and saved his life.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "The woman came to my mom, she kissed her.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "I remember that.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "And she said, as long as I live, my life is yours.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "I-- you saved my son.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 19,
      "text": "My son would have died.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 20,
      "text": "He had high fever.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 21,
      "text": "His father, same thing.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 22,
      "text": "Came, kissed my mom's hand.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 23,
      "text": "They were polite, everything.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 24,
      "text": "He was Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 25,
      "text": "She was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 26,
      "text": "When the Germans came, he became part of the SS.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 27,
      "text": "And he was in the big building there, where the SS men were.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 28,
      "text": "They took my father to a labor battalion.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 29,
      "text": "And he couldn't physically work very well.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 30,
      "text": "My mom ran to the Gestapo there, to the SS building.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 31,
      "text": "She ran to him and he threw her out.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 32,
      "text": "He said, don't you dare come to me again.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 33,
      "text": "That guy, that she saved his son's life.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So he was so good to us in all that.",
      "word_count": 10
    }
  ],
