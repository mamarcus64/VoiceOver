{
  "stem": "2074.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "She's from a different city and she came back and they throw her in our ghetto.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And she was really starving to death.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So some people came to me to tell me that.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "So I used to bring her all kinds of food.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And this story is connected with another story.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "One of my dreams that I'll have to tell you later.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "So she died in the ghetto, a young woman.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You talk about the food that you were given from the Ukrainians on the outside, from the locals.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "What food were you given in the ghetto in terms of rations?",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Very much so.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So much inches.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So much bread, weighing.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I was telling one of the Americans, and she's-- telling how little it was.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "She says, oh, that's nice.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "That's what I want when I go on a diet.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] It made me laugh.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "So that we ate that much she thought it was good because when she goes on a diet, that's what she does.",
      "word_count": 22
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I remembered exactly at the beginning it was not enough to live, and too much to die.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Let's put it that way.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "But I didn't have that problem.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I brought in.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My parents had enough to eat, and I was helping others with bringing in some of the food.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My brother was there.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "One of the-- two brothers were there.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "One of them, his wife died.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "One had a wife and three children in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And the other ones, his wife died and her daughter died, and then little boy was killed.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And he is-- one of them who ran away-- and I'll tell you another story after-- he was hiding-- how we bumped into each other during the night.",
      "word_count": 28
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "He ran a different way.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "My sister ran.",
      "word_count": 3
    }
  ],
