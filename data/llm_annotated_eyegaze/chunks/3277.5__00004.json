{
  "stem": "3277.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And also this guy told me, if you meet people-- how you get to Israel?",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "Just say that you tried different ways.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They gave you a shot, and you don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "You woke up, and you were in Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "You know, it's unbelievable stories, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I wish I could spend the real time, then it would take hours-- hours.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Already, I am in the chicken farm.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I'm getting everything.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He comes every day to me-- brings me Polish papers.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Because in Israel, you have printed Polish newspapers.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "He brought me, you know, even shoes--",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Everything was the organizations.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't like to say too much about it, because, you know, it's a little bit this-- you know, it shouldn't be said too much about it.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And, little by little, you know, I find out-- I went into Tel Aviv.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I found friends.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Friends took me there.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I worked a little bit as a dishwasher.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "You know-- different way.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "My brother used to support me-- send me some money-- to support me.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "The friend didn't want even to take the money from me.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And everything was for free.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "And my brother was trying very hard to get a visa to the United States-- a preference visa, because he married the American lady, and he automatically-- now, it's not that way.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "He automatically became an American citizen.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And I-- it took me a little more than a year being in Israel, and I came to the United States.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Being in the-- on the boat, coming from Israel by boat to the United--",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I was thinking, what I'm going to do?",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I haven't-- I am not like my brother, a watchmaker.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I am an accountant.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I don't know English.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "What I'm going to do?",
      "word_count": 5
    }
  ],
