  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And did I speak to other-- well, strictly it was-- I mean, I was basically just with my family, you know, my extended family.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "These were the contacts that-- that I made initially-- so I initially didn't meet many other people, except people at work.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And it was never-- it wasn't discussed there.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't discussed, no.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Did they know what was going on here?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They knew.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They knew.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They had some idea.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "That was just the beginning.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "It was the beginning, before, you know, the camps.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Did they fully know and wanted to know?",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "I don't think my uncles really dug into that to any great extent.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They knew, but it was far away.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And-- Tell us about the circumstances of you coming into the army.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was interesting.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In '43-- and I'd heard about-- I'd heard about the Austrian battalion.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And very little, very little known-- is known about that.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
  ],
