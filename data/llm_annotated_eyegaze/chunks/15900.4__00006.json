{
  "stem": "15900.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And-- and everything.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "He said to me, why don't you talk over to your wife.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "We want you-- I gave her some with [INAUDIBLE] already.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Now you can give me double the-- the salary?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I said, don't mix in my wife.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She's not working with you.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "It's me.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I come home from work.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He and his wife were there at my house, talking to my wife.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I asked the people, friends of mine, what do you do in a situation like this?",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "She said, you've got nothing against him?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "He just used me.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "He pay me starvation-- starving salary.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "What will you do?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "Look, he gave you the same salary?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "He agreed to give you a better situation?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "Don't switch.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "If you have not given-- and I told him, I'm staying.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I went out to the boss there, at [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "I told him, look, I'm sorry.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "I cannot leave him, and I'm staying.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "And he said, Sol, you don't have to tell me nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "Whenever you decide to come in, you got a job here.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I worked a couple of years.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The children came in to work.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Oh, they graduate college, they were little babies.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And they become my bosses too.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "His children, they get out of college, engineers, and this, all them come to the business, the wives.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I said, I cannot handle it no more.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "If-- and I said to the oldest one, I said, I'm gonna leave.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "He said, you're leaving?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "I'm leaving.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I said, you sign my slip.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And my brother got sick at the time too of cancer.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I said, I'm going to California.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "We're not going to give you unemployment.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "You quit.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "I said you should live so long.",
      "word_count": 7
    }
  ],
