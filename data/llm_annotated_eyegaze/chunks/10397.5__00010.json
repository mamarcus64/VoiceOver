{
  "stem": "10397.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "We went-- she had seven doctors.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And she had all kind of different tests.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "She had a pulmonologist, a cardiologist, and then another cardiologist, all kind of doctors.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And was-- she was taking cortisone.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "The only thing which helps her was cortisone.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "Cortisone damaged her heart.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Damaged her heart.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "She had one-- one doctor-- she had irregular heart.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "So one cardiologist said-- cardiologist said-- a good man-- he said, we don't treat that.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "She has irregular heart, but that is-- she doesn't need no medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "But it wasn't getting better.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "So I asked a-- a record.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "There's a-- a Jewish doctor, from New York, and I met him, because he did some tests on me, when I came to visit with my son.",
      "word_count": 27
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "And he says, now we have to give her medicine.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "She has digitalis-- digoxin and other things.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "And they took EKGs and what.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "Anyway, to make the story short, she didn't get better.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "The asthma was getting worse.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "And it-- and-- and go to the pulmonologist, the only thing I can offer, take 40 milligram.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "Instead of 10 milligram, 40 milligram of digoxin-- of-- of-- of-- of a-- of cortisone.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "And it didn't do.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "She was up and down and up and down.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "She was lie down.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "She was tired.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "She walked a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "She walked a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "She was not really sick a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "The last day, she slept in the-- in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I go to the gym.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And she says, I can't-- and she went to the gym.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "No, to the park for a walk, Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember if it was Saturday.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "But it was, anyway-- it was 29th of March.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And she says, I can't get out of bed.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "I says, well, I thought you were ready already.",
      "word_count": 9
    }
  ],
