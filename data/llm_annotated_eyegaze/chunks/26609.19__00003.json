{
  "stem": "26609.19",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Why do you think that she has another husband?",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "She is not your wife.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Sura, ?] or what's her name-- she is not [?",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Sura. ?] We knew her.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And they came all.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Quickly, quickly he changed.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He don't want if I am not the wife that in all those people-- I don't know how many came-- in my eyes, they were thousands on thousands of people-- came across like a wall of people.",
      "word_count": 37
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And I was standing here, little, and waiting for my child.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Suddenly, not he-- I hadn't seen him-- these people came to me.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Look, we have heard your story.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "You're not his wife.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And he says that the child is his.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "You say the child is yours.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "So the best thing is we make a wedding here.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And I said, I didn't come for a wedding.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't come for a husband.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And I don't know him.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Because he has the same name as I.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I don't want him.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I want my child only.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And I want to see her.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "If she's not my child, I won't take away from him, if she's his, not mine.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "But I know she's my child, not his.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "I want my-- he won't give her to you until you marry him so the child will have a mother and a father.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "It's very nice.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "But I didn't come for a wedding here.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And I don't want to get married at all.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "I want only my child, nothing else.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So you will never get her.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "So I want to see him if he's mad.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Now I changed all politics.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I said, maybe he's a relative.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So I will talk to him.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I don't know him.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "I never knew anyone in [?",
      "word_count": 6
    }
  ],
