  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 24,
      "text": "Later on, long time, I got [INAUDIBLE] on the girls.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 25,
      "text": "A lot of things happened.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 26,
      "text": "Sitting-- that was a Saturday-- Saturday or Sunday, Sitting in our home, and talking, talking.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 27,
      "text": "Then I see, come Sunday, The [INAUDIBLE], the Gestapo, they get on the-- there [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 28,
      "text": "[NON-ENGLISH], they call it.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "A skull.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "To catch the Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Oh, boy.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Then I run off my attic, where I used to-- run, you know, outside was a ladder, and up and down.",
      "word_count": 21
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And he saw me going down.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "He said, come [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "I'm gonna kill you.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "I got no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "I go down.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "Then he hold a rifle, like this, run, go.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "Then I go.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "He said, [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "He laugh ?] at me.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "They were coming on our street.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "I remember the city was [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "There my-- my friend from [INAUDIBLE], they started talking about the girls.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "They said to me, [?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "Szulim, ?] [NON-ENGLISH SPEECH] I hid it.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "They shot after me.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 19,
      "text": "They cannot catch me, and I run out. you were running and this-- Yes.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 20,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And I run with [?",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Zelig. ?] Then I hide, because I know the city.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I was living there.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And I hide.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And my mother ran after me.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And she-- she was so close to him.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "And I hide in a-- in a shack.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "He cannot find me.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "Then after a while, my mother said to me, she won't-- she [? won't ?] talk to me.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE] different name.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "And I know what she said.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 13,
      "text": "Then I run out, go over-- over the roof to another place.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 14,
      "text": "And go to my girlfriend, I used to go with her.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 15,
      "text": "And then her brother-in-law's in our basement around him.",
      "word_count": 9
    }
  ],
