{
  "stem": "13693.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Michael Okunieff.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And the spelling is Michael, M-I-C-H-A-E-L, last name Okunieff, O-K-U-N-I-E-F-F.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Moshe Okunw.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Moshe, M-O-S-H-E, Okunw, O-K-U-N-W.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Mike.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "April 24, 1923.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "72.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Vilna.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "V-I-L-N-A, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "When I start to remind myself about the past, I feel like a chill goes through my body.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I see before myself the town where I grew up and the beauty, and the enthusiasm.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We grew up, and this suddenly disappeared from the face of Earth.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "The whole community disappear.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And there remains only a echo and a reminder.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "This was a beautiful youth what I grew up.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I grew up.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "My family consisted of three brothers and parents.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "My father's name was Pinchas.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "He was born-- he came in from Moscow during the revolution in 1920 and was born on the turn of the century, in 1900.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And he run away from the Bolsheviks.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And he came in to Vilna-- Vilna, where-- where he married my mother, [NON-ENGLISH], in 1901.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "They had three children.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "One, Beryl, was the oldest one.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I was the middle one.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And the youngest one was Gershon.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "My older brother was born in 1920.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "I was born in 1923.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And my younger brother was born in 1928.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "The youth was pleasant.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "We had-- what I still remember about my town is I can still hear when there was a Sunday.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "You could hear the high-- the bells were ringing.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And this was like a holiday.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "The town Vilna was a cross-section of cultures.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "It was on the crossroad of-- of-- of states.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Napoleon in 1912 came through.",
      "word_count": 5
    }
  ],
