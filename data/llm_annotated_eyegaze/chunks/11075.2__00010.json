  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Just what they gave us, you know, pair-- that pair of nothings, you know, just-- always cold, cold in the night and everything.",
      "word_count": 23
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "But I-- when we walked, we walked and from both sides  were SS Men, maybe about 20 SS Men on one side, and 20 on the other side, and in the front.",
      "word_count": 32
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And we walked, you know-- and we walked, you know, from-- from east to west.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Just men.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Just men.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Just a camp for men.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "No, they didn't give us nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how good that I-- I need very little food at that time, you know, because I was always a bad eater.",
      "word_count": 24
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "So we went in-- we went day and night, day and night, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And we couldn't go indoor.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And probably we went west, because the Americans probably came from east.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "People.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Dead people.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "Not because-- not-- not from-- from the gunshots.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "You know, they couldn't make it.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] So I figured--",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "OK, good.",
      "word_count": 2
    }
  ],
