  "sentences_input": [
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "And when we get off, there's a rope ladder we have to climb down, and the-- Is-- not Israel, Palestinian Jewish underground will be there and help us on little boats go to shore.",
      "word_count": 34
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And then I said, and the British people will shoot at us.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And they said, yeah, that's possible.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I really don't-- probably the underground, the Palestinian underground.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And then he went to another office, the Santa Domingo consulate.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "They sold passports there.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "And it turned out he hadn't paid yet.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "He wanted to buy for everybody else-- my parents and his mother, who was still in Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "And it turned out before he paid that the people who bought these visas, they couldn't get on any ship.",
      "word_count": 20
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "The consul took it on themself to collect the money, but there was no transportation.",
      "word_count": 15
    }
  ],
