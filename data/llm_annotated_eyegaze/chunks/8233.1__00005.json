{
  "stem": "8233.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] It was just unreal, just unreal.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "They told us we're going to, to work.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "When we arrived in Auschwitz, there was, of course, screaming, yelling, a lot of SS in uniforms.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They start to separate people-- back-- to the right, to the left.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They separated my father from us.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "My mother-- we took, my sister and I, took my mother in the middle.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They were looking at us.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And they said-- they looked at my mother, looked at her.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And they said, well, I think you still can work.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "We didn't know what it means.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My mother must have been 44.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "She was a young woman, very pretty.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, when I think about it, they used to say, don't work with your mother because [LAUGHS] it doesn't do you justice.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "She was very pretty and very good.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "My mother and I were constantly in camp-- I mean, together in the camp.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I'm not talking today.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The first day?",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The first day, we were pushed together into the camp and then into unlousing place.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know what it was.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Everybody-- they took away all, all our belongings, all our little-- whatever we had.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They cut our hair.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "They didn't cut.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They shaved our heads.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "They said that we're going to have a shower.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "But we-- I don't even remember if we had a shower.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "Then we stood in the line alphabetically.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And they made a tattoo on our arm.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I got tattoo.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "My sister got tattooed, my--",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "[CRYING] I guess.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] It was-- [SOBBING] I didn't feel human anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was very, very-- [PAUSES FOR 3 SECONDS] very bad.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "That was, I think, the worst thing what they did to us.",
      "word_count": 12
    }
  ],
