{
  "stem": "15900.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "When-- when I was-- left Poland was in '45 and went to Austria and there they put us in-- in this camp.",
      "word_count": 22
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "In this camp, I was volunteered to be a chief cook.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I was their cook and we formed a soccer team.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "A soccer team.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And when I arrived to play soccer in Ulm, it's in-- near Stuttgart.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My friends were there who was with me in Poland, soccer players and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They said, you gonna stay there?",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "You come with us.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "We settle you in a camp with the people who had the numbers.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "They called them [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "They were the [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "There was a camp, a beautiful camp [INAUDIBLE] they took all from the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "You go back to Frankfurt.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "We go with you, take your [INAUDIBLE] and you settle here.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "And I settled there in Heidenheim.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Heidenheim.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "This is between Ulm and Stuttgart, a beautiful city.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And there I played soccer.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "The-- the owner supplied the food and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "United Nations supplied the food.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Later on, they camped in Austria-- Australia.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "People, to-- to-- when they liquidated the camps, everybody-- the Catholics at the church guarantee it here in America with the jobs, this, they bring the Catholics, the Russians.",
      "word_count": 29
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And they-- and the HIAS took the Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I don't want to go to Australia, build in Australia.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "I want to go to America.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "And I came-- and I came, and the HIAS took me to America.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "On, no.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I-- I-- I stayed to the last.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- I-- I-- I stayed to the last.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to go no place if-- if the HIAS going to take me to America, I go.",
      "word_count": 19
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And later on, they-- they-- they had--",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I registered with them.",
      "word_count": 4
    }
  ],
