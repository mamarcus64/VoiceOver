      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "Socks that was [INAUDIBLE], that was better than anything you could--",
      "word_count": 11
    },
    {
      "segment_idx": 86,
