  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "From the whole of Europe the best musician was there.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "May I have a little water?",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "[DRINKS] So we went to Stuthoff by the train.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "We didn't know either.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "But was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 7,
      "text": "The-- if you wanted to see the scenery, it was very nice, we arrived in Stuthoff.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And again, five line up.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Five in a row.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "So the-- we were somehow separated, not from my mother, from my group, not the five people.",
      "word_count": 17
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And we were the second row in a new--",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Hundred people.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "We were crying.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "We are separated.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "What's going to happen with us?",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "But that was a good luck.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] If you could call it good luck, because we went to our room.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "From there, the [INAUDIBLE] people was taken out to Zahappell, to counting.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "And they never let them to go back.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "And we find everything.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 10,
      "text": "We find food.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 11,
      "text": "We find bowl.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 12,
      "text": "We find [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Spoon.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "The word is get out because I am there now.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
