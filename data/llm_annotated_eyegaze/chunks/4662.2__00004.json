{
  "stem": "4662.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And he took me-- Louis was sent to a camp, and I was there with the children.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "While in the camp, I had to go to the German officers to show that my husband was working in a camp somewhere, and that they pay you a few, a few francs a week for that.",
      "word_count": 37
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "But they never paid.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "We went, but they just wanted to keep an eye on us that we were still there.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "That was in [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "That-- no, that was in Leuven, L-E-U-V-E-N.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And they took-- they had to go to a camp.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But he escaped with friends of his, and went to a hotel in Leuven, where he stayed for a while until he was caught.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Because he didn't come home that night.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Anybody who didn't come home one night, they were caught.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I knew he was caught.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I packed my bag.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I packed things for-- I had a girl living with me who used to be my maid before the war--",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "But she became a friend.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Dinneke.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Dinneke Lambretchts.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "She used to be the maid before.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "She used to look after the kids and help me in the house.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And after-- when the Germans said there's no-- Jewish people aren't allowed to have any help in the house, so she left.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "But after a while, she came back without anybody knowing, and she wanted to stay with me.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So she lived with us.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "But when we went to Brussels, Joss took us to Brussels-- myself and my children, because Louis was gone already-- and we didn't dare to tell her where we were going in case the Germans got it out of her, where we were living.",
      "word_count": 44
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "So we didn't tell her even.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "We just disappeared.",
      "word_count": 3
    }
  ],
