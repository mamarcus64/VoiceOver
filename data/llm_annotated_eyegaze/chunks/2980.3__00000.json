{
  "stem": "2980.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BACKROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I have to speed up, I realize.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They made the [NON-ENGLISH] in our town.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I did not hear in other places about it.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Jews had to move off from non-Jewish streets.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And non-Jews had to move out into their own streets.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So they concentrated Jews only on Jewish streets.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Subsequent to that, there was another [NON-ENGLISH] and a third [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "They caught, the second one, 500 people.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "In the third one, they caught several hundred men, women, and children.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And none of them came back.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They were all killed.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "Our houses-- there also came an order we had to wear the yellow badge on the right side and the-- in the rear left, 18 centimeter in diameter.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "Everybody had to wear a badge, yellow badge.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "Our houses also had to have a half-a-meter diameter yellow badge.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "Every Jewish house had the yellow, big badge.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I have not-- did not hear it in other towns, but we had to have it.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "Then came the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "The ghetto came later on this year.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "I believe it was around Yom Kippur time.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "They made a ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "And there are two ghettos.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "One was for plain workers, which means they were former merchants or whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "And the other ghetto was for artisans, people who had professions or trades, like tailors, shoemakers, mechanics, et cetera.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "They were in the other ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "Those who were in the worker's ghetto were considered to have a better chance.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "And they did work for the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "Everything was for the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "And they gave us-- we had certificates, which we called the golden Schein, the gold certificate.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 29,
      "text": "The other people had white, white certificates, white Scheins.",
      "word_count": 9
    }
  ],
