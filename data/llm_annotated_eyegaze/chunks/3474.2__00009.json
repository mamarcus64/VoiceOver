{
  "stem": "3474.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "It was made-- it was-- [SNIFFLING] it-- it was a yellow soap.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "[SOBS] it was a yellow soap made of-- [SOBS] it was-- it was-- marks on it, right?",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "RJF.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "They used to tell us it's Reichs-Juden-Fett, and it was made pure out of Jewish fat.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "They told us that's what it was made out of.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "That's what they gave us to wash ourselves.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "[SOBS] It could have been anybody.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Your family.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Anybody.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "[SOBS] And then every morning-- you see-- and then people used to be so sick coming up.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Whoever was sick, they used to pay them a single [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "One day, I can remember, I came home from work, and my boss, you know, the one who used to work in the bakery, he wasn't-- he was carrying mattresses that day for the SS.",
      "word_count": 35
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Mattresses--",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "--For the SS.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And he got a herniated stomach from it.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "They put him in the barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I went to see him that day.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And the next time-- the next day, they took him away the Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Never.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Whoever went to a sick hall never came back.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "If we put him into that room-- they couldn't work-- never came back.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Straight to Auschwitz.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I remember, I went for-- my ear was bothering me.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "Was running, my ear.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "I went into a sick hall, and there was two doctors there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And they took out a wire, and they put a piece of cotton on the-- on it.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And he just dug into my ear, broke the wall of my ear, and I was yelling.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "And they were laughing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "And it was-- was broken.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "It make-- made a water-- a-- a drain of something.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "And since, I never been back to-- never been back to sick hall.",
      "word_count": 13
    }
  ],
