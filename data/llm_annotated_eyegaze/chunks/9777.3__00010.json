{
  "stem": "9777.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "We were in such an apathy already, you know, no thought left account of you need food for the-- my mind to--",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "But we had nothing whatsoever for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And we weren't very well-fed from before.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And our mind was not functioning so very well.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So we-- my girlfriend decided we should go and organize.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I said, what should we organize?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I said, I can't even walk.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "So we went and organized on the men's side.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I found an [NON-ENGLISH] coat.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I-- probably I could wrap myself three times down to the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "But it was better than the striped one what I had.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "The dress fell apart.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "They had a V in the front.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "The stitches fell out.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "So I had to tie a knot not to be exposed.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I mean, I looked ridiculous like this.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "My girlfriend had a pink dress with an organza inset and nothing underneath it.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I mean, this was another very lovely dress.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So I got-- I put on the coat.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I had my own shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But the only thing what we found is shoe paste.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't a very big number.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Nobody ended up in-- [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Of storage room, something-- shoe paste was there by the millions.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "There where I found the coat.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "A little bit of shoe paste was on it, but who cares?",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "It was a nice warm coat.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And I found a wallet and one Hungarian pengo in, in the pile, whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And I slit a wallet, a man's, and a pengo was in it.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And another day, I walked myself around with the [NON-ENGLISH] coat.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I am walking.",
      "word_count": 4
    }
  ],
