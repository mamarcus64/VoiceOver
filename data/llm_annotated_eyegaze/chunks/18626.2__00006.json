{
  "stem": "18626.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 84.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "When the soldiers, the German grabbed him.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "They brought him right to that [POINTS] big officer.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And the officer called him like that, closer to him with his finger.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And the Russian soldier walked closer and closer, and the German took out a sword.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "And he chopped off his head in front of me while I was looking through the gate.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "When I saw that, I run into my grandmother.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "I couldn't stop.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And I says Grandma, I just saw the German chopping off the Russian soldier's head.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Look it, right there.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "Look at there, near Glick's house.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "A man lived there, Glick.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "Right near Glick's house.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "She says, don't talk silly things like that.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "Maybe you didn't see anything.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "I says, I saw, Grandma.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "And then I decided I'm going back, try to go back home.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "When I saw the army coming in, that German army, [PAUSES FOR 3 SECONDS] I thought there was no future no more.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "I thought the whole world is gonna be taken by Hitler.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "Because I've never seen such a power with, such a [PAUSES FOR 3 SECONDS] weapons, with such a organization.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "They smashed, you know, the Lithuania-- the Lithuanians.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "They smashed the Russian army so fast, that they grabbed thousands and thousands, tens of thousands prisoners.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "They didn't have a chance to escape even, the Russian army from Lithuania.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "And they were grabbed, you know, all over you know, as prisoners.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And that was every other big disappointment for me I thought it's-- there's no chance.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "But I saw the chance.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "And we'll talk later.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "I saw the shining German army.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "And then three years later, I've seen the German helmet laying in the gutter and they couldn't walk without shoes.",
      "word_count": 20
    }
  ],
