{
  "stem": "23572.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "The-- the United Jewish Appeal, as an organization, could not issue affidavits of support.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I guess they were nonprofit organizations-- or-- someone explained to me what it was.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "I'm going back, now, 47 years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "But he said, they go to rich Jews, and say, you know, [INAUDIBLE] put your name down there on 10 of these.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "These guys are millionaires.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Don't worry about it.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "We'll hand pick the people that come over to the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They will-- We'll take care of it.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I got-- mine was signed by [INAUDIBLE] Bulova from Bulova watches.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He doesn't know me from beans.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "When I came to United States, I sent him a letter thanking him.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "My [? people, ?] it never even reached his desk, you know, he signed so many.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "But that's how I came to the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I came as an illegal immigrant.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "OK, now, there are-- so, I said, OK, it's a deal.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I-- I was willing to go.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I had an uncle living in London who-- who wanted me to come over to visit him in Italy before I went to the United States.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And I had no travel documents.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "The only-- the only thing I had was this old, Polish document because in Switzerland, I-- I said I was a Polish citizen and, I think-- I think the Polish government in exile gave me $25 a month, which was a tremendous amount of money, you know, because I was a Polish citizen.",
      "word_count": 53
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Even though I couldn't speak Polish and everything else.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So I had this Polish-- I had this Polish passport.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And-- So I went to England.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I had to go through Switzerland.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "France wouldn't let me in.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "France would not let me in with a Polish passport.",
      "word_count": 10
    }
  ],
