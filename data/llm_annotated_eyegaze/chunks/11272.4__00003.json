{
  "stem": "11272.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "So I came back to Ellwood City and joined the US Army.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And probably the happiest two years of my life, because I fulfilled two goals.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Number one, to give something of myself to America because I was so grateful.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And number two, it gave me an opportunity to get to know the American people and get a little bit of an education.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Because when I was stationed in Fort Bragg, North Carolina, I got to meet a lot of people.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "When I was stationed in Fort Meade, same thing.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And most of all, when was stationed in St.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Louis, I managed to get a high school equivalent diploma.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And above all, I managed to have two jobs in addition to my army jobs.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And I saved up enough money to buy a car when I came out of the service.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "So I can have a car to join my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "But I helped him start the business.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And we got into the pre-cut home business.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And, I worked very hard, hired a lot of refugees and hired a lot of people, trained them myself.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And we became the largest pre-cut home manufacturers in the world.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "That was already in Youngstown, Ohio, Niles, Ohio.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we built up to 82 corporations [LAUGHS] that I was president of.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we were very, very successful, very successful.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But you know, not knowing enough about American business-- and we set up finance companies.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And then banks decided to go into the finance business.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "They put us out of business.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And it didn't stop us.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "We continued on.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And in the early 1960s, I had a dream that we wanted to build our own community.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And we came out here to Georgia.",
      "word_count": 7
    }
  ],
