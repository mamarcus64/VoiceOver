{
  "stem": "20088.9",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 55,
      "text": "But-- and I noticed that he was very, very on good terms with my mother.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 56,
      "text": "They were very, very nice together.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 57,
      "text": "And then, when I finished school I-- I went to work full-time in this-- in that studio.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 58,
      "text": "But again, I wasn't really very happy.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 59,
      "text": "And I had as a boyfriend, this Hank from the three brothers.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He always fetched me from my work and took me out, and so-- but I wasn't particularly interested in boys at all, still.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And then Otto said, perhaps you want to go to England for a year.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So I said, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Why not?",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And he knew somebody who had that photographic studio here, called [?",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Roban ?] Studio in Bloomsbury.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And he said, I'll speak to her and see if you can go there.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And he arranged it.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I went here.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I knew another boy who had an uncle in Holland, Harry Jacobi.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "He became later a rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And he lived in England.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "He went as a kindertransport child to England.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "But his-- his uncle lived in Holland.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And we knew him.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And this boy found me a boarding-- a boarding house in London in Cricklewood in [INAUDIBLE] Road.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "And so I moved in there and went to work every morning.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And I was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And England was at the time-- it was very bad still.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "There was big rationing.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "You had one egg a week and two lamb chops or little bit of meat and very little food.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "But there was a spirit of rebuilding.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "The English--",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "That was '51.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The English are very good at sticking together when things are difficult.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "For instance, well, you know that here, but in-- you could eat, for instance, in a Lyon Corner House.",
      "word_count": 19
    }
  ],
