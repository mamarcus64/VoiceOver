{
  "stem": "9262.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And we became like detectives, trying to find out who were these actresses, how they were Jewish, whether the grandmother was Jewish, or the great-grandmother?",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And we became quite experts on the racial laws which were predominant at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So life sort of carried on fairly normal, till we were deported to Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "When was that?",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And that was on the 28th of October, 1938.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I usually used to leave my house 8 o'clock in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "My mother got up, gave me something to eat, and left me something to take back to school for my lunch.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And we had a little cuckoo clock in our corridor.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "When it chimed 8:00, I would leave the house, kiss my mother goodbye, and go to school.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "We lived on the second floor.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "As I went down, I saw four people coming inside our block.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "It was an apartment building which went round, like in a half-circle.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And two fellows went on the first floor as I was coming down.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "They were-- they knocked on the door, and they shouted, open up, in the name of the law!",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No uniforms.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They were in civvies.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But I could see that they were Gestapo.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Because we already knew.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We could smell them.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Then, as they went up on the second floor, instead going to school, I had a premonition that something was wrong.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "I turned round and followed them.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "They knocked on my door, shouted the same thing-- open up, in the name of the law!",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "My mother opened up.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "They stormed inside.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "I followed them.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "My, my father was still in bed.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And my brothers were at home.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "And they went through all these, our property.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "And my father said, here's my passport.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "I'm a Polish citizen.",
      "word_count": 4
    }
  ],
