{
  "stem": "20405.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "They took us from there.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They put us in a barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "The barrack was not big enough to hold all of us-- still naked.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And they made us sit down on the floor in lines, like this, one knee to the other, like this-- lines, lines, lines, lines.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "At that night, this-- came that guy, the SS guy, the red one, that we used to call him [? red-- ?] a big tall guy who killed the-- the-- the Russian, Malenkov.",
      "word_count": 33
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And he was looking for the Sonderkommando.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "When I saw him, Carol, I got so scared.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Maybe he is going to recognize me.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I had near to me two guys, which they are in Israel now.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I don't know if they're still alive or not-- two brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "They were sitting behind me.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "When I told them that I was working in the crematoriums, and that's the guy who killed many people, and so on, so on, so now-- now, who knows?",
      "word_count": 29
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "He wants to look-- he's looking for the Sonderkommando people-- what they did is they made a little room.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I went flat on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And they sit on top of me.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "We're gonna stop right there and we're gonna change the tape.",
      "word_count": 11
    }
  ],
