{
  "stem": "16790.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 359.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--give you that.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "These are May '39.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "[GERMAN] What--",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "On the 13th of May.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Doesn't say what the ship was doing.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We used to enter in at the Southampton--",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, and nothing to go through, because he just--",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It was-- we, yeah, right.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Philip Freund, F-R-E-U-N-D.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Philip.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, P-H-I-L-I-P.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Middle initial is S, as in Sigfried.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was born the 5th of June, 1931, in the city of Munich, Bavaria, Germany.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, probably one of my earliest memories was that all of a sudden, we couldn't go to the park.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't ride the streetcar.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't go to the movies.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We were on half rations.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And food-- so food was scarce.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And there was a tremendous amount of anxiety and stress in the home.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And then-- I started going to public school.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And I was kicked out of there because I was Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I went to a-- to a Jewish school.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And that was burned down on Crystal Night in November of 1938.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I was five, maybe six, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I have a sister, a younger sister.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "She's three years younger, Lisa.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Her name now is Avedon, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "We were-- well, a family of three.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And then, we-- then, when Lisa came, we were a family of four-- my father, my mother, sister, and myself.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And we lived in Munich on Elisabethstrasse 19, in a large building.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We-- I had-- I shared room with my sister, if I recall.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And we had a, a good-sized unit there.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "We, we rented.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Non-Jewish.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "No, it was an integrated-- well, my grandmother lived a block down and-- on Tengstrasse.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And then across the street was my grandmother's brother.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He lived across the street.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And down the same street, her other brother, [?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Willy, ?] lived across the street.",
      "word_count": 6
    }
  ],
