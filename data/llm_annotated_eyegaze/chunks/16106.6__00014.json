{
  "stem": "16106.6",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 30,
      "text": "My-- And you are Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 31,
      "text": "Come on, prove it to me.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 32,
      "text": "I said, who was-- who was your [YIDDISH]?",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 33,
      "text": "He said it in Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 34,
      "text": "I said, [YIDDISH] was Chaim and Sophie Saks.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 35,
      "text": "But no, wrong.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 36,
      "text": "They wanted to say Abram, Isaak, and [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 37,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 38,
      "text": "Then they, ?] where are you from?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 39,
      "text": "I said, [INAUDIBLE], Latvia.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "They had one for there, from somebody was from there.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And this guy came and he was-- knew my parents.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So then that was the idea.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I got organized.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They took me on-- on, on, on a truck at night, over there, over [INAUDIBLE], over the-- over the mountains into Italy.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know [INAUDIBLE], no, not for a long time, not.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "In Italy, we went on [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "They were on a farm or I worked in a hospital.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And there where my problem started.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "One day, there was a rumor that the German SS lady has escaped and is-- is about in Italy.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I go with my-- my checkered blue and white from work innocently over their plaza.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And somebody says, [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "They tried to-- but they were angry, those Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "They tried to tear me into pieces.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "Then the American [INAUDIBLE], M-- M--",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "MPs.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "MPs came and grabbed me, schlepped me into prison.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Here I sit in the prison.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Whom do I meet?",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "This strange guy with the Swiss-- Swiss crosses, all bloodied, all smashed in.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "One eye cannot open.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Then the teeth are missing, and [? he ?] sits there like a hunk of raw meat.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And he says, ask her.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "She knows me.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "I know him?",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "He said, the guy said, do you know this guy?",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I said, yes, he was in Stuttgart.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "He was in that same place we were.",
      "word_count": 8
    }
  ],
