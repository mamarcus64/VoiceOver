  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "This, this, this, this, out.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "Take that, a lot of soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "It's 12 o'clock, midnight.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "Everybody's stand in line.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Nobody asked what's going to happen.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "You know can-- this is the Army.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "They are disciplined.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "You walk all night.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "The officers at the front, and you walk.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "In the morning you come in a station, a train station.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] When the train station takes you [PAUSES FOR 5 SECONDS] to a place called [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And there, everybody's out.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And this is a village, a big village.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And the officers opened the door for the farmer.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "How many people live there?",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Two.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "And one soldier here.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Here two people.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "Here three people.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "Nobody can tell [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "You sleep on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "Very hard life there.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "And how long did that continue?",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And then from there, stayed, I come to Stalingrad.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I come to Stalingrad with the division which I belong.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I don't want to tell you the time what I stayed in the villages, a lot of villages.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "It's-- it's a long-- a long story, know, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "No, I'll tell.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Night come, to [?",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Kamyshin ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Kamyshin, ?] this is 35 kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "This was about 20 miles from Stalingrad.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "They stopped the Army, the division line and from there, they get you [INAUDIBLE] this is wool, make shoes so thick.",
      "word_count": 21
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "Get you a very thick with cotton inside-- warm-- to go to Stalingrad.",
      "word_count": 13
    }
  ],
