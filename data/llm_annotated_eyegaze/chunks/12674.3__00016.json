    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 39,
      "text": "But-- but the things like that, I could have killed everybody.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "What did who say?",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "They-- they were-- they were some anti [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They said something about the battle being lost, that somebody had heard over the-- the shortwave radio and told us.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And we made a little one-page thing.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We wrote them on pieces of paper.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Print them.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Who had a printing machine?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We were kids.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "But some of those things happened.",
      "word_count": 6
    }
