{
  "stem": "26486.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "And he said, what are you doing here?",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "Where have you been all these years?",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 6,
      "text": "He had a big-- a daughter the age of mine.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 7,
      "text": "So I-- he said, well I'm coming here to see some precision machines that they were making-- not for the war but-- they said not for the war, but it was.",
      "word_count": 31
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 8,
      "text": "So anyway, we stayed in touch with him.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 9,
      "text": "So I told him, I said, oh, I said, I'm looking for work.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 10,
      "text": "I have no work right now here.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 11,
      "text": "He said, I'm going to introduce you to somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 12,
      "text": "And he introduced me to Simone.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 13,
      "text": "That's how I met her.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 14,
      "text": "And what did you think of her the first time that you met her?",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Well, I said, I'm glad to know you, [LAUGHS] the first time I met her.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And then she took a liking to me, and me to her right away.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "We became very, very close friends right away.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "And then I worked with her at the Chamber of Commerce.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "We never talked underground-- never, never.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "We did-- I didn't know anything.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know she did anything.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "Only when I told you that I wanted to go to Belgium to obtain-- to see a lawyer to get my divorce.",
      "word_count": 22
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 8,
      "text": "My husband was in the Belgium Congo and I wanted to, to quit that relationship.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 9,
      "text": "My daughter had never met her father, because he left me before she was born.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "So anyway, she said you're OK, you're going to work here with me.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "So I stayed and worked with her.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And then one day I told her I had to go to Brussels.",
      "word_count": 13
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "She said, I'll get you a pass.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "We're going to finish the tape right now.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "Rest?",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "May I have a rest?",
      "word_count": 5
    }
  ],
