  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And maybe it was very difficult, because that we should never ever forgot.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "In 1947, my son was born.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "We still lived in Romania.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And in 1947, it became a communist country.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And, of course, they nationalized everything, what I found, the houses, and everything.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "But we were free.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And that was the only important matter.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "Of course, the memory of the camp, what we went through, never ever passed.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "We could never, ever forgot.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "And somehow, in the conversations, whatever we talked about, it finally, somehow we arrived in a word or in a gesture or something remembering about the camps.",
      "word_count": 27
    }
  ],
