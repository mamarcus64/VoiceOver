{
  "stem": "21008.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "So I was also sent to that uniform repair shop.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "It was more than a shop.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "It was two big whole halls full of Jews, and Poles, and Russians, and Italians-- all forced labor workers.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And there, we had to repair German uniforms.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "But we were treated well.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "A certain Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Hoch ?] was the foreman, so to speak he ran it.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he treated everybody nice.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "As a matter of fact, we were sitting there without a star, working, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And-- and-- the-- the Gestapo would come and check on-- on-- on the setup of-- of this factory.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And-- and he would come running out, and put your stars on.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Do you have all your stars on?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "The Gestapo is coming.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "You know, he would warn us, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "He was very-- they were very decent.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And he treated the Russians very decent, which was-- they were the poorest of the poor, these Russian prisoners.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They lived in a camp, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And they were brought to work every day.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They were so poor.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "What we shared with them what we had.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "But he treated them well.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And after the war, the Russians saw to it that he had a good position.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He worked for the Russian army.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He was their tailor then, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He deserved every-- every good thing.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We received 32 pfennig per hour.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And you had to-- you had to-- on this, you had to pay 15% Jew tax, on-- on top of all the other tax.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Nothing was left over.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Practically nothing was left over.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Who cares?",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "There was nothing to buy anyway, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Money at that time didn't make any difference.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I worked the night shift, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I started at-- at--",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "12 hours, yes.",
      "word_count": 3
    }
  ],
