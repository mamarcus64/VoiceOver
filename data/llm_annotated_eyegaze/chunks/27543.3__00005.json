  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they were friends who they-- who they-- they were in the Swedish home.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Just only my aunt.",
