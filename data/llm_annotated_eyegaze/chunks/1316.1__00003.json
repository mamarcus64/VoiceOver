{
  "stem": "1316.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "Then when we opened the restaurant, she was very helpful in the restaurant, taking care of the children, taking care of the patrons in the restaurant.",
      "word_count": 26
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "But suddenly-- yeah, and then she started to attend a-- a Zionist youth organization, to [POLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "And she came home.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And she brought those booklets and pamphlets.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And I started to learn from that.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "I could read-- by the age of 10 I could read already Yiddish.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "And I started to read and-- and got interested in this new movement.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "And suddenly, she decided to leave home, at the say-- at the age of 17, it was in the middle of the summer, in the middle of the season.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "We needed her very much, and she decided she's leaving for Hachshara.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "Hachshara were communal settlements in Poland where the chalutzim, the pioneers, prepared themself for life in Israel.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "They worked a communal life.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "They worked very hard on factories and other works, preparing themself to go to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "It was a very hard dilemma.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "My mother protested because she was needed to attend the children and so on.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "But her father decided to let her go.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "She went to Hachshara.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "She spent six or seven years there.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 37,
      "text": "From time to time, she visited us.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 38,
      "text": "Finally, in 1938, she went to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 39,
      "text": "She came home.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 40,
      "text": "She helped out.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 41,
      "text": "She had to prepare a sum of money because the-- the travel to Israel was illegal.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 42,
      "text": "It was the illegal Aliyah.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 43,
      "text": "They went on a excursion to Italy.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 44,
      "text": "And there, on a ship, they stole into Palestine.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 45,
      "text": "And she-- they brought it a kibbutz, a settlement in the Galil, [HEBREW].",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 46,
      "text": "And we get a letter, she-- she finally arrived safely to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 47,
      "text": "She was in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 48,
      "text": "And she married there.",
      "word_count": 4
    }
  ],
