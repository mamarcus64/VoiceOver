    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "This was a big mistake they did.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "We all got kind of sick in our stomach, sort of a typhus type of a sickness.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But I wasn't really having the typhus very, very hard.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "But you get feverish, very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "You practically have to learn not to touch this food again.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "You just have to eat very little, and very light food.",
      "word_count": 11
    },
    {
