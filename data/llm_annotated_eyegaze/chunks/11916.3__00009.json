    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I got the food, all kind of a food, [PAUSES FOR 3 SECONDS] water, milk, a chocolate, meat.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And we all get sick of this.",
      "word_count": 7
