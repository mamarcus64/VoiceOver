{
  "stem": "14737.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And you know barbers had a machine and puts in your head here in the middle, a strip.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "Cut it off in the machine.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "This was every three, four weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And clothes, we have these striped clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In the winter they give us some coats from those who, in Auschwitz they took and they made a, a, a Christ, like a-- red.",
      "word_count": 25
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "But this one he leave.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Now, here where can you run away?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "For beating, going come horrible, terrible.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "They belong probably to Gross-Rosen but they never heard of Gross-Rosen name.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And here we are working, it's close to 2,500, 3,000 people are in that camp.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Small houses, small prefabricated. 5 o'clock [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I was working here for quite a time.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "At one point a guardsman, an SS, goes with me going to work.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "He was limping.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I was asking him, there I think he was an older man already but I'm going to.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I'm asking about [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "It's half, as some.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "His food.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "I say I'm a podiatrist, I'm a foot doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "Like this.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "To make a long story short, we come out of work, I hear they are calling the foot doctor.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "There are about 20, 30 doctors [INAUDIBLE] But I became the foot doctor.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "Comes out.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "Takes off his shoe.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "I should take a look.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "He has a corn.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "I used to go in Brno [INAUDIBLE] they used to take out they had ulcer corn.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "So I asked him if there was a Gilette, you know like-- I'll be able to-- I don't have any of my tools.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "I don't have no tools.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "So I warm up water for him, and soak his foot, and to make a long story.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And big deal, you know.",
      "word_count": 5
    }
  ],
