{
  "stem": "2568.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 10,
      "text": "There was one of the policeman, Jewish-- he used to take me every day out and bring me to a place that was like an estate I used to call [INAUDIBLE] and used to live a princess there.",
      "word_count": 38
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 11,
      "text": "And then they used to bring all the furniture from the Jews, from the ghettos, all the clothing, silver, everything.",
      "word_count": 20
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 12,
      "text": "So he put me there to work, to select clothing, to, you know just for be occupied not to stay in that camp.",
      "word_count": 23
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "So I've been there.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And one day, the guy comes and says to me-- we had one little room.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We got together more, a couple people.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "We put furniture against the wall, that you wouldn't see it's a room.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "Daytime we used to open, and go out to work.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "And nights, we used to lock ourself in.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 6,
      "text": "Nobody should find us.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 7,
      "text": "One day comes a guy-- he used to be like guard outside, watching the estate.",
      "word_count": 15
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 8,
      "text": "He comes to us and says, you know what?",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 9,
      "text": "Whoever has any money, give it to me.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 10,
      "text": "Let's hide some place because some partisans are coming from the woods, and they know you people are here.",
      "word_count": 19
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 11,
      "text": "They're gonna you.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 12,
      "text": "And I didn't know the guy.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 13,
      "text": "I didn't trust him.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 14,
      "text": "So I said-- I didn't say anything when he left the room.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 15,
      "text": "I had a mattress.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 16,
      "text": "I put everything under the mattress.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 17,
      "text": "In the evening, what happened-- two, three guys come with masks, with guns, and opened the door.",
      "word_count": 17
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 18,
      "text": "They knew exactly how to open it, to move the furniture.",
      "word_count": 11
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 19,
      "text": "Somebody probably squealed something.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 20,
      "text": "And he comes to me first.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 21,
      "text": "He said, where's your money?",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 22,
      "text": "I said, I have no money.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 23,
      "text": "The Russian language he said to me-- first of all, he walks in, he says, hands up.",
      "word_count": 17
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 24,
      "text": "Who was he?",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 25,
      "text": "A Russian?",
      "word_count": 2
    }
  ],
