{
  "stem": "3103.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I put on my uniform that I used to go to school because I came from school and in the morning usually you prepare the night before.",
      "word_count": 27
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "We used to wear black-- what-- black uniforms with a white little collar.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And that's what I run away from home.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "My mother in her dress with a few rolls, my brother, my dad.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "No money, no jewelry, no clothes, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "And we never saw our home again.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "It was maybe 20 miles away from us, but we heard what's going on on the radio that the Germans are coming closer, and my father decide we just going to run so far.",
      "word_count": 34
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Eventually the Germans won't take over all Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "We will wait till it's over, and then we return home.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "But there was no-- and there was no really plan where we going because we got short of gas.",
      "word_count": 19
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "Gas was not available to buy.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "They only saved for the military.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know the day, the mileage, but I remember our first stop.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "First stops used to be small towns, but the big town, we stopped in Lublin.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And I tell you a little story about it that I heard from my father.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "There was the prime minister of Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember his name.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "He came there with the [NON-ENGLISH] to sleep over that night.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "They were running also.",
      "word_count": 4
    }
  ],
