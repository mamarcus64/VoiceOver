{
  "stem": "4513.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "As opposed to the Europeans who said, whatever there is, we will change it so that our life quality will be better and we can live more comfortably.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And I think that was the great schism between the American Indians, the Native Americans, and the whites who came in from Europe.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes, there was.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My father would never go to church.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] My mother used to try to convince him to come to church with us because she would take us.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And I think the reason why we were Baptist wasn't because that was a-- that was a basic ideology called Baptist.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "What happened was that was the church that was in walking distance of our home.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And my mother used to walk us around the corner, because we had no transportation other than walking.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "So my mother used to walk us to the church, which was in our neighborhood.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And it was a Baptist church, and it was a church in the basement because they never were able to get the money to build the church above the basement.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So we used to go to this little basement church.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But my father refused to go because he saw it as being very sacrilegious for him to become-- to come to this kind of religion.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And he just wouldn't do it.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "The-- to get back to the house--",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Let's see.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "There were two bedrooms and-- upstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It was a two-story house-- two bedrooms upstairs and one, two, three, four rooms downstairs.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was-- we-- when I was a small child, we only had furniture in the kitchen and a small table in the living room, and that was about it.",
      "word_count": 29
    }
  ],
