{
  "stem": "12022.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And we find out little by little trains for the-- was going for the Polish army with any kind of foo, with the best food.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "We find bread.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "We find canned meat and coffee and almond nuts and liquor.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Find-- we find everything.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Finally, I brought lots of, lots of stuff.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And, and some soldiers don't have nothing to eat, was going hungry.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I brought maybe a quarter of a bag of cans and lots of bread.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "We used to cut half a lo-- half a loaf of bread and half a can of meat and give it to the soldiers, because we have too much.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "Finally, they give us the train.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And then we went on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "It was-- before the train, they line up all the soldiers before the train.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And then they said-- they took the, all the, the officers who was able to give the command.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And they, they line it up.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And then they said the Polish to step out.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "And the Polish people, Polish soldier by their nationality, they step out.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "Then Ukrainians step out.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "And the Ukrainians step out.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "Then Belarus, the White Russians, step out.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "It was a-- then I heard said, White Russian to join the Ukrainian.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "And the Polish, they took it away.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "I don't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Then were left over a few Jewish people and Muslims, Tatars-- same thing.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Come, they ask us, who are you?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We said, we are Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And who was them?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Tatars.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Finally, they said, Jewish to the White Russian and the Ukrainian.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We joined them.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Then they give us the train.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And they said us, they, they're going to give the train to Vilna.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Now, they don't took us to Vilna.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "They took the train to Russia or just wasn't [INAUDIBLE].",
      "word_count": 10
    }
  ],
