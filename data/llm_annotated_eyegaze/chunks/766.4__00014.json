{
  "stem": "766.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "Yeah, I forgot to tell you, there came another doctor from Yugoslavia.",
      "word_count": 12
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 7,
      "text": "She survived to live in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 8,
      "text": "And we are still good friends.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 9,
      "text": "And we didn't volunteer because we didn't have the right to say what we want.",
      "word_count": 15
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 10,
      "text": "But the German came and put us on the truck.",
      "word_count": 10
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 11,
      "text": "So all right.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 12,
      "text": "So we go, that we'll be shot, like with the others.",
      "word_count": 11
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 13,
      "text": "Fine.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "So-- so with-- so meanwhile, the others marched.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "And I talked in my-- adopted daughter, go.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "And others whom I could, go.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "Because this what she told me.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "And these who said they cannot, and I was on the-- on the truck too.",
      "word_count": 15
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "And we traveled a long time, day, night.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 7,
      "text": "Because I know it was day.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 8,
      "text": "It was night, open.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 9,
      "text": "And it was snowing.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 10,
      "text": "And we were full of snow.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 11,
      "text": "And on the truck we saw that they are dead bodies.",
      "word_count": 11
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 12,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "So finally, we came.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "I don't know what it is again, where we are.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "But this was Bergen-Belsen.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "You heard about it.",
      "word_count": 4
    }
  ],
