{
  "stem": "18397.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 292.6,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Jew in this-- in this part, you know, in the-- in the [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "You know, how they call it?",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "They used to called it [NON-ENGLISH], you know.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH], it was like a-- for-- for-- anyway, I was one Jew in this place.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "I was lucky, because there was another guy from-- from-- from Poland, you know, from far Poland, from the back.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "They speak-- spoke a good Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "But I looked like a goy.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And I-- so they didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Who is the Jew?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I went and-- and then I went to the school [PAUSES FOR 3 SECONDS] of [INAUDIBLE]-- how is it?",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "When you finished, you became a sergeant or something like this.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Engineer Engineer.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "Was it engineering school?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "This wasn't engineer.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Only school.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Military school.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "But they hate the Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And lately, before the war if you had finished school with-- you could get in in college. if they could do it.",
      "word_count": 22
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They wouldn't take no Jewish at all.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "They wouldn't take Jewishes in the army.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "This was the-- they didn't talk about it.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "But they didn't took it.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "But the guys who had the schooling, were lucky.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "But they didn't take them into their army.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "My mother?",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "When you were a young boy, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "She was a young girl, a healthy one.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "My father used to go to shul every day.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Shabbos?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I think so, maybe not.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Pesach, was a seder.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "This was normal.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't a holiday, you know, like to make a-- because this was like this.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Pesach was real Pescach.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "We used to buy-- bake the matzoh.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "We had to go to the bakery.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "There used to be a bakery.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "And they made it kosher for Pesach.",
      "word_count": 7
    }
  ],
