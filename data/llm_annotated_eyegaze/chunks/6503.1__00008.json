{
  "stem": "6503.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I know that she was not living, because a friend of mine came back that knew my brother and my sister-in-law, and said that my sister-in-law was selected for the gas chamber.",
      "word_count": 32
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So she knew that she didn't come, but she said to me the whole time, your brother is doing very well.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He's working for the German, because my brother was  a tailor, and a very, very good tailor.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And he made uniforms for the German army, for these officers there in Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And they told me he was doing very well, and he will come.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But he never came.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He never survived it, the march.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Like they told me in the march, they had no shoes, they had no clothing, they had no food.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Probably something happened to him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They were all very young.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "My brother was in his 30s, my sister-in-law was in her 20s.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "So young people, but none of them came back.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "People got-- we got a restriction that after 8 o'clock, we were not allowed to go in the street.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "That's when the [INAUDIBLE] started, after 8 o'clock in the evening.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Everybody had to be in the house so it was easy for them to pick us up.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "They came with papers.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I remember very well.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "They came one night, and they knocked at our door.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "My husband went to the door and opened up, and before we could do anything, they had the foot right in the door so we couldn't close no more.",
      "word_count": 29
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And they asked for a name that wasn't our name.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "It was the neighbors on the second floor.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So we told them, and we showed them the paper that we-- my husband has a permit to stay.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "So they went upstairs.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Upstairs was a family with three small children.",
      "word_count": 8
    }
  ],
