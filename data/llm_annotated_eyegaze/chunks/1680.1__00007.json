{
  "stem": "1680.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They grabbed a lot of people in the street.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I was once almost kept, but I ran away.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "So I missed these things.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "That was, again, same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And that was going on for two years like this.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "They grabbed people, and they took them away, and they didn't know.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And two years later, then they started officially the deportations.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1942.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That was the 10th of June, 1942.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They ordered every Jew to be registered.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "So I went to register.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And I had a [INAUDIBLE] card, which was called a working paper.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I had a Judenpass.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And in the morning, when I heard registration, I had a neighbor, a young doctor, which I was friendly with him.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "He went with the Judenrat.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "First they ordered the Judenrat to come to register with the doctors.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "So when he came back, he showed me.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I says, what do you have on this paper?",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So he showed me he had a seal, a big seal, with the Gestapo.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And then, when they ordered us to go to it, I was-- the lines were long, for miles.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And it was a very hot day.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Finally, I came into these things.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And I had my papers was-- in the beginning, I had the papers as a [INAUDIBLE], which means businessman.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And I realized that they don't need businesspeople.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They need working people.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "So I went to a locksmith.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And I paid him off that he should seal my papers that I worked for him as a locksmith.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And that's why I am registered on Schindler's list as a locksmith.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And when I had this paper, I came to register, he had this little seal in his hand.",
      "word_count": 18
    }
  ],
