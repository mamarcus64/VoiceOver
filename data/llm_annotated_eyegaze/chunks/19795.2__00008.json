{
  "stem": "19795.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 19.8,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 15,
      "text": "We used to be in the dark and lying and sometimes talking to each other and sometimes no.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 16,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "We didn't-- not about a movie, no the TV.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] So will she get a today a potato or not?",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Who knows if she's going to bring a potato or if she be able to bring a little bit of water.",
      "word_count": 21
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "This, this was the dream, to have a piece of bread and still to leave a piece.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And I say, oh, it's going to be enough.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "This was my dream.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "And thank God for this.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "I had bread.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "I have everything.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Oh, how do you-- oh, she had a broomstick.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "So she used to knock [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "So she used to scream, boy, how come-- how they got upstairs?",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "You know, [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "So we knew.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Nobody even said a word.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And nobody moved.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "Because even you can [? bust. ?] But nobody-- otherwise, we will be dead a long time ago.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I think I went two or three times.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I went to back.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Sure, she let me.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Because it was no-- because they-- all of them, they didn't go.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "So she used to ask me.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "So I, I think twice or three time.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I used to go, got the piece bread, got potato, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "So not only for me, you know, should be even for the lady also.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "Because she was a poor lady.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "In the-- near the house, you know, around, you know, into back.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "It was a lot of people, they used to go in back.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "So some of them, they killed.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And I was the lucky one, they didn't.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No, it was dark.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "It was all over dark at night.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember even to seeing soldiers.",
      "word_count": 7
    }
  ],
