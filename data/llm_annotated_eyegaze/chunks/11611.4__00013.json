  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "He said, this stupid son of a bitch is going to convict himself, which he did.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, you know, I mean, he, he didn't see how you could win a case after your defendant had been identified with about 12, 15, 30 lies, point blank, and I thought contributed very greatly to my case.",
      "word_count": 38
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I-- once I latched onto this technique, that's what my cross-examination consisted of, just leading him into one lie after another.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I cross-examined them all.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Well, to some extent they were.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "They weren't quite as heavily documented as my case against Rasche or Kehrl.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "That was-- that was my nucleus case.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That's what I started out with.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "That's where I put my efforts, but Puhl is interesting, the bank vice president.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Reichsbank, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Because he alleged that he was a defender and patron of one or another Jew, but he also denied knowing anything about Nazi atrocities against Jews.",
      "word_count": 26
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "At the same time, he stressed how useful he had been in saving these Jews.",
      "word_count": 15
    }
  ],
