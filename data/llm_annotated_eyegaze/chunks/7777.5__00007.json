{
  "stem": "7777.5",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 153,
      "text": "I said I give you something, I have a diamond-- he didn't want nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 154,
      "text": "Now I still need $1,500.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 155,
      "text": "I went to my cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 156,
      "text": "I said, Louie, help me out.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 157,
      "text": "I still need $1,500.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 158,
      "text": "He went with me to the bank, and he sign for me $1,500.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 159,
      "text": "When he comed home-- it's his friend was telling me-- his wife was firing so much-- you will lose the $1,500, and the other people will lose the-- She was crazy when I want to go into business, a greenhorn, after 22 months.",
      "word_count": 43
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 160,
      "text": "Only I went in the store, and we moved then in the back.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 161,
      "text": "Was before the holidays.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 162,
      "text": "Is my lender-- he was the lender what I bought from the store.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 163,
      "text": "I come for rent before the holidays.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 164,
      "text": "I told him, Sam, you know, I will close for Rosh Hashanah, Yom Kippur, the store.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 165,
      "text": "He said, Simon, don't do it here.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 166,
      "text": "The store was always open.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 167,
      "text": "And you will close, you will lose business.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 168,
      "text": "I told him, Saturday I have to work.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 169,
      "text": "I cannot make a living.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 170,
      "text": "He had my boss called when I bought the store, I call about not coming to work.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "He was not in the store.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "His son, I told him not to-- in the night he called me back.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Simon, how come?",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "He promised me-- the Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Robinson-- he will take me in for a partner.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He promised me.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And he called me up.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I told you I will take you in for a partner.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Oh, he don't take me in.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "He just promised.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "He will ask me one favor to be closed Saturday.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I told him, Mr.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "Robinson, I bought it money.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Saturday the best day.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "I have to pay the mortgage.",
      "word_count": 6
    }
  ],
