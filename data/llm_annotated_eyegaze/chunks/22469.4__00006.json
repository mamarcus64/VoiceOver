{
  "stem": "22469.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I'm looking for-- looking for the bull fighter.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Come to-- to me, [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] What happened, he said, and they said to him, listen.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We've got letter, and it's stupid.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "You want-- you want from him.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "He's very-- my best friend, the-- the-- my best worker, what-- [PAUSES FOR 4 SECONDS] bring me that bull fighter here.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And somebody brought him.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And Herr Schindler said, you bloody bastard.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "You idiot.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "You start to [? make it-- ?] [INAUDIBLE] hit him in his face, [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "Get out!",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "This was 100% dead.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "Was this-- the portrayal of Schindler is that he was a womanizer-- that he used to drink a lot.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "How true is that?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Womanizer-- I'm taking-- I'm taking a drink.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Excuse me, OK?",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "One minute.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "You want to be patient with me, now.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And a proper womanizer, I'm going to tell you.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] No one man is a womanizer.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "OK, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] .",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Every man, normal man, is a womanizer.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "In my life, if a girl went to my bed, I-- I didn't throw her away.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "That was Herr Schindler.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They were crazy about him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He was so beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was so manly, so [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They were-- our Jewish-- ah, the director spoke to!",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He never touched Jewish girl-- never.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "He was around drunk, he'd kiss a few, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "But the Gestapo came to him.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "But a womanizer-- the-- the most beautiful girls was chasing him.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Believe me, he never was looking for the girl.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "His secretary, beautiful girl.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "She was dead after him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "She was in love with him.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "But she was working.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "At 6 o'clock, she went home.",
      "word_count": 6
    }
  ],
