{
  "stem": "21731.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "And he let me know later that my mother was on this train, and the train was apparently going to Treblinka.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "My mother had poison with her.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "And I hope she took it.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Cyankali.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We all had it.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Well, I didn't take it because I had the child to look after.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "So there we went to Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And nothing happens in the train.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Naturally everybody's gossiped about something, about the German.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "There were Poles.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "There were Germans in the-- in the [BACKROUND NOISE] compartment.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And when-- I knew only one family was-- which was not Jewish in Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And I thought I will go to them.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And naturally, I didn't dare to go to anybody of my family.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "I didn't know whether they are alive, whether they are in the Warsaw Ghetto, whether they-- they didn't want to see me, certainly.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "That was friends of, of Lusia and Milek.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "That was a theater director-- doctor-- a director, [NON-ENGLISH] was his name.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "A very, very famous name, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I will tell you later how it is spelled.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "They were-- no, on the way to them, I gave the address to the-- to the cab driver.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And he went on with the horse.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I saw somebody running after us.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And I told him to stop because somebody wants to talk to him.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "He stopped.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And this man came up to me and told me, you have a Jewish child with you.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And I said, that is not a Jewish child.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "It is my son.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And he didn't believe me.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And he started-- if I gave him a thousand zloty, he will forget about it that I have a Jewish child with me.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And I say, that is my son.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "It is not a Jewish child.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "I didn't look Jewish.",
      "word_count": 4
    }
  ],
