{
  "stem": "2568.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "He said, I have everything sewn in my lining in the jacket in case I'm gonna need it in the future to hide or-- So at the same time came the four SS men from the camp.",
      "word_count": 37
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "And whoever was working that estate got us together, and they want to take us back to the camp.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "So we were marching, like six or eight people, and four gestapo on four corners.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And the one was near me.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "He said, with the shotguns, with his-- I don't remember if it was a gun or machine gun-- he said to me in German, go.",
      "word_count": 25
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "So I start running.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "And I start hiding in that estate.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "Then hours later, I start coming out, and I don't see anybody.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "But slowly, slowly, we met a few people.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "We got together, and we stayed in that place already.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "At the same time, we met a-- he was not German, he was a Volksdeutsche.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 13,
      "text": "He was Polack but he was working for the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 14,
      "text": "During the ghettos and during the Germans, he used to help to kill the Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "But later, he knew the end was so close.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "He wants to save his life.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "So he wants to help us.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "He says, I'm very close with the princess.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "What about we're going to take one room in the top.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "We're going to close up and you people stay there.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "We're going to bring you food twice a day.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "Whatever.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "We said fine, very good.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "We didn't trust him but still, what can you lose?",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "So the closed the last room in the top.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "And once in a while, she used to make us Polish sausages, something-- The princess made it?",
      "word_count": 17
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "And he used to deliver us twice-- we lived in one room.",
      "word_count": 12
    }
  ],
