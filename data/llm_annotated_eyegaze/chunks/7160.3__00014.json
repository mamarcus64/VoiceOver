{
  "stem": "7160.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And I say, to him, the whole thing I did, I say, my wife is sick.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "The baby's crying.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "I come to give my wife a relief, to take her up on the deck, you know, where she can sleep a little bit.",
      "word_count": 24
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "We are three days on this ship, I say.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "She cannot sleep.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Says to me, don't you know, he says, it says forbidden to come in the ladies rooms?",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I say, I don't speak English.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I don't read English.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "I don't know what you want me to do.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "I say, it's against-- but I know.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Then he said the captain, for the captain from the ship, he says to me, you dare attack one of the guards.",
      "word_count": 22
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I say, well, he attacked me.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I tried to defend myself.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "He says to me, what we going to do is, he says to me, we're going to put you-- it will take 13 days on the ship to go there.",
      "word_count": 30
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "The next following 10 days we're going to put you in jail.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "They got a jail inside the ship.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Or, you're going to do errands around here.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "You're going to work around the ship here.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I say, what are we?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "In the Nazi land?",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I say, I be coming to the United States, a free country.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "So the guy push me, I push him back.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I say, I don't kill nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "What's wrong with you guys?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "So he said, here's another problem.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "He says, you're talking back to the captain.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "You've got a big mouth.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "I say, what the hell?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "I do nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "Says to me, take it or leave it, he says.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "You're going to be 10 days in prison, or you're going to work 10 days around the ship.",
      "word_count": 18
    }
  ],
