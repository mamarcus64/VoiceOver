{
  "stem": "13655.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "The windows is blockaded from the Gestapo, from the gendarmerie, and they will shoot [? around, ?] and you can't [? run ?].",
      "word_count": 23
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "It was already late in the night, probably, maybe around 11, 12 o'clock, and I went there.",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And I was sitting near the [? aisle. ?] And I tried to help her, but she is cursing.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "She is in terrible pain.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "Who knows what means gallstone attack?",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "A doctor maybe knows.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "Who went through this?",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "It was late at night, around 1 o'clock, maybe 2 o'clock.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I was dreaming.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "Of what?",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "My father came in.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Louis, you came here to sleep.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "This is not that place.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "I woke up.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "I lift up myself [? with impact ?] And I went to a window, and I was there five times.",
      "word_count": 20
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 10,
      "text": "I couldn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "This time, I came to the window.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] a woman with two boys.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "They're frightened.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "She wants to jump.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "She had a couple towels that made a [INAUDIBLE] strong, something to catch.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "She wants to jump.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "They wouldn't let her.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "They [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "And they've-- are bargaining between each other.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And this woman was with me already when the police arrested.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Then she said to me, you want to jump?",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Jump.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And I said, tell my sister-in-law-- she knows her-- to do the same thing what I did.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "I went and I took the cut piece of cloth, and I looked--",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "[WHISTLES] --jumped down, took off my shoes-- the boots, [INAUDIBLE], and I went in.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "There was destroyed Jewish houses already.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I went into a window.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "I went out the door.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "The shooting was after me.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "And I went outside from the city.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "I was sitting there, and I was thinking what to do.",
      "word_count": 11
    }
  ],
