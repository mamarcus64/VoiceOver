{
  "stem": "9987.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "Fishbein that knew me from before.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And they asked me to be helpful to the Bricha.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "Since I had, since I was a Soviet officer, I had access to any place I can go.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "So they sent me to Warsaw to see Antik Zuckerman.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And Antik Zuckerman was at that time a member of the Central Jewish Committee in Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "The president of the Jewish Committee name was a Mr.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Biederman. ?] He was communist.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "That Antik Zuckerman asked me to go ahead, and since I am-- I am a Soviet officer, he'll be talking to me.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I should find out what they know about the Bricha.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I walked in to him.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I introduced myself as a Jan Jerzowski, but my previous name was Berger.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I am from Krosno.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I'm a member of the Communist Party.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I-- I had somebody, a friend in Krosno over there made me a-- a [NON-ENGLISH SPEECH] what they say a--",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "--paper that I'm a member of the Communist Party.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And he says, you're the right man that I need.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He says, we know that Jews are leaving Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And there is a Zionist organization that's leading them out.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We don't have any objections to the Jews leaving Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We want to know who the leaders are, because we don't want that to happen.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "We want them to stay in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, I told this to Antik Zuckermann, what is happening.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And I decided at that time that that's the end of me being in Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I took a group of these survivors from Warsaw to Lublin.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I dumped them off there at the committee.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "Then I took a group from Lublin to Krakow, came into the Jewish committee in Krakow.",
      "word_count": 16
    }
  ],
