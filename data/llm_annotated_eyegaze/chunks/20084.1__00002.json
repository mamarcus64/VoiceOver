{
  "stem": "20084.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 42.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "We enjoyed playing that.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "And we use to break a lot of windows on the streets.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "And we used to have to pay the price.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "Whoever we broke a window came down running and grabbed one of our hats or our jacket, whatever.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "Father had to bail it out afterwards and pay for the window.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "But this was, you know, like young kids.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "But soccer was the main-- my main interest.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "I used to love playing soccer.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were not considered as a European standard.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We were not considered European standard.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We were not all Orthodox.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But here, we would be considered Orthodox because we were observant.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Father never worked on Shabbat.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "He went to synagogue.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And we had to go to the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And we didn't cook or bake on-- on-- on Shabbat.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "We didn't shop.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "So we-- we were observant.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "But according to the European standard, we were not Orthodox enough.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Oh, used to enjoy all the holidays because, you know, you used to get the new clothing for the holidays, like kids go to the synagogue and show off your new jacket or your new shoes, you know, to the other kids.",
      "word_count": 42
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was fun.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And in the meantime, during the synagogue, we used to like to run out like kids and play a little soccer.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And father limited us.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "He used to come out and get us.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Come in back to the synagogue because we stayed out too long.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "It was-- it was fun.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "It was fun.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And the preparation, mother was baking and cooking for everything was.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "We didn't buy any cakes.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "Mother was baking the-- the challahs and the cakes for the Shabbat.",
      "word_count": 12
    }
  ],
