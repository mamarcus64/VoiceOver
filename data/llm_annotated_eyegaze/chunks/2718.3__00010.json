  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Anybody who couldn't stand up for two or three hours on a zahlappell in the morning, in the freezing cold, or the heat, or whatever, it-- they didn't have a chance to become sick.",
      "word_count": 34
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] They was very, very quickly taken away.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I did receive once-- once news that they were together.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My mother and my sister were together get in-- in the women's camp.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't know anymore who told me, but this sort of news came through.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "When you-- this is why we all-- all tried to get to of the kitchen because the kitchen was the place where all this sort of news somehow got through.",
      "word_count": 30
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And to work in the kitchen, it wasn't exactly-- exactly anybody's dream to work in the kitchen because it-- it-- it was-- it was sort of a calculated risk.",
      "word_count": 29
    }
  ],
