{
  "stem": "8725.7",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I wanted to know America.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I wanted raise my child.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And she grew-- become beautiful young girl.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "At 17, she find a mate and married.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And my husband become not well.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "He become sick.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "One day, I was reading newspaper.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "The newspaper said Holocaust never happened.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "It is propaganda.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Well, that put me on fire.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "How anybody can say so-- I was very-- I was there.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "So I was yelling and screaming.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "My husband belonged to the Rotary Club in Yorba Linda.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "They invite me to speak for the first time in 1980.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "I told my story to the Rotarians.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "There was a rabbi, Rabbi Asa from Temple Beth Tikvah in Fullerton.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "He sent my story to Jerusalem.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "First, he invite me to speak in a temple to the young people.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "He sent my story to Jerusalem.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "From Jerusalem, we received four letters from people I saved.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "There was a-- the survivors uniting.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "First letter I received from the young man whose life began in German major villa.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "He called me mother.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "There were letter from, from Hellers.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And there were letter from Heshu.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And there were letter from-- I have the letter.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "From four people, they, they-- my story was proven.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And, in 1982, I was invited to Jerusalem to plant a tree on the Avenue of the Righteous.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And there I prayed for Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Because if I would go with Haganah, my life would be completely different.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I would be long time Jewish and-- no, I was heartbroken.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Why I couldn't?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I wanted go with Haganah.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I could not find my family.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "But now, I am there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And I made my vow that, for rest of my life, I would spend to try to bring people together, regardless of nationalities, religion, color, or creed.",
      "word_count": 27
    }
  ],
