    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 32,
      "text": "Let him see if he like it.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 33,
      "text": "If he's going to make better, it's OK.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 34,
      "text": "Food and room and board would not cost him.",
      "word_count": 9
    },
    {
