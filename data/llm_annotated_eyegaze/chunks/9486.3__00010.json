  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "You know you couldn't get a job with Jewish or Polish.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "You needed to speak Hebrew.",
