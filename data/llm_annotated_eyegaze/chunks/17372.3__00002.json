{
  "stem": "17372.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Although I would like to go to America to be with my brothers, but my wife wants to go to be with her sister.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And I want to be with my wife.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "So I went to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Can you tell me, was that the last time you saw Oskar Schindler?",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "In Paris, he visit us one day-- in Paris and brought a dozen red roses for Helene.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, he was drinking still.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He was charming man.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "See, he was using a lot of aftershave.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "When he passed by, five minutes after, you can smell he passed [LAUGHS] by.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "He was very handsome, tall, good-looking man.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I mean, after, no-- you see on the photos, he, he went down from drinking.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "His liver gave up.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I came to Paris.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I got straight away work.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "You see, in Paris, I went to musicians union [PAUSES FOR 3 SECONDS] to get permit.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "So you can be hairdresser.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "You can be writer.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "You can be anything, but not music-- we've got too many musicians.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "But I got a job straight away.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I play in, in a-- with well-known, Jewish Russian orchestra, [?",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Yakovlev-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Jakovlev-- ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Yakovlev ?] in very big restaurant.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Then I play in Petit [INAUDIBLE], French restaurant, cabaret, owned by a friend of mine.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Then they play on the stage with composer of-- [PAUSES FOR 3 SECONDS] my god, the names-- [PAUSES FOR 4 SECONDS] Yves Montand was on stage and [INAUDIBLE], famous dancer, on the same stage.",
      "word_count": 34
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And I play with this gypsy band on the stage.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And Django Reinhardt, Stephane Grappelli-- very famous guitar player and violinist, Django, playing on the same stage.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And there-- I stay in Paris for three and a half years.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Very good atmosphere.",
      "word_count": 3
    }
  ],
