  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "But so anyhow, I-- I just agreed to everything, and I kept eating the salami sandwiches.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "So I had never had so much food in the previous nine months, like I said, I had on that one evening, which was a good thing because I built up my strength a bit.",
      "word_count": 35
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And so the life went on as usual.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "It was January, January '45.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And then we got the papers, and we could see that Krakow-- Krakow-- the big city of Krakow has fallen to the Russians, and they were advancing.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And the big, huge winter offense-- [GERMAN] started.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "The attack started.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And then we didn't know what will happen.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "We thought that either they will kill us all.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "We didn't know what will be.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "But we had some-- we were scared of the future anyhow.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Mm.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So we arrived to the middle of January.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So we did some progress.",
      "word_count": 5
    }
  ],
