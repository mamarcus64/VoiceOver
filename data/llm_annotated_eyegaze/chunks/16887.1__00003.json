{
  "stem": "16887.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "And I was afraid to go in the boat, because I promised not to.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "So I sat down by the river.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "But as I sat down, one of the boys passed by me and gently pushed me in the back.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And I went down to the river, all the way down.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "Being that there was a lot of people, I couldn't swim.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "There was a lot of people, and somebody jumped in, grabbed me by the hair and pulled me out.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "As I was crossing the street dripping with water, it was [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "I was shivering.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "My mother was sitting on this-- in the yard with neighbors talking.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "And she saw me coming on and dripping.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "She asked me what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "Being that I was afraid to tell the truth, I told her I fell in the gutter.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And then my friend said, no, it's not true.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "She was drowning.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "So my mother took me upstairs, covered with me with a heavy blanket.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "In the meantime, my father was coming home.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And he already found out in the courtyard from the neighbors how lucky he is that I didn't drown.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "As soon as he came into the house, he asked my mother what's wrong with me.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "My mother said that I have a headache.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "She knew that I'm going to get a spanking.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "So my father says, well, in one minute, I'm going to cure her headache.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "And we always had hanging by the window those whips.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "And they were consisted not from one, but there was about 10 or 12 tied together.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "So my father took the-- the cover, throw it over my head, and I got such a whipping.",
      "word_count": 18
    }
  ],
