  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "This-- no, this-- this happened in 1926.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "June 11, 1026.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We're having knowledge of-- in the 1930s, late 1930s, having knowledge of English.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I learned already English [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I became actively involved with the-- the American colony in Paris.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 7 SECONDS] And I'll show you pictures of a friend of mine that was a director of the United States line.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "He was also born in Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Very fine fellow.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "He's still alive, I think, today in Florida.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And through him, I became friendly with the whole office in the American Legion.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And somebody proposes to me.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Said, would you like to go on a trip?",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I heard a trip, I said yes without knowing.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "So two or three months later, they're giving me an assignment [PAUSES FOR 5 SECONDS] to bring somebody to Yugoslavia in that time.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] So I accomplished the assignment.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "They paid my pare, paid whatever expenses that I had, and that's all.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And that's how I reached a day to go to Persia in that time.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "It was prior to the War, World War II.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And I went there to Persia to work on security.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 4 SECONDS] That was also from Western Electric.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In the palace of the Shah of [INAUDIBLE], and in September 1938, I think.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was his birthday-- 50th anniversary of Shah [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And while I was in Persia, I looked around.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I went to any place.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I remembered I was supposedly born in [?",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Purim. ?] This story of Queen Esther.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And there was a-- there's a city in Persia by the name Hamadan.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And this is a big petroleum center.",
      "word_count": 11
    }
  ],
