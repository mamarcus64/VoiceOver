  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 52,
      "text": "And many testimonies like mine and the Holocaust Museum here in Washington will give a wonderful educational opportunity, and the Shoah program which I am participating here today.",
      "word_count": 28
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 53,
      "text": "And if I get this copy of this taping, maybe in years to come, when my children, grandchildren, and the following generations can read, and learn, and hear about it, it will h have some educational value.",
      "word_count": 37
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 54,
      "text": "And I thank you for your time.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 55,
      "text": "And it was emotional for me at times.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 56,
      "text": "And I'm sure I will probably think of it that maybe at times, I should have said more, different, more eloquent.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 57,
      "text": "But all of it is done in memory of my relatives I lost and classmates I lost from the Budapest high school, because they were-- they were my life.",
      "word_count": 29
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 58,
      "text": "And thank you.",
      "word_count": 3
    }
  ],
