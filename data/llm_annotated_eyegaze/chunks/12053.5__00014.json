{
  "stem": "12053.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We had weddings to make.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We had money to earn, a living to earn.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have time for things like that.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "We weren't ready for it.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "But now we're retired.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "That's when also a lot of the rot sets in.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "A lot of us now need mental support coming to terms with all the things that happened so long ago.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "But I'm still glad I've sort of preserved it.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And just the thought, 49 years after the event that nobody was doing anything about it, gave me the idea.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "Otherwise, it would have been completely forgotten.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "So that's my work now.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Thank you very much.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And thank the cameraman, the crew, and the ladies behind the scenes.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It's a lot of work you're doing.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And thank Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Spielberg, because without him, this project would have never got off the ground.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I know lots of projects exist.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH] lots of things exist.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "But he's doing a tremendous project.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Thank God he can afford it.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
