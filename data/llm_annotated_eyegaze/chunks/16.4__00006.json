{
  "stem": "16.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And when they were asking for papers on the train, we made believe we're sleeping.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And that, that way, they left you alone.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And one way or another, we made our way to Prague, where we had a cousin that was married, and she lived there.",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "In fact this was Andy's sister-- the Andy that lives here, Andy Meisels.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And we lived-- and then one day, we got a telegram from my uncle, that there's $500 waiting for you at the Czechoslovakian National Bank.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And somebody advised us, do not take the $500 out all at once because they give it to you in Czech money.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And from day to day, it changes.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So we sort of, like, lived-- for $10, another $10.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We lived off of that for six months, even going to nightclubs a few times, eating in restaurants.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And after six months, which was 1947 in May-- March-- we got to New York, I still had $40 out that $500.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I want to give it back to my uncle.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHTER] He says-- [LAUGHS] he started laughing.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He says, keep it for pocket money.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] He was really nice, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He-- when he saw the, the nightmares, the crying that I did, and all that, he says, why are you sitting always in the house?",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I came home from school.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And I sat in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He had a television set.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "People came-- neighbors came to watch television.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "That was in 1947.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "It was-- Milton Berle has just started.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And he used to give me, like, $20.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Why don't you go out and have some fun?",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Here's the keys to my car.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Go take out a girl, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Go have some fun.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "He had a brand new Cadillac.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "He gives me his keys.",
      "word_count": 5
    }
  ],
