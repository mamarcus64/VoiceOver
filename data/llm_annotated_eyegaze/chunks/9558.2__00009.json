    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "It was very cold.",
      "word_count": 4
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it took us I think around three days.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "And there was the crying, the screaming.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "And-- and they put in God knows how many people, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "And those cattle wagons.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "And you had no room where to sit down.",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "You-- you had-- it was horrible.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "You had no place where to go to urinate, or whatever, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 6,
      "text": "And people was standing, and it was cold.",
      "word_count": 8
    }
