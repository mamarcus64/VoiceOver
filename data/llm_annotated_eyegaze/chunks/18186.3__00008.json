{
  "stem": "18186.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.9,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "He-- he wore a-- I saw him in a uniform, not all the time, but specially when they used to have friends, invited the Nazi friends to their house for dinner, holidays.",
      "word_count": 32
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "I served them.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "I was not allowed to hear.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know anything about the war.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know if there are any Jewish people left.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "After the war, I thought I'm the only one who survived.",
      "word_count": 11
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "And then I was thinking, what will I do?",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 5,
      "text": "To be only one survivor of Jewish survivor in the whole Europe, Europe.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 6,
      "text": "But thank god, that more people survived.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 7,
      "text": "So-- so this was a day even he left to the army.",
      "word_count": 12
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 8,
      "text": "Then she was left with me.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "That was his wife, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And she said to me-- they not-- had no children.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And she said to me, you know, I would like to adopt you as my daughter.",
      "word_count": 16
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "No idea, not to my--",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I came with the family, and I'm the cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "I came with my family.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "I got to go back with my family.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "Wherever we go, I want to be with my family.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Because she's left-- Around the same-- it's only months of time.",
      "word_count": 11
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Like 14--",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "15-- Huh?",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "After, yeah, yes, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No, about 15.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "No, when I-- 18, I was not quite 18 when I was-- after the war, when the war was over.",
      "word_count": 20
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I married my husband when I was like-- I was [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "I was-- I needed somebody to sign for me.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "I was still not fully-- like a minor.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "Anyway, where was I?",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "So, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Well, she was left.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And the-- the Russian army was coming near closer, nearer and nearer to us.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "So she came from Berlin.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "And she want to-- she packed everything up.",
      "word_count": 8
    }
  ],
