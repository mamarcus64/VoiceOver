{
  "stem": "11671.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.0,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And then I was-- we went to this-- I went to this makeshift kibbutz, which was in Binyamina, a town about 30 miles from Haifa.",
      "word_count": 25
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And Harold was starting at the Technion and lived in the separate headquarters.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And then he came, and he joined our group as an official member.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And the group let him continue studying at the Technion.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "First, I stayed with a cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And my group didn't get-- I got out in August, September.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And my group didn't get out until December.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So I waited.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Miriam was with the group.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "So Harold and I waited until March of '47, until the whole group got out and my sister got out.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And we were married in March 1947.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "With the whole group.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And then my pictures are in this Binyamina, which was a small town at the time.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It's still a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And all the children of the village came to watch, and the kibbutz people.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And you'll see some children in the background.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "But that was-- that's where we were married, in Binyamina.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We stayed there almost a year.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "A little less than a year.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Harold wanted to continue his studies.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And conditions in Palestine were terrible at that time because the British were still there, and the Jewish people were trying to get them out.",
      "word_count": 25
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And bombs were going off all over.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And the curfews-- you couldn't leave, and you had to be back by a certain hour in the evening.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And it just was-- this was October of 1947.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "The United Nations voted on the partition in November.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So when we were there-- we were married in March.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And then April, May, June-- the entire time, conditions were very, very bad at that time in Israel.",
      "word_count": 18
    }
  ],
