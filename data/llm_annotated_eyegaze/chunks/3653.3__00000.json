{
  "stem": "3653.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[SIDE CONVERSATION]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It was about three weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "They were there, sure.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They thought maybe they will start beating me and I will tell the police.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But I wouldn't send the police.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "My mother used to come to us, Easter time, there in the bunker, to bring the water, the Easter water from the church, and sprinkle on us to live through.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And she used to say, just preach to Jesus.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "Then you will live through.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And the boy, your brother, used to take them out in the fields a little bit, during the daytime.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "Said, nobody knows you.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "But if you were here, they would know you.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Now they were in the fields for a couple hours.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "They came back.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And she, the girl, used to take me in the nighttime, a little bit of work.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Well, they thought, after the war, the parents came to me.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And they thought I was going to marry her.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "But I wouldn't do it.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "She deserved, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "She deserved, but I couldn't do this.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "I send them money all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "Now she's dead.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "But I sent her money, packages always.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "But they took me, no chance to live, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "They were good people, I'm telling you.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "With their whole heart, they want us to survive.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My--",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] She got two guns for us.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We thought in case something happened, the Germans will catch us.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So we talk to each other, we kill each other, and the last bullet, you kill yourself.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But it never happened.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Two guns she got for us.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you mean with the Polish people?",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Everything that we went through.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "So after the liberation, we went out.",
      "word_count": 7
    }
  ],
