  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "So the-- the Russian soldiers opened up some storages in this town, which was very dangerous.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "Because it was like a stampede.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "A literally a stampede.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "People started to step one on the-- it was a human stampede.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "I'll never forget it.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "People were running.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "If somebody fell, they'll step over him.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "They'll kick him.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "People were really not-- I felt, I kept on saying to myself, we managed three years.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "Let's not-- let's not go crazy now.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "Let's try to control our feelings.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "But I do remember that-- that run.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "That it's-- they were running five pairs of shoes, six.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "Shoes, clothing.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "Not even if it was fitting you.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "It's like grabbing things, a stampede of human bodies from-- from joy, from the liberation of opening up the gates.",
      "word_count": 20
    }
  ],
