{
  "stem": "12564.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We connected with a Jewish fellow from Cuba named Morris Demel.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Demel, D-E-M-E-L.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And we start-- we created a company with the name April Industries, like the month of April.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And we start building in Puerto Rico.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "This was from 1970, [PAUSES FOR 3 SECONDS] in Puerto Rico, already building with the experience I got, already, from New York.",
      "word_count": 22
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "We built an average of 1,000 to 1,500 homes a year, mass production.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "We hired one of the eight auditors with the name [INAUDIBLE] in New York.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Eight-- if you want to go public, you have to have one of the top eight.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Senator Javits was our law firm in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "That's where he helped me to get my brother in.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And after three years, our average profit was a million and over, net, every year for the corporation.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "We went public.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And we sold, successful, the stocks.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So at the meeting before this stock was finally-- before the bell when you sell the stock, we had a meeting with the underwriters from Wall Street.",
      "word_count": 27
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "One of the underwriters ask me, Mr.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Aptekar, would you mind telling us which financial school you finished?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I said, why not?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The name is Lysa Gora.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was-- everybody was quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Nobody understood what I answered.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I said, I was hiding in the-- in the woods with a mountain, the name, Lysa Gora.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Lysa is like a bald head with no trees on it.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And that's the school, what I finished.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And the stocks were successful sold.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "The oldest is 21, in Austin, college.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Second one is 20, which is North Carolina.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Goes for doctor.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They're both going for doctors.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Then I have-- I go on the line.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I have from my younger daughter, I have two girls.",
      "word_count": 10
    }
  ],
