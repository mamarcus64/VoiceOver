{
  "stem": "22652.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "They had-- [POINTS] two of them were supposed to be shipped to Israel by their uncle, and they fell in on their knees with tears saying, saying, we don't want to go to Israel.",
      "word_count": 34
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "We want to stay here.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "Keep us.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And the uncle had a change of heart, and they stayed in France.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "So I wasn't the only one who felt that way.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "30 days on the-- on the-- what do you call those boats?",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Cargo.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We landed in New Orleans.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And there were six Polish girls, orphaned.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they were on their way to Cuba, hoping eventually to come to America.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I was put-- somebody was waiting at the boat.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And I was put on a train from New Orleans to LA.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And then I-- one of the brothers, Liderman brothers, greeted me.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And then somethings sad happened.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And that is they said to me, the two millionaires, they said, you're not part of our family.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We've done our job.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "We've bought you over.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Don't ever call on us or ask for any help.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "We're not going to give it to, to you.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "You're not part of our family.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So I got to see them on formal occasions, maybe a wedding, or a funeral, or a-- or birthday.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But I was never to call on them.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So what did you do?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "You were 15 years old and you were in Los Angeles.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was living with my aunt and uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And then became-- and that-- when I came here at the age of 15, my sufferings began all over again, because they were very abusive.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And very cruel.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They were very cruel and abusive.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They also-- I found out later-- you know, things go on behind the scene.",
      "word_count": 14
    }
  ],
