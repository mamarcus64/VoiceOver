{
  "stem": "8002.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "But they didn't go deep enough.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, we, we weren't harmed.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "But my mother says, we can't stay no more here.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "We got to run away.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Because they're going to find us.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So we went-- we want to go back to Dvinsk.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "A woman saw us walking.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And she start to scream, you dirty Jew.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And she called the Latvia police.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And they took us to Dvinsk jail.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "In Dvinsk jail, they put us in a cell.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Maybe it was three feet by six feet, no more.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And the windows was covered.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They had covers.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "You can only see on the ground, but you can't see in front of you or upstairs.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "It was a, a big cover-- covers the windows.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And one of the Gestapo start to ask me questions.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Do you know where the Jews are hiding?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Did you know-- where you come from, you, you must hid some Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So where they hiding?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I told him, I'm, I'm a little boy.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I don't know nothing about it.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And he start to hit me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Where did he hit you?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "He first hit me in the face And then on my shoulders.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And then he took out a little black whip.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And on the end, had lead.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And he start to hit me over the head.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Because I told him, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "We were only me and my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "He, he told me I'm lying.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "Then he put me against a wall.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And there was mud-- actual mud on the wall.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "And he put me against it.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "He said, you better tell me the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I said, I'm telling you the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "And as I was stood against the wall, I heard zzzzzzzzz.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "And my whole body went like on a fire.",
      "word_count": 9
    }
  ],
