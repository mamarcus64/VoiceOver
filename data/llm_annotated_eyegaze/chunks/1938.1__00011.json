    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And this, the pail was under straw.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "So we had a party.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "Everybody was eating this thing.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "And then they became typhus, typhus, bloody typhus from all this cold, old potatoes.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "And this was the only party we had through the five months.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "So I like to make-- you have some questions.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 9,
      "text": "Go ahead.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't have no questions.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
