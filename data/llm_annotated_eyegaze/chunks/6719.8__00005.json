{
  "stem": "6719.8",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "And I said, oh my god, this is a mental home.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "And I kept on going.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So we sat down in a room.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And the nurses were nuns with the habits.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And there were about six or seven people with me in that same room down there.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And she came in and told us to take off our belts, to take off-- to take out-- if we had any false teeth, to take it out, and this and that, but still keep on being dressed.",
      "word_count": 38
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Just keep your pants and your shirt on.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And then they led a person at the time to a room on the other side of the corridor.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And then we heard this thumping noise, like somebody hit something, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Like you take a piece of wood and you hit the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "No notice.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And then it was my turn.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I walk in there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There were two or three of nurses and a doctor with a white coat.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Please lay down.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I lay down.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And they fastened something on my ankles.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They fastened something on my temples.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And then she says, please open your mouth, sir.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And I get a piece of rubber pushed into my mouth.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "She says, bite.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And the next thing I know, it was-- I woke up next day at home.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "What happened was I had shock treatment.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And I went back down there, I think, about five or six times.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "Shock treatment to me was one that gave me a tremendous headache the next day.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "I thought my head was coming off.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "They sent me home by ambulance, not by bus, with my mother-in-law.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "That's why somebody had to come with me.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "That's what I found out.",
      "word_count": 5
    }
  ],
