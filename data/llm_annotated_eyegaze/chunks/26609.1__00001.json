{
  "stem": "26609.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Her husband didn't like to review her story.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "So he kept it a secretions there.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "But when I came over there, I said, no, my sister's Jewish, I am Jewish, and I want everybody to know that she is not a Christian anymore.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "The war is over, she has nothing to fear now, and to tell the truth to everybody.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "So she did.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And, since then, a few years later, her husband had a heart attack-- passed away.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "She moved.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "It was a small town where she lived-- Berre-l'Etang.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "She moved to Marseille to be nearer Jewish people and went to a synagogue there.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "Now she lives as normal, as a Jewish person with Jewish friends, going to synagogue for holidays.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And we are in contact.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "That's the story how I found my sister.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I had three sisters-- I was the fourth-- and two brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Together, we were six.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So the eldest sister was Sarah.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Later was the brother Joseph-- one after the other.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Then was Rachel, then it was myself, Ella, the one in France, and Wolf, who was killed by the Nazis.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They all were killed, except Ella and myself, of course.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So we had two survivors.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And later I'll tell the story about my child, who was born in '39.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And, after the whole story, I have to tell it, how she survived.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Now she lives here.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "She's married.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "She's not anymore Mehr.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "She's Wald-- W-A-L-D-- 'walt,' Wald-- and lives with her husband and three children.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "I have three grandchildren.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Where was born?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Grodek, by Lwow.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "It's about 25 kilometers from Lwow.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It's actually like a big suburb, but it's a city for itself.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Grodek Jagiellonski.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And, as I said, my name was Spiegler.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "How many people, you want to know?",
      "word_count": 7
    }
  ],
