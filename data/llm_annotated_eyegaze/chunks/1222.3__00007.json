  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "And the only thing that I got out is two of the most wonderful children [SOBBING] that I ask in my life.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "They are with me all the way.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 44,
      "text": "They [? won. ?] [?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 45,
      "text": "Brendala ?] had to raise yourself alone, who helped me so much to raise up til today with your brother Archie.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 46,
      "text": "And up til today, he's your boss.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 47,
      "text": "They're doing very well.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 48,
      "text": "He's the one that assigns the checks.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 49,
      "text": "He pays your wages and even takes [INAUDIBLE], not the first time.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 50,
      "text": "He's very good to you, and God bless them.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 51,
      "text": "That's a blessing.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 52,
      "text": "So I would say I do have-- there must be a God.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 53,
      "text": "I'm not too fanatic with religion, but I do [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 54,
      "text": "It must be something, because I saw a lot of time and deaths in face, and so many times, I just get out of it.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 55,
      "text": "I don't know how, in what, but there's somebody's watching me.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 56,
      "text": "I don't know what does it.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And right now, I have so much confidence in my two children that a lot of people say, why don't you get married again and again?",
      "word_count": 26
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I just can't disconnect me, my children.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Like I tell Brenda-- she's listening probably-- [?",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Brendala ?], when you were born-- that's your birthday today.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I love you when you were born.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And Archie, the same, I love you.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I'll love you till I close my eyes, because they are with me all the way.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "[SOBBING] The best blessing what it could be, when they went with me to put in this headstone.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "If my son and my daughter would make me millions and millions and millions, wouldn't be such a good gift.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "[SOBBING] But they went with me hand by hand, step by step, to these steps with my parents.",
      "word_count": 18
    }
  ],
