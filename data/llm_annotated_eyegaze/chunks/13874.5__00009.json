  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It was taken last year, in 1995.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] This is the family of our son, Thomas.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "On the left is our son, Thomas Selling.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Next to him is his-- their eldest son-- the heck--",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Richard.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And next to him is our younger son, Matthew, and his wife, Jane Hagen.",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "This is my wife and helpmate, Hilde.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We have been together for 48 happy years.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "But I'm not looking forward to another 48.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "50 would be enough.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    }
