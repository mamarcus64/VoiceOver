{
  "stem": "3022.6",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "That's how well she took care of me.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "And I started looking for a job.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "The first job I went-- when I came to Atlanta, they had a bus strike.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "So I had walked Atlanta far and wide, looking for a job on foot.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 48,
      "text": "The first job I applied for was in the At that time, they had I wanted a job at a newspaper.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 49,
      "text": "Coming over on the boat, I edited a newspaper on the boat.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 50,
      "text": "Everybody had to work.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 51,
      "text": "I wrote for a newspaper in the University of Frankfurt.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 52,
      "text": "I sent some articles to I felt that I would like to go into that particular field.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 53,
      "text": "And this head of personnel took me aside and he said, look, you're not an American, you're not a Southerner, and you're Jewish.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 54,
      "text": "You have three strikes on you before you start.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 55,
      "text": "If I get you a job, you're going to be stuck in the copy room for the rest of your days.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Do you have any other skills?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I'm a machinist.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I worked in the machine shop.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I went to vocational schools.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He said, get yourself a job in the machine shop.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "So I got a job in the American Machine and Foundry.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It was owned by a Jewish man.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I worked there close to a year.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "In the interim, I applied for my first papers.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "When the shop closed-- the man went out of business or sold it out to somebody, I don't remember-- I got a job with Marietta Aircraft Factory.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And Monday morning, I arrived with my toolbox, ready to work.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "You had to fill out a little paper.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And there was a question, are you a citizen or not?",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And of course I wasn't a citizen.",
      "word_count": 7
    }
  ],
