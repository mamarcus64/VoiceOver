{
  "stem": "11882.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Jane Lester.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "J-A-N-E L-E-S-T-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "December 13, 1914 I was born.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, add it up. 81.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Kane, Pennsylvania.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They called me Jane of Kane.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It's a little town in Pennsylvania.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And my great-grandfather sent a card to Jane of Kane, and it was delivered-- because my family was noted.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They had the movie theater in the town, which was a very rare thing in 1914.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No recollection.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I left there in early childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I went back to the home of my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We all came from Brockport, New York, suburb of, oh, 20 miles from Rochester.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Eastman Kodak, Rochester, New York, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, my family are, as with many Americans, derived from many European immigrants.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "One line comes from Britain, Great Britain, from Germany, from Ireland-- and many-- in the way that many American families are-- a little bit of French.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Perhaps American Indian.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, primarily, he was a merchant, clothing-- clothing and dry goods.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "No, she was most frustrated and stayed home, and wished she had not been so-- what should I say?",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Reluctant to keep on with school work, and stayed home and had a large family.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Typical spinster, but she had a large family.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was the oldest of five children.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And we grew up in western New York.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I think I had 65 living, rather close relatives when I was a little girl.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And we're always-- my mother couldn't get as far away as she wanted to from the place she came from, and was about 13 miles away on Elm Grove Road, upstate New York suburb.",
      "word_count": 34
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They were three-- they came three-- after me, I had two brothers and a little sister.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And 15, 16 years after I was born, came our little-- our youngest, Elizabeth Ann.",
      "word_count": 15
    }
  ],
