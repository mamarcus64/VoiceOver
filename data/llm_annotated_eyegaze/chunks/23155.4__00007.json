{
  "stem": "23155.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "I was transcribing articles.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Like, people who submitted articles, hand written, I would type it out, or-- and then we had a place for people who had [INAUDIBLE] who subscribed to it, and things like that.",
      "word_count": 32
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And one day, I went downstairs to the-- to the mail room.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And there was a man who knew me, and he said, oh, you speak English?",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "He said, you know I have a good job for you.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I said, what is it?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "Oh, they-- they're looking for somebody at the American Joint Distribution Committee-- distribution committee.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And I said, gee, that would be good.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "So I got this job, and it paid much better than the one I had.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And that's where I-- that's where I went.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I-- since I had a job, the Gerstls said, no, that now I'm on my own, I should live by myself.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "So they found a room for me to stay.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "It was not very good.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I found another room.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And so I was rooming around there until I found a kind of nice room with a family, [?",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Stumpf, ?] in a villa.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "It was a small room, but it was nice.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "There son-- the lady-- Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Gerstl didn't know, but Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Gerstl knew that he died on the 15th of January in Dachau.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And so, since I was too old for them to adopt me, because there was not-- I was already grown up-- they adopted a small boy by the name of Peter.",
      "word_count": 31
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So we consider each other-- like, we consider ourselves as brother and sister, since we were kind of adopted by them.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He lives, today, in Austria.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "He has three children.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "He came to see me two years ago.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And we keep in constant contact.",
      "word_count": 6
    }
  ],
