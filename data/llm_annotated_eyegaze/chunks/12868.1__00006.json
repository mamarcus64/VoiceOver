{
  "stem": "12868.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Slobodka ghetto.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Kovno didn't was a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "This belonged to Kovno, you know, Slobodka.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto before, right now when the-- when the-- the Nazis came in.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It's before the [INAUDIBLE] over there.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "It's the anti-Semitic, you know, the-- the Lithuanian.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They kill more Jewish than the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "They came, and they robbed, and they killed, and they did it worse than the Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "All of them.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't leave by myself, but they took us every day in the morning, about 3 o'clock, 4 o'clock in the morning.",
      "word_count": 23
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They took us to any kind of work.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "The Germans came, and they took 300 people, 500 people to work on a-- on an airport or to dig ditch, to dig, to do all kind of hard work.",
      "word_count": 30
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Do-- do you got to come in a place.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "All of them got to go in the morning to say, everybody come on them-- their place.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans select how many people they need to work-- 100 people here, 100 people there, 100 people in the other place.",
      "word_count": 23
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "They took like-- like-- I didn't select.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I was placed where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Where they take you, you got to go.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And you couldn't say no.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "They who say no to-- you were right there.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "What they give you.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They give you some 100 gram for a person a day.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Bread on-- on a-- on a soup, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Some kind of soup from the horse meat.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Later, they give you like a piece of-- like a piece of margarine one day.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "You got a piece of marmalade, something like this.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "But this is-- this-- people died every day like-- like flies, you know, from hunger.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "Especially children.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "Especially elderly people where they couldn't work.",
      "word_count": 7
    }
  ],
