{
  "stem": "19969.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "At that time, district attorneys could also have a private practice.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "That's not the case anymore in Colorado.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Now district attorneys are full-time.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Well, I practiced there for 10 years or so and then was appointed to the Colorado Supreme Court as a justice in the Colorado Supreme Court, served out an unexpired term of one of the justices who had died.",
      "word_count": 39
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And then I had various-- I became a special assistant attorney general with the state of Colorado and was sort of a lobbyist for the state of Colorado and Washington for about 20 years and retired about in 1979.",
      "word_count": 39
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I retired-- I got-- after I got out of the service, I was in the Reserves.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And then I decided-- I had never been in the National Guard, but I had served with the National Guard regiment in the whole war.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So I joined the National Guard here in Colorado.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I ended up as a commanding general of the Colorado Army National Guard and retired from that in 1977.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "In 1979, I retired from everything.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, later, yeah, there were.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "About 10 months after I got back, our oldest daughter was born.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Jean Ann.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "She lives here in Lakewood now, got three children of her own.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And then two or three years later, a son was born.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Scott.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And then a couple of years later, my last child was born, a daughter, Kim.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "All of them are here in the metropolitan area.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We now have six grandchildren.",
      "word_count": 5
    }
  ],
