{
  "stem": "1160.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 363.8,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "None of the children are survived, and he hasn't seen any children yet.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "And he came back from somewhere terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "I don't know which part of the concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And he's looking for his family.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "If he has a lot children, also.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And he says, if we are alive, and we came back-- he says, from where to?",
      "word_count": 16
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "From Austria.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "Then he has hope his children will come back.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And he started this.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "At first he says, are you really living children?",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "He was asking, are you really alive?",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "And my mother says, don't talk to him.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "He must be crazy.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know that he's in Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And he was offering us some money.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And my mother didn't take it.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "He was a-- she was-- we were afraid.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "We didn't know what was going on.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "But all the way-- and he says, he told us where to go.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And they are going to feed us there.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "So they were already waiting for people who were coming back.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And he said, the Joint must have been-- you heard about the Joint?",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "This is like a-- Yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "It was already, I remember they gave out--",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "They were setting up, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "--soup.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "They gave us such a nice soup there.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "It was delicious.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And I wanted to eat more.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And I really couldn't eat more.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "A big plate--",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "--and I started to eat and eat.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And after a few spoons, I put it down.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And I was-- I was so sorry.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't eat it.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "I just-- I was very hungry, but I couldn't eat.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I was feeling-- I was scared.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Scared because-- never been to Budapest before.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "It's a big city.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We were walking there.",
      "word_count": 4
    }
  ],
