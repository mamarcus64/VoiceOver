{
  "stem": "27409.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And the chief of police, of militia there, told me he will close his eye if I run away-- to run away because they take all the young Jews, work able, labor [INAUDIBLE] away.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "But I couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "My parents were there, my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "So I had to stay put.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "We were taken all to Shargorod.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "From Shargorod, we were taken along the highway to-- back to-- to Mogilev, where we were brought to the station.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "There were already German standing around.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And over the entrance they had arbeit macht frei.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "They had the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "They were enclosed in the ghetto where you had to pass through the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I saw some friends, but went through.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "There were already from other places Jews, a whole train standing.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And they told us they had taken, the previous day, one transport for Mogilev.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It goes to the coal mines, the peat exploitation near [NON-ENGLISH], Nestervarka.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "So I went up to [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "From there we were escorted by a Romanian and Germans because in [NON-ENGLISH] were a German garrison and the Gestapo.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "They had a headquarters there.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "To Nestervarka and put in the stables of the local call house, which was empty.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And there were about a thousand of us.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE] from different place.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I found a cousin of mine.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "All we heard what happened in other places.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Some escaped death, particularly in [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "Next [? to ?] no food, only a pill.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "That means beating, beating, beating.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "Their dogs, which were rounding us up.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "Next morning, off to work.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "We were driven by escort [INAUDIBLE] a Romanian and Ukrainian militia up to the workplace.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "The had an exploitation of peat there.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "They put us to dig peat.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "They had pumps there where they worked.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "First, they had the-- a group of Lipovan.",
      "word_count": 8
    }
  ],
