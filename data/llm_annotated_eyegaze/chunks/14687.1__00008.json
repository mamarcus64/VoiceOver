{
  "stem": "14687.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 19.8,
  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "Because-- he say, why you are here?",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "I say, because Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "I told him, you see?",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "He said, I'm Austrian, not German.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "He was not SS, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 8,
      "text": "But he's to do his army, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 9,
      "text": "And he was quite nice mensch him.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 10,
      "text": "And after-- With you, he was nice.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "From-- no, from all the-- when we were crying there, he asked us why we were crying and why-- why we are here.",
      "word_count": 23
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "And we told him, because we're Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "They took us, the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "No, he didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And after from there, they brought two lorries to put the people up.",
      "word_count": 13
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "From [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "From Pireo--",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "--we went to Chaidari.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "No, by-- by-- by car, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "They put two lorries.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Because in Pireo, when we arrived in Pireo--",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "--by boat.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "After, they brought two lorries--",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "--to put the people, to take us-- I don't know-- 50, 60 miles away from Pireo.",
      "word_count": 16
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "They had a camp.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "Because there were plenty people there still from Salonika.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "So when we arrived there, they say, oh, you arrive here.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Now, they are going to take [INAUDIBLE] to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "Where is Auschwitz, we ask.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "They say it's in German.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Because already they took many people.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "And we were the last, they say.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "Because in 1944 the war is nearly finished.",
      "word_count": 8
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "And so you arrive here.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "Now, they are going to take us to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed there three, four days.",
      "word_count": 7
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "And we used to speak with these people in Spanish or Greek, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "And after, they took us for Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "And they put us the train.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "So from-- you went by bus--",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "No, by--",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "By truck.",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "And many people, they were fat, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "They couldn't go up.",
      "word_count": 4
    }
  ],
