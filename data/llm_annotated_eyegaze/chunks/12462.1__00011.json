  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "So I went over there, and I opened the door, and I said, I want to read you Section 12 of the National Labor Relations Act and to let you know that you're interfering with a federal officer in the performance of his duties.",
      "word_count": 44
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And each of you is likely to go to jail and be fined up to-- and I read them what it was.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "This scared the hell out of them.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And they backed up and went away.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And on the other side of the street, some people clapped, because they knew that these people were trying to intimidate me, and they didn't like it.",
      "word_count": 27
    }
  ],
