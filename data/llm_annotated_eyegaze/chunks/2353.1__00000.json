{
  "stem": "2353.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was born-- I was born on April 12, 1914 in a small town in the southern part of Germany-- population 6,000.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I went to school there.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Town, Laupheim, L-A-U-P-H-E-I-M.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I went to school there for 12 years-- no, for nine years.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to school the next town, which was Ulm, and that was-- that ended in 1933.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I had a wonderful--",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I had a wonderful time.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I had my mother and father, and I had an older brother, about two years older than I.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And once we got over the sibling rivalry, we got to be very good friends, my brother and I.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my parents found out pretty soon that what Margaret wanted, [LAUGHS] Margaret got.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And they let me be my own because I was not the usual child.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I had a very strong will, and whatever-- I-- I mean, not unreasonably doing things that I shouldn't have do-- do, but I, I had my own way of dressing.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I didn't like what my mother got for me.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I, I wouldn't wear it.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And I was strong willed.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And I had-- I knew what I wanted to do very early on in life.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I wanted to be a coach, physical education teacher.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "My parents thought I was a little freaky with all of this business about sports that I was so very into.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "I skated.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I skied.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I swam.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "I ran.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I climbed.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "Not the usual Jewish little girl, let's, let's put it that way.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well, Laupheim had a very large Jewish population.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I mean, 300 Jews in a town of 6,000 is pretty, pretty good percentage.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And everybody got along very well.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "There was no ant-- anti-Semitism that I know of.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And we lived in a nice house.",
      "word_count": 7
    }
  ],
