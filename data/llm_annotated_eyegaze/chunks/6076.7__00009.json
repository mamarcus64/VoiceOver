{
  "stem": "6076.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "Herlig couldn't get in.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And well, they took us out on the-- it was two weeks before liberation.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "But the last minute, they came in in a hurry.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "There were no time to talk.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "There were no time to discuss one inmate with the other.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "Hurry up.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "They gave us a half a bread, and line in five.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "The SS women with the rifles aroused from the barracks, and we marched.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "What can I tell you, marching?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Marching in April?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "With the-- at night-- I will say hundreds and hundreds of women together in five.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Well, for the first hour, you marched, for the second.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But the second day, the third day-- at night we slept on the wet grass, one near the other.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "It was raining once, and the rain was falling on us.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And we, and we turned with our back, and the rain fell on our back, not on the face, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Couldn't swallow the rain water.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "When we saw a river, we were running and picking up with our hands the water and drinking.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "When we saw grass high, we ripped out the grass and were eating.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "The half a loaf of bread was gone.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "We marched down for 10 days, from morning until evening.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And then we slept on that grass, on that wet grass, every day in a different little town.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "For 10 days, this march was gone.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Herlig, while she was pregnant like that, her belly was noticeable.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "She was, she was in her ninth month already.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "She was kept on that ward with five very sickly people, which the truck could not arrive.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "They couldn't take them.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Meantime, while we were going there, the Americans came into Leipzig, and we were marching.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "But every day, another city was liberated.",
      "word_count": 7
    }
  ],
