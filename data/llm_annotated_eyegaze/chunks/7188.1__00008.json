  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Then they did find out she's all right.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "And we get disconnected.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "We never knew what happened to her.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "This was my older sister, Sarah.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Shlomo.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "We don't know what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "With him, we don't know anything.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't too far, the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- we stayed in the house with my--",
      "word_count": 10
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Just my youngest sister, and my mother, and me.",
      "word_count": 9
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Toby, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "The rest wasn't-- everyone was already gone.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "My brothers wasn't there no more.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "We lived five family--",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "They pointed out.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "When this is-- when they saw a Jew, they'd point it out with a finger She's Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "She's Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Just the clothes.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] You couldn't.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "You washed your clothes out at night.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And you hang it up in the attic.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "The next day, they were stolen, you had nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "With nothing, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Because you washed something out, somebody stole it from you.",
      "word_count": 10
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And you lived five, six family in one apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "There wasn't barbed wire, but there was a gate you couldn't go out.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't go in.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "It was [INAUDIBLE] streets, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "Every time they liquidated some more Jews in the ghetto, and by the end they made Judenrein.",
      "word_count": 17
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Just one ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Five, maybe more than five.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "We had one room.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "My parents and my sister.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "And the rest was occupied by other couples.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't sleeping arrangements.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "We slept in chairs.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "We slept on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "We slept anyplace we could.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "But my mother never slept.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "She's watch us all night.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 6,
      "text": "She was like a dog watch, watching that the Germans didn't come.",
      "word_count": 12
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 7,
      "text": "She got gray overnight.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Was bad.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Was very bod.",
      "word_count": 3
    }
  ],
