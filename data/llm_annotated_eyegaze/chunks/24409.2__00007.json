  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Of the Revisionists, most of them weren't here anymore.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And I went for the Revisionists.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "I was not, at that time, a member of the Revisionist, of the Revisionist leadership.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "I don't think so.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "But I went, anyhow, and Turi was here.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "Turi was never a member of the Viennese organization, of the leadership.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "Turi and I went for the Revisionist organization to this meeting with Eichmann.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "And after [INAUDIBLE] people, then went out of the 10 or 15 minutes, sometimes shorter, sometimes longer, we were called in.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 16,
      "text": "Revisionist organization.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 17,
      "text": "And we came in, and Eichmann asked me first for our name, our addresses, and then somebody took for him.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 18,
      "text": "And he then asked me, what, where is now a certain name, which I do not recall.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 19,
      "text": "I think I mention it in the book, in then I still know it.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 20,
      "text": "I did not know this name.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 21,
      "text": "But I found out later, this was a man who has organized the anti-German boycott in the Baltic countries.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 22,
      "text": "And they were very much after this guy.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 23,
      "text": "He had organized the boycott [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "The man was very organized at that time yet.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "And I told him, I do not know.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 26,
      "text": "And he put me, said, turn around, and put me, and I stood with my face towards the wall with my back to him, and he pointed his gun at me.",
      "word_count": 31
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 27,
      "text": "Not he pointed, I felt the pressure of the gun in my back.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 28,
      "text": "And he said, I want to know, and you will tell me now, where is he, whatever name is.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 29,
      "text": "And if you don't tell me, I will give you a second belly button, or another asshole.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 30,
      "text": "And I was paralyzed.",
      "word_count": 4
    }
  ],
