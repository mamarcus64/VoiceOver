{
  "stem": "12868.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "Only Chattanooga, Tennessee, I put on my backs, I marked out Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I put Chattanooga, Tennessee.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "I never been.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I-- I never know what Chattanooga is.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Only in-- in Germans or in any kind of language, they don't spell Chattanooga like here.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Like they're the written-- they ask me.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "When I came here in New York, he said, where are you going?",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I say, 'Hat-a-noocha.' And everybody start to say, they say-- the man say, 'Hat-a-noocha,' I-- I think you got a mistake.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "He say, the United States don't have a country like this.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS] Another state like this?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "United States-- Chattanooga.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "When I spell this, I read 'Hat-a-noocha.' And everybody laughed.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "I got a poem about them too.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "Do you remember that poem?",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I got so many poems.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "But to write down, every occasion sometimes.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "We got birthdays.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "We got parties.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "When we got gatherings and everything, I write poems.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And I-- and I [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Germany, when she came to me.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "It was in 19 something and [? probably ?] something.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Was it Chattanooga?",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "How did you come to the United States.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "I didn't been in Chattanooga.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I-- I came-- I came here in the United State in New York.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Through New York, I got to go to Atlanta.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "But the Federation from New York met me there.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And they give me, you know, they give me the-- the instructions, made the papers, made the tickets to go to Atlanta.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And they give me $17 in dollar bills to buy for the-- for the-- some food, underwear-- which I got [INAUDIBLE] was three years old-- to-- to buy for milk or something.",
      "word_count": 32
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "But I got the $17 in my pocket.",
      "word_count": 8
    }
  ],
