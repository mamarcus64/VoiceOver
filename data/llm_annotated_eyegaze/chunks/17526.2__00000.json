{
  "stem": "17526.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 85.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We-- we were frightened.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They-- they-- we felt betrayed.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We felt-- That-- that-- we felt depressed, we felt scared.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We were afraid that-- of what's going to happen next.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And we realized that it's going to get a lot worse, but just had no way out.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I remember we tried to-- our youngsters-- as youngsters, we-- the people that we belonging to these organizations, we still were able to get together on weekends.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And we were discussing the situation and there was some kind of talk of an underground in our town.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I was approached by a friend of mine was contacted and we were discussing-- we-- we-- we were-- we tried to find ways of how to get out of the situation, realizing there's just no way out.",
      "word_count": 38
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "But yet how can we let them slaughter us?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "How can they-- how can we let them treat us the way they're treating us?",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Constant departures of young people without knowing where they are going, where they were shipped, where they were sent.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] We-- this-- this-- this man, this friend of mine, very good friend of mine, very intelligent, I respected him a lot because he was a very intelligent young man.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And at one time we were discussing it.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He says, Joe, he says, we ought to join this group.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They're trying to organize some contacts with the underground.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "They're going to give us ammunition and we'll go into the woods.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We're going to be dying like dogs anyway, we might as well fight for our rights and for our honor.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And maybe we will escape, maybe we'll be able to do something.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And this went on for weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And one day he says, Joe, are you coming?",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I decided, I'm going to join them.",
      "word_count": 7
    }
  ],
