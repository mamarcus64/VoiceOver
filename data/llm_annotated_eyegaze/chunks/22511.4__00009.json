{
  "stem": "22511.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 18,
      "text": "They-- I hope they don't change, they stay like they are, because they are lovely.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 19,
      "text": "I got experience why I say that, because I had a little business.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 20,
      "text": "I was very [PAUSES FOR 3 SECONDS] active.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 21,
      "text": "I want to help my family to-- not to be shortage of nothing, to be able to give them what I couldn't get.",
      "word_count": 23
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 22,
      "text": "And I opened a little shop.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And I couldn't speak English at all.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 24,
      "text": "This is marvelous what I-- because I'm not such talented in languages.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 25,
      "text": "For me, English-- any language to learn is hard.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 26,
      "text": "Just, I am a good businesswoman, and I like people, and I'm honest.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 27,
      "text": "And this is so important, to go your right way.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 28,
      "text": "That's why I never felt this in Europe.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 29,
      "text": "Because I have been honest and I like people.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 30,
      "text": "And people used to come to my shop--",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Grocery.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "First I start with grocery.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And the names of everything-- I didn't know the names.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I put them all on the shelves.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Only one article, I couldn't put on the shelves-- I had them in storeroom-- and that was eggs.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And when people come for eggs, I didn't know what it is.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they draw for me a chicken, and oy, God, what I didn't-- Help.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "They want to help me.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And they cluck cluck cluck cluck cluck.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And I laughed.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I didn't know what they say.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Only at the end, we come to a conclusion, and I knew they wanted eggs.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "They helped me.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "They didn't-- they come from everywhere, and they did help me.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "They didn't mind that I don't speak, I give them always-- the arithmetic was correct, and if not, I could make a mistake too.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "So I give them back.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "They come, they support us, they like us.",
      "word_count": 8
    }
  ],
