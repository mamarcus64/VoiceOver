  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "So they send it, a telegram-- don't get married, because easier to get out.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Because they send some affidavit.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Morton wasn't in Tokaj at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And the small town, in the post office-- they, don't get married, Hungarian Sunday, for [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "They was paid, the answer.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "So I sent that back, before Morton come home to Tokaj.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Our wedding going to be February 12.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "My future husband named [INAUDIBLE], born 1911, June 30.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Make the paper that way.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Then my sister, the second [? with us ?] went school with Morton.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "So then they wrote to us, but if you get married, don't get children.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "But we got-- so [INAUDIBLE] we got-- because they remember the little [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And-- and-- you know--",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Henry Fuchs-- I should say Dr.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Henry-- Henry Fuchs, born 1948, January 20, named after Morton father, [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And Marta, her-- she born in Budapest, 1950, June 24.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They had.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "That's the reason we escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We escaped two reason.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "When-- after-- we always want to come to America.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oy, my goodness.",
      "word_count": 3
    }
  ],
