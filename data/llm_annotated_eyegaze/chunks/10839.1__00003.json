{
  "stem": "10839.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And I used to have a other teacher.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Her name was Saksowna.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And she used to-- to live in other village, not far where I used to go to school.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "It was a walk maybe 20 minutes that she came every day to school there.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And when I finished school, I have to go to work.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "See, it was not like here.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "It was then big cities, rich people, they were in business or they have good jobs, they send the children to high school or-- or to-- to college.",
      "word_count": 28
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "Only it was maybe one from 10,000 what you went to college.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "Or some people got relatives in England or they got in Germany or they got here in the United States.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "They sent the-- the kids away to-- for education.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "See, I am from a family from seven children.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My mother used to have nine children, only seven they were alive.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And my father used to work in a mill, flour mill.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "He made a living.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "He was working very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I remember he brought home flour from the-- from his place.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And my mother used to bake for the children bread or some challah or some other things, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "My mother was a housewife.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And she got plenty work to do at home with seven children.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "At home, I was the youngest.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And then when they got older, the-- the oldest, they got married, then the second one, the third one, you know, and the fourth one.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And I was the only one what-- I was very young.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "Then when I was 21 years, I went to the army.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And when I started out, me, I went away, this was in 1938, March, 15.",
      "word_count": 15
    }
  ],
