  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 7,
      "text": "I was absolutely dead, called to the office.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 8,
      "text": "Sergeant, we have orders.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 9,
      "text": "Tonight is your Passover.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 10,
      "text": "No flying.",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 11,
      "text": "All duties crews come off.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 12,
      "text": "No pilots, no Jewish pilots go out tonight.",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 13,
      "text": "And we were taken to a place called Eindhoven.",
      "word_count": 9
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 14,
      "text": "The Royal Air Force had prepared Seder for us.",
      "word_count": 9
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 15,
      "text": "The Royal Air Force found time to fly a Dakota back to England to bring back matzot, maror, haroses.",
      "word_count": 19
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 16,
      "text": "And they laid on a sumptuous Seder evening for us in an empty shop in Nijmegen. 300 Air Force personnel sat down for the first decent meal they've had for weeks.",
      "word_count": 31
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 17,
      "text": "That's beside the point.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] A chaplain gave a service, unforgettable.",
      "word_count": 10
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "But I remember the catering officer, [?",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "Monnickendam. ?] Flying officer [?",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "Monnickendam ?] from the famous [?",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "Monnickendam ?] bakery family in London.",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "The Royal Air Force.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "It was all arranged by non-Jewish personnel of the Royal Air Force.",
      "word_count": 12
    }
  ],
