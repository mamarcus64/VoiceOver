{
  "stem": "15115.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "So I took the whole carton of cigarettes, and I put them into the boots, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And we went into the bath.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "First of all, they shaved us.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "They shaved us all the way.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "They left us a little Lause Strasse.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "Lause Strasse means a-- a-- a street to go to the-- the lice to go through.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "Lause Strasse.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "That was the name of the-- so they shaved us pretty good all over, and then they put us some kind of a-- a-- burn-- alcohol or something into, you know, where we had a little bit of hair left, and we went in to take a bath.",
      "word_count": 48
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "Took a bath, a cold water bath.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So we come out, and they give us some different clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "One guy's got pants that size.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Another guy so-- so finally we started to change them around till you get the right-- you know, everybody was changing themselves, because one was big enough because they didn't-- they give us clothes from other prisoners.",
      "word_count": 37
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "Of-- whatever they had, they give us.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Where did you think these clothes were coming from?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "From the people who were gassed, from the-- what do you call it-- from the crematoriums, you know, different.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And finally, we got out of there.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "A whole night outside.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "God, we wanted to rest.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "You know, we were five days on the train.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And already took us about 48 hours by the time we got the numbers.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We got into the camp, we got the numbers, we went through the steam-- to the room-- to the showers, here and there.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It's already seven days, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "We were so tired.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And finally, they put us in a block.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "Block 21 was my block.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "They put us over there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "Take a look.",
      "word_count": 3
    }
  ],
