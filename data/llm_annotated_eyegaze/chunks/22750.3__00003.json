  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Like over here is the capital city for around the little cities.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "This was not the custom.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Outside the house.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Made from wood, from the something.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I could give you the name.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Ivan.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And the second name-- [PAUSES FOR 7 SECONDS] this slips from my mind.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Waretchuk.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "W-A-R-E-K.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Waretchuk.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Fine people.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "The best.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Sasha.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "The best because she gave me, always, even at night, when I was in the underground and the area was [INAUDIBLE] more Jews in [INAUDIBLE] something.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I took my chance there at night in a bed, [INAUDIBLE] or something.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They came, and they gave me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I was not-- this is from the ghetto, you're talking?",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "She could go out the way, with here, if she has a permit.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But of course, we had yellow, you know, stripes over here and in the back.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Every human, every Jewish person.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I had a different.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I had a Star of David with a white band around.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "This was the-- the thing was-- they know already because, Judenrat.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "She had a child because he was a little boy there, my son.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "My work was picked up in the morning and they called us in to Germans or to the Polish family because they had the outside offices, which we were connected for certain things.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They took slaves.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Every day, they give you another number of slaves, how many you need, people to do their work where they needed.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "If they need, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "To me or to another one like me.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Sherman was, and then we had-- because we were from our little city, two officers.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They called him off-- and three officers from the city where they brought it in.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Only with mine.",
      "word_count": 3
    }
  ],
