{
  "stem": "2906.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And I looked at myself and the bones I was scared for myself.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And after the month, they gave us a lot of bread for a month.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "So it was good, but you cannot eat it at one time.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "When you start eating right away you can die.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The bread is the-- the [? like ?] little paypost in-- where the factory was.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "A woman she used to give out the bread.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Was always a line.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "You go even for this, you have to stay in the line.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In Russia, for everything you have to stay in a line.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "When they give-- when they used to give like soap, you know what kind of soap-- the soap-- like water.",
      "word_count": 20
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "And a man used to come and said, what are they giving?",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "You said, soap.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "He used to take off his hat and wait.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Took the soap in his hat.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "You stay in the back [LAUGHS] there.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "What were the living conditions like?",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "The living-- we were-- we were in a-- in a house.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And when it came winter, it was so cold when you put water, it was ice.",
      "word_count": 16
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "It was somebody's-- they run away, they moved away, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "It was-- it wasn't a good-- in a good condition.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "But it was ice there.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And we worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My clothes-- I had one time, I-- I fixed a [INAUDIBLE] in a [? matri ?] skirt for myself and for the two girls, and we went to sleep outside.",
      "word_count": 30
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "We came in the morning and somebody took away our skirts.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "We used to sleep-- because we was-- in-- in [? some ?] places, it was too hot.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "So there used to be like a veranda there.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "You sleep outside.",
      "word_count": 3
    }
  ],
