  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And next to it was the, the concierge, the one non-Jew around, who was responsible for cleaning the slaughterhouse and the synagogues and putting the lights on and off on Sabbath and holidays.",
      "word_count": 33
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He and his family lived there.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And they were virtually the only non-Jews for a mile and a half around.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And then you had the, [PAUSES FOR 3 SECONDS] the, some of the ritual slaughterers were living there.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And next to it, next to the beadles, there was a home of the deputy rabbi, the [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Below his building were the butcher shops.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] Of course, you know, the butchering of, of animals was under the supervision of the community.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "A community provided [NON-ENGLISH], who was, of course, paid for by the community.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "But again, it was paid out of the income paid by the butchers for the slaughtering of the animals.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    }
  ],
