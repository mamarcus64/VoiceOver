{
  "stem": "22836.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "I was making the 20 and the 30.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "You wouldn't believe that.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "In a short time, I save up about $4,500, $5,000 that time.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "It's inbelievable.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "Then everybody say, go buy a farm, a chicken farm.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 12,
      "text": "They're doing good.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 13,
      "text": "And I went to Newfield here in [INAUDIBLE], and bought a chicken farm in Newfield.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 14,
      "text": "Then the chicken farm was good the first year.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 15,
      "text": "The first year was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 16,
      "text": "And after that, went down, and I couldn't make a living with the chicken farm.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 17,
      "text": "Then I was looking again for a job.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 18,
      "text": "I went to work for [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 19,
      "text": "He then-- then he couldn't hold me.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 20,
      "text": "Then I went--",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], he was around here.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "He was living in [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "You should be having that name.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE], Mr.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "Gold, you know?",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "Gold was there with chicken farm, Gold.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "And that's [INAUDIBLE}-- that's [NON-ENGLISH] brother-in-law.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Farmers market.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Farmers market.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "He was going in the farmers market and I was working for him.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No, then I work with him to survive.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "To survive.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Everything is to survive.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And then-- I'll make it short.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "And then, after that, he fire me.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "He lay me off.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And then I have nothing to do.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "Then I went to my friend in Colk-- that [INAUDIBLE], and ask him what to do.",
      "word_count": 16
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "I have to do something I can make a living.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "I have two kids that time.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 9,
      "text": "And he says, get in this same business.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 10,
      "text": "I'll borrow you money.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 11,
      "text": "I'll help you.",
      "word_count": 3
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 12,
      "text": "Then I went and start looking for a truck.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 13,
      "text": "With a truck, I was very-- too much guts to do it.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 14,
      "text": "The guts was too much.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 15,
      "text": "I was not afraid for nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 16,
      "text": "I don't have the money.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 17,
      "text": "I bought a truck.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 18,
      "text": "The bank give me a mortgage on the truck, Newfield Bank.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 19,
      "text": "It's inbelievable.",
      "word_count": 2
    }
  ],
