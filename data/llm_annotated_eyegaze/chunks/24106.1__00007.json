{
  "stem": "24106.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] My mother worked about a month before Pesach.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Everything has to be kashered.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And the kitchen has to be [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have a lot of the dishes, but you have to make them-- you know, kashering the dishes.",
      "word_count": 19
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And we helped.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "We helped.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "Everything has to be changed, yeah, everything.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "We didn't have too much, but whatever we have, we have a lot of Pesadich dishes.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "[NON-ENGLISH] that they come-- they came from the-- from the attic.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Matzah-- we baked matzah.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "It was a special place that they opened up just for baking the matzah, so-- but you don't have to bring your own flour.",
      "word_count": 24
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They bake-- you come, you order your matzah, and they bake it for you, then they bring it home.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And you push it-- you push it in a-- you put it in a special place in a corner.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It came in a big box, a [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And my mother-- this was already Pesadich.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Nobody even supposed to look.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And you cover it up, and then you start bringing in-- you know, the rest.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "Potatoes and onions.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And-- and you didn't have matzah meal.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "You didn't have farfel.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "You have to do it-- you have to do it yourself.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "It was a thing like-- it's called a stamp.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "And you stamp it.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "And this was going on to the whole family.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "And then you [? sip ?] it, and you make from that farfel and matzah meal for baking.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Travelers?",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we have family and-- in-- in smaller towns.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Like we have family in Kostopol.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "We have family in [POLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "We have family in [POLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "They used to come to visit us once in a while, yeah.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "But that was short distances.",
      "word_count": 5
    }
  ],
