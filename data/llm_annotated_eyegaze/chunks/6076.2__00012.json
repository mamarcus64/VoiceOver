{
  "stem": "6076.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "But, you know, that was-- I was interrupted.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "The war broke out.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "That was just dreams and that's all.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "When the war broke out, I was 15.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "What happened when the war broke out?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "How the war broke out--",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "How the war broke out-- I'll tell you how the war broke out.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "A few months before, it was already rumors that-- I stayed with my sister in Suchedniow.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "About two months before the war broke out, I was there.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Esther, in Suchedniow.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I was on vacation, my last vacation from my public school.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I graduated.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So I went to her.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I stayed there for two weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "My parents allowed me to come home very fast.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "She allowed my brothers to come home from-- my brother Leibl to come home as soon as he can.",
      "word_count": 19
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "She wanted her family to be together, because they were talking about the war.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "She remembered the First World War-- how it was.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "At that time, in the First World War, she-- my mother was pregnant.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And she went through a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "They used to drag my father all the time to go to the army.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "It was so horrible.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "She used to tell us-- every Friday night at the dinner, at the table, we used to talk about-- my mother used to bring out at the time that her children should never have to go through what they went through.",
      "word_count": 41
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "It was so bad, what a war means.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "But as children, I listened to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "I didn't pay too much attention.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "To me, it looks like our children listen to me.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "I was sensitive, but I didn't cry.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "I felt bad, but I didn't take it serious.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "I was still busy with books.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "And-- and I was dreaming I will attend school in Krakow.",
      "word_count": 11
    }
  ],
