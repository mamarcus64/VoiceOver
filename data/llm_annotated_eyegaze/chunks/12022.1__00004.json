{
  "stem": "12022.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.5,
  "sentences_input": [
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Not very-- I was going to school, to public school, very little school.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "I think I was seven when I went to school.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to school, and I was pretty good in school.",
      "word_count": 13
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "I wanted to-- to learn.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "I was good at-- and then when my father died, my mother took us to Eishyshok, me and my younger brother.",
      "word_count": 21
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "I was eight, and he was six, I think.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "And the older brother went around and learned in the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "And we was going to cheder.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Was a Polish-- Polish lady.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Sure, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Elena Polokuwina.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Oh, she would be about 25.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "She-- she was strict, and she was a big anti-Semite.",
      "word_count": 10
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "She was strict, and she was big anti-Semite.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I know what this anti-Semite means.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Really, she don't do anything.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "She couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "Or she's-- the way she spoke to Jewish kids.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Naturally, she-- she don't like.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "She don't like Jewish kids.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "She don't like.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "When I was a kid, I took any-- everything.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Arithmetic and writing and reading.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "We got more than one grade.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Maybe about 50.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in different grades.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "We learned.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "That's always discipline too.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "It was-- in Eishyshok was a teacher, Shayel Lidzki.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "He was a middle-aged man.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "I think he was in the war.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "He was missing a finger.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "He was teaching-- they was teaching reading, writing.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "I learned Chumash and Tanakh.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "After I get older, I learn [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I think about 12.",
      "word_count": 4
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Was 17 kilometers.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No, I was staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "My mother took a room.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "And I was staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And with the board, we used-- eat teg.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "You what teg means?",
      "word_count": 4
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "Teg, they arrange for us, for me and my brother, every day to another family go to eat.",
      "word_count": 18
    }
  ],
