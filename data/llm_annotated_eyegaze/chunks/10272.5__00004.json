{
  "stem": "10272.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And he kicked and punched in the stomach, and in my face, all over.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And he says, what they're doing for a living?",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "[HUNGARIAN] means in Hungarian, is a sign-- sign painter.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh, listen to this.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He is from [HUNGARIAN] and he is a [HUNGARIAN].",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So he kept hitting me and kicking me, that I already was numb.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I didn't even feel-- could feel-- I couldn't even feel anymore the pain which he-- before I was felt.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I was so numb, that I found myself lying on the floor.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And he tried to revive me with water-- cold water.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And it didn't help.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So he-- he took a cigarette, put-- lit a cigarette and he tried, and put me here on the-- on the cigarette, on my body, tried to revive.",
      "word_count": 28
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So this, I was-- I jumped up from pain.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And this was-- happened also to my friends.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And this was-- then he said, get dressed.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He throw me some kind of a rags over there, which I couldn't even put them on.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I came out naked with the rags in my hand, with the shoes in my hand.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And this I would get to the backyard, between all of the guys who were there.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And we tried to put them on, little by little.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And I managed to put on the shoes, and to put on my pants.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I had no-- no buttons.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "With some kind of a string, I had to fix it.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And the jacket also has no buttons.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "It was small.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "The-- the shoe was small.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't put in no-- nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "I put in paper so I couldn't feel the cold.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "I put some paper on my-- my feet.",
      "word_count": 8
    }
  ],
