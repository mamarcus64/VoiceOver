  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I came in.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I saw in the beds was pillowcases upstairs in the-- of the beds the pillows.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "So the pillow cases was written Malke Kulish.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Your name was Malke and Kulish is our name.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "It was written.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So she told me she gave me, and she told me to use.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And she will sew [? all those. ?] So I am using it.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "But I want to give you up.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "You don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And so I didn't took nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "She opened-- I-- I have something in my-- a little-- she opened [INAUDIBLE] a-- a coffer.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And-- and she-- she hang up my little [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] Yeah, I have this.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And this is what I took.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And-- and later, I start crying for you.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Please, take me to the graves and the forest over there, the graves.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I want to-- to see-- I-- I saw in the grave.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And they made the graves [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "Take me to the forest, to the graves.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So she, with her husband, they took me to-- to-- that was our, rightly called, our cemetery.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] the ghetto, all the ghetto, [INAUDIBLE] there.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "This is not-- even then I came, it's still [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I saw where their blood was raining.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Running.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Such a-- [PAUSES FOR 3 SECONDS] [INAUDIBLE] like [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "You know, [NON-ENGLISH SPEECH].",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We say a brutal killing.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH SPEECH] And I-- I-- I cried, and I went out.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And I took to go to the forest where I left my children.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I know [INAUDIBLE] they said the last time if I will be alive.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "So I-- I wouldn't carry [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "When I-- when I came-- when I came-- and so one Ukraine asked me where-- where you going to go?",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I told him to the [NON-ENGLISH], to the forest.",
      "word_count": 9
    }
  ],
