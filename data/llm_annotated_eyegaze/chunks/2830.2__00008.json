  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We wind up-- until we wind up there, there was a lot of things going on.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "They found Jewish men.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And there was on the loud speaker to come out and see they're hanging Jewish men.",
      "word_count": 16
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "They were trying to hide out as, you know, gentiles.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "They recognized them in the shower.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "They were circumcised.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "Couple a day everyday, they find some.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "So when we finally-- I'm going to make the story short.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We wind up in a Bitterfeld in a aluminum-- aluminum work.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "It was a Farben.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "It was a Farben.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Farben.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "IG Farben.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] There were about 40 of us.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "We were 13 Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "There was a mother and daughter and a mother, Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "Felix, her daughter Kitty, and-- and Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Felix.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "And there were two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] Brenner-- their names were Brenner.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "After, I found out that their names were Brenner.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And there was another sister.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "And her sister, Hannah.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "She was about eight years old.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] daughter from near Lublin.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "So and there was another.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Her name was Maria.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "She was the one that actually got us into trouble, because she spoke with a-- you have to speak with no accident.",
      "word_count": 22
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "The-- the Polacks are going to recognize you, that you're Jewish when you have a accent.",
      "word_count": 16
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "And she had an accent.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "You got to-- you got to speak without a accent.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "You got to speak a perfect Polish in order not to be recognized.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Either you're too intelligent for them, or then you're not.",
      "word_count": 10
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "So that is a giveaway.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "So she was the one who always-- and she talked, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You could never-- she never shut up.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "She always talked.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "So this thing, when we started walking, there is from Krakow, they were from Krakow.",
      "word_count": 15
    }
