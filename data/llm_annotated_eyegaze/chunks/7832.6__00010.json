{
  "stem": "7832.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "A lot of trucks that-- from our transport with the SS with their supplies, and ammunition, one motorcycle, and a couple of trucks, and the guards walking alongside of us with their machine guns and stuff to guard us.",
      "word_count": 39
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And all of a sudden on this nice, bright, sunny afternoon, planes came out from behind those woods.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And they just bombed the whole transport.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "The trucks, and the motorcycles, and everything that moved they bombed.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "They-- we like ran off the road onto the-- to the side of the road.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "They wouldn't let us go into the woods.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "But just on the side of the road so they can pass with their equipment, the-- the Nazis.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "But they got them.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "They didn't get us.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "Nobody of our people died from the bomb or the shooting from the planes.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "They just shot up their-- those trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "They turned around and left.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "These planes.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "So they either were Russian, or French, or American, or one of the Allies.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "We-- to the very day, we don't know which ones it was.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "But they--",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So now they are wounded.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They have their own problems.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And we are on the side of the road.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And there's the-- the-- the foot soldiers-- the SS that were guarding us.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They scooped us all up and we kept on.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They kept on taking us.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And the trucks and everything that was bombed that was left behind.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "A couple of the SS got wounded.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They turned around.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And they on the motorcycle, and whatever was movable, they turned around and they went back from where we came from.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And they kept marching us on.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "So we-- that night, we were still on the same road.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And dark.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "There wasn't a star in heaven.",
      "word_count": 6
    }
  ],
