{
  "stem": "21004.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "After when I was 13, after my bar mitzvah, I was out from the house already doing business with Gentile people, you know, and taking all kind of foods with big-- lot of wagons and going like to Lemberg was quite a distance, far away.",
      "word_count": 45
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "We used to bring stuff, selling there.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "Sometimes you couldn't sell.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "Too much vegetables, you couldn't sell, so you just drop it and throw it-- throw it in the river, throw it in the river.",
      "word_count": 24
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "Something was overloaded, ex-- it just happened that everybody that bringed in too much food.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "And so much of so much you can sell.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "So you couldn't sell the whole thing.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "The rest, we'd throw it out.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "So some days was good.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "Some days was not so good.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Political party, I belonged to a Jewish organization, Akiba.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "The name was Akiba.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And we used to come together from all the villages, come together, speeches.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "They had a president.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "He was a lawyer, forgot already his name.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "So in my mind.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I forgot his name.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "He was the head-- the president on the Akiba.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Akiba is what-- like-- like the Ben-Gurion, like Ben-Gurion organization.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It was in the middle, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They were not to the left, not to the right, in the middle.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And I was young, at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Maybe also my cousins, a lot of cousins, they went on the Hachshara, going to farmers and learning the trade, because they want to go to Israel.",
      "word_count": 27
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So one of my cousins, she went-- she married and she went with her husband.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "She went to Israel about 1923, '25.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And then my other cousin, her brother, also went on Hachshara.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And he went also to France.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "He worked in France on a farm.",
      "word_count": 7
    }
  ],
