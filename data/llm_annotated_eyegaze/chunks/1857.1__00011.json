{
  "stem": "1857.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 173.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So there were the four of us, plus my father's sister's daughter, my cousin, and another friend of my cousin.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We-- all six of us lived in that one room.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And another family lived there, a very orthodox family, people who were manufacturing brushes.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And this was our experience.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I started-- I was still working at the automobile works for a while.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And then one day, they closed up the automobile works and I had to find another position.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And there was a big repair shop called [NON-ENGLISH] for German Army vehicles, where I also got a job repairing motorcycles.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "My father, in the meantime-- the-- an Austrian by the name of Julius Madritsch, who was a garment manufacturer in-- in-- in Vienna, established big factory manufacturing uniforms little outside the ghetto.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And people from ghetto were going there.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "My-- my father was one-- one of the first to-- to-- to get work there.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And he was going out to Madritsch, and he became quite friendly with Julius Madritsch, the owner of the factory who was an Austrian gentile.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "My mother and my sister were going out to another garment factory called Optima, which was at one time Optima Chocolate Factory.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "The Germans converted into garment factory, where the women were also manufacturing uniforms.",
      "word_count": 13
    }
  ],
