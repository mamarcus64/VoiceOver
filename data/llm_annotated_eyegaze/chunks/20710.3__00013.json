  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Then we went-- finally, we went back to-- to Lwow.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And then we-- we stayed there again for a few days.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And then-- [PAUSES FOR 5 SECONDS] then, of course, I had this friend-- I mean, now, he is my husband.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But that time, he was with me.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And we had no place to go.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he said to me, you're not going to stay here.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But he was from a different city that-- there was already Polish.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Here was Russia.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And he was, like, from [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "So this was already past [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And he said, I have to go there and I have to see if somebody is still alive.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And so he, you know--",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "--hijacked-- Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Sure.",
      "word_count": 1
    }
