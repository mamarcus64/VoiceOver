  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Because they put always money in, in a Swiss banks.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "But because of fear of persecution, you know, of a government, they used a code name.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So I absolutely have no idea what code name my dad put money in the Swiss banks.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And it's-- it's-- it's interesting, you know, really.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But the reason why I went back home, in case if I find something from my father, what left.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "But there was absolutely nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Absolutely nothing left you know, at all, nothing at all.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And I went back.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And I went to a school.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And because my family were in the theater business before, part of the rest of the family, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And I, like I showed you the papers, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "One of them showed I became a-- a director, you know, movie director.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I went to the school, you know, all this.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And also, I owned movie houses, you know, three movie houses, which I cannot own at the time, but I can rent from the government and run it.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And that's what I did until December the 6th.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "This friend of mine, whose [PAUSES FOR 4 SECONDS] brother I took out from the holding camp, who became a police lieutenant or captain, whatever, is in the Budapest police, came to me.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And he told me this, I would warn you to leave the country, because we have an arrest warrant for you.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Because I was too vehement to find out, you know, what happened to my father's holding and what's happened to the rest of our belongings, which the-- the communists, you know, took over.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And he said, we have a-- an order for your arrest.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "So what happened, I just went over.",
      "word_count": 7
    }
  ],
