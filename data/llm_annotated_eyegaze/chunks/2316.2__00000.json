{
  "stem": "2316.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "No, upstairs is only one person.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, I'm going to ask her.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Sharon?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I remember my-- witnessing, the first time that I witnessed was a bunch of Polish men attacking a bunch of Jewish boys, including my brother-- right in front of my house in the garden that he made and planted in front of our house.",
      "word_count": 44
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And my brother was older at that time, and he was very involved in Betar and some other organizations as a youngster.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I guess they knew of him.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And it was like a Sunday.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "On the way back from church, they had to pass our town, our shtetl, the Gentile people.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And on the way back from church, they attacked these boys.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "My brother was one of them.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "He was pretty beaten up, black and blue, real, real bad.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And everyone started to run and close their doors and hide inside because they were afraid of their children or themselves getting beaten up.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And after that my brother was forced to leave the country because they threatened to kill him if they catch him again just because he's Jewish and because he's active in-- he's a Zionist.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Well, he left for Argentina and eventually he, unfortunately, he died there.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "Got-- was electrocuted taking a bath.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "He escaped Hitler, but he got killed in Argentina.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "His name was Shimon, my oldest brother.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, I'm very sorry.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I got off track.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "That was my uncle, my father's brother.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I beg your pardon.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "That was my father's brother.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My brother was there also.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "He got beat up by accident, but it was my uncle, my father's youngest brother, that got attacked.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "He was very active.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "He was a Zionist.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And they were after him.",
      "word_count": 5
    }
  ],
