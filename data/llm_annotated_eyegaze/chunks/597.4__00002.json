  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 31,
      "text": "And it sucked in different kind of chemicals.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 32,
      "text": "So it was a little bit warm.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 33,
      "text": "So he let me in at night to sleep over there.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "During the day, I was in the attic.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "And during the night, it's cold.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "It was December.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "Christmas is very cold in Ukraine, Russia.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So I-- we-- eh, telephone's-- and-- and-- and he let-- he let me down then.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "It's all-- he came-- see, my mother came up to visit me dressed up, already warm.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Like ?] in the evenings, [? with ?] [? mine. ?] And she-- and she told me-- I'm-- now we have a place, where to stay.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I'm staying with Rachel.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My-- my-- that was the only place I was hoping to-- to get in.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I came in to my-- to my next neighbor, where I was, near my house.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And he says you can stay with me for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "His name was Joseph Chaichuk.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "Childless, didn't have children.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And he was working in the-- in the [? cohorts. ?] You know, they have their collective.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "They have a collective.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "He was the-- the guy what that kept the grains under lock.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "So we had plenty food because we had grains.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And the house was a warm house.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And she told me that.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "I was so happy I saw her.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And I-- and we embraced and chatter.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And I says, no.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "So far we have-- you have a place and we have a place.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "The winter, we'll be safe.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So there she had-- she was staying by that guy, by that Mr.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Joseph Chaichuk, with his wife, and food, and warm.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was staying there by my-- by my-- with that friend, with another one, six months.",
      "word_count": 16
    }
  ],
