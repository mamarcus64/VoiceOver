  "sentences_input": [
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 11,
      "text": "She was the first Jewish girl in the high school, which name was [POLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Time of war, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "How she died, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Too.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And my father.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "It was 1925, I think. 1924 or '25.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "I was there six years.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "Krochmaina ?] 92.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "It was a beautiful big house.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 4,
      "text": "In the house were 56 girls, 50 boys, 20 people personnel which helped students, which teach-- went to schoo-- to school to learn how to be with children.",
      "word_count": 28
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "When I came there they took my hair off.",
      "word_count": 9
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And this was the rule.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "Every child which came to the orphanage, they had to be shaved off.",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "[BACKGROUND NOISE] And I cried because I have no hair.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "But it was nice.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "I didn't-- I didn't feel any uh, anger that my father gave me there.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 8,
      "text": "Because I was happy.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 9,
      "text": "The food was beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 10,
      "text": "The children were very good.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 11,
      "text": "I was very happy there.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "The first day when I came in.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "He called every child [POLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH], It's like a little chicken.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "So I thought that I'm the only one he called [POLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "But I heard he called everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "It's hard to describe because he was so warm, so good, to every child that you cling to him right away.",
      "word_count": 21
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "It's like a magnet, a very nice person, a very good person.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "So everybody loved him.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Public school.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "I was too young.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "In school I didn't feel anything.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "It was mostly-- it was a Jewish neighborhood with mostly Jewish children.",
      "word_count": 12
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "So I didn't see the difference.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't feel anything.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "They were very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Mostly Jewish.",
      "word_count": 2
    },
    {
