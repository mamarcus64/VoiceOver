{
  "stem": "21004.6",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And they-- he was-- he with other people were organized to go in the partisans, to go out.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "They have rifles.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "They have guns.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "They were prepared, like 15 or 17 people to go in the woods and to be like partisans.",
      "word_count": 18
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And that's what they were figuring to do, because they know that it's going to be liquidated too in a short time.",
      "word_count": 22
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So I say, I want to find some people whatever they want to go with us.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But I can take only two people.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He said, the [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They were very rich before the war.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "They were very rich.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Three-- two brothers and a nephew.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So-- so he say, I'll take you to the [POLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I say, but I cannot go to the [POLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They were three people.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "They were two brothers and a boy.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Say, I cannot take them.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "It would have been better man than woman to take along, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "But this way, I can't take.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "So then he say, there's another woman, a very wealthy woman.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "They have coal mines in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "Very wealthy.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And she was the only one.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "Her brother was someplace else hiding, and she was here.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So he gave me-- he came with me and he say, this is the Scher.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Their name was also Scher, exactly the spelling.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But no family at all.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "So I came out, tell her who I am, so-and-so.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And I say, I have a place where we hide, and we'll go.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "She say, I'm ready.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I have a lot of money.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I have diamonds.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "I have everything with everyone.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "She brought out a cassette, opened up, with everything.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Gold dollar bills. 20 gold dollar bills. 20s.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "I didn't count them, but I saw a lot.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Scher.",
      "word_count": 4
    }
  ],
