{
  "stem": "365.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother was in the Polish army, was drafted, which was compulsory service.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "He served with the engineers squads.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And he just returned in the summer of 1939.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "He was discharged.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And there were strong rumors about upcoming war.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We knew that the Nazis invaded, already, Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They occupied Austria, or let me put it more bluntly-- they united with Austria.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "It was a case of occupation.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And we expected that war was coming.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "Within a month after returning home, he was recalled for mobilization, for the general mobilization.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "He was recalled to the army and sent to the German border to build fortifications.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "The war broke out on the 1st of September, 1939.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "Day before that, the last day of August, we received news where my brother was.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "So I and my second-oldest sister went out to visit him.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "It was about 20 kilometers away, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So we left early in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We got there, and he returned the late afternoon from work, all sweated up and dirty.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We stayed at a farmer's house in the barn, actually, spread out the hay on the ground.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "There we slept over.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "First thing in the morning, about 5 o'clock in the morning, he woke us up.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He says, you better go home and go quick.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The Germans attacked.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "That was September 1.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "So we-- and they were ready in full gear, ready to march off.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We left [NON-ENGLISH] Village and made our way back home.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "On the way, we could hear it overhead-- German airplanes flying.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "We heard explosions and shooting.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Somehow we made it back home.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Well, within three days the German armies were in our town, occupied.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Immediately, they introduced laws and announcements regarding arms, regarding curfews.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And any transgression is punishable by death.",
      "word_count": 7
    }
  ],
