{
  "stem": "942.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "So here we are sort of fooling around and talking to each other.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And all of the sudden, I see my partner, who is working with me, who is facing me, because we are, sort of, shoveling from opposite each other, he starts to work fast.",
      "word_count": 33
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And that gave me a signal that somebody is coming or somebody is nearby.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So, and I start to work myself.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "But I kind of felt something hot on my neck, you know, and I put my hand there, and I see I've got blood on my hand.",
      "word_count": 27
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So as I'm leaning down, shoveling away, I can see blood dripping down.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And then I look back behind me and there's an SS soldier behind me.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And he hit me with his gun butt right on my head, over here.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I still have a bend, here.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And you know, I felt no pain.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It's funny, when you get hit on the head, there is no pain.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "It was just a buzzing kind of a feeling happening, and blood was really coming hard.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And I was more scared than anything else, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And I'm working away, and this blood is dripping.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And finally, I just passed out.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I just fell down, and I guess, more from shock.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And I remember this [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "He was a Polish fellow.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Stan was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And he, they tried to stop the bleeding.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And he tore off a piece from my jacket, and he told me to urinate on it, and he put this on this wound, and it stopped the bleeding.",
      "word_count": 29
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "I guess it was ammonia or something, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And I was thrown into a ditch for the rest of the day.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "I couldn't stand up, because I lost too much blood.",
      "word_count": 10
    }
  ],
