{
  "stem": "8725.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I come from 12-hour job.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And in his room, there are Russian nurses, laughing and singing.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "They're drinking.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "I could not lock my door.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "But I brought a little tea in a bottle with me.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I fell asleep because I was tired.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "But somebody was in my bed-- awful smell of alcohol.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And men was fighting, trying to rape me.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "When I was fighting with him, my hand drop on the bottle.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And, without thinking, I knock him over the head.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "And he sort of slumped.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "And I sneaked from underneath-- I was so scared-- and I ran to the hospital.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "In the hospital, I was so shaken up that Dr.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "David-- they have a night shift.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "I could not-- I was not coherent.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "So he gave me-- just to quiet me down-- some injections.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "And I fell asleep.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "When I awaken in the morning, I was so scared.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "I thought I killed him.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "All I say to the doctor, I kill him.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "I kill him.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "I was so worried.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So he sent a nurse to check my room there.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Well, my bed was wet.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The tea, it was, yes-- But he was not dead.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "But then from then on, I became paralyzed with fear because Dr.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Ksydzof was just looking at me like a fighter.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I was so scared that I started losing weight.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I was getting sick.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "David, I confided in him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And I say, I will die of it.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "I am just so scared.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And so he said that he would try to find a way for me to get out from the hospital.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He's-- yes, he spoke Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And he could come.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "He was not a prisoner.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "He lived in that town, so he was coming and going.",
      "word_count": 11
    }
  ],
