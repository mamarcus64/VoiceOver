{
  "stem": "19895.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was in the border in the concentration camp--",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "--when this happened.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I seen the ruins of the bridges.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Yes, and I was able to see that so-called pontoon bridge, which was portions of wooded floats, which re-established the first closure between the two sides of the city, the hilly of Buda and the [INAUDIBLE] side, which was the major commercial and apartment building side.",
      "word_count": 46
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And so I arrived to the neighborhood where I was.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And before we were taken to the Jewish house, I was on my way seeing that building, which was bombed out.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "The first two floors of the building was shattered.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And the lower first floor was partly there.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And nobody lived in the building.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No, that was the house which before the Jewish house.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And a few blocks away, I went to the Jewish house.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It had no more the star of David on the front door.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "That was taken off.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And I went to the attendant's house, apartment on the first floor.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And the attendant's door, I was knocking on.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And a woman whom I remembered well, as far as her looks, I knew that she is the wife of the attendant over the building.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And she said, what do you want?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "Looking at me kind of strangely, I must have been some kind of a little unusual sight of a skin-and-bone little creature and all kind of raggedy clothing on.",
      "word_count": 29
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And I said, I am inquiring if anybody here from the days when this was a Jewish house is still alive and here.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And she looks at me, yes, there are some people here.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Whom are you looking for?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And I said, I'm looking for the Lichtmanns.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And my name is-- and she says, you are, I can tell now, you are.",
      "word_count": 15
    }
  ],
