  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "She started, and the call was over the few minutes.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And-- and one day it happened, a miracle.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "I came where this officer, the undercover there, asked me to meet him, and I asked for his name.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And there they said, he's not here.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And-- and he disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And that was the end of it.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "In Tomsk, [PAUSES FOR 3 SECONDS] I stayed till the end of-- '40-- till the end of '42 or '43.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I don't-- I don't know about the year.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "From there is a different story.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "My brother-in-law paid to-- me to bring me over.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "To-- to Stalinsk.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Because I couldn't get-- you know, from work, couldn't get a-- how you say, relieved.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I-- I couldn't get a-- a ticket.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't get a-- the-- the-- I had to have a visa.",
      "word_count": 12
    }
  ],
