    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And we could see outside, through the little thing that, they were carrying machine guns and dogs.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And we came out from the train, from the carriages.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And we walked.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "They didn't have where to take us.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "On the way, there was a doctor with us, he-- who swallowed some tablets.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And the Germans went and took him, straightaway, with them.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And they-- where they took him, we don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But we found-- we after, found out, that he was in a hospital.",
