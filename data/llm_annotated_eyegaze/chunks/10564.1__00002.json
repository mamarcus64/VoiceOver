{
  "stem": "10564.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we took-- because we took as much as we can, almost everything from the Krakow, Kazimierz, to ghetto Plaszow.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, closed, completely closed.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So we went to ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My father worked a lot for the Nazi as a plumber.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I worked, too, with them, and my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "My older brother didn't like it, what the German done at Kristallnacht, 1938.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "So my brother said to my parents, let's go to Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We have a better chance to be survive-- to survive the Germany, Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Let's go to Russia.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But my father said, no, no.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I know Germans because they are this and this.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But my brother said, no, I'm going out.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "So he went to Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "You were able to leave the ghetto?",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, not ghetto-- in Krakow, 1939, before, before we went to ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But my brother said, no.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He went.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And he survived the war.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And that means my father, my brother, my sister, my mother, and myself, we were in the ghetto, five of us.",
      "word_count": 21
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We were in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "So my mother had a store, fruit store like we have in Krakow.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "My father was a plumber.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "But the Germans, right away, took my father to  work, because they didn't pay too much.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They didn't pay at all, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "So we get passes to get out of ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "So that means we got passes to get out and to walk.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "If the job is 5 miles, we walk 5 miles, or 6 miles  or 3 miles.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "But we walk, and we have a bicycle.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And in the bicycle, we have a lot of tools, like [INAUDIBLE] and ice cream, like they're selling ice cream?",
      "word_count": 20
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And we have the tools in the bicycle.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And we always try to push the bicycle.",
      "word_count": 8
    }
  ],
