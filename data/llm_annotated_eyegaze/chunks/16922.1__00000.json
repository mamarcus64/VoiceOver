    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I used to go every vacation, I used to go to my grandparents in nice-- their-- a large family.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "There was a large family, uncles and aunts, and I visit them, just a small town.",
