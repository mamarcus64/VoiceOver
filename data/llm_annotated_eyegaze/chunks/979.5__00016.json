{
  "stem": "979.5",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "You're not-- you're choking because your nerves are weak.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "The ones around the heart, they're tightening your heart.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And that's why you can't breathe well.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "But don't get scared.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "So she gave medicine.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "But it's uncomfortable.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "Five years in England, I was fighting for breath.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "And yes, I was keep on going.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "I got a job.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "And, and also, I got-- all the skin of my hands peeled off, just like that.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "And I was in agony with the pain.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "They send me to-- I went to-- they-- from-- they sent me to so many doctors-- that doctor, he sent me from the skin doctor.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "And at the  end he says, send the patient to the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "So I went, not to stay.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "I went to the specialist there in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "He, he gave me pills for nerves.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "He says that the nerves make your skin like that, that that will hurt you, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "So he-- so he gave me medicine for that, too.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 22,
      "text": "And the five years in England was tough.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 23,
      "text": "I couldn't-- I wasn't feeling right.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 24,
      "text": "But I was keep, keep-- we don't-- because we didn't have enough-- the rooms were not the greatest rooms.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 25,
      "text": "We don't-- everything was wrong, the places we were living, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 26,
      "text": "You have to put up and pay your own money.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 27,
      "text": "And stay-- and so you eat less because they charge you so much for a furnished apartment or room.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 28,
      "text": "On that-- I could write a whole book on the furnished room that we  had to  go through.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 29,
      "text": "And then we were so desperate.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 30,
      "text": "I didn't have nothing to my sister or my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 31,
      "text": "But I sent them a picture, thinking they're going to like it.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 32,
      "text": "And I look so sick.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "They say, what's the matter with you?",
      "word_count": 7
    }
  ],
