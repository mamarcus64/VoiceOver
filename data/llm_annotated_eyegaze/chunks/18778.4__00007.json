{
  "stem": "18778.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 313.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to Philadelphia High School for Girls, and then I got married.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Right out of high school.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, there was a German-Jewish club here in Philadelphia called the Central Club.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It was a club for Jews from Central Europe.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And my husband had been one of the founders, and his brother as well.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was-- at the time that I joined, it was on North Broad Street, near Susquehanna.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And we lived on Park Avenue, near-- in that neighborhood, near the old [INAUDIBLE] synagogue.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And there was a youth group, and once I was 16 or so, I was of age to join the youth group.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I was one of the younger ones.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And this was during the war.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "There were-- the only-- the only young men around were 4-Fs.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Everybody else was in the service.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Nevertheless, there was a place to go to.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "There was ping pong to play.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "There were records to, to listen to and letters to write to the, the boys who were in the service.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And when somebody came home on leave, they always came to the club.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And my mother-- it was within walking distance of where we lived, and my mother didn't have to worry where I was hanging out.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "There was a restaurant in the clubhouse where you could have very good and reasonable meals.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Often, my family used to eat there Friday nights.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And Fridays with my father's day off, and so sometimes he would treat, for dinner, to go out there.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And it was a good-- and, and I met young people there, you know, and people who had the same background as myself.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "My American classmates didn't have a clue.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "Nobody ever asked, and I never told.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "I wanted to fit in.",
      "word_count": 5
    }
  ],
