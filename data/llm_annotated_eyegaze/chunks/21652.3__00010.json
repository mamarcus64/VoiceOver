  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "My-- 10 siblings and my parents were 13 people.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "We-- five of us-- three brothers-- three sisters.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] Actually, there were three brothers survived.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "One we lost later.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "Six survived.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] Oh, we decided to leave Buchenwald.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And we settled-- we were given trains by, I think, the Joint Distribution Committee.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And they helped us with transportation to the DP camp Landsberg am Lech in Bavaria.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We were there till about [PAUSES FOR 3 SECONDS] '45, '49 or so.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "My brother was given a position as a [NON-ENGLISH], brother Simon.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] That was in Germany, [GERMAN] in Bavaria.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And he managed a textile shop, because he was familiar with textiles.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes, please.",
      "word_count": 2
    }
  ],
