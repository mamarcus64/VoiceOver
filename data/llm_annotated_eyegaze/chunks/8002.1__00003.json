  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't like a private-- your house.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "Of course, it belonged to my father and my grandfather.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "But I liked at Viski better, because it was much larger, the house.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And it didn't look that ugly.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "The apartment house looked not so nice.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "My father's parents.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "They lived in Viski.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "They stayed in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want to move.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Jewish and Latvish.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father spoke fluent German.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "He also spoke fluent Dutch.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "He also spoke Swiss and Hebrew, and also fluent Russian.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "My mother used to speak Russian, Latvish, Jewish, [PAUSES FOR 3 SECONDS] and a little German.",
      "word_count": 16
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Well, at that time, I spoke Latvish and Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But in 1940, when we started to go to school when the Russians came in, we had to learn Russian.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "They didn't want us to speak Latvish.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "They wanted to speak Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "We had all kind of literature.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "We had books.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "We had like a library.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "There were a lot in Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Of course, we had a lot of Lettish books.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "There was Hebrew.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "There was some [NON-ENGLISH], Jewish, beautiful [NON-ENGLISH] works.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And there was quite a few in Latvish and Russian and also German.",
      "word_count": 13
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my father took us on a Jewish play, [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "When in-- it was in 1940 [PAUSES FOR 3 SECONDS] he took us.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "For the kids, it was a big occasion.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "My father and mother used to go.",
      "word_count": 7
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 3,
      "text": "And the nanny used to take care of us.",
      "word_count": 9
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I think so.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yes, definitely.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "There's no-- not on Saturday.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "I had to go Friday night, [PAUSES FOR 3 SECONDS] Friday night and Saturday.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "No, we didn't even know anything about Hitler.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Well, the parents never spoke to us about war.",
