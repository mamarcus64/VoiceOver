{
  "stem": "9489.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I figure up maybe they're going to fire me.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "You know, [INAUDIBLE] lots of people want my job.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So I decided, you know, I got a family here-- to try appeal for a few months.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "A doctor told me, OK, change your [INAUDIBLE] see what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "That's what happened.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So I took three months leave at half pay.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Then I start to be good.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I took another two years' leave.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And that's-- that's when you came to Winnipeg in 1956?",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Then I prolonged my leave.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And a while, after 10 years, you got the right for two years' leave without pay.",
      "word_count": 16
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "My wife was living in the station.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "She didn't have to pay the rent, you know, with the daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And I sent how much I could, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Plus, you've got your own family.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "They support you.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In 1958, they didn't let up my wife.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "They want me to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "The consulate come a few times to persuade me to go back.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And I told them that's not a job for something that thinks is my life, my health.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "So then they let my wife out, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "They brought my wife.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And that was a 1958?",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "'58, Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I was working in a cutter, Jacob and [?",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Crowley, ?] S and S Sportwear, you name it.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Was season work.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Hardly could survive-- $18 a week and unemployment insurance, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Three months, you work, and three months, you collect it.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My wife start to push me.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "She said, there's no end to it.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "She was working very hard, two jobs.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And my wife told me was going to be the end.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And here [INAUDIBLE] city for my wife's city.",
      "word_count": 8
    }
  ],
