{
  "stem": "7860.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My friend, neighbor who survived the war-- we're only two children survive out of the 25,000 people in my ghetto, Otwock-- [NON-ENGLISH]-- he went to [NON-ENGLISH], which means school-- public school number four.",
      "word_count": 33
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Which public school-- because Jews were only-- only quota had-- could go to public school.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I wasn't permitted.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Cheder, which is a Hebrew-- learned how to read and write and basic arithmetic.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have a chance to go much schooling.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Because I only went like equivalent to like second grade maybe grammar school.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Learn how to read and maybe a little bit of arithmetic.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "My mother was very religious.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "My father was a communist.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The reason of his I understand now why he was a communist and so was his brother in Chicago who worked for [NON-ENGLISH] as a salesman, is because they felt communism will solve everything, all the problem, anti-Semitism.",
      "word_count": 38
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Because everybody will be equal.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And he wouldn't have to slave, work day and night just to hack out an existence, hard existence, just the same.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "So communism would solve everything.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Very-- my mother was very religious.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So he likes to go out to the ghetto and bring home a little piece of meat back from the Polish butcher shops.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And she wouldn't eat it.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "She gave me a little pot to cook it for myself.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And all the people dying of hunger on the streets, children laying dead on the streets.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "She wouldn't let me-- no, she would let me cook it for her then give me a separate pan to cook it for myself.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes, celebrated Passover.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "All the Jewish holidays were under my mother's supervision, of course.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I remember even taking to burn the [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And she gave me some money to burn, build a little bonfire.",
      "word_count": 12
    }
  ],
