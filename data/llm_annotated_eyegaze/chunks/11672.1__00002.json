    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I learned the religion-- religion, you know, the Bible.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "No, like normal, like here-- the same thing.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And there is the-- in Lublin, you have the biggest yeshiva in Europe.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It's called Chachmei, [PAUSES FOR 5 SECONDS] Yeshiva Chachmei Lublin.",
