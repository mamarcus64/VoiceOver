  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "He ran after me.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I ran home.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "He followed me.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And he beat me up right in front of my parents' front door.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "Well, when they heard the commotion going on, they then opened the door and rescued me, so to speak.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "That's the only two times that this happened to me.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "But that was enough for my parents to realize that riding my bicycle on the streets and going to the park alone was not a very good thing to do.",
      "word_count": 30
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "After-- just to jump ahead here a little bit-- after the practice in Buchau, which my father had--",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "--was taken away by the Nazis too in 1935--",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Buchau is a suburb of Germany, about 50 miles away.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "My father had a second practice over there.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "He got there by car, by automobile.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "My father had a very small automobile, a three-seater, one-cylinder car with one headlight and one door.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Basically speaking, a covered motorcycle in a way.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But to come back to that, rather than being in the parks, being on the street in the summertime during vacation, I had a season ticket for the Berliner Zoo.",
      "word_count": 30
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I spent a lot of time in the zoo.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember if I was with my sister or not.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "This was a safe haven, so to speak, so I played in the zoo.",
      "word_count": 14
    }
  ],
