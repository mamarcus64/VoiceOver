  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "This is the most holy day of our year.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We're having a service.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "You can't see him now.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "You can't disturb our service.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I promise you I will bring him to your office tomorrow.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "So they went, and we continued with the service.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "And poor Abraham of course was trembling.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "The next day, I took him to the officers, and they grilled him as to what he was up to and so on.",
      "word_count": 23
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And he came out back, and he was trembling.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "We decided it was time for him to go.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "And so we packed him off to Bergen-Belsen to join the illegal immigration himself.",
      "word_count": 14
    }
  ],
