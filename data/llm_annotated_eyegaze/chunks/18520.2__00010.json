{
  "stem": "18520.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "What do you speak in Yiddish-- in Polish for?",
      "word_count": 9
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "They're so good to you?",
      "word_count": 5
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "But they speak Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "What you heard is songs, [PAUSES FOR 3 SECONDS] people sitting with the feet on the side-- on the sidewalk and singing songs.",
      "word_count": 23
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "You never heard beautiful songs, making songs.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "There was a, was a song one time in the camp or two, this we used to sing with a, a woman.",
      "word_count": 22
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 2,
      "text": "You work a whole day, and you come and you-- they-- you wait.",
      "word_count": 13
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 3,
      "text": "They give you outside a little soup, you know, for the day.",
      "word_count": 12
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 4,
      "text": "And, and she takes us in the hand and looks and she has nothing to eat.",
      "word_count": 16
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 5,
      "text": "It's a little water.",
      "word_count": 4
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 6,
      "text": "So she sings a song.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH], go a little deeper, and get [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Thicker stuff a little bit inside.",
      "word_count": 6
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH SINGING] You know, [LAUGHS] this was the song and another few words there.",
      "word_count": 14
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "But this is what was.",
      "word_count": 5
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 3,
      "text": "You turned in plain as an animal.",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 4,
      "text": "You see the dog goes, he smells on the floor.",
      "word_count": 10
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 5,
      "text": "Oh, you find something.",
      "word_count": 4
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 6,
      "text": "And these were the people.",
      "word_count": 5
    }
  ],
