{
  "stem": "16930.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Just to go back-step for a moment, while in [INAUDIBLE], in England, I started a correspondence course for a high school diploma.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And the same company in Britain also had a branch in-- in-- in Jerusalem of the correspondence course.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I continued with that, the correspondence course, after I got out of the-- out of the Air Force.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And I took several subjects.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And-- and then in 19-- and then I got a job, several different jobs in furniture factories.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Then I got a job in 1951.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I got a job as a teacher, a shop-- as a shop teacher in [INAUDIBLE] school in Tel Aviv.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And-- and I was also doing this-- this high school correspondence.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And then it got to a point I wanted to go, a little adventure, see my family.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I haven't seen any of my family, other than my sister, since 1939.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "And I had family, those who weren't killed, were in America-- uncles, and aunts, and cousins in America.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "I wanted to get to know my family.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "I wanted to complete my education.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I was into education.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And I wanted a bit of adventure, life adventure.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "You know, I was getting a little bit-- I wanted a little adventure.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So in February-- February, of 1954, I went to-- I got an affidavit from my aunt to go to United States.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "On the way there, I stopped off-- it was by boat then-- I stopped off in England for a few months, about three months, to visit with my sister and so on.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Where was her sister at this point?",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She was, at that point, still in that little village near-- down south.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But she was not happy there.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Things were not going that well there for her.",
      "word_count": 9
    }
  ],
