{
  "stem": "6526.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "We did not, as some children were-- stealing from parents or things like that.",
      "word_count": 14
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "We had enough.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have to do anything.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 5,
      "text": "We were loved.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 6,
      "text": "And we loved our parents.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 7,
      "text": "So this is how we--",
      "word_count": 5
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "--do the same thing.",
      "word_count": 4
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "Yes, uh, I belong to American Gathering and [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "And my daughter belongs here also.",
      "word_count": 6
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 2,
      "text": "And I think my daughter in St.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 3,
      "text": "Louis belongs also.",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 4,
      "text": "Whenever there comes something, they do a-- they do attend.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 5,
      "text": "And they do want to know what happened, and things like that.",
      "word_count": 12
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "They're very-- very well Jewish-minded.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "The children go to Hebrew schools.",
      "word_count": 6
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Uh, matter of fact, uh, my oldest granddaughter--",
      "word_count": 8
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "--uh, just got a trip, a free trip to Israel because she attended the-- and she still attends the Hebrew school.",
      "word_count": 21
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "And the children, um, in St.",
      "word_count": 6
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 1,
      "text": "Louis know very well, uh, reading, reading the Torah, reading the--",
      "word_count": 11
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "Very well Jewish-minded.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "Occasionally.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "Occasionally.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "I'm not, uh-- not-- not much.",
      "word_count": 6
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "I'm not trying to think during the days.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "Or sometimes, maybe occasionally, uh, you meet people and-- uh, that we were in the same camp.",
      "word_count": 17
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "So we talk about it during the day.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 6,
      "text": "And-- but we're not talking-- not like-- like we tell the story how it was here.",
      "word_count": 16
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 7,
      "text": "We-- it's different.",
      "word_count": 3
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 8,
      "text": "It's different.",
      "word_count": 2
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 9,
      "text": "We're not trying to go out and keep-- I was here.",
      "word_count": 11
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 10,
      "text": "You have to have respect for me.",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 11,
      "text": "I'm not coming up-- advertise.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 12,
      "text": "Look, you-- I was here.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 13,
      "text": "And you should, uh, keep your mouth shut because, uh, I was there.",
      "word_count": 13
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 14,
      "text": "I'm not trying to-- to promote myself-- that because I was there and I survived that I'm a-- I'm a big shot.",
      "word_count": 22
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "I-- I wanted to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "But I don't wanna go back by myself.",
      "word_count": 8
    }
  ],
