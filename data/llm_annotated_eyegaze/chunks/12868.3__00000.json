  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean how?",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We walked to the train.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember already.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I've been like an a coma.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "You see, I-- they I hardly moved.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Only they see-- when somebody-- somebody moving, and they think, let's go.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Maybe we try somebody to-- to bring alive.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "Only took three of them between thousands, what you see in the picture, thousands of them.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We-- my unit from an American liberate, you are the one who brought me in the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "When he came here, we took the pictures, what you see there.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "He got the pictures and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And-- and-- and he was one of the liberators.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I hear a lot, of course, from them.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "This-- their major, their major from the unit, he took every-- the pictures.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And he took-- and he-- when he say, I am [?",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Ahid ?].",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I am [?",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Agothid. ?] My mom is [?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Agothid ?].",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH], don't kill me.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Don't kill me.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH SPEECH] When he opened up his blouse and he took out the mezuzah.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "When I see the mezuzah, only he see the mezuzah, only he start to cry.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And I start-- I been so emotional, and I start to cry.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "There's all the soldiers around start to cry.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "On every [? shoulder, ?] see, I'm-- I'm talking to somebody a little bit.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "Everybody who got chocolate, and cigarettes, and [INAUDIBLE] on bread.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Everybody took-- [INAUDIBLE] it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "When the major said not to do nothing to him, not to talk to him.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I be in a half hour.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I'll be back.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "He came in the jeep with three doctors, American doctors-- the American-- German doctors.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "The American had them already prisoners of war.",
      "word_count": 8
    },
    {
