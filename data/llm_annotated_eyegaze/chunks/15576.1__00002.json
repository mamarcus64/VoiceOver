{
  "stem": "15576.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Now as far-- as far as school goes, I had non-Jew-- non-Jewish people that used to do our homework together and all that.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Slowly, it diminished to the point where-- I'll tell you later-- that the person that I lived so good with, it was such an-- it turned out completely, it was-- later, there was a law.",
      "word_count": 35
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I'll talk about that later.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And I remember going-- going to school was an ordeal and coming home was an ordeal.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I used to be the last one in and the first one out.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Because, otherwise, they would grab us.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "We were--",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "In-- in that same town, in somebody's house, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We had a full day.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "You know something, I don't remember.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But I don't think they got-- I would ever-- no.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "There was some.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I'm sorry, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "There was some.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Not all of them, but they did go.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I remember going home with [INAUDIBLE], and I had a crush on one.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "There is no little bit.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I never knew when my mother got up.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I never knew when my mother went to sleep.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Her maiden name was Lea, but she was called [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Sternschuss.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And where were we?",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "We were on-- on-- on-- with the school.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sorry.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I knew there was something.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No she was born where my grandfather was born, in a town called Myszkow.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You want to spell it, I'll spell it for you, M-Y-S-Z-K-O-W.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "This is where my grandfather lived, with this son and daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "The reason I remember, very close, because he only came for holidays.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And he always brought nuts.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "He had a nut tree.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Walking distance at half an hour to 45 minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I wouldn't call it far.",
      "word_count": 5
    }
  ],
