{
  "stem": "19596.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "The reaction of the population was worse in Poland than in Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Laughing, mocking-- I couldn't understand them at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Now, I speak Polish because I learned it there.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "But it was worse.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "[POLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I mean, we knew [POLISH] was, [POLISH]-- spitting.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Some asked for water, didn't give it.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "Germany, they gave water.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "In Germany, they gave water, and was chased away by the-- by the police.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Water for the children-- they gave water.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But they were pushed away by the police.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And the police said, they're all criminals in there.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "They're all rapists and children molesters.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "The police said that.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Mm.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Do you mean the ramp in Auschwitz?",
      "word_count": 7
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know about camp, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "There was no camp.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "There was a-- there was a station, a big, huge railway station.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And they stopped there, and they stopped there for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "And then the doors went open.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Dogs, SS in-- in-- in army uniform, SS, and prisoners with stripes.",
      "word_count": 12
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "No signs-- no signs, and no [? reliable ?] times of trains.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And then we went out, and the usual--",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    }
  ],
