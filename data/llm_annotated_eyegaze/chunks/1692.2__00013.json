  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And that's from Poland, we made our way to Czechoslovakia, to Austria, and in Austria, we were in DP camps.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I was in D camp-- a DP camp, [?",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Velz ?], and then they took us to Bad Gastein in the Alps.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And-- and then later on, we were in the Alps.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "That was not bad.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And in Austria, they took us to Ebersburg from Bad Gastein And that's where I met my husband who was-- who was a survivor of seven camps.",
      "word_count": 27
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Seven?",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Seven camps.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And he's the one that there were seven children, and he-- he was 15.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "The youngest was six months, and he was the only one that survived.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "He was the only survivor and fell in love and got married.",
      "word_count": 12
    }
  ],
