{
  "stem": "377.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[SIDE CONVERSATION]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Lola Kornfeld.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "K-O-R-N-F-E-L-D.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Poland, in Biala-Bielsko.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Biala-- B-I-A-L-A.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "What do you call that?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Not apostrophe, what is that thing?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Bielsko-- B-I-E-L-S-K-O.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "January 10, 1917.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "David and Hermina Kornfeld.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Whose name?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Kornfeld.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Isadore Kornfeld.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "He was four years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember his birthday.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "One brother.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My father-- my father had a carpet factory.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I was a happy-go-lucky little girl.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] That's all.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I didn't-- I didn't think of anything.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I didn't think of anything.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I didn't have to go to work.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I didn't have to look for a job.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have to-- I didn't have to do anything at all.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "I went-- I-- I could go up to the factory and help out a little bit sometimes.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And sometimes I did not go.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Sometimes went-- nothing very hard.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Not Orthodox.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Not Orthodox religion, but religious.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Trouble where?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "In Poland, or--",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in Poland, always was trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But in that time it wasn't so bad.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "In that time, it was-- first of all, I didn't live in between Poles.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I lived in between Austrian people.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "This belonged, before the war, to Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And they didn't Polandize.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I went to German schools, too.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "My brother-- all the schools in German, everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Later on, later, later, later on, they started to Polandize the schools.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "But then I was out of school.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "But later on, they did it.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't go very far.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "No, they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "They changed one school in Biala, where I was.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "They changed one school.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "Because the school where I went when I was a kid was a big, big, big building, a big school.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And that was German.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And the Poles didn't have big schools, so they took it away in that time.",
      "word_count": 15
    }
  ],
