  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We lived there.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And the store was a beautiful suite.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "We rented out the store for $175 and our mortgage here was $175.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "So we-- we broke even.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And thank to God my wife-- she helped me to pay up the bills, the mortgages.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "She was making a killing-- $21, $22.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "The last part-time job-- she helped me to survive through the business.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And after two-- after four years-- like I said, we-- after four years, we built a big huge supermarket.",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I got contract with the army and with Indian Affairs.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And they give me big orders.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "We retired [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We retired when-- five years ago.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "'89, I think so.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they moved in and they bought us up.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I never believed that Indian Affairs-- they buy the stock.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "They buy the home, everything.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I didn't even have a lawyer.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Clean deal-- they paid for everything.",
      "word_count": 6
    }
  ],
