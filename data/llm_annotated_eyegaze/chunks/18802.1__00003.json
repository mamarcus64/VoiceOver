{
  "stem": "18802.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 400.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And I finished school, and my father was very, very angry that he called every day from Berlin.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He said, my daughter is still a schoolgirl!",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It's awful, this!",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Only a German could do a thing like that.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And it's very sad that a Viennese girl couldn't find a boyfriend in Vienna.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "She had to import one.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "So he was mad.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Anyway-- Can we go back just a little bit about some of your earlier experiences in Vienna, as far as your Jewish identity, the Shabbot, if you celebrated that as well.",
      "word_count": 31
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I tell you, I lived in a very assimilated household.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "So I had no Jewish connection.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I was-- was later a Girl Scout in a-- a Zionistic movement, but my parents really didn't live as Jews.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I still remember the [INAUDIBLE] time for Christmas.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "My husband-- my father said to his bookkeeper, I want the same amount for the Social Democrats for the [INAUDIBLE] for the Jews.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So I mean, I had really no Jewish experience whatsoever.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "We-- I-- in the school, I knew I was Jewish, and I even was in some way, very attracted to a lot of things, but not influenced by my parents.",
      "word_count": 30
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "What kind of things attracted you?",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The stories, for instance.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I loved the Pesach story, and I loved the Purim story.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "What a young girl would like, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "But my-- my parents had no idea what it is about.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "My mother had a faint idea.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "My husband-- my father, not at all.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We had mostly gentile friends, not Jewish friends.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "As a child?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I was always making sketches.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I was good at drawing.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I liked to swim.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And that-- and what-- what a young girl doesn't.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I even liked school.",
      "word_count": 5
    }
  ],
