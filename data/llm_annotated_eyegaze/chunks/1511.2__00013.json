{
  "stem": "1511.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And then I said, I'm going to jump down for a second while the train is going.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Maybe I'll grab that lepyoshka and with a little bit hot water, just [RUSSIAN], they call it in Russian.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And I took off a few chervonets.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Chervonets, that means, like, 100 rubles or something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I just jumped on.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And I just let go the train.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And I want to go down from the hill.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And this train start going back.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And I said, uh-oh, if I'm going to be left, there was Tajiks, Uzbeks.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "I knew to talk a little bit, because there was a lot of them where I used to live.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "So I knew some words.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, That was-- I was coming back from Chkalov.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't-- I was in Kazakhstan.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Samarkand was Uzbekistan.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And that was Kazakhstan.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "It was far away, three months traveling to my place back.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I said, if they gonna-- if they going to kill, get me now-- and I had a lot of money-- they going to make hamburgers of me, or steaks.",
      "word_count": 29
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I start running back to the train.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "I start running back.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "I didn't have time to go down and grab anything.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "So when I started running back, I couldn't catch the train.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "A guy jumped on.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "His hand was bandaged.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "He was wearing a Russian uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "And he had revolver in here.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "And he held onto the train with his hand like that.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "He handed me the hand.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "And he grabbed me.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "He pushed me up.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "He brought me up on the train.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "When we came in the train, and I stood on my place, and he came over.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He said, who are you?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "What are you?",
      "word_count": 3
    }
  ],
