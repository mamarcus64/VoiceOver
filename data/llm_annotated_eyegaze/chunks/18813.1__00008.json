{
  "stem": "18813.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Both from there, we went to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "In the ghetto, there was not so much room.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "It was small apartment and a few families.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "And we lived there for awhile.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "If I have to be honest with you, I don't remember the name.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I just remember one girl, who I am very good friends with her still.",
      "word_count": 14
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "She lives in New York.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "And her name is Paula Fishman after she married.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "We are very close because we spend half the time-- she give me as money for-- helped me to get the job at the airport.",
      "word_count": 25
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "And we were both going to the airport and always, if I could bring her a piece of bread or something, I was bringing to the ghetto.",
      "word_count": 27
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "The two, three brother-- two-- three brothers, yeah, and me.",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yes, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "One wasn't married.",
      "word_count": 3
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "The youngest wasn't married.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "He is younger than I am.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "You know, the truth, I don't remember.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "I really don't remember how we got it.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "But it was tough, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "If we went out to, to-- I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "I really don't remember how was it.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody was working in the ghetto, nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "19-- September-- 1940, beginning of 1940.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No, Cracow was liquidated together.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "We all went together.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "To leave-- to leave--",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "I don't know if we were the first one or the last ones, but [SIGHS] we-- I was surrounded only by Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "So I don't know if they were there-- some before, some came after.",
      "word_count": 13
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "But Cracow was liquidated from the Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
