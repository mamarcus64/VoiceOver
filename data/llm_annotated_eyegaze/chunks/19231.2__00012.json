{
  "stem": "19231.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 426.9,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 12,
      "text": "And I wanted to have my own place, my own family.",
      "word_count": 11
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 13,
      "text": "And that's-- we got married in '48.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 14,
      "text": "I came '47 to Landsberg.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 15,
      "text": "I mean, to this DP camp.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 16,
      "text": "Were all together for a short time, but then we separated again.",
      "word_count": 12
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 17,
      "text": "This is [INAUDIBLE] brother, except my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 18,
      "text": "Well, the brother came here, too, a little bit later [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I begged my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "I said, don't go to Australia.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "Come to United States, so we all-- especially, I love this brother so much.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "But his wife had family in Australia.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And she wanted very-- she wanted to go to Australia.",
      "word_count": 10
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "So, he went there.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "I just ask him when he was here two months ago-- he was here.",
      "word_count": 14
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "I said, oh, it's so bad that you're so far away.",
      "word_count": 11
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "We-- we have such a separated life.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "We can't see each other.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Because we really love each other.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "But that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I went back shortly when I was-- after the war, I went back to my hometown.",
      "word_count": 16
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "And I went back to our house where we used to live.",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I went back to the neighbors, the Polish people.",
      "word_count": 9
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "And I thought maybe there is some pictures or anything left.",
      "word_count": 11
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "But nothing was left.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "The house was there.",
      "word_count": 4
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 6,
      "text": "There was like a six apartment house where we used to live.",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 7,
      "text": "And so--",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "No, absolutely nothing.",
      "word_count": 3
    }
  ],
