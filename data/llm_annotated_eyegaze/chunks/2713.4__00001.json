{
  "stem": "2713.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "We were there for quite a little while working on those trenches.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And we never had any trouble.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "No one was ever hit or anything.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They were quite, quite nice, I must say.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't a camp.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was like a farm.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And we slept on straw, which was very good, because it was in fresh air.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It was different.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "There were no lice or anything.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "It was-- really, we wish we would've stayed there till the end of the war.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "But unfortunately, this finished too.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "For only a short time.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We were there only a few weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I can't remember exactly how many.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "But from there, same story all over again-- back to the carriages and back to a camp.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So we traveled for a while.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And we arrived to a city called Czestochowa And the camp was called Czestochowianka.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In the same city, there was three camps.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "One camp was called Warte, and the other one was called Plzen.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And ours was Czestochowianka.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "What was our job?",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Mainly, the job was tanks were coming there.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And they were repaired.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And they were repainted.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And other jobs, like odd jobs or-- my job was I wasn't painting the tanks.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I always tried to be in fresh air.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I loved fresh air.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So I found myself-- because I was once working at the railway, so I got a job at the railway again.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And I was unloading things.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And it was a very, very good job.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And trains were passing with potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I used to steal potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And then I brought them into the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And we used to cook them.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "If I would be caught, most probably, with the potatoes, I could have been shot.",
      "word_count": 15
    }
  ],
