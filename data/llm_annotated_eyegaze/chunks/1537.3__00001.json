{
  "stem": "1537.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We went to Gusen.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Sometimes we walked about four kilometers, five kilometers.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes they took us by train.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The-- the train was-- the wagons were half cut, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was not covered.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And when you were in the train, you were not supposed to stand.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "You had to keep your-- sit on the floor and keep your head between the legs in order you shouldn't see around, what's going on.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "So they put us into those tunnels, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I was-- I was a young boy.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I never worked.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Beating, and unbelievable, what was going on there.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "You know, they put me to the tunnel, tried to straighten out the concrete.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "You know, the way they filled up the concrete to make the tunnels.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And we'd come home in the night, dead tired.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You had to-- again, in the train.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "The train, the wagons were full of gravel, you know, small gravel.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And you had to bend, go on your knees.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "That's the way you had to, all the way till you arrived to Gusen, to the camp.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And you were not supposed to move.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "There was no space.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "In the knee, you know, the bone into the gravel, we were dying for pain.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Because I was not supposed to get up and move.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "There was nowhere to move the gravel because all the floor was full of gravel.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So that was going on for a few months.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I forget to tell you, also, before we-- they started to take us to Gusen, you know, to-- in the tunnels, I was working in the [GERMAN]--",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Stone quarries, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That was not so bad.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We had to fill up those little metal wagons with the stones, and push it further.",
      "word_count": 16
    }
  ],
