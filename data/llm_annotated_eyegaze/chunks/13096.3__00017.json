      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] dead, count-- nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "It was the-- you know, a fly, you know, in human time-- you know, in normal time-- it's got more chance to survive than us.",
