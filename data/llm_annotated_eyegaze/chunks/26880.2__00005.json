  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I go, but it's not-- not true.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- start-- I told him I started, you know, for a minute.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I said-- and he was-- he was won't take me.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I have came here, taken my wife.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And then she starting cry-- crying and hollering.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And she won't go.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "She won't even go for herself.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And I'm not going from you.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Then I went for myself.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I-- I asked him-- when that was a barn-- you know, he was over there in a barn.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And in the morning I came, before-- before it got light.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And oh, he say, he was here-- and they-- they-- them-- their dog barking then they noticed I came.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And this place, he told-- he went home, he told his wife what's happened, where we are.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "Then she says-- she started crying.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And she said, you know, we have to do something with them.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And then they was taken over by him in the barn.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "They make a hole in barn.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And over there, I arrive in barn, and by the side, it was a hole, what we was to go in the barn, in-- in the hole.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And we was in barn till they start to-- Polish people was branding and killing the Ukrainian.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And the Ukrainian used to kill them.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "It was between them, a revolution.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "Ocean",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "One time he came and he said, Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Steinberg, instead of hiding didn't know you were save you.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "You know, now is another thing.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "What's going on?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "She's right in the hole-- one [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I say, You see, Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH], with me it's going to be a-- it must be a miracle, I say.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "You know-- you know my-- mine grandfather, he was a religion man.",
      "word_count": 12
    }
  ],
