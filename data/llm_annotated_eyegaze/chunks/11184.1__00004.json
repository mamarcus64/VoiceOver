{
  "stem": "11184.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "At that time, yeah, mm-hmm.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Polish history, yeah, a lot of Polish history.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, yeah, we did, uh-huh.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Jew-- we study religion.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "It was only one class, religion.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "So we-- there was one teacher that-- he taught us about the Bible, our-- and our religion.",
      "word_count": 17
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "But on the outskirts, I mean, you could have gone-- you know, mothers were sending children to special Jewish schools--",
      "word_count": 20
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "They were Jewish--",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, mm-hmm.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I mean, in a way-- they did in a way.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "Because we were surrounded with everybody.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "Like cooking-- my mother would cook for Passover and the holidays.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "And everything was, yeah, celebrated.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "This-- this we did.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "But my father wouldn't go down to a sukkah downstairs, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "--I questioned-- I always questioned them, why don't you do it?",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "Somehow, that's what happened, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "They, they-- he said-- my father used to say, what God wants from people is to be good, honest people.",
      "word_count": 20
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "That's all what He expects--",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "--he said.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "And this-- the other is immaterial.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "That was the explanation.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "I-- that, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "It could be that they would say a word or two.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "But, but--",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no, no.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "Because they were wonderful people--",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--you know, very kind and good people, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "I liked English.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I mean-- [LAUGHS] Polish, I mean.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] I like history.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I liked history.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And I liked geography.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "My father's family, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "I knew my father had four sisters, five-- or five sisters, mm-hmm.",
      "word_count": 12
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "They all were-- they all were there, mm-hmm, mm-hmm.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "And they also came to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Not in the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No, I mean before this-- before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, we used to go and visit.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "We used to go and visit--",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "--mm-hmm, visit them, uh-huh.",
      "word_count": 4
    }
  ],
