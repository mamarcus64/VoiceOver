{
  "stem": "1419.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.9,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They called it a big jail in Montelupich, I guess.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And the people who were hand-workers, like carpenters, cabinet makers, tailors, shoe, shoe makers, they were shipped to Montelupich.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "People who worked on the manual work, they were shipped to, to Plaszow.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Till 19-- till January, 1945.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We were the last to leave Plaszow by foot.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Plaszow, I, I remember that killing on the-- on the-- on the-- they call it Hujowa Gorka.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They used to--",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Hujowa Gorka, they used to call it.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It's kind of-- it's a name they used to call it, that particular spot.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It used to be a big hill with a big-- with a big-- what do you call it?",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Big, big holes, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Not holes.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "What do they call it?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Like, like a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "You know what they call it?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Big, big, big, deep ditches.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And they used to bring people from, from Montelupich, [INAUDIBLE] Gestapo, as you know.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] Jewish people.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Jewish and maybe Polish people.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They knew there was a lot of Polish people political.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "And they used to kill them there.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "They used to take them up from-- I saw it myself.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "They used to bring them with big trucks.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "They used to take them out from the trucks to the-- to the-- to the ravine, and just kill them with little machine guns.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And also people from the camps, if they were sick or old or did something, they took them over there, and they killed them.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "They shot them.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "And in 1944, end of '44, we had to dig all this-- all the-- all the thing out, and we had to burn all the people on, on a-- on a-- on a-- on, on a stakes of wood.",
      "word_count": 39
    }
  ],
