  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "So they-- they free you probably from your life, not from your spirit.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They break your spirit, actually.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "With my father.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I don't recall.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I think that it was during the day.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We-- we arrived there, and-- and we were gathered to facilities [PAUSES FOR 3 SECONDS] where they took all the clothes away from you, and-- [PAUSES FOR 3 SECONDS] and shave your head.",
      "word_count": 33
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "So first they-- when we arrived, and there were their prisoners standing on benches, like the sheared sheep.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And we were-- after-- before the showers, they tried to cut your hair.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I-- we-- we already knew their trick.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Like in Auschwitz, they'd take you to showers, only instead of water, there would come in gas.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So if you ask, they-- they are eliminating us, or this is just to-- to shave the hair and give a shower?",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And so he says, no, we don't have-- we don't have gas chambers.",
      "word_count": 13
    }
  ],
