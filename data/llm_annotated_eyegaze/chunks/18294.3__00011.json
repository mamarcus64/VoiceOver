{
  "stem": "18294.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And then when it comes the month is over, and they find out that I am-- yeah, before that, I had a lady there in the camp.",
      "word_count": 27
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Who she said, I'm going to Vilna.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I said, are you going to Vilna?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "My name is Drabkin.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "Oh, Drabkin!",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "I know the mother-in-law.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "I know them very well, the father and the whole family, I know them.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "I said, look you're going to Vilna.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And I have a feeling that my husband is there.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "Give him my regards.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "Find him there.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "I don't know who I have now when I come up from here.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "She didn't find him anywhere, she didn't give him-- and then after-- after months, they let us go to Vilna.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "But you were sick.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "You said you were sick.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I was hiding my sickness.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I worked with the Russians a month's time on the railway.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I didn't work, but they took the notice-- the notice I'm going to work, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "The girls done for me.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I was sitting there.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Because I couldn't do nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I was very, very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I had two big holes when I come back to Vilna, two big holes in my lungs.",
      "word_count": 17
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, there was no Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Nobody looked after you when you're working there.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "They bring you to work, you done it, you done it.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "When I come to Vilna, it was 10:30 in the nighttime.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And you have only right to go till 10:30.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "That was the Russian, you have no right to go out after 10:30 on the streets.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So then we arrive with the train in Vilna.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "The first house we went in, there was a Polish woman.",
      "word_count": 11
    }
  ],
