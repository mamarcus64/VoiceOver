  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "I start-- after that, I got a job in plumbing.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "And I did not bad in plumbing.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "I succeeded right away.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "I went right away to school in the United States after being a short time.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "My brother helped me.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 25,
      "text": "And I went to night school.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 26,
      "text": "I had to learn the English language.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 27,
      "text": "Although before I came, I prepared myself in Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 28,
      "text": "For a year I learned the English language.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 29,
      "text": "When I came, I knew a little.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 30,
      "text": "It helped me tremendously.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 31,
      "text": "It helped me a lot when I came to United States, and I knew a little English.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 32,
      "text": "After of couple weeks, I started talking English.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 33,
      "text": "I spoke English a little, not too well.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 34,
      "text": "And I applied for a job.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 35,
      "text": "In order to work in plumbing, I had to know well English.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 36,
      "text": "I went to school, and since then in the United States I went about close to 11 years night school.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 37,
      "text": "I attended various, various courses in, in this.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 38,
      "text": "And then I started plumbing, engineering, and I became a licensed plumber, and then a licensed underground tank installer.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 39,
      "text": "And I made a nice living in the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 40,
      "text": "And I was never sorry that I married an American girl, my wife, Tillie, former Rosenzweig.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 41,
      "text": "And I built a nice family.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 42,
      "text": "I had two boys, which I was proud of them.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 43,
      "text": "And one, Howard, is now a rabbi, Howard Kaminsky.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 44,
      "text": "And my other, my older boy, Marvin, is working now in Syracuse.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 45,
      "text": "And he, he's doing all right.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 46,
      "text": "And I'm proud of them.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 47,
      "text": "So that's what it is, and I'm very happy here.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Politically, they tried again I should be active politically.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I considered.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "But it wasn't convenient for me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I, I had-- I lived in this, in Bayside.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And all the actions were in Manhattan.",
      "word_count": 7
    }
  ],
