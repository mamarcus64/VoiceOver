{
  "stem": "16106.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And the doctor, the SS man had a little stick like laying on a bandstand [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And we had to line up and walk in the dark, you know, walk that huddle and in front of him.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And I did right, and to the left, right and to the left.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah we had our uniforms.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "At that time, we had our uniforms already.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I, I don't think so.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "We had already-- they took away my beautiful jumpsuit, and I had a striped thing.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Our hair was already, not shaven yet.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I don't know when they shaved the head at this point.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "They shaved the head.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And my mom was hanging on with me on the back, and my little sister.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And we were walking.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "I saw that a girl from my class did not want to leave her mother.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And she went to the-- to the side where I didn't like the look of the people.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "You know, you had-- you know where you should be.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And he and I moved up.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And this doctor looked at me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And he sees Adolf's sweetest dream, blonde, tall, light complexion.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "I mean, they couldn't have a better example of Aryan womanhood.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And he said to me, you aren't Jewish or are you?",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I said, what do you think, Herr [GERMAN] blah, blah, blah, fuhrer.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I've been here for whole long [GERMAN] Kaiswerwald.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I'm here on holiday, on vacation in the the beautiful Kaiserwald.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And he said-- he laughed.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And Hannes [GERMAN], Hannes said, oh, she just looks like that.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "A big help, him, yeah, looks like that.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] She just looks like that.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "Of course, I look like that.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "But that was a whole idea of the-- of the theory.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "I just look like that.",
      "word_count": 5
    }
  ],
