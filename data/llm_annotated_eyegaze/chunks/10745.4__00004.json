{
  "stem": "10745.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Came from a concentration camp, and took him away.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "There's another one came, he took him away, that took away that one.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "There's always somebody came and took away.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Nobody wanted to talk that the Jews were killed.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "We knew that the liquidation of Krakow-- we went around Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Krakow was a Jewish city.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "It was-- in Krakow streets were packed with Jewish synagogues.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Krakow was not destroyed.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And as a young kid, we saw a synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "We saw a Star of David.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "We couldn't get in there, but it was all Jewish-- no Jews left there.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "There was one more house which kept Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "They took-- [NON-ENGLISH] 10.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Which actually they transferred my mother from the hospital to that place there, to [NON-ENGLISH] 10.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Like I said, a lot of the kids who didn't go to Zakopane, they arranged a place called, Rabka.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Rabka was a little bit closer to Krakow, and the air is a little bit different.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "It's also in the country.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And they took a lot of children to Rabka from Krakow.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "Now, when we got to Zakopane, for three days she wouldn't let us go outside to get to the air of Zakopane because-- not to get sick.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Because we were sick people.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "We had-- first thing she did is to take everybody and see the-- we were on the third floor, on the second floor were the girls, the bottom floor was there for the schools.",
      "word_count": 34
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "But we were on the third floor-- everybody had to get undressed in the nude.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Helena Kuchler",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Lena Kuchler.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I would not spell it because I might not spell it the right way.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "My impression-- she was a very strong woman.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "She came into Zakopa-- to Krakow-- I met her in Krakow only twice, or three times.",
      "word_count": 16
    }
  ],
