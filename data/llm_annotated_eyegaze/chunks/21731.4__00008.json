{
  "stem": "21731.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "No, I can say more about it, because that is what Mrs.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "Stelmachowska did for me, again.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "And Jan.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "She decided that Jan should come on Sunday for a meal to get off this, because the children there, in the school, were not really up to the standard of Jan out there.",
      "word_count": 33
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "Even I must say that.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "What I heard about them, only what Jan said.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "I never saw them.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "But they were, well, Polish children from Polish-- they were not all officers' children.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Could have been anybody.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "So Jan-- somebody brought Jan to Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "Stelmachowska.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I never showed my face there, and Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Stelmachowska didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "For years.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Back tram.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He was a Polish boy.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "He had his school legitimation.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I showed you the legitimation.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So he-- the first time, somebody brought him, because Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Stelmachowska spoke to the head mistress or head master, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I was not involved in that.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I never showed my face.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I don't know whether Jan said that he has-- I think it was agreed to say that his mother is dead, that he's an-- the father is in the service, but the mother, no.",
      "word_count": 34
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "He doesn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "So he came.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And, well, he was very happy.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "He made at once friends with Wisza and Ola.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Wisza was much older.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Wisza was seven years older.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Ola is Jan's age.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And he got pancakes.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I remember this day when he came, Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Stelmachowska made pancakes.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Stelmachowska had some sardines, because she got from her husband, through the Polish Red Cross from Sweden, through Sweden, or through Portugal, very good food parcels, which she-- she nearly sold everything to buy ordinary things.",
      "word_count": 36
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "There were also beautiful sweaters, which she kept for the girls.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They were-- twice there were watches.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "But there were sardines.",
      "word_count": 4
    }
  ],
