{
  "stem": "10839.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And the toilets they built in the halls, not in the apartments.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "Then I said to him, the toilets are ready there.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "They are not open yet.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "Let them-- my sister in the toilet.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "You take the key.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "And give me the key.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Or you will hold the key.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "He let in my sister there.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "They send away all, all the women there-- [? went ?] away with the men.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "Later on, I took back the kids from the stable there.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And, and I got the sister back.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And then somebody, a Jew, he went to the-- not to the police.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "Only, he went-- it was one in the Sosnowiec.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "His, his name was Maryn.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "And he was the leader from Sosnowiec till Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "He used to have a building for himself.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "And he got his own police, the Jewish police.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "But they were recommended from the, from the Nazis.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "And, and he-- later on, a Jew went to his office.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "And he told him that David gave to $200 [?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "Lazer. ?] And, and [?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "Lazer ?] let out my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "And other people, Jewish people, they sent away.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "Night time, the Jewish police took me out from bed.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "He said, David, you have to go.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "We don't want to hurt you.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "For you, you'll be [? right, ?] you'll be lucky.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "It will nothing happen.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "And they took me to Sosnowiec from [INAUDIBLE], Sosnowiec.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "And I don't know-- around 11 o'clock, I got an appointment with Maryn.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "I went up to him.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "[PAUSES FOR 3 SECONDS] And I was sitting down waiting, like you're sitting in a court.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "And later, comes in the judge.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "Here comes in the judge, Maryn.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "He sits down.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And I was sitting by your chairs there.",
      "word_count": 8
    }
  ],
