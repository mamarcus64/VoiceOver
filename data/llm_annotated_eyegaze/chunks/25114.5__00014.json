{
  "stem": "25114.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "A few older carriage-- and all the energy and everything required.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "That night-- she pulled something out.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Only the will to survival put me through it.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Many times I stopped and I told my husband not to-- to go ahead.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "By then I had my two sisters with me.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And this is another story.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "And we now, they all encouraged me to go on.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "I didn't want to go-- to go on.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "I was too tired.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I was just about dead.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And no food and no water, and mud, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Every time, stepping up--",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And we arrived eventually in this little hill, which was dry.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And we had some berries.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We picked some berries.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "We got some water from somewhere. now, what we come back to life.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "We rested there.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And the Germans were coming close, all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "We heard the voices.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "We heard the thing-- the artillery bombing and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "But it's just like-- was like a cat and mouse.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I don't think they-- they-- didn't want to go around the camp to the swamps.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "They stopped and went on a little bit, and they didn't go.",
      "word_count": 12
    }
  ],
