    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And he gave them to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "That was a translator, a Polack.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "He saw this, and he told him.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "He told him.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "He was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "Or maybe he told the Gestapo.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "And you know, and he-- and he-- they took out them and they killed them.",
      "word_count": 15
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "He couldn't say nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Now I go--",
      "word_count": 3
    }
