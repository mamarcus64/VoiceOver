{
  "stem": "2916.5",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that's a wonderful question.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We were lined up when we arrived.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And this-- Herr, or Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Zerkuebbel was his name, I remember.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Z-E-R-K-U-E-B-B-E-L, Zerkuebbel.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "He was a tall, red-headed man.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "He was the head of the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And it was his job to select according to intelligence.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "You know, the more intelligent people will do the more sensitive jobs, and the less intelligent, the more menial jobs.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And how was intelligence decided?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "He had a ruler in his hand.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "First of all, all the people with blond hair, blue eyes, very white skin were put in one group.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They were already the most intelligent group.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "That was the superior intelligence.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Then the next group was people with brown hair but blue eyes.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "That was the next group-- light color eyes.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "That was next in intelligence quotient.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And the third group consisted of people who had the brown hair, brown eyes, but were, you know, tallish.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And then last came the people with very dark brown hair and dark brown eyes, and they were short.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Now, for instance, this Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Tauber, the doctor-- she also came with us in that transport-- she's a short lady with brown hair and brown eyes.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And she was in the last group, the least intelligent.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And I was a 13-year-old girl who hadn't even started high school, but I was in the superior group.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And then afterwards, he took us, only us.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "The others were assigned different jobs in the factory according to this grouping.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "But the superior group then was further selected.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And he came with this ruler in his hand.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And he measured the distance between the cheekbones and the eyes and the forehead and the width of the forehead.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I don't know what it meant.",
      "word_count": 6
    }
  ],
