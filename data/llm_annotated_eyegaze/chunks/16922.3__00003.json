  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, [INAUDIBLE], a girl, she was walking there.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And they kill her.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "They, after work, they tell her to stay.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And she was a sickly girl.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And Rosenbaum kill her.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Next thing we know, she-- he was-- he killed her.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Not nice.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The landlord, what-- who was our landlord, he-- I find out-- he kill-- he sent to the gestapo my mother.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I didn't tell you about.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "My mother sent to-- my-- my sister to him, she was ask him, she wanted to ask him, I left our apartment everything.",
      "word_count": 23
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I left-- he should give us some money for bread.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "He didn't want it.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "He took my sister, and put-- send her to-- to gestapo.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Now-- [PAUSES FOR 3 SECONDS] he sent her to gestapo, and the-- the gestapo killed her.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "They said, she had to sign a paper, she was a-- a Russian spy.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "She was 16.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "She didn't know nothing about anything.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "She just was reading and studying.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 5 SECONDS] They killed her, [PAUSES FOR 3 SECONDS] so beautiful she was, so beautiful, blonde.",
      "word_count": 18
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] Later, my mother came to look for my sister.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "He took my mother, and he took her to-- sent her to-- to gestapo.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 14,
      "text": "He bring her to gestapo.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 15,
      "text": "And they kill her.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Not long.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I ran away from there.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't stay there.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "To Krakow.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I went to friends.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "But they went-- what [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "I went to my friends.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "I met my husband.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Through my friends, I meet my husband.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "We went to Germany, and I got married.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And I went to Konstanz.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I went to Regensburg, and Regensburg is when I went to Konstanz.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
