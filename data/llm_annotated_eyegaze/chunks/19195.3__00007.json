{
  "stem": "19195.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 362.0,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I'm taking you home.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Because I already talked to my wife on the telephone.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And we gonna nurse you back till you get real healthy.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And I said, but what will your wife think?",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He says, don't worry what she'll think.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You'll see what kind of wife I had.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "He was, you know, a-- a-- always against the government, communism.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They arrested him.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And he used to go to Auschwitz and bring me-- send me always pictures from there, you know, in-- in Auschwitz.",
      "word_count": 21
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "There's-- they are from each country like Hebrew and Hungarian, Czechoslovakian written.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "You were there, so I don't have to tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "But it was, [?",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I think, really ?] in Auschwitz, the-- I went back the first time.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "Is-- it was like a bad dream.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "I went back with him.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "It's in Moravia.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, we were-- we were able to get on trains without paying.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And I-- they-- they told us that whatever you see, whatever you want, you just go ahead and get it, and-- and-- and take it.",
      "word_count": 25
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "About-- about two days.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Because we came to Prague, and from Prague it wasn't that far already.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "We came in very late at night.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "But we-- he notified his wife that we are on our way.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And some friends were-- of his were able to take us by car to his house, to their house.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And I [? never ?] forget.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "I got up in the morning and went to have coffee.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And all of a sudden, I-- I see a man.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And he was dressed like a policeman.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "I started screaming and carrying on like a lunatic.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "They didn't know what happened to me.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "But finally, you know, they appeased me. 'Cause he says, look, this is [?",
      "word_count": 14
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "Mary's ?] brother.",
      "word_count": 3
    }
  ],
