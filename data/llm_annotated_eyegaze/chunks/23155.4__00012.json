{
  "stem": "23155.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "She has two daughters.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And her older daughter is married and she has a child.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "That makes me a great grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And my son has three children-- three girls.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And he lives in Orinda, which is in the East Bay, near San Francisco.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "My husband's name is Sidney.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, my husband passed away on the 1st of May, 1996, which is not too long ago.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He was very ill.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] it was a very hard time for me.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "He was a very jolly person.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "He was a very-- he loved his job as a sales manager, because he loved people.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "He collected anything which could be collected.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] He liked to play the piano, entertain people.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "He had a good singing voice.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] He was much older than me.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] He didn't always like what I was doing, because I went back to school.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "I went to university.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "I went to Loyola where I graduated in 1974-- the last year of Loyola.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "I studied fine arts and literature.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And so when-- at the beginning, when I only could go in the evening, when I left after supper, I would make dinner and I would wash dishes.",
      "word_count": 28
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I would say, now I'm going.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he would say, so where are you going?",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "He knew very well that I was going to school, but he just couldn't fathom [LAUGHS] that I was going to school.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So I was married 46 years, and now, I'm alone.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "But I'm very busy.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I'm back at school.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I'm taking three-- three computer courses, which are quite difficult.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And I will travel.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I went back to Czechoslovakia-- or now it's called Czech Republic.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I went back after 46 and 1/2 years.",
      "word_count": 8
    }
  ],
