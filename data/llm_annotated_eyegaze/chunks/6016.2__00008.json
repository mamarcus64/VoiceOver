  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "When he was in a really-- before we were separated, he said, those who will survive have to talk, not to be silent.",
      "word_count": 23
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "I didn't listen to my father.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "I didn't practice this right away because I-- I didn't wanna put into my children hatreds.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "But it's-- I'm pleased that I opened now, and I-- and I can share and talk about this.",
      "word_count": 18
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "And I wish if my parents would live through something and not to die in such a terrible way.",
      "word_count": 19
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Maybe occasionally we did, maybe.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, talk about home.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "Yes, with other ones, socializing a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "Yes, maybe we did.",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "But I have a-- a-- I have a blackout to-- to recollect those mementos from-- maybe because they are not as-- maybe they were not important to me.",
      "word_count": 28
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "I recollect some things that it must have been useful for me to keep me going.",
      "word_count": 16
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "And to dwell on something that I am here and to cry, it's-- it hurts.",
      "word_count": 15
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] But now, if I'd let it out, I share.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] That's my way.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I was not punished by anything, no.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "No, I was not punished, no.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I was a good girl.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "I mind my work, and so did my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "But my sister was-- and until today, she had a fear of a dog, which an SS man put a dog on her.",
      "word_count": 23
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "And today, if she-- she won't come in a house if there is a dog in a house, especially a German shepherd.",
      "word_count": 22
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "A small one, maybe, compromising.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "But she has a fear.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "I have no fear, no, no, because it wasn't put on me.",
      "word_count": 12
    }
  ],
