{
  "stem": "7777.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 54,
      "text": "He took me in to work over there.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "He asked me if I am alive, he have two suits.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Who took his suits?",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "If I was in the bunker and the police was taking, who knows.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "On a ride he took me to work.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Being there for work is I see a truck is coming with a Russian police, and he take the people to the military, the working people-- because I ran away.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I ran away, and I come over there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I live with this doctor, [NON-ENGLISH] with this family.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I live over there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "They said if you will work again-- because I went and got a job in farmers bringing the milk to make the butter.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I have that job.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "As I was thinking this guy what he was a Russian manager, he will protect me and need me for work and even I have protect.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "He went and he come back.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "He said, you have to go.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "They want me to come to work.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "This doctor, what he was-- he worked in the [NON-ENGLISH] for the Russian doctor.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Is I ask him, he make for me a propose to go to Lublin.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And I went to Lublin-- was already Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "I met over there one cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "In [NON-ENGLISH] he lived.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] Oh.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "[NON-ENGLISH] I think we have here.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "He lived here someplace.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And I met him in Lublin.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "He took me, and I lived over there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "Well, in Lublin-- and I don't have no money, nothing-- I was cleaned up.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "Only he give me some 50 zlotys, 100 zlotys.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "And I went in into the truck.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "Over there was a little truck.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 26,
      "text": "And I was doing buying from the soldiers and selling to the people.",
      "word_count": 13
    }
  ],
