{
  "stem": "19130.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 494.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And they came, and they told us.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They told us exactly what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They saw the families.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And they, they, they told us the stories and who escaped.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You know, they used to-- they used to catch people.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And they used to take him to the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And they used to shoot him there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "One, one Christian-- we came to, to ask for food-- nighttime.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "So he said, you know, I was yesterday in Stepan.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "It was already when nobody was there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "So I, I went to the-- on the cemetery.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And I saw-- and he called the name who this is.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They killing that baba.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "She was still alive, asking, please, please, kill me.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "Please, kill me, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "They, they let him-- but he said, I, I didn't have a heart to do it.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Only two brothers.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We are very close.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He is coming here.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And we are going there.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "We are very close.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "My brother has now a family.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He has a-- has, has a son and a-- a son and a daughter and grandchildren, six, six grandchildren.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And we are very close.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "We are going to them and have a-- the best vacation.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "To Lwow-- to, to Philadelphia.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Our--",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Our aunts were in Philadelphia.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But they were in a neighborhood-- they were in a neighborhood that there is-- were-- they only two-- it was Strawberry Mansion.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if you're familiar with it-- if you know it.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "It was Strawberry Mansion, a very good neighborhood in a-- one time.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But when we came, there was no Jewish people anymore, but only two, two, two sisters.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "They were in a house.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "They couldn't move because they didn't have the strength already.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So we, we lived with them for, for 10 months.",
      "word_count": 10
    }
  ],
