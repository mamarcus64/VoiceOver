{
  "stem": "1020.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Two months-- good two months in time.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The only thing I have to tell you that everything what we are talking-- all of us, we will never recall dates, days.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know from a Monday, or a Tuesday, or on Shabbos.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We lived like Adam and Eve, you know, wilderness.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Our lives were numbers, that's all.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So good-- over two months until I came into the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "How did you eat?",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Very hard to tell you-- anything that came into my hands-- out of the fields, potatoes left out in the fields, dug out, could be trees, anything-- to take away a bowl of soup from a dog, to kill a chicken if I could get it, anything to survive-- worse than that.",
      "word_count": 52
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Wherever I could-- in the fields.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "I snuck myself into places.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I slept through-- lucky the time was when it went into the springtime to the fall-- I mean into the summertime.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "So I could survive a little.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "By myself.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "All what I did it by myself.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes-- Russian Jews, plenty of Jewish people from Poland arrested by the Russians, given sentences.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Cold and bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I worked.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I worked outside.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We used to go out in 50 degree below, 60 degree below.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[SIGHS] And-- wasn't such-- such a good-- they are not good stories to relay, but we have to do it, just to remind ourselves.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "In Russia, you couldn't get sick.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "If you broke a leg, it was no excuse.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "You have to have fever or die.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "If you didn't have any fever, you were not excused from going out to work.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "You could have an earache, headache, toothache-- you had to have fever or kill yourself.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Siberia, in the camps--",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In a concentration camp.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We were under guards, Russian guards.",
      "word_count": 6
    }
  ],
