{
  "stem": "2690.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "He said he would go to my parents, and he would see what was going on.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "So when he went to my parents, of course, my dad told him that he had given a big sum of money to the Germans, that we would be going to Portugal.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So he-- when he saw us on the list, and one day the head in the barracks-- we were in barracks-- came in and they said you're-- you're going on transport.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I quickly contacted my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I said you better go to Meno-- that was his first name, Meno DeHaan-- and tell him we are on the list and he better get us off, otherwise we'll be leaving.",
      "word_count": 32
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And my husband went to him.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He said, don't worry, you will be off the list.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And indeed, that was true.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "He took us off the list and we did not go to Auschwitz that day.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "Otherwise, we were gone.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "After a week we would have been in Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Then the day later, they came from the head of the Germans and they came to me and they said, you can leave the camp.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And they gave us 10 guilder, at that time, to pay for our fare to Amsterdam.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "But it was a long walk to the train station, at least an hour walk, at least, and with the young child.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "But at that time we met a gentleman, a non-Jewish man with his car.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "He was, I think, selling merchandise to the people in the camp, and he recognized my husband through his twin brother.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And he said, are you so-and-so?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He said, yeah, I know your brother well.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, I said, yes, but we have to go to Hochhalen, now I remember.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "That was far from Westerbork.",
      "word_count": 5
    }
  ],
