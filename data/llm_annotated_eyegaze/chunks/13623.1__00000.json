{
  "stem": "13623.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Eli Stern, S-T-E-R-N.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "The second name was the same.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The first name was spelled E-L-I-A-S.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "May 30, 1930.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Petrova in Romania.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Leah, L-E-A-H, Perl, P-E-R-L.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Mordechai Hersh.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "65.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "She was a beautiful lady, and that she was a housewife.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Her only thing in life was to take care of her husband and her children.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 6 SECONDS] When-- after they-- after they were married for about a year, they moved to Stramtura, which was a town not far from the place that I was born in.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "This village that we lived in is a northern Transylvania, called-- the area is called Maramures, and the closest city to us was Sighet.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "We lived a-- it was in the Carpathian Mountains.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "From-- after I was a year old I lived in Stramtura until the day that we were taken into the ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 8 SECONDS] My father comes from a family of 10 children.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He was-- he was the oldest of the 10.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "When the children were still young, his father died of pneumonia.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And when these-- when the-- every child that got married after that and they had a child and if the child was a boy, the boy was named after my grandfather Eli, the one that I'm named after.",
      "word_count": 38
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 7 SECONDS] We lived in a-- in a-- at a time where when two people got married a dowry was given.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "My mother-- my mother gave a dowry of money.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "My mother-- my father's mother gave my father land because we were all farmers.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "I remember my father building our house, [PAUSES FOR 6 SECONDS] which took a long time.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "Took several years before the house was finished.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "In the meantime, my mother had other children.",
      "word_count": 8
    }
  ],
