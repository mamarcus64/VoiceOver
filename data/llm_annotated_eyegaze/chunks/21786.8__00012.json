  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And they put an engine on, and as they start to drag us, we found out that we are not going to Mauthausen, occupied by the American.",
      "word_count": 27
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Dachau, occupied by the American.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 4 SECONDS] Naturally, Sachsenhausen was occupied by that time by the Russians.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "They are taking us to Theresienstadt.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Part of the Theresienstadt was a very bad fortress, simply where there was the toughest political prisoners.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "So that's where they will take us.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "We stopped after a day and stood on the [INAUDIBLE], which was formally a Czech territory.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "There was the train, and the-- the city called Ceska Lipa, C-E-S-K-A capital L-I-P-A, was on a kind of a hills.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "And the civil-- civilian population looked at us.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
