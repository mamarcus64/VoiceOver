{
  "stem": "25423.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "There were three kinds of Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "One, you had their Germans belong-- or people in German uniform belonging to a Ukrainian battalion called Nachtigall.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Nachtigall was a group of saboteurs and [PAUSES FOR 3 SECONDS] Fifth Column organized in Western Poland occupied by the Germans in preparation for attacking the Soviet Union.",
      "word_count": 28
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And they had German uniforms and blue and yellow ribbon-- patches.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They were commanded by future minister of refugees in the government of Konrad Adenauer, Dr.",
      "word_count": 15
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "Theodor Oberlander.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] This was one group of the henchmen.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "The second one were German soldiers.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "They probably were also some SS people, also German police-- Feldgendarmerie.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "So it's very hard to know.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "And besides, I was not inclined to [LAUGHS]--",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "--make any inquiries because people were shot, and quickly.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "All day long, from roughly 10 o'clock in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "And we were thrown out of there, the survivors, around probably 7 o'clock in the evening.",
      "word_count": 16
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Back home.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Well, I would say probably a distance of one city block.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Well, I came back home.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Obviously, I smelled of, of corpses.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And that's the very characteristic Swedish smell.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "So I washed up.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And I-- people were waiting at my house, my neighbors, because there are two of us who came out.",
      "word_count": 19
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And we told them what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "They wouldn't believe.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Myself, and a son-of-law of my neighbor, a friend of my parents who were much older.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And he was a pharmacist.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And he said to me, let's commit suicide, so we don't have to go there-- back tomorrow morning.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And my mother talked me out of it.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "They had told us to come back.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "But my mother said, you will not go.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And I was hiding in the apartment on some library shelves.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    }
  ],
