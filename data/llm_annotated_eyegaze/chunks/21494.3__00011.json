{
  "stem": "21494.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "And there we were a whole year-- maybe-- maybe less than a year.",
      "word_count": 13
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Ah, liberation day.",
      "word_count": 3
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "Then we were-- it was very cold, wintertime.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "He had a nice house.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "And we were all the time, you know, in the house and then in the-- in the-- he started-- we shouldn't freeze anymore, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "And at night, he thought, you know-- and-- and they used to go-- the partisans-- the Soviet partisans-- they used to go through the villages, you know?",
      "word_count": 27
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And-- and they used to say, you know, [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "It means the-- the bad people, you know, the-- like nuts.",
      "word_count": 11
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And-- and he used to-- and-- go-- go on the-- on the-- on the pitch.",
      "word_count": 15
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Hide yourself.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "We hiding in the pitch.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "And we go in, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "Two soldiers, you know-- and we saw that this is not-- not Ukraine police.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 5,
      "text": "They speak a perfect Russian.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 6,
      "text": "And I was looking so.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 7,
      "text": "And I say, Sonya-- I was already with the Canadian friend, Sonya.",
      "word_count": 12
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 8,
      "text": "I say, this is not a-- a partisan.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 9,
      "text": "No, this-- this is not a Bandera.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 10,
      "text": "This is a-- this a-- a Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 11,
      "text": "And he say, come.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 12,
      "text": "I-- the-- the-- I need horses.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 13,
      "text": "I need horses.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 14,
      "text": "He came out, the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 15,
      "text": "We called him uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 16,
      "text": "He came out.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 17,
      "text": "He saw so many.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 18,
      "text": "He say-- and he was a communist.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 19,
      "text": "He was, you know, a socialist.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 20,
      "text": "He say-- he was-- he was drinking.",
      "word_count": 7
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 21,
      "text": "He was a alcoholic.",
      "word_count": 4
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 22,
      "text": "Then he-- when they-- they threw him out from the Baptist.",
      "word_count": 11
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "He didn't tell.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "We right away, we understood.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "We right away understand.",
      "word_count": 4
    }
  ],
