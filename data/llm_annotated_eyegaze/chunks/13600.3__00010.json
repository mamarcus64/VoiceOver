{
  "stem": "13600.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "Now if you say the word, Jews, you-- you bring in your work, the Jewish term again.",
      "word_count": 17
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "So they very seldom used the word Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "Very seldom.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "That was, yes, that was as an event.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Until September or October '45.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "At that stage, I had already-- people started disappearing.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "What means disappearing?",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "People, together with us, the Polish colony, started little, one by one, disappearing.",
      "word_count": 13
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "So we got to know that they are leaving.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "What I did is I looked up again this woman.",
      "word_count": 10
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "The lady.",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "And I asked her if she can get for me documents, I should be able to get out and go back to Poland.",
      "word_count": 23
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "And this is how it happened.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "For me and a group of three people, four people who left.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Documents for each one of us.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "Four people.",
      "word_count": 2
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Four lots of documents, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Forgeries, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "Obviously forgeries.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "That we are officers going back from-- from a special job.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "This was a highly risky-- looking back, you see, I took a great risk.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] What happened?",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "I went from there to Moscow, via Kiev.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "To Moscow.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "First to Moscow.",
      "word_count": 3
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "This is a little story in itself.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "I went to Moscow, from Moscow to Kiev.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And from Kiev, I was in Moscow a few days.",
      "word_count": 10
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "And from Kiev, I went by train to-- these documents had the destination, Lviv.",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "Lviv was the Soviet side.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 5,
      "text": "Krakow was already not the Soviet side.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 6,
      "text": "On the train, while we were travelling, the four of us, [PAUSES FOR 4 SECONDS] there was such an institution, Soviet Russia's train police, police who just bother about the trains.",
      "word_count": 31
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 7,
      "text": "They cordoned off the train and started looking for documents.",
      "word_count": 10
    }
  ],
