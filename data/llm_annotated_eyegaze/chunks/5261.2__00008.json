  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "He tried to probably to receive my-- my [? honest ?] or my-- my assurance.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "He wanted to find my-- as a friend.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Because he tried to bring me something.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "Some sweets, some-- once he brought me some one apple, even one orange.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Orange in the war, you can understand.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "They had, but we never.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And when I needed later some shoes, some shirt, he brought me also.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "Even he gave me some [INAUDIBLE]-- for-- this is for military soldiers.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And during my [? walk in the ?] evening, I could go to the [INAUDIBLE]-- to the bakery and to buy some-- of course, there is also instant pastry, but it was [? good-- ?] [?",
      "word_count": 36
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "So ?] [? that ?] he got a good-- as a friend from me-- [? dual ?] [? duties ?] what he made for me.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was very glad.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Me too.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "My behavior was changed.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Of course my mother feel at home.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "My brother feel at home.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "They seen the change.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You must understand.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "It was war.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And then I wanted to look more nicer, not to the people in theater, but I wanted to look to see better for him.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "So I asked my mother to wash my shirts.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Every day I change another one.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And she asked me, you see?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "We have no soap.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And when we receive one piece of soap for one month, it was so bad quality, you couldn't do nothing with the soap.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "How she washed the shirts, I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "Until now, it is unbelieved.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Anyhow, I was-- and my brother also-- she-- he-- he feels something.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And I feeled also that he is doing something important with all of us.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We met very often some friends, his friends.",
      "word_count": 8
    }
  ],
