{
  "stem": "393.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "I gained-- for double.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "I became so fat that when my sister saw me, she says, what happening to you?",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "She was expecting a skinny woman.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "I got-- meanwhile, I was a couple of months with my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And I ate, day and night.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "But we were so hungry, I don't know how is that-- we are constantly-- when we had lot to eat, we ate all kinds.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "It didn't matter what-- whatever we had.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "It wasn't too much food.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "But that how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We got married, with nothing-- absolute.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We had a hard time getting a place where to live.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "I got pregnant very fast, which I didn't want to.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "But it happened anyway.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "My daughter was-- I was married in '47-- 1947, February.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Pretty soon, it's going to be 50 years.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And my daughter-- that was February.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "My daughter was born in the same year, in December 25th, 10 months after.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "It wouldn't matter if it were would be earlier.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And-- I forgot I am on the camera.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Now, anyway.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So right, we liked each other.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It was quite a nice life.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And in the beginning, I-- somehow I put aside the-- the past.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I was occupied with my family life, with my children.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "You see, I had my husband in the business.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "We had the [GERMAN], little factory, a shop.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And I didn't talk too much about the concentration camp.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't talk to my children, either, until they were small.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "Somehow, I-- I didn't know what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I didn't know how to tell them.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I-- I don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "I-- I didn't want to hurt them.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "And I thought they wouldn't understand.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "I-- I-- really, I wasn't-- I had a problem with them.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "One day, my daughter came home from the school.",
      "word_count": 9
    }
  ],
