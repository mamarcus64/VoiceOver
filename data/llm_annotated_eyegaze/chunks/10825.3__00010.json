  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And then she met her brother.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "Her brother took her to her home, had a wife and one child.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And he had prepared a room for her.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And she should live with them, and then go to ulpan, and learn-- and study the language.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "We went to a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "It was in a [NON-ENGLISH], near Tel Aviv.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And she came to visit us.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And she saw-- [LAUGHS]-- in what circumstances we live there.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And without we had to-- to bring a little bit of water.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And-- and it was very inconvenient.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "And when she saw how we live, she said to her brother, you see my dear, thanks to those people, I am alive.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I was able to come to see you.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "You have a wonderful family.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And I am very thankful to you.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "He was 10 years single-- younger.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "And he didn't forget that she took care of him as a child.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So she said, I have to help, now, those people who helped me.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And she took her things.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And she came to the [NON-ENGLISH], to live with us.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And the Director came.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "He was from Vilna, and brought another cart.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And there were three carts together.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And Elsa lived with us.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And then when we started to appear, Elsa went with us everywhere.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "We were three people, one soul [? in ?] one pocket.",
      "word_count": 11
    }
  ],
