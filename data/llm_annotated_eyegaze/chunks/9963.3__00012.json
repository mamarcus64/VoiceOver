{
  "stem": "9963.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, after that happened, they took us on a place where they were working in the steel-- you know, to pick out some people from us to send them to the ghetto, and they sent us to another camp.",
      "word_count": 39
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The camp was [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And at [NON-ENGLISH], we finished the work what we start-- was the same company, actually, but the same company what was before.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And we finished the work, you know, what we started.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And later, they send us to Tarnow to the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Tarnow, that is a-- from our city, about 60 kilometers from the-- from our city.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was a big city.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And over there, they had two ghettos-- they had ghetto A and ghetto B.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "With trucks.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "They put us on trucks and they transferred us.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "That was 19-- [PAUSES FOR 3 SECONDS] 1941-- end of 1941.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yes, it was late in the year.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It was maybe like October.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "It was later in the years, but they sent us to the Tarnow ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And the Tarnow ghetto, as you see what I mentioned it to you, was ghetto A, ghetto B.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Ghetto A was for all the old people, or the sick people.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Older people, you know, what the--",
      "word_count": 6
    }
  ],
