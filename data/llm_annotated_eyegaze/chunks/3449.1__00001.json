{
  "stem": "3449.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We had one-- I have one sister, Myrna-- M-Y-R-N-A, called Musia, in Poland-- M-U-C-- M-U-S-I-A.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And when was she born?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "She was born in '28. 1928.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I believe it was summer of 1928.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "It was like a kindergarten school, a Jewish type of organization, kindergarten school for a couple of years.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And then I was in public school for about three years-- two years-- two to three years.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Then the war broke out.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "In a regular Polish public school.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Playing soccer.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHING] I don't think there were.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember that far back, honestly.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to be a race car driver.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Would you believe?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well I always liked cars.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And to me, it was the most magical thing.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I could see we had a few cars even then.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, when we were liberated, I didn't have a car, but I had two motorcycles.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So it was a start.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[CHUCKLING]",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, very good.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Always a happy child, and lots of playing.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And just having a normal childhood.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Oh sure.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Quite a bit.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Quite a few.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Quite a few.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We had to go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Our school was-- we lived like in a little suburb.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Can you picture, I don't know, miniature Lake Ontario.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And we were divided-- we were on the island, let's assume-- you know, like central island here.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And they built a-- like a stone, a roadway.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And they built two bridges so the water could get around it.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "We lived on that outside of that city.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And the school was in the city.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And we had to always drive forth and back-- or walk or bicycle-- depends on the weather.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "It was seasonal like here.",
      "word_count": 5
    }
  ],
