{
  "stem": "17515.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "With some friends-- my friends.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "It was like a-- special for the very wealthy people, for the rich family who belonged to the Pilsudski or an organization, like a Legion Pilsudski.",
      "word_count": 26
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Although I was not from the poor-- from-- from the rich family-- I was like a poor normal.",
      "word_count": 18
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "All boys.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "I think it was-- it was organized by a-- a wife of the-- [INAUDIBLE] president, she organize.",
      "word_count": 17
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And there was a couple hundred people.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "From all over Poland, mostly from a good family.",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "There was like a-- like a-- a-- West Point cadet.",
      "word_count": 10
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Like academy.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "We'd be working, cleaning the rooms, and making clean for the what you call, for the [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "And keep-- keep in good shape, and tip-top everything.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Carpentry, [PAUSES FOR 3 SECONDS] which I was interested.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "But, everything was broke under the German occupy.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "So we were in different-- different-- different living.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Different interests-- I was-- I was interested very much a little bit of everything.",
      "word_count": 14
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "I-- I went to parents, I visit home.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Maybe once a year.",
      "word_count": 4
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Through-- though special holiday.",
      "word_count": 4
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "From 19-- about five years, from 1935 to '40.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "But-- also Warsaw was occupied by German-- German army.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "So everything was broken, like everything.",
      "word_count": 6
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "In school.",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that's when the German come to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I work-- I work in the daytime for the [INAUDIBLE], the association with the barons from all over Europe, that's what they called it, [INAUDIBLE].",
      "word_count": 26
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "Incorporated.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "I believe that's a German name, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Messenger, to-- to make them breakfast, and pick up their clothes, like a coat put on hanger, and delivering a message to the manual, or going to post office, et cetera, et cetera.",
      "word_count": 33
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Only me.",
      "word_count": 2
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 1,
      "text": "I have this special job, by special recommendation for the barons.",
      "word_count": 11
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
