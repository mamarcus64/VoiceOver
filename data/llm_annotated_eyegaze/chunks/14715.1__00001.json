{
  "stem": "14715.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Rachel.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "In Jewish it was Rachel.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She was a homemaker, busy in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Home was no machinery or washing machines or dishwashers, so she had her hands full.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I mean, it was a full life.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Since I remember, a very good cook.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Very festive.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "As I mentioned, my father was very religious, very observant.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Well, I had only one sister and one brother.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "The house wasn't big.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Although our intermediate family lived around us, but we were always by ourselves.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "We got together certain evenings for supper or dinner.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "There was not too much room to sit down many people.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "But we went to the temple in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And by the time we came home, we had dinner.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And I saw my father lay down.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And I tried to get out, play a little ball.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "But secretly.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I shouldn't have done it.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother's name was Leon.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He was taken into the war, into the army.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I never know what happened to him.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I'm, to this day, I don't know if he ever survived or he got killed.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "I had a younger sister.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Her name was Sarah.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And when I came back to the ghetto from one of the camps, my father told me that she was taken away with a lot of children from the ghetto.",
      "word_count": 30
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And they were all slaughtered.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't be more than eight years old.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Well, as I say, we-- 8 o'clock-- 8:00 in the morning we had to be in school, which when I go to public school.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And that school went on until about 2:00, 2:30.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And from there I went what they called cheder in Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "It was a religious school.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And six days a week we went to cheder.",
      "word_count": 9
    }
  ],
