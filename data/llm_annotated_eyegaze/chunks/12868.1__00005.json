{
  "stem": "12868.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And we been in the ghetto, like three, four families in one room.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "They didn't care if you got a leave-- if you got a room or you don't got a room.",
      "word_count": 19
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "They keep us like-- like animals.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "The Germans.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Nobody else except the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They make the ghettos.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And they made the concentration camps.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In Kovno, there was a-- like here, is Atlanta, let's say.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "The Decatur or Marietta, there it is Slobodka.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "It was Slobodka.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "There what we live is Slobodka.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean who takes?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "It was announced.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "They make announcement.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "All the Jewish people got to go this and then date in ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Got to go in the ghetto, and who don't do it, who be late, he's gonna be shot.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "They're gonna be killed.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "We grab-- we took only what we can handle in hand.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "We got to leave everything.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Your clothes, what you can take.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Anything that you can.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Clothes, the main thing is clothes or shoes.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I couldn't take a bed.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Or I couldn't take-- we couldn't take any furniture.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "We took anything what you need is right away.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "The first thing is clothes, shoes, clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto was-- the ghetto-- they make the ghetto in Slobodka.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "There where we used to live.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And this, what we was-- lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "What we have the furniture, too, with everything.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "You know, but we didn't move nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "But who lived in Kovno, when they got to go in the ghetto, they couldn't carry everything.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Only-- only that what you can take in your hand.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I'd-- I'd been in Slobodka.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto was in Slobodka.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "The took the whole like [NON-ENGLISH], like Decatur, you understand?",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "This is Slobodka.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And there is where they make all Slobodka.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "They make a ghetto from them.",
      "word_count": 6
    }
  ],
