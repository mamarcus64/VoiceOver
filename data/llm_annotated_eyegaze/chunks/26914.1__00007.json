{
  "stem": "26914.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Not very Jewish educated, she was with a Jewish heart.",
      "word_count": 10
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "She was a very nice lady.",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "I remember her father when he died, we were all going to the cemetery.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "She was tall.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "She just used to take care of him.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "When he went out he used to holler, [NON-ENGLISH], you didn't take the shawl!",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "But put on the hat.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 4,
      "text": "It's raining.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 5,
      "text": "It's cold.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 6,
      "text": "Otherwise, no.",
      "word_count": 2
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 7,
      "text": "But we know that they're-- were close a little.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "My best friends are two.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "One is in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "Which I am in contact with her.",
      "word_count": 7
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "There is a picture of her.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "And the other-- I had lots of friends.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 5,
      "text": "But two were very close.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 6,
      "text": "One is in Israel alive, and the other died in ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish atmosphere.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Jewish holidays, we celebrated.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "We have a teacher of dancing.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "We have a teacher of gym.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "We have a teacher of Hebrew.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "And we were very active.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "The Jewish education was very high.",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 7,
      "text": "Every morning Dr.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 8,
      "text": "Korczak used to go to the hall where we prayed in the morning.",
      "word_count": 13
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 9,
      "text": "He prayed with us together.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 10,
      "text": "So we were educated in Jewish tradition.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 11,
      "text": "We have Seders.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 12,
      "text": "We have Hanukkahs.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 13,
      "text": "All the holidays were celebrated there.",
      "word_count": 6
    }
  ],
