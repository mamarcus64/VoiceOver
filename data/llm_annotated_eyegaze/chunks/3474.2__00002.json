{
  "stem": "3474.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't walk because he was-- from the urination on top of each other, they got rashes and everything.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "They couldn't walk out.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So they just picked him up like a sack of flour, put him on, like, a shoulder, threw him in a wheelbarrow, and took him on the side there, on the side.",
      "word_count": 32
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people like that.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "If they couldn't walk, they just put them right on side.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "There was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "When-- later I seen what happened.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Who picked him up?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Just-- also [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They call them-- they could call them [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Other prisoners, Jewish prisoners.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "But they were there before.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "You know, the Polish, they were there before us.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "You know, Polish Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So they said to us-- we used to want to take something-- don't need it, take it.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Look, there's the crematoria was there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They-- that's where they burn the people.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They told you that as soon as you got off the train?",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, but we asked what that chimney was there.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "The fire was burning like crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we--",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "That was Birkenau.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "That was Birkenau.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "So we got there to Birkenau.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And people couldn't walk out-- walk down.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They just put in wheelbarrows like sack of flour, and they wheeled them over to a-- like a ditch in the side there.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "They threw them in there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Alive.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "There was fire-- and it was burning there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "Alive.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "They threw them in the fire just alive.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "They threw them alive there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And the other side was the-- the-- the crematoriums.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Whoever went to the left, like they say-- left and right, left and right.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "I happened to be in-- on-- they send me to the right.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And before-- behind me was a lady with a little baby.",
      "word_count": 11
    }
  ],
