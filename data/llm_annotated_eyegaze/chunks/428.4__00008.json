    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "She knows everything.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "She has-- this was the [? death camp ?].",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She was-- she was lucky, too-- young when she lived through that hell.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But she has the number over here on her hands, yeah.",
