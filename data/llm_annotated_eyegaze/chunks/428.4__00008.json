    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "She find out.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Now she-- and now I tell her all the things.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Because I tell her, you see this and this.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I told her everything in advance by Schindler because I was by Schindler.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "So I tell her, I'll tell her everything.",
