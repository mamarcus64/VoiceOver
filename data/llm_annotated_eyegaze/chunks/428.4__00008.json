    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "So he's going to go to the briss.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "Then I see them two, three-- two times a week.",
