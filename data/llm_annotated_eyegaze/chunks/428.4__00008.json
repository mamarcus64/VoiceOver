    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "They was by me visiting over here, too from-- she has a few friends living in Israel.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "Yeah, I still have a cousin in Israel.",
