    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "I call them, they call me.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "The kids are very close to me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Very seldom.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "She find out-- she find out-- she-- she went to-- to see She find out.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I didn't tell her that things.",
