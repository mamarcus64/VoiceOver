{
  "stem": "7282.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "But he used to come into the school.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And, and at the lecture, he used to write down on the table, I mean, on the board, some Hebrew words.",
      "word_count": 21
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "But actually, this writing, it just gave you needles, what.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "That's what I remember in, in school.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No, I do not.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I never--",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Well, my father's-- on the father's side--",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "--it was Shejman.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Because-- I know because when I, I say [NON-ENGLISH], so I remind him.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And the mother's name, the grandmother, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "I just know-- and on the mother's side, so I'm after my grandfather, Nison.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "He was called Nison.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "But grandmother, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "My mother had a sister, as I remember, in Rovno.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "This was another city, 30 kilometers from our city.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "She had a, a sister there, what, as I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And she had a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "They used to come to us once in a while.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "No, I can't.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "On my father's side, I do remember he had a stepbrother.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I do remember-- he had.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And his name was-- [PAUSES FOR 5 SECONDS] I knew-- I, I, I can't--",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "--recall it now.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "But I can't recall it.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "But I, I know he was-- we were in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "He was in Russia, on the Russian side there, all the years.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And we met them after Russia-- I mean, they took over Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "So then, the border was opened.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "So we could go to each other's house since then.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I, I knew that he has a stepbrother What-- he has-- I've been there.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Like, he had two sons.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "One, Shejman, and one [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "The stepbrother?",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The stepfather--",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "--he had sons.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "--I mean the father, yeah, had, had two--",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Two--",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "And, and, and, and, and one-- three sons.",
      "word_count": 8
    }
  ],
