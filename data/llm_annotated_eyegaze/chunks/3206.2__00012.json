  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "We-- the minute they started to shuffle around, we heard, you know, through news, which the Poles brought into the camps, that they are here, they're fighting here, they're fighting there.",
      "word_count": 31
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "The war getting closer, and closer, and closer.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "When they-- when the last minute, in that-- from Skarzysko, when they took us out, they made an appeal.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Everybody should be out from the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And they're going to send us out someplace else.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So there was-- there was-- there was one guy, an SS man, without one-- one arm, chopped off.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And one arm, he was going with a pistol.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And we were staying there.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And they were segregating.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Like, you left, you right, you left, you right.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "They took out-- you know, they-- to send us away, to different camps.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "OK, we're going to have to stop here and continue on with the story in tape three.",
      "word_count": 17
    }
  ],
