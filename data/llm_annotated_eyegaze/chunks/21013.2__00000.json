{
  "stem": "21013.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "There were placards on buildings with the excerpts of a newspaper called the which was a newspaper edited by a man by the name of Streicher, that had very, very nasty cartoons about Jews and terrible anti-Semitic slurs.",
      "word_count": 38
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And they were enlarged three stories high and pasted onto sides of buildings.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] that was really the first thing.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "Then there were all kinds of marches.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "Austria had something like 47 different political parties [BACKROUND NOISE] and they were always having marches and torchlight parades and things like that.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And of course, [PAUSES FOR 4 SECONDS] during the civil war, the various factions were actually shooting at each other and we had martial law.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And we were locked into our apartments and couldn't get out.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And we didn't have any water.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We didn't have any electricity.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I mean-- then they burnt the Palace of Justice down.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I mean, it-- it was constant strife.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I don't know all the dates anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "But I would say from 1934 on.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, we heard a lot about it, but it was all rumors.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We didn't really know as much as we should have known or-- we read a lot in the paper.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And we didn't believe it.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "We didn't want to believe it.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We heard about-- German Jewish refugees came into Austria and told stories.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "And we felt sorry for them and my father donated money toward them and all that.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "But we didn't believe that anything could happen like the death camps.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "We really didn't believe that.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "We heard about people getting shoeboxes full of ashes from their relatives.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And of course, after Hitler came, my uncles were arrested.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "My father had to constantly hide.",
      "word_count": 6
    }
  ],
