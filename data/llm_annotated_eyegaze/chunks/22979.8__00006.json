{
  "stem": "22979.8",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "He was living in Prague at this time.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And I-- he brought me photographs to identify from the photographs, from the [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And I did.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "But the main thing how I got as a witness in Vienna-- our good friends, Fred's and mine, two our friends who were three years in the camp, both, like we, Fred and me.",
      "word_count": 34
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And their wives were also three years in Auschwitz, from Presov.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And they were living in Presov, immigrated in 1965 to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "But they still lived there.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "They went in and out to Vienna.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And when they came to Vienna, they went to a restaurant.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And somebody came to them and said, in German, Alex, you know, [GERMAN].",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Oh, [SPEAKING GERMAN]?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And he turned around.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was the SS guard from Auschwitz, owning this huge, beautiful restaurant.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "He went to Simon Wiesenthal.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And he reported them.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And he said, also, survivors from Auschwitz mentioned my name, Fred's name.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And so when we are--",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Bratislava.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Half an hour from Vienna, we were living.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And so they called me, but they called witnesses from the registry from all over the world.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "So in 1972, we were already in America.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Hans Wunsch and Otto Graff.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "They both were guards-- SS guards in the working place where I was three years.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And I went to the trial from America already.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And at the trial, you know, when I was on the witness stand, the judge asked me, do you know?",
      "word_count": 20
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Both were the same time there, Hans Wunsch and Otto Graff.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And I point at them, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And then the judge-- because I was s speaking in German at the trial.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "They didn't need any translator.",
      "word_count": 5
    }
  ],
