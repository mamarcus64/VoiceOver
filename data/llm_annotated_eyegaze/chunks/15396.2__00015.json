  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And then she said, well, look, I think you had better go up to-- I shouldn't be saying this, because after all her husband was an ambassador.",
      "word_count": 27
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "You'd better go up to the-- to a Porto in the North and go to the consulate.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "And I'll phone them and tell them you're coming.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "And that way, you can-- they won't know about the one down there.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "You can't imagine how she helped us, and all.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "And that's where I took the girl that I had-- you know, the singer.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    }
  ],
