{
  "stem": "766.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "From hour to hour, from day to day.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I suffered additional.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "Because, you know, this trauma for me, I got married to a man who was the man for me and all of a sudden after two months disappeared.",
      "word_count": 28
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And I remember the one word to two words which I said to him before he left.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "I will be waiting for you all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "And two days later, I was out from this place.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "But I got letters from him.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In the ghetto, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "He was released-- he was a prisoner of war.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "But later, they got rid of him.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "They sent him to the periphery of Poland, more to the east side.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And he knew the city, they found me somehow-- they found me.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And I got from him letters.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "And I remember there was a woman.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "I found out that in the same city where he was had a sister of hers, and the husband was a doctor.",
      "word_count": 22
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "So I met this woman.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "I said, you know, I will help you here.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And you write to your sister.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "She should help.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "He was a doctor over there-- healthwise or other advice, to let them sit with them.",
      "word_count": 16
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "And they paid us in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "So I helped this woman, and they helped my husband over there so that I knew a little bit.",
      "word_count": 19
    }
  ],
