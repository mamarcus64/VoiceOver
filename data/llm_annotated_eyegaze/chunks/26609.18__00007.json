{
  "stem": "26609.18",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I tell you what.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "She said, your husband took her from me.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "She was in a orphanage.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "I said, the orphanage, I have heard here from the other lady in Kudowa.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "Yes, he took her from the orphanage.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "He came to the orphan-- took her out from the orphanage.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "That's not true.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And we don't know now.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "He had a [? system, ?] [INAUDIBLE] and United States.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "He could go to United States or to-- to America.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "Now search for her.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "I said, I don't believe it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "I don't feel it.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "It's not true.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "My husband's not alive.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "I knew it before.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "I know it.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "He's not alive.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "He was as an officer in the Russian Army, and there was very-- [?",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "Katinga, ?] a very know, very well-known place, [?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "Katinga ?] what was the name, that the Germans killed without-- anything Polish, not Jewish.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "He was not as a Jew.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "He was as a Pole.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "They killed them all.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "So I didn't believe that, too.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "I know that he wanted to jump off a-- a Pole told me, I told you, from a train, and they shot him.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So she said, it doesn't matter, but we know that your husband took her.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I said, describe me her husband-- my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Oh, he was very dark, very thin.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "So I said, my husband was very fair.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He was-- he had blue eyes, very fair, not very thin at all.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It's not my husband.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "So she said, yes, in such a world, a blond one can get black.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "So I said, it's-- it's no time for jokes.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Tell me where she is now.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "We told you, in search Israel or United States.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "There where she can be, because he took it from that orphanage and left with her.",
      "word_count": 16
    }
  ],
