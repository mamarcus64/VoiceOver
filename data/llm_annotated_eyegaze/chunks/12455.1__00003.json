{
  "stem": "12455.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They told us to get dressed and go outside.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They round up all the Jews from town.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And they put us in a large building like a-- where soldiers are-- like a--",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Armory, exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And after they round up all the Jews, they started to sort out professionals.",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "By that-- what I mean by that is tailors, shoemakers, and young children up to a certain age.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And they let us go.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And the rest of them, they killed all in one day.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] So when they let me go, I was left by myself.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] They were led to the woods.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And there was a grave dug-- massive graves dug.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And they were killed.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And they were--",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I heard the shots.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "And they never came back.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And we were told that's what happened to them.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "The-- after I was let go, I stayed with one of my neighbors.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "He was a tailor.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "So they let him go and his whole family.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And that's what they talked about.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I never had a chance to go to the grave.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "But this is what we were told.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And we heard shots.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "My family and all the rest of the Jewish people in my town.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "That was August 25, 1941.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I stayed with my neighbor until they decided to round up all the professionals and children and kill them, too.",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "So when they came in to-- to the man that I stayed with, and they told them to go outside, I hid in back of a door.",
      "word_count": 27
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And they didn't see me.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "So after they left, I went-- I crawled on top of the attic in the house.",
      "word_count": 16
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And I stayed there for a day and a half.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I was petrified.",
      "word_count": 3
    }
  ],
