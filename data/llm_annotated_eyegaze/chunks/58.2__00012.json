{
  "stem": "58.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "My sister was there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "The parents were there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And I said to my parents, I'm going back to Warsaw where my sisters are working.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "I have nowhere else to go.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "My mother says she wants to go with me.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "I say the same thing like you went to the village.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "You're just going to hold me back, because it's 77 kilometers.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "It's not easy for a middle-aged woman to walk.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "Well, I talked her out of it.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "Besides, it was dangerous for me to cross the bridge.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "There was guards on the bridge and they doubled the guard.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "I sat there-- not far away-- I knew a person there, and I was sitting at their house until the guard changed.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "While the guard changed, I went through the bridge.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "And I walked in to a village 4 kilometers before Grojec that we-- my father used to rent orchards from the guy.",
      "word_count": 22
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "And I called him by the name, and I told him who I am.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "He says, look.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 23,
      "text": "He says, I know you're Sana's son.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 24,
      "text": "I recognize you.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 25,
      "text": "You see, I have six people working-- we just picking the grain from the fields.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "I could keep you only over the night.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "I say, that's all I need.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "But you have to sleep in the other side from the-- from those people, because if they knew you're Jewish, they'll take you to the German like it's night now.",
      "word_count": 30
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 29,
      "text": "Well, I went to sleep, and I slept through the night. 4 o'clock, he woke me up in the morning.",
      "word_count": 20
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 30,
      "text": "He brought me a half a bread.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 31,
      "text": "They usually bake their own bread-- the farmers.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 32,
      "text": "He said, may God be with you, in Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 33,
      "text": "And I left.",
      "word_count": 3
    }
  ],
