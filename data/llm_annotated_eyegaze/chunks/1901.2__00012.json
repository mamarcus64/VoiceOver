{
  "stem": "1901.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 309.5,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "There were prostitutes in camp.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "They were mainly Polish girls.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They made them-- I don't know if there were Jewish girls amongst them, I can't tell you.",
      "word_count": 17
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And-- and they entertained them, but non-Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "Say, Polish prisoners, if they worked well.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "They're getting certificates.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And when they had enough, four or five, they could go to the [?",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "Puff. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Never heard that?",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Puff. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it was.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "And-- and we called it a [?",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Puff. ?] It was like a-- a brothel.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "For the-- not for the Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Only for the Polish prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "And where the girls came from, I don't know.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "I never had contact with any of them.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Seen them, when the Germans entertained them.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "You know, they-- healthy, young, but who they were, I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "I don't know what happened to them.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "Maybe gypsies, there were a lot of gypsies in camp, too.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "You see, we had such a mixture of concentration camp people.",
      "word_count": 11
    }
  ],
