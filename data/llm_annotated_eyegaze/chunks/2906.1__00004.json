{
  "stem": "2906.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And Friday morning, when they used to work in Rowne-- because they used to work all over Poland-- they used to come in every Friday.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "My mother used to bake pancakes, and make like cookies. 10 used to come in and finish eating, used to walk out and another 10 used to come and sit and eat.",
      "word_count": 32
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And then, for Christmas, my father used to buy them presents.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And they used to come and say, Shymon, you're the best boss on everybody.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So and then, when Hitler came, my father was hiding because they start killing everybody.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The same good friends went and they show Hitler where my father was.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And they took and they killed him.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "When you were growing up in Rowne, did you experience any anti-semitism in school?",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Public school?",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In school, the-- the teachers-- they were-- they used to-- my father was very good looking.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "He was tall and dark and handsome.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "She-- my teacher used to say, your father doesn't look Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "This was the only thing they said.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "He was Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But otherwise, no.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We were-- you know, it was a teacher and children.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And-- the thing is that we were playing.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "So the other kids, if they can beat up a Jewish kid, they will beat him up.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, this one thing where my-- where my brother went and they was run after him, and want to beat him up.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And one time where my uncle used to live, next door was Gentile people.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And somebody came with a wagon, and accidentally the wagon went in the other side.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And they came out with big sticks, and they beat up this man.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And he was bleeding, and they had to take him to the hospital.",
      "word_count": 13
    }
  ],
