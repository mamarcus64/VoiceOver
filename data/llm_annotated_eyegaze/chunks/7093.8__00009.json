{
  "stem": "7093.8",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 52,
      "text": "And  my heart broke, because I was really-- I was just starting to get onto my feet in Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 53,
      "text": "And so I didn't go back.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 54,
      "text": "I got a-- and then my, my permanent residence permit came through.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 55,
      "text": "And I could work.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 56,
      "text": "And I got a job at the nursery school, at the Jewish nursery school in Durban.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 57,
      "text": "And I started building up things.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 58,
      "text": "And my husband-- and we got together.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 59,
      "text": "We didn't live together really.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 60,
      "text": "But we moved together.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 61,
      "text": "We were in the same-- I run his household.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 62,
      "text": "And, and the child was-- the child had parents.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 63,
      "text": "And then I-- and I was working as a nursery school teacher.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 64,
      "text": "And eventually, I was asked to go and help out at the infant school.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 65,
      "text": "And then I was asked to stay at the infant school.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 66,
      "text": "And from there, I was kicked up to do-- actually, up to A level standard, which I didn't want to d.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 67,
      "text": "Because I said, well I haven't done mine.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 68,
      "text": "I haven't got my A levels.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "So the headmaster said, why don't you do it?",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I'm hopeless at exams.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And my two pupils who were-- who were-- who learned everything from me came out with honors.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And I managed to scrape through, which is-- and then I-- but I was-- I didn't want to stay in South Africa.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't stand the apartheid.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't like to be in South Africa.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I just didn't want to be in South Africa.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And so we tried, but we didn't-- couldn't get out.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "We had no papers.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "We could get out of-- I had in between a Hungarian passport for one year.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But it was a false passport.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I can't tell.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "It's too long to tell the story how I got it.",
      "word_count": 11
    }
  ],
