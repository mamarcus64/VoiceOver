{
  "stem": "6277.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And some of them-- he didn't find my father.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "But others he found, and was taken away.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "In the first days, most of the men from our house were taken away to the main or central jail.",
      "word_count": 20
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Also, my friend-- my best friend, Yakob, also, [INAUDIBLE] was taken.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "My uncle, Gutman Feld, and many, many others, friend and neighbors.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "My father was hidden.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "But they couldn't leave-- they couldn't leave the apartment now, well, not to take somebody.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So he was looking to me, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I was 13 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "My bar mitzvah was when the Russians were in Riga.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "It was the last simcha, the last-- the last holidays, what we celebrated, or last celebration in our house.",
      "word_count": 19
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And so he looked at me and asked different questions to ridicule me.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And he didn't know what to do.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "So he took Mother.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "He took my mother.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "But they didn't take her to the-- to the jail, but took her to the headquarters of the police in Riga, on Aspazijas Bulvaris.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And there she witnessed what was going on there.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "They were drunk, celebrating there.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "They ridiculed the Jewish people who were there, beating them up.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "There was also taken, our landlord, Milbitzki.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] They stripped him naked, put on his head a Russian Army hat.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "And he had to sing Russian songs in front of all of them.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "Girls were raped.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "There was a cry-- [PAUSES FOR 3 SECONDS] --going on.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
