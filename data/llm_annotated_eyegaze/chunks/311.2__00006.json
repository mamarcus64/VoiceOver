{
  "stem": "311.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "You know, the-- the thread.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Buttons are all right, it wasn't such-- and this-- they took whatever they wanted.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "They left the stores open.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And then the crowd goes in, and start throwing out all this stuff.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They load themselves up.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "They take whatever is left.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And this goes on for twenty-- the stores were loaded.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "You know, there was a lot of merchandise.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "Everybody was loaded.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't have store.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was a factory-- locked up everything.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I mean it was-- 90% of our work, my father sent it up, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "It came in in the season.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Like the-- what do we need-- what are we going to do with all those Poles?",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Where are we going to keep them-- you know, pay them?",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't the Soviet Union yet.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "They went-- they went-- the Germans on this side, the Russians on this side.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So everybody went east.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "That side-- you know?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They went east.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, the Germans had to open up.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "The Polacks wouldn't open up.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But what are the Germans going to do with it?",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "They need a certain amount of something, they open up the store, and they have a lot of fun, you know-- and then the Polacks come in.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Some of the stores-- they close in.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "You know, there was a store, you know, near our house where we used to live, the [NON-ENGLISH] 45.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "There was like a little mall, 11 stores.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "They called it the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And there was-- there was like a sort of-- it was a jeweler's store, a perfume store.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "There were two shoe stores.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "There was a bra store.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Those stores-- you know, when came at night the housekeeper-- you know, from the house-- used to close it in the front.",
      "word_count": 22
    }
  ],
