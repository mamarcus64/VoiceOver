{
  "stem": "17374.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 302.6,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Romek ?] [POLISH], got four other brothers, they went somewhere to-- [? further. ?] They didn't go to ghetto.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Only he comes to ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Romek, ?] one of the boys-- there was five of them.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "And he came to ghetto because of me.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "That's what he told me.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "And a few of the-- one of my uncle went.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And my father didn't want to go, I think, in the beginning.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "But he went to ghetto as well.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "It was such a time, indecision.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "You didn't know what, what to do with themselves.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "People didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "At this time, they didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "But my sister was insisting that we go with the others to Jewish, with Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "How old was I at the time?",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Still 17 or 18, 17, 18.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my sister was 10 years older than I.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Yes, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "My brother was seven years older.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "I was [? the younger. ?] Actually, I, I shouldn't be born, because my, my mother was going for an abortion when she was pregnant with me.",
      "word_count": 27
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "That, I heard from my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "She told me the story.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "They didn't want-- it was such a big difference.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "And they just-- but somebody told her, no, have a baby.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "It will be happy.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "And I was born.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "But I knew, all the time, [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "My father was disappointed.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 12,
      "text": "He wanted to have a boy.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 13,
      "text": "And when I was young, I have short hair, always.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 14,
      "text": "And I was riding on a horse.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 15,
      "text": "He wanted a boy.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 16,
      "text": "But in the end, he find out that he got more naches from the girl than the boy.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 17,
      "text": "My, my brother was a naughty boy.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Many wrong thing, many wrong thing-- my mother was always upset.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "My mother was crying.",
      "word_count": 4
    }
  ],
