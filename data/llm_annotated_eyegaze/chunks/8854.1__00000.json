  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Freda Weiss.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Maiden name is [?",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Frima. ?] They used to call me [?",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Frima ?] Marcus.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Yiddish, I'm [?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Frimad. ?] In the Romanian school I was [?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Frima ?] Marcus.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is April 18, 1920.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "75.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I'm born in Ruskova.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "In Romania they called it Ruskova.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "R-U-S-K-O-V-A.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "This is in Maramures.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "M-A-R-A-M-U-R-E-S.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was one six children by my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My father's name was Mayer Marcus.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "My mother's name is Rose [?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Yankowitz. ?] They were very, very good people.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My mother wasn't only a mother for me, but she was just like a friend for me.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We weren't very rich at home.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "But we had a very nice agricultural place, which we raised cows and chicken and gooses, and all kind of those things.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We had 200 apple trees in our garden.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "The house was located in the garden, surrounded by trees, all kind of apples.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "I could tell you the names, even.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "There was [?",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Gold, ?] [INAUDIBLE], Macintosh, Jonathan, and many, many more other names.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And in the garden we had-- my father, [?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "[YIDDISH], ?] he were very, very handy in the agricultural things.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He built a house between the trees for bees.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He raised bees to make honey.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He said there is the apples and there is good children, like I have.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "There should be sweetness also.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "There is honey, good.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So he raised a bunch of bees, about 100 families.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And he built a house for them.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Between the trees there was that.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Beautiful.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "People used to come from all over to admire our garden, our honey house, and our bee house.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And we had [? meters ?] of honey.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "And this, from what we made a living.",
      "word_count": 8
    }
  ],
