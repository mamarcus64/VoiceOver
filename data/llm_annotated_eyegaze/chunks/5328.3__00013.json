{
  "stem": "5328.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "So I said, I'm looking for a person that I know only the name.",
      "word_count": 14
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "They said, what's the name?",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I said, [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Who are you, she asked me.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I said, I am his cousin, from Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "And I described the relationship.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "So she said, you wait here.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "In another 10 minutes, he come here for lunch.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "It was before 12 o'clock.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "Another 10 minutes, he'll come here for lunch.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "And that's the way it was.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "On a motorcycle, he comes in.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "And she-- she said to him-- And who was she?",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "She was the sister of his wife.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS] It's all miracles.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And he came in, and she introduced me to him.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And he said he was working in-- in Petah Tikva [SPEAKING HEBREW].",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "That means in the-- in the office from-- from working compensation.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "He was the manager there.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "So he had a big, big job, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "He was well-known.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "So he said to me, oh, my-- my cousin will not stay in the-- in the camps, in the transport.",
      "word_count": 20
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "And came-- where is your husband and your child?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "I said, he's in Ra'anana.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "So they put me down on the motorcycle.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "We went right away to Ra'anana-- picked up my husband and my baby.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "He took us to the house, to his house, and we stayed a couple weeks.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "I-- myself and my daughter, my baby, we stayed in his house.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 10,
      "text": "And my-- my husband-- he didn't have so much space.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 11,
      "text": "He had very little space.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 12,
      "text": "So he put him in a-- in a ma'abarot, in a-- boy, how do you say it?",
      "word_count": 17
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 13,
      "text": "Where, [SPEAKING HEBREW]-- this-- where a lot of people, homeless, are living.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 14,
      "text": "But-- A shelter?",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "A shelter.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "In a shelter.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "So he put him there.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And-- and we stayed for two weeks.",
      "word_count": 7
    }
  ],
