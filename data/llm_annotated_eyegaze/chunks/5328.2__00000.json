{
  "stem": "5328.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, we used to go out-- my mother and myself, we used to go out through the back of the ghetto and go to the farmers and exchange for clothing.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They use to take clothing from us and they'd give us some bread and milk and flour and [INAUDIBLE], you know, [INAUDIBLE] the farmers have.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Also, we used to have some sodas.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They were short of soda, baking soda.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "So we used to give them some baking soda, and they'll give us all the food from the farmers.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And we really in the ghetto, because of that, we didn't have any-- we were filled with food.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "We had enough food.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Some other people didn't but we did.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we-- we-- in the ghetto we could take all the clothing we had.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "It's the-- and the furniture too-- as much as we-- was the-- it fit in in the room that you had.",
      "word_count": 21
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We could take everything we had.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Sure, it was dangerous.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But we weren't caught.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "If we were be caught, we wouldn't be-- we would-- they would shoot on us.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But we weren't caught.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We-- we-- we survived that way.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "It was dangerous.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was hiding my patch not to be seen.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Because, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I put it under my clothes, a shawl over it.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "So I had my patch in case of something, I have it.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But I hide it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I put a shawl over it so they wouldn't see it.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "No, there were no schools.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Soon the Germans took over, all the schools were closed.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "There's nothing anymore.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "No-- nobody even thought about it because we were so much occupied by staying alive to-- to rescue ourself that this was already a minor thing to go to school.",
      "word_count": 30
    }
  ],
