    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Not a lot of people speak German.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And take me out in center city near Krakowskie Przedmiescie Street, was called Krakowskie.",
