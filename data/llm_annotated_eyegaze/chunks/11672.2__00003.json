      "text": "You can go in.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And you can go out of the hospital, the [NON-ENGLISH] now in Polish.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And my mind work so fast.",
