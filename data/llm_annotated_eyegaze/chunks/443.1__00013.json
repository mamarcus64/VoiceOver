  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And we waited till the siren was called that it's over, then we went back to the-- to the barracks.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "This was going only for a couple of weeks because then they evacuated us.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Well, when they start to evacuate us, that's when the real trouble started.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "People were freezing to death.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Like I told you before, we all had only pajamas on.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "It was 20, 30 below zero, so you can imagine how cold it was.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Today, you would probably put on underwear and a-- and a jacket, and undershirts, and a winter coat, and we only had the pajamas.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And by the time we arrived somewhere, it was like one third was less.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And if someone sat down, they said they don't want to walk no more, they just give him a bullet, that's all.",
      "word_count": 22
    }
  ],
