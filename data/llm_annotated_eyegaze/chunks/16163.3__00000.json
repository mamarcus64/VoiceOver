{
  "stem": "16163.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "No, I only can say that when we got back to my house, everything was like, at that particular time, there is-- were the stormtroopers, and the Germans were there to destroy the houses.",
      "word_count": 34
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And my mother got me and my grandmother and Mrs.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Katz, Gunter's mother and the two boys, and we started walking towards another town.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And on the way there, she ran into a farm.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "There were like farmlands around there.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And asked the farmer if she could make a phone call to Herford to my father in the factory, let them know what-- wanted to ask him what to do.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So she got my father.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They called him on the phone.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And my father told him we should stay there.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "We were outside, and my mother was in the farm.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "She should stay there for a few minutes.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "She's-- he's trying to get somebody, to call somebody and get his advice.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He had a Christian man who was in some kind of a office in Herford, which had to do with the veterans of 1914-'18.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "So he must have been a friend of my father.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I forgot the name.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And my father called him and called my mother back over there that we should try to get to Herford and go to that particular office.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And he will be there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "My father would be there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "So it took us like at least four, six hours to get there.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "First we had to walk to the town where we could get the train and then, et cetera, et cetera.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "But anyway, we got to that office.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "My father was there.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And he closed off the office and told us not to leave.",
      "word_count": 12
    }
  ],
