{
  "stem": "8352.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "We had a lot of lice on our body.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "The buys-- the lice were crawling all over us, sucking our blood, what we had left in our body.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "We never took showers.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "They gave us little soaps to wash our hands sometime.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "On the soaps were three initials, J-R-F.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "And we found out that those soaps are made of the-- [PAUSES FOR 5 SECONDS] Rein Juden Fett, right-- of the fat of the bodies, what they were cremating.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "We didn't want to use those soaps.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "We just throw it away.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "[PAUSES FOR 4 SECONDS] We were-- maybe in the whole time were were in the camp, we had-- maybe they took us out to take one or two showers in the whole time.",
      "word_count": 33
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "No change in clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "And we were just eaten up by the lice.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "They were crawlin' all over us.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We survive somehow.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "In 1945, around April, whatever was left in that camp, they put us together.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They put us on trains and were takin' us who knows where?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] But we went on those trains, in those wagons.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] The Americans bombarded the railroad, quite far ahead of the train.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We could see it.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "The train slowed down.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They told us to jump out of the train, of the wagons, and run in, in a little forest there.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Some people got killed jumping out from there.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Some people could run.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "They surrounded.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And we were in that forest.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "The train kept on going slowly.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "They surrounded that forest.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And they gathered us together again.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Next to me was a dead bird.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "I grabbed that bird and I ate it up.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "I was glad I had something to eat on.",
      "word_count": 9
    }
  ],
