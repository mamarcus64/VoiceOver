{
  "stem": "5626.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "But life had to go on.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 31,
      "text": "We were pushed, the guard at the door.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 32,
      "text": "One guard inside was sitting next to a fan, cooling himself.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 33,
      "text": "And we were just doing it one after the other.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 34,
      "text": "After the time we left the work, we all had to lift up the big leather apron.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 35,
      "text": "And one guy from the back side of the oven shoveled ashes into our apron, which we had to go outside and spread it on the mud.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 36,
      "text": "So where the German soldiers had their so-called officers, when they come into the workshop, they didn't have to walk through with the shiny boot through the mud.",
      "word_count": 28
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 37,
      "text": "That was our job.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 38,
      "text": "We found out that the group who were working before us, they started on the same day.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 39,
      "text": "And they were told that they will work over there 10 days, and they will get an assignment.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 40,
      "text": "The eighth day came, and we started to pray.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 41,
      "text": "Whatever, whoever could say, we were praying.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 42,
      "text": "And that's how we marched to the work.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 43,
      "text": "That was the best day of our working days over there because we passed by a wagon which was full of bread.",
      "word_count": 22
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 44,
      "text": "And we stole the bread, even though we know that for a potato peel, you will get shot.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 45,
      "text": "But we stole the bread.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 46,
      "text": "And we ate.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 47,
      "text": "And we went to the work.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 48,
      "text": "That helped us going through the day.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The ninth day, we finished the work.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And we went home.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We were in a mud floor tent.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Big commotion in the tent-- what's going on?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Rush, rush.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "[GERMAN].",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Didn't know where, what-- they chased out from the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "That was the fastest three day run I ever did in my life.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "That was on the end of April-- 20-- 24, 25, and 26th of April.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Of what year?",
      "word_count": 3
    }
  ],
