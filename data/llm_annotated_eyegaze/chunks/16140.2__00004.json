{
  "stem": "16140.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "I was talking to him and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "And then when I was in Germany after the war, I read the paper that Boris Lebdavidov got kill, in Berlin.",
      "word_count": 21
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "He liberated Berlin.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "And he got killed.",
      "word_count": 4
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "Because in 1939, the Russians took over the part of Poland that I was living in.",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "I was going to a Russian school.",
      "word_count": 7
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to grade seven.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "And then I was a year in gymnasium.",
      "word_count": 8
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And then I was-- then I made exams for grade 9 and 10, and then I had one year university.",
      "word_count": 20
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Russian literature.",
      "word_count": 2
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "A teacher.",
      "word_count": 2
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Literature.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "No I wasn't studying any more, just in Russia this-- this [INAUDIBLE] that I was going.",
      "word_count": 16
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "And my uncle.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "My mother had two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "They both survived the war.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And my uncle survived the war.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "He was in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "He was in a hide out at the Polish farmer's place.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "You just preferred not to be in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] In the woods was a very hard life.",
      "word_count": 12
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "We had no choice.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Then there was a war between the Ukrainian and Polish people.",
      "word_count": 15
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "So the Polish people left for Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "The Ukrainian people stayed right there.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "While the war was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Ukrainian and Polish were fighting.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "It had nothing to do with us.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "The Polish people wanted us to come with them and to cross the river and go over to-- on the Russian side.",
      "word_count": 22
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "But we were afraid to go with them.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "Maybe some of the Polish people will give us out.",
      "word_count": 10
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Because there were all kinds of Polish people.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Oh, around the 11, 12-- 12 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was living in Tuczyn.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I was going to university, and then I came back to Tuzcyn.",
      "word_count": 12
    }
  ],
