{
  "stem": "3022.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "I think she paid a lot of money and she came by bus or something from the town of Bielsko and told us about what was happening-- how the Germans were treating the young Jewish men, about the shootings and the killings in the town, and about the fact that so many of our friends and acquaintances all of a sudden declared themselves to be German in that town.",
      "word_count": 69
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "And there was a council of all my aunts, and the decision was made that the young men shall flee.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "So myself and three of my cousins, two of whom were approximately my age.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "One was 10 weeks older.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "One was a year older.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "One was several years older.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "He already had served in the Polish Army.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "We decided to flee the town of Cracow.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "My father was still in the town of Bielsko.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "He tried to liquidate and realize whatever he could from whatever possessions we had.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "And we started out from the town of Cracow.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "We marched on foot toward Sandomierz and then towards central part of Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "The scene on the highways of Poland was indescribable at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "There was a multitude of people with whatever means of transportation they could put together-- the push carts, horses, bicycles, some very few cars.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "And everything was moving.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 46,
      "text": "They was leaving from, from-- going east, trying to escape the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 47,
      "text": "We were strifed and bombed by Germans' airplanes on the, on the roadsides.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 48,
      "text": "At night we used-- we to-- we used to try to stay with Jewish families, find lodging with Jewish families.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 49,
      "text": "Before the war, I refused to speak Yiddish because I considered it the language of diaspora.",
      "word_count": 16
    }
  ],
