{
  "stem": "18061.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 61.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "He was inside with us, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No I wouldn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Then we went home.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And we started to build up a little bit of our-- our life.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I went back to work.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And everything was like little bit normal.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My mother was back home, and my brother was back home.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "My little brother was also back.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And we started to live by day by day.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And the life was very, very hard because money we didn't have.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And the prices started to rise, like a bread.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We paid for a bread $0.50 or $1 for 2 pound.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "It grew to about $3, $4.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "It was very hard, that time.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Oh, later on, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Later on, should I say, you know, few weeks later was an order.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Jewish people can go out up till-- excuse me-- up to 7 o'clock.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You got to be inside between 7:00 and 7:00 in the morning.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They couldn't go out.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Any-- anyway, any place, they couldn't leave the houses, not even emergency.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "All that was, oh, little by little was going on like that.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And then come deference orders.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Deference orders means like taking out Jewish people from better apartments and giving away to Volksdeutsche, which Volksdeutsche means people who lived in Poland, and their great-great-grandparents used to be Germans.",
      "word_count": 31
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "They called them Volksdeutsche.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "All they took the apartment for themself.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "Or they give those good apartments for Polish people, which they work together with the Nazis.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And it was like every day was worst and worst because they cordoned off the Jewish people.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "It wasn't a ghetto yet.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "[INAUDIBLE] so a high number of Jewish people, which they came in the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "You got to leave, take in five minutes whatever you can, and out.",
      "word_count": 13
    }
  ],
