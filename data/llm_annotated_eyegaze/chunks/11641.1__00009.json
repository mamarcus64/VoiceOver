{
  "stem": "11641.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "The whole family, to live there in one room.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And we lived by selling our clothing.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "My mother brought clothing.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You, you, you sell your clothing.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "You get wheat, or you get flour, you know, to bake your own bread, all those things.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And we went to-- to live there.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "He had a farm.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "My uncle had a farm.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "He had a house, and he had also many children.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "We lived in one bedroom, and he rented sort of part of a dining room for us.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "We made a separation, sort of.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And we lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And, and eventually, we made a living going to town-- was Wisnicz Nowy, where Sally comes from.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "And we were cutting wood, all three of us-- my father, my brother, and I-- to cut wood for, for inhabitants of Wisnicz Nowy.",
      "word_count": 24
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "Let's say you cut wood in large pieces, then you cut into small pieces.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And that's how we made a living at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And also, the Hasidic Jews-- let's say, the order was from-- from the German government to the Jewish community that they want to have, every day, x amount of people to work for them.",
      "word_count": 34
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "So you rented yourself out for them who didn't want to go.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "They paid you, and you went instead.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "To me, it didn't matter, because I spoke the perfect German, and my brother-- my brother, also.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "And we rented out.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "And we-- you know, that's how we made a living, also.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "1939.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I was 18.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "My brother was 16.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And that's how I met Sally over there.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I-- all kinds.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "We were picking strawberries.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We were cutting wood.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "We were-- some kind of other manual labor.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "At one time, because I spoke German, so he took a few people.",
      "word_count": 13
    }
  ],
