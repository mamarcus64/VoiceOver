  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And when I went there, it was about 1958, 1960 the first time-- 1958.",
      "word_count": 14
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "And I been told by the-- I told the people that's, that's a very important thing.",
      "word_count": 16
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I said, he did have a child of about a year, a boy.",
      "word_count": 13
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 7,
      "text": "And I made a mistake because the child could be already 12-year-old or 15-year-old.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Or whatever it is in 1958.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "But I made a mistake.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "And I couldn't find the people.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "When?",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "When I--",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "After the war?",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "I told myself knowing the people there and being with them and trying to do something, that I been in Warsaw in my place during the war.",
      "word_count": 27
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "So I told myself, I'll have a look.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And I'll see what is happening to them.",
      "word_count": 8
    }
  ],
