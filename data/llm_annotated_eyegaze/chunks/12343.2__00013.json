{
  "stem": "12343.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "We can't do faster.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "I was too mad to run away.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "Run away, he kill me.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And then he run after me-- he run after me.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "I run to the factory, the Jewish working there, through the factory, run out the factory.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "And they ask the factory, you see this-- they didn't know me everybody.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "He said, we don't know if seen nobody.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "Cannot catch me.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "I run a-- a toilet.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "I sleep all night in toilet, and I was afraid tomorrow to go to-- to go back to the-- the camp.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "I was afraid that he did it.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "This [? work ?] not good.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "Was all [INAUDIBLE] good.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "I was-- I rescued myself.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "That-- that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "I cannot stand it no more.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 24,
      "text": "Kill, that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 25,
      "text": "They never going to [? kill him. ?] Everybody knows me over in the lager.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 26,
      "text": "Everybody.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 27,
      "text": "Because I did good, very [? bad. ?] [INAUDIBLE] I do good.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 28,
      "text": "The same thing then what's happened.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 29,
      "text": "Oh boy.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 30,
      "text": "Oh boy!",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 31,
      "text": "I have to remember everything.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 32,
      "text": "This is in the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 33,
      "text": "I got a history.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 34,
      "text": "I can never [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 35,
      "text": "My children don't like for me to tell them this.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 36,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 37,
      "text": "This-- there I make it from that.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 38,
      "text": "I walk-- I walk over there until I-- until they take me away from there.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 39,
      "text": "One time-- and over there, in the same camp was a lot of people not far from our city-- [INAUDIBLE], [INAUDIBLE], name it.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 40,
      "text": "They take the little towns.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 41,
      "text": "They know me, everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 42,
      "text": "I used to go over there to barber.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 43,
      "text": "Some people, they don't like it.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 44,
      "text": "People who come from Majdanek to this later, they don't like it.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 45,
      "text": "The Jewish don't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 46,
      "text": "They call the Majdanek, they call them with names.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 47,
      "text": "They don't call me because I don't know.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 48,
      "text": "They like me.",
      "word_count": 3
    }
  ],
