  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So this was my closeness to the ghetto at the time of the uprising.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Later on, the two people who came into my own apartment, this was [POLISH] and [POLISH], they got out from the ghetto May 8 and they came up.",
      "word_count": 28
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They knew my address, they knew in the ghetto where I lived.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they somehow came through the sewers through the ghetto-- from the ghetto [INAUDIBLE] side for help.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "It was a hectic time how to get help.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't organize it right away.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Somehow after a while, we succeeded to organize somebody who walks or knew the sewers for money.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And they also organized two trucks which came to a place near the opening of the sewers.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And this was the place where 60 ghetto fighters later on got out from the ghetto into the woods.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "The majority of them got killed in the woods.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "A few survived.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It's enough.",
      "word_count": 2
    }
  ],
