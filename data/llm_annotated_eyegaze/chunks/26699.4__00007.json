  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 27,
      "text": "And in August, 1969, the Russian troops occupied Czechoslovakia.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 28,
      "text": "We, in Romania, felt very insecure, because Romania took, at that time, the side of Czechoslovakia.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 29,
      "text": "And we were scared that the Russians will do to Romania what they did to Czechoslovakia, a full occupation.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 30,
      "text": "But it didn't happen.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So a year passed.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And then, I planned my escape from Romania.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "There were already 12 years since I applied for my immigration with all the frustrations, and the demotions, and ill-treatment, and blackmail.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So I decided to take my life in my hands and to escape from this big jail.",
      "word_count": 17
    }
  ],
