{
  "stem": "21004.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "But before that-- before that, to describe, before we went out about three years ago-- three years before we moved out, my mother moved out to Krakow, we had a problem when we went on a-- to [NON-ENGLISH].",
      "word_count": 38
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "We went to the other village, to my uncle.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "We went to [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Mom locked up the house and we went there.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "She had a lot of jewelry from my grandma and, you know, a lot of jewelry.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "She had a chain, gold chain, going three, four times around, my father's jewelry, diamond rings, and all of that.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Some of them she put on on herself.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And a lot of them, she left a whole package, which a lot are my father's jewelry, gold watches and all that.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And so she left it in a place, in a hiding place.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "But they broke in.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Somebody broke in through the back door.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "They came, broke in.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And they took out all that.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "The whole package they found, the jewelry and also money we had.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And we were selling cigarettes.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "We were selling cigarettes, because my mother was a widow, so she allowed.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "And this was our government.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "Not everybody could sell cigarettes or liquor, only a widow or a widower, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "So-- and then we came back.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "He opened up in the front door and he came in.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "We saw the door was open.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "The back door was open.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "So our mother went right away, oh, somebody broke in.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So there is-- it's nothing there.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It's gone.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So all right.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "This was late at night when we came back, so in the morning she went to the priest in the-- in the village.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "She went to the priest and she told him the story.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "This was I think on a Thursday.",
      "word_count": 7
    }
  ],
