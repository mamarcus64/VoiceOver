{
  "stem": "25381.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Like the rabbi walked-- first they started that the Jewish people have to wear a yellow on the arm-- on the arm, on the-- on the left arm, like a patch, yellow all around.",
      "word_count": 34
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "They should be notified.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Wherever they go, they should know that they are Jewish, while we were still in the homes.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Then they decided, if you wear, for instance, on the arm, you wear a jacket, then you're covering up.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So they took off and we had to wear a yellow patch, it's like a [NON ENGLISH], the Jewish star-- a yellow patch in the front, and a yellow patch in the back denoted that we had to know that we are Jewish.",
      "word_count": 43
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And then they started-- the Polish-- they gave notice to the Polish people, [NON ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "That means, don't buy anything by the Jew.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "They closed the grocery stores.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "They closed the-- the-- the clothing stores.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "They closed-- they closed all the Jewish stores already.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "They start already-- and, like, they brainwashed the Polish people.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "They brainwashed the Ukrainian, the young generation and-- against the Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "They used to write, already, swastikas, you Jude, you Jew, and [NON ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "And then they start already punishing the Jew.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "Like the rabbi walked to synagogue and they took-- they took with a knife and they cut off fingers in the front of everybody.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "They cut off a ear, and they took with a rope and they put it to-- to the horses into the barn, and they dragged them all over the street, the rabbi.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "And then another, when they saw-- you know, the-- the Orthodox Jew-- there wore-- they were very religious and they wore the beards, the long beards.",
      "word_count": 26
    }
  ],
