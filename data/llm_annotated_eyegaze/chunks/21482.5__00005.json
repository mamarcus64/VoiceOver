{
  "stem": "21482.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So my mother's brothers and sisters, their wives, their children, and their-- her parents did not come back.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Of course, my father did not come back.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "My aunt had died.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Six of my father's brothers and their wives and children were murdered.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "My grandfather survived because he was with us on Schindler's List.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And then, after a few weeks, my father's youngest sister-- only sister-- came.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "She survived in Bergen-Belsen.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I had five girl cousins who survived on my father's side.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Four cousins, four sisters, and survived together.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "They went to-- on a death march from Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And they ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "They hid the last-- like a day before, or the-- the morning before, the-- the Americans came because they said they can't walk another-- another second.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they hid in a hole, someplace, in a barn.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Five of them, four-- four sisters and a friend.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And they weren't there more than-- than maybe six hours when the Americans came.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And then I had two cousins, two boy cousins, who survived. 11 of my boy cousins were murdered.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And, you know, most everybody I knew, they were orphans.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Had no-- nobody left.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I had my mother, my grandfather.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I had an aunt and an uncle and some cousins.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Two of my father's youngest brothers who escaped Russia came back after the war.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And [PAUSES FOR 3 SECONDS] we knew we couldn't stay in Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We didn't stay very long.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I think maybe we stayed there four or five weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "My mother got a job right away.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I got a promise of a job that, in September, when school starts, I would be a kindergarten teacher, a nursery school teacher, also through a friend of my father.",
      "word_count": 30
    }
  ],
