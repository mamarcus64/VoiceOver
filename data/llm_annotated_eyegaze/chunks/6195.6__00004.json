{
  "stem": "6195.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I, of course, washed myself wherever I had the opportunity to get a bit of water-- if it was raining, where we were getting the food.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And I used that for the rain water to wash my hair, or to wash my body.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "When we got to Brunnlitz-- well, I had typhus, and another girl had typhus.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "We were-- of course, over there we had to be honest, because it was more confined.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I said that I have typhus-- or whatever it is.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know the name of it.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But we had doctors.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They were prisoners' doctors.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Oh, nothing elaborate-- and very cramped.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "It was a factory.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And Schindler made-- cut it in such a way that the factory and the living quarters were together.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He didn't want-- I remember-- [LAUGHS] It's-- you know, when you talk about it, and you see it in your-- in front of your eyes, things are coming to my-- to your mind.",
      "word_count": 33
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "We-- I-- I couldn't talk about all that, because there isn't it enough time.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Schindler-- well, Schindler gave us extra rations of bread, and soup, and a real welcome.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And-- but bread was no good to me.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Schindler was bringing-- we were put a little bit in such a distance from the others, the healthy ones-- healthy, well-- but without typhus.",
      "word_count": 24
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Schindler was coming and-- and hiding, and bringing us some soups, some-- I suppose they were disprins, aspirins.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "I don't know what they were-- whatever she could put her hands on.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Unfortunately, the girl next to me has died.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Again, I survived.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I wasn't better than any of them that died.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "[CRYING] Did you see--",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I often-- sorry?",
      "word_count": 3
    }
  ],
