{
  "stem": "16.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "He said, Dad, I went to see And he says to me, don't see it.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "It's not for you.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "Mom, don't let him go.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And he walks out of the room.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And I said to my wife, I said, you know I know I shouldn't see it.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "But I know I must see it.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "I have to go see it.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And I went on a Sunday afternoon, figuring I'll be calm.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Sunday afternoon, I went with my wife.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I ran out three times just to cry because I didn't want to do it inside.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And the man that's selling popcorn, he saw how upset I was.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he says, would you like a glass of water?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I just went yes, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And then he brings me a cold compress with it and-- which I thought I was very nice of him, and so on.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And then I went back.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I knew it was going to be more pain.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "But I had to go back.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It's just one of those things.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I had to see it.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Just like a few years ago when the very first time they showed the on television, like Monday two hours, Tuesday two hours, and Wednesday two hours, from 9:00 to 11:00, and so on.",
      "word_count": 34
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "That was with Meryl Streep and-- the original I was invited to see it in a movie before it was shown on television, for-- on, on a Tuesday for four and a half hours and on a Wednesday for four and a half hours in Century City.",
      "word_count": 47
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I went to see it.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "I ran out a few times just to throw up because it just affected me that much.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "But I went back for more pain.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Gross.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I just had to see it.",
      "word_count": 6
    }
  ],
