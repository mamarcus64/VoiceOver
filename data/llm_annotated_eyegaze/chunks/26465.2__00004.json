{
  "stem": "26465.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And there was this lady with this baby-- in her eiderdown-- she was holding this baby so-- like a very precious thing.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And some woman-- I believe she was Ukrainian, because I heard by the accent, I understood she was not Polish-- and she said, of course I should not say that in Polish, but she what she said that-- give me that.",
      "word_count": 41
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "She wanted the eiderdown.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And the woman said, no, I cannot do that, I have a baby in there.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And that woman tore this eiderdown from her, and the baby almost fell to the ground.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And the lady was-- she grabbed the child just in time, and she was shrieking and crying.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And the German gestapo, the German, came towards her, and pushed her towards the river, and said, go, go swim.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And then he ordered everybody to go right through the way-- right through the river, when the water was very, very cold.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And some people were up to here, and they holding-- they were holding their belongings above their heads.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And some were falling, and one was grabbing another in order to not to drown.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "It was a very shocking sight.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "And I was standing there, and I was crying, and I couldn't take it anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And I remember running.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And I was running, and running, and running away from that sight.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And I got in one place and sat under a tree, and I was crying there, because I couldn't understand, and I couldn't take it anymore.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And my-- my brother, of course, he, being a man, he came and was laughing at me, jeering, and saying, you're a-- coward.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "You're a [POLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "You're a-- [POLISH] is a very mean word in a Polish course, which means old hag, something like that.",
      "word_count": 19
    }
  ],
