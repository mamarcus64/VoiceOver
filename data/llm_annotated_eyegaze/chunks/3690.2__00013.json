{
  "stem": "3690.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "So I jumped up and I started to, you know, clean myself up.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I says, I'm going to try to go back to my hometown and see if anybody's alive, anybody came home from the concentration camps or the labor camps.",
      "word_count": 29
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Sure enough, I came back to Mukach--",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was 1945.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I came back to Mukach--",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In the war, they were still shooting here and there, but it wasn't completely over.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "But it was kind of quieted down, especially in my part of the world, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "In the Carpathian, was no more-- they were occupied by the Russians.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And you used to be called SSSR.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Used to belong to Russia already.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The Russians had annexed it.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the Russian occupied it, and they said it belongs to Russia already.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And I came to town, and it was very early in the morning, about 4 o'clock or 5 o'clock in the morning.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It was kind of still a little dark and daylight started coming out.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And there was very few people on the street.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And I seen some truck go by, some buses.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I says, hey, is there any place here around where there is some people came back to town, some Jewish people?",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "He says, yeah we heard some Jews came back, and they lived there, and they.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So I went first back to the house where my father used to own.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "A big-- we used to own a big apartment complex with four apartments on each side and three front-- the front was three big stores.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "So I come back there.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And everything was closed up, and they wouldn't let me in.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And I don't think they knew who I am or recognized me.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "So I says, did anybody came back?",
      "word_count": 7
    }
  ],
