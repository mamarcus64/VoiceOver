  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And this is about [PAUSES FOR 3 SECONDS] all that I know about that night.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 6 SECONDS] One interesting thing is that following of what happened there, my father's [PAUSES FOR 3 SECONDS] sister-in-law-- younger sister, who was escaping thanks to my father's documents-- forged documents as well-- went to the station-- to the train station close by of where they were living.",
      "word_count": 50
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And she was there with one of her nieces and her sister.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And they were going towards [?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Czestochowa-- ?] the same way as my mother was going for work-- to work in Germany.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "They were at the station while my other mother was there with me.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And my cousins recognized me.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "But of course, they would not come close to me because they do not want to endanger me.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "However, they showed-- they saw me.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And they heard the lady say that she just found me.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Someone actually found at the-- the village elderly found me and announced in the church that there is a child, and who would like to take the child?",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And she was so delighted to take the child because she only had a son and she couldn't have any more children.",
      "word_count": 22
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And it was, for her, like a gift from God.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And my cousin said I was beautifully dressed.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And I was going to a doctor with her.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And she was surrounded by some people that she knew.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And she was telling some strangers who were right next-- next to her.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And they were all admiring me.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And they were all happy for her.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And she said she just looked and she was so glad that she could recognize me-- at least that I'm in good hands.",
      "word_count": 23
    }
  ],
