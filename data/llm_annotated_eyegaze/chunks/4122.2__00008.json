  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "People were coming in and out, and they were taking them to, to be killed.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "I can't talk about it.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, in the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "In the ghetto.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No, I was alone.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Just with a cousin, a girl, another girl, behind this closet.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "A whole day was going on the aksia.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "They were taking people, and bringing them, and killing them in the ghetto, whatever they can.",
      "word_count": 16
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "The next, the next day, they took--",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "They said they're going to liquidate the ghetto.",
      "word_count": 8
    }
  ],
