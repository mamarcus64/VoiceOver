{
  "stem": "4345.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I remember they did not allow me to go with her when they rounded up all these young women.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And I know many of them, because they were my cousins who had a baby-- who had babies, and friends, you know, neighbors' children who had, who had babies.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And my sister said to me, Mila, [NON-ENGLISH SPEECH], because they will take it with me.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I said, maybe it's better that I go with you.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "She says, Mila, mommy is still home.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "You cannot do that.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And they took them down to the great synagogue in [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I will show you the picture later of the great synagogue if I have a chance to get up and and take down them.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I did not stay home.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I didn't go home.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "I went down to the [NON-ENGLISH SPEECH], which means the synagogue street.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "Because the shul was there, they called it the [NON-ENGLISH SPEECH].",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "And we had a friend who had an office across from the shul.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "He was a German Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "He lived in Berlin but came to Chrzanow.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And he was very, a very brilliant guy, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "So they allowed him to have an office.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "He worked for the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So I said to him-- he died in Florida four years ago.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I said to him, Mr.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Prista, I must hide here.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Because my sister is there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "My cousins are there, the people that were just brought.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "He said, he said, of course you can.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I-- and he allowed me to be in the office.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "They took them at night, of course, you know, so I slept in the office for, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And then I looked out, like it could've been maybe 1, 2 o'clock in the morning.",
      "word_count": 16
    }
  ],
