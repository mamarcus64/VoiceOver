{
  "stem": "598.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "We are selling a liter of wine for a-- for a zloty.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "He comes in, he says he wants a zloty from each liter for himself.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "We had to close up.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "We could-- we didn't have no choice.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "My grandfather tried to sell it.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "Not to pay him, they put him in jail.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "So after a couple of weeks in jail, he didn't-- just stop selling it.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "But otherwise, the town was a beautiful town.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "You never see a town like that on a hill-- beautiful fresh air.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "And the food was natural food-- the best food in the world.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "The climate was good.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "And the people was good.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "Right now nobody there.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "Not even one human being there.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Then in '39, first they came in-- the Russian came into us.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They start coming with airplanes.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Somebody came in, they say that Russia came in.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We came out, we greet them.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "After a couple of days, everybody goes to work, everybody goes to school.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "My father opened up a factory.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Start making wine.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "In-- of course, they took away half, Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "They used to-- they used to get wine from big cities, from Warsaw, from Lemberg.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "Now everything is closed up.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And the Russians like-- like to drink.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "So my-- my father-- and then we made mead, they call it, made from honey.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "We get a lot of honey by us.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "We cannot sell them anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "They-- the farmers cannot sell them anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "So they bring over to us.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "My father start making mead and wine.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "Sell it to the Russians-- sell it to everybody.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "Making money a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Of course, it was fully dangerous.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "They say that you are [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 22,
      "text": "You're-- they're gonna put you to Siberia.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 23,
      "text": "So be our partner.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 24,
      "text": "The partner came in.",
      "word_count": 4
    }
  ],
