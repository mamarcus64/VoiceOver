{
  "stem": "18307.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.1,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He used to work-- he used to drive for my father.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And my father said, go to him.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "He's not going to give you out, he'll give you bread.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And I went and it was very cold and I didn't know then that there-- there was a wire between his front door and the barn and there was a dog on that wire.",
      "word_count": 34
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And the minute I put my hand to open up the door, that dog bit me in my thigh.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I remember looking at his teeth.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "His teeth were blue-- not his teeth, his gums were like blue.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "And he-- and Wedke opened the door, he saw what was happening.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "They were putting snow on it.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "I saw every tooth, the dog's tooth in my leg.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "I couldn't go to a doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "I told Wedke where the families live, and he gave me some bread.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "I don't know how I walked back, but I did.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And I came in and my mother and father took one look and my leg was swollen.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "And they thought or sure I'm going to die.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "But I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "I lived.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "It was-- the teeth were there, the marks were there.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "My leg was getting bigger and bigger and then it got smaller and smaller and I lived.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 25,
      "text": "I lived.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We had nothing to wrap it.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We had nothing-- nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was the oldest.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My sister was only 11 and she-- when I look back, she always-- every day, she said, why don't we give ourselves up?",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Why don't we get ourselves up?",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I mean, look at us, she said, we're-- and I would smack her face many a times.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I would say, don't talk like this.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Do not even talk like this.",
      "word_count": 6
    }
  ],
