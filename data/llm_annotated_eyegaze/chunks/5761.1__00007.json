{
  "stem": "5761.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "You were-- you were afraid to get out from the house in the evenings, at night.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "You were afraid to walk by yourself.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "It came to-- to a situation that my parents were very afraid.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "And we were not free to walk around, you know, in town.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "It seems like things changed very suddenly and very drastically.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "This was when the war broke out.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "We knew that the Polish army is putting up the resistance.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "The German-- the Germans were bombarding.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "They never bombard our city But in the beginning, they took me to my older sister, and I stayed there for a few days.",
      "word_count": 24
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "And when I saw planes bombarding the city, for me it was a happiness.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Look at this.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Planes are throwing things and bombarding.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "What's going on?",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "You know, homes are-- big buildings are falling down.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And I ran to the center of the town by myself.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Nobody realized what happening.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "It was a sudden, you know, bombarding day.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And I run to the center of the city.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "But they were-- they were digging bunkers.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And I remember I took a shovel and I helped.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Naturally, then I went back, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And my parents and my other two sisters joined the whole family.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Then when the war began, we all got together.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "We lived-- we all lived in-- in the house, you know, in Pruchnik.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And naturally, we were hearing, you know, rumors about the German are advancing.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And we also heard that a town not far from us, they came in and they killed 30-- dirty, you know, 30 Jews.",
      "word_count": 23
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "Another town, they killed Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "But we-- you know, my family never believed they would come to our town.",
      "word_count": 14
    }
  ],
