{
  "stem": "26359.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well, weeks, a few weeks before the Germans came, I noticed that the people the young people were called back to their army for army duty because I saw lots of people, they were ready to go to the army, the military duties.",
      "word_count": 43
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "This is when it was in 1941 ad in June, the beginning of June.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know at that time what should expect.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have no whatsoever, no news, from nobody.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "Well, it started in 1941, the 28th of August.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They assembled.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "The Germans came.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "The first time I saw in my life, the German people, the military Germans, they had assembled young people in a place.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And but they-- about 50 or close to 70 people that took away.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "They never returned.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "They never came back.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "But my father was released.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "They took him also.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "But they released him.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And I was happy when I saw my father was back home.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "For a few hours.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They took him.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They kept them in a place there in the marketplace.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They kept them.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "But they released the elderly people.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "The young people, they put a [INAUDIBLE] on there.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "We didn't discover what's happened to them.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "We didn't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "But it was rumors they took them somewhere else and that killed them.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "But nobody knew what was happened with the young people, the young people, meaning the age in their 20s and the 30s, mostly men.",
      "word_count": 24
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And this was going for a whole month.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "We used to want to hide, figured they maybe come during the day.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "If they come to collect some money and something, we want to hide.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "And of course, it was agony knowing that this looks like this is the end us and that's it.",
      "word_count": 19
    }
  ],
