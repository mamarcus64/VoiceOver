{
  "stem": "5328.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "She-- she was a gorgeous woman-- young lady.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And she was born in 1921.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Then next came my brother, which is now in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "He was born in 1923.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] And then I came in 1927.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And a younger sister than me, Rachel-- she was in 1929 born.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, my--",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "My oldest sister was a very good-looking young lady.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "She had beautiful white teeth.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "She went and-- she-- I remember her going already to university, to college, in Rowne.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Rowne was 12 miles-- 12 kilometers away from Zdolbunow, where there was a old-- where there was a Hebrew school, a Hebrew college, just-- because not everywhere Jews were accepted in college.",
      "word_count": 32
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "So in Rowne was a Hebrew college.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "My brother was-- is-- was the only one son in the family, which my mother adored.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "He's-- the little boy.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "He-- he was-- he left-- he left to Russia before Hitler arrived.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "Like a day before Hitler, I mean, occupied our city, he left the day before to Russia.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "And he survived.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Well, this was-- we now-- specific place-- my father-- being under the Russian regime, my father was-- had a grocery store.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Not he had-- he was running a grocery store for a manager of a grocery store.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And apparently he sold-- he sold a little bit-- he took some-- you know, like, less than he was supposed to take home.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And he was arrested-- by the Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "He was arrested and sent away to a different town, to work there instead of being with the family.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "This was his punishment.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "My father.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And when the-- when-- when the Germans occupied our place, my father wasn't home.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So if he would be home, possible that the whole family will go to Russia.",
      "word_count": 15
    }
  ],
