  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] You understand?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 6,
      "text": "The Germans was all over, fully equipped.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 7,
      "text": "We didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 8,
      "text": "The only thing we got  is rifles and guns.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 9,
      "text": "A few grenades.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 10,
      "text": "The Germans got tanks, machines.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 11,
      "text": "And there in these areas in general in Poland, Ukraine, there were lots of volksdeutsche.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 12,
      "text": "You understand me?",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 13,
      "text": "Hitler prepared them before the war.",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 14,
      "text": "They brought in settlers.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 15,
      "text": "He was so smart, Hitler.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 16,
      "text": "Even in our province, he sent in volksdeutsche, settlers.",
      "word_count": 9
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 17,
      "text": "They bought up land, and they settled down.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 18,
      "text": "And they all got stations.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 19,
      "text": "[INAUDIBLE] how you took it, even the Russian army, what was at [INAUDIBLE], if you heard about it.",
      "word_count": 18
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 20,
      "text": "Or, you don't know about it?",
      "word_count": 6
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 21,
      "text": "We'll pick that up on the next tape.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
