{
  "stem": "5516.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And one was near the Frankl's shop, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was near the Frankl shop.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, with a lot of people.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "The only thing is, before they established the ghetto, it's a Christian.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But they told him he had to go out because they're making a ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Till he come over in Siauliai and he took over the house where I was living with our family.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And we was over in his house.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "We had, I think, the best place in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Even the management, the president from the ghetto-- because the German made-- they don't talk to all the Jews.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "They make a few people, and they talk to these few people.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And he was like a president and like a leader.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "They want even to take away from me the, the place.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "I don't know if he was fighting on he could hold on.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "But the only thing is, a lot of people.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "We was living maybe 18, 20 people in a room.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "In a room.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "The food was very bad, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They used to give according to the ration, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They used to let in so much.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "You can get so many people.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "They used to send in so much food, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Even the Germans, they had calories.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "They have to have so many calories-- 1500.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "But the only thing, I had better, because I used to go out to work, and I was in connection with Lithuanian people, Christian, who used to work in the shop.",
      "word_count": 31
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "So I used to get food a little bit more, like anybody else.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "But the only thing, to bring in the ghetto is very hard.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Because they used to look, like you go now in the airport.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They search you.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "If they find something, it's trouble.",
      "word_count": 6
    }
  ],
