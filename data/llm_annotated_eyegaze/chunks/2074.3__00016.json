  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "To build me up and bring-- and bring me some food.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Well, I sort of was thankful to God I'm alive.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "I-- I just didn't know what miracle happened to me that these people so interesting.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "So it was Captain [INAUDIBLE] from Leningrad.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I'll send you back to my wife and children and the family.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "A month later, they-- I didn't want to go.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Where do you want to go?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I had family in America.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "Maybe I can go there.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So-- but anyway, a month later, they have to go on Berlin.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They started to say goodbye to me.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And they cried.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I cried.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Because they went on Berlin, and we don't know if they survived or not to go home to their families.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "But that month, they really built me up and make a-- made a mensch out of me.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "But before they left--",
      "word_count": 4
    }
  ],
