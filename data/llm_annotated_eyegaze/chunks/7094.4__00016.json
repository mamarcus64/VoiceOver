  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And I was dividing them for the children.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And an elderly lady was standing in the corner, travelling very badly.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And I had some, so I gave it to her.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And she told me her story.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "She came from Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "She was coming to her son, who was a lecturer in Oxford.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And through her-- and she gave me her address, because I didn't have my address.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And this is how sometimes it goes by.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "When I was in the hostel, looking-- and also later on, when I wasn't in the hostel-- a way out of that situation, what am I going to do with my life, the family decided that I should go to a factory and work as a machinist.",
      "word_count": 47
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "I had some other inspiration.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "I wanted to go back to education somehow.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "I reminded myself about this woman, and she-- and he was in charge, in Poland.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "At that time, there was a Polish university course.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "And the Polish-- he was in charge of that.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "And he gave me the address of this Polish university course.",
      "word_count": 11
    }
  ],
