{
  "stem": "2851.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And we walked, maybe one-- one week.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "We-- we walked every day, every place we find.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But we came to one place.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "We came into a house.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "It was Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "And she took us in.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And she said--",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know the people.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "She took us in, and she said, I will make you potatoes.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You can sleep over.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And then in the house, it was a-- it was-- he was a church man.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "He also came, because all the people were running after the war.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "So he said, you Jewish?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "We said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We just-- so he said to her, don't make them potatoes or nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Tell them to go.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So she was afraid, and she didn't give us nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And she told us to go.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "It was at night.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "We been hungry, and wet.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "So we went away.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And we start to cry, you see?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "We are free.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "But this is free?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They didn't let us stay.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "So we walked that night.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "So we say-- we-- we saw from far away a house.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "We went into the house.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "It was-- it start to be day-- daytime.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "It was about 4 o'clock in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "We went into the house.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "No one was there.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And we find two potatoes-- two raw potatoes.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "So we eat the-- the two raw potatoes-- the three of us.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "My-- my brother-in-law, I gave him one potato and we had two, me and my sister.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And we saw a place where to hide, to sleepover.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "So we came into the place.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And my-- and my brother-in-law said, you stay here.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And I'm going to see where I am.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "And he came out.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "And he thought-- he-- he start to walk.",
      "word_count": 8
    }
  ],
