  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "Then it's come a couple-- two, two or three people came from the bigger groups from the partisans to take us.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "They know what somebody is here, and they find us.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "No, and we tell them, we meet with them, and then tell them what we are Jewish and we want to go with-- together with all, with the group to go.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "They took it, they took us, and we came.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "That's for a, maybe kilometers-- no. 30 kilometers we make for one night.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And we came in a, in a place that's-- no, I will [? not ?] to tell the episodes, short episodes, how we went through the, the railroad, [INAUDIBLE] we [INAUDIBLE] railroad.",
      "word_count": 32
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "It's, it's-- if to tell episodes, we need time and time and time.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "Now, the most important.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "I will tell the most important things.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "We came in the big forest, that's, that forest, that's more to Belarusian.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "That's [? white, ?] [? white ?] Russia [? called. ?] That's more bigger forest than the forest, but we was in that place near to our Komarova.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "When we came at daytime, we came in a, in a, a village-- partisans going at daytime.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "Don't have afraid nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "Oh, we saw we was happy.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "They give us food, and we explain them from there.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 29,
      "text": "And we met Jewish people in the partisans.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Then they keep us [? no ?] [? in ?] the [? period. ?] It was different time.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Who knows who, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Because the Germans, they send people to, to, to, know, to knows what, where is the partisans.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Then they come, they come with, to kill the partisans.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "No, they told us, you will stay here for a week in the, in the village.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
