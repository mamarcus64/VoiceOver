{
  "stem": "597.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And this little town alone is a beautiful town, with a nice-- nice people, young people.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It used to belong to different kind of organizations.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And-- but I was young.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "That time I was around 15-years-old, 14-years-old.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't belong to some of them.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't-- didn't understand yet.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I was a very young girl.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "During the war I start already understanding what it means-- what is war.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And in 1939, the war was bombing out.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "They bombed.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "The German bombed our town.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And then, the Russian came in.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "So I knew where to start.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And, you know, everybody was shaking, bumping you.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "The airplanes are on top on you.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "You know what's going on.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "You never saw a airplane in my life.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "[LAUGHS] It was the first time I saw it.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "After that-- that was-- I had some girlfriends, and-- and the same-- the same thing.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "They-- they all come from orthodox places, homes, raised very Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "Shabbat-- it was a Shabbat with a dinner-- special.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "We used to go visiting each other on the day of Shabbat-- going to synagogue-- all-- all of them raised-- was raised up in the same.",
      "word_count": 26
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "This is like a shtetl, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "My father used to sit there all the time in the market and-- and take care on making a living.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was not easy, but he tried to mate-- make, but he can't.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "My mother helped him all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "He was a grocer?",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "A grocer, yeah-- sending, you know, for the-- he used to come in every-- every-- every once a week it used to be a big market in the city.",
      "word_count": 29
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And the-- all the farmers used to come in and buy things.",
      "word_count": 12
    }
  ],
