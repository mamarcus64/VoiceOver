{
  "stem": "2581.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So if we make a pair of pants for them, they would bring some food.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "But things started to get tighter and worse.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And I remember the first time that my mother had cooked horse meat.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And you know, it wasn't kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But it was no problem anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I remember, it tasted like-- like baked  goods.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "It was delicious.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "Because you get used-- you get used to things.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And we were sitting on the attic, I and my father, and made these clothes by hand.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "They took-- Germans took away all the machinery from us, because in town, they had created a clothing factory where we, again, were making clothing for German civilian companies.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And then we made uniforms.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "So it's what-- that is what it's going to be.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "If we have to work during the-- work isn't the worst thing.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "We had a roof on our head.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "We had before four rooms that we lived in the apartment, plus the factory upstairs.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And here we lived all in one room, which was fine.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "No one complained about it.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "We came home from work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "We still had our-- you know, our--",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My mother and  my brother up-- up to-- up to the deportation.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And the ghetto was getting worse and worse.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And like I said, they-- they-- what they did is knocked down our spirits, our-- our self-respect.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And they tried to scare us in every way they could.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They would take-- send out groups of people to go to work outside the ghetto to the Germans.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And one day, two young brothers came back from work.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And they carried some potatoes in their pockets and in their shirt, like you must have seen the shows about the different-- you know, I've seen it a number of times.",
      "word_count": 31
    }
  ],
