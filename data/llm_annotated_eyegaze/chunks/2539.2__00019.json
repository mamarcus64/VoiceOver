{
  "stem": "2539.2",
  "chunk_idx": 19,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "A secret-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "This was under the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "You see, he was a Ukrainian, you see-- you see-- a Ukrainian working for the gestapo.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He was not a German.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "He was a Ukrainian working for the gestapo.",
      "word_count": 8
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "In any case-- or maybe he was a volksdeutche-- or-- I don't know.",
      "word_count": 13
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "In any case, I ran.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "I never saw them again.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "And I-- I went to this-- to the chaussee, you know, where the traffic was going.",
      "word_count": 16
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 8,
      "text": "And it was already afternoon.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 9,
      "text": "And it used to get dark-- no, it was summer.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 10,
      "text": "But nevertheless-- ah, there was curfew.",
      "word_count": 6
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 11,
      "text": "You couldn't walk.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 12,
      "text": "And don't forget, that was the time when the Ukrainians were killing the Poles.",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 13,
      "text": "And I had an ID card of a Polish girl.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "So I was at risk.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "If I would have been caught alone on the chaussee and a Ukrainian would have come up to me and say, [NON-ENGLISH]-- miss, where are you going, and who are you?",
      "word_count": 31
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "If I would say, I'm Halina [NON-ENGLISH] Scmigero-- Polish, they would have chopped up my head off!",
      "word_count": 17
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "Because-- We'll-- yeah, we'll-- we'll stop there.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
