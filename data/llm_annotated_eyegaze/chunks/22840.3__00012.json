      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] There is an end to that story, before we go to it, the discovery.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "He did discover me.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I was taken.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I was brought away.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "He died after the war, but he-- he discovered me, and we headed here together, less than a year until he died.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] I wrote a letter.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] Hardly to say a letter.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I have it.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I have here a copy.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 3 SECONDS] I wrote a letter to that family in 1945, [PAUSES FOR 3 SECONDS] in Christmas, 1945.",
      "word_count": 20
