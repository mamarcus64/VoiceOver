{
  "stem": "26790.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "You can't speak nobody, because nobody was there, only two men, which I was looking for the, for the barracks, and I used to cooking for us.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They can't speak Polish, they can't speak Yiddish, and I, and we can't speak Russian.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But we already knew a little bit, a few words of Russian.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We find out, not far from here, a few kilometers from here is a village.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Next, next day, they took us to work.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "What work we doing?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They was building a road for Moskva, Minsk.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And the, the road have to go through the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Our work was to cut the trees off from the forest, prepare it for the road.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "Can you imagine that we people, we, we never use to work like that.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "We were-- Sunday, not working day, we got off.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "We find that not far from here, a few kilometers from here is a little village.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "We went over there.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We met a few Yiddish families in this village.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We didn't have time to be long, because we all had to [INAUDIBLE] there and we had to go back.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Take a while till  we come back.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "As we come back, they, they tell us, next Sunday, you come earlier.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We never talk and speak, we might be friends and something like, [?",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Yiddish ?] people.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Next Sunday, we come more early.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "We-- after breakfast, we went straight there.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "We come there.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Was 11 o'clock, something like that.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "They took us in their home.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "They make a nice meal.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "They started talking.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They start asking, how you live in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Before the war, how you live?",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We was asking how they was living under the Communist regime.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "They were very, very friendly.",
      "word_count": 5
    }
  ],
