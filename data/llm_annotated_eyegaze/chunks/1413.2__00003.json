{
  "stem": "1413.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "With the older people, the women and the older-- the older and the women on one side, and the young and strong-- they need slave--",
      "word_count": 25
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I've never-- I can only say what I heard later.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And they were sent to Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I didn't see that-- I can't say that they did go to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "But I see on paper that my father died November 19, 1942.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "My wife died November, 1942.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "My aunt died November, 1942.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They must have all gone to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "They died the same day.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "I have it on paper here.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I'm going to show you later.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I told you, before, either from [NON-ENGLISH], or from the Dutch government, that I don't know.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My daughter got it from me.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "The paper says Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They all went to Auschwitz, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My brother went to the camp-- was sent away from Westerbork, because I spot both-- no, no, no.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My youngest brother, I saw in Westerbork.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And he was sent away to Germany, Poland, whatever they did.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "That's my brother--",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "The other brother-- also on paper I got that.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My older brother, [PAUSES FOR 4 SECONDS] he was sent away in '43, September '43.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And he--",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "From Westerbork, or from-- yeah, I don't know if he was in Westerbork or not, because I was already in Germany.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "But like I said, I got a very, very partial list, very small partial list, from the Jews from the Netherlands who died-- only the-- my name and my second wife's names.",
      "word_count": 32
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And he is one-- he is one of the two people who only said he died in Poland, not in Sobibor, or or Auschwitz, or Blechhammer, or wherever.",
      "word_count": 28
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "There are two on that list.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And my brother is one of them who died in Poland, it says.",
      "word_count": 13
    }
  ],
