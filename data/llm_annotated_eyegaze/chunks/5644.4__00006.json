  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And if they said, they haven't got it, he asked the Germans to shoot him.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "He was here.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "He was caught by me.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "He was given to the police.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "By me.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "In Australia.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "In Australia.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Came here to Australia.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And the police arrested him.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And I did give him to the hands of the police.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "The police asked me in [?",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Russelstead ?] to bring a document of five people signed.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Till 8 o'clock in the morning because I brought him in at 12 o'clock in the night.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And when I came in the next day at 8 or 9 o'clock in the morning, and brought them in the papers, they said they let him out.",
      "word_count": 28
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "When I asked him, why, [INAUDIBLE] finish up with it.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "When I asked them why they let him out, from here, he said that we checked that with Germany.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Because when here is night, there is day.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "We checked with the Nuremberg.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Nuremberg.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "There's--",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Nuremberg.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We checked it.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "His name is not there.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Definitely a little stinker.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "How would he be there?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "So we let him out.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I was chasing him--",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They let him because he's not in the Nuremberg book.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Files.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Now what we did, he went to Adelaide.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "My friends, and myself here, and elsewhere.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "But they did want to put him where he should be put.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "For the police or to court.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Now he went to Adelaide.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "I chased him in Adelaide.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "I advised some of my friends, Christian friends.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And luckily, luckily, that's what you call it?",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "That something happened which I am not a believer but God helped us at the time.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "He pinched some cars or something.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "He was in prison and then he died.",
      "word_count": 8
    }
  ],
