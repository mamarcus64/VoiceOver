  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 28,
      "text": "And especially the young Jewish survivors, young men, they were angry.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 29,
      "text": "They were bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 30,
      "text": "They were rightly so.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 31,
      "text": "And I have witnessed where they would, you know, kill some-- brutally kill some Germans, and if they were certain that they were Nazis and they participated and killed somebody.",
      "word_count": 30
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 32,
      "text": "They were recognized.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 33,
      "text": "Certain Nazis were recognized.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 34,
      "text": "And some of our Jewish people really took a hold of them.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
