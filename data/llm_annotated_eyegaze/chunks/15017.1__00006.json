{
  "stem": "15017.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "After a while, I got a bit tired of it, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "After a while, then I decided to find a job.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "It was very difficult, because in the dance band business-- I'd now learned how to play dance music, because before, I never played dance music, you see.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I learned to play dance music.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And there was a band coming over from the Ambassador Hotel here in Los Angeles called Eddie Oliver.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And that was the time of Prohibition.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And when the ship landed-- his ship landed in England-- two of the guys had to be sent back in a basket from drinking, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And he came looking for two men to join the band.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "And we opened up at the Commodore Hotel in the Boulevard Haussmann in Paris, Eddie at the Ambassador's Hotel-- it was supposed to be a copy of the Coconut Grove here.",
      "word_count": 31
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And from there, I kept moving around in Europe.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "I worked in Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "I worked in Italy.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "I-- I coming home all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "And that's when I-- when I came home and got married.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I met my wife in 1934, November 1934.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I was very much in love with her.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "To me-- and the picture that you got-- she was one of the most beautiful girls that you-- anyone could see.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "She was a real head turner.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And I felt very, very proud.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I went with a friend to a club, and there I met her.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It was a-- it was a Jewish club, you know, for the young people, you see.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And there I met her.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And we got married March the 15th.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Sunday, March the 15th, 1936, we got married.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "But of course--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In London at-- with Rabbi Shaposhnik's synagogue, which was in Bedford Square in London.",
      "word_count": 14
    }
  ],
