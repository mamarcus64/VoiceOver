  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So when we reach the stop between-- on the border between Czech, Moravia, and Slovakia, this Gestapo which he came with us, he handed over a paper to the Hlinka Guard who took-- he told him to take over these people.",
      "word_count": 41
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And it's all-- you are-- they are yours.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And he went back to Brunn.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Now we are under the-- under the orders of this Hlinka Guard, these Nazi troops.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And we didn't suspect anything bad.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "But then we, we, we-- they, they licked us very bad.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "They put us-- they took us down with-- in a rude manner, [PAUSES FOR 3 SECONDS] yelling and screaming and kicking us, and put us on a-- on a truck.",
      "word_count": 30
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And they took us to Kosice.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "It was a big city, Kosice, in, in, in, what, eastern Slovakia.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "In that city, they took us also to a military camp.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
