{
  "stem": "12402.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And his was [INAUDIBLE], this-- this Malzman.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "The three of us.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So I gave him enough money.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They wanted, I think, $100 for a passport, you know, under the table.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "But the names were the original names, because those boys, they send them to Germany for-- for work.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You know, they-- they usually catch transport.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "They send them, Polacks, to work for Germany, the German.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "So that was original papers.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "If they ever-- we ever get caught in Germany, they're gonna check back.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Sure, they were registered here.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "It was-- it was done wonderful.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "So we got-- one day we got the papers.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "They says it'll take a week or two until we get them out.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And we got the papers, and we take off in middle of the night.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "We didn't say goodbye to nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "It's not the story.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And then-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "We got three Gentile boys.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "He organized three Gentile-- we had-- what we gonna do with the papers?",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "We have to go to an office to go volunteer to work to Germany as Polack.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "But we can't go.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "They used to give examination.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "The minute they undress me, I'm finished-- we are finished.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We got three boys to go for us with the papers.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And they get-- they went through.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "They got their permits stamped, so-- so they went with us.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We went six of us-- the Gentile, the three of them, they got paid.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And the-- the three of us.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Middle of the night, we sneaked out of the hole.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We went on the train, and we-- we traveled-- we went on the train.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "There were all kind of SS checking, checking, but we had papers so no problem.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And the Gentile boys went with us.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I'll tell you why.",
      "word_count": 4
    }
  ],
