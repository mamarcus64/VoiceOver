  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I met the commanding officer, which was a Brigadier [?",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Kendrick, ?] a Britisher, who knew me from my [? mother, and ?] Jews from Vienna.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "He had been a military attache to Austria before.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "But he, he used it.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "He used it quite extensively.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I did not during the time in the military.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I experienced some after that, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I have a very good military record.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I have four battle stars.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I took part in-- I got a star for the Battle of Normandy, although I came after the landing in Normandy.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "But the Normandy battle was still on.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I have a battle star for the, for the campaign in, in, in Belgium-- in northern France and Belgium is the campaign name.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "I have a third battle star for the Battle of the Rhine, and a fourth battle star for the Battle of Central Europe.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I was not a fighting soldier.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "But I went to the front lines, or near the front lines, to interrogate important prisoners right after they were captured and when they were still in the shock of capture.",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "And I had to find out certain people who have, who is information [? was ?] only for certain purposes.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And I tell you, I won't make so many jokes about the Army, that the Army sends their physician or somebody to-- as a cook.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And so I was always on the spot wherever I was best used.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "They gave me-- the first assignment I was, when the Allies approached Vienna.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Can the Allies expect an uprising or any support from the local population?",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "To what degree?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So I was flown over.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And the Battle of Normandy was still going on.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The Battle of, of Northern France and Belgium was still already on.",
      "word_count": 12
    }
  ],
