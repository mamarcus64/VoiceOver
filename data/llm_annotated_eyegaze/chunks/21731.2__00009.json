{
  "stem": "21731.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "It was a girl coming as a receptionist for a few hours a day.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "And I helped also my husband in the hospital as a physiotherapist-- voluntary, he didn't need that.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "They, they were not paid.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Lublin was, for me, an ugly town and a very unpleasant town--",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "--very Jewish, very Jewish, very Orthodox, which I couldn't stand and didn't understand.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The doctors-- the Polish doctors sent their patients to Polish x-ray specialists.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And the  Jewish doctors sent their patients to the Jewish ones.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So it was always what, with these patients-- I didn't like it very much.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But I made friends with a few people.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And I had one-- I had-- with a Jewish family, the Brombergs, very, very Orthodox, but educated and civilized, not the Jews in the kind of ghetto behind one of the walls.",
      "word_count": 32
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "That-- it was not a wall built by the German.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "It's a ghetto wall.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "It was old wall.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And behind that, there was the Jewish-- the Jewish district.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And they were really ghetto-like, these Jews were.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "But the Brombergs were civilized, educated.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "And their daughter was a young widow with a boy of Jan's age.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And we got-- friends.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And Jan and Alek were great friends.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And the two nannies were friends.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "So everything was fine.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "Life went on till, more or less, it was-- it was winter '38.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "No idea.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I just wanted to come to that.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I had no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Not only me-- I was not interested in politics at all.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "But what, what about all these educated men, all these doctors, lawyers?",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Didn't they know what was going on in the world?",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I wasn't interested.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I had my child.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I had my, my cook to instruct what to make for supper.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And I wasn't interested in, in politics.",
      "word_count": 7
    }
  ],
