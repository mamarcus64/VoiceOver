{
  "stem": "2590.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And when I was sitting all by myself in there, they cannot-- I go insane.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "I kept repeating it to myself, to myself, that maybe one day, one day it will come in handy.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I decided to go to that village too.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She brought me a long dress, a peasant dress, and an apron.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I decided to go on a little prayer book.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I decided to go to that village.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It was [NON-ENGLISH], what it is called.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I should-- maybe I'll get a job too.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And in order to go, I had to go at night.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I was afraid not be recognized.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I had to cross a Christian cemetery.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And it was twilight, and I got very, very panicky, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Somehow my imagination carried me away.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And I thought that all the dead people came out from the graves and tried-- and started to chase me.",
      "word_count": 20
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And apparently, I fainted, because when it started-- getting goosebumps all over.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And when I woke up, or I came to myself, there was this Polish woman standing near me.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And she said-- she asked me who I am.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I told her the make-believe story.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And I said that I am looking for work.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And she said, are you a peasant girl too?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Do you know how to milk cows?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Do you know how to dig potatoes?",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Whatever she asked me, whatever I can do-- and out of fear I said, yes.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "So she said, OK, sit.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "She said, she's going to the Germans to work.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And she'll come back in the afternoon.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "She'll take me to her place.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "She has one.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "So I stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "She came back.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "She took me.",
      "word_count": 3
    }
  ],
