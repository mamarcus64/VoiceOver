{
  "stem": "1316.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "And they formed parties, each with drums and with the-- some with-- with accordions.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And they used to go out over the city, especially above the rail tracks where there was the nicer, the-- the better part of the city where there were many villas and-- and hotels and collect donations for the upkeeping of this society.",
      "word_count": 43
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "And this gave them the means to help poor people with doctor-- free doctor, free medicine, and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My brother-- only one brother-- he was a little, lovely boy.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He's just, when I left, he just started to go to-- a cheder.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So I don't remember him much.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "My oldest sister I remember very much.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "She was-- she influenced me very much.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "She was four years older.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And soon when my father changed-- he bankrupted there-- he borrowed.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "There was-- in the '30s, there was the crisis-- the economic crisis.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And he couldn't afford.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "He borrowed a lot to the shoemakers.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "They didn't pay.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And he decided to change his profession and to-- to open a restaurant.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "Where the shop was, they worked it over with a buffet, with tables, and they opened with a machine for beer.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "And they opened a two rooms-- both rooms were taken, the back room and the-- and the front room for the restaurant.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "And we moved in so not far, on a second street in a back room in one room to live there.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "But we stayed mostly in the restaurant.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "And then I remember my sister, even before when we lived in that little room, she-- she used to attend Polish school.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "And she came home.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "She attended me.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "She told me stories she read in the Polish school-- she heard-- about Polish kings and queens.",
      "word_count": 17
    }
  ],
