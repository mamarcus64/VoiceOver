    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I kept saying I'm older.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And my mother got me a long frock.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And she braided my hair to make me look older.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And those women were helping me, the Polish women, sometimes.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I had a Blockalteste, a Polish woman.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And every time there was a selection, she used to hide me.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And I'll tell you how she was hiding me.",
      "word_count": 9
    }
  ],
