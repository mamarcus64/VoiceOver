{
  "stem": "12768.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And I said, you guys are crazy, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "This is-- go and look in his overcoat.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "I stuck everything in his overcoat in the outside pocket.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And my brother went down the hallway and opened the closet.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "There was his money, his papers, his passport, and everything else.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "That kind of upset me a little bit, because I had been away already now from the family for the second time.",
      "word_count": 22
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "So I said, this is it.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "I'm leaving as soon as I can.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "Went to the embassy, begged and cried and said, I must leave, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "And finally, I got the, the papers.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "So now I could go back to the same place I had been, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "And-- but this time, I had the permit to stay.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "So I came back to New York.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "I stayed in New York, got a job, and worked there for awhile, and enjoyed the time.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "I'm a member of the Danish Soccer Club out to Bay Ridge, Long Island.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "And then I met some other Danes at the Sloan House in-- when we were down playing badminton.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "And they had just come back from Houston, Texas.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "And they said, oh, it's God's country, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "And, and so I went to Houston, Texas.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "And we met this Dane that they had given the name and address.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "And he, the next day, sent us to a construction company that was owned by a Norwegian called [INAUDIBLE] Construction Company.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "And he hired us, boom, right on the spot, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "And lied a, an inch or two, you know, but that was just-- they asked, can your drive trucks and can you do this?",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "And we said yes to everything.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "And we figured, we are not going to say no.",
      "word_count": 10
    }
  ],
