{
  "stem": "11641.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He says, you speak enough to check the papers and count it.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I'll need somebody else.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "So means more work.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, so I worked there for a couple months.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And one day-- one Sunday, we were walking with the baby, you know, in the street, take a walk on Sunday.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And I see somebody was playing ball over there.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "So I ask, who is playing?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "So they says, Team Hatikvah.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "It's a Jewish team.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So I said, where is the manager?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "To the manager, I says, look, you need any players?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "He says, you're a star also?",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Everybody who comes here is a star.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I said, I'm not a star.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "I says, you want me to play?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "I said, I'll play.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "Give me a pair of shoes, I'll play.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "So he gave me a pair of shoes, and I played half a game.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And I scored two goals, and we were leading two-nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And I get dressed, and I was going home.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "I says, where you going?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "I says, look, I just want to show that I know how to play.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And then we had a talk.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "So I told him, I says, look-- he was a very nice guy, Mr.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "Bernstein.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "Very nice man, the manager.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "So I said, look, I work in a place where I'm killing myself over there.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "I says-- I says, I don't mind, but I don't make so much.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 25,
      "text": "I  says, I'm looking for a job.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "He says, listen to me.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "The president of our club is in the garment industry, underwear.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "He says, I'll get you a job by him.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I said, look, I would like to learn a trade while I'm there.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "He said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "So a day later, he introduced me.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "We went there.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "He introduced me to him.",
      "word_count": 5
    }
  ],
