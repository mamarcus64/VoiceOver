{
  "stem": "26888.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "The whole thing was like a-- [PAUSES FOR 3 SECONDS] I don't know how to describe that.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And one SS came up, he said like that, listen, if you're going to scream like that, you see that big bonfire?",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "You're going to go there, too.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And he brought out the girl.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "She was shaved.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "She had a long dress on, with a German thing on it-- an apron, [NON-ENGLISH] [INAUDIBLE].",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And he said, if you're going to be quiet, you're going to look like this girl.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, we settled for that, because, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So t was true-- they took us.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And that place was a huge, huge place there.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And we're shaving, shaving hair, shaving everywhere.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "We had to pick up our clothes, get something, you know-- everything.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "There was nothing that you could keep.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Who did the shaving?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Germans.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "German girls, German men.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There was no difference, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was a horrible thing for us girls, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And the dogs, the German dogs, they were all around.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "All the time, you know, between us.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And we settled for that.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Then they took us in the blocks. bon oh, yeah, we got a pair of wooden shoes.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And of course, no hair, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I didn't recognize my sister after Auschwitz-- I didn't know where.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "I didn't see her, because, I didn't know, you look so different.",
      "word_count": 12
    }
  ],
