  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] And I-- and I recognized people that were close to me, dead.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "They were dead.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 12,
      "text": "Like our-- our neighbor, Salzman again, Salzman.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 13,
      "text": "And a little girl.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 14,
      "text": "It was the head of the little girl in the sweater, the angora pink sweater, that I could never forget.",
      "word_count": 20
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I can't even-- I can't even tell you the names of the people that I buried.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And the most, was the most shocking, that my friends, the Salzmans, they had a sister, and she run away with-- she was already married with a little boy.",
      "word_count": 29
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And it was a chubby little boy, and I loved him.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "He wasn't a year old.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "He was a very chubby little boy, and I used to like to play with him.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "So when-- this was November.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "This I'll never forget, November the 11th.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "Why, because we had at that time the first snow in '42.",
      "word_count": 12
    }
  ],
