  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "So he brought his socks that had torn, and I knitted and he took-- there, the kapos had like a little thing built from wood.",
      "word_count": 25
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "They was going inside.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "They were staying inside.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "So I went in, and he gave me food, the kapo.",
      "word_count": 11
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "And he was a murderer with a green sign, and he gave me food.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "And I thought, oh, I got something to [? help ?] here.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "And then a few nights being there, he came-- he came in back.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And he started screaming at me, going crazy.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And he-- he was sent-- he told me to get out of there.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And the same kapo took me to [INAUDIBLE], carry logs and shoulders.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "And I was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I was a temperature that time.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't believe in a person how he changed.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "He I saw I was darning his socks.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 8,
      "text": "He was helping with a little bit more food and then suddenly became strange.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 9,
      "text": "He was hitting me.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 10,
      "text": "He was starting to get out of that.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 11,
      "text": "And he-- he put me-- he make sure that I [? working ?] [? hard ?] carrying those logs on me.",
      "word_count": 21
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So what happened, I was-- got so sick, and I was sent in Buna to krankenbau.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "That means sick house.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And when I went up on the-- in kranken house, there were Hungarian doctors.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "And what happened, I was climbing up to go.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I was on the second bed to go up.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "The bed is wood, and I fell down and I fainted.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "So I hit myself, but those Hungarians doctors saved my life.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "They-- they got me back.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "I was-- I fainted.",
      "word_count": 4
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "They got me back, and when I woke up, I was full bandage [INAUDIBLE].",
      "word_count": 14
    }
  ],
