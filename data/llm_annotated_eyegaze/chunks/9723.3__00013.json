    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "So they could write to me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "So I uh-- I-- I-- I remember I came on leave for about a day or so or two.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And finally I was discharged.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "I went to school for some-- for a brief period of time.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Uh, and my mother contacted her sister in New York.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And she started-- uh-- um-- to make a-- to try to bring her-- us to uh, to the States, which was not easy.",
      "word_count": 23
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "Nobody could leave Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So finally, the-- it was decided the only way to get out was to illegally leave Poland, go to Germany, the occupied of Germany-- part of Germany.",
      "word_count": 27
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And uh--",
      "word_count": 2
    }
