{
  "stem": "25834.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Going through the German part of the Poland, in the Vistula River, was capture-- I mean is arrested and sent to a place, where, during the war, four years, was working on the farm, big farm [PAUSES FOR 3 SECONDS] in the west part of the Poland.",
      "word_count": 47
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And after the war was ended, my father and my mother meet together, at this time, in the camp and come back to Warsaw, married.",
      "word_count": 25
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And I was the first child.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And my father was working for state [PAUSES FOR 5 SECONDS] company, mean was working like a sailor in-- on the ship on Vistula River.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Not-- my father was working later there in state, big place, where they all was built, the ships.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And that was a couple years.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And later, there start a small business, small factory.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "That was the latest time.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "That was 19-- [PAUSES FOR 3 SECONDS] --30, 1940, something like this.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Warsaw, in a part, the old part of the old town, very close to the king castle in Warsaw.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Ah, apartment was like, you know, this time people like my father start organize own life.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And this was other child, like Irina and also the next one.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And the apartment was not big.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Was two and-- two-- three-- three rooms and kitchen, something like this.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And we was small family.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Save the money.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Probably, that's my father was doing.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And that was one of the nicer part of my life.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Because we was close to the Vistula River.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Each evening, after we grow a little bit up, we go with our parents on the Vistula boardwalk.",
      "word_count": 18
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And if I look back, that was one of the nicer part of my memory.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "My father was very honest man.",
      "word_count": 6
    }
  ],
