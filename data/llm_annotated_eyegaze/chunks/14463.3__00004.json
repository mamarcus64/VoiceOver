{
  "stem": "14463.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "So my mother and I were lying, you know, one next to the other, and my uncle, my auntie, and the two boys next, 50 people to a hut.",
      "word_count": 29
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And down in the bottom-- it was very picturesque, very beautiful.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Down on the bottom was a little river, you know a tiny little river.",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And it was under the auspices-- there was-- the guards which where there was not ordinary police, you know, civil police.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "It was the [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And the [NON-ENGLISH] there was not only [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "That was the-- the what's the name?",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "The department which looked after spies-- you know, there was the secret police.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And why we were under the secret police?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "Because-- because we didn't want to take Russian citizen, therefore we were spies.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "We were enemies of the country, enemies of Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "The Jewish people-- enemies of Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "You know, and that's why we were under their control.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "How long would you have spent in this encampment?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Till the war started between Germany and Russia.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It was, I think, another year-- actually, 14 months.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I can remember now, 14 months.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Now what was the job in there?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The job in there was that they took the people-- and we were laughing.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "At the first day, we were laughing.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Because well, there was a lot of doctors, and a lot of accountants, and lot of business people.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "They never saw a axe in their hand.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "They never saw a saw in their hand-- took them into brigades, six people to a brigade, into the forest.",
      "word_count": 20
    }
  ],
