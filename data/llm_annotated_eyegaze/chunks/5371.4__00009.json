{
  "stem": "5371.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "There was a pogrom in Poland before the war in Przytyk.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "There was a pogrom.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And yeah, there was a big pogrom at Przytyk, and he was the head of that city.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And then he was transferred to our city.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "So this burgermeister-- I'll call him burgermeister-- took the license away from my uncle because May 1st, they hung out a red flag.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So he was not allowed to practice law.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "May 1st is the labor, labor holiday they celebrate in Russia.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They also celebrate all over Europe and all socialist countries.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So May 1st they used to hang up from their place where they had their, their rooms.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They hung up a red flag.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And actually, with the Star of David, but it was a red flag.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And so he was stopped from practicing the law.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "So my sister used to help him.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "She used to-- whenever these-- farmers, mostly, used to come to him.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "So they told him their, their [INAUDIBLE], I mean their, their story, and their case.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And my sister used to type it on a typewriter-- my oldest sister.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And then they went with that court.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So I went down to that building to see that man, Mehler And he knew my uncle very well because he himself was a communist.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "He was already sitting in Poland before the war and, and imprisoned for being a communist.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And I went in there and I told him who-- because I was a kid, so he didn't know me-- but I told him my name.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And he says, oh, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I knew your uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I knew your father.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So I-- he's said to him-- he said to me that he can put me up here in the building.",
      "word_count": 20
    }
  ],
