{
  "stem": "23599.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Everybody-- I wanted to go to America.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And I had my relatives there.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And so everybody after the war, whoever one survivor met another asked what are you doing?",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know what to do with ourself.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So I-- once I'm in the street, and I met a guy that I knew from before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And we, again, we ask what are you doing, and how are you.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And he says, oh, I'm very happy.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I got-- today, I got a-- a visa to go to Mexico.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And when I have the-- you can go to Mexico, I get the transit to the States.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And I have my-- my sister there.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And then I'll be in America.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And then you won't have to worry anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I said, oh, that looks nice.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "It sounds nice.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "Can you get one visa for me, maybe?",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "He said, well, I can inquire.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I had to pay for it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "But I say never mind.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "If you can get, get me visa.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So he-- next time he went to Warsaw-- that was in Warsaw.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And he knew they're somewhere.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And he comes back.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And he says yes, he can get it for me.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I wish I remember how much we paid.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] I don't remember now.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And he came back, and he-- and we bought two visas, one for me and for another cousin.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "To Los Angeles.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "There-- in Los Angeles and San Francisco where my father's family.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He wants something from you.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
