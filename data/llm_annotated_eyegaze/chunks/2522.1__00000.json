{
  "stem": "2522.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I am Paul Strassmann.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "S-T-R-A-S-S-M-A-N-N.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My date of birth is January 24, 1929.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Trencin, Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Trencin, since early in the 12th century, has been the district town from which the surrounding villages derive trade, support, legal services, courts.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "All the institutions were always in Trencin.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "The military has always been in Trencin.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "In the '30s, it was a town of about 8,000, maybe 9,000.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It was a small town nestled against a big fortress, which was dominating the town, which was built around the fortress.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "The fortress [PAUSES FOR 3 SECONDS] goes back, perhaps, to the eighth century-- has been rebuilt over and over again.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And the Jewish community in Trencin had a large synagogue because the Jewish population provided much of the trade and services for the surrounding countryside.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My family was-- has been living in Trencin since the late 1890s, maybe 1885.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Neither my father nor my mother were born in Trencin.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They were born-- my father was born in [NON-ENGLISH], which is a small village not too far from Trencin.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was born in Budapest.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I have one sister.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "She's still alive.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "She still lives in Trencin.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "She never left Trencin.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "So there's been this long continuity in there.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My father was a young lieutenant who retired from the Austro-Hungarian Army in 1918 and established a small business, a food business, a food distribution business.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And he just grew that business during the '30s, during the prosperity of the Czechoslovak Republic.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father went into the First World War as the commander of the local battalion and created close ties with men who were his non-commissioned officers from the surrounding villages.",
      "word_count": 30
    }
  ],
