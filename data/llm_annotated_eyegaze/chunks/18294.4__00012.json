{
  "stem": "18294.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So we have to fly to London, to pick up the paper there.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "To go with a Russian plane, there was no such a thing like a Russian plane then, maybe now.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And we went, we get the papers.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And we had two-- like three days in Moscow, three days in Vilna, three days in Riga, and three days in Leningrad.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "So we come to Moscow, when it was the Russian.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And when you come to Moscow, you have to declare how much money you have, what rings you have, jewelry what you wear, everything has to be declared there.",
      "word_count": 29
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "So we declared, and we went into Moscow, and we paid here in England.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Everything was paid, for luxury hotels in Moscow.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Everything perfect.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And we were still afraid, whatever it was.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Then when we went in, we landed in-- in Moscow, and we meet two couples, one was from Canada, a Jewish couple, one was from England, no Jewish.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And we all six keep the two weeks together.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "We so close to each other, that I went last year.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "I visit them in England.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And nine-- and five years ago, we went to visit them in England, and we make a tour in Scotland.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "So we have to wait six days.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "So we ring them up.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They left us the key.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We went to the brother, [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "We was very close with them.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And they keep us there for a week.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "We went with them.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "Till now, we're still in contact.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And did you go to Vilna?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I went to Vilna.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I went three days in Moscow.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And from Moscow, we went to Vilna.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "We find we was-- really we took a taxi by ourselves, with one.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We was traveling around Vilna.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "At first we went to Ponary.",
      "word_count": 6
    }
  ],
