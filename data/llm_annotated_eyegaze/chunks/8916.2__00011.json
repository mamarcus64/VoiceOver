  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And then she had to go and live there, near the-- in this camp.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "It was a labor camp.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Always, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "But the thing was, you know, at the time, these things were happening and no one had any control over this.",
      "word_count": 21
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "There was no control over it.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "There was no-one-- there is nothing anyone could do.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "And it was the same and even worse to, say, escape from-- from the ghetto, for example.",
      "word_count": 17
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I could have-- I slipped out of the ghetto many times as a child.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "And I didn't look much Jewish, so people didn't pay much attention to me.",
      "word_count": 14
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "But I couldn't stay out there, because I would be discovered, sooner or later, and be turned in.",
      "word_count": 18
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Already?",
      "word_count": 1
    }
  ],
