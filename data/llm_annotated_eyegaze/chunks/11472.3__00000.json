{
  "stem": "11472.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We're running.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "We're running.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "You know, we-- I used to-- my grandmother used to teach us poetry.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They taught us Tanakh.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "That's the Hebrew history, you know, the, the Bible.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Whatever they remembered orally, they would teach us.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Because in the dark-- yes.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "No, because I just went-- I, I, I didn't know Hebrew yet.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But I-- but my, my mother would sit and tell us the stories.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We were told about King David, about King Shaul, you know, and about the, the Shofetim-- that with the prophets, and-- because they had to keep us occupied.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And they taught us poetry.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And what happened was that I would study the poem.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And my sister was so smart that she knew before me, my little sister, Sima.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And we would sit and sing.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And you know, the children, we were the entertainment committee.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] Anyway, we were running.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "We came up to Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "We came to her home.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "She had a barn.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "My aunt brought us up to the barn.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "In the morning, she went down.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "This is in Bilcze.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I really don't know.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I will look it up for you.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Near Korolowka, a few miles away from Korolowka.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "It's a village, a big village.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my grandmother was born there.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And my grandfather, he used to handle, he used to deal, do business with all these people there.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Anyway, this woman says, that yes, yesterday that she, she knows the people-- my, my aunt told them what happened.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "She says, yes, in fact, the Germans gave them to the Ukrainian police.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And they're holding them in jail and that the Ukrainian police is going back.",
      "word_count": 14
    }
  ],
