{
  "stem": "1282.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "If you went either to Bucharest or to Budapest, the agencies, Jewish agencies, organized themselves, those that survived being deported, the wealthier Jews, and immediately started assisting those people that came back from camp.",
      "word_count": 34
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "So my sister went there to get a certain amount of money.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "It was the equivalent of $250, something like that, to start life again.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I went to Budapest.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "Then when I started going towards Bucharest to search for my sister, I heard that she is coming to Budapest to look for me.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "That time, I came home to my little small town in Czechoslovakia, to Sasovo.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "And I left posters and notices in the railroads and notices with anybody, whoever sees my sister to tell her that I am at home.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "I am not leaving home, 'til she doesn't come home, because we'll be chasing each other forever.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "When I got off the railroad, two Jewish kids grabbed me and they brought me into my distant relative's house.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And he says, you're not going into your own house.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Why am I not going to my home?",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "He said, because everyone who tried to recapture their houses was killed.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In your house there are six, seven Gentile families, peasants, that their homes were bombed out.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "You'll be dead tomorrow morning if you try to get back your house.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "So they brought-- brings me into a huge house.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And what happened, the house was full of bedding, grain, food, no furniture, with these instructions.",
      "word_count": 16
    }
  ],
