{
  "stem": "11472.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The first day of [NON-ENGLISH], early in the morning, I was sleeping, and my sister, Sima, was sleeping.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "The grownups, perhaps they were up already.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "But my grandmother was standing, and she heard noise.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "She heard running.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "My mother tapped me at the shoulder, and she told me to get up.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "She grabbed my sister, and we went into our bunkers.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "Each one of us, since there were six bunkers in the house, all the people knew which bunker to go to.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "Everybody ran to their bunker.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "As soon as we got into the bunker, we started to hear running.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We started to hear shouting, shouting and screaming and shooting.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "And then all of the sudden, we started to hear shooting.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "With shooting, we knew it was an aktia.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "As long as I live, I'll remember that day.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "I was laying and shivering.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "I couldn't stop shivering.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "I was so scared.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "My grandmother was sitting next to me because it was, you know, our bunkers, we dug out a small little spot for all of us to sit.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "My sister was a baby, she's three and a half years old.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "Anyway, we hear screaming, we hear dogs running.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "And we hear the Germans are in our barn.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "They came in.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 21,
      "text": "They searched the barn.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "And the aktia is going on and on.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "All of the sudden-- we figured already they were here, maybe we're safe-- all of the sudden, we hear German talking, Polish talking, Jewish talking.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And people are in our barn.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And we hear German talking.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "And the Germans spoke very loud-- you could hear them.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "What happened was, they caught a family that lived next door to my grandparents' house.",
      "word_count": 15
    }
  ],
