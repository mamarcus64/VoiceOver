{
  "stem": "1387.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "It took a long time until I received my permits to come to the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "In that respect, I was also lucky, because I was born in Czechoslovakia, and the-- the Czech quota was much larger than the people that were available from Czechoslovakia.",
      "word_count": 29
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "My wife, Dora, was not able to get a certificate to come to the United States because she was born in Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "But I refused to accept mine until she comes along.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "So in November of 1947, I got my certificate with my wife to come to the United States.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I waited 22 months.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Not from liberation.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "From-- from the day I arrived in Italy.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I spent 22 months in Italy waiting to get to a permanent place to--",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, I-- I was liberated, as I told you, in-- in 1944.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So I came to the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I was-- [PAUSES FOR 3 SECONDS] I lived with my family for a few months on Dumont Avenue in Brooklyn.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I gotta tell you that my times in the United States were not easy.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] First of all, I knew no English.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I went to a night school in Brooklyn, [PAUSES FOR 3 SECONDS] and I couldn't find a job.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "My brother-in-law was in the oil business, and he rented some space for his trucks-- for the oil trucks-- [PAUSES FOR 3 SECONDS] on Dobbin Street in Brooklyn-- in Brooklyn, Greenpoint.",
      "word_count": 31
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And I was able to get a job in-- in a body-building place.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Let me go back a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I was first taken to a company by the name of Metropolitan Distributors.",
      "word_count": 13
    }
  ],
