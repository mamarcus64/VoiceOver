{
  "stem": "95.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "There were-- they were, like, again, 50 to 60 women who would work, again, in the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "There was in a-- we did not have a hospital in Ottmuth, but we had a hospital in Blechhammer.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "The laundry, the kitchen.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "Talking about being sick, hospital-- in Ottmuth, we had one doctor, a dentist.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "He was-- he was the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "He was Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "He was the doctor of the camp for the 150 people who stayed.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "He was such a nice person.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He was so nice.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "He was-- I was sick-- during our entire time, 31 months in camp, I was sick once with a fever.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And for two days, I did not go to work, and he gave me some aspirin, and then I was fine.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I had a toothache, and he filled that tooth.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "That stayed fine until I came to France five days-- five years later in France, I had to change the filling.",
      "word_count": 21
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "He was such a sweet person.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "That gave you really a way to want to live, because there are great human beings.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "I saw some remarkable people who will help you, will give you courage.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "That's-- that's really-- that's what keeps you alive.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Anyway, in Blechhammer, we are put into barracks and we go to work.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "Again, I'm very lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "The Judenalteste from Ottmuth, who loved me because I was singing, goes to the Judenalteste in Blechhammer and says, this little kid sings quite well.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "He's a great entertainer.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "You should-- Every Sunday, they had a special barracks for the elite, for the kapos-- for-- for-- not the Germans, yet, not the Nazis-- for the-- for the kapos, for the Judenalteste, for these people.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "Some people would entertain.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "And again, I'm entertaining in-- in Blechhammer, and loving it.",
      "word_count": 10
    }
  ],
