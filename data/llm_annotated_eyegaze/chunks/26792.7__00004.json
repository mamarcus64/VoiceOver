  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I kept word.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "So the first time you could do something was about this subject was in Sweden when you have your report?",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Not exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I started with it in Riga when I was pregnant with Shulamit in 1948.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Shortly before I gave birth to her, I met in the street a Latvian man who was my neighbor in Goldingen and who led the killing of all Goldingen Jews, [INAUDIBLE].",
      "word_count": 31
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I thought he was in Germany, but he was in Riga.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "He jumped onto the train car.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I jumped after him, and I accompanied him.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He didn't notice me.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "He got off.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "I got off.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "He went into the house.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I went after him.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I went to [INAUDIBLE], and she took me for a Latvian.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I said, you know, I know somewhere in this house is my friend [INAUDIBLE] must be living.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Perhaps you know where he lives?",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And she told me where he lives, in her house.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And so I have a friend who was in the [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was a special organization who were looking for war criminals and for war crime-- punishing war crime, and I told him the story.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He's from Goldingen.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "The man was not arrested.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "He had-- he had been in prison in [INAUDIBLE] but he permits them to work as a KGB agent, and he was released.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And this was a very bad feeling, my first bad feeling about the war crime and the Russians.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They didn't care if Jews were killed or if they were not.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "So started in-- in the full sense meaning of the word in-- in Sweden.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Here in Israel, of course.",
      "word_count": 5
    }
  ],
