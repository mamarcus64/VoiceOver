{
  "stem": "3277.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And in the morning, when you get up, take the other one.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I slept very well.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And even so, I was excited-- I slept.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I came to the-- to the-- to the ocean-- to the no, to the-- to the-- to the sea-- Baltic Sea.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I'm telling you-- so much noise.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Because this was the border, and so much-- so many dogs, you know, barking.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And then two-- two Polish officers came in-- give-- show-- give me your passport.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I gave him my passport.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I looked-- I looked at him with one eye, and one eye, I was reading the-- the Austrian-- the Austrian magazine.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And I make myself believe that I don't care too much about what he's talking to me.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And he took away from me the passport.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Then, they came in, those guys, who take care on-- money, or the luggage.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He said, open the luggage.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "And then I said, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Because they were very nice to the other countries-- showed them that they are very democratic, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Toward-- to their own people, they're very rough.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "No, he said to me, do you have any money?",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And this guy gave-- the diplomat, gave me some money.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "I showed that.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And he said, ah, that's nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "It's OK.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Then came three soldiers.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And they said, get out of your seat.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "They took off the seat-- they were thinking maybe somebody is under the seat.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And they took off-- Of course, take it sometimes.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "Then the captain who took my passport, he came back.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I recognized by the collar.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I was-- I felt very strong after the-- after the Valium or whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I pulled out my own passport.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And it took some times, you know, and went into East Germany.",
      "word_count": 12
    }
  ],
