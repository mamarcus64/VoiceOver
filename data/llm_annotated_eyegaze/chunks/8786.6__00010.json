  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "But I was the head designer for the-- for the Apollo emblems, the patches which their astronauts wore on their uniforms.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Apollo 8, 9, 10, 11. 11 went up. 11 landed on the moon. 12, I did. 13 I didn't do anymore.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And then 13-- Apollo 13 had an accident-- not because I didn't do the patch, but it's so it did happen.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "'69?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I still have the original patch.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I still have the patch.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It's in my room.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "I hope I have it in my room.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So, this-- I became a designer in the embroidery field.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "The company went broke, and I-- and I got a little bit older, thank [PAUSES FOR 4 SECONDS] But I'm still active, I still draw, I still sing, and I still try to do-- I wanted to ask you, is there any message-- well, I think we're going to pause now.",
      "word_count": 51
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "OK We're going to go--",
      "word_count": 5
    }
  ],
