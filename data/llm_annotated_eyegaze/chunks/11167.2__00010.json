{
  "stem": "11167.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 467.7,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "We get from the army vegetables.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I used to run away.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "I was so ashamed.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Ashamed of what?",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] You haven't got-- [DRINKS] [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "She didn't see me.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "She came and she said, I will never speak to you.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "You mustn't be like that.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, she did help us a lot.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "They also didn't have.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "But they did have at least, they did have more bread.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And the vegetables did give them.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Some carrots and cabbage-- and then they used to-- to cook and to make something.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "She used to say, I've got enough to divide it.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have even what to cook.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "What can you cook?",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "You haven't got a pot.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "You haven't got nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "That was in Namangan.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We had a half a kilo of bread with the factory.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And then they used to make a soap from-- from tomatoes, from green tomatoes.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And after this soup, we-- we used to, excuse me, sit in lavatory.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And the lavatory wasn't a lavatory then.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "That was a problem.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You didn't have even a little paper to wipe yourself.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "You didn't have nothing-- no newspaper, nothing, because that cost money.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah, [?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Galia ?] met the four or five days after I was in Namangan.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "She gave me an address.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "I think she was very shocked to see me.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I did look.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "But I cleaned up myself.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "He bought some from-- from sacks.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "You know, we made a little something to-- to wear-- you know, to-- to look--",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Sacks--",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "--made something to wear it.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And we-- I washed my clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I did look better than I-- than [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And her sister did help us a lot-- a lot.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "She used to give us bread once a week.",
      "word_count": 9
    }
  ],
