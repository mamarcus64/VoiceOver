{
  "stem": "26609.17",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It was a half a city, [NON-ENGLISH] Nuremberg.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "So when I started to work in [NON-ENGLISH], I was still under the non-Jewish name.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And then I felt, something is wrong.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "After the war, and I still have to-- also many people kept the non-Jewish name even here.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "In Australia, I found a lot of people that they stayed as they are.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "I felt no.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "It's an insult to my family, I thought.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "If I want to get away from them, I go back to my name.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I'm Mehr.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I'm not-- and I was-- Wanda was an assumed name.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But because no one knew me as otherwise, I had no one left.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "So I put two, Ida Wanda.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "I was Ida Ida, first name.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And I started to work.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "Then I thought, no, I have to go back to my name.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I went to-- but we didn't have anything in [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "I had to go to [NON-ENGLISH], to Meiningen.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "There was a-- a-- like community center.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "And I came in there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "And they were mostly Hungarian Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "And I came in.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "And I said [PAUSES FOR 5 SECONDS] I want to go to the head of the community.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "They showed me someone there, came up.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "And I said, but, once at home-- as I said, my mother used to talk to the children Polish, because young children Poland-- in Lwow, mostly attending non-Jewish-- we didn't have Jewish schools there.",
      "word_count": 34
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "It was only one gymnasium on [NON-ENGLISH], where you had to pay a lot of money.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "Not everybody had could pay for the children attending that gymnasium.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "And they learned a little bit Hebrew there too.",
      "word_count": 9
    }
  ],
