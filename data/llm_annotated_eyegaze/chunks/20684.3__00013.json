{
  "stem": "20684.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "We used to also walk around somewhere and create a commotion and pretend that we're pointing at-- look, look, look, look and we're screaming and so on.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And everybody-- everybody would stop.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "We'd get up to 100 people looking up and they'd be pointing at it and looking up.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "They didn't know what they looking-- we were pointing at a building, like pretending that someone is jumping out of the window.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And we were saying, yes, they're going to jump out.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Look, look, look, he's gone inside.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "He's jumping-- jumping out.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And everybody would look around because we didn't have any toys in those days.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "So we-- we used-- he was smarter than I was.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "They were all his tricks.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "I've learned all those tricks from him.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And you point up and you know you'd have 100 people pointing and they all see see people jumping out of windows.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "And it was all just-- we just-- just took the Mickey out of them.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "We used to have some regular friends, too, we used see them at [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "[NON-ENGLISH] are people who don't have any home where homeless people drink methylated spirit or whatever and they-- in certain places.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "And they were very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "They were nice.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "We used to talk to them because most people didn't want to talk to us, kids from orphanages, you know, bad news.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "I mean, you might catch something if you talk to us.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "But they didn't mind, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "So they felt at home and we felt at home.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "So life went on in Paris like that until we came to Australia.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "We arrived in Australia in 1951, March the 14th, 1951.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My uncle guaranteed-- my uncle and auntie from Russia that my father married came here.",
      "word_count": 15
    }
  ],
