      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "You know, it wasn't-- we walked.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They were three Jewish men, but they saw, you know, three Jewish girls.",
      "word_count": 13
