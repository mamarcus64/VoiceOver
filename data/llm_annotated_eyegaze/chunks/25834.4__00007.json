{
  "stem": "25834.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Meantime, Wanda, Aldona was on the ground there watching what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Because, you know, right away, one to other said, there is a revision.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Mean is something, search criminal polizei.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Because the car was, you know, a criminal polizei car.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And, you know, we go from the third floor, we go two flight down.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And my mother start crying and please, the fellow and the chief there.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And happened the fellow was Ukrainian and said, you know what Jewish people did for my family?",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "My mother was, I don't know this-- the Jewish woman, and mean, this woman give me the change.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And you know what happened?",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "This fellow sent all guys down to the car and took the paper, took the money, and said me, go.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "You know, I go back.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "That was something there.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "[SIGHS] Because this was worst, like send me to the concentration-- send me to work someplace.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "That was, for sure, concentration camp privilege, something like this.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "That happened to me four-- that was two time arrested, and the third time this, and fourth time, you know, that was Flossenburg.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "How old I was, right?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I was about 24 years or 23, something like this.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "I not remember.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "It-- it was not one, two days.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "That was long enough and further from us.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "The first day was close to us.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "Later, there was other part burn.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I am sure it must be at minimum two, three weeks.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "I not-- I cannot give you the exactly date.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And it was-- was job for SS.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Mean, that was minimum two weeks, what I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "No, that's-- I never think that someday I'll be asked for this.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] But I go-- I passed this.",
      "word_count": 7
    }
  ],
