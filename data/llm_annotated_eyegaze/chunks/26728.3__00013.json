  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So they had-- there were still dead people in there, but they had taken the ones that were alive.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "But they all died.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And-- but they had-- all they had them was cut enough wire to get a couple of guys in there to get them out.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They left it.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They were instructed to leave things pretty much as they were.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Don't change anything until these people from SHAEF decide.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "What is SHAEF?",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Supreme-- Supreme Headquarters Allied Expeditionary Forces.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "That's what Eisenhower's-- that was what-- he was the supreme commander, and SHAEF was his organization.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Supreme-- whatever I said-- Supreme Headquarters Allied Expeditionary Forces.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "OK, this driver said-- first-- first he took me to this enclosure where these men had-- and he said there were 40, 50 guys in there, no clothes, no water, no food no blankets, no nothing.",
      "word_count": 36
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And they were dead, these guys that were still there, probably 10 or 15 had expired.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We're going to stop this tape now.",
      "word_count": 7
    }
  ],
