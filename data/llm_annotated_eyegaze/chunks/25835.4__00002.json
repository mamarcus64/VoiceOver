{
  "stem": "25835.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "And when we ran-- not walking, running-- around this circle, this SS man and this-- in the farming industry man, they show only by finger for girls.",
      "word_count": 27
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "They took me, my sister, and all young women.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Then other women were taken to other side to stay in Ravensbruck.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "In this moment, my mother broke.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And she fall down on the knee close to this SS man, begged him, take me-- in German language-- take me with my daughters.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "I don't know how and why-- he agreed.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And thank God for us because maybe she helped us survive.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "Then they took us again for this transport to Spandau.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "Sachsenhausen was main, main campus.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "But Spandau was small, very close to Berlin, 7, 7 kilometer only from Berlin.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And they brought us in the evening, [PAUSES FOR 3 SECONDS] were, were waiting for us in black uniform.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "This-- I don't know, SS or somebody-- some other animals with big German shepherd, with carabines, with everything, with whips.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Quick!",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "Raus, raus, raus!",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "They took us to campus, where it was, of course, wire on high voltage.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "A big, big building-- it was like place where before was wagons, trams-- wagons or something.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "Because still, we saw that this place was something else and covered with very thin [PAUSES FOR 3 SECONDS] roof.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "Inside was three bunks of beds.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 3 SECONDS] Infirmatory was very small for three beds-- infirmary, [LAUGHS] sorry.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "And everybody took place.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "One cover was again some, some-- no dresses.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 27,
      "text": "Only we received-- we took what we brought from Ravensbruck.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 28,
      "text": "And very soon, they took us to ammunition factory.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we know.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I heard in the same-- in Ravensbruck, my aunt, and my cousin, very close cousin-- but I couldn't find them.",
      "word_count": 20
    }
  ],
