{
  "stem": "18486.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "A tunnel under the ground.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I don't know, I would say the length of-- a little longer than this wall.",
      "word_count": 15
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "That's about 12 feet, I would say.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "10, 12 feet.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "They could crawl in.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Not-- not stand up, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, it did, that leaded to the [INAUDIBLE] reservation, where it came out, and where they could then--",
      "word_count": 18
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "--if-- if they saw-- looked out of the hole and saw that it was safe, then they could get out there and disappear.",
      "word_count": 23
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Oh, all the Jewish people, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "I myself with my children.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "And we had a studio.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "My first husband was an artist.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And we used that studio, also, very much for the hiding people.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "And then I always said that it was for my second husband, who was not an artist, but--",
      "word_count": 18
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Beg your pardon?",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "An-- an artist's studio.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "A painter-- painter's studio.",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "It was in back of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Very close.",
      "word_count": 2
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "I went there just last summer a-- a few months ago-- weeks ago.",
      "word_count": 13
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And then I went to see it and then they had added to the house.",
      "word_count": 15
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "They had built-- it was from here till, well, the end of this room somewhere.",
      "word_count": 15
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "But it was a place to hide.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "But it-- they could go in there.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "And they had-- there was-- there was a hole in a wall.",
      "word_count": 12
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "And it was so meticulously made that it-- it was a wall of from all wood.",
      "word_count": 16
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "And they had slid open one carefully and then you could push that away.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "And then you could get under that coal bin, which was outside.",
      "word_count": 12
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 7,
      "text": "And from the coal bin, in the tunnel.",
      "word_count": 8
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "No, you couldn't get in from the outside, because it had a lid.",
      "word_count": 13
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "It was a high coal bin.",
      "word_count": 6
    }
  ],
