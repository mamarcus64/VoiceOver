{
  "stem": "23774.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[BEEPING]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Adam Goszer, G-O-S-Z-E-R.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My birth name is G-O-S-Z-E-R, Goszer.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And first name is Abraham.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "August the 15th, 1921.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Korzec, K-O-R-Z-E-C.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Korzec was a small town.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We were about approximately 7,000 Jews in the city.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "It was a Ukrainian territory, actually.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "But we used to do business with the Ukrainian.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "The Ukrainian people used to do business with us, like, with my father.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I was too young at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And we got along very good.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Jewish life.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Jewish life, we had many synagogues in our city, or town.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 4 SECONDS] many Jewish organizations.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "It was actually a Zionist town.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Myself, I used to belong to organization called Betar, all my life.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "But there were others.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "There were [HEBREW], Halutzim.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And we had sports clubs.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Like myself, I used to belong to a sports club.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "I used to play soccer.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And I was an amateur boxer.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My family.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father died in 1932.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was left with three children.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Like, myself, my brother, and my sister, the immediate family.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And it was hard for a widow to raise children, but she somehow managed.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Myself, I went to a Hebrew school called Bet Sefer Tarbut.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My brother went to the same school, Bet Sefer Tarbut, but then he went to yeshiva, because-- because we had a famous yeshiva in our town.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "My sister was the youngest one.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "She went to same school, to Bet Sefer Tarbut.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "It was a private school.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, I was the middle one.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My brother was the oldest, then me, then my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was difficult for a widow to raise children.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But she managed, like I said.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we had everything, whatever we needed to immediate life.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "We had our own house.",
      "word_count": 5
    }
  ],
