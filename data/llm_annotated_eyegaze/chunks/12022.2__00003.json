{
  "stem": "12022.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And the war, the war is over.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We was going to the war.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "The war was over.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "Finally, we came to our town.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And they, they start to-- them soldiers, what they run away from the war [INAUDIBLE], they all were beat up to organize them and send them to, on the, for the, the defense on Warsaw.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I hear that.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I don't like that.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I don't show up to that organization.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "Maybe somebody was going that's voluntarily.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I don't show up.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "I don't wanted to be registered and to go on defense on Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "Because I know that's the end.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "It doesn't matter what kind of defense they are going to put together, it wouldn't stay too long.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I decide to do-- I came in the town.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Rovno, ?] then the Russian already.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And then we was waiting to see the Russians.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Then came one Russian soldier.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "When he said-- by ourselves together, all the soldiers-- it was a lot of soldiers, Polish soldiers-- and he said, you're all free.",
      "word_count": 23
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "You, you can go home.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "That time was the season for potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Said to dig the potatoes and everything, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And who was close went home by foot.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Or it doesn't matter how he, he can get.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I went and asked for a train to go to [?",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Vilna. ?] How far was [?",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Rovno ?] from [?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Vilna? ?]",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "A few hundred kilometers, naturally-- and they promised us to give us a train.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Just got, we've got to wait.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "By that time, we don't have any food.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We start to look for food.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I was with a few guys together.",
      "word_count": 7
    }
  ],
