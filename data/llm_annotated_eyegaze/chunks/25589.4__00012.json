{
  "stem": "25589.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I meet up with some nice people.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Who are these people?",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "They're nice people, Ma.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "She, well, what can you do on a, on a boat?",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I said, Ma, trust me.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I'm having a good time.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And the only guy-- the one person that knew that I had a good time was a steward.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "He kept me-- he kept me, feeding eggnog's in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "So I had a good time.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That was a nice trip.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "We got to Toronto.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "It was bitter cold, bitter cold.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "I remember, my brother-in-law picked us up from Union Station, and we got outside.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "I says, my god.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "This is cold.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And all I see is snow.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I says to my mother, Ma, what kind of a country are we coming to?",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Eskimos?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, my brother-in-law says.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "You'll be OK.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "It was on a Sunday that he picked us up, so everything was closed-- conservative, Toronto-- everything locked.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "She said, what am I-- I was homesick.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "I was homesick for about a year.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "But we fit in pretty quick.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "After a while I got to know a few people-- nice, nice fellas.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "They introduced me to B'nai B'rith.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "I joined B'nai B'rith.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And they were the ones introduced me to baseball, football, hockey.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "I liked hockey.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "We never played hockey back home.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "And they treated me nicely.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 13,
      "text": "We went to the baseball game, and we went to a place in the summertime.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 14,
      "text": "They took us to Crystal Beach.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 15,
      "text": "Yeah, that was the time where we hung out.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 16,
      "text": "Crystal Beach-- we go on a Friday night, and don't come up for air until Monday.",
      "word_count": 16
    }
  ],
