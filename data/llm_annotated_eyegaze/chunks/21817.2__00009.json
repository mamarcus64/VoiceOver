{
  "stem": "21817.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 31,
      "text": "And-- He was very-- he was injured very badly.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 32,
      "text": "He was dying.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 33,
      "text": "After the house exploded-- not the house.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 34,
      "text": "It was-- the house went on fire suddenly.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 35,
      "text": "And there were a whole row, all homes which went-- had the same problems.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 36,
      "text": "Some of the people did not go out at all.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 37,
      "text": "They were burnt in the homes.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 38,
      "text": "In, in my case, my father was badly injured and I was not injured.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 39,
      "text": "And I pulled him out from the house.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 40,
      "text": "The house burned down to pieces.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 41,
      "text": "And I was-- there was a field next to it, like you're growing potatoes or whatever.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 42,
      "text": "And I pulled him in between two lines where they plant the potatoes.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 43,
      "text": "And the German went through once or so.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 44,
      "text": "It was burning the street.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 45,
      "text": "The hounds-- the whole thing over there, the whole area.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 46,
      "text": "They left us.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 47,
      "text": "And I pulled him to the front.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 48,
      "text": "And then they took him to the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 49,
      "text": "And they told me, you go you go whatever you want.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 50,
      "text": "We'll let you know.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 51,
      "text": "Next day, I find out my, my father was dead in the hospital from the injuries.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 52,
      "text": "There were some older people, Jewish people, who came with me.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 53,
      "text": "And we took him to the Jewish cemetery.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 54,
      "text": "And I was present when he was buried.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 55,
      "text": "Now, I was left alone.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 56,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 57,
      "text": "But a family took me.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 58,
      "text": "[CRYING] A family took me in.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 59,
      "text": "They told me, you can stay with us.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 60,
      "text": "And they had-- they were selling corn, wheat, I mean farm products.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 61,
      "text": "And I stayed with them till about-- that was June till about October.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 62,
      "text": "But since I was already a grown up man in, in the German's eyes, I had to go-- they used to take me to, to work.",
      "word_count": 26
    }
  ],
