{
  "stem": "11075.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Of course, I didn't have a chance to go higher because in the small town in Mirkow, you know, that's, you know, was too-- no one went, you know, to a high school, only public school.",
      "word_count": 36
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And then we moved away to Cracow.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And in Cracow, my father has a store, a grocery store.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I helped him, also, in this store.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Before?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It was very-- very-- the Jewish community was very nice, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Almost everybody we know.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And-- and that's, of course, like life is supposed to be, like-- like a family, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It was not too-- was maybe about 500 Jewish families.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "But Cracow is a large city.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I was a skate-- I-- I-- I liked to skate.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I was skating on ice a couple years in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Then when we came to United States, I was skating.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And I teach, you know, my-- my and my daughter skating, also in the Rockefeller Center.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "When I moved to Cracow, I-- I help my father in the store till I was 18 years old.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And then I-- I went to the Polish army.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I was in the Polish army one and a half years from 1938 till 1939, just a few weeks before Hitler came to Poland, the war started.",
      "word_count": 28
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The army was not bad, because in-- I-- I was in the army in Cracow, and we lived in Cracow.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The six months, you know, I couldn't go home for a couple hours with the street train.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "But after, I could go everyday home for a couple hours from 7:00 to 11 o'clock.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "As long, to be back, you know, for at night.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My brother moved to Cracow, and my-- and my little sister.",
      "word_count": 11
    }
  ],
