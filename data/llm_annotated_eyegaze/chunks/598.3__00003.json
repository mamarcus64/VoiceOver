{
  "stem": "598.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "When they gonna go away, I'm going to deal with you.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I go in the barn.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "It's 4 o'clock in the afternoon.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I'm staying there.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The partisans are still there until the evening.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I'm so hungry, all day I didn't eat anything.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "In the evening, I see some pickles.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Some-- I grab the pickles, I didn't think much, and I eat four or five pickles.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Then I was so tired, I went in a corner over there in the barn, and I fall asleep.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Then I wake up with pain in my stomach.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And I cannot cry because they are staying outside the-- the barn, and they can listen to me.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "I open my shirt, I put my shirt in my-- and eating at my shirt from the pain.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Two, three hours-- I don't know how long [? in ?] the pain.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I eat up all the shirt with my teeth.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Then I threw up.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "After I threw up, I felt better.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "I went in another corner and fell asleep.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I was asleep all day-- all night.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "And next morning, she came and she said, the partisans went away.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "She gave me the yeast.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "I paid her the money.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "And I came-- and I went back up the 50 miles.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And from that little yeast, I made more yeast in bottles.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "I was going around to the farmers saying that I have yeast.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "You can make moonshine.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "Nobody wants to believe me.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "Nobody wants to take from me.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "One guy [INAUDIBLE] is the first one.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "He says, I'm gonna take it.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "If this doesn't work, you better watch out.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So he took from me the two liter.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And he made that thing for-- for moonshine, and it came out moonshine.",
      "word_count": 13
    }
  ],
