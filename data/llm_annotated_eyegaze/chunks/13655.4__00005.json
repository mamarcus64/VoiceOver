{
  "stem": "13655.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "That time, I would say maybe 20,000 Jews was in that train.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "The train was pressing.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "That night, it went out all the way to Treblinka.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "A friend of mine jumped out from the train.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "He came to Konstantynow.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "Not in Konstantynow, in the neighborhood, in [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes, you got it.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I got every date.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Every date.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "In 1942, this was-- this was two-- two days after Simchat Torah.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Motel Goldring.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "He's still alive.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "He's in Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "My friend, my [NON-ENGLISH SPEECH].",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "To me?",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Then I went-- when he came back and told me the story, then I had nowhere to go.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Then I'm sitting with two friends-- my cousin and my friend [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "This was Wednesday.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "I came to them Wednesday night, tell them the story what-- the message, what I got from Miedzyrzec to that Polack [INAUDIBLE] from [?",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Lodz. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I was sitting there, and we cried.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We cannot sit here.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We can not-- what we're going to do?",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "This was Saturday night.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "One boy, my cousin's boy, [INAUDIBLE], 10 years old.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "He came from Miedzyrzec.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "He was hiding himself in a cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And the grandpa was in cellar.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "After they [INAUDIBLE], the grandpa took that grandson, and they came to-- in our direction, in our neighborhood.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And he came to that farmer, and he told me, your sister, your brother-in-law, two-- and two nieces, they are alive in that basement.",
      "word_count": 24
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Because I was a couple days before in Miedzyrzec.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And he told me this.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Then I picked up myself, and I went in the daytime to Miedzyrzec.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] On the way, I hired a man, what he took me by horse and wagon.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "Unfortunately, I went through in a fire.",
      "word_count": 7
    }
  ],
