{
  "stem": "16792.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 26.4,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "They didn't know I was work in a coal mine or something, but they knew I-- I am in the Russian territory and in Lwow.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Because in this particular time, Lwow before was Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And Russia came in, they took it, because they don't want that the German-- they make agreement with Hitler at this particular time to take this particular part of Poland.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "That mean they divide Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Germany took a part, and a part took, Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "See, the pact was, normally, Russia said always that the Lwow, until Lwow, or a little bit further on belongs to Ukraina and belongs to Russia.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "But it didn't belong to Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "But they said that, and give us going in.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And this is the pact which Hitler made with Stalin in this particular time, that he will take Lwow.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Stalin-Hitler agreement.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Non-Aggression Pact.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "But Hitler didn't work on non-aggression.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Mother was speak Russian, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Was not-- not-- OK, I-- I spoke a little bit, but I learn Russian in the time when I was in the coal mine.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I learn Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I speak it in this particular time very good already.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Lot of Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No more.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I don't got payot no more.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "No payot.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "When I-- when I walk in Sosnowiec, by the company [INAUDIBLE], [PAUSES FOR 3 SECONDS] which they sold only to-- to people which making suits in factories.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I cut my payot.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I couldn't be in the store with this particular payot, because I haven't got any connection.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Tefillin, I got with me all the time, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I came home one time, and my third brother, [INAUDIBLE], don't want to talk to me.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Because I'm not religious enough to talk to him, even.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "We come from a very religious family, see?",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    }
  ],
