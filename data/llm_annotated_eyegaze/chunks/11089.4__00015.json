{
  "stem": "11089.4",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And I said, Doctor, I can't.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "I can't.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "I can't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "He says, you must swallow it.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "And people were yelling, give me a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "Give me a little bit.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "And that's how he revived me.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "He revived me.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "But I could never come back to my strength.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I left already, until the end of the war.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And one day, I got a message.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "The doctor wants to see me across the ditch.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "He's in the other camp.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "What happened?",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "He fell into typhus, the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Which doctor was this?",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Dr.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Weiss.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So I say, I can't walk.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I could hardly-- I put in my leg the mud, I couldn't pull it out.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] He saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "I have to go.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Finally, I made it to him.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And I say to him, Doctor, what do you want?",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "What can I do for you?",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "He says to me, they're going to take me to the hospital-- it's called the hospital, so it's just for the world-- so I want you to hold onto my stretcher.",
      "word_count": 31
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I said, what-- what is this?",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "He says to me-- I said, Doctor, I can hardly walk.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "You can't carry, you just walk beside it.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I says, what for?",
      "word_count": 4
    }
  ],
