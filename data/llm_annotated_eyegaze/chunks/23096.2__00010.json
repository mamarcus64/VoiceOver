  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 83,
      "text": "To see something like this-- [PAUSES FOR 3 SECONDS] we had never seen human beings in that condition.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 84,
      "text": "We had just been through a POW camp.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 85,
      "text": "And everybody looked halfway decent.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 86,
      "text": "I mean, they weren't fat.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 87,
      "text": "But they were alive and at least semi-healthy.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 88,
      "text": "But to walk into a place like that, where the people should have been dead months before, I, I don't think [PAUSES FOR 4 SECONDS] for a long-- for maybe hours that people, the GIs, really realized what, what they had walked into, [PAUSES FOR 3 SECONDS] maybe until the news of it got to the headquarters where, where they, they knew what was going on.",
      "word_count": 66
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 89,
      "text": "We, we didn't-- I mean, the ordinary GI doesn't know what's going on.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 90,
      "text": "We didn't know from one, one town to the next where we were or where we were going or what we were doing or what we were supposed to do.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 91,
      "text": "We just did it.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 92,
      "text": "[PAUSES FOR 3 SECONDS] We've got to stop now.",
      "word_count": 9
    }
  ],
