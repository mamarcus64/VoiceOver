{
  "stem": "23579.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.0,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "When we came from school, about two o'clock, not later, we had supper.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Supper was not at night like here.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But supper was between one and two o'clock.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "We had a woman, she was working 14 or 15 years, an old [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "A woman from the village.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And she was sleeping by us, and working.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "And she was cooking.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "And we had another cousin of my mother's, what she didn't have nobody in the whole world.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "And my father went, before the war, he went and he brought her in to our house.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And she stayed with us, and lived with us, till the end of her life.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So and I slept with my mother and father in the room.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We had another two rooms, small ones.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "This was for the servant.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And one was for Eshke, my mother's cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You remember the servant's name?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Aneczka!",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Aneczka.",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "You see, when I talking, you remember.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I remember like that, that about two years, three years before the war broke up, my mother send you to United States.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Because she had a son in the United States.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Aneczka.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "The woman, who she was working for us, from the village, she had a son.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And her husband went to United States.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And he took away her son from her.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "But after a couple of years, he began to write to us that he would like the mother should come to United States.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So my mother took her to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "She made a papers for her.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And she send her off to United States.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "What were the religious practices of the home?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My mother was very religious, orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "My father, I cannot say that he was very orthodox, but he loved her very much.",
      "word_count": 16
    }
  ],
