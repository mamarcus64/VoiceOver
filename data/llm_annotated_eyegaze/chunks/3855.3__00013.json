  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And on top it said, [GERMAN], which means, protective custody Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "In those days, we didn't have to be called Sarah and whatever, Moshe, whatever.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Every Jew had to take on this name.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "Carl Hirsch and my address-- and it was there that they were able to send me letters, which were censored.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "They opened every letter.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And they prescribed on the postcard that I was able to send them how many lines, how many sentences, in what form the letter had to be kept.",
      "word_count": 28
    }
  ],
