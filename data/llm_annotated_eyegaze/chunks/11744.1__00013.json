  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And this was absolutely-- restricted.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "There was no ration card, or no coupon that gave us the right to have any of that food.",
      "word_count": 19
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "So that food was simply deteriorating in the attic of that store, and nobody could benefit.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "So he put an ad in a paper, and announced to the population that as of Monday 8 o'clock in the morning, he would be distributing anything that he found in the attic.",
      "word_count": 33
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So at 8 o'clock in the morning, the whole population showed up [PAUSES FOR 3 SECONDS] in-- in front of that store, before it even opened.",
      "word_count": 26
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And then everybody left with a big package of whatever was there and was-- could be distributed to entire population.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I mean, until the last one, everything was given away.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And about half an hour later, the Gestapo came and picked him up and put him in a fortress.",
      "word_count": 19
    }
  ],
