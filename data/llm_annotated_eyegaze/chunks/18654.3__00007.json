{
  "stem": "18654.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "So I said, I have to get permission for this, which I did.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "So we went to Baker Street.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Bear in mind, I'd only just come back to London, and I didn't know London at all.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "So we went there, and she decided we wouldn't stay there after all.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "We'd-- we'd go back to Willesden Green.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "For some reason, she decided to walk.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "We would walk.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And it's quite a-- quite a long walk from Baker Street to Willesden Green.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "And all of a sudden, it was getting dark.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "She left me, and I didn't know where I was.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "I had no idea, and I had no money.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "And I-- I became quite hysterical.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "And she disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 23,
      "text": "I didn't know where she went to.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 24,
      "text": "Anyway, to cut-- I don't want to go into the whole details, because it's rather boring, I think.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "Eventually she turned up, and she insisted we would go back.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "I think she then took a taxi, and I went back to the hostel, and hid myself.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "I wouldn't-- in case she came back for me.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "I was so frightened.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "And another occasion she insisted I went with her to a lecture in the synagogue.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "A man had come from Israel to give a lecture.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "And she started to heckle, which was very embarrassing for a young girl.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "And people around me said, take her out.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 33,
      "text": "I said, I can't take her out.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 34,
      "text": "You take her out.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 35,
      "text": "You're bigger than I am.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 36,
      "text": "And then eventually I ran out, and again, I ran back to the hostel.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 37,
      "text": "I was so frightened of her, and hid in case she came.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 38,
      "text": "And then when it came to my wedding, she caused me a lot of problems.",
      "word_count": 15
    }
  ],
