{
  "stem": "198.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 315.4,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "We didn't know where we were going.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "But they sent-- they round them up and they sent them to Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "They closed the Lodz ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "I was hiding with my sister in a basement, and [SIGHS] all day, we were hiding.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "In the daytime, we wake up-- at night, excuse me, we were coming out for fresh air.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "We were so weak, no food.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "My sister used to say to me, leave me.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "I can't do it anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "I said, no, you going where I'm going.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "As long as I will survive, you going to survive.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "She said, no, leave me alone.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "Anyway, it was 1944, they liquidated the Lodz ghetto, they took us all to-- on a train to Auschwitz.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] I guess, we were very young and we survived somehow.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "When you're young, we survive.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was taken away in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "After my younger sister was taken away in ghetto-- this was 1944-- I was sitting at the windows and I turned gray.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I was staring to the window, and [SIGHS] I just didn't know what was happening to me.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I said, now it's no use.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I don't want to live anymore, no use.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "But somehow we stayed another year till everybody was deported from Lodz ghetto to Auschwitz.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My sister and and--",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "--I.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I still stayed with my sister.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I was with her all the years till we got in 1944, till we got into Auschwitz.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was killed right in the beginning, everybody.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "There were round-ups.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "We never knew what's going to be next day.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "We never-- we lived from day to day, we never knew what's going to be next minute.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "Who's going to be caught and who's going to be killed.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "We were not allowed to have any telephones.",
      "word_count": 8
    }
  ],
