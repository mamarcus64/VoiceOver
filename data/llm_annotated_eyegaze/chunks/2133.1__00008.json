{
  "stem": "2133.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But we-- [SIGHS] we tried to avoid to do that, you know, to wear it.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "So we-- we tried to avoid to go down the street.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "We were afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "[CLEARS THROAT] I-- [CLEARS THROAT] as I said that when-- when the Germans came in, then I was just about ready to graduate.",
      "word_count": 23
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And-- but everything stopped, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Couldn't go to school.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "There was just a certain percentage was allowed to go.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "I believe it around 6%.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Well, I just stopped.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And [CLEARS THROAT] we thought that we're going to emigrate somewhere, and if it's a possibility, that we can go out.",
      "word_count": 21
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So I took a course.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "They had several different courses you can take, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "And I took cosmetology up.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "I thought, you know, that I-- if I go somewhere, somebody suggested to me that it would be a good field to be in if you emigrate to some other countries.",
      "word_count": 31
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I always had the dream to come to America, because my mother was here-- and she used to talk about it-- in the 1800's and the-- and the early 1900s.",
      "word_count": 30
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "She lived in-- with my grandmother-- in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And she went to school there.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And she always-- you know, she spoke a fairly good English.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And [CLEARS THROAT] she always used to talk about America.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And her-- all her brothers and sisters remained in America.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "My uncle lived to be 94.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "He died in Los Angeles here.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And her sister died-- my mother's sister died in San Diego.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "She also lived in New York.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "And also, my father's family was all living in America.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "Only one brother was living in Europe, [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "My mother had only one sister.",
      "word_count": 6
    }
  ],
