{
  "stem": "26486.6",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "And we saw this road.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "We could see far, far, far.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And after, it must have been about 7 o'clock at night.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "It was still very light.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "We saw coming down the road, great big trucks, great-- about four of them coming down that road.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And we thought, my goodness, what's that?",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "It was the Count Bernadotte.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Were we happy.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We were-- oh, we were crazy.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We were jumping.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And there was-- in front of the cars there was a-- a-- like an ambulance, a big ambulance.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And he was in the first car, in a white car.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And we wouldn't let him get by.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "We wouldn't let him get by.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We were jumping in front of the car.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "He said, it's all right.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "He spoke English.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Don't worry, he said.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "I'm here now.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "You're OK.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "But that-- oh, her-- her name was Bines.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You want to know the- the- the mistress of-- her name-- you want to write it.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "B-I-N-E-S, Bines.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "She was there, and she was still hitting us with that bat.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "He was looking at her, and he couldn't tell her to stop.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "But she was still hitting us, because she saw we were so happy, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Anyway, he said, I'm not going to be long, but I have to go.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "So he went into the camp to talk to the commander of the camp-- that Bines' boyfriend.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Anyway, he went in there, and he stayed for a while.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And apparently-- now how true this is-- this is what we were told.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Don't tell me-- don't tell me it's not true or it is true.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I don't know how true it is.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "Apparently, he made-- he-- how do you say negotiate-- negotiated?",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Is that correct?",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "Yes, yes.",
      "word_count": 2
    }
  ],
