  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And next day she was taken to a place outside of the-- of the camp, and didn't return-- means they killed her.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "28, 29, pretty nice-- a working woman.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, with where-- with whether I performed--",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In Spilve, teenage-- teenage-- fourteen-- and the teacher, they were killed.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "You didn't have of this age.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "This one-- 28, 29.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The women were from 18 up to 40.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Oh, shortly, that is an episode to mention.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And the Russians are coming closer.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And we are very tense what will be.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "That is approximately August '44.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes I was with my wife-- yes-- my wife, obviously.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I brought--",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I brought her to the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Well, she was all the time helping me.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Too, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And-- and--",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We started-- we don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Will they liquidate us now or they will take us?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "The 2,000 Hungarian women, they brought-- they took them one day out, and we didn't hear about them missing or they were liquidated.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Now will they us liquidate, or will they transport us to Germany?",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "We were very tense.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We don't know any-- have any information.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS] There were few children in the age 10, 12 in our camp-- still survived.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I don't know-- nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "But the children ordered by the commandant of the camp to come together.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Some mothers said we-- we stay with the children.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And it's all right.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Go with the children.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "They were taken, and they were killed somewhere-- disappeared.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Not in Spilve.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "In Spilve-- this is in Kaiserwald.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They have the place in Spilve where the places there where they were killing the people.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In Spilve, no.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We don't have any-- any cases of human killing in Spilve-- oh, one case.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "If you want to-- [LAUGHS] --want to know, yes.",
      "word_count": 9
    }
  ],
