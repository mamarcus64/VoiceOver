{
  "stem": "18865.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 357.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "Not me, brought it for my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "So-- How long have you been dating before you got married?",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We-- this was in [PAUSES FOR 3 SECONDS] November.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And the following June we became engaged, and we married in September.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Three.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "When he left for overseas, we were just two.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And when he came back, we were three.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "When he left, we didn't-- I didn't even know I was pregnant.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And she was born [PAUSES FOR 3 SECONDS] 8 months and 27 days after we got married.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] My husband was gone 26 months overseas.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "To the Philippines.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Only days.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Actually, it was only supposed to be three days.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And then I contracted front-- trench mouth.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And they were afraid to send him.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And that's how after our marriage in California-- I went to California to get married, right here, Riverside.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And we were together for six weeks after that, because of this trench mouth.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And it was very infectuous, very contagious.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So it was only supposed to be from Friday 'til Monday.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "And we were lucky that we were together a little longer and he left.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "He was here.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He was to be shipped out.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We were supposed to get married in-- in September, in Chicago.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "But he was-- from one day to the next, he was shipped out.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "He was-- he left.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "He was in-- in Florida then.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And he called me and told me in German, broken German, that he was being shipped and I should come to get-- California.",
      "word_count": 23
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "My parents said, no way.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "You're not going to go away like some floozy or something.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "It's out of the question.",
      "word_count": 5
    }
  ],
