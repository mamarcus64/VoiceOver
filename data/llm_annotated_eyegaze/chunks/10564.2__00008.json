{
  "stem": "10564.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "He would tell-- let me say German came in, I need five people.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "So they didn't come to me.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "They come to him.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "And he get five people to work.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "Or you work there, or you work there.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "They needed somebody who knows.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Let me say, the Jewish said, listen.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "I need 50 people.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "Command the five.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "You, you go down there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "So they have a-- they call it kapo [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "In the Krakow-Plaszow concentration camp.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My mother was there.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And after I came in, I still was to wash myself.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "There was a latrine there.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I went in.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I washed myself really, truly with cold water.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Then I see my mother, you know, and my sister.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And my, my mother thought that I wouldn't be here, but I came.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, you could walk in.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "In the ghetto-- in the concentration camp, you could walk in.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "There was a section, woman's section, a man's section.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So we went to the woman's section there, and I saw my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "My brother, my brother went to Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "My brother went to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "One brother was in Russia.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And my sister was in camp.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I was in camp.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Auschwitz.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "He was sent to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They took him to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In 1942, in June.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And later, three months later, they took my brother to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I never saw him again.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So after, I got a job in a Steinbruch.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "What the job was there?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Another person with myself, we're supposed to drill a hole in the mountain.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Steinbruch is-- Steinbruch, that means when you drill a hole in a mountain.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "You blow the mountain, so you can have a gravel for the road.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "How would you put it in?",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we dynamite the mountain.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we dynamite the mountain.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Krakow-Plaszow.",
      "word_count": 1
    }
  ],
