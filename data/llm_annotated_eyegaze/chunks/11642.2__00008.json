    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 29,
      "text": "I went to the cemetery.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 30,
      "text": "I couldn't find the grave of my grandmother.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 31,
      "text": "But my grandfather was next to the rabbi from our town.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 32,
      "text": "And that grave was not only not touched, it was like kept up, like you would have done it now.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 33,
      "text": "And I took a picture from the grave, not me, a Pole, and he gave me the picture.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 34,
      "text": "And I came back.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
