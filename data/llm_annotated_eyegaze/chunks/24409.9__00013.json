  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Romanian is amazingly close to Latin.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I learned Latin in school, too.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And Greek, I have learned in schools [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "For many years, it was ancient Greek.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "But I could communicate.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "When I came?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Very matter of fact.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "These people, were very matter of fact.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They checked, and they interviewed me.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And they found that I'm really going to Venezuela.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I would have gone to Venezuela.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "If I couldn't have stayed in America, I would have been arrested there, probably, because the visa wasn't valid.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
