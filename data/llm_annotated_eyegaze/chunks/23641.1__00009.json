  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "And, she went to Sobibor, and I went to work for Falkenburg, and since then I never hear it, I never saw her.",
      "word_count": 23
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1942, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "The year or the month?",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Well, it was in 1942.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "There were the [NON-ENGLISH.] I think it was in after the summer-- right after the summer.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "Right after the summer.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, we went back to work, and then we already digged the channels.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "In the beginning they measured it out, and then next year we had to dig channels, that all the water from around should go into the channels.",
      "word_count": 27
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And that's what we did every day.",
      "word_count": 7
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Oh--",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Oh, what I knew?",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "I knew, I knew all of them, but now I-- I don't know them.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "I knew all of them.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "But you see, we were-- we were groups.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "Our group was the young, young boys groups, they used to call it.",
      "word_count": 13
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "The younger groups.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "It was girls groups.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "It was men's groups.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 8,
      "text": "Our group, we had a leader.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 9,
      "text": "And our group was the young-- the young boys groups.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And the group was maybe-- I would say, maybe 50 in the group.",
      "word_count": 13
    }
  ],
