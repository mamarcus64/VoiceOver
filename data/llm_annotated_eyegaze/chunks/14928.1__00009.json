{
  "stem": "14928.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "They have bakery stuff, like now they do, too.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "So they used to take it from the bakery.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And every Saturday night, we used to have to go to the Sunday-- mostly Sundays, because Sundays, the stores were closed.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "The bakeries were closed.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Sunday they did not allow-- the government did not allow to have open stores.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So we used to go to the stores and get-- collect the money.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "So I used to write down every day, when they picked up the bakery's stuff, and I had it in my books, and I went with the man, the owner, and collected the money from them.",
      "word_count": 36
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So this is where I worked first.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But then I decided it's too much for me.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Saturday night, when all the kids used to have fun, go to movies, theaters, or, or there was a studio that we went to dance and to discuss things, all kind of stuff, and I had to go after Shabbos-- even before, because when it was already after Shabbos, I had to open the, the bakery store, because people used to come by.",
      "word_count": 63
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "So it was too much for me.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I wanted to live a little bit.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "So I quit over there.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And I went to work-- maybe not right away, a week or two until I got a job-- sewing, so I just had to work five, six days a week.",
      "word_count": 30
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "I worked Sunday, Monday, Tuesday, Wednesday, Thursday, and Friday.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "So I had Saturday the whole day and all evening to myself.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And I could go wherever I wanted with the young kids.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "I didn't have to stay and sell.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't-- I mean, most of the kids were together, like groups.",
      "word_count": 13
    }
  ],
