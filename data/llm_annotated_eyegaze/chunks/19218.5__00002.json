{
  "stem": "19218.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And they all still live-- not-- I shouldn't say all.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "The grandchildren have all-- his sons and daughters still live in Costa Rica.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "But all the grandchildren-- not all-- my niece's grandchildren have all-- all living in the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They just-- they were young enough to appreciate what the United States has to offer.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And they all in here.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "They don't want to return.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They go back there on vacations.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "But they-- they all live in here now, in the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "Now, as I've indicated before, I had a wonderful life.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "I mean, my life actually began when I met my wife and when we got married.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "My wife, her name is Esther.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "And she worked side by side with me all through the years.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "I'm in the insurance business.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "I still am in the insurance business.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "We had three children.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "My oldest son, Lawrence, we call him Larry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "It's Lawrence David.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "My daughter-- Larry was born in 1955, February 2.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "My second one was a daughter, Dina Rochell.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "Larry is named after my father, [NON-ENGLISH], so, translation, Lawrence David.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "His name is [NON-ENGLISH] David.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "He couldn't be named [NON-ENGLISH] David.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "He couldn't be named [NON-ENGLISH] simply because my father-in-law was named [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "So his name is [NON-ENGLISH] David, my father's name.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "My daughter is named-- Dina is named after my mother and after my sister.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "Her name is Dina Rochell.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "And my youngest one is named after a-- on both sides, after our grandmothers.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "They were both Faiges.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "And that was my grandmother.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "So she's named Faye [?",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "Alene. ?] She's married.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 36,
      "text": "My son is not married yet.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 37,
      "text": "My daughter is in process of getting a divorce.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 38,
      "text": "And my youngest one is very happily married to Mark.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 39,
      "text": "He's a physician.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 40,
      "text": "He's a medical doctor.",
      "word_count": 4
    }
  ],
