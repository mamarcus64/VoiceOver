  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "And-- I said to the-- it wasn't very crowded at first.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "The only other people were some Greeks from Salonika, who ran the place, who, by the way, were very corrupt, unfortunately.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "They were Jewish, but they were in charge.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "And the little food we got, they stole a lot of it.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "By the time we got it, we-- there was very little left, you know, especially the bread.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "Bread becomes very-- becomes very important in-- in those circumstances.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "We got very little of that.",
      "word_count": 6
    }
  ],
