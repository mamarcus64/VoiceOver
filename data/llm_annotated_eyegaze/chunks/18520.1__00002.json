{
  "stem": "18520.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And you pass by on the sidewalk, this was Christians, no Jews then this area.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So they're always-- they're hiding in the-- in the-- in the-- in the building.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And we used to go in a group, because we knew.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "So we used to go 10 kids, eight kids, you know, together.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And then when we start seeing something already when you pass they hide inside, in the building.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "You know, they used to lock the doors at night, 11 o'clock they lock.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Because there are drunks and things.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "So everybody-- the, the guy who cleaned the sidewalk, this part, he used to lock.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "If somebody worked, after 11:00, he ring the bell.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And they used to pay him some money, so he came out from the house and opened the door.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So we knew already where they hide.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "So we-- once we, we pass the bad part, we start running already.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "So then they jumped out, and they're after us.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So they used to-- we used to fight.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "We used to get-- they used to have sticks and things.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But this is what happened, oh, a lot of-- Did anybody ever protect you?",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No protection, no policemen.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "They always come-- they came always when was already finished.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "When it was finished, then they showed up, what happened here.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I finished in Poland three, four classes, three or four.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "It was a, a, a, a Jewish school.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Public school, a public school.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Jewish support, philanthropists, Jewish people.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Only Jewish kids.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "They teach Hebrew.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "They teach general things, history; general things, everything.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Everything what a normal school--",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "My teacher was a woman.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And I was always-- a funny thing, I don't know if I can say this-- but it was a funny thing.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I-- she was very tall.",
      "word_count": 5
    }
  ],
