  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 25,
      "text": "So they themselves, the Wehrmacht and the Gestapo, went from house to house look for their achievement, to take away women without permits, children, and sick people.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 26,
      "text": "And the Germans find us [INAUDIBLE] occupied our block.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 27,
      "text": "We hide ourself under, under a staircase.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 28,
      "text": "For three days the white Russians didn't find us.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 29,
      "text": "Their aim was to find people as it comes, they find it.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 30,
      "text": "But they wanted to amuse themselves.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 31,
      "text": "And the Germans were not happy with their achievements.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 32,
      "text": "So they themselves went to the ghetto to look for those victims.",
      "word_count": 12
    }
  ],
