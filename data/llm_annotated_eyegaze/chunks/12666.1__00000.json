{
  "stem": "12666.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Demetrius, D-E-M-E-T-R-I-U-S, Dvoichenko, D-V-O-I-C-H-E-N-K-O, dash Markov, M-A-R-K-O-V.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My birthday is July 10, 1921.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Almost 75.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "In July, I will be 75.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Thessaloniki in Greece in the refugee camp.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Thessaloniki is spelled T-H-E-S-A-L-O-N-I-K-I, Greece, G-R-E-E-C-E.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in the Kingdom of Romania.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father was a guard officer of the Czar in the Crimean guard regiment in Yalta and Livadiya.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And he fought as a student, as a volunteer in the Russian-Japanese war, was taken prisoner by the Japanese.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "He also fought the Balkan Wars as an advisor, a military advisor, to the Bulgarian army in 1912 through 1913 in the war against Turkey.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "He fought in World War I, and he fought in the Russian Civil War over the White Guard Army.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And he fought also in Spain against the Communist and the monarchist forces of the [INAUDIBLE], which are the traditionalist Carlistas.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My mother is from the Don Cossack region.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Her grandfather was the Marshal of Nobility of the Don Cossack host.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "She had an academic career.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "She taught at the University of Bucharest at the Commercial Academy.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And then she came to America and she taught in Vassar College, Columbia University, [?",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Free ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "French ?] University, and University of California in Los Angeles.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Both my parents are dead.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I had one sister.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "She died recently in 1994.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And she lived in Switzerland.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She was married to a scholar who was active in Turkey.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And he disappeared during World War II, so we don't know what happened to him.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Childhood I spend, in the first six years, I spent in an area which today is called Moldova, or it is also known as Bessarabia.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And later on, I went to elementary school in the [?",
      "word_count": 11
    }
  ],
