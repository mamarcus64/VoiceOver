{
  "stem": "24958.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "You know, till we are-- till we got to Krakow.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Let me take you back a little.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Then we'll pick up over there.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "The day that-- that you were liberated by the Russians, was Oskar Schindler there?",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he--",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes, said-- he said, do you know you are-- you are-- you are free now.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "You can do-- and he-- now we had to save him.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "We had to save him, because he was in danger.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "As a German, when somebody would have-- so he put on-- they got a car for him.",
      "word_count": 17
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "His car was there.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And one-- a few-- a few of our people-- they-- he put on the-- the-- the-- this-- the suit for the camp-- the striped suit.",
      "word_count": 25
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And they-- they went.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "They wanted to take him to the Swiss border, you know, to save him.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And they got him somewheres.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "They-- they saved him.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "They saved him.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Very emotional.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Very emotional.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "We wanted to give him something to remember.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "So some was-- one of these-- one of the-- our haftling-- our prisoner-- he had some golden teeth.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "So they took out, with-- with-- with regular thing-- they took out these golden teeth from him.",
      "word_count": 17
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "And one of them was a-- a jeweler.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And he made him a ring, for this gold.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "He made him a ring, and he engraved in this ring, 'Whoever saves one person saves the world.' And they gave him this ring.",
      "word_count": 24
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, all of us were there.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "He was crying.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "He was-- he broke down.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And they took him away.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Though, they saved him.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "They-- he-- he was-- and we got-- everybody got on their way.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "One went to Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "One went to Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "One went to-- wherever they go-- the-- they think that they can.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In an apartment.",
      "word_count": 3
    }
  ],
