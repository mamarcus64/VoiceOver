{
  "stem": "25423.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, there was a Ukrainian paper, which was controlled by the Nazis and by Ukrainian nationalists, pro-Nazi nationalists, which provided the usual information issued by the ministerium, minister of propaganda.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "In the library in the city, there were German newspapers.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But it was dangerous for me to show that I speak German, so I kept away from it.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Radio was the same.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "There was some local radio, but most of the news came through hearsay and visitors.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "It was arranged for me to go and see him after I adapted to the environment.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And a mother superior, over the Brazilian nuns, took me by train at night-- which was very dangerous because she endangered her own life.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Her name was Monika Polanska.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Monika Polanska was a physician.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She was born in Philadelphia, a Ukrainian, and she was widowed.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And she sold her property and went back and became a nun and a superior of this particular house in Podmichalowce, was the name.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So she took me there, transported me with her.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And the chaplain of this monastery, Father Kiprion, kept my brother.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Because he also was being trained to be a Ukrainian, as you said.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "In order to put my mind at ease, I was there for a week.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And then when Mother Monika Polanska had to see a lawyer in a nearby town, she took me there.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we traveled by sleigh in the winter.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And from there, I went to another monastery.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Then, I didn't see my brother for a year, until I came back to Lwow.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And then he was brought to Lwow too, as the Germans were approaching.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "No, he took care of pigs.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Certainly not.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "As a boy, as an orphan.",
      "word_count": 6
    }
  ],
