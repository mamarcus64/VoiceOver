{
  "stem": "543.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "That was also a very, very traumatic experience.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "First, I told you I was living in Holland, like-- like wild-- you know, wild?",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We were just like everybody else.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "We were not singled out that we were Jewish and I was into-- I told you I was in a sport organization.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I was in a youth organization.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I did a lot of, you know, we were all active in-- in-- in other things-- sports and things like this and sailing and-- Name the youth organization that you belonged to.",
      "word_count": 32
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "The-- the-- the first one was the-- the ISC.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "That is the-- the-- the arbiters, like the workers youth center-- center.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And it was for working people, like you came together, and we went on walking things, and we-- we did all kinds of things.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And music, we played mandolin and guitar, folks.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Social group.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And all were the same.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "And it was-- there was all Jewish and-- and Gentile.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "It was not specific Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I was in the-- No, I did not in the youth organization whenever I went to Haamstede.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "But we did go swimming at the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "It's also like-- there was a youth sport group that was not the-- the-- the other group.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "So we were swimming and-- and all kinds of sports we did.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Mostly he painted.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Mostly he made a book-- like layouts, books, things, and--",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Painting, no.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He painted in the war, too, but he was sensitive about it happened.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He was very-- he knew [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He knew-- he was very, very afraid that time that they told the people would get picked up in razzias and things like that.",
      "word_count": 24
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "He made a lot of friends in Haamstede.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Haamstede was a small place.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "It was maybe two or three Jewish families.",
      "word_count": 8
    }
  ],
