{
  "stem": "21978.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 68,
      "text": "And the German people, when we met them later, during-- we came to Lubeck.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 69,
      "text": "Lubeck is a port in Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 70,
      "text": "How did we get there, I can't recollect.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 71,
      "text": "Slowly.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 72,
      "text": "And we were given money by somebody, probably some Unite-- international help or something.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 73,
      "text": "We were given accommodation in some school, and we were given some money.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I went to a hairdresser to have my hair cut.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The hair dresser didn't even want to do it because she saw us, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We were not really such good looking and clean looking.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We had washed and so on, but our hair didn't look so well.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "But they did, and we paid for it with the money that we have been given by-- Did she actually say--",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "They didn't talk to us.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "They did not know anything about what happened to the people.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Then I had a toothache, and I had to go a tooth-- to a dentist.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "He didn't know anything, and I had to pay him for this-- for service.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So people in Germany, well, they suffered themselves during the war, too.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And they were not very sympathetic because they didn't know anything.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "I mean, that's what they told us.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Eventually, we got on a truck in Lubeck, which took us, slowly, to Czechoslovakia.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And we came to Prague-- Prague.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And we were looked after by Red Cross.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We were accommodated in a school.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "We couldn't go to our home.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We found out that there were Jewish Joint.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "Jewish organizations started to try to find out through, I don't know, Red Cross archives or what, if somebody survived.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And we found out our family didn't come back.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "They--",
      "word_count": 1
    }
  ],
