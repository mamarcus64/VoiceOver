{
  "stem": "888.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "You know, Auschwitz, you know, and then I recall the people who would just hurry you down, you know, from the trains.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I remember the selection.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And me, my brother-- of course, I didn't even know if my sister was selected, you know, to-- or anybody.",
      "word_count": 20
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "Just me and my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They were separating us.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "The selection, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And of course I don't remember who, really, it was, if it was Mengele or-- of course everybody said it was Mengele.",
      "word_count": 22
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And of course, he always had an assistant.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And the children and my mother went to another side.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "And they took us into, to the camp, and you know, went into what they called delousing or whatever they called it.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Delousing, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And then, you know, we stripped everything.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And they gave us clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And-- pardon?",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "They cut their hair off, you know, and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Payos and, you know, with people with beard, everything was-- they sheared everybody off, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And they put us into a camp, into a barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I think I remember it was Barrack 2, if I remember.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "That's about it.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "And then we stayed over there for maybe a week.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I remember, if I recall-- well, I think it was the second day of Shovuos that they took us away, you know?",
      "word_count": 22
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I mean, they marched us to the train and they took us, like I said, to, to Plaszow.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Did you have any clue as to what happened to your mother and sisters?",
      "word_count": 14
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have any, any clue.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's just-- I mean, everybody was talking like in sign language.",
      "word_count": 13
    }
  ],
