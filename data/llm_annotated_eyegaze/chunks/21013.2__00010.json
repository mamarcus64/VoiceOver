{
  "stem": "21013.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "When you were in the boarding school, [PAUSES FOR 3 SECONDS] how many people were there?",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In the boarding house?",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Maybe 10.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It was like a little bed and breakfast place.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I had my own room.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I had a tiny little room.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I had seven suitcases.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And my mother packed in a hurry, because it-- I only had two days when Mr.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Jaretzki got me the visa.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So she packed.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I had seven formals, because she thought that they dressed for dinner in England, and 30 pairs of underpants, but nothing really useful.",
      "word_count": 23
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] So I had all the wrong things with me.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And that's how I came to that boarding house.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "What was the nationality of the people in the boarding house?",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I really don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Don't forget, I couldn't communicate.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "About three weeks.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "My parents didn't want to let me go.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "It was a tremendous struggle to make them let me go.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And we took a taxi to the airport.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "None of us had ever been on an airplane before.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "This was in 1938.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "People weren't flying very much.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] I-- neither one of us said anything.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "We just kissed and hugged and-- [PAUSES FOR 9 SECONDS] And I remember looking out the window of the plane and seeing them get smaller and smaller.",
      "word_count": 27
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "[CRYING] Anyway, it's so long ago.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "But it feels like yesterday.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 6 SECONDS] And then I was so enthralled with the idea of flying and it was so beautiful to be above the clouds and it was exciting.",
      "word_count": 29
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Everything was an adventure after that.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "When I was in England, I could telephone them and write to them.",
      "word_count": 13
    }
  ],
