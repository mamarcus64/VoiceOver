  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And maybe I will also tell you something about spiritual moments that are unimaginable and unbelievable in Wolfsberg.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "One day, these brothers, these-- these-- these lager brother, this camp brother that I had, his name is Tully Lazerovitch.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "He still lives in Israel today.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "These organizer who-- who could make some food of nothing, from under the earth, literally, when we would walk to work, he would jump out of the line.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "I mean, they shot you immediately.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "They-- they-- they would beat you to death if they catch you.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And he would go into the field, dig up something, and would come back with a blouse full of potatoes and then open my blouse and put-- stuff potatoes into them.",
      "word_count": 31
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And-- unbelievable how these men dared to do things.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "One day, he comes and says, Itzo, ooh, I have good news.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "What is the good news?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "He said, remember, you have gold coins at home.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "You left gold coins at home.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Now you have to tell there is a boy from our town who works in the kitchen.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "His name is Shier.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "You have to promise him that you're going to pay him.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "For every bowl of soup extra that he's going to give you, you're going to pay him a gold coin when we come home.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And he brings me a piece of paper torn from a-- from a cement sack, because there wasn't paper there, and a-- a small pencil, and I write my name, I, Izchak Goldblatt am going to give Shia-- so I don't remember his name-- Shia Berger, a coin for every bowl of soup that he's going to give me.",
      "word_count": 59
    }
  ],
