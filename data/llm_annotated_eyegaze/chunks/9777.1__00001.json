  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "My grandfather was a che-- a chief of the Hungarian railroad, retired.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "His name was Frank Pollack.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And this was his second wife, Eugena Pollack.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They had five children between them.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I had-- my mother was the oldest, and she became a nurse after the times being very bad in Hungary's financials goals.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And I had four uncles.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] One of them was called Emery in English, Emre in Hungarian.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Paul-- [PAUSES FOR 5 SECONDS] Bondy we call him for a nickname, Andor is the full name.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And the youngest one was called Lotze, Laszlo in English.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "From all those uncle just remained my uncle, Bondy, who lives still in Hungary, an early age of 92 or so.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In Pecs, the Jews lived very lovely.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They were comfortable to do, should we say.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "There was very few who were, should we say, a little bit less established, financially, didn't have good fortune or there were a couple of widow girls who had small children.",
      "word_count": 31
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "One or two used to go like aid days.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "This is a old European custom, to feed a meal for a deserving, poor child in a house where food wasn't that scarce.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "But beside that, the people were quite comfortable to do.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I went to the public school-- the Jewish public school-- this was a custom.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Only thing that was a bit difficult, we had to add on car fare for the street car, on account of she lived in the other end of town and I lived in a different end of town.",
      "word_count": 38
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "So this, my grandmother didn't appreciate that she had to add on the car fare to feeding the child.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My parents name was Klara Pollack Deutsch, and Karoly Deutsch, Karl in English.",
      "word_count": 13
    }
  ],
