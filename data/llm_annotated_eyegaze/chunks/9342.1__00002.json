{
  "stem": "9342.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "You went to a smaller city where you can--",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "I went to a bigger--",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "--where there were more Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "There was one, he was a rabbi, and he was the-- the-- the schochet, and he was everything.",
      "word_count": 18
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "The chickens.",
      "word_count": 2
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "So he couldn't do such a good job with the children, to teach them.",
      "word_count": 14
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "So that's why we moved away to a more Jewish city.",
      "word_count": 11
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Well, not much.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I--",
      "word_count": 2
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had friends.",
      "word_count": 4
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "My age.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "There wasn't such a thing in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "Not for the-- not for the girls.",
      "word_count": 7
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "Yes, my older brother.",
      "word_count": 4
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "Well, we observed--",
      "word_count": 3
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "--the holidays.",
      "word_count": 2
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Well, we went to-- my parents went to a different city where there were more Jewish people and bought the kosher and matzo and all that, because over there where we lived, there was no such a thing.",
      "word_count": 38
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "We had to--",
      "word_count": 3
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 1,
      "text": "We had too-- My mother had a sister there, in the same city.",
      "word_count": 13
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 2,
      "text": "I remember--",
      "word_count": 2
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Sister.",
      "word_count": 1
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "She had sisters and brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 1,
      "text": "So your mother had a sister?",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "And she would come and spend the Passovers with you.",
      "word_count": 10
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "And some maybe other people.",
      "word_count": 5
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember so well.",
      "word_count": 5
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 0,
      "text": "What I remember, I went to my cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 1,
      "text": "I was going to stay with my cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 2,
      "text": "I helped out sometimes in the house, sometimes in the-- she had a store, a grocery store.",
      "word_count": 17
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 3,
      "text": "So I went there and we-- and I stayed with them.",
      "word_count": 11
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 4,
      "text": "And when the war broke out, I had to go home because I didn't want to stay there because there was Oberschlesien, and there were more Germans then Jewish or other Polacks, so I went home to my parents.",
      "word_count": 39
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] And that's how it start.",
      "word_count": 9
    }
  ],
