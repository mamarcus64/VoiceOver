{
  "stem": "7722.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 21.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And from Bremerhaven, a military ship took us three to the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And we came to New Orleans with the boat.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And over there in New Orleans, the Jewish-- Jewish center over there, they came, they greet us, it was.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And they took us down.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And-- and we stayed over there.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And over there, there were already tickets from my cousin to come to New York.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "So from over there, we came to New York.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They were railroad tickets.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And we came by train from New Orleans.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "We came by train to New York.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We were over there in New Orleans a day or two.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They took care of us, and they were very nice.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They showed us the town, and they fed us.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I came-- we came to New York.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I decided I cannot be a-- a presser, regardless.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Regardless that cousin was very nice to us, really.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "So-- so I decided I'll-- I'll become my own contractor.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "And with this-- with this friend whom I became friend, [INAUDIBLE], he was already-- he came two years before me.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I thought he-- he spoke English.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "I thought he's a Yankee already.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know what.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So we decided, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "In the [NON-ENGLISH], in the camp, there was a guy who was from home.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He was a tailor.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He had golden hands.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "He could be-- he could be a designer.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "So I took him, and we bought a shop in Brooklyn.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "In Brooklyn, we bought a shop, and we worked like horses.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "What was the name of the shop?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No, a contract.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We had only 12 operators, that's all. 12 operators, and we worked the presses.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And we went-- and me contractor.",
      "word_count": 6
    }
  ],
