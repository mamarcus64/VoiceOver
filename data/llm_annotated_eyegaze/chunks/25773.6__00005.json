  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Masia ?] had great friends in Pruszkow who owed a pharmacy.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And you know, it-- it seems to you probably completely like a fabricated story.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "But this pharmacy was opposite this camp, and she said, I know this place.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "It has been for me many times-- this was a Polish girl who-- whose-- who parents and her husband run the pharmacy.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And she said, look, if-- if it is what I think, in any case, let meet-- let's meet opposite on the stairs.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Opposite this-- opposite this camp.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "She told us the number, which would-- if it should be this number, this is the pharmacy.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I'm almost sure.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "She inquired before if there is such [INAUDIBLE], and she found out there is such a pharmacy.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So she was almost sure.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "We asked the nurses, that there is a third girl who wants-- we want her to be saved with us.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "So first went [?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Masia ?] and disappeared.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "Second went I.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I put the uniform.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Believe me, I couldn't remember the name.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I couldn't remember anything.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "Nothing at all registered in my name.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "I went into this enormous square-- [BACKGROUND NOISE] --went into the enormous square-- and-- [BACKGROUND NOISE] --maybe somebody want-- maybe my daughter.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "So I should stop now.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "I want to this is enormous square-- and-- yes, in the kitchen-- and she-- and I was waiting for somebody, some invalid to come out.",
      "word_count": 25
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "Now-- now, look at the series of coincidences.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "Now, where we lived on [INAUDIBLE] Street in Warsaw, it was very prominent and right in the elegant [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "That was the heart of the town.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "It was a very elegant street.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "There, on the corner, we-- we lived.",
      "word_count": 7
    }
  ],
