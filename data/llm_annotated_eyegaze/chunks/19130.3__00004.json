  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So [SOBBING] this way, [PAUSES FOR 5 SECONDS] we got together the brother.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "[CRYING] [PAUSES FOR 4 SECONDS] So we were already four brothers.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] So then we were looking for partisans.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But we couldn't find.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "But Yossel contact that-- it was [?",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "Freisin ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "Rafael ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Freisinger. ?] And he said that he can take us to the partisans.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "He told what place we can meet him.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He showed my, my brother what place we can meet him.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And he'll come with the-- with a few of the guys for the partisans, and we will get together.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So we went there.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And he said-- and, and it was a very-- woods.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It was very crowded.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was very-- [PAUSES FOR 3 SECONDS] it was very hard to go in that, that part.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So-- but one time, we went there.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "He, he told them a signal.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "And they will come.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's very hard to find.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "But he'll make like, a a bird, you know, a signal from a bird.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "So if you hear that signal, you know that we are coming.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So we went.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "We find that place.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And we were waiting for them.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "We were waiting for them.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "We wait.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "We wait.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And they don't come.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And it was a very dark night.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It was so dark, you didn't-- couldn't see anything.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And then we heard somebody is coming.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And we heard shooting near, near the place.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "It was a little-- how do you call it, like, shack, you know, where we were waiting for them.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And shooting around and running-- we didn't know what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Maybe, maybe Germans, they surrounded us.",
      "word_count": 6
    }
  ],
