  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "He didn't feel it was fair for just save his life, or he didn't know whether he will be able to save his life.",
      "word_count": 24
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "Because a lot of people did.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "A lot of people died.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "A lot of people saved their life, that they went to Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "A lot of them finished up in Russian concentration camps.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "And a lot of them survived, just like we survived.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "So he stayed with us.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "It was very tough living in-- and then-- and we had new laws came out every day practically for the Jews.",
      "word_count": 21
    }
