  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "After three months, my mother died.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "I was with my mother three months.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "How old were your sons, when you came to the United States?",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Mine oldest was 10-- 10, David was seven, and Zvikela was four.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "In all the ways.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "In all the ways.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "First of all, me and my husband was like one head and one hand.",
      "word_count": 14
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "We say like that-- I don't want it nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "I don't want something what I cannot reach.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 5,
      "text": "But I want only to give the children education like my mother and father gave.",
      "word_count": 15
    }
  ],
