  "sentences_input": [
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Benny got killed in an elevator.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "He didn't know the elevator didn't work.",
      "word_count": 7
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "He walked up three flights.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "He's supposed to walk up another flight or two.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "And there was a little window in the elevator.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "He wants to see if the-- what's going on.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "And somebody pushed a button, and he got killed.",
      "word_count": 9
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 8,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "It started to move, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And then, you know, we went home.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "We took a cab.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "My boss closed up the shop right away.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "Everybody went to work.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "This was Labor Day weekend.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "And the following day, a friend of mines-- he lives here.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "He's my landsman.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "[NON-ENGLISH]-- his name was [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 10,
      "text": "He took both boys to recognize the body.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 11,
      "text": "They didn't let me go.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 12,
      "text": "And they recognized the body.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 13,
      "text": "Well, Karl run away.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 14,
      "text": "He couldn't take it.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 15,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Oh, full of life.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "All the neighbors knew.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He always was singing.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "And with everybody-- just self-learning-- he never went to school.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "He could have a speech in English.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "And he loved sport.",
      "word_count": 4
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "He was full of life.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 7,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Wonderful.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Look.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "It was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "Irving went to Florida.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "He was a stock broker with a family.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 5,
      "text": "And I was alone.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 6,
      "text": "And Karl just-- supposed to go away to-- to college in Long Island-- Stony Brook.",
      "word_count": 15
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 8,
      "text": "And then I told him, look.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 9,
      "text": "You've got to go.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 10,
      "text": "You gotta.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 11,
      "text": "No, you've got to go to school.",
      "word_count": 7
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 12,
      "text": "But we talked.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 13,
      "text": "And, you know.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 14,
      "text": "After two weeks, I went back to work.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 15,
      "text": "And he came when he could.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 16,
      "text": "He had a ride.",
      "word_count": 4
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 17,
      "text": "He came home.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 18,
      "text": "And this was it.",
      "word_count": 4
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "Not-- I have the pleasure of my children.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "I have a very fine friend.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "I have a good friend, yes.",
      "word_count": 6
    }
