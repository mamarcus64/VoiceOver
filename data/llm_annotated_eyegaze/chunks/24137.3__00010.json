  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And to this day, when I see a lot of metal in bathrooms, if it's in a hotel, I always tell my husband, I don't, I don't like these rooms.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I don't like to be here.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I remember we were in Switzerland just recently.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And we went into a hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And they had so many pipes.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And they were all this color of silver, you know, metal.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And I said, I don't want to go into the showers.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And my husband said, you have nothing to be afraid of.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "This is such a long time ago.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And I said, I'm not-- I just don't want to stay in this hotel.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes there were a lot of children in Ravensbruck.",
      "word_count": 9
    }
  ],
