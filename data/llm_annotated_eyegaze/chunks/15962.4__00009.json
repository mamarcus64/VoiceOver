  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "It was-- so when I later on re-constructed those-- those months, I was surprised that what seemed like eternity was only a week or a few days, particularly the last days of the war seemed eternal.",
      "word_count": 36
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "This first time, we were there maybe a week, maybe 10 days only.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We were just inspected and cleaned and de-loused and had to wait in different places and shifted from place to place.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Until finally, we were marched back to the railway station and shipped to another destination.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I would say that maybe 20, 25 in that transport.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Others went elsewhere.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It doesn't mean that they were all dead by then.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I would say, no.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They-- they just went to other-- some went to Buchenwald, some went to Bergen-Belsen and other camps.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "So would-- would--",
      "word_count": 3
    }
  ],
