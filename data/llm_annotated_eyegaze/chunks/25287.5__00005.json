{
  "stem": "25287.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "But before, I forgot to tell you, when we arrived to the hospital, one of our lager sisters was front of.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "And she said, my goodness.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "We was think about they killed you.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "Erzsabet-- six kilometer, or 20 kilometer, in another lager.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And when this woman doctor want me stay-- we stay how long need to, because we want to go to this lager.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "But [PAUSES FOR 3 SECONDS] in this small hospital, we really get-- I get, every day, an injection, and-- and food too.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And then we want to, when we was able to walk, to this lager.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And again-- [PAUSES FOR 4 SECONDS] I want to skip certain things.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I want to tell you that we get a house-- 11 us, you know, or maybe more.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "And we used to go to the kitchen, where we get meal and help.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And we talked Hungarian.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And one day, some men heared us, to talk.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "They came from [INAUDIBLE], from the Joint.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "You know what this mean, the Joint, Jewish-- and we want to go home already, because they had some kind of story that the Russian people maybe take young people to Russia.",
      "word_count": 32
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "And he said to us, after the eating he want to talk to us.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "And he came, I think, two or three men were-- he came and ask us where we live, and came and talked to us and ask who want to have the leader, and give some money.",
      "word_count": 36
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "And was, I don't know where we were.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "This man came there.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "Wasn't even Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And we said, the man is-- you know.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "So he said he has a railroad, and for this money you can get the ticket.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And next morning, before light, we should go.",
      "word_count": 8
    }
  ],
