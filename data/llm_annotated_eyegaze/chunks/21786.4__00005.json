{
  "stem": "21786.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They had a special room allotted for that in the local insane asylum.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "There were plenty of people who were brought from all over Bohemia and Moravia who were insane, so one room was simply given for the marriages, with a little bit of German tongue in cheek.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And we were married under a chuppah by a rabbi with all the trimmings, and with stamping on the glass and saying mazel tov.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And then simply, with a passkey which I made, we spent the-- the night with Eva on top of the building where she lived with the 16 plus, with-- and every room other-- other girls.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "There was plenty of hay there in the loft.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "Everything was fine.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Only we discovered that it was just loaded with fleas-- thousands and thousands of fleas.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "So it was about 3:00 or 4:00 in the morning and we ran.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "One gets accustomed to bedbugs.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "One gets accustomed to lice.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "But fleas, at least me, no.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "Eva is very resistant.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "We got married on the 22 of November, 1942, so that in 1982, we had a special kind of-- 1992, we had a special kind of anniversary.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I know people who were born on 1922, also people who were killed on 1920-- November-- No-- November 22.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Jack Kennedy.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It was beginning of-- of-- of-- of October, 1942.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Uh-huh.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "By that time, we had been in four transports.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Once I had to pretend that I had got typhoid fever.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I injected myself with a typhoid fever vaccine.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] In the-- the year 1943, so I worked in the agriculture.",
      "word_count": 15
    }
  ],
