{
  "stem": "3933.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "She went to a village, and she was there, and they find out, and she came back to the city, to Rowne.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "And she saw [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "Kola. ?] She saw [?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "Kola. ?] And she knew him from before.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "He was coming there.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "They used to live-- this is such a coincidence.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "They used to live-- before the war, they used to live in a different street, and they-- they-- [?",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "Kola ?] with his parents, and that's the reason she know him.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "And also she saw him coming to me in the ghetto, visiting me.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And she saw him on the street, and she said, [?",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "Kola, ?] please-- And he says, [?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "Fela! ?] Mary's there with me, with the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "Come, come.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And he took here there.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "We were there and he took her around.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "When he was going terrible-- terribly drunk, and she said, Mary, how can you stay-- Mary, I would prefer to go out and die.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "Anyway, once, they were going to confiscate the apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "They are going to knock the door any minute.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "We hide, all three of us-- [?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "Fela, ?] myself, and my son-- under the bed.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "We were sitting-- lying there, under the bed.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "And she became hysterical, and she wanted to laugh.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "This is such a sickness.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "And I said, [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "Fela, ?] please.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "[LAUGHS] She was choking laughter-- such a hysterical.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And, thank god, we survived.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "After, I was so angry with her.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "And she said, I'm sorry, Marry.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "She's in Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "Fela ?] survived.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "I hope she's not-- she's-- she's about seven years younger than I-- seven, eight.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "She's married, with children.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "She has second husband-- that's another story.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 46,
      "text": "Now-- she has two sons.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 47,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 48,
      "text": "The first husband was Sephardic.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 49,
      "text": "The second is Ashkenazi.",
      "word_count": 4
    }
  ],
