{
  "stem": "3928.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And the resistance movement asked me if I would work in the factory there and get the information for daily what they-- what's going on.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "They put me in as a welder.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And I worked in this factory as a welder.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And daily, I gave all the information what we needed for the underground.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "They-- I was--",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The factory was taken over, since that's owned by Jewish people.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was taken over by the government.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And they run the factory.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "It was the main ammunition factory for the country, which supported the German war effort.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And they-- through the union, they put me in.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Since they figured out, nobody will-- a young man.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Nobody will suspect a young man that goes around.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And as a welder, I worked every part of the factory, every time they needed.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So I had access to every part of the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "So I had the information what they needed.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Daily, I know the-- the product.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I know what they was working on it.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I know what they're planning to work.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Which was-- I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Whatever they did, the information, I gave them.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "But I gave them the information what they asked me to give them.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "What exact-- can you be specific?",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Can you give me some sort of information?",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Like I can tell them, you know, they was working on a Tiger tank.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I can tell them exactly how many was on the-- in the process, what they did with it.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I can remember the ammunition, what they were working on it.",
      "word_count": 11
    }
  ],
