  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And they returned it to-- to-- to the-- to the-- German [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "You you know what I mean?",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "It's gold.",
      "word_count": 2
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "It's not only life, but we can use gold too.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "From-- from--",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "From the jobs?",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They-- we-- we were all one kommando, sonderkommando.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Kaminski was kapo.",
      "word_count": 3
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Was a kapo in-- in crematorium two and three.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "We had a kapo, Leizer.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "And there were Schlomo, which we [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
