{
  "stem": "26609.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Why do you have to help her?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Why do you have to go [? run ?] there?",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I said, I promised free.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "No one paid me for this anything.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But I wanted to help her.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "She was not a good student.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Not only good, she was a very bad one.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She didn't remember anything she learned in school and came home.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And I had to write later.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I was punished at school for this, because her school work was the same as mine.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And I ran all the way to her to do her school work.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "And then I had to run back.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "And it was the day before [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "And they used to beat up people in the street, Jews, [INAUDIBLE]",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And then finally, I came home.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And my mother said, look.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "We wanted to go out to look for you or to bring you back.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "They knew where the place is, where I went to.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "But [PAUSES] maybe they wouldn't do anything to you for a child when you are running.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "But if my father goes out or mother, they would beat them up.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they never said even thank you for that, your mother that I did it for her.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And at school, when I came back at school, they had to punish me for this.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Why did you write her?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Let her write-- do it herself.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "If she doesn't know it, she won't know.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "So she will not have her school work.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Said, but I promised her that I will do it for her.",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And that was how it was on Christmas mostly, pre-Christmas, Christmas time, on all Catholic holidays.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Jews were afraid to go out in the evenings.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "I didn't encounter any Poles, no.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Ukrainians.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Mostly Ukrainians.",
      "word_count": 2
    }
  ],
