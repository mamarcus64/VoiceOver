  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "The-- you should know the Franciscan, the German church, helped a lot of Nazis to escape South America.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And his family was there-- three children, I think, three or four, and the small boy of six years old, that now it was discovered suddenly that he is a, he's a-- became a professor in Bonn.",
      "word_count": 37
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And he was then six years old.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Had another boy.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And he lived very poorly.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And it was not understood how a man like him could be a billionaire if he would take only the money to leave some Jews alive.",
      "word_count": 26
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "But it looks like it was very important for him to kill.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "And also, how you say it, didn't mind the money, it looks like.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And he mind to stay alive with his family.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "Because he was really a family man, as we-- I tell it later.",
      "word_count": 13
    }
  ],
