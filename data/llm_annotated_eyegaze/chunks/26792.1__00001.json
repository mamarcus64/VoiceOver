{
  "stem": "26792.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And we lived like that-- quite wealthy-- until the year of 1931, '32, when the Great Depression beg-- started.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Then we lost all our property and we were out in the street.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Meaning that we had to get a place to live in.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We-- I started to work at the age of 11, giving lessons-- Latvian lessons to little children.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And my brother also started working, although he was a student.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And life became very tough to all the family.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They were placed like honorable Jewish people.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Trad-- we had a traditional house.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "My father used to go twice a year on Rosh Hashanah, Yom Kippur, to synagogue, and so did my mother.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I was the one-- I was the one who knew already-- could read Hebrew.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So I was in a synagogue and was reading the Seder and all the Jewish ladies who didn't speak Hebrew were repeating what I was-- my prayers.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "That was my duty.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So my brother-- my father had four brothers.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "One of them immigrated to America at the beginning of the century because he was supposed to become a Russian soldier for 25 years and Jewish youngsters fled Russia.",
      "word_count": 29
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "He had another brother, Shai, who also lived in Kuldiga, with a family of two daughters and a son.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Then was a-- a brother-- a childless brother, Moshe.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And an uncle in Riga-- Herman-- the most educated one, who had a son Robert.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And both of them were killed the first night the Germans occupied Riga.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "All of the mentioned people were killed or crippled before they died.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "My mother's family were lucky to be over in Scotland.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They-- they went to Scotland at the turn of the century.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "So all the children were born there.",
      "word_count": 7
    }
  ],
