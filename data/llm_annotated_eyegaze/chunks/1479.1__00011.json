  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And again, we were assigned to work in the factory.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In Schindler's factory, definitely.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "There was a barrack, what we called a latrine.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "There were, you know, running water.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And there were bathrooms.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Of course, they were not, you know, like you would expect-- English baths and whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "But there was running water.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Even it was cold, you could stay clean.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes.",
      "word_count": 1
    }
  ],
