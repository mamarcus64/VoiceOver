{
  "stem": "8423.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So Sunday came around, and it was already almost nighttime, and my sister-- my sister-- my friend Joli and I-- my sister was off talking to other prisoners, trying to find some information on my grandmother and my sister Roszi because we had found out before we left the ghetto that they had left earlier.",
      "word_count": 55
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Some of the people that had seen the train go through our town, some of the Hungarian trainsmen who knew us and got messages from them, bore the messages to the ghetto to tell us that my mother's mother Bubbe and Roszi had been taken away.",
      "word_count": 46
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "So we knew that they got there earlier.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "So she was looking for some people from that village so she could find out some news them.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And my sister, Joli, and I were sitting, crying.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And this woman, the [INAUDIBLE] came over to us and she said, oh.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I see I have two crybabies over here, she said.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "[DRINKS]",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Polish.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "But it had nothing to do with nationality.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They were so inbred by the Germans by now, you know, that they were acting just like them.",
      "word_count": 18
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And she said, so what are you crying about?",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And I was afraid to speak up.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But my sister Joli said well, you know it's Sunday.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And they had promised us that on Sunday we would be reunited with our mothers, and it's almost dark.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And she said, your mothers.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Is that what you're crying about, she said.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Look at those smokestacks, she says.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "What do you think they're doing in those buildings?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Do you think they're breaking bread for you in there?",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Do you think they're bakeries?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Just like this, sarcastic as anything.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "She said, those are crematoriums.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And of course we already heard, but we didn't listen.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "We didn't believe.",
      "word_count": 3
    }
  ],
