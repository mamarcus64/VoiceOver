  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "In other words, the Poles would go to a school where the language of instruction would be Polish.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Ukrainians would go to a school that was Ukrainian.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And Jews would go to school language of instruction was Yiddish.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And the teacher was from Kiev.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And I remember the way he taught Yiddish, which I thought was funny in a way.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That school I was in Lvov, you see.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "But I had to leave Lvov.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I'm trying to remember why I had to leave Lvov.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So later, I lived in Kalusz.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And that round-up happened in Kalusz.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And subsequently from Kalusz-- we had to leave Kalusz, because Kalusz was considered too big a town for us to live and so forth.",
      "word_count": 24
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "We'll stop now and continue in a moment.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Good.",
      "word_count": 1
    }
  ],
