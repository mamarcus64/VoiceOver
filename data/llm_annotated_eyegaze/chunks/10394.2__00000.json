{
  "stem": "10394.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "When they liquidated there, I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was working in Madritsch.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "When before, we went to Krakow-Plaszow, I didn't know where to go.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was scared.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I said, where I can go?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "This was when they liquidated.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "But I was working before in Madritsch, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "But everybody, all the Jews has to be in ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Everybody has to be in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But we went to work outside ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Now everybody has to be in ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Then they make clean-- clean from the Jewish people, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And I said to my brother, I go with you.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "He didn't-- this was the concentration camp, Krakow-Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "This was already for the people-- you know, they make barracks.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I remember the barrack where I used to live.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And [PAUSES FOR 6 SECONDS] [SIGHS] before they liquidated the ghetto, it was different.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Wait-- I didn't tell you what we did.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "They make an appel from all the girls, of all the womens, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "Before they liquidated this ghetto-- I didn't tell you this.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "There was a big [NON-ENGLISH], you know.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "All the Jewish they take on the train, the people who goes.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "We didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And to my girl friends, they said, Gienia, if you come to the front, go to the back again.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "But here in the back you can go because the German police watch you.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "And I went maybe two, three times I went back.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And they go.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "There was 5,000 women.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "They take the women, we didn't know where.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And when I came to my brother, who was in an appel-- they-- nobody can-- has to stay in place.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But my brother says to the German, please let her know.",
      "word_count": 11
    }
  ],
