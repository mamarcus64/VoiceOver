  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "And we were a lot abroad while he was playing at theatre, and television, films, and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "And he died very, very suddenly, from one second to the next.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "He was holding his inevitable cigarette in one hand and his inevitable cup of coffee in the other.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "And mid-sentence, keeled over and had a very massive heart attack.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "And that was in Salzburg, just before the festival opened.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "He was due to appear at this festival.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "And there was a banquet, opening banquet that night.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "This happened in the morning, on the 25th of July, 1979.",
      "word_count": 11
    }
  ],
