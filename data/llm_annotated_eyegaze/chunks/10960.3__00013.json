  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "As long as you are here, you will take care of Shayala, and I'll go to work.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So it's-- it was-- there was a-- a-- but I don't remember.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "It wasn't near.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "It wasn't too far away from Mlynow.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I should find out maybe sometime.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "There is somebody who lives in Tel Aviv-- in-- in New York, who was with me together in the same woods, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "So-- so I went to work, and what did I receive?",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Two pieces of bread and a potato.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And this is what I could bring home.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Then I said to my sister, you see?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "You see what kind of a?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Why should I go to work?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "I'll take the baby, and I'll go to the Czechoslovakian-- there was a colony, like a-- in the farms.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was owned by Czech people but born probably in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "They were very rich.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And my sister and I knew that my sister told me she gave them so many things to hide.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "You know, if anyone will remain, I shall know that they have them.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Schultz-- you have the name-- Schultz-- Mr-- family Schultz.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "We used to--",
      "word_count": 3
    }
  ],
