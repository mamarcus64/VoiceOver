{
  "stem": "6837.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "She said she recognized me because I looked like my uncle.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "We looked-- there was a window and we looked at ourselves in the window.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "We looked strange.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "We didn't recognize ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Then they lined us up.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And they tooked us to the camp, which was Camp B in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "They were alphabetically.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We had shoes, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We had our own shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "That they left.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They gave us the shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And there were barracks with wooden-- with wooden beds, uh, bunk beds.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And we had to-- I was on the top, so we had to climb up.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And there was a lot of us on a very small space.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Just women.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Some of them were mothers with daughters, which they must have been in their 40s, early 40s, late 40s, not older.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And the girls, my age and older.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And when we went to sleep, we didn't know how.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "There was nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "It was bare.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And we had no room.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My sister was on another-- on the lower bed next to me-- not under me, next to me.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And we were hysterical laughing.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And they gave us something to drink before we went into the bunks, which was like black coffee.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But later, we found out that they put something into that-- [?",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Brom, ?] which is like, uh, a tranquilizer, something like that.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "The name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Brom. ?] I don't know-- in German maybe?",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And we were hysterical laughing.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "We were like, like monkeys.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "We didn't know what's happening.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "And, and, it was-- it was a very, very funny situation.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "And we had to go to sleep and we couldn't find room.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "We, we couldn't-- we didn't know how to do it.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "We couldn't sit up and we couldn't lay down.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "But we managed.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "We squeezed together.",
      "word_count": 3
    }
  ],
