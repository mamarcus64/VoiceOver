{
  "stem": "3150.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "My-- my brother, myself, and-- and that was around Christmas in 1942.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "But he-- he kept us-- we were at that time, because the-- our big worry was they're going to throw us out.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "But he did not.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "He kept us through '43, with the same system.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "We used to go out-- we used to go out to get food.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "Mainly my brother used to go, and my aunt used to go.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "And like I say, once in a while, myself.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And it was probably about five-- four or five kilometers.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "We used to go at night.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Into the-- you know, and the guy used to prepare the food.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We used to-- Where was-- where would he be?",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "At his house?",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "He was at his house.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We used to go out to his house.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We didn't-- we used to go his house.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "And that's how we survived all through '43, into February of '44.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And that's how long you were in hiding?",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "That's how long we were in hiding.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Now, what did you do for toilet or water?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And who-- and who would take care of that?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "At night.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "You-- you-- you stayed with it all day long.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "At night-- at-- at night, you cleaned it out.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "Just a bucket, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "We, actually-- during the day we didn't-- we didn't move.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 7,
      "text": "Because there was no room to move.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 8,
      "text": "I mean, the-- the place they put us up, they-- they built a mock room for eight people.",
      "word_count": 18
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 9,
      "text": "It was-- it was not enough, really.",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "You couldn't even walk.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I mean, really, to tell you, we used to do that at night.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "We used to go down to the barn.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "You know, stretch-- stretch your legs and walk and clean out everything.",
      "word_count": 12
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "It's--",
      "word_count": 1
    }
  ],
