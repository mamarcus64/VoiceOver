  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 29,
      "text": "Smell, that smell is so bad.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 30,
      "text": "It's unbelievable.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 5 SECONDS] I do remember this.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 32,
      "text": "I didn't mention that 1944, we were marching.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 33,
      "text": "And the Russian told us to sing [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 34,
      "text": "This is the Russian song.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 35,
      "text": "This is forbidden to sing.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 36,
      "text": "But they were Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 37,
      "text": "But they were watching us.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 38,
      "text": "They were [NON-ENGLISH SPEECH].",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 39,
      "text": "So after we came to our camp, [PAUSES FOR 3 SECONDS] one guard, who was watching us, he said, he sing that song, young boy.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And I do remember what Goeth done.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "He told the Jewish people that if ever he catch a Jew with a beard, he will kill him.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "A beard, they will kill them.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "So what Orthodox Jew, they didn't have nothing.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They took the pride away, so the only thing what they had is the beard.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "But for me, you can-- beard, you can grow later a beard.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "When he took the handkerchief off, there was a beard.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "So he killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "So he killed.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "He took machine gun on a horse, and he killed.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "He was just a vicious animal, most vicious animal that this-- that-- I can't understand it.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "He killed.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "He killed.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "He killed.",
      "word_count": 2
    }
