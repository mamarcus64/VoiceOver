  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And their location was in Budapest, in Csanyi utca 12.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "Csanyi, which is spelled C-S-A-N-Y-I 12.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And that's what their location, where the factory was located.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "That consisted of two different , parts which was separated underneath by the sewer system.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "And I went to school in Hungary.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And I worked in the factory with them, also.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And the same time, I went to school.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And I was aware, actually, this-- the problem which was facing the world, when I do believe was 1938.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "I was sunbathing by the Donau, and I listened to the radio.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And the radio announced, it's a beautiful Sunday, nothing can disturb the peace in the world.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And the same evening, Hitler marched into Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And that started the so-called conspiracy of the resistance movement from this day on.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I remember, as a young man, [PAUSES FOR 3 SECONDS] my aunt hired Czechoslovakian refugees, intellectuals, people who had to fled their country, and they worked in his factory.",
      "word_count": 29
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They slept in their factory until they find ways, till they can go, to France or whatever they wanted to go, to leave the country, legally or illegally, you know?",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Because the Hungarian government would not give them working permit.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In fact, they were sneaked into the country.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And this was my first encounter, you know, by helping and hiding people.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "In [PAUSES FOR 3 SECONDS] 1941, [PAUSES FOR 3 SECONDS] the underground, which was the headquarters in Csepel Island, at the time.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Csepel Island is spelled S-S-- C-- I beg your pardon-- C-S-E-P-E-L.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "This island was a home of one of the biggest factories in Hungary, called Weiss Manfred.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And they are manufacturing tanks, ammunition, textiles, and the dive bombers.",
      "word_count": 11
    }
  ],
