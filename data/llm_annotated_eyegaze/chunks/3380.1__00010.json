  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "I mean, within-- within three, four months, they had nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "They had to leave their apartment with-- with-- within two hours, sometime a day.",
      "word_count": 14
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "So how many people-- well, you already had a large family.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "How many people were in your home?",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "That was another family.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "We used to have a room, a kitchen, and a bedroom.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "They put in another family to us.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And there were five people in the other family.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we were living in lots of people.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "I mean, we always used to sleep, you know, during the ghetto, at four, five people in one bed.",
      "word_count": 19
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "I mean, this-- this was a normal thing.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I mean, we had to take those people in.",
      "word_count": 9
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] If we had something more, we used to share with people what didn't have.",
      "word_count": 18
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 5,
      "text": "My mother used to take care on those thing.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "That was 2 and 1/2 when I--",
      "word_count": 7
    }
  ],
