  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 7 SECONDS] I want to give you-- you see, I told you about the house what-- what-- what we built.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And when my youngest sister next to me got married, we rented land from the Polish government.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Do you know in Europe, only the big towns-- only the big cities had electricity.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "The small towns, they-- they-- they didn't have.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "They-- they lit their houses with kerosene lamps.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "So-- so I built the house over there, and I-- and I brought a big tank.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And we used to bring kerosene in cisterns.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "And we used to sell-- sell them to the whole stores, to the-- to the-- to the stores, we used to be-- we used to sell them.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And they used to sell them to the customer.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So this date, my brother-in-law from my-- from my sister, he was over there-- over there, the manager.",
      "word_count": 18
    }
  ],
