{
  "stem": "1704.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I remember I went outside, and then I remember that somebody picked me up and said, oh, it's Lotte, it's Lotte.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And they took me to the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And I was unconscious.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And that's friend, you know, the mother of the boy, she brought me soup everyday.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And vaguely, I remember it, and the typhoid, I have to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I have to eat.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And I came out of it.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And as soon as I was better, as they say, I was, I had to go to another barrack where I was used to, and I couldn't even get up the steps, I was so weak.",
      "word_count": 36
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Anyhow, I went a few times back to the hospital and I helped out.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "And I stayed there to help out.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, take temperatures, get them the pan, the bed pan, and just be there for them.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "At the end, you know, you get big water in the legs-- fluid, fluid.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Typhoid, of course, and malnutrition-- anything.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We all got a needle against typhoid, after which we all got typhoid.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "So I don't know what they gave us.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "We all got typhoid after we got the needles.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Probably.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Probably.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And then, you know, when I helped out in the hospital, I saw a good friend of [NON-ENGLISH], while I nursed his mother in the other ward.",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And that was terrible.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "A lot of friend had typhoid.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He survived it.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "That was a terrible time.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And I had to wash them.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And the lice.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We had so much lice.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "You know, everyday, we got-- we got undressed, we looked at our clothes and tried to kill, and kill with your fingers.",
      "word_count": 22
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We thought we'll never, you know, we'll do this for our lives.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "We never though, you know, it would get any better.",
      "word_count": 10
    }
  ],
