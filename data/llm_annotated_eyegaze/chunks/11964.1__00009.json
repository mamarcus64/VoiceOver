{
  "stem": "11964.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we would chop it up with all kinds of stuff and then stuff it.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And that is why we call it gefilte, or stuffed fish.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I did not know my grandparents.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "My grandparents must have died before I was born.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I know of my grandparents.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I know of my parents' siblings.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But we have never-- I was named after my mother's mother.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "My older sister was named after my father's mother.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "And my younger sister was named after my mother's grandmother.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "So we have not known our grandparents.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My father-- my mother did not come from Radomsko.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "My mother came from Lodz, or 'wudge' in Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So all her siblings were mostly in Lodz.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She had five sisters, I believe, and two brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Thanks to one brother who left Poland very, very early-- I think right after World War I he left for England.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Thanks to his leaving Poland at that time, I have a lot of my own relatives, first and second cousins, in England now.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "So my mother had several sisters, two of whom migrated to Israel in the 1930s.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And thanks to them, we have a lot of family in Israel, because my mother actually helped her two sisters and their children financially to leave Poland, and they actually settled in Israel.",
      "word_count": 33
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "When were you first aware, if at all, of any anti-Semitism in your town or of any danger?",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "We were always aware of anti-Semitism.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We knew anti-Semitism existed.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We knew that in as much as it may not have been felt every day, it was there.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "It was covert, and it was overt in certain things.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We knew that certain-- certain people were very anti-Semitic, that they didn't want to tolerate Jews in their town.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "But they simply co-existed.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "They simply co-existed.",
      "word_count": 3
    }
  ],
