{
  "stem": "21354.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "I used to see him and say good morning and good afternoon, and that was the end.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And that applied to everybody.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Not much, because my father was in partnership with a non-Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "The business was in a non-Jewish name.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "My father handled many more Jews who were emigrating who came to buy suits and have suits made.",
      "word_count": 18
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "But beyond that, little changed.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Didn't change at all.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He was an extremely honest, decent German citizen.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "No, not at all.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I don't know-- first of all, he was an old man then, and I-- I've no contact with anybody.",
      "word_count": 19
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Multsera.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Frants Multsera.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Perhaps it was already getting on for '38, but between '37 and '38, yes.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "From my point of view, from-- first of all, we were not accepted in a non-Jewish school.",
      "word_count": 17
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "We returned to our school, but basically the German sch-- the Jewish school that I went to only had four classes-- four elementary classes in Germany.",
      "word_count": 26
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Now, the Jewish community in Munich was confronted with a problem, that the children could not be accepted, nor the teachers.",
      "word_count": 21
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And so they founded four additional classes.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "That was easier said than done.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "First of all, we had to find premises adjoining to the previous school.",
      "word_count": 13
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "We had makeshift classes, but a fairly good education.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish community.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "The Jewish Gemeinde Community.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "There was no such thing as a big bar mitzvah party.",
      "word_count": 11
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "We had-- but we-- my bar mitzvah took place traditionally.",
      "word_count": 10
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "The party was held at home.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Friendly, but tense.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "I remember the tension.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "We didn't think how things were going to turn out.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "We only thought how soon could we leave.",
      "word_count": 8
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "The next incident happened in Germany.",
      "word_count": 6
    }
  ],
