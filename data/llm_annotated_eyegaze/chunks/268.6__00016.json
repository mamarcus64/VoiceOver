{
  "stem": "268.6",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And he-- this was a steel-- a steel ladle, quite heavy.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he started hitting that guy over the head.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And he split his head open.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "Blood was all over.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And, yeah, after, I was shaking.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "I couldn't-- and I said, please, I can't do this.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And he says, get out of here.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "He says, you, you know, you can't do this, he says.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And I begged him.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I says, don't, don't put-- make me do this anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "I says, I, I, I can't-- I can't do this.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "They-- I'm too little.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "They-- this takes a strong arm.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "I didn't want to tell him I can't-- it takes a strong person to lift the kettle, and all this.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "So from there on, he actually-- I don't know what happened to the guy.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "But he, he-- they took him.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "They carried him out.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I never saw the guy again.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "But he split his head.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "And he would beat up on them.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "He'd say, you-- he says, you-- this is-- this is how you-- how you stir it.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And he would really hit and beat and kick him.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And those are the kind of kapos and Blockaltestes we were subordinated to, you see.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "You had to work and live under.",
      "word_count": 7
    }
  ],
