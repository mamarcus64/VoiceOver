  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Our oldest granddaughter [PAUSES FOR 3 SECONDS] Our oldest granddaughter is-- is 20 years old.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "[DRINKS] She wants to get married.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "So hopefully we'll have a simcha.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this was the most important thing that happened to me, to-- to not to be silent.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Because I find out that if I am silent, and everybody of all of us is survivors, we are going on in age.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "We are not going to stay young forever.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And denying while we-- we are still alive, the denying this has ever happened.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The deny that my parents, my brothers, and little David, my brother David, they were all hoaxes.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "They never existed.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "For this reason, I decided that I'll do everything in my power to tell and to speak and to say what has happened to our people, individually.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "In the [INAUDIBLE], the people who were killed, they have stories, worse stories than I had to tell.",
      "word_count": 18
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "But the live-- the people who are alive should at least, they are obligated, their parents, their brothers and sisters, to their own people, not to keep silent.",
      "word_count": 28
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    }
  ],
