  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I was there, which-- it was, you know, a lot of-- we got a lot of people from Poland to this town.",
      "word_count": 22
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Because there are a lot of them run to the east to save--",
      "word_count": 13
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I didn't hear anything.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "No, I didn't hear anything.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "No, at that time it was impossible already to go anyplace.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "They didn't let you.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "So I was there.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] And while-- this was-- Ostrog was a town where a lot of-- [PAUSES FOR 3 SECONDS] very also, the-- most of the people there were speaking Russian.",
      "word_count": 31
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 6,
      "text": "That was the intelligentsia.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 7,
      "text": "The Jewish intelligentsia were speaking Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "But here in Ostrog, there was a guy, a man who-- I used to go there sometimes also for my vacations.",
      "word_count": 21
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And he was an artist.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "And he always used to make sketches of me.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "He used to play the violin, artist and performer.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "He was an artist.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] And when I arrived in '39, and during those two years, he was courting me.",
      "word_count": 19
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And I eventually got married to him.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "There, in Ostrog.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
