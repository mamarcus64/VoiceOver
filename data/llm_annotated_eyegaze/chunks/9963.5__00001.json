{
  "stem": "9963.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "We stayed over there for eight days in the quarantine.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "When they sent us out to work from the quarantine, they sent us outside the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Because Buna was a very big factory.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "It was the-- Hermann Goering's Werke-- that mean Hermann Goering could-- you know, this was his factory.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And over there, everything was done in that factory.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "Thousands and thousands, tens of thousands of people working in that factory.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "All kind nationalities-- they were working in that factory.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "But we had to work-- the first days, we had to go out to outside, and we had the shoes, only the wooden shoes.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "And that was already the first snow come down, and the-- and when you were walking, the snow got stuck to the-- and this was moving around.",
      "word_count": 27
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "We didn't have any socks, we didn't have anything to wrap our feet.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And that wood was rubbing on the feet to the bare bone.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "It was very painful.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "But we had to throw away the shoes and just walk barefoot in the snow.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "We came over there to work.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "It was so cold, the SS made a fire, and they allowed everybody to go to the fire for a minute or two to warm up, and to go back to work.",
      "word_count": 32
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "But I know it-- at the exactly that if we will go warm up and go back, this is even worse.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "We had to work as hard as we could in order to circulate the blood, and not to get frozen.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "I told all my friends not to go to the fire, because that is murder.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "People what they didn't listen.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 24,
      "text": "They went to the fire, they thought that-- they got sick the same day.",
      "word_count": 14
    }
  ],
