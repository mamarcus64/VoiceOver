{
  "stem": "13524.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And the whole family of my brother-in-law managed to escape through the forest, into Czechoslovakia.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And from Czechoslovakia, they were sent to Budapest.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Or they wanted to go to Budapest.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Budapest was at that stage still fairly easy to survive.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "The Jews were not sent to camps.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "And they went there as Poles.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "They managed to get papers, false papers, that they are Poles.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And my brother was sent right at the beginning, before we went even to ghetto, he was sent to Lwow.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "My mother had sister living in Lwow, her oldest sister, who had no children.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And she was in care of orphanage.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And her husband was army officer, Polish army officer.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "So that was a good place for my brother to survive.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "My parents-- I remember like today-- gave him him a rucksack full of clothes and food, a beautiful long coat.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He was also very tall, very good-looking boy.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I have grandson, which he reminds me so much of my brother, Avi.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And he went to Lwow.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Now in Lwow, everything was lovely.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "My auntie looked after him.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "We never got in touch with him again.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "We only know via somebody else that when the Russians came to Lwow, they ask all the people who were there-- Jews and non-Jews-- if they want to opt for Germany or Russia.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "So my brother in his naivete felt, well, we were not killed.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "We're sitting comfortably in ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "Little did they know.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "And he has signed petition, yes, he'd like to go back to Krakow, to be with his family.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "He missed the family.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "He missed my parents.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "And that was sufficient for the Russians to send him on a transport to Siberia.",
      "word_count": 15
    }
  ],
