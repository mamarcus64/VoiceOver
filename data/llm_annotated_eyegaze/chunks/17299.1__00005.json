{
  "stem": "17299.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And they all died of heart attacks or something else, they said, the Germans, but the bodies were not returned.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Only they could have the ashes of the bodies.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Nothing till 1938.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "In the pogrom of 1938.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Our house [INAUDIBLE] three rooms.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "The furniture got smashed, the windows got smashed, and I got arrested.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "So did my father.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And all other [INAUDIBLE] were arrested in town during that time.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "My brother was-- oldest brother-- was in Westphalia.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "He got arrested, and he got shipped out to Oranienburg concentration camp.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "My father was sent to a prison nearby, and since I was still considered a minor they let me go.",
      "word_count": 20
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In 1938, I was 20.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I was released.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And then I had to replace the windows and everything what was smashed.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "So the Jews had to fix up the houses, and you could not get any outside help to do that.",
      "word_count": 20
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "My mother, my sister, and my youngest brother.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he remarried in 1927.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Fanny, and she was the sister of my first mother.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "She was a widow.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "My father was away close to three months, and they let him go under the condition that he would sell his property.",
      "word_count": 22
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And the Nazi government set a certain price for the property, and the money went in a bank account which we could not touch.",
      "word_count": 24
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "The house, the barns, and some grazing land on-- on some farmland where we had a big garden, food garden where we were planting vegetables.",
      "word_count": 25
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "We were self-sufficient at that time.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Beginning of '39, and he had to sign everything over.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "The Nazis bought it for 6,500 marks, which was confiscated.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "I got it back later on when I sold it for over 40,000 marks.",
      "word_count": 14
    }
  ],
