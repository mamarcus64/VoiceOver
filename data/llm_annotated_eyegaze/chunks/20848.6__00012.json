{
  "stem": "20848.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And then he got a job and I got a job.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I'll never forget it, because I've got two left hands.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I'm not very good with my hands.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And the job I got was in a clothing factory.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They were making men's suits.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And in those days, really, people-- you couldn't get people enough to work, enough people to work.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "They would take anybody to work, even a person like me, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And he wanted-- the boss put me on a machine and to-- to put sleeves together, to sew sleeves together.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And I went like this, you know, because I didn't know how to do it.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "So he gave me a little gadget.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And I couldn't go wrong.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I made straight-- you know, the sleeves, the seam was straight.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I'm very fast.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "And I-- I made a lot of sleeves for him.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "But I was pregnant, as I said.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And downstairs was a fish and chips shop, and a pie shop.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And I was all the time nauseated, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "And although I worked there two or three months, I-- I couldn't work there.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "Because I was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "And the girls who were working there, they didn't know what happened to me.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "They didn't know I was pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "I didn't know myself.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And they said, oh, you're such a young girl.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And you're so sick, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I had to give up the job because I couldn't stand the smell.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And the boss-- he just couldn't believe that I am giving up the job.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "He thought somebody gave me a better offer.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And he just couldn't-- till I, you know, I said, look, nobody gave you-- and-- and I got out.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Now, when I was in Birkenau, I had-- you asked me whether I was sick.",
      "word_count": 15
    }
  ],
