  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Polish ?] school, in not only-- not only the school kids which I was in school with was anti-Semitism, but the teachers, too.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "You see, they didn't respect you.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was in school-- I was in school a very tough guy.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was very strong, and-- and I was very intelligent.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Not because I am, I want to tell you that, but I was.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And the teachers didn't respect me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Only [? which ?] respect me when I complain one time when I was going to the director from the school, then he changed a little bit.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "They call you bad Jew, you know, different type of names.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "They call-- it was bit anti-Semitism in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes I must fight.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "When we was going out after the break, and they start fighting, and I must fight, and I always win.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I was very strong, and I-- the friends of mine also was very strong.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Can be also do a lot of wrestling when we was kid, 8, 9, 10 years old, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "We was-- was doing different type of sports to protect ourselves.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My second brother was a very intelligent person.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I mean, he was a little bit older.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He was not so religious as I was, and he was learning the-- the skill of diamond cutting and gold.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And my third brother, Emanuel, was not only religious.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "He was fanatic.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "A lot of time, he didn't even talk to me because I'm not so religious as he is.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "This was my third brother.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "He-- he study-- he want to be a rabbi, but if he would be alive, he would be.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And my fourth brother, [?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Chaim, ?] was a young kid, you know, nice.",
      "word_count": 9
    }
  ],
