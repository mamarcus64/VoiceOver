  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I got my place what I sit.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I was in the corner, the back.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "I was in the back side from the truck.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "And they left side.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "It was in the corner from the left, how it's called-- the board from the truck.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "You know, if they fill up, the couple Germans sit in the-- in the car.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 26,
      "text": "And outside, maybe five policemen with-- with-- with guns.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 27,
      "text": "No, and they begin-- they take us from the ghetto somewhere to the-- to the where it was-- the forest.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 28,
      "text": "From that time, we know that they kill, the place.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 29,
      "text": "We saw that's where we're going.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 30,
      "text": "We decide where we see where they take us the same, in the same forest, there was killed our families in the first pogrom.",
      "word_count": 24
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 31,
      "text": "When they came-- no, we came out from the ghetto, from the city maybe.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 32,
      "text": "This was maybe three, four, five kilometers.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 33,
      "text": "And it was ground.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 34,
      "text": "The truck begin go slowly.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 35,
      "text": "The guy get up and begin to shot the in-- with his gun.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 36,
      "text": "The gun didn't work.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 37,
      "text": "When he do this, the police-- the police kill him in second.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 38,
      "text": "They kill him on the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The guy what I say that the-- from-- the-- the Polish guy.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "It was two brothers.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Jewish people.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The one who had the gun.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They was together, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We came together with them in the truck.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] When I-- I know-- I don't know from where it come, the energy from where it come, but it's to make a decision like that.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I will tell you the true.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "When we sat on the-- only in the truck-- and I was looking near to me the people.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Take the men and put them on the ground.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "He will not go.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "He's-- He's dead.",
      "word_count": 3
    }
  ],
