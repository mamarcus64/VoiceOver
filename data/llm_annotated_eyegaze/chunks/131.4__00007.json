{
  "stem": "131.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He didn't see his children.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "Just Saturday, every Saturday.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "It was a poppa-momma store.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And it opened 8:00 and it was until 12:00 open [PAUSES FOR 3 SECONDS] every day.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 5 SECONDS] my husband came home at night, after 12:00.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "The kids were sleeping already.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And when he left, they were still sleeping.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 14 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "We left here-- [PAUSES FOR 5 SECONDS] I don't even know.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I know that the second time when I came, I went, like I said, three different countries the children went to school.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I went to my brother to Mexico City.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And after that, I went to Canada with them, because I thought, he can start something.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "But it was worse there.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So I said, if I have to go back walking from Canada, I will walk back to California.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And then I came-- we came back here in 1957.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And since then, we live here.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "But it was already over, the gold rush.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I didn't find a gold rush anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 12 SECONDS] And I-- we bought that house in '60, and since then, I'm living here.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "My husband passed away 1991.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "We'd been in Israel just before with my other daughter, Robin, and her husband, and the two children-- grandchildren.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We'd been there four weeks.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And my husband, you know, in Israel, they-- [PAUSES FOR 3 SECONDS] your hotel room is bed with breakfast-- big breakfast you have.",
      "word_count": 23
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Usually we used to have breakfast and no lunch.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "Just breakfast and dinner.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And we'd been in Israel, and my husband didn't want to eat nothing for breakfast.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Usually, he used to have coffee, and they had delicious rolls and croissants.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "He didn't want to touch nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I said, what's the matter with you, Alex?",
      "word_count": 9
    }
  ],
