    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 71,
      "text": "We saw the, the railroad trucks go through.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 72,
      "text": "But on both sides, the Germans cut the trees at least 100 feet or 150 feet.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 73,
      "text": "And they had-- they had set up over there German and militia with machine guns, because they were so afraid of the partisan.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 74,
      "text": "It was unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 75,
      "text": "Especially at night when you walk, you have five people walking.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 76,
      "text": "And you've got the dry brush on the floor on the ground.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 77,
      "text": "And it-- you walk, it sounds like 50 people walking.",
      "word_count": 10
    }
  ],
