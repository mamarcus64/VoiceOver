{
  "stem": "1885.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 356.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "She taught us [NON-ENGLISH SPEECH] was the song.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "I even remember it today-- for Hanukkah.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "She taught us about the, the religion and our holidays.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And even, she taught us how to sing and dance in Holland.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "Other language, I don't remember.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "But the, the Dutch language, I do, some song and the Dutch people.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "There were people, very, very rich, of great families who were rounded, rounded up at the end, end of the war, from Holland.",
      "word_count": 23
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It was not a singing happy singing.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "It was always memories.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It was for the memories of the good old days.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And there was a lot of crying, a lot of sickness, and a lot, a lot of hunger, and cold.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I had smallpox in the camp with very high fever.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And they took me to the dispensary there.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And I remember that my mother had to sit on a bench-- it was not a bench, it was a little wooden bench, a little one.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And she slept there and stayed for weeks because I was very sick.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But I survived.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I think they called this good for people.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I survived.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she did stay with me.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Every morning, we had to go to the appell.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And appell meant we had to be present in the square in the camp so that they could count us.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I remember that that was an ordeal, because we had to stand up for a long, long hours in the cold.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I don't remember men SS.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "I remember the women very well, with the big dogs.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "The women, I can see them till now.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "The women was-- perhaps because I was a little girl and the women attracted me more, most, but I don't remember SS officers or soldiers.",
      "word_count": 25
    }
  ],
