{
  "stem": "393.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.5,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And-- and-- and our-- with our bald heads, you see, we were cold-- and whatever dresses we had-- there was not a paper to grab-- nothing.",
      "word_count": 26
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Oh, I didn't talk about that.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "That took-- that took about four hours in the morning and about three hours in the evening.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Two times a day they had to count us-- two times a day.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Auschwitz-- the life in Auschwitz was absolutely below human-- whatever.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "You-- you know, I-- I think even the animal lived better.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "We didn't have absolute, absolute nothing, you know what means.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "We had a-- we had a bathroom for everybody.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "The bathroom, you go in.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "You went about, I don't know, 200, 300 people the same time-- the same time, like a table with rows-- two, three such huge thing.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "But we didn't have men there.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Sometimes, men were working there.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "It didn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "It didn't matter.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We-- we lost that kind of thing.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "It didn't matter a man or a woman.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "But we didn't have to do it with men too much.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "We didn't have a piece of paper-- absolute, absolute nothing, nothing, nothing, nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was 24.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "From time to time-- you see, Auschwitz was a place actually, where people changed.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Because people came, and they took people to-- to work.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But they never knew who.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They had only numbers, you see.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I was there, for instance, for months.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And some others were there just from one day to the other.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "But there were-- people were always changing.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And somehow, I-- I got the job in my block-- we call it a block-- barrack, my barrack-- as a cleaning girl.",
      "word_count": 22
    }
  ],
