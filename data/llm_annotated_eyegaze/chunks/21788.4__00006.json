{
  "stem": "21788.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.4,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Some sympathetic person called my mother, my uncle's brother, and says, hey, you gotta come over here.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "You gotta get this guy released.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Well, my father went to our family doctor, got a certificate that my, my, my uncle was buried alive during the First World War and has claustrophobia.",
      "word_count": 27
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And he's got to get into a hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "Only my mother went.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "She was able to get the release of my, my uncle, and he had to go to a hospital.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "He was-- he was out of it.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And he then left.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "He went to Bolivia.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "From Bolivia, he tried to get into Chile illegally.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "There is a-- the Titicaca, the Titicaca Lake.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "It's one of the highest lakes in the world.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "He went across the border in a small rowboat into, well, ended up in Santiago, Santiago de Chile.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And in Santiago de Chile, he opened up his same profession that he had in, in Germany.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "He became a very respected person, making shirts to orders, again, to the higher-class people.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "There were ways through the Red Cross and through South Africa to get mail from one place to another.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Usually, it took like two or three months to get mail from one place to another.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Yes, we knew where he was.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And he knew, knew where we were.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "To continue on my, my, my uncle for just a second here-- what happened to him, he was actually quite happy, made a good living.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And after the war and everything was over, came to visit us in-- here in Denver, Colorado and decided that Santiago is getting on the communistic side.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "He needed to get out of there.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Actually closed his business in Santiago and wanted to open his business again, of all places, in Hollywood.",
      "word_count": 18
    }
  ],
