{
  "stem": "9.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Oh, you did?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "How do you make a list if you interview a person [INAUDIBLE]?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, as a small child, I remember only one of my grandfathers and his wife, his second wife.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "He was selling flour.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And the type of a business it was, he didn't even have a store.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "He just had few sacks of different flour at the entrance of an apartment building.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And people would pass by every day and buy a kilo or two kilos of flour.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We have to remember we lived at times were there was no ready-baked bread, so people had to bake their own breads all the time.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "For some strange reason, I do remember fresh rolls, where everyone would buy every day, but not bread.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "So that was the business.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "That's how he made a living.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "It was in Przemysl, P-R-Z-E-M-Y-S-L, in southern Poland, in Galicia, close to Carpathian Mountains.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was a rather mid-size town.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] I was the only child in the family.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I had a governess, who was with me all day long, from the time I got up until I went to sleep.",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "She watched me practice piano.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "She took me to ballet lessons.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "She took me skiing and skating, whatever there was else that I was doing.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Being an only child, I needed other children to play with.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And the governess would always follow me and stay with me while I was playing.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "I was a rotten spoiled kid from a well-to-do family, the youngest in the large, large family, and everyone was doting over me.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My mother's name was Cyla, C-Y-L-A, Lewin.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Her maiden name was Liebschard, L-I-E-B-S-C-H-A-R-D.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "My mother was a aggressive person, the go-getter, organizer in the business.",
      "word_count": 12
    }
  ],
