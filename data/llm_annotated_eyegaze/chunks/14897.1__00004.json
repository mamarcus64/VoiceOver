{
  "stem": "14897.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "There's an interesting story about that.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "When my father came to United States, which was in late 60's from Israel, he got his license to practice medicine here because United States had a reciprocity treaty with Imperial Russia on licensing doctors, which expired in 1914.",
      "word_count": 39
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "My father's degree was from 1912 from Kharkiv.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And on that clause, he got into-- he got his license to practice in the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "It's a grandfather's clause.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Of course, I speak Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I speak some Russian, and I speak pretty good French.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I understand a lot of Yiddish.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I speak a little bit of German.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And I used to speak Hebrew fluently, but I forgot it almost completely.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I, I can follow a service a little bit in a temple and read, but I don't understand half of the words.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, I learned French-- I had a French governess when I was a little girl, which was the sort of thing that the Polish intelligentsia-- Jewish intelligentsia in Poland, people learned French.",
      "word_count": 32
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "This was the lingua franca of Europe at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And I learned Russian during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I went-- this goes already into the war years, but I attended Russian school for about a year and a half, and I learned Russian.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "My father-- both my parents spoke Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "My mother had been born in Minsk in Russia, in Belarus.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And my father helped me by reading with me Eugene Onegin in Russian.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And then I learned Hebrew when I was in Israel after the war.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I learned German-- don't ask, out of thin air.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "And the same with the little bit of Yiddish.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "When I was a child, as I told you, I wrote poetry.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I loved to tell stories.",
      "word_count": 5
    }
  ],
