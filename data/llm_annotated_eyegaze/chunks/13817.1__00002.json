{
  "stem": "13817.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "His name is-- was Herman, and he was killed in a-- in a concentration camp as-- as my mother did.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "My grandfather just died shortly before the-- the evacuation started.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "Coming back to Kerpen, we-- we lived, like I said, a normal life.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "We were respected.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "We were I would say a middle class.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "We had a-- we lived in a house with five bedrooms and-- and living room, dining room, two kitchens-- one for-- one for the summer, one for the winter.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "And we had also the business itself, the showroom at the same house.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "And then in the back of it there were the-- the warehouse.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The business was a so-called gas and water [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "That is an electric.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "It was a gas and water and electric [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Installation.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And also we-- we had a lot of appliance sales, appliances, light fixtures, and close to what you would call a hardware store here or more like an appliance store.",
      "word_count": 30
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And-- and both towns, and it was one business.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "At the height of the business when my dad was alive, we employed about 20 journeymen.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "When-- up to 1939 when Hitler came, there were at least 10 to 15 journeymen always working for this business.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And my-- my mother and my grandfather ran the business together, was one business.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And [PAUSES FOR 6 SECONDS] like I said, we were just middle class, and the main thing was soccer.",
      "word_count": 19
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I played on the soccer team when I was seven years old.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "The soccer team over there was not like here in the States.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "There was one sport organization for the whole town.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And from the youngest kids on till the seniors, they had a team for each group, each level of age-- age-- age level.",
      "word_count": 23
    }
  ],
