{
  "stem": "4695.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He was-- he was afraid for consequences like that.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "For that, he sent Hersh [?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Berel ?] to prepare us.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "So your father was afraid that it would be too much of a shock if he just came home.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He was in the city, but he not come to us.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He come-- he, he went to his brother.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "When he went to his-- to his brother, and he knocked on the door.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "He asked him, who is that?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "He didn't tell, I am your brother.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I have a letter from your brother.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And my uncle was very-- a letter from my brother?",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He is alive?",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "OK, come in.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It was 2 o'clock at night.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He opened the door.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He bring him in, and before sat down, please you are nice guest.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Take a tea and he talk with him.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Then when my father drink the tea, and he ask him, gentleman, you tell me you have a letter from my brother.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Can I see the letter? my father gave him paper for write you.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He didn't recognize him because it was eight and a half years.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Then-- then he sent his wife to prepare us for this moment.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "My brother, when my father went away, was eight and a half years.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "When he returned home, he was 17.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "My father could under-- in the middle.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We come one side, I walk.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "My mother keep by my hand, by the hand, and my brother keep on the eye on my mother.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "On the other side, sidewalk, maybe hundred yard away, was walking my father with his brother.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Then my father ask him, who is the gentleman who is walking with my wife?",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They tell him, is not a gentleman.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "This your oldest son.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "[CRYING]",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "He fall.",
      "word_count": 2
    }
  ],
