    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "It was summer.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I was in the house with my parents.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "When the war started, we didn't have radios.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have televisions.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have no way of knowing what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "But they-- I-- I didn't know what to do at that time.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "I could've left my parents and to go to run away to a bigger city like other people, but I didn't want to leave my parents.",
      "word_count": 26
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "I didn't want to leave them alone, and I remained with them till the end.",
      "word_count": 15
    }
  ],
