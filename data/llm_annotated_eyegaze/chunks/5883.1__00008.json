{
  "stem": "5883.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So when-- after we changed clothes, there was another house in front of ours.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "So we went over to the other house.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And then we looked at the road, and we didn't see nobody walking.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Ran across the street to this man's house.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "My mother knocked on the door.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And the man said, if you're not gonna leave, I'm calling the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I don't care what happens to me.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "He said, but you will be killed.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "So we saw we-- it's not good.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "So we went to our next door neighbor, which my mother knew also, those people.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And the man said that he could keep us overnight.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Because he lives right by the road and he has no place.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "He had a stack of hay sitting on the-- outside.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "So he said we could climb in there and take a chance till the next night.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "So we climbed over in there, and he brought us some food.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And he brought us some clothes what looked like Ukrainian people, not, you know, Jewish people.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "And the next day, in the evening, we climbed out of there, and we started walking.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And my mother was the hero.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "She was in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "And she kept just tellin' us that God be with us, and we'll be saved.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 12,
      "text": "Were your-- was your family with you?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the whole family-- my father and my two sisters.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "So we walked the outskirts of the city.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And my mother-- we went into a Polish woman because there were, you know, Ukrainian and Polish people, they were in the town.",
      "word_count": 23
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "And when we came in her yard, we heard Germans speaking in the house.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "So she had like a little shack where she used to keep a pig in it.",
      "word_count": 16
    }
  ],
