{
  "stem": "17001.8",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.1,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I said to her, give me the ticket so I could get the food.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "She said, if you are not sterilized-- you didn't bring me the ticket from the sterilize, you not going to get the meal.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "Meantime, the phone rang.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "So I went and I put my hand underneath the ticket, and I took a handful.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "So when she turned around, with a big-- big shot, that now you can.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "She had no compassion whatsoever.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "That--",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "That these people are hungry, that they want to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "So I went and I stayed in line.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I had the ticket because I stole it while she was busy.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "In-- in few seconds.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "So when she passes by, she said, you're not supposed to stay in here.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You're not going to get food.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I said, oh, yes I do.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "She said, where did you get the ticket?",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I said, here, I have it.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "What's the different where I get it for?",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "She said, but I want you to tell me where I get the ticket.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I said, big shot.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "You want to know where I get the ticket?",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I went through Auschwitz, OK.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Which you didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "So while you talked on the phone in that split second when you turned your back, I stole the ticket from you.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "Now you know where I get the ticket.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I said, you are the meanest person.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "You have no compassion whatsoever.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "We have to break for tape change.",
      "word_count": 7
    }
  ],
