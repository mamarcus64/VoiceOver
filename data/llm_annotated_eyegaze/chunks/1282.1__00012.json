    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And at least we children didn't know.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I believe my father and mother knew.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "They knew much more.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "But they sheltered us.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "They sheltered us as much as the could from the horrors that they knew that exists.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "So as time went on, more and more filtered down from our parents to us.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "Because eventually, they reasoned with us, rationalized and explained to us what we should know.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "But were--",
      "word_count": 2
    }
