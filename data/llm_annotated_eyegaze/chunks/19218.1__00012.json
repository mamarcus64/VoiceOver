  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 73,
      "text": "Nobody came back running after me.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 74,
      "text": "And I was in-- in-- taken in to the labor camp, of course, while my father went the other way.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 75,
      "text": "And this was, of course, the last time I have seen my father or mother.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 76,
      "text": "I seen him go away in the trucks.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And this was the-- the beginning of concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "This was Birkenau.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We were taken from there to Birkenau, because we went through the-- the undressing and-- and-- and everything else and the disinfection, what they call, and disinfected us all.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It could have been a gas chamber.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "What did we know where they were taking us in there?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And this is when-- Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They took us all to Birkenau from there into barracks, and they gave us the striped clothes, wooden shoes.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We were stripped of everything.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I remember I did hide some pictures.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "It's the only thing which I was able to hide-- some pictures inside my body, inside my buttock, as a matter of fact, and I brought them in to camp.",
      "word_count": 30
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] Just to say briefly what happened to the pictures, of course, one of--",
      "word_count": 17
    }
  ],
