{
  "stem": "20580.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 27,
      "text": "[NON-ENGLISH SPEECH] you know the way it tastes.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 28,
      "text": "But that time, that's was the life.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Then, I'll come to the point which I'll bring you out how I come there to Lokacze.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Then, suddenly, they find out I have hided leather and I make leather with a-- a little-- that machine with the hands, you know.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Find it out.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Who told them?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "You know the communists-- they told them.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "My mother says, you better hide yourself.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Because they was looking-- three police was in this house.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And they're looking all over.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "In middle of the night, I run away.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "I was already hided in the roof.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And I run away to my aunt in Lokacze, in the other city.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And I was hided there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "A month, two, three.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "They bring me food into the hole.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And I don't see the light all together.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And suddenly, she says, listen.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "The-- one guy, he says, I cannot hold him.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But you, I have to.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I want to get married.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "You get married with my-- with my daughter, which I know already, from years and years, since childhood.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "She was in 1921, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "You have to-- I could get-- I married her, get free, and then-- no.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Right away, I'll tell you what.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "I told the rabbi, which it was in this country.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And he come in middle of the night, [NON-ENGLISH SPEECH].",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "He came over, the rabbi Volcan.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "He die in America, over here.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "Volcan.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "He [NON-ENGLISH SPEECH] and we went away to Luck-- L-U-C-K.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "My wife-- Michla.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "M-I-C-H-E-L.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Michla.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "Kessel.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Because the children are some-- your cousins are called Kessel.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "K-A-- K-E-- Kessel. double S-E-L.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And-- and she ask, I got $500 American money.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "I'll give it to you.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Says, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And then she gave me food.",
      "word_count": 6
    }
  ],
