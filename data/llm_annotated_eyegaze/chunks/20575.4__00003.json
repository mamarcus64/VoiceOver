{
  "stem": "20575.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 58,
      "text": "I was like, I mean, everybody-- but I was like-- I was hysterical because I thought, that said, now, go in a shower, and we're going to be gassed.",
      "word_count": 29
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 59,
      "text": "And as I was crying like this, one guy came to me.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 60,
      "text": "He was a guard in-- was a guard.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 61,
      "text": "He used to be in the army.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 62,
      "text": "And I don't know, they sent him back there as a-- as a guard.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And he asked me in German, why do you cry?",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I said, because we are going to get gassed now.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I'm so afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And he said in German to me, he says, no, you won't.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Don't forget, this was April-- end of April-- end of April.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he said to me, no, you-- you're not going to be gassed.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "You're not going to be gassed.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "He says, where do you come from?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I said, I come from Vienna.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He was-- he said he's from Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And he says, wait here.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And he went.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And he says, who, who are you with here?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I said, well, my sister and my mother is here.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And he brought us something to eat-- I forgot what it is-- which we-- [LAUGHS] which we ate very fast.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And he disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "He disappeared-- didn't see him until later.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And all right, I was a little bit-- I told the other people-- I said, I heard from this guy we are not going to be gassed.",
      "word_count": 27
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We're just really going into the shower.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And we got some in the shower.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And he gave us-- they gave us some men underwear which, which were full of lice already.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But this is what we had.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Don't forget, we were on the train for three weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "We were, like, smell-- smelly and dirty.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "You cannot imagine.",
      "word_count": 3
    }
  ],
