{
  "stem": "5255.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I mean, not 100% of the Polish population acted that way, but a great-- a lot of people were anti-Semitic.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Jewish businesses-- now, the business owners [PAUSES FOR 4 SECONDS] weren't-- they were the owners of the businesses, but the people that worked for them were non-Jews.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "They run the businesses in the non-Jewish neighborhoods.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And certain-- and not all the Jews in Poland-- in Warsaw-- were Hasidim.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They were very much Westernized.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "The business people were a different group of people, especially people in the retail business, people in banking, and insurances.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "They were entirely different.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "A different group of people.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "They wore modern Western clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They were shaved.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They wore shirt and ties.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "They were just like Americans now.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "There was the-- they were a different class of people.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Not everybody was Hasidish, or wore a beard in Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "They couldn't be recognized so easily.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "A man-- a Jewish person that had a beard, and he had these dark black clothes on-- he was easily identified.",
      "word_count": 21
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So he was beaten up.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't like a-- a revolt against the Jews, but almost every day some Jewish people in Warsaw in certain neighborhoods were attacked because they were Jewish.",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Western.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I-- I didn't want that.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I was dressed like now.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "September 1, 1939, was the first day the Germans attacked Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And planes were over Warsaw with scattered bombardment, not very heavy.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And there was the mobilization right away.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And Germany started marching into Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And they marched all over Poland in, maybe, eight days.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "They were on the outskirts of the city of Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And then the military decided that they will defend the city of Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And the German encircled the city of Warsaw with artillery, and were shooting down into the city.",
      "word_count": 17
    }
  ],
