  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I must admit that I disliked New York from the day I arrived there.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "My cousin came in a Lincoln Continental--",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "--to pick me up at Grand Central Station.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And they were trying to show me all the skyscrapers and down Fifth Avenue.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And I was totally unimpressed [PAUSES FOR 5 SECONDS] and probably remained skeptical ever since.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Of New York.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I was at Columbia for four years.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And-- and at that time, they only awarded bachelor of architecture.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And I went, immediately got a job.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And for two years, I worked very hard to save enough money to take a grand tour of Europe.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And I became a American citizen in [PAUSES FOR 3 SECONDS] 1956.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And the next year, I bought myself a one-way ticket on a steamer.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And when-- at midnight of September 1, when the rates got cheaper for-- for such trips, I sailed for Europe.",
      "word_count": 20
    }
  ],
