  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And that was signed before we were selling to the Poles the suits, and we had quite acquaintance with them.",
      "word_count": 20
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "And one of the Poles, when we told him what's going to happen, he said, look, don't worry.",
      "word_count": 18
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "When something will happen, you just come, and you stay at our place.",
      "word_count": 13
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "So we will look after you.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "We've-- I've got a hiding, and you will be at our place there.",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "So we were very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "And we were discussing, with our parents, this.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "But my parents didn't want to go.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "So we were really worrying, because we could see that every day it was getting worse.",
      "word_count": 16
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "And we knew that they could come any day now, the Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 5,
      "text": "So what we did-- We-- we might stop here.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    }
  ],
