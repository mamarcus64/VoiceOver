{
  "stem": "23579.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "That means from the-- [NON-ENGLISH] mean from the-- from the Polish state.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] I was attending there the high school.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And after the high school, I attended [NON-ENGLISH], like two years college here.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "This was French, history, Polish, and Latin.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "And after that, I did the two years.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "My mother and father wanted me to go to Sorbonne, for dentistry.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Because I had a very big family in Paris, and very rich.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And they said, let's send Sonia here.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "And we'll give her the qualification what she wanted.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And in '37, 1937, my mother took me to Paris to see the family, if I like it, to go there.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "For a while I liked it, but I was very miserable.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know how to talk French.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I was miserable.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I studied in school, but this was not enough.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "So when I came after that, my mommy took me, a madame.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "A madame, a teacher, a French, where she was coming two hours a day.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And she was conversation with me in French.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "When the war began, I was better speaking French than I'm speaking now English.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "But with the time, even you're not speaking a language, you forgetting.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "I'm reading.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And I'm writing.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I had big ambitions.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "First of all, I wanted to go from Novogrudok.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "A time from Noel, that's [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "That's New Year, the Polish, yes?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "My father was taking me always to Vilna or to Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "They were buying me everything what I were thinking about it, a jewelry, shoes.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "They were not buying me in the stores, but they were making orders for me.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "I was only 15, 16.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "And they were making already orders [NON-ENGLISH], Vilna.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "This was the biggest stores for the making the shoes.",
      "word_count": 10
    }
  ],
