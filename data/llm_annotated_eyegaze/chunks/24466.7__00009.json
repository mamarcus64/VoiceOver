  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Szendorowicz was sent to Auschwitz so that from the 20 left, only 18 people, and amongst them, my father.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Was confirmed by that Kormin, that son of [?",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Shmuel ?] Kormin.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I returned to Gdansk.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Till illegally, when I left Gdansk, left Poland, through the town of [?",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Klatzko ?] with other Jews, illegally leaving Poland, going to, that time, to Palestine.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No papers.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "It's not allowed.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I got some papers done before, but by going through-- by going through the [?",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Klatzko, ?] the-- the border, Czechoslovakia-Poland, we should get rid of them.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Some of them, actually, I have.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "That is-- [PAUSES FOR 4 SECONDS] that is out-- [PAUSES FOR 5 SECONDS] to become a Czechoslovakian-- Czechoslovakian citizen, I got this ill-- [? illegitimation. ?]",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No, to become-- to become-- to be able to get out a [INAUDIBLE] passport, [INAUDIBLE] that I am not-- that I am international-- an international passport.",
      "word_count": 26
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I don't need nobody, because that was implanted in me through my dear father, so--",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "That was an organization, too, Yichud.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] [INAUDIBLE]",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The organization was Yichud.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Yichud, Yichud.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Zusammen.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "Was waiting for the-- and the Bricha, what was working there.",
      "word_count": 11
    }
  ],
