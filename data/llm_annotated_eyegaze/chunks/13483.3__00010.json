{
  "stem": "13483.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "Well, I had seven days' leave then I went to work-- [PAUSES FOR 6 SECONDS] this-- this I'm gonna have to remember now.",
      "word_count": 23
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 6 SECONDS] I did do some work.",
      "word_count": 9
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 4,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 5,
      "text": "I did jobs as a radio mechanic, I think, a firm I used to work for before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 6,
      "text": "That's right, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 7,
      "text": "I was fixing up aerials.",
      "word_count": 5
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 8,
      "text": "Mm.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Well, I started up my own business after time.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "I went into business on my own.",
      "word_count": 7
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "And well, I buy and sell government surplus material, you know, right up to the time I came here to Australia.",
      "word_count": 21
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "What made me come to Australia?",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "Well, my-- my eldest son, David, who was about 17 at the time-- this was 19-- decided to come to Australia with a friend.",
      "word_count": 24
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "He wanted to try his luck here.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "I think that was 19-- 1967.",
      "word_count": 6
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, I think it was about 1965, he came to Australia.",
      "word_count": 11
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "And then we got a letter from him to say he'd met a Jewish girl, and he was gonna get married.",
      "word_count": 21
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "So my wife and I decided to come here for his wedding with my young son, Barry.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "Came here for the wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "Stayed here a think for about three or four weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "And I think we fell in love with Australia and decided to come back, so it took me a couple of years, you know, to sell the business I had there, and we came back here in 1969 and right up to the present day.",
      "word_count": 45
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "Unfortunately, my wife had died in '91-- '91, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 11,
      "text": "But life has got to go on.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Well, I still light Shabbos candles.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "I still pray to God.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "Right?",
      "word_count": 1
    }
  ],
