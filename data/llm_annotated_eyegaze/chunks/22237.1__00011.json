  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And when I got off the bus at the next stop, I remember thinking, I didn't-- I could under-- not understand, but these were children, or young people-- they weren't such children anymore.",
      "word_count": 33
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But there were grown up, adult people on that bus.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And I always wondered, how can--",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "It bothered me more than being pushed around by children.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Why didn't the adult people tell them anything?",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Why didn't they do something about it?",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Why didn't they come to my help?",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "So that is what I remember in those years.",
      "word_count": 9
    }
  ],
