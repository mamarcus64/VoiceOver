{
  "stem": "11797.6",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "There was a guy came by.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They had a cow.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "They killed a cow in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It was a different kind of camp.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "This was a different kind of camp than the other ones was.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "This was more camp.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "There was more eating.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "It was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "They want to build you up a bit, but I was so gone with the ground, I must have weighed less than I weighed before.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I was so skinny though, they called me a Muselmann.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "You know, a Muselmann means a step before dying.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "They called them Muselmann.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "My brother called me the Muselmann.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "My feet were so swollen.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "My hands were swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "My eyes were swollen.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "My stomach was big.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "And I had my wooden shoes, my [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "And one of them, they killed a cow outside and they threw in a piece of skin with the hair from the cow to our barrack.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "I would lay on the couch.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "Somebody, one of the haftlinge, he was one of those prisoners threw in a large piece of skin instead of throwing it away.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "They thought they might find some kind of necessity to use it.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "He was sucking on it for hours.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "And the guy next to me, he sucked on it.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And this place, they gave us a little bit more soup, with more ingredients inside than the previous ones.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "And this was going on.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "This was a little better, They didn't treat us as bad there, but we were treated much bad there from these other prisoners because they were very strong people.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "There were a lot of German people there.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "They were put in there for reasons that they committed to their own country, like murderers.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I was laying there with a blanket.",
      "word_count": 7
    }
  ],
