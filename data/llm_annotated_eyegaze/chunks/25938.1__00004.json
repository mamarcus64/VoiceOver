{
  "stem": "25938.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "I used-- it was in every house there was a pushka, you know, that little-- and we used to-- and then we used to go every week or so and collect the money.",
      "word_count": 33
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "That was a-- that was a tradition.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "It was not Zionism.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "It was-- that was Jewish life, a tradition to-- to-- to-- for Israel, for Zion.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Unfortunately, I didn't have any plans then to go to Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Even--",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I believed in Zionism, that's right, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, yeah, for me too.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "But see, to-- that would be to be uprooted from my-- my town.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "We didn't think in these terms.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "We just-- we were trying to help-- to do-- to help that cause.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "But that [INAUDIBLE] didn't go.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "We knew about that Dr.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "Herzl, we heard about this.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "I used to-- that's how I started writing poems.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I-- I published my first five poems in Philadelphia.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I sent from Poland in '98.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "In '98, I sent five poems to-- and they published it in a-- in a Jewish newspaper.",
      "word_count": 17
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "It was called [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "Over",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Hitler was not in the picture then, when I started to-- to work for Keren Kayemet, for the Jewish National Fund.",
      "word_count": 21
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "It was later.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "It was about maybe, I don't know, 17 years old or-- or 19.",
      "word_count": 13
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "I can't-- I don't remember.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I cannot say right.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "As I said, because to me-- see, the motive to me to collect money for-- for-- for Keren Kayemet, that-- that was the thing to do.",
      "word_count": 26
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "We didn't-- we didn't use the word 'Zionism' even then.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "Didn't call ourselves Zionists.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "I think that as a Jew I had to do that.",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "But later I-- I-- I-- I-- I learned, I read the Zionist literature.",
      "word_count": 13
    }
  ],
