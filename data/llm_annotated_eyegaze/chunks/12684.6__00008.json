{
  "stem": "12684.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "One of them, unfortunately, died about [PAUSES FOR 3 SECONDS] three or four months ago.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "At first, I worked at the household from these friends of Mr.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE], and they paid me $10 a month-- a week.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I worked from 8:00 in the morning until 10:00 at night.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And they figured it was a very good salary they gave me.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And they lived in Great Neck, and they also had a farm in Afton, New York, and I had to work there, and clean their house, et cetera, et cetera, be their maid.",
      "word_count": 33
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And after that was over-- and I really didn't like that-- [PAUSES FOR 3 SECONDS] I did I don't how many jobs.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I worked as a sales girl.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I worked as a laboratory person-- a man who was a nose.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Do you know what a nose is?",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "A man who makes perfumes.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I worked there.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I worked for Welcome Wagon.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And I can't tell you how many jobs I had.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I don't think I have enough fingers and toes.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Because people would hire me, but I didn't know anything.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I didn't speak English too well, and I couldn't do this and I couldn't do that.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "So it was rather hard going for the first few years, or many years.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "I was the assistant of a public relations-- in a public relations agency.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I was the assistant of the president and an account executive.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "That I had two guardian angels [PAUSES FOR 5 SECONDS] because I made it through.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Six million didn't.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Two guardian angels.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "That's all  I can tell you.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "You don't know who your guardian angels are.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "One is too busy-- would have been too busy.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He's too busy.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHTER] I still have them.",
      "word_count": 5
    }
  ],
