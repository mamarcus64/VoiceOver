  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "There were, obviously, some people still behind.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "And we were arrested, put into prison.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "[PAUSES FOR 3 SECONDS] [SIGHS] My luck, who should be the Sergeant in charge of the guard house, is a boy called [NON-ENGLISH].",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "If you remember, [NON-ENGLISH] was my home town who spent the times in the ghetto in our house.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 39,
      "text": "He saw us.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 40,
      "text": "He knew us.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We told him the story.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you better try and find somewhere else to go.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] said go, go to another camp.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Turn up somewhere else.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And, unfortunately, that-- the majority of the people who went there to [?",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Latrun ?] didn't come back.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So there is, again, a little story that-- whether I was destined to stay alive, I don't know.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "It's a bit unpleasant to say that we didn't want to do-- we made out that we don't eat kosher.",
      "word_count": 20
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And we don't [INAUDIBLE] in the army.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "It wasn't-- but that's what we did.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And we're here.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "It's a little-- it might not be in sequence.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "But these little stories that you hear from me today that some are pleasant, and some unpleasant.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "I suppose it's unpleasant to tell that I disobeyed orders.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "But, nevertheless, I must have a vision that I wanted to stay alive.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "That's what happened.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Who was--",
      "word_count": 2
    }
