{
  "stem": "13198.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Beatrix, with an X, Sachs-- B-E-A-T-R-I-X Sachs, S-A-C-H-S.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was van Lier, Beatrix Van Lier. small V-A-N, and then second word, capital L-I-E-R.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Oh, well, I had my first husband's name.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Frank.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Beatrix Frank-- F, for Frederick, R-A-N-K.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I'm born on the 13th of November, 1910.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "And I'm 80-- I shall be 86 this year.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Eastbourne, Sussex-- town and country--",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "England.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was rather dominated by the Grand Hotel, where-- my father had the orchestra there and was the conductor, or leader.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He was a very good violinist.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was an excellent violinist, too.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And she was also part of the orchestra.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "So my parents were a good deal out of the house, and we were sort of more brought up by a nanny, whom I adored, who was as good as a mother to us.",
      "word_count": 34
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Her name was-- do you want her name?",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "She's dead now, of course-- years ago.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We always called her Nanny.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But what was her real name?",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Ada.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Ada-- I really didn't know what her surname was anymore, because she was never called Miss.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "She was always called either-- she was always called Nanny by us.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And I think the whole family called her Nanny.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my younger sister, who was [PAUSES FOR 5 SECONDS] 20 months younger than-- than I was.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, she's eight years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And there were two boys in between who both died at birth.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my-- both my mother and father were born in Holland.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But my mother came to England when she was very, very young.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And my father came to England also when he was a teenager.",
      "word_count": 12
    }
  ],
