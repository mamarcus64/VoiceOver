{
  "stem": "18281.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.9,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "It was just one year before our liberation.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And they went from there to Avenue Louise, the Gestapo headquarters in the, the cellar there.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They went to the assembly camp of Malin on the outskirts of Brussels and left with the 22nd transport.",
      "word_count": 19
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "The Belgians have exact records.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "And my parents are number three and four, prisoner number three and four.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And they went to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "The Germans told them that they are only going to a labor camp in Holland and that they'll be back soon.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And my dad or my mother threw a letter from the train and a postcard.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "The letter is on the wall of the Holocaust center in Montreal.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And it says, we are fine.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "I lost one of my shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "Don't ask me how.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "And we are only going-- we're together with Belgian Jews.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "That was one of the first transport that also arrested Belgian Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And we are only going to Holland to a labor camp.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "And we'll see you soon.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "And bring the money to grandmother.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "That letter was thrown from a cattle car through a-- probably a slot between two [INAUDIBLE], through, through the wood.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "I'm sure that my parents didn't have any stamps.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "But the Belgians, with their bicycles, went along the railroad tracks and picked up the letters that prisoners threw from trains and mailed them.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "That letter was mailed to a girlfriend of my grandmother so that even if the Germans would find the letter, they wouldn't know where we are, like a safety precaution.",
      "word_count": 30
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "They addressed this to a friend of my grandmother's.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother, due to the marriage, the famous marriage that I related to you-- I can tell you again-- was a Belgian subject.",
      "word_count": 23
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She was an old lady with white hair.",
      "word_count": 8
    }
  ],
