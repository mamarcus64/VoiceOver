{
  "stem": "1502.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "It was very difficult not to go in Yom Kippur to-- to a synagogue for-- we-- we made all the prayers that take a whole day, we made them in a half hour.",
      "word_count": 33
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "And it was Passover.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "Somehow, the Judenrat had matzahs.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And we sent the woman, and she got matzahs for us on Passover.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "But shortly after Passover-- and I think a few days, a week or so after Passover-- one night, it was the night of April 27, 1944.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "We are awakened in the middle of the night-- maybe it was around 3 o'clock-- by tremendous banging on the outside door in the house.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "We immediately knew what that means.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "We knew who was there.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "They didn't wait for anyone to open the door.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "But they broke-- they broke the door.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "They broke the front door.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "They came in very-- very wild and very brutal.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "They're extremely brutal from the second they came into the house.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "When we heard the banging-- my sister, her husband, and myself-- we decided to try to escape.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "We were in our night-- nightwear, in our pajamas.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "And we got out on the roof, the three of us.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "The-- the Gestapo came in.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "It consisted of a officer-- it was an elderly man, he was German-- a-- two Belgian SS, who were extremely brutal.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "And the fourth was sitting in the car in front of the house.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "And now, the SS-- which I don't know if it was German or Belgian.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "They-- We went on the roof.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "We heard, from the house, screaming and beating.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "They were beating up my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "They tore off from a-- a leg from a chair.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 46,
      "text": "And they beat my mother in the face.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 47,
      "text": "And they beat my father, my brother.",
      "word_count": 7
    }
  ],
