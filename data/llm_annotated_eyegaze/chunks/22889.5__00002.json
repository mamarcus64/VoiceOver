{
  "stem": "22889.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "They brought her from the ghetto [PAUSES FOR 3 SECONDS] because the women were separate, they slept in different barracks than the men.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "But some people, they were married.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They used to get together with each other and so forth on, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Sometime the women came, and they slept overnight, too, with their husbands.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes they stay with their boyfriends, too, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] Myself, I didn't had so bad in, in Plaszow, really, because after work, I got myself a job in the kitchen.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "A fellow I used-- I knew-- me and my friend Benek Kalfus, he lives in New Jersey, we knew them.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We-- give us a job.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "So after work, we used to go to the kitchen, clean out the kettles, used to cook the soup for the people in camps.",
      "word_count": 24
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, you know, this was a, a-- this was, like, they called it kosher kitchen, this particular.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was different kind of food than the rest of them.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] It's funny thing.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I could never figure out why do they keep like a kosher food?",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It wasn't kosher food, I'm sure, but it was a different kind of food for the, for some people.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So I had a job, so I always had something to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "So I don't have so bad in Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS] One time we received a shipment, barracks came in.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Was a one Sturmfuhrer, his name was [NON-ENGLISH], in Plaszow.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He was a murderer.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "He was no good.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We had to go to the railroad station, empty the barracks, carry it on my shoulders, you know, parts because all were prefab, to our camps.",
      "word_count": 26
    }
  ],
