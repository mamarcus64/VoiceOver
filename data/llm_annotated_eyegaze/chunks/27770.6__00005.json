{
  "stem": "27770.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And about two weeks before we were prepared, already, to be destroyed.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Because the German get a-- got a order to destroy the whole camp.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "They made a grave, what we had to dig, this grave.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "If I would tell you a grave, what, maybe 10 times as big as this room.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Had to be deep at least like, two floors deep.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And it was prepared, the grave.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "We prepared for ourself, the grave.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Soon as they get the order, the Germans, they all throwing in there.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "But this grave had a second purpose, not just to bury us when we are dead.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "There was no facilities, toilet facilities.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "So anybody who wanted to go to-- please forgive me for saying it.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "He had to stay-- if this is the opening, you had to stand next to the opening and arrange your arrangement.",
      "word_count": 21
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "Whoever fall in, in this grave, because it was very big, he stayed there.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "He choked in human waste.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "This was the grave.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "The hunger was so big already.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "Yeah, before I finish this, I have to tell you, again comes the Red Cross.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "And everybody's getting one coffee spoon of sugar.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "So have to stay in the line.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "The line has to be straight.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 29,
      "text": "And we're waiting, already, for the Red Cross is giving us sugar.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 30,
      "text": "At the SS comes.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 31,
      "text": "And before he wants to give you the spoon of sugar, he looks there, straight.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 32,
      "text": "And the line is not straight.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 33,
      "text": "Piff, piff, piff.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 34,
      "text": "All these people around got shot right away because he was not straight in the line for the spoon of sugar.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Everybody walked away, no more sugar.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Because we figure if another few days, we become free already.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So why to get killed last minute?",
      "word_count": 7
    }
  ],
