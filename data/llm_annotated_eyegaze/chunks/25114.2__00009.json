{
  "stem": "25114.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "At first, when the Germans came in, the first thing they did, they said, we have to organize the Jewish community.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "So let's go and make a meeting.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "All the prominent people, like lawyers, doctors, state counselors, all sort of prominent people.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "We'll have a meeting in the city hall, and we'll see how to organize the Jews.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And the ones that were vain went there.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "The ones that had a bit of more-- [LAUGH] they could reason better, you know, didn't go.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "Nobody has seen them since.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "First thing-- that was their policy.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "They liquidated the leaders of the community.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "That was right after they entered-- the same week, that.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We need to organize the Jews, and we need all the prominent citizens to come in town, so we can talk things over and organize the community.",
      "word_count": 27
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So they went, and nobody has seen them.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "They were the first to go.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And then they had some, uh, casual shootings.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "They'd just go to the marketplace, with a lot of shops, and they'll pick up 50 Jew people and just put them-- line them up in the market and just shoot them.",
      "word_count": 32
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "For no reason whatsoever.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I remember they had 49, and there was one still open-- a pharmacy.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "They went into the pharmacy, and they took out the pharmacist Jew.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Because they needed 50.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "We were witnessing it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't there, but a lot of people were there.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And then they were all dead, and they went to put-- the cemetery.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We knew the people.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "It was a town that everybody always knew everybody else.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And we saw it.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I didn't see the-- when it happened, but other people did.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And then they were just casually catching up people.",
      "word_count": 9
    }
  ],
