  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And we heard-- let's say, on the other side of the track from Malynsk-- we were on one side, them on the other side-- was a Polish town.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And all the Polish people left the town.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "The Germans gave them a train, and they took them.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And we didn't know where they took them.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "Because some Ukrainians was telling me that they took the Polish people to Poland, or they took them to Germany to work in the camp.",
      "word_count": 25
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "But they left the-- the town.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "When they left the town, they left the fields with-- with food.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "You know, there was enough potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "You see, if you would do that on a Ukrainian and they catch you, they would kill you to take out.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "Even, we stole a potato.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "So we took out from one bush one.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "We took out from the other bush another one, not to be noticeable that we dig.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "But over there, we had-- we-- we went over to the other side, my mother and my brother, all three of us.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "Then we heard from others there was a little girl with a brother.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "[PAUSES FOR 3 SECONDS] They had their mother with them.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "And one night, she froze to death.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] And they-- they remained.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
