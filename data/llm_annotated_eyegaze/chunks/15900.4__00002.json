{
  "stem": "15900.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.6,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And they called my boss, and they tell him, you could be arrested.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "You brought him to America, guaranteed a job.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And you have so many people employed, and you laid him off?",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "I didn't know you don't have money.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "I said, what, I have to report to you?",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "I want a job.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And the HIAS said to me.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "They're gonna give me $25.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "I was making $20 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And he said to me, $0.50 an hour.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And he says, all right, I give you some money.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "Maybe we find you a job.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "I said, I don't want money.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "I want a job.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "I don't want charity.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "And the boss said to me, all right.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 25,
      "text": "Come back.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Since then, I went back.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I worked twice as hard.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I used to sneak in, in the dark room, when the people were working, photographers.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I never told them.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I finish my job cleaning and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "I sneaked into the dark room.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Later when he need some people, printers, and I learned the trade better with them.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't work.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I just watched them.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And he needed to finish the job, first the schools and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I said, how about me learning?",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "What you?",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "You don't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "I said, let me go in.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I show you.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "Give me a job.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And I made the pictures.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Since then, he was shocked.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "How did you learn?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Later on, he said-- and-- and I organized everything.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I told him, a big place, how to keep the files, how do anything.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And he said, you know what?",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I'm now gonna make you the manager.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "I said, you crazy?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "You're going to make me the manager.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I said, how much I'm going to make?",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Oh, we give you a raise.",
      "word_count": 6
    }
  ],
