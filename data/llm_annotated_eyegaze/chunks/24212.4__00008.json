  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "Somehow put the picture of a horse on the wall.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "That was art.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "That was a sign of another life.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "But we didn't enjoy our room too long, because then we were taken on that march, the hunger march.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we still were together until the hunger march, at which point, I told [?",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Veritza, ?] the one who's in Yugoslavia-- [PAUSES FOR 3 SECONDS] it's so hard to believe that [?",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Veritza ?] is more than 60 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Anyhow.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And I said, watch me.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "I am going to lots of good confusion, because it was such a mess that you wouldn't believe this.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "German refugees.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Army refugees.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Our refugees.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Jewish refugees.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "You name it.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "People going with pieces of furniture on top of a horse one way, and others went-- it was unbelievable on the highways.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "Military machinery, and we all had to go into the ditch because the military had to go through.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I said, lot of confusion, I'm going to try to escape.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And I wasn't the first one, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And I said, if you want to run with me, don't move from my side.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Because if the chance comes, I go.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "You are there, you're not there, I go.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Don't move from me.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "And she did.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Because we got to this village, and there was a cauldron, but cauldron, you know, like they make plum preserves.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Oh, you wouldn't know about plum preserves in Europe.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Anyhow, a big cauldron of boiled potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And not for us.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "For the German refugees who were coming through, running from the Russians.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And our group who just zoom on that cauldron of boiled potatoes, including [?",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Veritza. ?] And I went in the other direction, over the fence.",
      "word_count": 12
    }
  ],
