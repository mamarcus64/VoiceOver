  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So [PAUSES FOR 3 SECONDS] about 10 days later, Goebbels called off the pogrom.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I went home, back to Breslau from Berlin.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And, as a matter of fact, while I was in Berlin, I prepared my-- for my immigration.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I found a travel agency in Berlin-- the Palestine [INAUDIBLE], whose manager said, I can get you out of Germany.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "But I need your passport, and you have to get a visa for Peru.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I'll ship your passport to the Peruvian Consul in Paris.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "And for $280-- payable in dollars-- you will get a Peruvian visa, and we'll put you on a boat in Hamburg.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I didn't have $280.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "It was under severe penalty-- it was prohibited in Germany for any German to own foreign currency.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I had a very distant cousin in Gastonia, North Carolina, who had immigrated to the United States.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "He sent $280 to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] He was an accountant with this-- with a textile mill in North Carolina.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I need to-- I'll be right back.",
      "word_count": 7
    }
  ],
