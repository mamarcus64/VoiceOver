{
  "stem": "22685.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "And the first one without arms to go on the fields to blow up the mines-- and this is out of thousands, maybe 10 remained alive or something like that.",
      "word_count": 30
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And I was supposed to end up with this end.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Then I met-- I saw people, friends that I knew, Jewish people, that were going to the Polish army.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "And I told one to give me a bottle of vodka.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "He brings me a bottle of vodka.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Next morning, the, the sergeant comed in-- comes in to check.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I give him the vodka.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He said, why?",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I want to go to the commandant of this-- of the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He said, you cannot.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You have to write.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I said, I wrote already a letter.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He doesn't read it.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "But the vodka speaks very-- much better than anything else.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "He took me to the-- gave me to, to soldiers around with a-- with a gun, with a-- with a rifle in the back and the front, like a real gun.",
      "word_count": 31
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And they took me to the commandant of the-- of the camp.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And I started to tell them what is my story.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I am a Polish citizen.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I want to go to the Polish army.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Why do they send me to the Russian army?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And I worked all the time for this organization, which was called [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "[NON-ENGLISH] is an abbreviation-- [PAUSES FOR 3 SECONDS] city, [PAUSES FOR 4 SECONDS] city-- the supply of energy to the city.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "All the fields, wood, coal, oil came from this organization.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And I said, I-- why don't you check?",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And he said, oh, I'm glad-- he tells me, I'm glad you told me.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "I need some wood.",
      "word_count": 4
    }
  ],
