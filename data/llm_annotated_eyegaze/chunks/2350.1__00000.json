{
  "stem": "2350.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Good afternoon, Brad.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Lilly Tykocinski, L-I-L-L-Y T-Y-K-O-C-I-N-S-K-I.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Lilly Butnik.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And the Hebrew name, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "B-U-T-N-I-K.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Zawiercie, Poland, November 12, 1928.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "That's the real age.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, gosh.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Z-A-W-I-E-C-I-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if I did it right.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "That was the closest to Katowice, and not far from Auschwitz, like within 40 kilometers from Katowice, and close to the German border.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "We were a very normal, middle class family.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We were seven siblings, four brothers and three sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I was the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And we had with us living our grandfather, who stayed with us all the years that I remember.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And he passed away in 1938 at the age of 107, officially, they said.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And my father, he had butcher business in wholesale and retail.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Joel Butnik.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was Faigla.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And her maiden was Weinreib.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "My father had one brother and three sisters, and they all had children.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "My mother had two brothers and one sister.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "So from the whole family, I survived, my four brothers, and one cousin, that I found after 25 years, and a cousin that she is my sister-in-law now, from people, maybe 60, 70 people in the family.",
      "word_count": 37
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "So that's all what we were left.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Very close family.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Very close family.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "Listen.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "In Poland, everybody was a close family.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We lived together.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "We shared the good and the bad together.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And everybody respected the parents.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Were everything for us.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Whatever the father says, goes.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "We all went to school.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We had a comfortable home, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Not like in the United States comfortable.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "But for Polish conditions, it was quite comfortable.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And we were a happy family.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "We visited the families.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "They came to visit us.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "We shared simchas and all other activities.",
      "word_count": 7
    }
  ],
