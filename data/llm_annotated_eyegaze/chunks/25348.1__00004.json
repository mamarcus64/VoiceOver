{
  "stem": "25348.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And of course, I was a city girl, which was different and differently dressed to the peasants and the locals.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "I wore plaits, and one remarked that how cute that girl looks.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And the other sort of nudged her.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "She's Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "And they all turned away.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "This is the kind of experience that I had as a child in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "How could I take it?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was, it was natural.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "But I was, I was liberal, in a way-- not in the sense that I approved of it.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But for example, my grandmother had a neighbor not very far away.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And she was a schoolteacher.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Her name was Miss [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And Miss [NON-ENGLISH] was fond of me.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So one-- it was some kind of, of a Polish holiday, of a Catholic holiday, and she brought me a platter of biscuits.",
      "word_count": 23
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And my grandmother was very kosher.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "She wouldn't want that platter of biscuits to have at home.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And she kept threatening me that I will die unless I give the, the biscuits-- because they weren't kosher-- unless I give them to the dog.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I thought to myself, I'm going to try whether God's, God's going to punish me for eating those biscuits.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And I never gave in.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Even then, I was stubborn.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "What I can tell you about my home.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My father was-- when I opened my eyes, he was always praying in the morning-- [CRYING] I'm sorry-- [CRYING] before he went to business.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "But he was a very good man, and I think fairly broken, because mother left us.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he didn't have much time for us.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We didn't want anything or need any material comforts for the standard that were maintained for children in Poland.",
      "word_count": 19
    }
  ],
