{
  "stem": "12810.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "And my girlfriend said, that's the boy for you.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I said, Cat, how can you say that?",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "That's a-- we are not thinking of that way yet, you know, it's-- I was so, so upset-- the whole things.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I was not over it yet, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And then the coming Rosh Hashanah-- and I light the candles from front of my family's picture.",
      "word_count": 17
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And my husband come in, and I was crying.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And I said to him, I said, why I survive for what?",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "I am alone here.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "And he said, to make me happy.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And that's how we get together, really.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "That's the story of my life.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "We married in-- in September.",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "And he said, he-- he want to marry me.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And that he said, but not yet.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "I said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "I not-- don't need a boyfriend.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "Sorry.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "We get married.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "He said, when?",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "I said, I take you to the priest, and I will tell you.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "And I take him over there to introduced him.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "To the priest?",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "To the priest, of course.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "Had he--",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "--was my father.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "And he said, and when you want to get married?",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "I said, in four weeks time.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "My husband look at me, [LAUGHS] and he said, and how?",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I said, I will fix it.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 5,
      "text": "And I ask, and I fix it.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 6,
      "text": "In four weeks time we was married.",
      "word_count": 7
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Yes, in-- in his place, in the priest's place.",
      "word_count": 9
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "And then--",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "The priest.",
      "word_count": 2
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah!",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "So I married three times.",
      "word_count": 5
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "So that's why my marriage working.",
      "word_count": 6
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "First time married in the town hall.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 4,
      "text": "Then I married in his place.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And then before we come out from Hungary, we go to the Rabbi, and we have a ceremony.",
      "word_count": 18
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "So I have three weddings.",
      "word_count": 5
    }
  ],
