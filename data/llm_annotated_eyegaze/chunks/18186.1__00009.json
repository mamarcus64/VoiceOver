{
  "stem": "18186.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 281.9,
  "sentences_input": [
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "I with my-- my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 1,
      "text": "And they divided the ghetto in tow halves.",
      "word_count": 8
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 2,
      "text": "The men went-- was-- lived in one half and the women and children in the other half side.",
      "word_count": 18
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 3,
      "text": "They-- if there was a boy who became 14 years old, he had to go to the men's side.",
      "word_count": 19
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 4,
      "text": "And I could only see my father-- there was also a fence between the two sides.",
      "word_count": 16
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 5,
      "text": "And the only time I went to see my father, I sneaked in.",
      "word_count": 13
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 6,
      "text": "Or some-- once in a while, they let you in or they let them out to see the family.",
      "word_count": 19
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Sort of like, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "In my house-- in the house I lived?",
      "word_count": 8
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 1,
      "text": "I assume about 20, 25.",
      "word_count": 5
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "All women and young boys.",
      "word_count": 5
    },
    {
      "segment_idx": 170,
      "sentence_idx_in_seg": 0,
      "text": "And kids, children.",
      "word_count": 3
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 0,
      "text": "The house had two rooms and a kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 171,
      "sentence_idx_in_seg": 1,
      "text": "And that's all.",
      "word_count": 3
    },
    {
      "segment_idx": 172,
      "sentence_idx_in_seg": 0,
      "text": "We slept in the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 173,
      "sentence_idx_in_seg": 0,
      "text": "My-- There was-- there was nothing to cook unless we-- we sneaked out of the ghetto and were running going to Polish or Ukrainian people begging for some food.",
      "word_count": 29
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 0,
      "text": "Till they gave us some of the-- yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 1,
      "text": "I did too sometimes.",
      "word_count": 4
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 2,
      "text": "I was the only one in the family.",
      "word_count": 8
    },
    {
      "segment_idx": 174,
      "sentence_idx_in_seg": 3,
      "text": "That's--",
      "word_count": 1
    },
    {
      "segment_idx": 175,
      "sentence_idx_in_seg": 0,
      "text": "I--",
      "word_count": 1
    }
  ],
