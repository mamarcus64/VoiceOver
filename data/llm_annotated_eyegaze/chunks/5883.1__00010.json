  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And was the fall when we got to her.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "So she put a lot of pumpkins on top.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And she left one little opening so we could go down there.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And we all climbed down there, and we stayed in there for 16 months till we got liberated.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't tell.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, everybody was-- [PAUSES FOR 5 SECONDS] you want me to keep going?",
      "word_count": 15
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Well, the life was very strange because everybody was afraid.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They didn't know what the next day will bring because when you went to work, the SS was there with the-- with the whips, standing right over you, and you were very scared.",
      "word_count": 33
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And you have to stay in the houses.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "When you get back, you couldn't go no place.",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "You have to stay in your own place.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "You were like in a jail.",
      "word_count": 6
    }
  ],
