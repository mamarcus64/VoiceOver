  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 3 SECONDS] And the first thing that they did [PAUSES FOR 4 SECONDS] after they settled in the camp, and after they oversaw what was [? on, ?] the next day they came with DDT pumps, DDT guns.",
      "word_count": 40
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And God bless them for it.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "Because we were eaten away by the lice.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And they sprayed our clothing.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "They sprayed the straw in the barracks.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "They did not let us into it.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "We had to get undressed.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "They sprayed our bodies.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "They sprayed our clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "God bless them for it.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "Because this was-- I think if I would win now a million dollars, I don't think I would be as happy as I was as happy then when that itching stopped.",
      "word_count": 31
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "That was May 8.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And May 9 I was liberated from lice.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
