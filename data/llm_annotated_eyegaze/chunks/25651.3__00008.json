{
  "stem": "25651.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "It's a-- it's a whole interesting story about my mother, because I overheard these two women talking-- women's talk.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "I wasn't supposed to listen, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "I was supposed to be asleep.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "But-- [LAUGHS] we were all in one room.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "She was in bed with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "And I was in bed with [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "And I was straining to-- [LAUGHS] --to hear what was being said.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "Anyway--",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My brother, [NON-ENGLISH], I, my mother-- three-- one room.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "We had a piano from-- from home-- [LAUGHS] --that was taking up a quarter of the room.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "So then, there were two beds.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And, I mean, you couldn't walk two steps without falling over something, because we went from a huge house that we had in Novy Jicin to this pokey little room.",
      "word_count": 30
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "He came to England.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "He was in England.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And he came to England in January 1939.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "He just-- there's a passport.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "He came to England as a-- as a-- he was a major merchant.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Oh, because he wanted to transfer a large amount of money.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "So he bought furs-- precious furs this time-- in Russia.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And he had them transported to England.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And he came to take them out of store and sell them in London.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And that was his capital to save us.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I remember, my father was a-- an operator.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He was-- he was a very, very astute man.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Unfortunately, my mother just didn't live up to that.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "She knew she was different.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "She has a different view of life from him.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "He was cosmopolitan.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And he was-- he knew political situations.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "And he could outguess, you know, what to do with money, how to conduct oneself, and so on.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "My mother couldn't outguess anything.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "She was duped.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "I mean, we were all duped.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And my mother wasn't stupid.",
      "word_count": 5
    }
  ],
