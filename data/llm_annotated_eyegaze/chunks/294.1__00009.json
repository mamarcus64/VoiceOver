{
  "stem": "294.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He still-- his brother and him still owned the business.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They had, like, a wholesale of leather skins, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And he said he has to stop and let his brother know that they have guests.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And he stopped.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And who does he come back to the dorozka?",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "With my husband--",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] --future husband.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And I remember how he introduced us.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "My friend-- high school professor-- this-- everybody in Poland was a professor-- [LAUGHS] --the teachers-- a high-school professor, Leopold Pfefferberg.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And this is how I met my husband-- yeah, my future husband.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And this guy took us to his house.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And my husband, and then other two people, lived also in this apartment, because my husband's parents were thrown out from their apartment by the Germans before I came-- before my mother and I came.",
      "word_count": 35
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "So part of the family-- he lived with this friend, and his parents and the sister lived with some family.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "So the family was, you know, broken here.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no-- completely different section of the city.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I just met him--",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "--in the dorozka here.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "No, future--",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "--I said future husband, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "My future husband, again-- there were many doctors-- many-- and many people who fled toward the Russian-- you know, toward eastern part of Poland.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And from there, they were taken, or they fled themselves, deeper into Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And my mother and I always felt very sorry that we didn't do it.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "We started.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "There was a big exodus in my city of Lodz, at the very beginning, right two days after the Germans came.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was trying to get to eastern Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "So there was a big exodus of the city-- everything by foot, you know?",
      "word_count": 14
    }
  ],
