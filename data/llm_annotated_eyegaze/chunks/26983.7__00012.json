{
  "stem": "26983.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 1.9,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Some of our boys were sent to be people for the SS, call boys for the SS in that Zigeunerlager, which later saved my life.",
      "word_count": 25
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Two of them are still alive or three of them.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Some were sent to different places.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Some were [NON-ENGLISH], which was a very high kind of functioner.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Running around, but this [NON-ENGLISH], it's unbelievable if I say it today, they had power over life and death about all the prisoners.",
      "word_count": 23
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "If he was a bad [NON-ENGLISH], for example--",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "He could take the whole ration of the whole day of the coffee and spill it.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And the people would be without food.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Or vice versa, I remember we tried to help and we took bread and we-- later on Czech people came, and we distributed it.",
      "word_count": 24
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "Or when children from Lodz came--",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Well, a little less.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Because one boy found his father, Kulka, who is today a professor at the university.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And so he was taken to his father who had a kind of workshop.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And he was staying with him.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And as I told you, others were [NON-ENGLISH] and so on.",
      "word_count": 11
    }
  ],
