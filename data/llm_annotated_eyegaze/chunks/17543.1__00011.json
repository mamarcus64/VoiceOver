  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "I was shouting, Mommy, Mommy, [SOBBING] Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Hochhauser in Hungarian.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And every barrack I went and shout at top of my voice.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "There's nobody taking notice of me.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "I went to the next.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I was doing that for ages, because 22 barracks was all together.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "I went to all this.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And I was waiting somebody recognize me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "Because they were just laying on these-- there was no blanket or anything.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "They was just laying on that wooden [PAUSES FOR 3 SECONDS] bunk beds.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "But large because a lot of people could go on-- on each of those bunk beds.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "And on the very end of this-- it's called [?",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "C ?] lager-- we'll continue.",
      "word_count": 5
    }
  ],
