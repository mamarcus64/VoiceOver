{
  "stem": "26609.20",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 22,
      "text": "She went from house to house looking for Jewish children, just openly asking for money, money they get-- got from the United States.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "A lot of money-- United States-- how do you call it-- like [NON-ENGLISH]-- sent in money to get out-- they-- and you ask them did they need money to pay some Polish people.",
      "word_count": 33
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "They pay them off, they can get out.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "Otherwise they had the children.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "They didn't want to give them back, not because they loved them so much, but to convert them to Christianity.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "That woman, she was a rabbi's wife, the one who told me my husband's alive in Nuremberg.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "She and others, some others, went around from house to house, from convent to convent, from church to church, looking for children and paying a lot of money-- they got a lot of money from Jewish com-- from United States-- Jewish-- how do they call them-- like [NON-ENGLISH]-- to pay to get out the children.",
      "word_count": 55
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "As they went on Grudetska Street, where that woman lived, side of Grudetska, they saw a little girl-- winter on snow, barefoot, only in a little shirt or nightdress like this, shivering, with no hair, as I have the photo there.",
      "word_count": 41
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "I have it-- that's-- she was already [INAUDIBLE]-- on the street.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "They ran after her, out of the house where she was.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "That was my daughter.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "They ran after her, two women.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "And she was there.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "She told me this story.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And she said, little girl-- and they had with them with them, in a bag, dolls and everything to tempt them out-- many were left in convents and [INAUDIBLE]-- and said, little girl, what's your name?",
      "word_count": 36
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH]",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She understood already.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It was after the war.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH] I don't want Jews.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Jews will kill me.",
      "word_count": 4
    }
  ],
