  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes, if a peasant would, you know, go by on the-- with a horse and a buggy, he would stop and take us.",
      "word_count": 23
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And he would drop us off wherever he would turn, and we would walk again.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And that's how we would get places.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "I don't remember if I walked, or somebody, you know, somebody took me.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I think I went alone.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I-- I don't think my mother and my sister went with me.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "That was my private visit.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Well, by train, it's about an hour and a half to two hours.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Legnica?",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Well, now, it's about 100,000 people.",
      "word_count": 6
    }
  ],
