{
  "stem": "7832.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She was selected out of Birkenau and sent to-- I think she said she was working in an ammunition factory in Mauthausen.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I'm not sure which camp.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "But she was in a labor camp after that.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "When we arrived there, we were assigned to bunks, our own bunks.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And I thought I was in a hotel because the bunks had straw, and a blanket, and pillow.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I said, no, this is not for us.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "This is a impossible.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "What-- what did we do to deserve this?",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "But yes, it was.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "We were supposed to be mechanics to fix the machines that-- that were in the factory.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And these were our quarters.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And we were brought in at night so everybody was sleeping.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "It was a very small camp because I only remember seeing one huge building.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "And I don't know, maybe there were buildings behind that one.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "But I only-- only-- I always only saw this building because we were taking each morning and go across a street into the factory, and stayed there all day and worked, and came back to the same building at night.",
      "word_count": 40
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "So I don't know what else went on there.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "But the-- but the best part of this-- of-- of-- being there was that I found my friend, Sabka again.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "I woke up the next morning, and she was in the bunk underneath me.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "I was in the middle, and she was in the first bunk underneath me.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "And I put my head down to see whether there was a real person underneath me.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And she picked her head up and the two of us met.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "You know, we looked at each other, and at the same time we both screamed.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "How-- how did you get here?",
      "word_count": 6
    }
  ],
