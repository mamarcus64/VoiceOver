{
  "stem": "2946.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "He-- he audition for the Metropolitan Opera later on.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "I accidentally turned the radio, heard his voice auditioning for the Met Opera.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "But he died shortly after.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 15,
      "text": "And Karel Berman, who became conductor of the Toronto-- of the Prague National Theater opera, he was staying with us.",
      "word_count": 20
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 16,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 17,
      "text": "Garren ?] and Moses Singer, also Singer-- that's his name, Singer, but he was a singer.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 18,
      "text": "And he was, we got a piano.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 19,
      "text": "There was a lot of singing going on.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 20,
      "text": "And that's where we stayed.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 21,
      "text": "And this friend, Gus, told me, there is a Israeli fellow here who was buying guns for Israel.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 22,
      "text": "He's getting the gun out to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 23,
      "text": "But he was caught.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "The train, the car-- the train car was open, and it was declared as electrical equipment.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They opened it, the customs, and they found guns there.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So he escaped, but he was looking-- the radio was looking for him.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Would you hide him for a few nights?",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "He slept there, over, with us.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And when he left, because he had to sleep over some nights, over somewhere else, he said, if you need any help, look up this guy.",
      "word_count": 26
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "He gave me the name.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I looked up this guy.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We want to get out of here.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "There were all kinds of rules by the Communists, you know, that we didn't like.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "And I looked up this guy.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I said, oh, could you help us to get out of the country?",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "He said, yes, but it will cost you money.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I said, all right.",
      "word_count": 4
    }
  ],
