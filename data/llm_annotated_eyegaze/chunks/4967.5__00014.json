  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "And they employed German prisoners to clean the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 26,
      "text": "But they had a hell of a job to clean it.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 27,
      "text": "The Americans fed us very little.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 28,
      "text": "But we thought we were clever.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 29,
      "text": "But there were cleverer people than me.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 30,
      "text": "I stayed three times in the queue to get three meals.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 31,
      "text": "They didn't give us any milk.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 32,
      "text": "Then may have given us rice, porridge, not to get a runny stomach, and not loose food.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 33,
      "text": "No fried eggs, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 34,
      "text": "And a lot of biscuits.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 35,
      "text": "I actually [INAUDIBLE] a tin of biscuits which lasted for a month, I was eating it.",
      "word_count": 16
    }
  ],
