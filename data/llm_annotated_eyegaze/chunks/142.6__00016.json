{
  "stem": "142.6",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.5,
  "sentences_input": [
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "And I don't-- I don't know how he used to do that.",
      "word_count": 12
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 5,
      "text": "And the-- the other problem with this kind of people is after work, they used to go to their families not too far away, a couple of miles from-- from the camp, and having-- having a wife and children.",
      "word_count": 39
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 6,
      "text": "And I could-- I couldn't think or believe that a guy of this nature would do such things to-- to the children.",
      "word_count": 22
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "No, never.",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Well he used to bring the people from-- from the station, you know, to the crematorium",
      "word_count": 16
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "In front of the people that are there.",
      "word_count": 8
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "Just-- very, very, very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "I don't even like to tell the story.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "I always told the story about Moll-- Otto Moll.",
      "word_count": 9
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "Always.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "I wrote about and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "It-- it was a very, very bad feelings.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "All of the people that work in the sonderkommando, the feelings that you get in-- in your soul.",
      "word_count": 18
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "And then you don't know what to do.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "Always-- I always, at night, many times, I will-- and the only thing I will think is Moll.",
      "word_count": 18
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 4,
      "text": "Because he is the-- the people that I observe.",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 5,
      "text": "And I don't know, and I don't-- don't think that were pretty nice things to do.",
      "word_count": 16
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 6,
      "text": "I don't care who you are in society.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "And we were looking at there.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "And they did so many things that were not-- you know, they were killing the people.",
      "word_count": 16
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "What do you have to play with them, and having taken young girls and shooting them [INAUDIBLE] here and here and there.",
      "word_count": 22
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "No-- responsibility, no.",
      "word_count": 3
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "I-- I know people, there-- there are a lot of people who are survivors, they don't care about us at all, you know.",
      "word_count": 23
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "But who-- we couldn't do anything else?",
      "word_count": 7
    }
  ],
