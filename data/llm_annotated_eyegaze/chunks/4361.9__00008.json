  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "I am very, very involved in this particular project that Steven Spielberg is sponsoring because the importance of the testimony is the more [PAUSES FOR 4 SECONDS] needed now when the deniers are abounding all around who say it never existed.",
      "word_count": 41
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "That six million Jews, if they died, it was heart attack, malnutrition, high blood pressure, but that gas chambers?",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "It's made up.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "It's the Jews' fantasy.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "This is what is happening today, and I am very, very involved in, in making sure that the truth comes out.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I write on this.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I speak on this.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 4 SECONDS] that's where we are at.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Because I think it's beautiful to, to know, to understand because I do think that ignorance breeds prejudice.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Ignorance breeds bias.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And only education inside perhaps may, may help to overcome this.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And I also think-- I, I, I I think that without knowledge, without, without reading a poem that really moves you, without reading the or without-- I mean, without listening to music that moves you, life is drab.",
      "word_count": 38
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Life is drab without-- it's not--",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "There, there is a book, the title of which is And I have no idea who wrote it because I remember one of the first books when I began reading English.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "This is what it is.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Why did the cavemen paint those cave paintings in the Lascaux caves?",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Yes, perhaps there were some-- there was some religious significance, but they were made pretty.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I saw those, those cave drawings before they closed the caves.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "There is something that the soul needs besides the food, the shelter.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And what the soul needs is love.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "What the soul needs is friendship, goodness.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And what the soul needs is the need to soar, sometimes, by just hearing, hearing a song.",
      "word_count": 17
    }
  ],
