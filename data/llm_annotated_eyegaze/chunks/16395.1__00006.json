{
  "stem": "16395.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "In 1939, when-- really, before-- a couple months before the war.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was very well observed.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Well, two weeks before, we started making matzah.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We-- it was in private homes.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "There were people working.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And they were preparing the matzah and baking them.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And my mother used to go in and buy whatever she needed.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "I think they bought it in a big-- I don't know how many pounds, really.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "But they brought it home.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "And we had it over the Pesach.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "She-- she cleaned.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The whole the house was empty.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "They took out the beds.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And they-- and they cleaned the beds, and they washed the floors.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And they-- they painted the walls with white and took out all the [YIDDISH], because we had a lot.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And our whole [INAUDIBLE] was outside.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "It was a real preparation.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I hated this.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "Before really came the holiday, she was so tired that she couldn't wait until it's over.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "It was a big preparation.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We had then the Seder.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "All the kids came to our house.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And we all-- always had my father with all the children, was sitting ahead of the table, and we had the Seder.",
      "word_count": 22
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I was the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I always I am ashamed to say it, but I never was till the end.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I always fell asleep.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "My mother used to put me to bed.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We-- we had younger kids.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "My sisters' younger children, they were saying the four questions.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It really came out in one time.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The war came out, and it's-- from day to day, we had different things.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "The first thing was-- well, we felt it right away, because in a month, the Germans took over the whole street, because, I said, it was the nicest street.",
      "word_count": 29
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And they threw us out.",
      "word_count": 5
    }
  ],
