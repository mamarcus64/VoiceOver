  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He-- I talked-- I talked to him because I wanted the name-- it was very-- in all the units, we heard about it, and we were really scared.",
      "word_count": 28
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Because as I said, we were totally depending on the-- on the commander.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "The commander had-- life and death was in his hands.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Whatever he wanted to do, nobody-- there was no law-- no law to protect-- protect us.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And we came to this place, and we-- we-- we-- they stopped us, and we just saw German high officers put out tables in the middle of the street and looking at maps, and we thought we were surrounded.",
      "word_count": 39
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We were hoping that if the Russians would liberate us.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what the Russians did.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "We found out after the war, then, they liberated-- I have a cousin that fell in-- that in those camps, the Russians, they treated him-- they treated these people like they treated the other-- the other poor prisoners.",
      "word_count": 38
    }
  ],
