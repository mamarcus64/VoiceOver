{
  "stem": "23626.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 32,
      "text": "And I ran to the drawer.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 33,
      "text": "I grabbed a white kerchief.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 34,
      "text": "And I said to Helen, I have to go.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 35,
      "text": "Because in case Adele and Betty are in the, in the transport, I'm going.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 36,
      "text": "She says, Helen, don't go.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 37,
      "text": "Don't go.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 38,
      "text": "Let's see what we can do with her.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 39,
      "text": "She was sleeping upstairs, his mistress.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 40,
      "text": "I said, no, no, I can't take chances.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 41,
      "text": "I'm going.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 42,
      "text": "She was trying so hard to hold me back.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 43,
      "text": "I said, no, I have to go.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 44,
      "text": "In case they are going, I'm going with them.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 45,
      "text": "I had no one anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 46,
      "text": "And I ran down.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 47,
      "text": "And you know, I probably lost my head.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 48,
      "text": "Because I was running so fast.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 49,
      "text": "And when I saw them in the middle of the transport, I ran straight to Goeth.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 50,
      "text": "He was in front of the cattle cars, right in front of the entrance of the camp.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 51,
      "text": "And I probably lost my head, because I thought that if I tell him that my sisters are there, maybe I am working for him such a long time, maybe.",
      "word_count": 30
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 52,
      "text": "Well, he looked at me with such a vicious look.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 53,
      "text": "And he swung his arm.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 54,
      "text": "He hit me so-- over my head-- so hard.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 55,
      "text": "He says, get away.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 56,
      "text": "And he put his hand, hand on his, on his gun.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 57,
      "text": "He said, if you don't go, I kill you.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 58,
      "text": "And I hear, I hear somebody in the back of me, move away, move away, a German, SS.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 59,
      "text": "And I'm slightly moving.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 60,
      "text": "He says, move away, move away, I tell you something.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 61,
      "text": "He says, don't say nothing, just walk, walk.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 62,
      "text": "I tell you something.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 63,
      "text": "He says, keep walking.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 64,
      "text": "Don't look at me.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 65,
      "text": "He says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 66,
      "text": "Go over to your sisters and tell them to move slowly back.",
      "word_count": 12
    }
  ],
