{
  "stem": "22004.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And they played-- played a play about him about that time.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And I played the-- his role.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "I played-- I played Trumpeldor.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was-- it was-- I belonged to a club, where they was playing often different kinds of plays.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "This I play-- I sing in the-- in the Jewish-- in the Jewish-- in the Jewish organization here in Cleveland.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I was singing there.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I even got a picture from them when I was singing in a group.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] I don't have anything.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Hobbies?",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "What are--",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I can dance.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was running-- I was with another friend in Losice.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We got this dance group, was learning-- learning people dancing.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, I was a good dancer, but [LAUGHS] not now.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "I can dance.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "But not--",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, I traveled away.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And one time before when my father started to launch the business with salesmen, I went to kibbutz in Bialystok in Poland.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "I was three months in the kibbutz.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And I was trying to get a certificate to go to Israel at that time.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And it was-- I had to be there too long.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "It was my friend who was there for three years.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And it's got a hard time to get a certificate.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And so I left the kibbutz.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I didn't give up.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I was trying to go.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "But it was no way-- not-- then when the war broke out, it was-- was a waste.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "My friends?",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I got a lot of friends.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Not too many non-Jewish friends-- not in our city.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was-- in our city was real bad.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "We didn't-- we didn't like each other.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "But in the school, in the-- in the public school-- they used to go together.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    }
  ],
