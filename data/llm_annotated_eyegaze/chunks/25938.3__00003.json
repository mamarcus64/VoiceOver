  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, the same kind.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "The same.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I never opened it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I never opened it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Interesting.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Now I wonder much.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And sometimes I think about it very intensively.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I know this--",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No-- yeah, sure, sure.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They did-- they did all kinds of useful things.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They used to bribe-- bride the SS.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They used to-- to-- to bribe everything.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Maybe it was-- maybe it was a lot of jewelry, gold, a lot of valuable things.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And maybe it was ammunition.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Later, I heard they found-- they found a girl, four girls who were working for a-- in a-- in a factory.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And they had ammunition there in the-- in the-- and they-- they had ammunition.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And they were hanged, these four girls.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "It was known.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "In the-- in the-- it was in the press, in the literature.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I-- interesting.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I think I told you that in New York, years ago, I was in-- in a-- in a cafeteria on-- on 96th Street, I think.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "That cafeteria [INAUDIBLE] I used to-- used to write about.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "I used to eat there.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "I live down not far from there.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So one man came over to my table and said, oh, [?",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Leon. ?] You remember me?",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He stood next to me.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Like this.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Do you recognize me?",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And I said, who are you?",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I don't know you.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Do you remember you used to tell us what to do?",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "We used to sometimes-- we had-- we had to-- we used to gather all the five groups, the five cells with me.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "We used to go to a place where the Jewish doctors, they were also in a movement.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They used to have to see us.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We have to report to them without speaking.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "They was a sign how to do that.",
      "word_count": 8
    }
  ],
