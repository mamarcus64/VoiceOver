{
  "stem": "19352.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 557.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Dora Nesselroth.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Poland in 1922 and my father's name is-- [PAUSES FOR 8 SECONDS] Ezra Rozencwajg.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They were born also in Skarzysko-Kamienna.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "They married in 1917 in Skarzysko-Kamienna.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I have a brother and a sister.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They both are survivors of the Holocaust.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "My sister was five years old when a friend of ours came to the ghetto and took my sister and-- [PAUSES FOR 3 SECONDS] --and saved her.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "They were marvelous people.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "My brother went with his father to Buchenwald, but he survived.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My brother's name was Joseph.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "My sister's name is Lydia.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "She's a medical doctor in New York City.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in Skarzysko-Kamienna.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I went to school there.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "After I finish grammar school, I went to high school.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I finished high school the same year when the Second World War broke out.",
      "word_count": 15
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I have a very good life with my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My parents were very loving people, both of them.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "They gave-- they tried to give me a good education.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "High school at that time, you have to pay tuition.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I went to a private high school because in our town, they haven't that didn't have a government high school.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They have a few in the whole country and the Jews were not permitted to go to a private school at that time.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "My father teach me to respect and to, [PAUSES FOR 3 SECONDS] to, [PAUSES FOR 4 SECONDS] to respect and also to said the truth whatever.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "He didn't think that people are bad, they're only people.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "Everyone has something good in them and we're supposed to help those people to bring out the good things from a person.",
      "word_count": 22
    }
  ],
