  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Yes, we-- we-- we were very much concerned about our families, but were not aware of the real danger.",
      "word_count": 19
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The-- there was-- the best description for that time between our leaving and our arriving was one big question mark.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We did not know what we were in for.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "We had, of course, an idea of-- of what we would have to study, because we had started to study for the rabbinate.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But we did-- had no awareness of-- of what school life was like in America, how it would differ from-- from Germany, what we could take for granted and what would definitely be a-- a new experience.",
      "word_count": 37
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "The-- it-- it was an exciting thing, because obviously we knew that we were going to be among friends, because they were thoughtful enough of us to-- to bring us there.",
      "word_count": 31
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "But what that would mean, we did not know.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "The--",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "English.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "--two-- two of us were fairly fluent in-- in English.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "The remaining three had studied English, but did not speak it very well.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But they learned fast once they get to this country-- got to this country.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "The skyline of New York, something which of course we had seen in pictures many times.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "But to see that skyline and to see the Statue of Liberty, that was just the thrill of our lives.",
      "word_count": 20
    }
  ],
