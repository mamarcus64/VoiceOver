  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "Martin was already gone because the Army had released him finally to a British company that wanted him to work with them.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And they had gone.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So I couldn't drive in those days.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And we got together, two families, and they were driving to Spain, to drive that, that corner, the southwest corner of France where people were refugeeing to get into Spain.",
      "word_count": 30
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And-- but Martin and his family were-- and his group, his office, were on the river Loire in a place, little place called [INAUDIBLE].",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And we drove there.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "And this other man left us there and he drove off with the car.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So I was with Mark.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "We slept on the floor that night.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "And then we, we heard the Germans were coming.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "The French were not going after all to set up a line there.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "They were going to go further south, maybe to North Africa.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And so we stood on the, on the platform all day until late at night, one train after train full of refugees, even things piled over on top of, top of the train, would pass by and not stop, till finally one stopped.",
      "word_count": 43
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And we squeezed in.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "There was not much room, and we just squeezed in.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "I forget what I had.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "I think I had grabbed a package of dried fruit I would give my child to suck every now and then one.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "We got there, instead of getting there at midnight, to, to Bordeaux, we arrived at noon the next day.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "Martin's office was set up, but we found a place on the outskirts of Bordeaux in a little-- we slept overnight in a little wooden hut on the land of a market gardener.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "And that night, we heard bang, big bangs and noise.",
      "word_count": 10
    }
  ],
