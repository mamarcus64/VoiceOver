{
  "stem": "5225.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He said, no it doesn't work this way.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "He say, you come with me to a lawyer, and the lawyer going to take it over because it's not yours.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It's just your parents.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And if you going to settle, you're going to have money.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And I knew that if you go to a lawyer it cost money just for talking to him.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So I just knock on the door, he comes out, he say, listen man.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "I don't have one penny to give it to you.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "This guy wants to buy my father's house.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "If you could take it, for him money take it I don't have nothing.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "He said, you come in.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I come in and was on table glass with cigarettes.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "Maybe about 10, 12 cigarettes.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "I asked him if I can take a cigarette.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "He said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "I already took three, two in pocket, and one in mouth.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "Do you know when I walked out from him I got all the cigarettes, and he give me 1,000 zloties, the lawyer.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "He said, you don't worry.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "It's your money.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "I just what I need is a witness that's your parents were killed and he saw it and your brothers were killed that he saw it.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "I just need witnesses.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "I said, I got witnesses.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "I got the cousins.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "He said, that's good.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "It was like a judge that was going to them.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he told them.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They put the house on my name.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And that cost 10,000 zloty to take it over from one to another.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I said, I don't have money.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "He say, who told you about money?",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "He pays everything.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "The lawyer pays everything.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And after then the customer says, how much you want it?",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "You tell me.",
      "word_count": 3
    }
  ],
