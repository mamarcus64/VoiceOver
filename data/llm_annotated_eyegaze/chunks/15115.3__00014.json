  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "But I found out later that it was bad.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Well, in case you run away so they'll know who you are.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Because in Warschau, there was no electric-- in Warschau ghetto when we got down there, there was no electric wires.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "It was just-- what do you call-- a brick wall, you know, are surrounded.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And there were some guards, you know, on top, just a few guards.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "It was sort of nothing there.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "There was no-- there was nothing, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "When we got into Warschau and I start-- they started building our own.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "We didn't have even two at the stage.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Just odd barracks.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "So they started building the barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I got started working, bringing potatoes from the-- from outside and carrying by hand to the kitchen for-- for the cooks to start preparing food for us, you see.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "Like-- and it was hard work, you know, I was young and it was cold already.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, OK.",
      "word_count": 2
    }
  ],
