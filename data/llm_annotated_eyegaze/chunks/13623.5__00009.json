  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 38,
      "text": "[PAUSES FOR 3 SECONDS] After a while, some of us that were a little stronger than others, when we got out of the camp, they went into the German houses in the surrounding area.",
      "word_count": 34
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 39,
      "text": "And they were-- they were taking whatever food they could find in the-- in the-- and they-- they had-- they didn't have a problem of-- with food.",
      "word_count": 27
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 40,
      "text": "They-- there was no law and order at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 41,
      "text": "They could have robbed.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 42,
      "text": "They could have taken gold, diamonds, any kind of valuables and nobody would have done anything to them.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 43,
      "text": "The only thing they were looking to take was bread and anything that was able-- we were able to eat.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 44,
      "text": "And they would bring it back to the ones that didn't go out to those houses to accumulate all that food.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 45,
      "text": "[PAUSES FOR 3 SECONDS] After a while, things got a little better.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 46,
      "text": "The-- we got-- the problem was that we were so-- our stomachs and our insides were so dried up from lack of food, that-- I would say thousands of people died after they were liberated from overeating.",
      "word_count": 37
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 47,
      "text": "Because they ate anything they could put-- lay their hands on.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 48,
      "text": "[PAUSES FOR 3 SECONDS] Pieces of bacon, ham, whatever they-- It was fat.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 49,
      "text": "Fat-- food that was too rich for the intestines at that time because we weren't used to-- our bellies weren't used to have food in them.",
      "word_count": 26
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So people would drop after they were liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Well then, life is-- they-- we're being fed by the, I assume, British army.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Slowly we were trying to-- we are still in prisoner clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Some of us that found regular civilian type of a coat would put it on, to-- to bring him back to the civilian life.",
      "word_count": 24
    }
  ],
