  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "They were-- they were-- they were taking children as runners-- go here, go here, find out what's going on next block.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "Find out here.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "So I think I did some running.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "My brother did some running, I did some running.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "Some kind of-- of orders to do.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "Something to do-- just to find out what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We saw people dead.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "We saw people-- about a few hours later, it started smelling, that it-- it was very dusty, from the bombs, no.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And-- And we saw people-- fleshes-- flesh of people laying on the street, no, from the-- from the people got killed from the street from the-- from the bombs, no.",
      "word_count": 30
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And-- [PAUSES FOR 5 SECONDS] we-- well, it was-- it was-- it was very bad.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Very much so.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Well, I was a young kid, and I was very frightened.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Bombs were the first experience I ever had, no.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I never heard bombs, no.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "Of course I was afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And for a long time, afterward, no, any kind of explosion, or any kind of sound of a big loud noise, no, used to affect my ears, no, from those bombs.",
      "word_count": 31
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Even when I was in the-- in the camps later on, there was still like a shimmering noise in my ears, hearing from those bombs, no.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We went back to the house.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We went back there.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We came out.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We tried to help.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We went-- first we went to houses, no, where they were bombed, to see what's going on there.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "How many people got killed, no.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Oh, they were screaming, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "They were hollering.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "People were hollering, oh, this one got killed, this one got killed, this one got killed, no.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "People were crying.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "People were screaming, you know.",
      "word_count": 5
    }
  ],
