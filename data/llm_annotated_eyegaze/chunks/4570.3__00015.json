  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I had a room with my girlfriend.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "I made friends with a girl who is now an old lady like me.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And she's in Carmel.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And we had a room together.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "And, and Italy was very good.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "But I had no connection to go to America.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I had no relatives to send me papers.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So we waited in the camp and then came Chile and Venezuela.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I didn't think that was right.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And one day on the loudspeaker they said, Australia is opening migration.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "So all three of us went.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I came in 1949 to Sydney.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I've been here ever since.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Stop.",
      "word_count": 1
    }
  ],
