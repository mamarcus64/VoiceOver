  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "Like every week would be a train going to Auschwitz.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know where it was going.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "They didn't tell us anything.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "But they said they were going  to take us in a place where we're all going to be together, and there was going to be housing, like everything.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "In the meantime, oh yes, they were also in the ghettos again.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Any valuable possessions, any money, anything that you have, give it up because you're going to be severely punished.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "Home, it was from the Hungarians.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "In Berehovo, it was from the Nazis.",
      "word_count": 7
    }
  ],
