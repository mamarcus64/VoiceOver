{
  "stem": "18186.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 4,
      "text": "And I saw-- I saw the four boys and the policeman walking with them, after them with a gun, with a-- with a--",
      "word_count": 23
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "You know, what is a big-- the rifle, the rifle.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And they killed them.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "They were gone.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And then we--",
      "word_count": 3
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "It was like September time.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "To me, it's-- I think it was September, maybe it's beginning of October.",
      "word_count": 13
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "But it's something like this, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Because right after, winter came.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "And we had-- we had-- we couldn't sleep in-- in the forest.",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "So this Polish lady gave us-- let us into the house once in a while.",
      "word_count": 15
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Not all the time, but--",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "And some others did too.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "Some others did too, let us in, or they lets us sleep in the barn or so.",
      "word_count": 17
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "Because it was very dangerous for them to let us in.",
      "word_count": 11
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "Because they knew if they-- if anybody was hiding Jewish people, they'll be-- they'll kill them, just the same as the Jewish.",
      "word_count": 22
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "So they were really--",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Strangers, completely.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Well my Polish family, who survived it, is-- is-- was Janicki.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "I have the--",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
