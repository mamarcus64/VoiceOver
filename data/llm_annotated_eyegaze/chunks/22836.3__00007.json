  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 16,
      "text": "Now this time, he tell me to go-- to go and see what going on there, over the lake.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 17,
      "text": "Three men, it took us.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 18,
      "text": "But I was not-- I was never run the first one, and never the last one.",
      "word_count": 16
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 19,
      "text": "Always go, like, in the middle, see what happen.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 20,
      "text": "And they start shooting on us.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 21,
      "text": "They start shooting on us.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 22,
      "text": "When they are shooting on us, they shoot one.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 23,
      "text": "One run away, and they catch me.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 24,
      "text": "That's where they catch me here.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 25,
      "text": "That's where they catch me here.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 26,
      "text": "And finally, they took me back.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 27,
      "text": "That was my luck.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 28,
      "text": "Like those things, they going to cut up the end, they cutted up the end, the legs, everybody.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 29,
      "text": "Over there, they cut me out the end.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 30,
      "text": "And they took me back to [NON-ENGLISH]-- that's a burg back in Russia.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 31,
      "text": "And they took me there.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 32,
      "text": "They keep me there six months.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 33,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 34,
      "text": "Six months they keep me there.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In hospital.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "My wife was in [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "She knows I'm in army.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I was writing letters to her.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And I was telling her even I'm hurt, but not bad.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And she was thinking I'm bad hurt.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And then we went there.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And finally, I got a Jewish-- there was Jewish doctor there.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And she give me [NON-ENGLISH], come on, go back to [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "She gave me six months off to go three months and three months.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "And when we come there, the-- I was-- I was trying not to get healed.",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "I don't want to go back to the army.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "But anyway, they was getting healed.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "In the meantime, the war was finished.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 11,
      "text": "That's why--",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Because I'm afraid to go again on the front.",
      "word_count": 9
    }
  ],
