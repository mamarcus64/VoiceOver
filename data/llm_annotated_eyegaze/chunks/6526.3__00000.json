{
  "stem": "6526.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "From the Umschlagplatz.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "That was on January 18.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "When I-- when I-- when I came to, to the Umschlagplatz, I found my friend that we originally came to Warsaw together, and with his sister and brother-in-law.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And we were-- and one nephew.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And said, all right, we are here alone.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Let's stay together.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And we'll plan what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And we decided that we're going to jump from the train.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And we made the plan that the first one to jump was my friend's sister.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "She was-- I knew her from before the war.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "We knew we were going-- we're going-- then we already knew that we go to Treblinka, to a, to a--",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know exactly what Treblinka was.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "We know-- we knew the name of it.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And, we know we were going to--",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "We're finished.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "So we had to take no chances, either this way or that way.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And we decided that the first one to jump was the-- my friend's sister.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And she would follow the train.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "The next one to jump was the, the father and follow the train.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "The next one to jump was the-- was I, and then the nephew, and then my friend.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "While we were walking with each other, I could see that my friend did not jump.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "When I jumped from the train, like, I would-- a feather would fall down on the floor, like I was swimming, such-- so easy that only a button from my jacket fell off.",
      "word_count": 33
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "It was a, a, a freight train.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "It was a freight train, a cattle car.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They was all mixed.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "No seats.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was sitting on-- if you find a seat, you could sit on the floor.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "From the window.",
      "word_count": 3
    }
  ],
