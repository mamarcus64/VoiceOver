  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "You sleep!",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "He know my name, because I was his adjutant a few weeks before.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "I was his adjutant.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "He know me before.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "He know me.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "I said, I'm not sleeping.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "He said, you asleep.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "He said, no sleeping.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "You're not sleeping now, but you were sleeping before.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "And he start to deliver a speech, a moral speech.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "Ganc, he told me, you know what responsibility you got here.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "The Germans, they only are two meters or three meters from here.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "They was-- that's [INAUDIBLE] the Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "We was in the forest.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 31,
      "text": "They was outside the forest.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 32,
      "text": "If they will come, they will kill you.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 33,
      "text": "They will kill us.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 34,
      "text": "They will take away all the, all the ammunition.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 35,
      "text": "He speaks a, a moral speech.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 36,
      "text": "And I told myself, if [INAUDIBLE] [NON-ENGLISH] and I will [? disappear, ?] I would be happy not to listen to his speech.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 37,
      "text": "After he finished speech about few minutes, he come close to me.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 38,
      "text": "He put his arm on my shoulder.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 39,
      "text": "He tell me, Ganc.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 40,
      "text": "[SPEAKING RUSSIAN].",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 41,
      "text": "On Russian, that mean pity.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 42,
      "text": "I did not report.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 43,
      "text": "You [SPEAKING RUSSIAN], not report.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 44,
      "text": "Then after we went kick out the Germans from [NON-ENGLISH], we went further.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 45,
      "text": "Majdanek was already free.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 46,
      "text": "We went further.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 47,
      "text": "We come to the river, a town named [?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 48,
      "text": "Pulawy. ?] This town is the river Wisla, Vistula, of Polish, of English, is Vistula.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 49,
      "text": "We crossed the Vistula.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 50,
      "text": "Very heavy fighting was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 51,
      "text": "We crossed the Vistula.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 52,
      "text": "We went again in a forest.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 53,
      "text": "Little fighting was going on between in a few days, every few days, a little fighting, not very heavy fighting.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 54,
      "text": "And one day, a officer from the, from the high officers come along.",
      "word_count": 13
    }
  ],
