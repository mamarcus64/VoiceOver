{
  "stem": "3040.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Well, there were no volunteers so they picked 20 people.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They marched into the kitchen, which was outside of that camp.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It was in the larger camp, because this one didn't have a kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And when they-- when they came back, every two people carried a large canister of black water-- like coffee.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "There were-- these maybe 50 liters canister, so tall.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "They needed two people to carry.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "They lined up 10 canisters, one next to the other.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "And now everybody was supposed to come close to get a-- a ladle full of coffee.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "But there was always a skirmish.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Everybody-- you know, people want to get ahead.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "People want to get it sooner.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And there was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "Oh, you're going to be punished.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "He took all the 10 canisters and turned it upside.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "They poured the coffee out.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "This was the end of the coffee.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Nobody got any coffee.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "This happened not once, not twice.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Every day.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Every day, they brought 10 canisters of coffee, and they poured it out to the ground.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Nobody got coffee.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "This was the cruelty of-- of-- of Flossenburg.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I mean, probably every camp had its own.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "But this was-- OK.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "So no coffee.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "We stayed out in the cold outside, and we try to warm, standing one next to the other.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And then at about 12:00, they chased us in to the barracks.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "They're bringing soup.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "Same story with the-- like with the coffee, they needed volunteers, and they brought the soup.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And they-- they pushed the-- all in the-- in the barracks to one side.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "They lined up the canisters with the soup in the center.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And people would come over from one side, get their soup, and go to the other side.",
      "word_count": 17
    }
  ],
