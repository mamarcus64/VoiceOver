{
  "stem": "17299.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 99.3,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Her aunt was the secretary from [?",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Shols, ?] the chief of the labor office.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "For the Riga ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And she made sure that we had good work kommandos, where something was to eat and also that nobody would get [NON-ENGLISH].",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "That means housed outside of the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "The family stayed together.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And that is how we survived.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "My oldest brother, Kurt, who died in Salaspils.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Hilda.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And, and her maiden name was Zander-- Z-A-N-D-E-R.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And her aunt was Emma Harf, H-A-R-F.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And her husband was a policeman in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "She made sure that we were [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And my sister worked in a clothing depot in the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And my brother-in-law was a policeman.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "OK, that is where the Latvian Jews were.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They were separated from this German ghetto till October, 1942.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Then a couple of Latvian Jews had escaped.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And the Germans found out.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And then they surrounded the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I was all day in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I had burns from caustic soda on my arms and I had to go to the hospital.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "And on my way to the hospital, I got stopped by the police and pushed in a house.",
      "word_count": 18
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "On here, near the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And here, I saw that they were selecting Latvian Jews and putting them on the tracks in the Latvian ghetto.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "And then they marched the police, 30 policemen, on the [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "And then they had to line up in one row.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 12,
      "text": "When they were lined up in a row, Lange took the machine pistol off his shoulder, and some others too.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 13,
      "text": "One was Zoger.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 14,
      "text": "The other I can't remember.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "There were quite a few.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "And one of the policemen yelled, run!",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "So they started to run.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "And the Germans opened fire.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "And they got shot.",
      "word_count": 4
    }
  ],
