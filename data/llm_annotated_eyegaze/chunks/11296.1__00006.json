{
  "stem": "11296.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They didn't give us nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "So I had an aunt who had-- how you say this-- a little place on a field, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "She was holding the-- I don't know-- something.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "She said, go in there.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "You're going to-- you know, it's summer.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "It was summer.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "You're going to stay in this place till we going to find something.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "What was it like?",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "A shack.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It was a-- it was a little shack just-- and we made our bed there.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't take the furniture, so we took a piece of plywood.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "We made a bed.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So there was-- the other sisters, you know, they was married already the others.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So it was just me, and my sister Hanka, and my brother, my father, and my mother.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And it was-- and we were staying a whole summer.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We didn't do-- there was-- I did.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "They took first of all, the Germans, you know, they made-- when they made the ghetto-- but even before, right away they took the Jews for them to work-- the young girls, like me, you know, all the-- the old ones, the young ones.",
      "word_count": 44
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "The intelligentsia, they took the other way-- way.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "They put them on trucks.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "They took them to jails.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "Or they took them to another camp.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "They took them to [NON-ENGLISH] camps, to working camps.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And these people never came back.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And we never saw them.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Some went to jail.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Behind the town, there was a jail.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "So they took them-- some to jail.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "Or people who didn't have money, they said, you're going to give so much-- so much money, we're not going to take you.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "Whoever didn't have the money, they took them to jail.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "And so the young ones, they took to work.",
      "word_count": 9
    }
  ],
