{
  "stem": "11067.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My full name, Suse Margot Rosenstock, S-U-S-E M-A-R-G-O-T R-O-S-E-N-S-T-O-C-K.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Herz, H-E-R-Z.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is May 6, 1931.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "So, at present, I am 64 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Worms on the Rhine in Germany, W-O-R-M-S.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And it's on the river Rhine, and Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Albert, Albert Herz.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My mother was Flora Herz.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I have one sister, Edith Herz, now Pagelson.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We had a hardware store in the town of Worms.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My father was a businessman.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "My mother worked in the store with my father.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And we had an apprentice whose name happens also to be Herz, but no relative, who worked for us in the store.",
      "word_count": 22
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "There was a woman in the office.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "We sold farm implements also to the farmers that were in the surrounding area in those days.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "You sold household items, but as I said, also farm implements, axes, and the things that you need on a farm.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "My father would go and deliver these things.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Sometimes I would go with him.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "So I got to meet some of these farmers.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The standard of living was a good one.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "We were middle class people.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We had a lovely apartment right near the store.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "It was across the courtyard.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And we were-- you know, my parents would play cards with friends.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And we had art, music in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "My father was always afraid that I wouldn't be able to carry a tune because he couldn't.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And my mother worked very hard at fostering that so that we would also always appreciate music and art.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And of course, it was a good standard of living.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, Jewish issues, of course, we belonged to a synagogue.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "We were members, active members.",
      "word_count": 5
    }
  ],
