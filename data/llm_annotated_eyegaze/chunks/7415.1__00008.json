{
  "stem": "7415.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 26,
      "text": "And numbers of-- when you get, I think, other number you were supposed to go out and be free.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 27,
      "text": "And when you got another number, you were going to concentration camp, to Umschlagplatz first.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 28,
      "text": "And we--",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "It's a place where-- it's like a terminal or rail station where train are taking-- were taking people to Treblinka.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That's what concentration camp was for Warsaw ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So we were not lucky.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "We got a bad number, my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I remember getting to some house where there were a lot of dead people, close to Umschlagplatz.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And there was a lot of-- excuse me-- shit, because people didn't have place, or bathroom, or whatever.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't have any food with us.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "Now who was-- that you were there with your mother?",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "With my mother.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Plenty of people.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not family-- just strangers-- or family, maybe too, I-- but not with us.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "There were plenty of people on this Umschlagplatz.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And there was a outside.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And I remember staying with the group of people.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And there was-- in ghetto, there were policeman, Jewish policeman.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And next to my mother was standing a woman with a little kid.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And my mother had just two-- two pieces of sugar with her.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And she gave one piece to me and one piece to this other kid.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "She didn't take it for herself.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And this other woman and my mother became friends.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And she put us on the side where this policeman wives were standing.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "So we were a little bit longer there.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "But it was very frightening experience to be-- for me.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "It was one of the worst-- it was the worst experience to be on Warsaw, Umschlagplatz.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "We were there about 10 days.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "There was no food.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "There were people killed all the time.",
      "word_count": 7
    }
  ],
