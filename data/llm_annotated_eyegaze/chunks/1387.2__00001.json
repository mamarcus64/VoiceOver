{
  "stem": "1387.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 23,
      "text": "At that time, [PAUSES FOR 3 SECONDS] he made a Aktion and a [NON-ENGLISH] and collected some dozen of Jews and brought them to Sasow to camp.",
      "word_count": 27
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "And the Judenrat made sure that I show up there in, in camp, in lager.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "He asked for me, and made-- I saw with my own eyes that he shot all those Jews, all those people in front of us.",
      "word_count": 25
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "And my girlfriend's father, Anszel Felig, and myself had to bury those people.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "It was an awful experience.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "It was a horrible experience.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 29,
      "text": "One of them that I recall vividly, he had a man there on crutches with one leg.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 30,
      "text": "He made him jump.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 31,
      "text": "He had him jump until he shot him dead.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 32,
      "text": "And I had to cover, to, to bury those bodies.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 33,
      "text": "I don't know whether he chose me because I refused to show up in, in lager.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 34,
      "text": "But if it wouldn't have been for me, it would have been somebody else to bury these people.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 35,
      "text": "But it made an awful impression on me.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 36,
      "text": "I cried for days.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 37,
      "text": "I was in, in bad psychological shape at the time.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 38,
      "text": "On the way back to Zloczow, Warzog stopped at Judenrat and told them to ship me out to Lackie Wielkie.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 39,
      "text": "Lackie Wielkie was already a larger camp, an established camp.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 40,
      "text": "It was much more difficult there than where-- than in Sasow.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 41,
      "text": "Over there, we slept on planks, wooden planks without anything, one above the other.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 42,
      "text": "And sometimes, we woke up in the morning, and my next-- the man next to me, sleeping next to me was dead.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 43,
      "text": "And I was there for quite a few months.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 44,
      "text": "And I worked on the quarries.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 45,
      "text": "And I worked on shoveling snow from Lackie Wielkie to Zloczow.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We were, we were getting some food.",
      "word_count": 7
    }
  ],
