{
  "stem": "27390.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And after the Sabbath was out, we had to collect from this person a note, and give it on Sunday to the teacher, that we knew what we were-- what we learned the whole week.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "So even on Sabbath, we-- we had to go for an hour or however long it took to be tested to this person.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yes--",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We, we, we-- even people that could hardly afford to-- to eat sent their children to a Jewish school to have a Jewish education.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Jews always-- as today, I think it's the same.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Myself, I spent a lot of money on educating my children.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "If I wanted them to know-- to have a Jewish education, I sent them to private schools.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And it was a very expensive part of my-- I spent a lot of money-- part of my earnings.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But we always considered that to be important, so that's why.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "In the school were only Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It was a Jewish school mainly for Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "In the summer, we used to go-- we had very long school holidays.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "They started from the end of May till the end of July, nearly three months.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And my father used to rent a cottage in the country.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And he used to-- he used to send us away with my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And he used to come out for the weekends only.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "And even on the holiday, he didn't leave us alone.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "He rented-- he hired a, a man to teach us a few hours a day.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "And-- but it was nice.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "It was a nice life.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And we, as children, we enjoyed it.",
      "word_count": 7
    }
  ],
