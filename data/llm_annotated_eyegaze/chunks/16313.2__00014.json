  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Wlodzimierz Wlodzimierz, they call this Wlodzimierz Wolynski.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "This was a place where they got over there-- like the-- the Russian army got over there like special-- not post.",
      "word_count": 21
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "More like post over there.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Like you cannot go in because it was everything [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "This means mines, all over is mines, so I cannot go in.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Now I got this piece of paper.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "I show this piece of paper [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "Then the soldier show up, a soldier, and then I go into the place, to the city.",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "The other way I cannot go because I'd be dead.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that-- that I can go in.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I go in, and the soldiers [? show me. ?] I says, the soldiers, I show them this paper.",
      "word_count": 19
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH SPEECH]",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "So I [INAUDIBLE] because he tell me I'd be dead, because I don't know how to go in.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Go, go, go, go, and I went into the city, Wlodzimierz Wolynski.",
      "word_count": 12
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And from this city, I see this-- this situation was-- because I hear-- this situation was so fluid the whole Russian army was destroyed in couple days.",
      "word_count": 27
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "They catch over there [INAUDIBLE] always-- over a million-- a million Russian army destroyed.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "I hear this some-- some-- came some news.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And I think to myself, well, must save myself and go away from the situation.",
      "word_count": 15
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "So I catch a train.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "Train go and come.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "I catch a train.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No money.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "You don't need the money.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Just-- just go and catch up with the train, outside, inside.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "You go in this way.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "I catch up, and I go night and day.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "I wind up in Kiev, a big city in Ukraine.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "A big city, beautiful city, with a lot of Jews over there.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "So I went over there on mark-- on the market, and Jews over there.",
      "word_count": 14
    }
  ],
