{
  "stem": "26276.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Just to have me-- give me, everyday, different party with their friends, with their families.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Everybody would bring presents and everybody was looking for somebody, you know, to introduce you to somebody, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And right away a lot of woman came over and they says, oh, I have a daughter for you.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And I says, I'm sorry, I have a girlfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And she may come over pretty soon.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And so soon I made enough money after I took a job.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "In a factory.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Soon, I had made enough money, I sent for my wife.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "She was my girlfriend, and she came over a year later.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And after she was here awhile, we got married here.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I didn't like New York.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I was not used to a big city, didn't know the language.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "So I found out about a friend of mine who was in concentration camp with me together, that he lives in New Haven.",
      "word_count": 23
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So I called him up.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And I says that I am in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "He invited me to come down.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "I come down on Sunday, get off the station, get out from the station, and I see that's more of a town that I would like-- that I'm used to.",
      "word_count": 30
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I went back the next day, Monday, took my suitcase, came down to New Haven.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "When?",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was working from the beginning in the tailor shop.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Then, after that, I opened up my own shop.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "In New Haven.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And I am very-- well, I mean, anybody in the street-- doesn't matter black, white, policemen, anybody-- you ask for Sidney, everybody knows me.",
      "word_count": 24
    }
  ],
