{
  "stem": "3331.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "After Matla, we had a-- I have a brother.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "His name was David.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "His full name is [?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "Shia ?] David.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "And David was in Palestine.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "He left our town in 1933 as a pioneer, as a Chalutz.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "And he was in Palestine, and this is the reason why he survived in Palestine.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "He was married in Palestine.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "He has two children.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "When I came to the United States, he wanted to be together with the family.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 29,
      "text": "I brought them over.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 30,
      "text": "And he is in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 31,
      "text": "He lives here.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 32,
      "text": "His wife died since then, but he is alive.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 33,
      "text": "This is the only siblings that I have left.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 34,
      "text": "After David was the youngest sister.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 35,
      "text": "Her name was Raisel, or in Polish, Ruchla Her full name, [?",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 36,
      "text": "Reiselghagow, ?] but we called her [?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 37,
      "text": "Ragho ?] or [?",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 38,
      "text": "Raisel. ?] She was my beloved sister.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 39,
      "text": "Even all of them, we were very close home.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 40,
      "text": "But because she was close in age to me, and she tried to help me with things that a young boy should know, and she was only three years older.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 41,
      "text": "And she also perished.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "At the same-- all of them at the same time.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "As I mentioned, [?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Raisel, ?] she could survive.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And being in the Holocaust, there were-- unfortunately, the Jews have two things that they-- it was a curse for the Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "One was the closeness and the attachment to the family.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Like, for instance, [?",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Raisel ?] worked in our ghetto because she spoke good German, she wrote good German.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "She was very intelligent.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "She spoke English, Hebrew, Yiddish, Polish, German.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My father was a very prominent man in our town.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "To be prominent in a small town, you had to have two important things.",
      "word_count": 14
    }
  ],
