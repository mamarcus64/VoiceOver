{
  "stem": "22979.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So he arranged the ticket on the airplane from Prague to Milan.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And so, she left.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And they married in Milan.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And their [? first ?] daughter was born in Milan.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Then later, she had-- she has one daughter born in Milan, one son born in Belgium.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Because he went from club to club.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "So just-- so she came here in 1953.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Or later-- '54, '53.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "She came first to Chicago, because he was playing in Cicero.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "It's 200,000 Czechs in the soccer club in Cicero.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And he was already then 30.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "You know, 30 for a soccer player is old.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "So the Maccabi here in San Francisco wanted him.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "So he came to San Francisco.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "But the Maccabi didn't pay too much, only when they had a match.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "So they found him a job at the Hotel Fairmont.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "So Hotel Fairmont-- but he didn't have any idea what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "But two young men, the [?",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "Levine ?] brothers, were there.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "And they helped him with the language.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "And when Hilton was built, the asked him, Gene, you want to come with us?",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "We are going to the Hilton.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So he was then a manager of the banquets, [INAUDIBLE], my brother-in-law.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And he was working 30 years for the Hilton.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "He retired two years ago.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We came the 1st of April.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And we had the case worker from the Jewish family service.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "We went to register, because they wouldn't take them back to school.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Dasha, my daughter, was 14.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Paul was 16.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So they had to go back, yes?",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "So we registered them.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "But since they couldn't go, only in September to school, we registered for English classes.",
      "word_count": 15
    }
  ],
