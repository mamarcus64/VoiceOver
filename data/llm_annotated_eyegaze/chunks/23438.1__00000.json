{
  "stem": "23438.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Elizabeth Gorski, G-O-R-S-K-I.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth, the Polish name is Elzbieta, that I've anglicized here to Elizabeth.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And my second name was Fizhiut, F-I-Z-H-I-U-T.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My date of birth is fifth November, 1926.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Warsaw, Poland.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My age today is 70.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I would like to take a-- tell a few words about my grandparents.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My paternal grandparents, I hardly knew the grandfather.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "He died when I was about three or four years old.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "All I remember is a little old man with a small, white beard.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "He used to be a bank employee.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And they had, years before the war, converted to Protestantism, because that enabled him to advance in his work.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "They had three boys.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "The oldest, Joseph, was a bachelor, living with grandmother all his life.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "The second [? aged, ?] he was my father.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And the youngest, Roman, was also a bachelor.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Roman worked in public service before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "Roman had converted with his parents, because he wanted to advance at work.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Joseph didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "Neither did my father.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] My grandmother ran a frock salon in her apartment.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "She had quite elegant ladies coming, to be dressed there.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "She had two or three seamstresses working.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And the-- the forelady, a Polish girl called Jadwiga Giegiecka.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "She'll be quite important in the further story.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 4 SECONDS] The oldest son, Joseph, was madly in love with her.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "She was quite a good-looking young woman.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "But of course, he couldn't have married her.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "Grandmother would never, ever agree to such a mismatch.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 6 SECONDS] When my brother was born-- he is older-- he was older than I-- my grandparents wanted him to be converted.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "But my parents hesitated.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "They were totally irreligious and non-traditional.",
      "word_count": 6
    }
  ],
