{
  "stem": "16345.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "My-- my parents, for instance-- my father had a-- a shop that sold and repaired sewing machines and bicycles.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And he used to sell many, many sewing machines and bicycles, also repair them.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "My grandparents on my mother's side, they-- my-- my grandfather had a liquor store, which in Poland was a monopoly.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And my grandmother and he both had a dry goods store.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And during the pogrom, which is what that was when they started beating up on us, the-- all the stores-- first of all, the peasants started looting the liquor store.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And my grandfather tried to keep them out, but he was knocked down.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And one of my uncles, one of my father's brothers, was considered a hero because he was defending his parents.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And they wanted to put him in jail, but he had a good lawyer.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "My father owned a firearm, because at one time, he had been a traveling salesman selling Singer sewing machines from the back of a horse.",
      "word_count": 25
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And he had kept his firearm.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "But fortunately, he never fired it.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "But they still tried to indict him for defending himself.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "I remember our store was completely demolished.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And I remember for-- for months afterwards, my father and mother both spent their time cleaning up.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Baruch.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, I named one of my kids after him, except I called him Burton.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Hannah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "My granddaughter's name is Hannah.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My mother was mostly-- it was very seldom that people in Przytyk had their wives working.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "It was not a-- a-- a woman's place to work in those days.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "My-- my father had gone to a yeshiva when he was young.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "But he-- subsequently, he became less religious.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I got most of my religious upbringing from my grandparents.",
      "word_count": 10
    }
  ],
