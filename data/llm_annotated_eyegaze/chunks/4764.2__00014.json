  "sentences_input": [
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They sort of went in there first to-- to-- not that I'm a historian-- but they must have gone into a country and sort of softened them up a little bit.",
      "word_count": 31
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "So there were a lot of infiltrators in there.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And they had infiltrated the Hungarian police, or they had some-- a lot of men who were really very vicious, because they wanted to impress their masters.",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And therefore, they were even worse than some of the Germans, because of the fact that they went-- there was sort of an overkill.",
      "word_count": 24
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "And this is why it wasn't good to stay in the main cities.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "It was better to be out in the country where they were less likely to be than they were in the metropolis-- metro-- metropolitan area.",
      "word_count": 25
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And this is why we went to a very small village.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "Change of tape now.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    }
  ],
