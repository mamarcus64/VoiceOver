{
  "stem": "1537.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I was-- I get stuck on this side.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And he gets stuck in the other side.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And for a moment, I said, Betzalel, come over this side fast.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He was afraid, the poor guy, because he was afraid that they're going to beat the hell out of him.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And what happened, this was the last time I saw my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "They took him away.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know where.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "And I end up in Mauthausen.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "And from Mauthausen, after a few days, they took us to Gusen eins, Gusen 1.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 9,
      "text": "And then, they took us to Gusen 2.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 10,
      "text": "And I didn't see my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 11,
      "text": "The only thing I know about my brother, that after the war, my cousin came home.",
      "word_count": 16
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 12,
      "text": "And he told me that my brother died.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "The English were bombing the city.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "And the bomb fell on his barrack, where he was sleeping.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 15,
      "text": "And that's the way he died, in Melk.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 16,
      "text": "That's the way I found out that he died.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "This was-- yeah, it's a part of it.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, well, they gave me a number.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But I don't understand why.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "I don't-- I don't have the tattoo.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I will never understand.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Somebody told me because I was too young.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Apparently, I was supposed to go to the gas chamber.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "I know that some others, they got the number, and I didn't get it.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes, only in German.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "[SPEAKING GERMAN]",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Only in German I remember it. 67,917.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Were you asked how old you were by anyone.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Officers?",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Were you asked your age?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Were you asked any questions?",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Well, they knew.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I had to give-- because every block had the block schreiber, you know, the block writer, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Everything was there.",
      "word_count": 3
    }
  ],
