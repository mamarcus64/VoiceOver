{
  "stem": "443.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "The uncle from New York sent me the papers to come to the United States.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "But I had to go, first, in-- into a quarantine for two weeks, before they let us out from Germany.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "Because at that time, the Americans didn't let in anybody that was sick.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "You had to be in a good condition.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And someone had to guarantee for you that I will not be a burden on the government, that someone will support me.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So I had my uncle.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He vouched-- he vouched for me, that he's going to see to it that I'm-- and it's still-- I never was an unemployed in the United States.",
      "word_count": 27
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I never collected one cent in the United States, unemployment.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I was only here one week in the United States, and I found myself a job.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "The Joint provided us with a run down hotel, till they're going to find us somewhere suitable to live.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But I found out myself, on my own, found myself a job.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "After that, I got my uncle's apartment, because it was already too small for him.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So we got the apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "This is how we started.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "We established ourselves in the United States.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "In 1946, after I married my wife in the camps, my-- one of my brothers-- I was going to the train.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "While we were on the train, he heard my voice.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You know, we have a special voice, all my brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "We all talk the same voice.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You could be between a million people, you could recognize this voice.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And he heard my voice, and he kept on screaming my name.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "But-- but there were so many people at the train.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Everybody's trying to go on on those trains.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "You can imagine, for free, so everybody was pushing.",
      "word_count": 9
    }
  ],
