  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Do you know where you were?",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "That was near Dusseldorf, I think, there where it was.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And he said, not now, not now, and I was very disappointed.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It knocked me down.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] But he said, you will be home, you will be home whenever.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And of course, what they did, they said, we need you here.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "You know German.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "We need in special-- [PAUSES FOR 3 SECONDS] how you call the special thing in army that-- [PAUSES FOR 3 SECONDS] agents, special.",
      "word_count": 23
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Service, yes, special service.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "That they have to call Germans and ask all sort of things.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And by the time the war-- the war was finished 9th of May, so by the time the war finished, I was already established as a, as, as a interpreter, German interpreter, in the special service.",
      "word_count": 36
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Secret Service, special Secret Service.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And of course, they, they need me.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I could see that they need me, and they said, we need you.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "You can't go home.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And I scream I want to go home.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "You can't go home.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So I was working with the Secret Service for a long time.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "As interpreter only?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "As interpreter.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Yes, as interpreter.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "They give me a special [PAUSES FOR 3 SECONDS] how you call, a document, that I can go to all Russian-- [PAUSES FOR 4 SECONDS] Russian--",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And who I am, what I'm doing, all sort of things, and I start there.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "When-- that was the whole May, June, July, August, September Now in August-- in August after the war, they decided that there was a lot of Russian troops on the German territory, and the, the war is over, so they need some entertainment.",
      "word_count": 43
    }
  ],
