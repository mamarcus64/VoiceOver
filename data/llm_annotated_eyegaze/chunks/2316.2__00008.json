{
  "stem": "2316.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "So she hid.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "And before we left we saw her, they took her out and shot her.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "This little lady, this sweet little grandma.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "They just pulled her out of there and shot her because they got mad at her for hiding.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Why she didn't go with everybody in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So we took whatever we could, and we walked with the crow.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I don't know, maybe 1,000 people from where we lived.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And they took us to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And once we got to the ghetto my father and mother, two of my-- my cousin who built the wall, his wife and their three children, my two brothers, that's it, they went back because you were allowed to make, like, two trips, OK?",
      "word_count": 44
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "They went back but they never-- and they left me with my grandmother in the ghetto, my father's mother, in the ghetto to watch the belongings.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And I sat there with her, and I realized that nobody came back from my immediate family.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Right away, it dawned on me they must be in the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And I got scared.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I got angry why they left me.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And they were hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And my cousin and his wife and three children were there.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And they were little kids, younger than me.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "One baby was younger than me.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And I was very upset.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And I was so torn.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "My grandmother sitting there with the [NON-ENGLISH] with her belongings, and I'm sitting next to her and all the other Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "But I wanted to live, and I didn't know what to do.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "She couldn't go back, and I left her.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "That was a very tough day of my life, probably the worst.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "And I ran back.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "I knew they had to be in the wall.",
      "word_count": 9
    }
  ],
