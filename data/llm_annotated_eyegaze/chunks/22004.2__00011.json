{
  "stem": "22004.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "I got a chance to shoot.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "When the war was over--",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "When the war was over, we went-- we find out that all the Jewish people is going to Lodz.",
      "word_count": 19
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "You heard about Lodz?",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "And none of us there the Jewish federation.",
      "word_count": 8
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "It was most-- all the Jews who was going to Lodz.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "We came to Lodz.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "We talked to a lot of people.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 6,
      "text": "We met people from our own city, or they came from Russia, from all over.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 7,
      "text": "And we saw them, talked to them.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 8,
      "text": "And they said, the best places to go is to Waldenburg, the big German city.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 9,
      "text": "We came to Waldenburg.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 10,
      "text": "It was already many, many Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 11,
      "text": "And they took over all the kind of places, businesses.",
      "word_count": 10
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 12,
      "text": "And it was a-- was a Russian Jewish guy became the mayor in the city.",
      "word_count": 15
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 13,
      "text": "And we went to him, and we said, we run a shop.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 14,
      "text": "They took away from the Germans shops, stores, and they gave it to the Jewish guys.",
      "word_count": 16
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 15,
      "text": "So when we was in army clothes, and we came in there.",
      "word_count": 12
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 16,
      "text": "And we said, we run a shop.",
      "word_count": 7
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 17,
      "text": "Finally we got a shop.",
      "word_count": 5
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 18,
      "text": "And we was making shoes there.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "So now to go and get leather material for shoes, you couldn't get it to Waldenburg even though it was a big city.",
      "word_count": 23
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "So I-- [DRINKS] in the mean time, came to me a guy.",
      "word_count": 12
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "And he said to me, you know you got a sister?",
      "word_count": 11
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 3,
      "text": "He said, she was in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 4,
      "text": "And she is in Sosnowiec, IN Katowice-- she was in Katowice.",
      "word_count": 11
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "And I called her up.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "I find out right away how to get in touch with her.",
      "word_count": 12
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "And she was-- she left.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "She was with an older man.",
      "word_count": 6
    }
  ],
