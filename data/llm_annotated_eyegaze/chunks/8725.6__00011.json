{
  "stem": "8725.6",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 4 SECONDS] we heard that, now, by the short radio from England, we heard that-- that the German pushed the Russian again from Tarnopol, pushed them out.",
      "word_count": 30
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "I am sitting, in the morning-- oh, Ida and Franka-- you know, Ida was heavy with the child.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "She would need hole in the ground by herself.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I was here in forest to tell Pachovski that I am hiding two women and that one is pregnant.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I am scared to put her in the forest in a hole because she will die.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "So he did-- he was connected with England.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "He did have a special room that nobody know.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "He sent his wife, with two children, he sent them to grandmother.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And that day, I brought Franka and Ida to his home.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He put them.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And the rest was in the forest.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Now, the war, they are fighting back and forth, the Russians.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I am sitting at the kitchen window.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "Who is coming?",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "Major, with the [NON-ENGLISH], He was so worried that the Russians would kill me.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "He loved me, the Major.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "He did not tell him about the Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But they-- now, he asked the help that I am at the cousin.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I am sitting and they're coming.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Henry Pachovski got white.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Because he said, you know, the Gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "I said, one minute-- let me run out.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "I run out.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "I run out, I say, oh, I'm so glad you come.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "I was so scared of the Russians.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "You know, I told you that I will run out to my-- to my cousin and this.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And in the meantime, the wife of Henry brought coffee, and the coffee, and brought it out to the car.",
      "word_count": 20
    }
  ],
