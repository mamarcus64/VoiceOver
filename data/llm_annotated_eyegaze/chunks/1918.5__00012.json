  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Because the Germans escaped from the Russians, and they took along their dog, of course.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And the house was empty.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And that little dog house.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "First, we were crouching in the dog house.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Then we climbed out.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And that's when we heard the German cursing to himself.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And he passed us by.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "He didn't notice us.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And the dog evidently, didn't smell us because the wind was so great it blew our smell another way, probably.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And finally, he was gone.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And then-- [PAUSES FOR 3 SECONDS] and then we climbed out of the little dog house.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And we went up to the attic.",
      "word_count": 7
    }
  ],
