{
  "stem": "10394.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Was a big room for the sick people.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 21,
      "text": "And if you was sick, you have to go.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Thank God, no.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And then, [SIGHS] there the-- the-- the Jewish doctor was Gross-- the name was Gross.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "How many people he sent in oven over there?",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He was Jewish and he sent--",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Jewish, Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They hang him after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "In Krakow, they hanged him.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "They wait for him-- oh, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He sent so many Jewish people in oven.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Terrible.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And was-- seven people came.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "If you got jewelry or something, there, that guy, that Jewish guy, that-- that-- he was the master of all the Jewish.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "You know, the-- the men.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He go to-- to Goeth, and tell them, they in there, he jewelry.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "So they know who has the jewelry.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "He took-- says everything to them.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Everything to them-- Goeth.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Was seven people.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "One night we was in the factory.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Was one woman, she used to work [? for ?] us, too.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "They take her out-- outside.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "It was the-- the-- the-- the from the woman-- the-- the-- the-- the-- the big shot, what she call name the woman.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And she beat everybody-- her, her husband.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "Seven people was.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "They take them outside.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "We didn't know what's gonna happen.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "When they take them outside, we hear, boom, boom, boom.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "They kill everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 24,
      "text": "Seven people.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 25,
      "text": "Because he doesn't need you anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 26,
      "text": "He knows everything.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 27,
      "text": "He doesn't need you, and they killed them.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 28,
      "text": "And we have to go and look.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Like-- like-- the-- the-- like this, they left them.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They-- one by one, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "One by one they was killed.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And they-- the one got a boy.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Was five years old.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He left someplace-- we didn't know where he is.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He is alive, but who knows where.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "He is alive.",
      "word_count": 3
    }
  ],
