{
  "stem": "24650.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "You don't have eggs.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "You don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "In Riga.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So we were hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I got food for the children from the government, that's true.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "But I have to walk or to go by train, street train, 17 kilometers a day in one side.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "My first daughter was born October 11, '45.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "Malka, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Musia, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Malka. ?] Her name-- her real name [? is Musia. ?] But she calls herself Molly.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "It's all right.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And my second was born '48, March 10.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Sima Glickman.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "She isn't married.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And my husband was born June 23-- 13, in year '23.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "And mine you have, I think.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "12 and a half years.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I write to Molotov.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "You know Molotov?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Who was then like here is the Secretary of State.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He was a very intelligent man.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Nothing to say about him.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But he didn't-- to-- to say something just had to say Stalin, nobody else.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "What he said goed.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "If you said, this-- you have a suit.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And this suit is a good suit, somebody will say.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "He would say, it's from London.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "I bought it in '39, '38.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "You got three years for it.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "It was terrible cold there.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "It's unbelievable.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "It's the best air in the world there.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "But with no food, there is not enough.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "So people died.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "My husband, thank to God, didn't sit.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And me neither.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "But what I did is I got to know people from the Jewish theater.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And we had to play Sholem Aleichem's You know it?",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Please explain.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "The [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "So nine days before we had to play, Stalin said, no Jewish theater, nowhere.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "No concerts, no dance, no music, nothing in Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "So this was the end of my playing.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "So and other things I couldn't do it.",
      "word_count": 8
    }
  ],
