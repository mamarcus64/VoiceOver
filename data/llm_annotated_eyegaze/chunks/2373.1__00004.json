{
  "stem": "2373.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And they were jumping and pulling us down and all what we had our belongings.",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And they said, give the little children to the grandmothers.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "We didn't know what that-- what does that mean.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "The men were taken away straight away.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "So my father, we were worried about my father, because he had angina.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "And we were worried if he has his pills with him or it was in my mother's handbag.",
      "word_count": 18
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 11,
      "text": "Anyhow, then I stayed with by mother and aunties and cousins.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 12,
      "text": "And the women went one-by-one.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 13,
      "text": "There was a very good-looking German officer standing.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 14,
      "text": "That was Mengele.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 15,
      "text": "And he was deciding who goes left and who goes right.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 16,
      "text": "Left was straight to the-- of course, we didn't know all that.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 17,
      "text": "Only the elderly and the children went to the left.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 18,
      "text": "And the younger ones went to the right.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 19,
      "text": "When I came with my mother in front of Mengele, he showed my mother left and to me right.",
      "word_count": 19
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 20,
      "text": "And I said [SPEAKING GERMAN] That is in German-- that is my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 21,
      "text": "And he said [SPEAKING GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 22,
      "text": "She will follow in a car.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 23,
      "text": "So we were happy that she will come by car.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 24,
      "text": "She doesn't have to walk.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Never, never saw anyone-- anyone who went to the left again.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Well, of course, he went to the left.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see that.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "But, of course, he went to the left.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "He was 61, and he was-- he wasn't very healthy.",
      "word_count": 10
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "He had heart problems.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "When-- well-- when we-- there we walked to a big room where we had to undress.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Then showers started-- a cold shower.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And we were really even happy, we were refreshed.",
      "word_count": 13
    }
  ],
