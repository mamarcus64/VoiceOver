{
  "stem": "11589.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they came out with numerus [INAUDIBLE] which is in Latin that nobody is allowed on numerus clausus which is a limited-- kind of people can go to school, you know, not everybody if you're Jewish.",
      "word_count": 36
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "You know, out of 100, maybe 10 could go to school.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And numerus [INAUDIBLE] means that nobody, no Jews, are accepted.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And that was the first thing.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "You know, we start learning about anti-Semitism.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "In those days, no.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I had a radio, very cheap radio.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And that's the only thing that kept me very interesting, you know, about music, especially music, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Well, it depends what kind of problems.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "You are asking me about the family problems or personal problems?",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We talked about it.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Nobody imagined that the situation is so tense, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And we never knew what's in his mind.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Because it was a start of his party.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We knew that he is a Jew hater, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Was an anti-Semite.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "We knew all these things.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "But then we had in Poland many of them, too.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "So we didn't know what really-- how far they'll go with it, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And only later, we start finding out.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "What was your home like?",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "Describe it to us.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "It was not a big home.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And we have a little corner in the backyard where I used to play, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And my sisters used to fight around a little bit, like any family, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "But we liked each other.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And mother and father were good to us, real good.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They did what they can.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "In those days, we didn't need so much luxury as we need today.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And we loved them.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "My mother was a good cook.",
      "word_count": 6
    }
  ],
