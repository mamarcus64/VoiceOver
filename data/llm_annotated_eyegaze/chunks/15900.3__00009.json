{
  "stem": "15900.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "To go in and rob the Jews and kill them.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "But the Russian Army surrendered the building and American government in Germany gave the Polish government an order, you cannot control your people.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Give the people a right to move and get out from there.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "Open the borders and let them go.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And we got two weeks to pack and go-- and go.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And the men who lived there were--",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "There-- there-- there were-- the police got announcements.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Anybody who wants to leave, the mayor of the city-- it's a beautiful city--",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Krakow.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And he said, you can leave but you have to leave everything what you have.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Just take your anything.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "We-- we-- we crossed the border and we went by-- to a train to Czechoslovakia.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "In the train, we were not allowed to speak Russians.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "The Russian soldiers were there, the train, Czechoslovakia.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I-- I had a-- a-- I had a-- a Polish birth certificate and a passport.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I had a Krakow passport.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And we landed in [?",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Austria-Germany. ?] And [?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Austria-Germany, ?] we were there a day or two--",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Well, that was already 1945 then.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "End of '44, 1944.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In Austria we landed, in Austria.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "In Austria, we stayed there for a week and they put us--",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We went to the camps in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "With all the people.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "People who-- who in the train-- with people.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "In the [INAUDIBLE] camp.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And we went to a camp in [INAUDIBLE], that's near Frankfurt.",
      "word_count": 11
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "The-- the-- the German military [INAUDIBLE], a big place there.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "And they took over and they put us--",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "In-- in Stuttgart-- in Frankfurt.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "In '45, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "In '45.",
      "word_count": 2
    }
  ],
