  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And everybody try who can-- who can do better, a better job.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "This was later.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "So we weren't, anymore, in the houses.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We were hiding where we can.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "But later, wherever they can catch us to-- to-- they took us to-- to clean the streets.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "You know, there was one street.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "But it was dirty.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "You know, in a village, how it is.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "So the-- the Jews has to do the-- they dirty work-- work.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was a order from the-- from the police, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "From the Ukrainian.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And one of them used to-- he used to be a friend of mine, sitting in-- I mean, he was watching us, you know, if we do a good job.",
      "word_count": 30
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they were the Ukrainian-- they were-- they promised them that they're going to have Ukrainians, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And they-- if they're going to help them out, they're going-- they're going to have a Ukrainian.",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "So they did what-- what they told them to do.",
      "word_count": 10
    }
  ],
