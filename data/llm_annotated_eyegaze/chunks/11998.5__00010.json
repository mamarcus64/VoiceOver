{
  "stem": "11998.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "So this way, I was out of sight.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And then, nobody knew where I was.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Did you ever get caught?",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "That's the point.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I got caught.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Once, I got caught.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "The-- the-- the civilian that saved my life came by my-- came by the warehouse.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And he says, where's der kleine?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Because my name was 'der kleine'-- the little one.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So the other guy says, he went to deliver material.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "He says, where did he go?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "So he told him.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And while he-- while he walked away, I came out.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And you know, I started making myself busy.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So I told him-- he said-- I said-- he says, what did you tell him?",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I actually heard what he said.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "So he says-- so I said, I better tell him that I went somewhere else.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "So when he came back, I told him I went in the opposite end of the factory to deliver some material.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "So he says, You're lying.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "He says, I went past there as well, on my way back.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And he says, they did not see you this afternoon.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "So he says, I'm going to take you to the Gestapo, because you tried to escape.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "He says, I saved your life once, but this is it.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And so-- and I started pleading with him.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And I was saying, look, you must have children, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "You know what's going to happen to me.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "They're going to either hang me, or they're going to send me back to Auschwitz.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "I says, please, believe me.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "I'll tell you what-- I'll tell you the truth what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "I was hiding in the desk.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I was sleeping.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "He says, you're a liar, you.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He got mad at me.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He started shouting at me.",
      "word_count": 5
    }
  ],
