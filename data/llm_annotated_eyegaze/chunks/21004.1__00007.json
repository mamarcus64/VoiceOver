{
  "stem": "21004.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And you had somebody go in with, you know, making the land, you know, grow everything to help, us, you know, we paid them, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And we were going also we worked.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "We cleaned the grass out, whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And we did a lot of work.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Then we have a garden.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "We have a nice garden.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I planted also.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I like to work in the garden very much.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "I even planted-- my grandfather, we plant like apple trees and pears and all kinds of fruit, cherries.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "We plant in the front of the garden trees.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "And later, they grow up.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "We had our own-- our own fruit we had.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "We had two cows.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "We had chickens.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "We had-- we had what-- even my mother used to bring two, three times a year to the city of Krakow.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "There were a lot of poor people, lot of poor people.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "And she know already all the poor people, so we used to hire somebody.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "We had a special-- one man what we hired.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "And when she packed up packages, you know for each one, what to do and how-- how many children they have, and bring packages with food.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "This was two, three times a year.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "That's what-- and we didn't live high.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "We weren't rich, but we weren't hungry.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "We weren't hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "At home, Yiddish.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "At home, Yiddish.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Outside, we speak Ukrainian, Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We speak--",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "For reading, books?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Oh, I liked stories, all kind.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "You had going in the newspaper, the Jewish newspapers, they call it [NON-ENGLISH], between Rome and Jerusalem, the war.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And it was a story, every-- every week a story continuing.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I liked to-- to read this.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And then I read Polish books about Sherlock Holmes.",
      "word_count": 9
    }
  ],
