{
  "stem": "18061.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 55.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And Sunday after dark, they started coming more and more, not only from the German army, also from the party, like the black SS.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "They wore black uniforms and red uniforms with the arm bands with the swastika.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "Monday morning, they started to take out all the Jews from the part of the Jewish quarters, which wasn't exactly the Jewish quarter, because over there, also, non-Jews lived over there too.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "But they took all of them out.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "They took them to various places, like a place where they had the Polish army left over there.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Myself and thousands of other people, they took into a church, a very big church.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Where they where, my brother was a different place.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "My mother was a different place.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I was there myself.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And over there, they started going into the church, putting the ammunition, killing people.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Huge number of people are killed going in to the church, in the church.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Shooting.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And over the-- over the-- a couple of days.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And all of a sudden, out-- they let us out from the church.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And we went back home.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Hm?",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Men.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Just men, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "They-- they didn't have to lock us inside because at the front of the door, there was SS.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "So there was no use to-- to lock us.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Nobody-- nobody anyway could escape.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They didn't give us any food.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But we had over there priest.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] And he did for us a lot, a lot.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "He said, don't be ashamed.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Use any place for a toilet.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "You get water, whatever we can do, we will help you.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "His name was Frubleski.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "He was very, very, very fine man from the priest.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "In Catholics, he was one of the finest which I know of.",
      "word_count": 12
    }
  ],
