{
  "stem": "9665.7",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Joey. ?] And I don't really know when it was.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was in 1975, or '76.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "They've got four children.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "My daughter, Yvonne-- you know, at one stage, my children were all over the world.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "My son was in London.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And he started in New South Wales, and he started in America.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He's a-- he's a-- he's a-- he's a-- that's with the highest degree in marketing and commerce.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "My daughter, Yvonne, was a bit lost all over the world, but she was in Amsterdam.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So my son was in Philadelphia.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And my Anita had her teachers degree-- I think it-- my teachers degree.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "In Sydney, she was a teacher for the Yeshiva.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I'm coming to that in my next tape.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "But a teacher with the Yeshiva.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "She was also-- then, at the Yeshiva, Robert Feldman helped me to find her a job-- oh, no.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "She didn't need a job in-- she wanted to have a Green Card in Los Angeles.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "So at one stage, one daughter was in L.A, and my son was in Philadelphia and London.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And the other daughter was in Amsterdam.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "So I was really not very, very happy about the situation.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I think that was the time when I divorced my wife number one.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And it could have been before that time.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "I divorced my wife number one in 1981.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "Right?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And was-- was-- I-- I just spoke to her this morning, so there's a happy relationship.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "Now, the other thing which you like-- what else you want to know?",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "Tell me about your interests and your hobbies, your activities within the Jewish community.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Now, until recently-- until recently, I used to play tennis.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I was a keen skier-- keen skier.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "I was in Holland.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "When I was in Holland, played soccer.",
      "word_count": 7
    }
  ],
