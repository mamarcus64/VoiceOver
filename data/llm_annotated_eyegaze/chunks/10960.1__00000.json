{
  "stem": "10960.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "OK, my name is Molly Lewis.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes, Molly is M-O-L-L-Y, and Lewis, L-E-W-I-S.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Malka Kloc.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Malka is M-A-L-K-A, and Kloc, K-L-O-C.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Not until I got married.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The other name is Cmielewski.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "May 5, 1918.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "It's 50-- 57-- excuse me, seven-- [LAUGHS] Sorry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "77.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Yes, the city is Horochow, H-O-R-O-C-H-O-W.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And the country is Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Should I include my parents' name, no?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Can I?",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I am the daughter of Rachel and Gershon Klotz.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I was raised in faith of believing in God, believing in good humanity, doing pioneer work, helping the others, and getting a good education.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father was a businessman.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He had a few different times in his-- in-- difficult times, so therefore he had changed the business.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He had once a clothing business, men's clothing, for a few years.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Then due to a partner, he gave it up.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And then he went, and it was like a [POLISH], we used to call it in Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "It's many things.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "It was a grocery.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "It was dishes.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "It was lamps, fixtures, was even herring, everything at the big store.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "That time, when I became the age of six, we had a big fire.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And what there were they couldn't throw out and didn't got broken outside, got inside burnt.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And my mother got very, very hurt about that.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "In Poland, we didn't have no insurance.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "And-- although we had-- we had a cow, I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "We had two horses.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "Because my-- then my father changed to burning wood.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "He got in partnership with a very rich family.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "The other one supplied the money, and my husband gave his ability--",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My father, I'm sorry-- his business ability.",
      "word_count": 7
    }
  ],
