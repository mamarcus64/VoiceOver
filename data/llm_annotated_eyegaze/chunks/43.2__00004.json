    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He was a [NON-ENGLISH], a horse, a man-- a-- he was-- he was so good.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He was over eight years old.",
