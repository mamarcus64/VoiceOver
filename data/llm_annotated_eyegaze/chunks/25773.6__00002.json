  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Masia ?] and somebody else-- and we went in search for bread for this children.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And as we went for search for the [INAUDIBLE], da da da da da, we could be killed any time.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But young people, who cared?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Also, this cousin of my friend and fiance, [?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Julie-- ?] suddenly after a long, you know, walk here and there through Warsaw, joined us and this-- came to [INAUDIBLE]-- to our place where we were, and he joined us in this shelter.",
      "word_count": 34
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "So we were three together.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And then we went out.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We joined an enormous queue of horrible looking people, all like us.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Dirty and starving, and their faces looking like God knows what, like out of, you know, Dante's hell.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And then we joined the queue, and the Russian and the Germans, again with the rifles and the uniforms, and the German order.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And we started walking through Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "And Warsaw, you must remember, in-- before the war, it was the most charming, delightful city.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "A small Paris.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "Full of cafes, full of beautiful houses, full of shops.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "Full of elegant women.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "Full of-- really, truly charming places-- theaters, and concerts, and it was quite a cultured place, and it was all burned down.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "The Germans systematically burned every single house.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And we were walking in the middle of the road, and it was-- it was a picture of hell.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "I don't know how hell could look.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "Maybe look it looks nice by comparison what we have seen.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 14,
      "text": "It was like the end of the world.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 15,
      "text": "Eventually, they brought us to a railway station-- I don't even know which one it was-- and boarded the trains.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 16,
      "text": "And I remember saying to my friend, [?",
      "word_count": 8
    }
  ],
