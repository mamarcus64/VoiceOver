{
  "stem": "7744.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "I-- I know for a fact that a couple of members of the family felt, well, you know, a 16-year-old girl, you're bringing in a lot of tsuris.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "You are going to have a hard time.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "And-- and-- and they did.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "And I wasn't appreciative either.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "I was a pain.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 21,
      "text": "I was a real pain.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 22,
      "text": "I wanted to go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 23,
      "text": "I wanted to go to university.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 24,
      "text": "I wanted to take music lessons.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 25,
      "text": "And they couldn't afford all that.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] They couldn't afford all that.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "But my cousin Elizabeth is just a wonderful individual, and I shared a room with her.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "And the room was very small, and I don't even remember if we had a closet.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "And she went to York Memorial too.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "She was the same age as myself, but she was a couple of-- one year ahead of me.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "She was a couple of years ahead of me to start with because of all-- all of this stuff.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "And she had a girlfriend, Adele, and Adele became my friend as well.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "And then I befriended a couple of people who were also Holocaust survivors.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "And so we used to go to what they called the [?",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "Greenie ?] Club on Markham and to the Y on Brunswick.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 36,
      "text": "And I was quite popular.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 37,
      "text": "I had a lot of boys after me.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 38,
      "text": "And I liked boys.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 39,
      "text": "I always liked men.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 40,
      "text": "Don't make any bones about it.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 41,
      "text": "And I like the company of-- of people, and I had a good social life.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 42,
      "text": "I used to go to dances.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 43,
      "text": "I was busy many Saturdays.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 44,
      "text": "But I also studied very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 45,
      "text": "I studied all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 46,
      "text": "[PAUSES FOR 3 SECONDS] I know my cousin sometimes wondered-- so much studying.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 47,
      "text": "So much studying.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 48,
      "text": "I had a lot to catch up.",
      "word_count": 7
    }
  ],
