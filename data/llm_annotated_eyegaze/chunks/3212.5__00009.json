{
  "stem": "3212.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And we met again.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Instead, he should be in Israel, we met in Italy.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "So we found out we had an aunt in Italy-- in London.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "We wrote to her, and she got a special visa because our parents were gassed in-- in the camps.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "She got a visa from the Queen that we could go to England.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And when we got the visa, I went to my teacher from Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Or you send me to Israel, or I go to London.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I go to England, Palestine.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And he saw that I could go, he says no, no.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "You go to Palestine.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Walter was sick.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't go to Palestine.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I went with a ship, [INAUDIBLE], it's called. 900 people on one boat.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "We came to-- to-- on the-- on the front of Haifa and this.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "A British army ship captured us and took us in a camp in-- in Palestine, in Atlit.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "So here I came from Italy to freedom.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Again, the British put me in a-- in a camp.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "But we were not-- but we got food, everything.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "They released us after three weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And after these three weeks, the whole-- all the group from Selvino, all the children, we came Hanita.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "To Kibbutz Hanita.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "We were the first-- they called it the first Aliyat Hanoar, the first group of children that the kibbutz in-- in Palestine got there.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So we came there, the first group.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "In-- in Kibbutz Hanita, we had-- we start studying a half day, and a half day we worked.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And I was there in Kibbutz Hanita [PAUSES FOR 3 SECONDS] oh, January, February, '45, a couple months.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Then I found out that my uncle, that left before-- Wait, now, January '45, not '46?",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "'46, Yeah.",
      "word_count": 2
    }
  ],
