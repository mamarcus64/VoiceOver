{
  "stem": "7302.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "And we have been begging my brother-in-law, who was having the wagon with there, to come with us and my mother and father.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And he was saying, no.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "We're not going.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "They will take us to somewhere where we're not going-- no.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "We staying here overnight, and we will see what we will do farther.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So we had to say goodbye.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "My parents have been old people.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "They wouldn't go to the trains.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "They have been staying with them.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And we, like, the two sisters with their husbands, and me, we went to the trains.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "It was trains-- cattle have been in the trains.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And where the trains was taking us, we-- we went.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where we going.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "We-- we have been planning.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We will go to Kiev, but it's never happened.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Instead to Kiev, the trains was taking us to-- near [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "And then when we went in to this train, all of us sat.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And I looked up-- my husband was sitting there.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "I met him the first time after-- I hadn't seen him before.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no, no.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "So we have been very happy.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "At least we got each other.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And then we went with the trains.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And they took us off to some-- you call [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Farms.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "To farms, kibbutz, and they came from there with the farms to take us there.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So we didn't know.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I thought we going all together, but we couldn't sit in one wagon.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So I packed for us.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I have been sitting with my sisters and with the child in one wagon.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "They had been-- my husband was sitting in the other one, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "All of a sudden, they took them to another village, [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I lost him again.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] I didn't know where he is.",
      "word_count": 7
    }
  ],
