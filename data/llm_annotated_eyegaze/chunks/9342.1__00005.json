{
  "stem": "9342.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 193,
      "sentence_idx_in_seg": 13,
      "text": "I had to go to that bigger town, Sosnowiec, and they put me right to jail.",
      "word_count": 16
    },
    {
      "segment_idx": 193,
      "sentence_idx_in_seg": 14,
      "text": "My--",
      "word_count": 1
    },
    {
      "segment_idx": 194,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 195,
      "sentence_idx_in_seg": 0,
      "text": "They put me right to jail.",
      "word_count": 6
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 0,
      "text": "I can't remember if I went myself or with my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 1,
      "text": "I just don't remember anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 2,
      "text": "And they put me-- maybe it was my mom.",
      "word_count": 9
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 3,
      "text": "And they put me to jail in there, but it was no jail.",
      "word_count": 13
    },
    {
      "segment_idx": 196,
      "sentence_idx_in_seg": 4,
      "text": "There was a big, very big, like a warehouse.",
      "word_count": 9
    },
    {
      "segment_idx": 197,
      "sentence_idx_in_seg": 0,
      "text": "A market.",
      "word_count": 2
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 0,
      "text": "A market there.",
      "word_count": 3
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 1,
      "text": "And there were other prisoners that came in there.",
      "word_count": 9
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 2,
      "text": "So many people, prisoners, sleeping on the floor.",
      "word_count": 8
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 3,
      "text": "And the lights, headlights, were shining on them going around like that.",
      "word_count": 12
    },
    {
      "segment_idx": 198,
      "sentence_idx_in_seg": 4,
      "text": "And the policemen--",
      "word_count": 3
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 0,
      "text": "Spotlights.",
      "word_count": 1
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 2,
      "text": "And they put me there, I didn't know for how long or what.",
      "word_count": 13
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 3,
      "text": "And when the policemen took me, I had to go back.",
      "word_count": 11
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 4,
      "text": "I didn't take a coat.",
      "word_count": 5
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 5,
      "text": "I didn't have my coat.",
      "word_count": 5
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 6,
      "text": "So my sister was home, and she threw the coat on me that I should have something, because they didn't let you have anything.",
      "word_count": 24
    },
    {
      "segment_idx": 199,
      "sentence_idx_in_seg": 7,
      "text": "So when they took me to that warehouse--",
      "word_count": 8
    },
    {
      "segment_idx": 200,
      "sentence_idx_in_seg": 0,
      "text": "To the market there, right.",
      "word_count": 5
    },
    {
      "segment_idx": 200,
      "sentence_idx_in_seg": 1,
      "text": "And my mother used to come sometimes-- every day, almost, and brought me some food package.",
      "word_count": 16
    },
    {
      "segment_idx": 201,
      "sentence_idx_in_seg": 0,
      "text": "Otherwise they would not give you--",
      "word_count": 6
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't go in.",
      "word_count": 4
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, they give us something, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 2,
      "text": "And she couldn't go in in that warehouse, so she sees someone she knew that he is there too.",
      "word_count": 19
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 3,
      "text": "So she would give him the package, the food.",
      "word_count": 9
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 4,
      "text": "And the next time my mother came, she said, did you get the package?",
      "word_count": 14
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 5,
      "text": "I said, what package?",
      "word_count": 4
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 6,
      "text": "He took care of it.",
      "word_count": 5
    },
    {
      "segment_idx": 202,
      "sentence_idx_in_seg": 7,
      "text": "He ate it.",
      "word_count": 3
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 0,
      "text": "He took it.",
      "word_count": 3
    },
    {
      "segment_idx": 203,
      "sentence_idx_in_seg": 1,
      "text": "He didn't--",
      "word_count": 2
    },
    {
      "segment_idx": 204,
      "sentence_idx_in_seg": 0,
      "text": "She recognized the food.",
      "word_count": 4
    }
  ],
