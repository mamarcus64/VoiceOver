  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And they knew that there were hiding places.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Now, what happened is the attic had, like, dust.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "No-- not wood.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, sawdust.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Not sawdust.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "Just, like, [INAUDIBLE] whatever it was there.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "So when they went to get the-- the water [PAUSES FOR 3 SECONDS] from someplace-- I don't know if they went downstairs or-- they filled the water too much, and the water spilled, and makes spots in the attic.",
      "word_count": 39
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And when the German came out, they were shouting, are you in the house?",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And the water led them to the place where everybody was hiding.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And this Mr.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Shaiya ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Zinger, ?] he was the first one to get out.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "He didn't want to wait anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "He gave-- [INAUDIBLE] the German money.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And I don't know if the German took the money, but everybody had to go out.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "They went down to the Jewish police station, which was in our [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And then they took them to the great synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "And all those Jews, then they send them to Treblinka.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    }
