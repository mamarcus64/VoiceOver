{
  "stem": "20745.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Regina. ?] I don't remember her name now.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Very good-- the same-- no different than the other-- the Gentiles.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had a few friends from school, from the class.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, I don't remember that, no.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yes, he did.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He had a lot of friends, many friends.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was about around 300 to 350-- between 300 and 400, I would say.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "There was one big synagogue, and there was a little-- two shtiebels.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "My family prayed on the holidays and on-- on Shabbos.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They prayed at my uncle's shtiebel.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He gave up a room-- a big room-- for the holidays and for Shabbos.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "During the week, they went to the big shul.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in Bais Yaakov, we learned how to read Hebrew, write Jewish, and we used to go-- every Saturday, we had minyan for the girls only, and that's about it.",
      "word_count": 30
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Friday, my mother used to get up very early.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She used to be challahs and cake, and she cooked-- made gefilte fish.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She cooked, and she did everything.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And we sat down at the dinners Friday night.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "My mother lit the candles, and we had the-- my father made kiddish.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And we were singing and eating, and we enjoyed it.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Shabbos morning, I went to do the Bais Yaakov's school.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "We had [BACKROUND NOISE] a minyan, we davened.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "In the afternoon, we played with the children, with the friends.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Oh, Passover was a very big holiday.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "We had to change the dishes and do a lot of shopping.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "You used to bake matzos.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "They didn't buy a ready-made, but they used to go to a special bakery.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Everything was kosher.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And we had a lot to-- to prepare.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A little bit.",
      "word_count": 3
    }
  ],
