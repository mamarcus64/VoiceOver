{
  "stem": "23815.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 34,
      "text": "And I'm sorry to see him go so quickly.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 35,
      "text": "We had two bar mitzvahs.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 36,
      "text": "He was none of them there.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 37,
      "text": "We had a bar mitzvah for Troy-- for Jarrod first.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 38,
      "text": "He was older; then Troy.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 39,
      "text": "And he was not there to see it.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 40,
      "text": "Then after that, six years-- I was on my own for 1 and 1/2 years.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 41,
      "text": "[PAUSES FOR 3 SECONDS] It was sad to be on your own.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 42,
      "text": "It's not good to be on your own.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 43,
      "text": "Especially when you've been through so much, you want somebody near you to talk to.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 44,
      "text": "It's very hard to be on your own.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 45,
      "text": "I met Gary-- a nice man.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 46,
      "text": "He knew my husband.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 47,
      "text": "He knew him in-- from Belgium, he knew him.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 48,
      "text": "His wife passed away for-- she died from cancer.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 49,
      "text": "But I'm very lucky to find a man like him.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 50,
      "text": "He's very generous.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 51,
      "text": "He's kind, understanding, thoughtful.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 52,
      "text": "Every woman should have a man like that.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "You mean my story?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I did told them-- not everything.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "This is the first time in my life that-- I didn't want to do this interview, because it's too much pain for me-- too painful.",
      "word_count": 25
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But believe you me, I am glad I did it.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Because my pain in my heart was too-- for too long-- so many years to keep inside me.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I'm very glad to share it with you and for the world to know.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "This is not just a story.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "This is the real truth.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And I tell you another story.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "I came here to Australia.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And the first time in my life that I went to see a movie, a movie that's for-- in concentration camp.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "I wish I wouldn't go, because it's very hard for me to see what I've been through.",
      "word_count": 17
    }
  ],
