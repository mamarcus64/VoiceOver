{
  "stem": "3933.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I'm going to tell you.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I told him the story.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And he said, Oh my god.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "You don't know who he was?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I would kill him and this.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "He said, I'll take you there, to this doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Barbara and him, they took me to this doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You've got the abortion.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "He made the abortion.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I gave him the packages of cigarettes and wine, and he gave him something, this Franz.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "When I came back, the abortion wasn't so very good, perhaps.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I bleeded and without stopping.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "The lady, the old lady-- I  shared the bungalow-- the one who worked int he kitchen.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "She said, Maria, there is something wrong here.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I went back to the doctor.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "He took me again with this-- with this transportation and he said, In a minute everything is going to be all right.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "Well, and since then I never could get pregnant.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "That's what I want to tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "He ruined something there inside me.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I was raped.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "I came back, and I was rid of it.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "Oh, my God-- God-- and then, anyway--",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I was holding on in this bungalow.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "One of the Germans want to send me to a special kitchen, very hard work.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And they could see this Franz Knoler is very nice to me.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They sent him away in a different unit.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "The officer said, this is a Polish woman.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Why do you so-- and the Polish baby.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "Why do you carry on?",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "They transferred him in a different unit.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "He came once, in the middle of the night, with a motorcycle-- would you believe it?",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "Asking me how I feel, and brought me some bread.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "Well, that's another story.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Then I-- I met Germans-- said, you are going to have to work.",
      "word_count": 13
    }
  ],
