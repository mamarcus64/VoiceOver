{
  "stem": "12868.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 20.1,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "My father davened three times a day.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And my mother would light the candles every Friday night.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And it was really religious.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And come Saturday, you didn't do-- nobody did nothing in the world.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "When it comes Saturday, Saturday night, they make the Havdalah.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "They come and-- they come back in shul-- from shul, they sang [? the zemiras, ?] you know, all together, like when they make the Havdalah.",
      "word_count": 26
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And this is the way that he'd-- he'd daven three times a day.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I went in a public school.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And I went in a cheder.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The cheder first when I'd been six years.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I still remember how the father took me in the tallit.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Only he took me on the hand.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "And he brought me in his hand in cheder, the first time in this cheder.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And he put his hand on my head, and he [NON-ENGLISH] me.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "You know, he make a prayer on my head.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "[NON-ENGLISH SPEECH]",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the-- the cheder was about 30, 35.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "In the cheder-- I'd been in-- I'd been in public school and the cheder, too.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "I'd been in public school for to learn Hebrew and Yiddish and Lithuanian.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "This is the main Lithuanian language.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And later, in the night time, we went to cheder again to learn more about the Judaism, you know, like Humash, like [INAUDIBLE], like Tanakh, everything.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Yeah?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Like, you know, like in-- every-- every shtetl had their little-- not too much anti-Semitism.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "But, you know, all the Jewish people live together.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Everybody make a-- a living with the Gentile people from the country.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "We bought from them some-- some chickens, some cows, some everything.",
      "word_count": 11
    }
  ],
