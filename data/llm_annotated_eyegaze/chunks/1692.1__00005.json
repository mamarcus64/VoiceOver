{
  "stem": "1692.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 8,
      "text": "When we came to a big field, there was a selection-- the young and the children to one side, the sick and the old to another.",
      "word_count": 26
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 9,
      "text": "We couldn't find my father.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 10,
      "text": "I was so afraid they'll send my mother to work.",
      "word_count": 10
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 11,
      "text": "I was trying to protect her.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 12,
      "text": "So I urged her to go to the sick.",
      "word_count": 9
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 13,
      "text": "And she didn't wanna go.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 14,
      "text": "But she finally went.",
      "word_count": 4
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "When my sister noticed that my mother wasn't there, she started to scold me, 'Why did you let her go?' And my sister can scold.",
      "word_count": 25
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "So to get away from my sister, I went to the selection line, limping and bending down, hoping to go to the sick.",
      "word_count": 23
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "But this young Nazi officer straightened me out, and he said, 'You are young.",
      "word_count": 14
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "You can work,' and did not allow me to go to the sick.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "As it turned out, the sick and the old were held back.",
      "word_count": 12
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "And the young and the children were sent home.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 4,
      "text": "When I came home, I found my father.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 5,
      "text": "He was hiding.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 6,
      "text": "In the evening, you-- we heard shots.",
      "word_count": 7
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 7,
      "text": "Then, at midnight there was a knock on the window.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 8,
      "text": "And my mother walked in with her long hair down, and only a slip on her body.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 9,
      "text": "She couldn't talk.",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 10,
      "text": "She embraced my father for a long time.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 11,
      "text": "In the morning, she told us what happened.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 12,
      "text": "When we left, they were told to undress, put your hair down, just in case she has something hidden there.",
      "word_count": 20
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 13,
      "text": "And the Ukrainian dug graves to put 10 in 1.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 14,
      "text": "They set them in lines, 10 to each grave.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 15,
      "text": "When they killed 'em and buried them, while the ground was still moving.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 16,
      "text": "My aunt and my uncle were in the same grave with my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 17,
      "text": "Suddenly, my aunt said, 'Pearl, get up.",
      "word_count": 7
    }
  ],
