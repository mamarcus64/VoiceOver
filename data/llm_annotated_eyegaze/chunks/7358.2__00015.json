  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And they slept all four of them-- all five of them-- together, and they kept-- body heat, I guess-- they kept themselves reasonably warm.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "And I laid by myself in a corner.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And there were people there that were able to-- to build much more substantial huts, like a log-- almost like a log cabin.",
      "word_count": 23
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "They were strong men.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "And they got together groups of people to build a big log cabin.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And somehow they obtained one of those old-fashioned little stoves, that you could-- a wood-- a wood-firing stove.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "And their place was fairly warm, but they were very crowded, and they would not let me go in there.",
      "word_count": 20
    }
  ],
