{
  "stem": "1537.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 25.6,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "The school was a private school.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Was there until 1 o'clock. 1 o'clock, we had to run [BACKROUND NOISE] to eat lunch.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "You know, the lunch was the dinner.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Like here, it's Dinner time.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "There, we used to eat lunch-- I mean, the big dinner was 1 o'clock in the afternoon.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "So sometimes I had to go two kilometers to my uncle where the meal was.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "Because there, I had two days I was eating there.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "Then I had to run back for 2 o'clock already to be back walking, because the yeshiva started 7 o'clock in the night.",
      "word_count": 23
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "I didn't even have time to study, you know, because the Talmud.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And I-- the Talmud with the schooling, the homework-- I just, I couldn't do it.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "It was too much for me.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And then the problem with my sister-- my brother-in-law was not home anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "They took him to labor camp.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And she had three little children.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And I had to help in the store to watch they shouldn't steal the merchandise.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "If the merchandise arrive, I had to go with a bicycle to put the textile on the bicycle, you know?",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "It was heavy.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I used to turn over.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "You know, it was so heavy to bring the textile, the merchandise, into the store and, and help her there.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We didn't know where my brother-in-law is.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Finally, my brother-in-law and his brother were shot to death in Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "This-- my bar mitzvah was in my brother-in-law's father's house.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "That's where my bar mitzvah was.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "My father only, because they came from Somotor.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "It was a big-- it was-- the whole trip was maybe 75 miles from Somotor to [INAUDIBLE].",
      "word_count": 17
    }
  ],
