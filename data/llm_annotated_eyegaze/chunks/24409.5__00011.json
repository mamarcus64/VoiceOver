  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "Because he must have taken from people, let us say, 100 Czech crowns, which were, [INAUDIBLE] officially 12 pounds, which he had to pay to me.",
      "word_count": 26
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "And actually he got for this money much more when he sold it.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "But he sent it to Switzerland.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "And he was [INAUDIBLE] of something around [INAUDIBLE] in Switzerland.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "Because he was killed by the Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "He was too smart.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 33,
      "text": "He stayed too long.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So with his support, we got money for the For the it was the biggest ship ever to arrive in Palestine with illegal immigrants, so-called illegal immigrants.",
      "word_count": 27
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] this was after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "It arrived after the beginning or the war.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "They left Constanza-- [PAUSES FOR 3 SECONDS] not Constanza.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They were in-- no, they were, I believe, in Constanza.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They left on the 1st or 2nd of February.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And you know, God was with us all the time.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "They had there on the ship, and the British Navy stopped the ship, and the captain said, what should I do with them?",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I bring them to the next consulate, British consulate, and who takes them over in Smyrna.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We can't have them in Smyrna.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "The British Navy ordered him to proceed to the next British port, which was Haifa.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And he wrote it in writing.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And it said the ship could--",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
  ],
