{
  "stem": "1530.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And my mother always would have two poor little boys who went to school in my town.",
      "word_count": 17
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "So there were eight of us, and two more people.",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 3,
      "text": "That's 10.",
      "word_count": 2
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Come for-- other towns, studying in Kisvarda.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "And they needed to go somewhere on the Shabbat.",
      "word_count": 9
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "And my mother seeked them out.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 3,
      "text": "And so we always had at least 10 people at the table.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "And it was a beautiful dining room with this giant table and a white cloth, the damask cloth.",
      "word_count": 18
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "Or sometimes, we even had a tablecloth that my mother designed.",
      "word_count": 11
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "She was very, very talented.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And with her, all futuristic designs--",
      "word_count": 6
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "--and a religious home.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "And we had 32 candles burning every Shabbat.",
      "word_count": 8
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Shabbat candles.",
      "word_count": 2
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Because we came from a very big family from my mother's side, you know.",
      "word_count": 14
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I think that all those who died.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "I think that was it.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "But it was beautiful, all those lights, candelabras, and then smaller ones.",
      "word_count": 12
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "It was a beautiful occasion.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "Every Shabbat was beautiful.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Beautifully.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "You know--",
      "word_count": 2
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had maids.",
      "word_count": 4
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "And always a couple of maids.",
      "word_count": 6
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "And I used to help in the kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "I always loved the kitchen.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "And I loved to be around my mother, and the maids.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I always did--",
      "word_count": 4
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "--you know?",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "And yes, there was fresh, homemade challah every single Saturday.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Well--",
      "word_count": 1
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "--yes.",
      "word_count": 1
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "Yes, my father and my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "The girls didn't take such role in this whole Judaism.",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 4,
      "text": "We were kind of in the background.",
      "word_count": 7
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "No, but they knew how to read the prayer books.",
      "word_count": 10
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "I, when it came to me, I didn't even know how to read the prayer books.",
      "word_count": 16
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Well, because in the school there would be one--",
      "word_count": 9
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Public school once a week.",
      "word_count": 5
    }
  ],
