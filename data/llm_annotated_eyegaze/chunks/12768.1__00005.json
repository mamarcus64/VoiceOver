  "elapsed_s": 2.0,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was born in Denmark and raised and-- but he was still the assistant rabbi, so-- but people were wondering when he came in on September 30, 1943 and wasn't in his robe and his round kippah, which they used in those days.",
      "word_count": 43
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And he came in.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And he said, everybody, please sit down and be quiet.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I have something to announce to you.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "He said, I have gotten it on good authority.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] He said, I can't name the man's name right now, but the prime minister of Denmark, or former prime minister of Denmark, Hans Hedtoft, have called me and said that some weeks prior, the Germans had broken into the Jewish office, religious office in Copenhagen of the rabbi and the whole congregation, you know.",
      "word_count": 58
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And they took the list of the names of all the Jews in Denmark.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And we didn't know why, you know, they wanted the copies of everybody, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And we never thought about it, and-- but now we have it on good authority at, on Yom Kippur, which is October 1, the Germans are coming and want to take all the Jews and put them in a concentration camp.",
      "word_count": 41
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So he said, I beg of you to go home, right now, all of you that is here, and start calling your friends, your relatives, all you can, and have them again call others and et cetera, et cetera, so that it's spread out.",
      "word_count": 44
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I got, that afternoon, a telephone call.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I was 16 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I said to my mother, something is really wrong.",
      "word_count": 10
    }
  ],
