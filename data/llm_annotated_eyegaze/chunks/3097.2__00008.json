{
  "stem": "3097.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The food-- I-- I don't recall exactly was I hungry or not-- in the ghetto, myself.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I-- I don't really recall that I was starved.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I was hungry, but I didn't starve.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I worked under very primitive conditions.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I worked, for example, with blasting sand.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have any mask.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I used to take a handkerchief over my nose, put it here, and that was-- the thing.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I worked on a lathe, a metal lathe-- nothing, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "There-- there was no protection at all.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "We worked very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "There was no set hours.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We could work day-- 12 hours, 8 hours, 10 hours.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "On special Jewish holidays we did double kind of work.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "That was in Ludvikov.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Then I was transferred later on to the sister plant, to Henrykov, to the wooden production.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But that was already after they liquidated the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "For example, like on Purim, I think it was-- it was '43 or 4-- let's see-- or '42?",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They used to take the doctors-- intelligence.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They used to take people who they thought they were communists before the war-- the Germans.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "They used to take people who make some minor breaking of the law-- let's say, like smuggling, trying to buy something from the Poles through the ghetto, let's say, through the-- through the fences, or through the barbed wire.",
      "word_count": 39
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "They used to beat up people.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "They used to take the people at night to the jail and send them away to-- without-- nobody knew where.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "They used to-- there was a jail on [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "There was a Polish jail in the city.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And they used to put them to this jail, temporarily.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And then from there, they used to take them to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "They don't come back.",
      "word_count": 4
    }
  ],
