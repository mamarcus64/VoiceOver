  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "The train was equipped with an anti-aircraft gun, and we were traveling through Germany going east.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "We were on that train for about 10 days.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "No, I'm wrong.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "April 3 to April 13 we were on the train.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "April 13 we were liberated.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "So on that train for 10 days they never fed us.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "The only food we got was at the various little stations where we stopped, young people would run off the train.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And there were always stacks of turnips and beets or potatoes lying in the train station, and we would grab some.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "No cooking facilities, eating raw.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "The last few days, standing near the river Elbe and running off the train, begging for food in surrounding villages.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "Then we were liberated.",
      "word_count": 4
    }
  ],
