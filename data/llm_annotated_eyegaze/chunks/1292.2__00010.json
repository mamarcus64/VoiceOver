  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Wonderful, wonderful people, proud people with this transport going-- so brave, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember distinguish one family, and they was bosses of my husband.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "They did have a big business in well, it's a motoring and hardware and, you know, big business it was.",
      "word_count": 20
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And I remember him.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He was a lovely man with his wife and his children.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And he was-- I did see him in a transport walking so proud, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Like the idea, they can't get me sort of thing, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Not knowing, because he didn't survive.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Terrible memories.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And how many of that kind of aktion was there?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "What I recall, must've been three or four transports.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And of-- and then, oh look.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Can we have a little interval before I have to go on because it comes now to that little girl, my cousin and how she-- can you--",
      "word_count": 27
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Can you?",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Because I need a bit more water and I--",
      "word_count": 9
    }
  ],
