{
  "stem": "26359.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "I studied the history of the-- the old history from Russian history from before.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And the geography I liked very much.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "I always looked on the map to find where my uncle lived in the United States.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Language we-- our main language was Ukrainian.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We had twice a week Russian language.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It's a little different than Ukrainian.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And then later, in the later years, we had the German.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "Once a week, German.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Yes, of course.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I got-- Yes.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I got the diploma in 1939.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, after I was prepared to be a schoolteacher.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And the-- [PAUSES FOR 4 SECONDS] the war caught me in the process of being-- they sent me to a village.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I should teach children.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And the war caught me up at that.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "This was finished.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I did start.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And the wages were-- the salary what very, very poorly for teachers.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It was 240 rubles, which is very little money, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "We could hardly make a living.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "But it was a prestigious job.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "It wasn't like that, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "You look up to a teacher in my time.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to teach in a big city.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "But when I went there to the board of education, they didn't grant me the jobs.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They said that we need teachers for the village children, too.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "You cannot be-- not everybody could be in a bigger city.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And then what I wasn't in Komsomol.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "If I would have been in Komsomol, maybe they would have sent me to a bigger city.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "I wanted to teach in Kiev, in a big city.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "But I-- but I was refused that job.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "This was bad.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "This was very, very bad for us.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The war started on the 22nd of June, 1941.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I was on vacation.",
      "word_count": 4
    }
  ],
