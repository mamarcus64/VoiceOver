{
  "stem": "1692.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "He had a deep voice, and that's why I was so scared.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "I never heard of-- of Protestants.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "I never knew they existed.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And since there were no telephones, he couldn't call anybody, he just said to us in the morning, you don't look Jewish, and between our brothers and sisters, we'll find a place for you, and you won't have to hide.",
      "word_count": 40
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "He went to talk to a Polish Baptist, and in the evening that Polish Baptist came to the house and took me to his farm, and my sister stayed there for a while.",
      "word_count": 33
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "When I came to the farm, I found two Jewish boys hidden under the oven.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "And the ovens we have there are not like here.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "We have bakery ovens that you can hide under them.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "And there was another Jewish boy taking care of the horses and cow.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "And I joined the staff.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 44,
      "text": "I call it as a mate.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 45,
      "text": "They were very, very poor people.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 46,
      "text": "They had one child, one son.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 47,
      "text": "But they were very kind in sharing.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 48,
      "text": "A week later, my sister joined me, but he couldn't keep her there.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 49,
      "text": "There was too many of us.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 50,
      "text": "So he said to her, he'll give her a few leads so she can go and see if she can get a job.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 51,
      "text": "And she really didn't look Jewish at all.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 52,
      "text": "I have very curly hair.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 53,
      "text": "She had straight hair and a button nose that I envied.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 54,
      "text": "She got a job on a Czech farm, on a Czech colony.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 55,
      "text": "She told them that the reason she doesn't know how to work on a farm or to milk a cow was because she used to be a maid in a Jewish house.",
      "word_count": 32
    }
  ],
