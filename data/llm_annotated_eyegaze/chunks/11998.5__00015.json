  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And it started to heal.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And he threw me out.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "He said, OK, you've got to go out.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And it was just as I expected.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "I got terrible clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I had terrible shoes.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I had-- I was freezing all day long on the Baustelle.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And then, at night I went to the [NON-ENGLISH], or to the infirmary.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I said to Zambromski, you know, my foot swelled up again.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I said-- I said, please, let me stay in the-- in the hospital ward.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "I said-- I said, I remember, you owe me.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I helped you in Birkenau, you got to help me now.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I said, I am-- I am not going to survive, being on the Baustelle.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And so he agreed to let me stay in the barracks-- in the infirmary barracks.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "It was actually a compound.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Had about four barracks.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "One was an infirmary, and a couple were the-- the hospital wing.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And I was-- became his personal helper.",
      "word_count": 7
    }
  ],
