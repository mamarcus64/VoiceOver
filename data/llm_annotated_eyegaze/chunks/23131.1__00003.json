{
  "stem": "23131.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Any new clothes that I didn't like it-- they didn't buy never clothes for me in the shtetl.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Daddy traveled a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "He used to go to the big cities like Bialystok, Vilna, Warsaw, you know, for business.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "So always he came full-handed with all kind of clothing, with [INAUDIBLE] coats and-- [PAUSES FOR 3 SECONDS] and stuff that you didn't see.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "The whole shtetl played with my toys.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Even when I wasn't home, and they used to come around the window to look if I'm home.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "Mommy always let them in and she said, she's not home.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "She'll come soon, but you can play with her dolls.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Because my dolls-- still I hear people from my shtetl that I talk very little about, but they tell everybody the story when they shocked me-- when they shocked me and-- by telling.",
      "word_count": 33
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I said, how do you know?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They said, why?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Do you think there's no witnesses?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "They played with your dolls.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Always-- they were always welcome.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "It was a open house for everybody who needed it.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "Did you mind that they came in and played with your things?",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Because Mom was always ahead of me.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "She said, if you have it, you have to share.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "But not everybody could afford it.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I had dolls from the world, you know, talking dolls.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "At that time, it was-- everything was a novelty.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My-- it was a favorite doll.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "You would be surprised that I had the doll even after the war, and I lost the doll in the United States.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Because I found him-- I found it after the war by a peasant.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It was a blonde big doll that my aunt sent me for a birthday, or a different occasion.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember what was the occasion.",
      "word_count": 7
    }
  ],
