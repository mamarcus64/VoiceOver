  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And the potatoes, I used to keep them two weeks, till they used to go off and then like-- like, water, like, you know-- in the end way was eating them.",
      "word_count": 31
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "That's how I was eating.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "When the war was coming to end?",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "One time it was over a couple of weeks and no snowing.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "No snow.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They had afraid and never [INAUDIBLE] was no snow.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Once it started snowing-- started snowing.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I had to look, it's snowing.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "When the snow started to fall bigger, I took everything out and I say to-- I came to the hole and I say to my wife, you know Schendel, something's going on here.",
      "word_count": 33
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "It's not far, the-- the-- over there, the-- the-- the old-- main road, what's going.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "It's something going on.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "Either the German running away, either the Russian coming in.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Something is going on.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "I said, maybe I take little bit to go near.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "Maybe I go here and what they talking, he was talking.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "I was here and I hear there's talk.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "You know, I can understand if it's-- if it's Ukrainian, if it's Polish.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "She say, no, don't go.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "Then all night, that time, I didn't sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "Just keeping the [INAUDIBLE] night and to look.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Till the morning, sun already like the morning, I saw, it's two horse with people.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "And they are-- they are riding a pair of horses, two people.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
