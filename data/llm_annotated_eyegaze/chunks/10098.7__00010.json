{
  "stem": "10098.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "They had places where people could register, people who were in concentration camps, and most of my friends-- a lot of friends-- went to Israel.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "They'd been-- I'd been thinking about going to Israel, honestly.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And for some reason, the Betar, Menachem Begin, the people involved in-- in-- in Warsaw knew me more than I knew them, you know.",
      "word_count": 24
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Knew my story, and they told me about maybe they would look in the Irgun.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "It was looking for young boys like me, dumb boys that don't know nothing, with guts in them to do something, you know, exciting things.",
      "word_count": 25
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And I used to look for exciting things to do, you know, and I was wearing the American uniform, wearing that .45.",
      "word_count": 22
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "Oh, I was really-- I thought I'm something.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "And I almost fell in that.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And just when I got married and my wife was pregnant, that's when everything was going on.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And they told me they want to take me to Marseille or somewhere.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "Where is Marseille, Belgium?",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Somewhere-- is Marseille in Belgium?",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Marseille, maybe in France?",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "France, Belgium-- I think Belgium.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I don't know, Antwerp, I don't know, somewhere.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "They want to take me and smuggle me to Haifa and join the Irgun.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And I told them I cannot leave.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "My-- my wife is pregnant, she's soon How-- how can my wife go with us?",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "No, they can not.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "After, they are going to send her.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "They're gonna send after her.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "And then I had a baby already.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "Still Israel was not independent.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "They want me.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "You see, your wife got the baby, she's safe here.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "We're going to bring her later.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "I said no, we're gonna travel all, the whole family.",
      "word_count": 10
    }
  ],
