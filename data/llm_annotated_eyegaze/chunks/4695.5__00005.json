  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "I told him, listen, he's a young guy.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "He can take.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "He can be at the sit to [INAUDIBLE] something to do.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Give him work.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "He's a young guy.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "A few things like that, he [? decide ?] to help him with.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "OK, a few things like that.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "He call him back to give him [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "And when I go there to [? evacuate ?] in the collective farm, he is coming with me too, with his wife.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "And when I wrote a letter, then he comes over.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 16,
      "text": "My conscious wasn't clear.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 17,
      "text": "Because I was-- I know he has a woman with a child.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 18,
      "text": "And the other woman sent to his wife a letter.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "I'm his wife.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "He is with me.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "We have a child.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 22,
      "text": "And you look for another husband.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Tarlowski.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Iosif Tarlowski.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] And he is now in, in Holon, a big building in Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "He was a survivor.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "At that point, when I came to, to Bakhara, they called me in to the voenkomat.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "It's a military institution.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They tell, listen, you like-- what do you like to do?",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I tell them like to stay a few months because to go back, they put-- the [INAUDIBLE] see I cannot go.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "Because they put the army against Japan.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Then I must go to the Trans-Siberian Road around [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "I told them I'm afraid my child is now three, fours years in middle Asia-- a warm climate.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I'm afraid to go now back.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I'd like to be over the winter in the spring to go home.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "Tell, OK, we'll give you a job.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "They gave me a as a from a restaurant so to make a living, because you are a man who was fighting [INAUDIBLE].",
      "word_count": 23
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And you helped us a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    }
  ],
