  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "I don't know the name.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "That was in beginning of '39.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Deeply, in a way, because I knew that he had given so much trust and whatever you want to call it to his son-in-law.",
      "word_count": 24
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And that this man betrayed him to such extent.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I felt so bad for Grandfather.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I'm sure you would understand that.",
      "word_count": 6
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "I never forgave my uncle for it.",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "I think I saw him after the war twice.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "Once to give him a piece of my mind and I said, I will never put my feet under the same table with you again, and I didn't.",
      "word_count": 28
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
