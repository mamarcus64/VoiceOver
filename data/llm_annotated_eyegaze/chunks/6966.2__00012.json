{
  "stem": "6966.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "You were spending time talking to your father and walking in the grounds of Westerbork.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, wondering how [? and whom. ?] Terrible time.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "An outsider can't feel what, what was going on in our mind and in our hearts.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Some of them took it light, but a lot of them didn't.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "The longer you could stay in Holland, the more chance you had that the war would end, and you would be freed, and all those things.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "You tried to fix yourself in a different frame.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "But it didn't work.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And then it was the 17th, the 18th, January, 1943.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "After about four months in Westerbork, this is what happens.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "The lights go on in all the barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "And on the table is a man with a sheet of paper in his hands, and on the paper the names of the people that going to be deported.",
      "word_count": 29
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So I'm laying there in bed, listening.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I look around, you know, underneath my blanket.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I see them get dressed.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "That one gets dressed, all ready to go.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "When is it going to end?",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And then I hear, Greenman, Leon.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Get up.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "Get dressed.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Tomorrow morning, deportation.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "And the same thing happens in the barrack with my wife and my child.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "So I got dressed.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "I rushed to Dr.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "Neuberger's ?] office.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "And I shows him-- you get a strip of paper, deportation.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "He said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I don't understand, he says.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he talks to me.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "He says, your papers are on the way.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "They're supposed to come.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Anyhow, nothing helped.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "At half past 8:00, we stood there.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "There were 750 people.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "The exact is 748 people, as registered in the books.",
      "word_count": 10
    }
  ],
