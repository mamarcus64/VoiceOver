{
  "stem": "6195.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Syda, S-Y-D-A, Selinger, S-E-L-I-N-G-E-R.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Florenz, F-L-O-R-E-N-Z.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, it's just that instead of Syda they used to call me Sydja.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "In Krakow, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "22Nd of April, 1922.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "73.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was a very happy childhood.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I can go back only as far as I can remember, and that would be about when I was four or five years old.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Jacob, in English-- Jakob in Polish, [?",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Jakov ?] in Hebrew.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My mother's name was Bluma Hinde.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "She was born Leineer, L-E-I-N-E-E-R.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And I had a brother, Beno, in Hebrew, [?",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Benzion ?] Florenz.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "In 1914, on the 13th of April.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I had a sister, Eda, E-D-A.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And she was born in the 12th of September, 1927.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The most wonderful person I have ever met as a person, and a very, very caring father.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I have never, with all honesty, never have I heard my father raising his voice, yelling at anybody.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He achieved, always, in bringing up his children by communicating with us, even though he was a very, very orthodox, religious man.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "He knew how to get through to us and convey whatever he wanted to to us in such a way that I could never, ever lie to him, nor to my mother, for that matter.",
      "word_count": 35
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "But that's how we were brought up.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "I have never heard any arguments at home.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "It was just the most pleasant, the most happy atmosphere.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "What did my father do?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Well, first of all, he was a partner in a bank.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "He was-- he had properties.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And he also had a like an agency for-- [PAUSES FOR 3 SECONDS] in Vienna, there was a, a very known factory of [INAUDIBLE] hats.",
      "word_count": 25
    }
  ],
