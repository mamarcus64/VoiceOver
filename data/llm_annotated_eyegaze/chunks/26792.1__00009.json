{
  "stem": "26792.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Because in-- in Riga, I-- I only knew where the synagogue is because all Chagim I spent in Kuldiga.",
      "word_count": 19
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "You mean the out-- outbreak-- the-- actually the outbreak of the occupation?",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "My brother and my-- my sister-- and my sister had just finished high school, with the gold medal that I've told you.",
      "word_count": 22
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And she was about to come to Riga to study at the university.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "But since she was taken by surprise during-- by the war, they stayed on all together.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "My brother decided to send the family to Russia, somewhere in the rear.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "The evacuation.",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "But my parents could not go any place without me.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "They decided to take me with them.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "So they make-- made a stop in Riga.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "And we saw it is impossible to get to the train-- to get on the train.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "Because the Russian officers wanted to evacuate their wives and all the crowd they had.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "And we had-- there was no way out.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "We had-- we were stuck in Riga.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So he was the one who first seated the family on the truck and made sure they leave.",
      "word_count": 18
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And he was sure they are somewhere in Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And only then did he get on the last truck and went-- went to Russia with some other people who escaped the Germans.",
      "word_count": 23
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "That was the 27th of-- of June.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "--41.",
      "word_count": 1
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they come to-- they come to join me.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Two days, I believe-- two days or three days prior to the 27th.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "So it could be 24th or 25th of June.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "War broke out in 22-- on the 22nd.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "In what sense, you mean?",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I had-- I had a boyfriend who shared my opinion, who was also Jew-- also Jewish and also a Zionist.",
      "word_count": 20
    }
  ],
