{
  "stem": "11274.3",
  "chunk_idx": 17,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "So I had the choice at that time to be shot to death myself and the young couple and the little girl.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Now, they were mad at me-- that they-- when I-- I tell you later when they were mad at me.",
      "word_count": 20
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "But anyway, so I gave myself up and went to the military compound.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I wrote a letter to my sister and wrote a letter to [?",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Cheine ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Gottlob. ?] That was my boyfriend that I was supposed to marry in two weeks.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "The wedding was scheduled, and the people that I lived with gave me the money to buy the material.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And a tailor made a robe for me and made some nightgowns.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Everything was preparations to have it before the holidays?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "When-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I think before the holidays to get married.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And Danka said-- Danka was going to come.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And Zosia couldn't with the children.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But Danka was going to come to the wedding.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And I wrote a letter to him and wrote a letter to Danka and went to the military compound.",
      "word_count": 19
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And I went in the afternoon dressed, prepared to it, without a coat.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "Just the suit I was wearing and prepared to come back after I-- but you stay right here, he said.",
      "word_count": 20
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And you stay right here was until the next morning outside with many other people there.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have any conversations with them because I was freezing.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "I was holding myself, and I went on my knees, put down.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "And I pulled my pleated skirt.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "I had a pleated skirt and a checkered blazer.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "And kept it over my legs.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "I was cold, and I was falling off-- dozing off a little bit and that.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And I was thinking already, what did I do?",
      "word_count": 9
    }
  ],
