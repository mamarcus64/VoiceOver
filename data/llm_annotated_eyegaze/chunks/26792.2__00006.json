{
  "stem": "26792.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "He suggested every, every Latvian who still has weapons to gather at the [NON-ENGLISH], picture is here, at the [NON-ENGLISH] which is in the old city of Riga, in the struggle against the local and the foreign enemy.",
      "word_count": 38
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "The local enemy are the Jews and the communists-- this is what he said-- and the outsiders are the Russians.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And thousands of Latvians came with weapons, which they had hidden during the year of the Russian occupation.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And there, they were mobilized, organized, for the first struggle, in inverted commas, against the Jews and communists.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I remember and will never forget that very first night.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "My nanny was staying with us.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "She had come from the countryside in order to help us somehow, some way.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yes, that's right.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "The same room.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "She had-- she had been living with our family for over 33 years, so she was as a member of the family.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "We heard footsteps at night, knocking on doors.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And there were Jewish-- it so happens there were Jewish families living there, the Kotten and the Joffer and us.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "So they knocked on our door.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And my nanny went out, and she said, what is your wish?",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "What do you want?",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "We have come to pick up Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "She said, there are no Jews living in this apartment.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And she closed the door.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And she saw that she's Latvian.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "But upstairs, there was the Kotten family.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "So I heard them-- I overheard them, or I eavesdropped-- Kotten, Kotten Is it a Latvian name, or is it a Hebrew, a Jewish name?",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And then they decided to make the people come out, and the people never returned.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "The same happened to Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Joffer, who lived the same floor, her husband.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Only males were taken away.",
      "word_count": 5
    }
  ],
