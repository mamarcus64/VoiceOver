{
  "stem": "24466.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.0,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "When I came to his place, a lot of people like me have been.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "The whole town was full and his flat was full.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "They called them [NON-ENGLISH]-- that we are running away from the-- And I asked him, listen, is that possible, because I know that you are big contacts with tanneries here.",
      "word_count": 30
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Is that possible-- he know me very well-- if that will be possible to-- I want to work in a tannery.",
      "word_count": 21
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I want to engage, because it looks to me that I have to leave and I have to earn money to be able to leave.",
      "word_count": 25
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And so he said to me, wait a second.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And he closed me in one of the rooms.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And he took, maybe, no longer than 10 minutes.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "He came in with the gentleman, a young gentleman, with a [NON-ENGLISH], very nice person.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "And he introduced me to him and said, that is my son.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "He is a rabbi, a rav, a rabbi, in a little town in Motal.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My son is a rav, is a rabbi in Motal, at night, we heard that Vilno will be next as the capital, and from there-- and Lithuania is not in the war.",
      "word_count": 32
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "From there you can go wherever you want.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Listen to me, better go help my son, because the wife, his wife and the children are still there.",
      "word_count": 19
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Go there and try to get to Vilna.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And I listened to him.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "I went to that Motal, to Pinsk.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "I remember because the trains no-- that is the end station of the train.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And after we have about four kilometers to the famous swamps-- Pinskiya baloty.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Swamps, you know, how to call it in English?",
      "word_count": 9
    }
  ],
