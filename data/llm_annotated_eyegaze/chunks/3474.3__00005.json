{
  "stem": "3474.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "Didn't give us a drink of water.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "They could have said, when we came to the door, they say, look, we don't want no trouble.",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "Please leave.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I would have-- we would have left, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But she didn't give us a drink of water.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And they called the SS and took us back.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "They took us back, just two of us, and two soldiers with machine guns, two people.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "We marched to a town.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And we came back to the tr-- where the train was.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And where the train was, there was-- What did the SS say to you?",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "What did they say?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They didn't say nothing, just marched.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Let's go.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He says with the machine [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And they pushed you by the, by the, by the butt, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Let's go, go.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "We come back to the train.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "I see the train.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "There was people against the, the hill and people in front of the, f front of the, the cars, the railroad cars.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And the people, I don't know who they was, what was going on there.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And I see people they were dragging out from the sewers, people, from the, from the trees from the-- you know, they were hiding all of-- they tried to run [INAUDIBLE].",
      "word_count": 31
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "And the people that they were bringing back, they put on that side, one side.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And I don't know what-- how I did it.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "I walked away from that side to the other side.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "I don't know what the difference.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "I just walked away from this side to the other side.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "And I stayed there and was talking to somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "And it didn't take 10 minutes.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "The SS and the machine gun mowed them down.",
      "word_count": 9
    }
  ],
