{
  "stem": "18575.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 35,
      "text": "And then, one morning, the German had discovered us.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 36,
      "text": "They threw gas grenades, smoke grenades into it.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 37,
      "text": "And we had to get out.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 38,
      "text": "And we were in the building's garden, so to say.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 39,
      "text": "A friend of mine gave me a cigarette.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 40,
      "text": "There was an SS man, a young boy-- he must have been 18-- lighting a cigarette.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 41,
      "text": "And I walked over and pointed out.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 42,
      "text": "And another SS man right next to him hit me with the-- with the butt of cigarette, knocked the cigarette out of my head, and knocked me off floor.",
      "word_count": 29
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 43,
      "text": "Never lit a cigarette.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 44,
      "text": "They took us to Umschlagplatz.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 45,
      "text": "Umschlagplatz had a building there.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 46,
      "text": "The-- the room was full of-- of the inhabitants.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 47,
      "text": "Some were wounded.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 48,
      "text": "Some were very sick because they threw those smoke grenades or gas grenades, were vomiting, were laying there, green in their face.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 49,
      "text": "We were there two days-- no food, no water, just packed.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 50,
      "text": "I was half dead.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 51,
      "text": "I was in high fever.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 52,
      "text": "I-- I had terrible infection in the hand and the foot, couldn't walk.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 53,
      "text": "They brought us down and put us in a railroad cars, closed railroad cars, packed.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 54,
      "text": "And truly, I don't give up easy.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 55,
      "text": "But I just didn't have any-- any strength.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 56,
      "text": "I could have-- if I was in a whole thing, I could escape from there.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 57,
      "text": "It basically was a window you could have broke.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 58,
      "text": "People did that and escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 59,
      "text": "Some did not successfully, because the SS was riding on a roof.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 60,
      "text": "And anybody escaping, that would shoot at.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 61,
      "text": "But some escaped.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 62,
      "text": "Anyway, they brought us to Majdanek concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 63,
      "text": "Majdanek is in a suburb of Lublin, the city of Lublin.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 64,
      "text": "That's a eastern city.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 65,
      "text": "That's southeast of Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 66,
      "text": "It was only a few hours' train ride, I think four or five hours' train ride.",
      "word_count": 16
    }
  ],
