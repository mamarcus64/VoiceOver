{
  "stem": "19195.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 556.6,
  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "But going back to April 11 of this-- this is '96, '95, right?",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 6 SECONDS] So he said to me, [PAUSES FOR 3 SECONDS] 50 years ago today we liberated this camp.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And there was-- I don't know where to run, to crematorium, to the hospital, or where.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "I come to the hospital, and I see this young lady screaming, hysterical, burning up with fever.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "Would you by any chance know what happened to that girl?",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "I looked at him.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "I start crying.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "I says, sir.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "I am that little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "And in my honor, they opened up the theater for the city in Nordhausen.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "What else happened on the day of liberation?",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I think I was in love.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't know, really.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "About three weeks after liberation.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And he got the bus to go back to Prague and come back for his people.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And unfortunately, he-- he got cancer, and he passed away.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "But I used to go to Prague a-- a-- a lot.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And God forbid if I came to Prague because of the papers coming, being able to come to America.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And God forbid if I came to Prague and he found out that-- he would call my-- the lawyer, because I would go to the lawyer to help us get the papers.",
      "word_count": 32
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "He-- he would call him.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Was she in town?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Was she in-- in the city?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And I told him, tell him the truth.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Yes or no.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "He was a good friend.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "So you remained in Nordhausen for another three weeks?",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And then I--",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "During that time?",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Not much.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I came back to the living.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Then there was another prisoner, but-- because with the Czechoslovakians, we got along.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And he came over and he says, you know, you come with me.",
      "word_count": 13
    }
  ],
