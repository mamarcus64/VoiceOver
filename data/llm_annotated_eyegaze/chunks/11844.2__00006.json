  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He and Professor Cohen were the leaders of the Jewish Council, what you would call here the [PAUSES FOR 3 SECONDS] Jewish Council, the [PAUSES FOR 3 SECONDS] Federation.",
      "word_count": 29
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Federation Council, we call it here.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "That's only where the buses were unloaded.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I came to a family by the name of Kaufmann, on Raphaelstraat 20.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Very little.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "However, it was not important because on June 11, 1941, which is about two months later, something else happened.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 9 SECONDS] I left my house, Raphaelstraat 20, right around 3:00 in the afternoon, and I was visiting [PAUSES FOR 3 SECONDS] a family by the name of Lehman.",
      "word_count": 31
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "There were three boys.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "The two sons-- Lehman, they were in [?",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Viering ?] and they went to their parents.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "The two boys, their parents were living in Amsterdam, so they were not taken in by another family.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "They were the two Lehman boys and one other guy from [?",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "Viering ?] by the name of Ansel Freidlander.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And I went visiting with them.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And after 20 minutes, the doorbell rang, and a maid comes in with two Gestapo people.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "What's your name?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Gert Lehman.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Over there.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "What's your name?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Kurt Lehman.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "Looking at the list, over there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "What's your name?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Ansel Friedlander.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Over there.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "What your name?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Eric [?",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "Felgenheimer. ?] Not on this list.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "They had me on the list at Raphaelstraat where I lived, and I left.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Not on the list.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No, here I belong.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They go out on street.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "Name of the street is [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And I see another young boy from [?",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Viering ?] by the name of Kurt Wurzweiler with his head down, walking on street between two policemen-- Dutch policeman.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I saw another one and another one.",
      "word_count": 8
    }
  ],
