{
  "stem": "597.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "Because I used to-- he put me under his children.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "The children used to sleep in the front, and I used to lay in the bed.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "And covered me up with that, like a little blanket.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "The partisan, the-- the young guys shouldn't see me.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "Such a good guy, he was.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "Very good, understandable man, person.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "And this way I was staying there the year, until liberation, until the December of '44.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "Every day, food. he had plenty-- I had plenty scares.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "They used-- Germans used to come in and look for food, for-- for partisans.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "They used to look around there all over.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "A couple times he were scared.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "I thought they're looking for me.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "But it came out it was not-- they didn't look for me.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "They looked for partisans there.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So maybe every day was a different scare.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Every day, a different-- I never was in the house.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I was outside, either in the bushes outside, either under the house, and the-- and the attic during the day.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I was afraid to stay for the-- before the liberation.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "It was kind of bad.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And he had a younger son, one son, two sons and three daughters, little ones, little kids.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The son was 13, the younger one.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "The older one was 16, 15 or 16.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The older one was really bad.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Teenager, you know, he was.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He used to say to his father-- to his mother, not to the father-- are you keeping this Jewish Jew?",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "The [INAUDIBLE]?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "You don't need her.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "What do you need her for?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "But the younger guy was a very, very nice person. 13 years old, what did he know?",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "He used to go in the woods.",
      "word_count": 7
    }
  ],
