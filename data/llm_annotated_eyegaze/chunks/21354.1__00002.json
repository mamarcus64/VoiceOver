{
  "stem": "21354.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Beyond that, there was a Jewish school, a [INAUDIBLE], all facilities.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Jewish sports club.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "It was well organized.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I went to a Jewish school, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Judische Volksschule Munchen.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And that means Jewish Elementary School, Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I'm trying-- now trying to relate.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I think from 1928, '29 till '36, '37.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "General education.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Probably more than an outside school, but by no means exclusively Jewish.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "The children who were all Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "The teachers were all Jewish, as far as I remember.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Reasonably good.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We lived in a building.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "We were the only Jewish family, and all families around us were non-Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Not-- not before 1933.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Our home life was a happy one.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "We were a simple family.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "We had no great luxuries.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "It is pretty well the same as it's here.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] Shabbat, we all went to synagogue.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Perhaps not my mother so much, but certainly my father.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We came back and we made Kiddush and we sing-- we sung [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "It was no different than it is here.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "In my later years, I was a choir boy.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Shabbat morning-- in the synagogue.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Shabbat morning, everybody went to synagogue.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "When I see everybody, at least the people that I knew, all went to synagogue?",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "The food.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 6 SECONDS] I don't precisely remember, but the choice wasn't that we have today.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "One ate [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "We always said if you had a lot of-- if you had money, you had more meat in the [INAUDIBLE], and if you had no money, you had [INAUDIBLE].",
      "word_count": 29
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Mainly boys' books written for my generation.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Westerns and such.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I was extremely interested in communication in radio.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And as my parents couldn't afford a radio, I joined a club-- a radio club-- and eventually made one.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "In Munich.",
      "word_count": 2
    }
  ],
