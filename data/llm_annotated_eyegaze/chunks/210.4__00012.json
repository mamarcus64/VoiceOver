{
  "stem": "210.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And before the-- I went to the hospital, you know, when I was in the ninth month, I, you know, my husband and I, we painted the room and made everything ready.",
      "word_count": 32
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And-- because you couldn't buy any clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "When the baby was born, they gave you a-- gave you a ration cards to go to a place and buy things for the baby.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But before, they didn't give you anything.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "So we, you know, I remember I washed the windows and made everything ready.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, after my son-- after my son was born-- after a week, I-- yeah-- part of my ninth month, I got-- my feet started swelling.",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And I got very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "I had uremic poisoning.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I had to be in the hospital the whole ninth month.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "Well, in the hospital, a girlfriend of mine that we were very close friends-- and she was pregnant.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And she was a month-- she gave birth a month before I was due.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "And her baby was born dead.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "And this was such a-- and I was in the hospital at that time.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And this was such a terrible blow to me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "I just couldn't-- I just couldn't-- you know, I was scared to death.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "And I, you know, they had to induce labor because of the condition that I was in.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "They induced labor, and my son was born.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "I didn't scream, because I was in the hospital the whole ninth month, and I-- whenever I went to take a bath, I-- they took me next to the labor room.",
      "word_count": 31
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "And I heard all these women giving birth and screaming.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 21,
      "text": "You know, it was horrible!",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 22,
      "text": "And I'd think to myself, you know, this is-- you know-- I don't know.",
      "word_count": 14
    }
  ],
