{
  "stem": "7415.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So I never figured out how my mother did make it back and forth from ghettos.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "One--",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Czestochowa ghetto.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Then when I was alone, my mother came from Warsaw to Czestochowa.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Found out from this woman that she sent me to ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "In Czestochowa.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "She came to Czestochowa ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "That was second time Czestochowa ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And took me out.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I don't remember how long ago-- how long I was in Czestochowa, but I remember being on the train, again, to Warsaw and being in few different places hiding.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And one of these places was the prostitute.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] She was-- the woman was a prostitute, and she was sleeping with German soldiers.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] And she had another guy, a Jewish guy, who lived with her in her place.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "So she had somehow secure her future.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "In case of Nazis win, she will be having Nazis boyfriends.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And in case it will be different, she was helping some Jews for money.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "But this woman was really bad to me-- for me.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "She shaved my hair and--",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Because I had lice.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I had scabies in her place.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I did sleep on-- there was no bed, of course.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "There was a little hole in the wall, and there was a little bit-- a lot of materials.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    }
  ],
