    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "By game.",
      "word_count": 2
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "For me, it was no good.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "In '49, September of 1949.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "My brother went to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "He was in Germany, too, my-- my-- my brother.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "And the older brother, the HIAS took him here.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Oh, after the war, I-- [PAUSES FOR 3 SECONDS] not anywhere.",
      "word_count": 11
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "I find them in the war.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "I find them in Samarkand.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "Oh, right.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "That brother.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "But the other brother.",
      "word_count": 4
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "Oh, the other was-- I never find him.",
      "word_count": 8
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "You found two brothers survived.",
      "word_count": 5
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "The two brothers were in Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "They both were in Samarkand.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I thought one.",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "I lived with them together.",
      "word_count": 5
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was-- I was very, very excited.",
      "word_count": 8
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "I went there--",
      "word_count": 3
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "September-- September '49.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
