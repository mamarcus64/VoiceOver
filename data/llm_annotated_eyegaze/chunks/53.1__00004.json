{
  "stem": "53.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "We couldn't run away from there now because there was German Volksdeutscher.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "They was Germans, but they were really Poles but they were Germans.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "And they wouldn't give you the day of light.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "They wouldn't give you nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "If you went somehow to beg for a piece of bread, they slammed the door in front of you.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "[PAUSES FOR 4 SECONDS] Finish with Stutthof.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "Go on to Magdeburg.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "Magdeburg, we had-- also a labor camp.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "No gas, no-- [PAUSES FOR 3 SECONDS] no killings.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 44,
      "text": "They wanted to get out of us as much as they could.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 45,
      "text": "They got trains with coal.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 46,
      "text": "Trains with bread.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 47,
      "text": "Trains with everything.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 48,
      "text": "It went to the front.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So they gave each one of us, who, you looked healthy or was whatever, they gave us a whole wagon full with coals to unload with a shovel.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I could do it, but some people didn't do it, so I went to help them to do it.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And how did we eat?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We didn't eat.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "How did we-- how can we exist?",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "So we ate what the pigs ate.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "The pigs.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "What they ate, that's what we ate.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And there were instances-- [PAUSES FOR 3 SECONDS] when I was going to work, a German who was a corporal, he was drinking a lot.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He was saying to me, you know, I'll let you go to beg for a piece of bread if you bring me some whiskey.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And he let me go and I brought him some whiskey.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And at the same time I brought myself a piece of bread or whatever I could beg for or steal.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I did everything to survive.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "That's why I'm here.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] And we worked.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] Our life was miserable.",
      "word_count": 8
    }
  ],
