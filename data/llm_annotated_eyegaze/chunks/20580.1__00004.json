{
  "stem": "20580.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I went a couple weeks in 1932.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And I went a couple weeks Offenbach, close to Germany-- to Frankfurt.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I was there a couple weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And then Hitler came to the power.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It was 1933, I guess.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Oh, with the mother.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We were-- the-- mom was a mother and she did the [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "Not modern lady, beautiful dress that you see in the picture, nice dressed.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Plus, she came, one from the telling people when they finish university in the Russia and they-- there.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And they told me the same.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "He wouldn't be a rabbi.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "He wouldn't be-- if he goes to be educated, he wants to be a doctor.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "He would-- a doctor, he couldn't get anyway, the-- the-- he couldn't get the diploma.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Because Jewish people cannot be doctors.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "The only thing-- learned a trade.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "I went to Germany.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "I learned a trade.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "He says, yes, but the-- the government wouldn't give you permission.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "You have no-- you have no practice.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "And they called it a [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "Permission to work for yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "Then, anyway, I wrote to the president from Poland-- not the president.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "He was the head from the-- Pilsudski.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "I wrote him a letter, which I remember the letter, which I did wrote to him.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "He send me, in two weeks, a permission to work leather if I could.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "I had the permission, [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "They called it [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "In Polish, it's the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "And I had permission.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "And then I started to work leather for myself.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "It was also illegal for the-- for the-- to tax us, it was illegal.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "I didn't pay taxes.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "But I work--",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "My childhood was-- you know, what-- a childhood of-- in school, I did-- I liked the school.",
      "word_count": 17
    }
  ],
