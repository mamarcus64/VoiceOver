{
  "stem": "26447.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The first name is Semyon, S-E-M-Y-O-N.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And the last name is Menyuk, M-E-N-Y-U-K.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I got the Yiddish name.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "But they give me these two names together.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "It's [?",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Royal ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Borough. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Now, is this a Hebrew-- if to translate this in Hebrew-- in English will be now, bless you.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Bless God Israel.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The 4 of May, 1922.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Now, it's the 75th year.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "In May will be 75.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "That was Poland, P-O-L-A-N-D.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The city, Komarow.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's a village.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "K-O-M-O-R-O-V-O.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I remember we was in-- Komarow, it was a village.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Approximately, it was about 250 houses.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Knowing my parents was born in the same corner of the village my grandfather, and then-- and more and more and more, all the generations was in Komarow.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "It was-- most of them, it's Ukraine.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We live only that's five, six families Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Now, in the beginning, I was in school.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Now, then, now I can say what-- what I was doing.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I was study in school.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Now, and I helped the parents, what they can do.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And after there when I got finished maybe four grades, and the parents send me to this.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "We didn't got more.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "It's only four grades in the village.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Now, it was this-- they teach us Ukraine and Polish and no Yiddish.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Then the parents decided to send me in a school where it's-- where we can study Yiddish and Hebrew and the [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And we got in Sarny, city Sarny, my mother's sister.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And they send me to stay with them.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "And I went to school Tarbut.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I never studied in Tarbut.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "Then I came that's-- I finished the school Tarbut in 1938.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And I come to the parents back.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And I helped the parents in village Komarow.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "This approximately that's in 1938.",
      "word_count": 5
    }
  ],
