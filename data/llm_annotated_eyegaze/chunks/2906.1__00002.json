{
  "stem": "2906.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We used to read the papers.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "The older people used to read the papers.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "The younger kids used to read books.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "And it was a-- a wonderful, a wonderful place Friday night.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "It was so happy.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And then neighbors used to come in and-- together.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "They used to make-- you know, they used to give something to-- to-- to drink, to eat, and it was-- it was something-- it was something beautiful.",
      "word_count": 27
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "It was wonderful.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] It was maybe about 60,000 Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Rowne was the-- was the main city, and then was little towns around the-- around Rowne.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "All kind of little towns.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, people come, say-- they all say that they are from Rowne.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "Rowne was a big city.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "There's a lot of stores, and-- and-- and there was beautiful shops.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Everybody used to go for walks.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "There was a main street, and every shop was-- everybody used to go walking there.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "Used to get dressed up, and it was-- it was wonderful.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "But it's funny-- one side, Jewish people used to go walking.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "When they're outside, the-- the Polish people used to walk.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "But the-- you know, they-- they didn't-- some are anti-semitic.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "They-- if they could find my-- my brother when-- when he went around, and it came late, and a couple boys was running after him.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "They want to beat him up.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "So he was running in a bakery, and he-- and he hide himself.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "They have, like, for all ages, institutions.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I just remembered for the-- for the younger people, what there was.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "For the older-- for the older people, it was just for-- when you get older-- they used to-- Usually older people used to stay with their parents.",
      "word_count": 27
    }
  ],
