{
  "stem": "20684.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "My uncle spoke to me in Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "His wife was Russian so she couldn't speak Polish.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So everybody talked and so on.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And everybody was eating and eating and eating and talking and this and excitement.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "It as about 12 people or so.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And where I run out of luck is because I was put close to the meat.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "There was a roast.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "I hadn't seen a roast for a long time.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And that's the bad news.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "What I did with the roast is what anybody would do as smart as me.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I was a smart guy then.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "I was 10 years old and I was professional.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "I knocked off half of the roast and put it inside my shirt so I knew the next day, we were going to eat this well.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And that's when the roof came down.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "My white Russian auntie got me by the ear, pulled my ear.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "They started working me, hitting me.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "After they hit and whacked me for five minutes, I explained to my uncle in Polish to tell them I've spent two years with partisans.",
      "word_count": 25
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "If she thinks I'm going to cry, she said her hand will be much sorer than it is now before I start crying, so don't waste your time.",
      "word_count": 28
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So she hit harder and the results were the same.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Partisans don't cry.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So we-- but she got the better of me, God bless her.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She's been dead for quite some time.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "She got the better of me.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "My auntie put me in an orphanage for four and a half years because of my [INAUDIBLE].",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And that's a hard [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] Things got tough.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "If you see the cut here across my nose, that was a razor from the orphanage because we'd-- we'd settle arguments with knives and razors.",
      "word_count": 25
    }
  ],
