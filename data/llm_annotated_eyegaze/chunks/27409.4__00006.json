{
  "stem": "27409.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 78,
      "text": "I took her out and I brought her, so I had my family together.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 79,
      "text": "Now where to go-- we started moving away from the transport along the trenches.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 80,
      "text": "It was dark night.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 81,
      "text": "Suddenly we heard heavy going, heavy boots.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 82,
      "text": "Three Romanian soldiers with a woman, Ukrainian woman, she spoke Ukrainian-- stop.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 83,
      "text": "We paid them.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 84,
      "text": "We had still money left.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 85,
      "text": "We paid them, and they let us go.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 86,
      "text": "They took two of our rooksacks away and let us go.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 87,
      "text": "We moved along the trenches.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 88,
      "text": "We didn't know where we are.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 89,
      "text": "We see-- during the day, we see where we are.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 90,
      "text": "We could all speak Ukrainian, which was the local language.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 91,
      "text": "I remember we had again some with the running, heavy boots are running after us.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 92,
      "text": "They said, the Romanian soldier came back without the girl.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 93,
      "text": "And, uh, they very afraid, we assume they're very afraid that we will not be caught by [INAUDIBLE] patrol.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 94,
      "text": "So they say, come forward, forward.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 95,
      "text": "And they brought us-- we saw from far there was a fire in a yard.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 96,
      "text": "We didn't know it was a school.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 97,
      "text": "And in the middle of the yard was a fire and bad Jews.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 98,
      "text": "Afterwards, we found out it was a rebel from [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 99,
      "text": "They shot the rebel, was there with his Hasidism.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 100,
      "text": "We were sitting there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 101,
      "text": "We were deported from Suceava.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 102,
      "text": "He had some elder left, Jewish, we discuss with the soldier which were guarding them.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 103,
      "text": "Any case, they opened the gate and let us in.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So there is where other Jewish women is there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "They gave us hot tea to drink.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We were frozen, cold.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was November in the Ukraine.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "There was already snow on the Earth.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "We were the first night, detention, so cold.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "During the night, they searched for forced labor.",
      "word_count": 8
    }
  ],
