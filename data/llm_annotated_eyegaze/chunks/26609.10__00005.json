{
  "stem": "26609.10",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The floors were not even boards.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "It was a-- just a soil, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Not covered at all inside, very poor, a table and a bed, that was all.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And what to do?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I went in.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "I can't go out on the street at night.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I thought maybe someone will see me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "So I thought, the best I go into a toilet.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "They had outdoor toilets, wooden outdoor-- not like here in the flats.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "Not at that part.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "It was a very poor part.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "It was a-- a outdoor-- we have here a toilet outside, there to the back where the carports are.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "There is a toilet too.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Like I say, it's a wooden toilet.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "There was such a toilet.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "I thought I'll wait in the toilet.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And it was near, not far from her place.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "So I can hear the children talking when she comes home.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I knew when she has to come, between 10:00",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "00, half past 10:00.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I went to the toilet.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But then someone wants to go to the toilet from those houses around.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "There were people living.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So a man went in-- want to go in.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "So he started-- in Ukraine, he something said-- something not nice.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And he opened and had seen-- it was dark, no light there.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "But he knew it's a woman.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I didn't want to talk because if I talk-- if I don't talk, it's someone from there.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I went out.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "He went in.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He finished his business, went out.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "He went out and was right into his place.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I went back.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "There was only one toilet for all the people around.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I went back to the toilet.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Another one came.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "(LAUGHING) I had to go out again.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "I went out.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "I didn't go for any purpose in.",
      "word_count": 7
    }
  ],
