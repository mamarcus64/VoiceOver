{
  "stem": "56.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "There were onions hanging and-- and salami.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "And there was so much stuff there.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And pillows, and-- and a silk coverlet.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "And there was no one there.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And she said, this is gonna be your place.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And I-- she says, I-- this is mine, but I don't stay here.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "I will come every morning, and I will bring you more food and give you more things.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "She said, but in case, if I don't show up for more than two days, she says, you go through the washroom, and there's a little little [NON-ENGLISH]-- little house there.",
      "word_count": 31
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "And she says, you knock on the door, and you ask for Ivan.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "And you tell Ivan that you are my sister, and he'll take care of you.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "So for a couple weeks, she used to bring me all kinds of things.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "She used to bring me underpants and food, soups.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "Every time I stayed on Zahlappell, she used to bring me water, whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "And I used to share it with my cousin.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "And there was another Czech woman standing there with two daughters.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "Because she-- her name was Rondova.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And we were standing by names.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "And she had two daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "And one of the daughters had dysentery.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "And she was just standing there, and it was just coming out her.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "So when this other girl-- by the way, her name was Ilanka Hershkovic.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "She brought me a pair of pants.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "I took the pants, and I gave them to this Mrs.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "Rondova.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "And I said, look, put them on your daughter so it won't run through right away, so no one is gonna see that she has dysentery.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "So she took it, and she said, I'll never forget that.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "I'll never forget you for doing that for my daughter.",
      "word_count": 10
    }
  ],
