  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "And many were cold and many were killed.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The Polish Uprising took by two months.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And then, all of Warsaw was evacuated.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, I and Ben were together and his parents were in a hiding place with Poles and they were in another place.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They were also evacuated.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They survived, but as Pole.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And we were also out of Warsaw and we survived in a small village-- in Grojec-- as Poles.",
      "word_count": 18
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And his father survived as a person who cannot hear and cannot talk.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "So his Polish was very bad and had the Jewish accent.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "He looks good, but till he opened his mouth.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And if he opened his mouth, right away, you knew he was Jewish.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "This was organized by the Polish underground, the Armia [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The Polish military underground.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So it was participation of the Armia Ludowa.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "This is a smaller Polish group.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "The more leftest group.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "After the Uprising, when all-- after two months, the German evacuate all of Warsaw.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And it took till-- from September till January 17.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "The new attack of the Russian liberated Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "So the Russian came in in January to Warsaw.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And this is when I came back to Warsaw.",
      "word_count": 9
    }
  ],
