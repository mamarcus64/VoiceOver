{
  "stem": "7684.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The police was very good.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And they tried to get me out.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "But I didn't want to go out.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "I want to go to my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "Were they Dutch police, or--",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Dutch police.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Because my brother, I think, was after that, and he was already a little bit underground.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And-- and they came to me.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And they want to hide-- to get me out.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And-- and they had a place for me.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't know that the underground was that [NON-ENGLISH]-- strong.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have any money.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I also wanted to go to my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And so my mother is in Poland in a big camp.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "And my brothers are there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "And I will find them.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "And I wanted to go to my mother.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "That's all what I thought about it.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 13,
      "text": "I-- I didn't think about anything else.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So, from there, I went to jail in Amsterdam.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "I was three months in jail in Amsterdam.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And we were together in a very small cell with-- with 10 girls-- 10-- 8 women-- all-- from all ages.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "And that was a time that I really grow up in jail, when everybody tells their life story.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And-- and I really was not the little girl anymore from the family.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "And I really had a reality what was going on in life, really.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "From-- and so, also, it was very coincident-- we did get very little to eat in the-- in the jail.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "One was a professor's wife.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And one was a doctor's wife.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And one was a beautician.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And one was just a girl from-- from-- from on the street.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So everybody tells their story.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And-- and-- and we-- and one woman was very beautiful.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "She had blonde hair.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And she blonde-- she made it-- colored it in-- in jail.",
      "word_count": 11
    }
  ],
