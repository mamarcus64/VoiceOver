  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And she says, you see my son?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Oh, your son, I see.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "He goes with the-- with the head for the city.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He goes-- he goes nice dressed.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And your son is this and this and this and this.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "She has a-- And when I bring leather, when I bring material, then I took material for flour or bread, I left it with my uncle over there.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And over there, I gave the other friends, I gave bread.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "You know, bread, sugar, you know the way it is.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Other things, food.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Potatoes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "I give five kilo potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "And I give their five.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Because the beginning, I start to bring from here to there.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Why should I gave over there?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I go with them there-- swap not legal.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "But when I go with the two police, with the leather, see, then I steal then, the beginning, and later on, I have no problem.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I-- I give to them here, and I give-- meanwhile, it's my uncle Luchon Royce.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "This was a rich man.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "At that time, was rich.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And he haven't got brought to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I gave him bread and potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And I give back them there.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And then most I didn't.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Regarded?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Guarded, was a little wire.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "But nobody was going out the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "But if you'd go out the ghetto, this guy over here, they was watching.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "When you go, he shoot.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Not fence.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Not fence.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It was an own wire and that.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "So we know this is the wire.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "This is the ghetto.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "It's divided.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "But in the back from the ghetto, they make the change for each other sometimes.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "But the last dead which I see it, was a name, Yuri Solles.",
