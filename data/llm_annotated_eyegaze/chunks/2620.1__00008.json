  "sentences_input": [
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the other brother?",
      "word_count": 4
    },
    {
      "segment_idx": 165,
      "sentence_idx_in_seg": 1,
      "text": "He was taken away--",
      "word_count": 4
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 0,
      "text": "Isidor was taken away, like, in the military.",
      "word_count": 8
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 1,
      "text": "But the Jews were not in the military.",
      "word_count": 8
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 2,
      "text": "The Jews were in forced labor camps.",
      "word_count": 7
    },
    {
      "segment_idx": 166,
      "sentence_idx_in_seg": 3,
      "text": "So he-- he was working in forced labor.",
      "word_count": 8
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 0,
      "text": "Well, no, he was taken away before.",
      "word_count": 7
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 1,
      "text": "Like, you know, when you become of the age to go to the army.",
      "word_count": 14
    },
    {
      "segment_idx": 167,
      "sentence_idx_in_seg": 2,
      "text": "So he went into the army.",
      "word_count": 6
    },
    {
      "segment_idx": 168,
      "sentence_idx_in_seg": 0,
      "text": "He may have even had a-- an army uniform, but he didn't-- he worked as forced labor for the military.",
      "word_count": 20
    },
    {
      "segment_idx": 169,
      "sentence_idx_in_seg": 0,
      "text": "I believe that was either '42 or '43-- in 1942 or 1943.",
      "word_count": 12
    }
  ],
