{
  "stem": "7414.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "But as it was no room in where I should have stayed, he put me on a train to Krakow.",
      "word_count": 20
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "As I was standing.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I'm telling you.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I had my coat on.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I was over seven months pregnant.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And I go to Krakow, where I was not in my life.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "You know, that is like that.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Przemysl is here.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Lwow is here.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "I went first to Lwow, then I was up to Warsaw, then I was down to Krakow.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "All over Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And that was my '40 [POLISH], which I didn't know that it is '40 yet.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And pregnant.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Then it was coming to summer.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I come in-- it is April, into spring.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "In May-- in May, I was in Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "May is a beautiful month in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "It is the full spring.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So I come to Krakow to this family.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "That was some family of those Polish couple, Prowiszaks, from Warsaw.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "That was a woman and two daughters.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "One of the daughters was around my age, it is presumed my age.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "No, I--",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Unsuspected.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Even not suspected.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I will tell you a thing like that.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I was traveling from Warsaw to Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "In the compartment, there were two women and a man, a young man.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And I was talking with those women, it-- but after the war, my husband showed to his friend-- a Polish friend-- my photo.",
      "word_count": 23
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "That one which I have in the desk, which is so-- so--",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Creased.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Damaged.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "He had it on.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And this man looked at him and  told him, that's not possible.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "She can't be Jewish.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I was traveling with her in the same compartment from Warsaw to Krakow.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "You see?",
      "word_count": 2
    }
  ],
