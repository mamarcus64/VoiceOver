{
  "stem": "21978.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Go that way, they are the American.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And we have heard that the Russians were not so very gentle to young girls.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "So we tried to run the other way, and fortunately.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "After stopping in several houses of Germans where we helped ourselves to some food which was left there, or some clothes-- I even think I have left with a wallet with some German money.",
      "word_count": 34
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "And we took that, and we continued.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "And we came where we met some German-- oh, sorry some-- some US Army.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 22,
      "text": "And they were very good to us.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 23,
      "text": "We were not alone.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 24,
      "text": "There were many other people.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 25,
      "text": "And they have established a little camp for us.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 26,
      "text": "They had tents, and they gave us food.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 27,
      "text": "That was the first time I have seen a negro, when he came-- a soldier-- into the tent to say hello to us.",
      "word_count": 23
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 28,
      "text": "We didn't speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 29,
      "text": "One of our girls-- one of our friends spoke a bit English, so she was the interpreter between the English, you know, the American soldiers and us.",
      "word_count": 27
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 30,
      "text": "And they give us cigarettes, blankets.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 31,
      "text": "And we-- from then on, we are-- we knew that we are living.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 32,
      "text": "And we have been trying to get to some points from where we could go back to Czechoslovakia, because everybody wanted to go home.",
      "word_count": 24
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 33,
      "text": "I mean, we four girls.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 34,
      "text": "The other-- the other people on the-- on the way, the French who spoke English was from a very rich family.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 35,
      "text": "Her father had, in Prague, a car-- was selling cars, and she knew a bit of driving.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 36,
      "text": "So the American soldiers had there some jeep-- a German jeep, probably.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 37,
      "text": "And they gave it to us, and she was going to drive us.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 38,
      "text": "And we ended in a-- in a ditch.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 39,
      "text": "Nothing happened to us.",
      "word_count": 4
    }
  ],
