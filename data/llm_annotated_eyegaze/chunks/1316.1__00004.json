{
  "stem": "1316.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 49,
      "text": "She has-- she died, but she has three sons in the country.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The only one that survived.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "The other sisters, I don't remember much.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "The younger after me-- I was busy with other things.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The younger after me, Tama-- we have the photograph there.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She was a nice girl-- dark like my father with braids.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "The other one was a blond one, Rachel, [HEBREW] was blond one.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "I don't remember very much about them.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "I was up-- at the age of 5, I was taken to the cheder and then to another cheder, a cheder for beginners.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "And after that, I went to a cheder where they studied Chumash, the five books.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "And I read a little bit of the legends and-- and Talmud.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And at the age-- and I became very religious under the influence of this rabbi.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "But at the age of 10, my father-- my parents decided to enroll me in public school, in the Polish public school, because you needed to know Polish and so on.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "And there a transformation began.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "Slowly, under the influence of the secular environment, I became not religious.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "We had a-- I-- and-- and then I became involved politically with what was going on in the world.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, Shabbat, I remember in the-- in-- in-- when we were had already the restaurant, Shabbat we spent in the back room.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The restaurant was closed.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We put together two tables, covered with a-- with a cover.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And Mother lit the candles.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I went with my father to the [HEBREW]-- it's a house of study, a big synagogue in the area-- Friday night.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Saturday morning, we went to the visiting the sick society.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "We came home.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We had a traditional meal Friday night.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "The Saturday morning, we went-- I went to the [HEBREW].",
      "word_count": 10
    }
  ],
