  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And a matter of fact, I'm not seeing good, and I pray [? bad. ?] Every day I pray, I pray [? bad. ?] And sometimes I feel that I pray for a moment-- pray for [? bad. ?] I have seen it with my own eyes.",
      "word_count": 47
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "It's historic.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I have a new face for me.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I was in Gemany four years.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "In Germany.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Liegart ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Rechland ?] I was at logger there for four years.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And the [NON-ENGLISH SPEECH], they was making and the loggers was a lot of tree-town people.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They'd have an accident, you know, something-- all kinds of accident between wide burn and load burn.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "You know it was all people, but-- then they was making like an [GERMAN], call of German [GERMAN], like our coat.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "I was the hat, [? finnim ?] coat.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I used to be the had and coat.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "[NON-ENGLISH SPEECH] And then, I had a big family-- my wife's big family in Cleveland.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "They sent me papers, affidavits in German.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And they warned me in the paper-- in the letters-- should I work myself, I'm a butcher.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "She had a girlfriend in some Miles factory making salami.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "He signed an affidavit.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "He gonna give me a job, started to work [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "And one uncle, he was a builder-- Abrahams.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He told [INAUDIBLE] and myself, I'm a bricklayer.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "A matter of fact, I had a brother who he died too from cancer here in America.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "He died already.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "He came here poor, and he became a millionaire.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He left property for $2,500.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "He became cancer.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "He died, too.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "He became a bricklayer, and I became a butcher.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I was working one day, and he told me, OK, I could go keep you.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "You are a good worker.",
      "word_count": 5
    }
  ],
