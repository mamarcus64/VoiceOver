{
  "stem": "26358.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "He said, be a bad night.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I say, why?",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I think we can't wait longer with the Gestapos.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "I think you need to go in camp.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "We buy-- we think we bought the Gestapo.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He sends you home, girls.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I said, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "3 o'clock, we got a knock on the door.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "The policeman came, one, and a Gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And he say, you ready to go in camp.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we went.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "My father say, we-- I bring them, don't worry, six girls.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "There was six girls.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We used to go every day to wash the clothes in camp for the concentration guys.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "The nicer thing happening in camp.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "One day was snowing very bad, wintertime.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And we came a half hour late.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] That was '42.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "We came very late.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "And the Gestapo was waiting for us.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And when we walked in in that room where we washed the clothes, we saw trouble.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "I said, something happen here that's awful.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "And he told us we should stay straight.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "We're getting shot a half hour late.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "He took out the gun-- put it to the heart to me.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I was the first one.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And he said to me, why are not screaming.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "That should help me.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "I say, you shoot me today, and you'll be suffering tomorrow.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "I think God put in my mouth what to say.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "I believe in that.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 24,
      "text": "He said, to suffer, I'll let you live-- all six.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 25,
      "text": "He was so mad, he walked out and shot twice outside, the gun.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 26,
      "text": "We thought that he shot somebody of the yard.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 27,
      "text": "He was-- he want kill somebody that day.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 28,
      "text": "That's how mad he was.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And when we came home, we told my-- what happened.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And my father say, that's no good, girls.",
      "word_count": 8
    }
  ],
