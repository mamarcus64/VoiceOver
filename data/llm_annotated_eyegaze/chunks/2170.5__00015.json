{
  "stem": "2170.5",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "I'm going to Odessa.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "I can't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "And I come in at night, and I have to go.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "I had a letter from the American embassy to go to the Hotel [?",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "Gosteinsta ?] that means Hotel [?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "Londonskia ?], London, which is on the end of the city near the Black Sea.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "I did not know so late at night at 10 o'clock to-- where to-- how to go, but they told me you gotta go up this street, it takes you straight to the end, maybe five miles or six miles.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And I walked to the end.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "And I came to the hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 28,
      "text": "And I came in the hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 29,
      "text": "There was office in the front.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 30,
      "text": "I walk to this, was a woman.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "I gave her my passport.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "I told her who I am.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "And she called down the American military attache from the second floor.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "His name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "Herscher ?].",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "We have over here a passenger that has to go to the United States and please come down.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And he came down.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I didn't understand any.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "She spoke to him in English.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Big, tall military man.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I give him the passport first.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And then he opened up the passport.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "He said, what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "What is this?",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "He spoke Russian, and I told him what happened.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And I had-- so he said, don't worry, you might have problem, but I'm gonna try to put you on the ship.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "OK, try to look at me rather than around the room.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
