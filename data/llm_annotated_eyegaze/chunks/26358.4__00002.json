{
  "stem": "26358.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, the Russian soldiers us liberated.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And they took us off a truck-- off the back, not keep us from the front-- took us back a little bit.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "In a city that we was afraid the Germans should not come back-- not get-- you're not-- you're in again with the Germans.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "That was, like, a week.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "1944, July, end of July.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "In August-- we came home, beginning August.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "The Russians was very nice to us.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They went-- how much boys was left, took them all to the service.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But my husband was shot by the Germans, when he ran away from the concentration camp, in his left arm.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "I have the picture.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "My daughter-in-law saw it yesterday.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "She said, that's the scar.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "Yes, he went in hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "He was in hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "And my boyfriend, my cousins, friends-- about 30 people-- guys-- the Russian took to the service and sent them straight to the front.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] I was left with my mother-in-law.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "She was not, that time, my mother-in-law.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "Well, I stayed with her.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "My boyfriend told me I should watch his mother.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "They went to the service.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "He went, and they sign papers who he leaves.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "He went.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "He told them he left a wife and a mother.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "He no told he left a wife, a mother, and a girlfriend. 1940, for that, I came already in-- in the city, after they went to the service [INAUDIBLE], I came to the city where I was afraid to stay and where I was born.",
      "word_count": 45
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "For the Ukraine was Partizaner still.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "And when I came to the city, I have nothing to eat.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "I was starving.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "After the war, after everything nice and set, we was liberated-- Ruthie, you're going through still hell.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "You're not still set.",
      "word_count": 4
    }
  ],
