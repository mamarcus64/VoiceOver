  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 121,
      "text": "And if you go over there-- he said when he go in over there, he probably will do $1,000 or more because it was a better store like this, a bigger.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 122,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 123,
      "text": "I bought the store.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 124,
      "text": "I have $2,000 left.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 125,
      "text": "In meantime, my cousin's wife-- his name was [NON-ENGLISH]-- I have vacation was in May or in June in '47.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 126,
      "text": "I went to look for a business.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 127,
      "text": "I come in in a grocery.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 128,
      "text": "The men want to give me the grocery for $8,000.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 129,
      "text": "And I don't have to pay him.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 130,
      "text": "I will pay him out when I go in the grocery.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 131,
      "text": "I come home, and I tell this to my cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 132,
      "text": "My cousin's wife said, first time you have to be agree now.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 133,
      "text": "You have time when you want go in business, we always borrow you money.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 134,
      "text": "This what she told me.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 135,
      "text": "Is I quit the grocery.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 136,
      "text": "I don't take the grocery.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 137,
      "text": "Later my cousin told me about this candy store.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 138,
      "text": "I went to look, and I have $2,000.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 139,
      "text": "I want to buy the candy store with my cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 140,
      "text": "He don't answer my to give him money.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 141,
      "text": "That man what he was selling the store is he said he will borrow me $2,500.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 142,
      "text": "Because I have already $4,500.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 143,
      "text": "He know the store, and he don't know me.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 144,
      "text": "Only he know he will pay out.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 145,
      "text": "He will work out, they will pay out.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 146,
      "text": "I was making $25 a week.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 147,
      "text": "Later, I need more money.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 148,
      "text": "Is one time when I come to work, I have over there a guy, a friend.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 149,
      "text": "[NON-ENGLISH] was his name.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 150,
      "text": "He asked me, Simon, look like you think something.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 151,
      "text": "I told him, I want to buy a candy store, and I don't have enough money.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 152,
      "text": "He said I have $1,000 I borrow to you.",
      "word_count": 9
    }
  ],
