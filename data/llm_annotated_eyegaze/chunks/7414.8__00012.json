{
  "stem": "7414.8",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "I nearly fainted.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "I said, where I am going to buy the material?",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "Where I'm going to buy the lights?",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "I need it for this.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "Who is going to make those 1,000 blouses?",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "I'm not going-- where we are going to cut it?",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "So somehow we resolved all those problems, and we were on our way.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "I had very good neighbors.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "We found a flat at the beginning.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "We were very hard up this-- because in those days, you could not rent a place with a small child.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "Small.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "Michael was not so small anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "He was 9 and 1/2 years old.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "But they heard the child, that was it.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "No decent place would let it.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And I did not-- we had enough money to put a deposit on a house.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "But when I saw those little red brick houses with the little gardens in front of them, so I told I never lived in the country.",
      "word_count": 26
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I will not know how to live in a house like that.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I want a flat.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "So we got-- finally we got a flat in Clovelly.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I will tell you, that was a blessing.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "We were--",
      "word_count": 2
    }
  ],
