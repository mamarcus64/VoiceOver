{
  "stem": "598.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "It took them two, three days to get the letters.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "And then the 120 smartest people they killed.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "And then every couple of months, they came in with a letter saying that their people working over there.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "They need clothing.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "Many are women with clothing, and with-- also begging to bring their clothing and food.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "They're going 40 miles.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "The police, Ukrainian police waiting for them, beat them up, took the clothing away, threw everything away.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "And this was two times like that.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "That was 120.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "Then at-- at that time it was 150.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And the third time was Tisha B'Av, 450.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "And then came in-- I was working at that time in a sugar factory.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 25,
      "text": "Me and my father beating up stones-- calcium-- for the sugar.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 26,
      "text": "And when-- if they catch Jewish people not working, they don't care if they work or not.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 27,
      "text": "But if they-- they not standing right now by work, they take them.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I was working in that-- I didn't go home-- in the sugar factory beating up stones.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And my-- my day work, then at night I'm back in the other workers.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "We take his place and beat up the stones.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Beat up the stones in order to stay there not to go back to the city.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "There was three nights and three days people working on that thing.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "Then on the third night, with-- with us together, was the rabbi's son.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Hold the thought for a moment.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "We'll-- we'll pick up in a minute.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "We have to--",
      "word_count": 3
    }
  ],
