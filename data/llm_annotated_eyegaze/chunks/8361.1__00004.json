{
  "stem": "8361.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 21.3,
  "sentences_input": [
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "They started to show their true colors.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "I wasn't in school anymore when it started to happen.",
      "word_count": 10
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] It was different.",
      "word_count": 7
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] Because that started in '38, '37, '38.",
      "word_count": 11
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 3,
      "text": "I was married already.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "I was a tutor to children, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "And later, I had a store.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "I opened a store when I was 19 years old, [PAUSES FOR 3 SECONDS] delicacies.",
      "word_count": 15
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Which-- that's what I did.",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Delicacies-- it's not delicatessen-- delicacies, sardines, all kinds imported stuff, and cheeses, and oranges.",
      "word_count": 14
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "It was a small town, so oranges were the big deal, and all kinds of stuff-- even bananas.",
      "word_count": 18
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "19 When they opened the store.",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "My husband did.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "We weren't married yet, but they helped me, and my mother.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "I was 15 years old--",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--when I met my husband.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "In the Zionist organizations, two children grew up in the same town.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "I guess I fell in love.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] And he did, too.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "So 15, we were married.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "I was already 20, 19 and a half.",
      "word_count": 8
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "1937.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "June 19th.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Jacob.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "Jacob Winshell.",
      "word_count": 2
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "In Tuczyn.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "His occupation-- he was [PAUSES FOR 3 SECONDS] like a tin smith.",
      "word_count": 12
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "And he opened a place that he made all kinds of things.",
      "word_count": 12
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "Tin smith.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "He made things for-- [NON-ENGLISH] I don't really know how to explain it.",
      "word_count": 13
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "And he had like a company.",
      "word_count": 6
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "And they covered roofs with tin, even churches, all kinds of things.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 3,
      "text": "He had a company.",
      "word_count": 4
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "When we got married?",
      "word_count": 4
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Wonderful.",
      "word_count": 1
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "We had a good life.",
      "word_count": 5
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 2,
      "text": "We were married 56 years.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "You mean during the war?",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "In 1939, the Germans and the Soviet Union divided Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "So our part of Poland became Soviet Union, Ukraine.",
      "word_count": 9
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "At that time it was Soviet Union.",
      "word_count": 7
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "So we were lucky.",
      "word_count": 4
    }
  ],
