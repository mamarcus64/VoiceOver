{
  "stem": "3346.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "My grandmother had died already.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "My-- she went to-- she-- she went right away to-- right after the war started, she went to-- to Israel to join my aunt, [NON-ENGLISH] who lived-- you see, [NON-ENGLISH]'s son had emigrated to Israel before the war.",
      "word_count": 38
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And he married an American.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And they lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He brought his mother over once he found her, once they got in touch.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And my grandmother went over there with her.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But when I got there, she had died already.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And well, it was very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I stayed with my aunt, and I worked for the-- whenever I say USOM, nobody-- nobody knows anymore what it is, because it doesn't exist.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "It's what the-- I guess, what the United Nations Special Fund does now-- that kind of thing-- technical assistance, et cetera.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "So I worked there for a year.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And then my father had a stroke.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Oh, he had several of them before he died.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And my mother asked me to come back.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "I went back.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "I still didn't like it.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "So I stayed for a year and I left again.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "[LAUGHS] And I came to the States.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, I came to visit my aunt in New-- my aunt-- I call them aunts.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "They aren't really.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "They're sort of adopted-- adoptive aunts from wartime, et cetera.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And I met some friends of mine who worked with the OAS in Washington, and they offered me a job, the OAS, that is.",
      "word_count": 24
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "So I worked from '58 to '60-- '58 to end of-- end of '59 in Washington.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And then I was offered a job at the UN in New York.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And I stayed there till '64.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] And then I went-- then I was offered a contract in Senegal, in Dakar.",
      "word_count": 18
    }
  ],
