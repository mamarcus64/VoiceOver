  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "My brother and I were delivered to a large 28,000 [INAUDIBLE] [? ton ?] German luxury ship called the And were ordered inside the The captain resisted to take us on because he already had 5,000 other inmates in there, and he said he had no room.",
      "word_count": 47
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "But the SS man insisted, and he had to yield.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "At this point, Schmidt escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "He escaped as just at the time that we were taken to-- to the Bay of Lubeck.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Just a group of SS men.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "No one that we knew.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "He was German.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Captain Bertram.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "He was the captain of the ship in-- in-- in peacetime.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "The ship was a luxury ship.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "It was traveling between Hamburg and South America, in Brazil and Argentina.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Very luxurious.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Very luxurious.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "It was hard to believe that we were put on such luxurious ship.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "There was also the and the [GERMAN] nearby within our sight, on which other inmates were already there.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "We were just added on to lots of inmates that were inside.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "They were from Gross-Rosen, from [PAUSES FOR 3 SECONDS] other camps near Hamburg, nearby.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Stutthof, Gross-Rosen.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And such camps that were in that vicinity.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Some of them were as long as two weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And they cleaned us out.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They took everything that we had in food from us because we only came, and they were already hungry for two weeks.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] We were on the ship for no more than 24 hours, as the following morning we felt a huge detonation, huge [GERMAN] of the ship.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And soon felt that we are not standing on even ground in this room that we were-- that we were-- have to hold on to one another or hold onto the wall to walk.",
      "word_count": 34
    }
