  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] So we arrived in-- to America on--",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Well, we always-- we always thing about it.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Now we are free.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We are in this free-- this free country, so what-- what we going to do?",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "How we going to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We were all [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "We didn't understand one word, English.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "We didn't worry about [INAUDIBLE] were worrying how the children going to-- we have to go to school.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "They going to go to school.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And they don't know, they don't understand one word of English.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "How they going to-- to-- to do it, and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "So that's what was a big worry for us.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "But then everything turned out nicely.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "And then some cousins, then Ilona's sister came.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "At that time, one sister lived in New York.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "She came out with her family to see us.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And we were in Camp Kilmer for a couple days.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "Then from New Jersey, came out some cousins, Ilona [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "And we got our papers, and they let-- our cousins took us their home in New Jersey.",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "And next day, a cousin-- a friend of my cousin's took me some place, and-- and I got a job.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "So [INAUDIBLE] that was on a Thursday.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And when Monday, next Monday, I was already working in a place.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "And-- and Ilona was sewing.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "But so we were working.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "And-- and the children we took-- went to the school.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 24,
      "text": "So it was everything went nice, and went smooth.",
      "word_count": 9
    }
  ],
