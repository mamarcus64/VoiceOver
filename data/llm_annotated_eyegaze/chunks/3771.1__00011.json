    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "And they start shooting at-- with their guns in their hands.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "And it was the most horrifying things.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "I have to relate this to-- to those future generations.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "They should know what mine eyes actually have seen.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 12,
      "text": "And I find it even now difficult to be able to tell what mine eyes have seen.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 13,
      "text": "I couldn't accept it mentally.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 14,
      "text": "It was--",
      "word_count": 2
    }
  ],
