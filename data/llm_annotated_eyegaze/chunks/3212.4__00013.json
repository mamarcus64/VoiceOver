  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I was in Birkenau till end of December.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "When they were talking about the Russians came close to Birkenau-- it was end of December-- they sended us on a march.",
      "word_count": 22
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "We had to get all together, in rows, and they call it, like, the death march.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "We left, I think, around by 60,000 to 65,000 people, we left Birkenau when the Russians came.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "We start marching.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "It was December.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "I remember it was snow.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And we start marching to Gleiwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] On the sides, SS with machine guns.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "We start walking.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "They didn't give us special food.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Walter and me-- because he worked in the clothing chamber-- we had-- shoes, we had.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And we had a jacket, like maybe a coat.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "But in the back was the mark from a concentration camp-- was cut out, with blue and grey marks in it.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "And we are marched to Gleiwitz, and I don't know how many days it took.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 15,
      "text": "But from Gleiwitz we went to another place, and we went in a forest.",
      "word_count": 14
    }
  ],
