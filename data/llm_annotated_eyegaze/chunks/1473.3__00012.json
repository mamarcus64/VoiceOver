    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "And the mandate was to keep our Jewishness alive.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "Not, perhaps, in the theological, religious manner, but observing and so on.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "And he was really subversive.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "He was a true, convicted communist.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "And he was very clever, too.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "But I mean this is just a sort of a profile of how-- but, generally, the people were wonderful.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "It was run by a man by the name of Maurice Chevrier, who would be a Freemason, and who was very good to us, very good to these Jewish children.",
      "word_count": 30
    }
