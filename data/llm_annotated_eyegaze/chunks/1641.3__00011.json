{
  "stem": "1641.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Must have been 600-- I'm just guessing, 600, 600, 800 people standing at night in front of the hospital trying to get in, either for treatment or for-- to get in because they had high temperatures, you know, coughing, and they got bronchitis and pneumonia, all sorts of sicknesses, terrible sicknesses.",
      "word_count": 51
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "They were all very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "They should have been all admitted.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "But my order was let in six men every half an hour.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "And during the whole evening, I think the average admittance was about maybe 30, 35 at the most, out of 800.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "It was my job-- and the other boy-- we were standing out there with our brand-new striped uniform with, you know, this [? thing. ?] And I asked people in English, French, where are you from?",
      "word_count": 36
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Poland?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "You speak English?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "What is your matter with you?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Oh, I'm-- I'm dizzy.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I got very high temp.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "I had orders.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "I can only let people in if their temperature is over 39.6.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "If it's only 39, that is still fit to go to work and carry bags of cement.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And people who had perforated ulcers-- if their stomach was hanging out, the blood running from the stomach-- that I could let in.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I could let that in.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "And they had people with hole in their stomach.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "The ulcer burned through their stomach and hanging out the intestines.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I could let them in.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And I let-- well, I tried to pick out the-- the most sick people, but they were all very sick.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And then I wouldn't let that in or this in.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And then they shouted at me, says, you bastard, can't you see how sick I am?",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "Why don't you let me in?",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "I'll fix you up after the war is over, you know.",
      "word_count": 11
    }
  ],
