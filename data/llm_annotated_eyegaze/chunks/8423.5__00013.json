{
  "stem": "8423.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I was really moments from death.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "I was so bad.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "Because after they arrived, and they handed out some canned food, [DRINKS] some rations that they had with them, like Spam and stuff like that, army food, my sister had secured a can of food.",
      "word_count": 35
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And she had taken a little tiny sharp rock, and a big rock, and she kind of worked it all around this can, you know, by hammering at it, and pried out the lid.",
      "word_count": 34
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And she stuck her dirty finger into it, and she fed it to me.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "Because she said, you're the one that's dying.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "I want you to eat it.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "So it would make you strong.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "When this is very rich, greasy food went down my stomach, and I already had typhoid and dysentery, [PAUSES FOR 3 SECONDS] I got such diarrhea, that I couldn't even walk to the back of the barrack, or anything, you know?",
      "word_count": 41
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I was just a mess.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "So I went to hide in the barrack.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And my sister found me there later on, because first she was trying to talk to the liberators and get some information, and so forth.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But when she found me that bad, she saw that I was absolutely dying.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I was just really feverish and bad.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She dragged me outside the barracks so I would get some fresh air.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And she said, you stay here and don't move.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "I'm going to go and get you some help.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And she went crying, yelling, my sister is dying.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "Because she saw a Red Cross truck.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And she saw some guys with Red Cross armbands, you know, the liberators.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And she went.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "And she dragged one of them over to me.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And he said-- she said, you must take her first, because she's dying.",
      "word_count": 13
    }
  ],
