{
  "stem": "24411.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "The tree fell on this side, and the tree fell on the-- on the guy, and he was dead.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We buried him.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Very simple.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You dig a-- a-- a-- a hole, you put him in, and you put the-- the dirt on him, nothing else.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, there was a place.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Was a lot of people died over there.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "No, who did-- who knew this?",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Nobody.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "He took my place.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "A-- a saw.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Where you saw-- two people have to stay and saw.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And like you say, a hack, you know, when you cut something.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I don't know how do you say it here.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "There's a wooden handle and a sharp.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And you-- before you-- before you cut a little bit the tree.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And then you've got to saw.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "If not, you can't put the saw in.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And then there's another-- other people stay and cut the tree, the branches with a little hack, with a little thing, and they cut off all the branches.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And there's people with horses and with rope or chains.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And they put the trees with the chains to the horse, and they took him on some-- on a place.",
      "word_count": 20
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "Someplace else.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, to the-- there was a big [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And they put there, it was laid like slabs of wood, and they put it, and this was flown away.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "I don't know where that this went.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "When was-- when we went it was dark, when we came home, it was dark.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Not far.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Everything was in one place.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Not far.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "But in the summertime, it was better.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "But the ants ate us up.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Ants.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "The mosquitoes.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was wearing a little bit, you know, the muslin over your face.",
      "word_count": 13
    }
  ],
