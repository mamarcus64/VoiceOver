{
  "stem": "26888.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "It was wonderful people-- good people.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Well, I know Jews were 20,000-- 20,000 Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "But the other in the population, I don't remember exactly.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It's probably more, because it's-- mind you, Munkacs was a very Jewish place.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "There was a lot of Jews-- 20,000 Jews-- that's, I mean-- [PAUSES FOR 4 SECONDS] and, you know, and most people were religious.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, we were spread.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have a ghetto, no.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "We were like neighbors who wasn't Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Then we had maybe, in the other, and there was a lot of non-Jewish in our street.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "There was a lot of non-Jewish people, too.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 5 SECONDS] I don't know.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We kept together-- kept together, even though we were very Orthodox.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "But it didn't make a difference.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I had friends who weren't Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "They used to come in my house.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "I used to go to their house, I don't think I knew that I'm not allowed to eat there, except the fruit.",
      "word_count": 22
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't mind that.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "We used to play together-- I mean, we were younger.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, we used to skate, we used to, in the wintertime, We used to do all kind of things for children-- doing jumping, doing, you know-- I mean, that was when I was younger.",
      "word_count": 34
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And after that, oh my god, after that, you know, it was like, we were very busy with school.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "We had a whole day school.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "There was no time in middle of the week to much of a friendship.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Well, we had one worker who lived with us.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "He was the head of the business there.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "He used to live with us, also.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "But he had-- we had like a summer kitchen, and most of the time he was there.",
      "word_count": 17
    }
  ],
