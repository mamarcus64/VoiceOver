{
  "stem": "23278.4",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "And her mother had remained in the insane asylum in Dijon.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And before Rita left, I told her, Rita, I'm going to go see your mother when I go back to Dijon for school.",
      "word_count": 23
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I'm going to go visiting her.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And Rita says-- and she heard me.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "She said don't bother.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "We have many friends.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "You don't have to go to see my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And I was hurt.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "But I went back to Dijon, and me being me at the time of the-- their Reformation, the last Sunday of October, I thought of her.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "And I said, I'm going to go see Rita's mother.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So I took my bike again, my good old bike.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The tires were like onion skins.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I was always having flat tires.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I went to the [INAUDIBLE], as it was called.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And that I saw the sister.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "The sister was a young woman from Belgium.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "She had the face of an angel.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "She was so good, so nice.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And I said, I come to see Madame Thalmann.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "Oh, she said, that's nice.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I said, she had many visitors?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "She said no, you are the first one.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "I couldn't believe it.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "I said, you mean nobody came to see her since last spring?",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "She said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "You are the first one.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "So after that, I went to see her every Saturday when I didn't have school.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And Rita's mother was insane.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "She spoke in Switzerdeutsch, which I did not understand, and Yiddish, in which I made huge progress, which helped me a lot when I came to America.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And German, of course.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And she mistook me for her daughter.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And we would walk in that cold park in the winter.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "She had this thin coat.",
      "word_count": 5
    }
  ],
