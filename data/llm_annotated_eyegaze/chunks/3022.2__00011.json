{
  "stem": "3022.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "The labor camp in Pustkow at that time-- the labor consisted of building barracks.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "We did not know at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "But later on, in that particular area, they built prototypes for V1.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "And they, they had about 40,000 of Russian prisoners of war in that particular camp later.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 24,
      "text": "But we were, at that time, building barracks.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 25,
      "text": "And the labor was very hard.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 26,
      "text": "Conditions were very difficult.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 27,
      "text": "And we worked under the supervision of Polish civilian workers who used to come in the morning and leave in the evening.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 28,
      "text": "And I made the decision one day that I'm going to walk out from this camp.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So our clothing, our jackets were painted with a, with a yellow stripe and a KL sign on it which indicated it was konzentrationslager or arbeitslager.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And so I hid my jacket, and I stole a jacket from a Polish worker.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And a couple days later, I stole a [? mess kit. ?] And I [? pulled ?] [? out ?] the jacket and [? the mess kit ?] and I walked out with the Polish workers.",
      "word_count": 36
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They checked their papers, you know, every fourth, fifth man.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And it was just a question of whether I'd be lucky enough or not.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "And I was able to walk out.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I had no money because they took all your possessions away when you got to camp.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And I got on the, on the train to go back to Tarnow.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And I had to ride outside of the train so the conductor couldn't check my, my, my, my ticket.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And when I got to Tarnow, my father, during his travels, found a little village.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "He told us that he found a little village outside Sandomierz called Zawichost, where he felt we would be safer than in Tarnow.",
      "word_count": 23
    }
  ],
