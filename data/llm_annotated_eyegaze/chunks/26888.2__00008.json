  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "It was a place where they locked up people who did something.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "He didn't steal anything.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He didn't, but that was-- that was it.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And they didn't really work there.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "They just tortured him.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] After that, they decided to let him out, but there was already close to take away us, too.",
      "word_count": 22
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "Did you have contact with your father during the time that he was taken away?",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We sent him sometime a package.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "That, they let, send a package-- you know, food, something.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But that's it.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You couldn't go there and talk to him, or see him.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "They didn't let you.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "But he wanted to send a package, so they gave him less to eat.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "They  had to give him less to eat.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "That's why they send the package.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "I mean, what kind of food he had there?",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "The whole family was--",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "[SHAKES HEAD] You run out of life, and that's it.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE]",
      "word_count": 1
    }
  ],
