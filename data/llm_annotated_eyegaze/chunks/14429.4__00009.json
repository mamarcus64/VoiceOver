  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "He's now living in an adult home.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "Morris of-- with whom I'm separated-- by whom I'm separated lives in a senior citizen home in Long Beach, near the beach.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "He's quite well.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "He's on medication now.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "He's 82 years old.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 23,
      "text": "He's just fine.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 24,
      "text": "My son is about 15 minutes away from him.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 25,
      "text": "I go there every Saturday, pick up my son, pick up Morris.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 26,
      "text": "We all go together for lunch.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 27,
      "text": "And we go out together.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 28,
      "text": "I take my son on vacation by myself.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 29,
      "text": "And I give my son a good time when we're together.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 30,
      "text": "There no crying, nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 31,
      "text": "We just have a good time together.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 32,
      "text": "And this is really my life now.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 33,
      "text": "I have been on the job for 30 years as a bookkeeper.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 34,
      "text": "I work there part time.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 35,
      "text": "I work now two days a week.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 36,
      "text": "I love it there.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 37,
      "text": "I really like there.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 38,
      "text": "This is a home for me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 39,
      "text": "I'm home.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 40,
      "text": "I-- I tell them I come in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 41,
      "text": "I tell them I don't come in.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 42,
      "text": "They're glad when the come in. 30 years is a long time.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 43,
      "text": "My son and I have a wonderful relationship.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 44,
      "text": "We talk only three times a day.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 45,
      "text": "He calls me Mutzi Putz.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 46,
      "text": "So how are you [?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 47,
      "text": "Kinderlei? ?] He says to me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 48,
      "text": "He's cute.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 49,
      "text": "We have a good time together.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 50,
      "text": "He's happy.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 51,
      "text": "He does, however, tell me, Mom, I cannot live without you.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 52,
      "text": "And that hurts.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 53,
      "text": "But if something happens to me, I have two fabulous nieces, Renee and Linda, whom you're going to meet.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 54,
      "text": "Should something happened to me, they will take over.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 55,
      "text": "They grew up together.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 56,
      "text": "They're very close.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 57,
      "text": "They love my son.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 58,
      "text": "And he loves them.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 59,
      "text": "Finally, [PAUSES FOR 4 SECONDS] I want to say that I'm glad in a way I did this.",
      "word_count": 18
    }
  ],
