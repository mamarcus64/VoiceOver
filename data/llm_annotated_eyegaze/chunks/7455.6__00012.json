{
  "stem": "7455.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "She said, somebody is here to see you.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 26,
      "text": "So Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 27,
      "text": "Popel, a attractive woman in her 50s, came out.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 28,
      "text": "And she invited me in.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 29,
      "text": "I said, I bring regards from Lydia.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 30,
      "text": "And so on.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 31,
      "text": "I cannot talk to her.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 32,
      "text": "The maid is listening.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 33,
      "text": "She recognized.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 34,
      "text": "She said, Hania, make coffee for us.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 35,
      "text": "And I told her.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 36,
      "text": "And she-- my-- Mrs.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 37,
      "text": "Lydia told me, tell her the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 38,
      "text": "Don't lie to her.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So I told her.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And she said, you poor thing, so young.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "You have to fight for your life.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I'm going to see what I can do.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And she made me something to eat.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "She took me in.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "She said, don't tell-- Hania shouldn't hear it.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And then she decided she's going to look for something for work for me.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The next day-- her husband came home.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Quiet man.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "A veterinarian, I said.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "The next day, he was going to farms where he inspects the cattle and things.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "He travels.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He comes and goes.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "We went out to look, through her friends to look if somebody needs some work.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "There were promises, but nothing particular.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "Two days passed.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "On a third day, I-- we are coming home from some-- there was a prospect that there's a woman that needs, but she was not at home.",
      "word_count": 27
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "Wiener needs somebody.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "So we'll go tomorrow.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "As we were walking up the steps, we hear German voices.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "Immediately, it's danger, and I run back.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "I run out into the street.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "Popel went upstairs to her apartment, and she saw the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "And she-- they were looking for a Jewish girl.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "They-- they were told that there's a Jewish girl working here, by her-- in her employment.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "Hania did not speak German, to my luck.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "She could not say anything.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "So Mrs.",
      "word_count": 2
    }
  ],
